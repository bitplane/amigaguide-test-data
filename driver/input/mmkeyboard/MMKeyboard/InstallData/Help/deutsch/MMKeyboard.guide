@{"Drucken" link "PICCPrin"}
@{"Unterbrechen" link "PICCBrea"}
@{"Control rechts" link "PICCRCTR"}
@{"Pos1" link "PICCHome"}
@{"Ende" link "PICCEndd"}
@{"Bild Hoch" link "PICCPaUp"}
@{"Bild Runter" link "PICCPaDo"}
@{"Num Lock" link "PICCNuLo"}
@{"Caps Lock" link "PICCCaLo"}
@{"Hilfetaste" link "PICCHELP"}
@{"Alt<>Win tauschen" link "PICCALTT"}
