@node "MAX232" "Beschaltung des MAX232"

 @{b}MAX232@{ub}

 Beschaltung:

                    ---------------
                  1|               |2              C1...C4  22uF/16V
              ,----|C1+         V+ |-----.
             +|    |               |     |+
         C1  ===   |               |    ===   C3
              |   3|               |16   |
              `----|C1-        Vcc |-----o-------  5V
                  4|               |15
              ,----|C2+        Gnd |-----o-------  GND
             +|    |               |     |+
         C2  ===   |               |    ===   C4
              |   5|               |6    |
              `----|C2-         V- |-----´
                   |               |
                   |               |
                 11|               |14
             -->---|T1in     T1out |----->
        Eingang    |               |       Ausgang
                 10|               |7
             -->---|T2in     T2out |----->
                   |               |
  TTL/             |               |                RS-232
   CMOS            |               |                (+/-12V)
                   |               |
                 12|               |13
             <-----|R1out     R1in |---<---
        Ausgang    |               |       Eingang
                  9|               |8
             <-----|R2out     R2in |---<---
                   |               |
                    ---------------
@endnode

