@NODE MN_PROJECT "Menu Project"

        @{b}Project@{ub}

@{i}Project@{ui} contains the basic operation you need: loading and saving configurations, information, and, of course, quitting the program.

Project    »
	@{"New    " link MN_NEW}
	@{"Open  »" link MN_OPEN}
		@{"Coordinates.." link MN_OP_COORDINATES}
		@{"Colors..     " link MN_OP_COLORS}
