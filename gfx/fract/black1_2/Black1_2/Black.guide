@node usage "Usage"

	@{b}Usage@{ub}

	Menus:
		@{"Fractal " link fractal}
		@{"Settings" link settings}

	Mouse:
		@{"Mouse   " link mouse}
@endnode


@node fractal "Fractal"

	@{b}Fractal@{ub}

	Load              - Loads a coordinates file.
                         If the coordinate file has an icon,
                         the picture is loaded directly.


	Save              - Saves a coordinates file.


	Render            - Renders the fractal in final mode,
	                    and saves it as an iff file.


	About             - Displays the about requester.


	Quit              - Terminates Black :-(.
@endnode


@node settings "Settings"

	@{b}Settings@{ub}

	Period            - Determines how often the colour will
	                    change from black to white, low value
	                    many shifts.

	Iterations        - Determines the precision of the
	                    calculations, high value high
	                    precision.


	Icon for savefile - If an icon should be written for the
	                    save file or not.

	Icon for picture  - If an icon should be written for the
	                    rendered picture or not.


	Icon width        - Determines the width of the icon.

	Icon height       - Determines the height of the icon.


	Picture width     - Determines the width of the picture.

	Picture height    - Determines the height of the picture.
@endnode


@node mouse "Mouse"

	@{b}Mouse@{ub}

	The mouse is used for zooming in and out.

	When you click in the window, and drag the mouse, a box will be drawn. When you release the mousebutton again, a requester will ask you if you want to zoom in, out or cancel.
@endnode
