@node Project "Project"
The Project Menu has the following four menu items:

 @{" About" link About}
 @{" Redraw(Same P) " link Redraw}
 @{" Save Image (bmp)" link Save}
 @{" Save Image (iff)" link SaveIff}
 @{" Save Parm " link SaveP}
 @{" Load Parm " link LoadP}
 @{" Quit " link Quit}


@endnode

