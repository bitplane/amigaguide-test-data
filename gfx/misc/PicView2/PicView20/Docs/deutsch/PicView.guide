@{"Auswahl Speichern" Link "SaveSel"}  @{"----------------------" Link ""      }  @{"--------------" Link ""           }
@{"Speichern als IFF" Link "SaveIFF"}  @{"Ansehen               " Link "Show"  }  @{"Sortieren     " Link "ListSort"   }
