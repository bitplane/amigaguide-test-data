@node Main "Image Descriptor Arexx Commands"

    Select Command:

	@{" FileComment          " link rx.fcomment }
	@{" GetFileName          " link rx.getfname }
	@{" GetImageType         " link rx.getitype }
	@{" GetInfo              " link rx.getinfo } 
	@{" Hide                 " link rx.iconify }
	@{" IsImageInBuffer      " link rx.buffer }
	@{" LoadImage            " link rx.load }
	@{" FreeBuffer           " link rx.panic }
	@{" PasteImage           " link rx.paste }
	@{" Request              " link rx.request }
	@{" SaveImage            " link rx.save }
	@{" SetInfo              " link rx.setinfo } 
	@{" Show                 " link rx.uniconify }
	@{" Version              " link rx.version }
	@{" Quit                 " link rx.quit }

    If you think that something is missing or you have
    an idea for suberb command, @{"Click here !" link rx.new}
@endnode
@node rx.fcomment "FileComment"

FileComment

	@{B}FORMAT@{UB}
		FileComment COMMENT,CLEAN/S,IMAGE/S,NONE/S

	@{B}FUNCTION@{UB}
		Sets file comment type. Only one of above can be
		set.

	@{B}INPUTS@{UB}

		COMMENT		Textual comment specified by user.

		CLEAN		Remove file comment if present

		IMAGE		Write file comment based on image
				info

		NONE		Dont write file comment at all.

	@{B}RESULT@{UB}
		None.

@endnode
@node rx.quit "Quit"

Quit

	@{B}FORMAT@{UB}
		Quit

	@{B}FUNCTION@{UB}
		Quits the program.

	@{B}INPUTS@{UB}
		None.

	@{B}RESULT@{UB}
		None.

@endnode
@node rx.getfname "GetFileName"

GetFileName

	@{B}FORMAT@{UB}
		GetFileName

	@{B}FUNCTION@{UB}
		Get name of image loaded into buffer.

	@{B}INPUTS@{UB}
		None.

	@{B}RESULT@{UB}
		RESULT = string contains file name
@endnode
@node rx.getitype "GetImageType"

GetImageType

	@{B}FORMAT@{UB}
		GetImageType

	@{B}FUNCTION@{UB}
		Get type of image loaded into buffer.

	@{B}INPUTS@{UB}
		None.

	@{B}RESULT@{UB}
		RESULT = string contains image type (ie."ILBM")
@endnode
@node rx.getinfo "GetInfo"

GetInfo

	@{B}FORMAT@{UB}
		GetInfo TITLE/S,AUTHOR/S,COPYRIGHT/S,COMMENT/S

	@{B}FUNCTION@{UB}
		Gets image description. Only one of above can be
		specified.

	@{B}INPUTS@{UB}
		TITLE		Image title.

		AUTHOR		Image author.

		COPYRIGHT	Copyrights notice.

		COMMENT		Misc comment.

	@{B}RESULT@{UB}
		RESULT = string contains one of above infos.

@endnode
@node rx.iconify "Iconify"

Hide

	@{B}FORMAT@{UB}
		Hide

	@{B}FUNCTION@{UB}
		Iconifies main window. (buffer will not be flushed)

	@{B}INPUTS@{UB}
		None.

	@{B}RESULT@{UB}
		None.
@endnode
@node rx.buffer "IsImageInBuffer"

IsImageInBuffer

	@{B}FORMAT@{UB}
		IsImageInBuffer

	@{B}FUNCTION@{UB}
		Check if there is an image loaded into buffer.

	@{B}INPUTS@{UB}
		None.

	@{B}RESULT@{UB}
		RC = TRUE or FALSE
@endnode
@node rx.load "LoadImage"

LoadImage

	@{B}FORMAT@{UB}
		LoadImage NAME,SILENT/S

	@{B}FUNCTION@{UB}
		Load image into buffer.

	@{B}INPUTS@{UB}
		NAME		A full path of image to load,
				if not specified a file requester
				will popup.

				Works in iconified mode.

		SILENT		Disable ALL warning requesters.

	@{B}RESULT@{UB}
		None.
@endnode
@node rx.panic "Panic"

FreeBuffer

	@{B}FORMAT@{UB}
		FreeBuffer

	@{B}FUNCTION@{UB}
		Calls internal Panic rutine. :-)
		Buffer will be flushed, memory released and
		program will set all GUI pages to defaults.

	@{B}INPUTS@{UB}
		None.

	@{B}RESULT@{UB}
		None.

@endnode
@node rx.paste "Paste"

Paste

	@{B}FORMAT@{UB}
		PasteImage SILENT/S

	@{B}FUNCTION@{UB}
		Paste image from clipboard.

	@{B}INPUTS@{UB}
		SILENT		Disable ALL warning requesters.

	@{B}RESULT@{UB}
		None.
@endnode
@node rx.request "Request"

Request

	@{B}FORMAT@{UB}
		Request TEXT/A,GADGETS,ASL/S

	@{B}FUNCTION@{UB}
		Open info requester.

	@{B}INPUTS@{UB}
		TEXT		A requester text.

		GADGETS		A requester gadgets.
				If not specified then OK gadget
				will be used.

		ASL		Use ASL request instead of MUI.
				The difference is that ASL requester
				can appear in Iconified mode while MUI
				request cant.

	@{B}RESULT@{UB}
		None.
	@{B}EXAMPLE@{UB}
		Request '"Hello world" "Yeah|Cancel" ASL'

@endnode
@node rx.save "SaveImage"

SaveImage

	@{B}FORMAT@{UB}
		SaveImage NAME,SILENT/S,CLEANUP/S

	@{B}FUNCTION@{UB}
		Saves image from buffer to disk.

	@{B}INPUTS@{UB}
		NAME		Full path of image to save.
				If not specified the file requester
				will popup.

		SILENT		Disable ALL warning requesters.

		CLEANUP		Perform cleanup instead of save.

	@{B}RESULT@{UB}
		None.

@endnode
@node rx.setinfo "SetInfo"

SetInfo

	@{B}FORMAT@{UB}
		SetInfo TITLE/K,AUTHOR/K,COPYRIGHT/K,COMMENT/K

	@{B}FUNCTION@{UB}
		Sets image description. All of above can be
		specified.

	@{B}INPUTS@{UB}
		TITLE		Image title.

		AUTHOR		Image author.

		COPYRIGHT	Copyrights notice.

		COMMENT		Misc comment.


	@{B}RESULT@{UB}
		None.
@endnode
@node rx.uniconify "UnIconify"

Show

	@{B}FORMAT@{UB}
		Show

	@{B}FUNCTION@{UB}
		Uniconifies main window.

	@{B}INPUTS@{UB}
		None.

	@{B}RESULT@{UB}
		None.
@endnode
@node rx.version "Version"

Version

	@{B}FORMAT@{UB}
		Version FULL/S

	@{B}FUNCTION@{UB}
		Returns Image Descriptor  version info.

	@{B}INPUTS@{UB}
		FULL		Get full version not only
				version number.

	@{B}RESULT@{UB}
		RESULT = string contains version info

@endnode
@node rx.new "New command"

    If you have an idea for new command or some enhancements
    for one of available feel free to e-mail me.

	COMMAND NAME: 	..............
	FORMAT:		..............
	FUNCTION:	..............
	INPUT(S):	..............
	RESULT(S):	..............
	NOTE(S):	..............

    Write something similar to above and send to :
    @{B}vepar@friko6.onet.pl@{UB} or @{B}vepar@irc.pl@{UB}
@endnode
