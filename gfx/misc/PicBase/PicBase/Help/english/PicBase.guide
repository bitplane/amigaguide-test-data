@language "english"
@author "Christian Effenberger"
@copyright "® 2001 by Advanced Visions"
@annotation "PicBase« Executable"
@remark "Web-Picture-Cataloger for the Amiga«"
@index INDEX

@macro prog "@{b}P I C@{ub} @{fg shine}BASE@{fg text}"
@macro title "@{bg shine}       @{bg background} @{fg shine}@{bg shadow}  @{b}$1@{ub}  @{bg background}@{fg text}@{par}"
@macro block "        "
@macro idxclr "@{fg shine}@{bg fill}$1@{bg background}@{fg text}"
@macro idxstr "@{fg fill}@{bg shine} @{b}$1@{ub} @{bg background}@{fg text}"

@macro bold "@{b}$1@{ub}"
@macro italic "@{i}$1@{ui}"
@macro uline "@{u}$1@{uu}"
@macro white "@{fg shine}$1@{fg text}"
@macro black "@{bg shadow}$1@{bg background}"
@macro blue "@{b}@{fg fill}$1@{fg text}@{ub}"


