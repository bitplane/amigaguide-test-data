@node FORMAT3 "Video Codecs"
Video @{b}@{fg filltext} K O D I E R U N G E N@{fg text}

RLEx@{ub}  @{fg filltext}Run Lenght@{fg text}  x = 1,2,3,4,5,6,7,8 Bitplanes
                  x = 9 ~ EHB 6 Bitplanes
                  x = 0 ~ HAM 6/8 Bitplanes
                  x = A ~ 12 Bit Chunky 4096
                  x = B ~ 15 Bit Chunky 32 K
                  x = C ~ 16 Bit Chunky 64 K
                  x = D ~ 18 Bit Chunky 256 K
                  x = E ~ 21 Bit Chunky 2 M
                  x = F ~ 24 Bit Chunky 16 M@{b}

RGBx@{ub}  @{fg filltext}Raw Data@{fg text}    x = 4 ~ 12 Bit Chunky 4096
                  x = 5 ~ 15 Bit Chunky 32 K
                  x = 6 ~ 16 Bit Chunky 64 K
                  x = 7 ~ 18 Bit Chunky 256 K
                  x = 8 ~ 21 Bit Chunky 2 M
                  x = 9 ~ 24 Bit Chunky 16 M
                  x = 0 ~ 32 Bit Chunky 4 G@{b}

YUVx@{ub}  @{fg filltext}Component Data@{fg text}
                  x = 4 ~ 12 Bit Chunky 4096
                  x = 5 ~ 15 Bit Chunky 32 K
                  x = 6 ~ 16 Bit Chunky 64 K
                  x = 7 ~ 18 Bit Chunky 256 K
                  x = 8 ~ 21 Bit Chunky 2 M
                  x = 9 ~ 24 Bit Chunky 16 M
                  x = 0 ~ 32 Bit Chunky 4 G@{b}

DLTx@{ub}  @{fg filltext}Delta Data@{fg text}  x = H ~ Horizontal 32 Pixel
                  x = V ~ Vertical 32 Pixel
                  x = B ~ Blocks 8x8 Pixel
                  x = W ~ Blocks 16x16 Pixel
                  x = L ~ Blocks 32x32 Pixel
                  x = D ~ Blocks 64x64 Pixel@{b}

MPEG@{ub}  @{fg filltext}MPEG Data@{fg text}@{b}

JPEG@{ub}  @{fg filltext}JPEG Data@{fg text}@{b}

CUST@{ub}  @{fg filltext}CUSTOM Data@{fg text}

@endnode

