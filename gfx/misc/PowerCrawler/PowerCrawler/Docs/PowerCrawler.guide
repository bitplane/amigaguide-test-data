@PREV "MainMenuProject"
@NEXT "MainMenuSettings"
@TOC "ManualMenus"

	@{" Project " LINK "MainMenuProject"} @{BG FILL}@{" Mask " LINK "MainMenuMask"}@{BG BACKGROUND} @{" Settings " LINK "MainMenuSettings"} @{" Confirm " LINK "MainMenuConfirm"} @{" Loader " LINK "MainMenuLoader"} @{" Saver " LINK "MainMenuSaver"}

