@node "1" "XLToolkitGUI · Abspielen"

  »@{"  ABSPIELEN  " link ""}«@{"  Erstellen  " link "2"}@{"   Prüfen    " link "3"}@{"  Einfügen   " link "4"}@{" Extrahieren " link "5"}@{"  Entfernen  " link "6"}

  @{b}Film Abspielen@{ub}

  @{" _/ " link ""}  @{fg highlight}eine eigene Palette für jedes Bild@{fg text} @{i}Voreingestellt, da das Format gar
                                            keine Information darüber enthält.@{ui}
  @{" _/ " link ""}  @{fg highlight}zeichne einen Rahmen um jedes Bild@{fg text} @{i}Hilft beim HAM-Format ausge-
                                            frannste Ränder zu vermeiden.@{ui}
  @{" _/ " link ""}  @{fg highlight}den Mauszeiger ausblenden@{fg text}          @{i}Voreingestellt, da unnötig.@{ui}

  @{" 64  " link ""} @{fg highlight}Lautstärke (0 - 64)@{fg text}                @{i}Lautstärkeregelung.@{ui}

  @{" 150 " link ""} @{fg highlight}Geschwindigkeit Kb/Sek.@{fg text}            @{i}Die Geschwindigkeit errechnet sich aus
                                            der ChunkGröße x Bilder pro Sekunde.@{ui}
  @{"  1  " link ""} @{fg highlight}Anzahl der Durchläufe@{fg text}              @{i}0 bedeutet Endlos.@{ui}


    USAGE: cdgsxl FROM/A,X/K/N,Y/K/N,VOL/K/N,VIEW/S,BLIT/S,BACK/K,MULTIPAL/S,XLSPEED/K/N,
    NOXLEEC/S,XLPAL/S,LACE/S,NONLACE/S,HIRES/S,LORES/S,BOXIT/S,SDBL/S,NTSC/S,PAL/S,DEFMON/S,
    NOPOINTER/S,XLMODEID/S,ENDDELAY/K/N,LOOP/K/N,CDXL/S,DOSXL/S,NOPROMOTE/S,LMBABORT/S,
    RMBABORT/S,FIREABORT/S,MSGPORTNAME/K,HAM/S,NONHAM/S,EHB/S,NONEHB/S,PATCHOPENWB/S

    FROM/A = CDXL-File [Path- and/or FileName]
    X/K/N = LeftEdge in Pixel (Default is CENTER)
    Y/K/N = TopEdge in Pixel (Default is CENTER)
    VOL/K/N = SoundVolume [0-64] (Default is 64)
    VIEW/S = Open on View is ON (Default is SCREEN)
    BLIT/S = Blit to Display is ON (Default is NON BLIT)
    BACK/K = BackdropILBM [Path- and/or FileName] (Implies BLIT ON)
    MULTIPAL/S = MultiPalette is ON (Default is FIXED PALETTE)
    XLSPEED/K/N = PlaybackSpeed [n] (Default is 75) [Blocks per Sec. (2048 Bytes)]
    XLPAL/S = Use CDXLPALETTE (Default is BACKDROPILBMPALETTE if BACK is ON)
    BOXIT/S = Draw a Box in Color 0 around Image (Default is OFF)
    NTSC/S = NTSC MonitorID is USED (Default is CDXL- or ILBMSETTING)
    PAL/S = PAL MonitorID is USED (Default is CDXL- or ILBMSETTING)
    DEFMON/S = DEFAULT MonitorID is USED (Default is CDXL- or ILBMSETTING)
    NOPOINTER/S = MousePointer is OFF (Default is ON)
    XLMODEID/S = Use CDXLMODEID (Default is BACKDROPILBMMODEID if BACK is ON)
    ENDDELAY/K/N = In Frames [n] per Second (PAL Default 50 FPS, NTSC Default 60 FPS)
    LOOP/K/N = Number of PlayLoops [1-???|-1~Infinite] (Default is 1)
    NOPROMOTE/S = NOPROMOTION of ModeID is ON (Default is OFF)
    LACE/S = Interlace Display is ON (Default is CDXL- or ILBMSETTING)
    NONLACE/S = NonInterlace Display is ON (Default is CDXL- or ILBMSETTING)
    HIRES/S = Hires Display is ON (Default is CDXL- or ILBMSETTING)
    LORES/S = Lores Display is ON (Default is CDXL- or ILBMSETTING)
    HAM/S = HAM Display is ON (Default is CDXL- or ILBMSETTING)
    NONHAM/S = NONHAM Display is ON (Default is CDXL- or ILBMSETTING)
    EHB/S = EHB Display is ON (Default is CDXL- or ILBMSETTING)
    NONEHB/S = NONEHB Display is ON (Default is CDXL- or ILBMSETTING)

@endnode

@node "2" "XLToolkitGUI · Erstellen"

  @{"  Abspielen  " link "1"}»@{"  ERSTELLEN  " link ""}«@{"   Prüfen    " link "3"}@{"  Einfügen   " link "4"}@{" Extrahieren " link "5"}@{"  Entfernen  " link "6"}

  @{b}Film Erstellen@{ub}

  @{fg highlight}@{" _/ " link ""} interleaved @{" _/ " link ""} AVM@{fg text}  @{i}HÄNDE WEG: kann sowieso kein Player abspielen.@{ui}

  @{" _/ " link ""}  @{fg highlight}HAM@{fg text}                  @{i}VORSICHT: 6 Bitplanes interpretiert MultiView immer als
                              HAM6. Also mit MultiView kein EHB und keine 64 Farben.@{ui}
  @{"     " link ""} @{fg highlight}Name des Films@{fg text}       @{i}Wie soll der Film heißen?.@{ui}

  @{"     " link ""} @{fg highlight}Basisname der Bilder@{fg text} @{i}Wie heißt das erste Bild? (Durchnummeriert!)@{ui}

  @{"  2  " link ""} @{fg highlight}Anzahl der Bilder@{fg text}    @{i}Ist wohl selbsterklärend.@{ui}

  @{"  0  " link ""} @{fg highlight}Audio bytes/Bild@{fg text}     @{i}Die Anzahl der Bytes errechnet sich
                              aus Tonfrequenz / Bilder pro Sekunde.@{ui}
  @{"  0  " link ""} @{fg highlight}Pad bytes pro Bild@{fg text}   @{i}BEDEUTUNGSLOS: kann sowieso kein Player nutzen.@{ui}


    USAGE: XLMAKE [options] [<IFFFile> [<IFFFile>...]] <CDXLFile>
     -f<n>  frame number,                        Example: -f45
     -a<n>  allocate audio track in bytes/frame, Example: -a2048
     -p<n>  pad frame <n> bytes,                 Example: -p24
     -b<f>  use base file instead,               Example: -bIFFFile.0001
     -i     store image data interleaved
     -h     IFFFiles are HAM
     -d     IFFFiles are Advanced Video Mode

@endnode

@node "3" "XLToolkitGUI · Prüfen"

  @{"  Abspielen  " link "1"}@{"  Erstellen  " link "2"}»@{"   PRÜFEN    " link ""}«@{"  Einfügen   " link "4"}@{" Extrahieren " link "5"}@{"  Entfernen  " link "6"}

  @{b}Film Prüfen@{ub}

  @{" _/ " link ""}  @{fg highlight}Untersuche Alles@{fg text}      @{i}Also alle vorhandenen Bilder.@{ui}

  @{" _/ " link ""}  @{fg highlight}Ignoriere Fehler@{fg text}      @{i}Tun wir Das nicht Alle!@{ui}

  @{"     " link ""} @{fg highlight}Name des Films@{fg text}        @{i}Welcher Film soll es den sein?@{ui}

  @{"  1  " link ""} @{fg highlight}von diesem Bild@{fg text}       @{i}Das ERSTE zu prüfende Bild.@{ui}

  @{"  1  " link ""} @{fg highlight}bis zu diesem Bild@{fg text}    @{i}Das LETZTE zu prüfende Bild.@{ui}

  @{b}Film Säubern@{ub}

  @{"     " link ""} @{fg highlight}der zu säubernde Film@{fg text} @{i}Welcher Film soll den gesäubert werden?@{ui}

  @{"     " link ""} @{fg highlight}der gesäuberte Film@{fg text}   @{i}Wie soll der gesäuberte Film den heißen?@{ui}


    USAGE: XLINFO [options] <CDXLFile>
     -w     examine whole file
     -e     ignore size errors
     -a     produce table of audio size estimates
     -a<n>  estimate audio sizes for <n> only
     -f<n>  first frame to examine, Example: -f100
     -l<n>  last frame to examine,  Example: -l322

    USAGE: XLCLEAN <CDXLFile> [CDXLFileOut]

@endnode

@node "4" "XLToolkitGUI · Einfügen"

  @{"  Abspielen  " link "1"}@{"  Erstellen  " link "2"}@{"   Prüfen    " link "3"}»@{"  EINFÜGEN   " link ""}«@{" Extrahieren " link "5"}@{"  Entfernen  " link "6"}

  @{b}Ton Einfügen@{ub}

  @{"     " link ""} @{fg highlight}Name des Films@{fg text}          @{i}Welcher Film soll den vertont werden?@{ui}

  @{"     " link ""} @{fg highlight}Name der Tondatei@{fg text}      @{i}Wie heißt den die Tondatei für den Film?@{ui}

  @{"  0  " link ""} @{fg highlight}Audio bytes/Bild@{fg text}       @{i}Wie viele bytes pro Bild sind denn vorgesehen?@{ui}

  @{b}Film Einfügen@{ub}

  @{"     " link ""} @{fg highlight}hier ab dem Bild@{fg text}       @{i}Der Film in den eingefügt wird?@{ui}

  @{"     " link ""} @{fg highlight}diesen Film einfügen@{fg text}   @{i}Der Film der eingefügt wird?@{ui}

  @{"     " link ""} @{fg highlight}Name der Ausgabe-Datei@{fg text} @{i}Wie soll der zusammengefügte Film den heißen?@{ui}


    USAGE: XLAUDIO [options] <IFFfile> <CDXLFile> [<CDXLFileOut>]
     -p     preserve audio compression
     -a<n>  allocate audio track in bytes/frame, Example: -a2048
     -i     insert audio into existing track (no output file)
     -e     ignore audio size errors when inserting

    USAGE: XLJOIN [options] <CDXLFileIn> [<CDXLFileIn>...] <CDXLFileOut>
     -i<n>  insert into first file at frame #, Example: -i100

@endnode

@node "5" "XLToolkitGUI · Extrahieren"

  @{"  Abspielen  " link "1"}@{"  Erstellen  " link "2"}@{"   Prüfen    " link "3"}@{"  Einfügen   " link "4"}»@{" EXTRAHIEREN " link ""}«@{"  Entfernen  " link "6"}

  @{"     " link ""} @{fg highlight}Name des Films@{fg text}         @{i}Aus welchem Film soll den was extrahiert werden?@{ui}

  @{"  1  " link ""} @{fg highlight}von diesem Bild@{fg text}       @{i}Das ERSTE Bild von dem etwas extrahiert wird.@{ui}

  @{"  1  " link ""} @{fg highlight}bis zu diesem Bild@{fg text}    @{i}Das LETZTE Bild von dem etwas extrahiert wird.@{ui}

  @{b}Film Extrahieren@{ub}
  @{"     " link ""} @{fg highlight}Name des Films@{fg text}         @{i}Wie soll der extrahierte Film den heißen?@{ui}

  @{b}Bild Extrahieren@{ub}
  @{"     " link ""} @{fg highlight}Basisname der Bilder@{fg text}  @{i}Wie heißt das erste zu extrahierende Bild?
                               (Name ohne Endung z.B. 'Bild')@{ui}
  @{b}Ton Extrahieren@{ub}
  @{"     " link ""} @{fg highlight}Name der Tondatei@{fg text}     @{i}Wie soll die extrahierte Tondatei den heißen@{ui}


    USAGE: XLCOPY [options] <CDXLFileIn> <CDXLFileOut>
     -f<n>  first frame,              Example: -f302
     -l<n>  last frame,               Example: -l322
     -n<n>  number of frames to copy, Example: -n20
     -s<n>  copy only single frame,   Example: -s10

    USAGE: XLIFF [options] <CDXLFile> [<IFFBaseFile>]
     -u     produce uncompressed ILBMs
     -f<n>  first frame,              Example: -f302
     -l<n>  last frame,               Example: -l322
     -n<n>  number of frames to copy, Example: -n20

    USAGE: CDXL28SVX ? | <CDXLFile> <8SVXoutFile> [-I] [-S<n>] [-E<n>] [-F<n>] [-N] [-M]
     ...extracts the Sound from a CDXL-file.
     ...CDXLFile is a regular CDXL-anim including sound.
     ...8SVXoutFile is the written iff sound-file.
     -I ask you interactive about -S, -N and -F.
     -S<n> is the first frame to extract.
     -E<n> is the last frame to extract.
     -F<n> is frames per second.
     -N flag will not generate a icon
     -M flag will generate a MagicWb icon if -N is not set

@endnode

@node "6" "XLToolkitGUI · Entfernen"

  @{"  Abspielen  " link "1"}@{"  Erstellen  " link "2"}@{"   Prüfen    " link "3"}@{"  Einfügen   " link "4"}@{" Extrahieren " link "5"}»@{"  ENTFERNEN  " link ""}«

  @{b}Bild Entfernen - entweder so@{ub}

  @{"  1  " link ""} @{fg highlight}von diesem Bild@{fg text}        @{i}Das ERSTE zu entfernende Bild.@{ui}

  @{"  1  " link ""} @{fg highlight}bis zu diesem Bild@{fg text}     @{i}Das LETZTE zu entfernende Bild.@{ui}

  @{b}oder so@{ub}

  @{"  0  " link ""}  @{fg highlight}vom@{fg text}  @{" Start " link ""}         @{i}Anzahl der Bilder die vom ANFANG aus entfernt werden sollen.@{ui}

  @{b}oder so@{ub}

  @{"  0  " link ""}  @{fg highlight}vom@{fg text}  @{" Ende  " link ""}         @{i}Anzahl der Bilder die vom ENDE aus entfernt werden sollen.@{ui}

  @{b}oder so@{ub}

  @{fg highlight}jedes  @{"  0  " link ""}  Bild@{fg text}           @{i}Jedes wievielte Bild soll entfernt werden sollen?@{ui}

  @{b}Bild Entfernen@{ub} · @{b}Ton Entfernen@{ub}

  @{"     " link ""} @{fg highlight}Name des Films@{fg text}         @{i}Wie soll der Film aus dem etwas entfernt wird heißen?@{ui}

  @{"     " link ""} @{fg highlight}Name der Ausgabe-Datei@{fg text} @{i}Wie soll der Film aus dem etwas entfernt wurde heißen?@{ui}


    USAGE: XLTRIM [options] <CDXLFileIn> <CDXLFileOut>
     -b<n>  remove <n> frames from beginning,    Example: -b20
     -e<n>  remove <n> frames from end,          Example: -e30
     -f<n>  remove from frame number...
     -l<n>  to frame number,                     Example: -f80 -l90
     -n<n>  remove <n> frames,                   Example: -n10
     -a     remove audio
     -d<n>  delete every <n>th frame,            Example: -d2
     -m<n>  max number of frames,                Example: -m500
     -t<n>  max time of frames in seconds,       Example: -t85

@endnode

@node GENERAL
@title "Allgemeine Bedienungsführung"

  @{b}Liste der Filme@{ub}
  Ein DoppelKlick auf einen Listeneintrag ermittelt wichtige Informationen
  über den Film, die unter anderem auf der rechten Seite als Text angezeigt
  werden, und mittels diverser Knöpfe (siehe SymbolKnöpfe) übernommen und
  weiter benutzt werden können.

  @{" Film.CDXL " link ""} Der aktuelle Film. Ein Klick auf diesen Knopf bewirkt das
               Gleiche, als ob Sie einen DoppelKlick auf einen Listeneintrag
               und danach auf den Knopf 'Film Abspielen' ausführen würden.

  @{" Einfügen  " link ""} Sie können per DateiRequester Filme in die Liste einfügen,
               oder indem Sie eine Datei in das Fenster ziehen (AppWindow).
  @{" Entfernen " link ""} Sie können Filme aus der Liste auch wieder entfernen


  @{b}Informationen zum Film@{ub}

  Dieser Bereich ist wohl selbsterklärend


  @{b}Die SymbolKnöpfe@{ub}

  @{" < " link ""} der Pfeil nach LINKS bewirkt die Übernahme des nebenstehenden Eintrages in die Liste
  @{" > " link ""} der Pfeil nach RECHTS bewirkt die Übernahme als nebenstehenden Eintrag aus der Liste
  @{" | " link ""} der Pfeil nach UNTEN bewirkt die Anzeige der nebenstehenden Datei per MultiView
  @{" · " link ""} das Dateisymbol bewirkt die Auswahl einer Datei per DateiRequester


  @{b}Die Menüs@{ub}

    @{fg shadow}@{bg shine}@{b} Projekt @{ub}@{bg background}@{fg text}

    @{fg shadow}@{bg shine} Liste laden...     @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} L @{fg text}@{bg background} - Eine FilmListe wird eingeladen (ASCII&FTXT)
    @{fg shadow}@{bg shine} Liste anhängen...  @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} A @{fg text}@{bg background} - Eine FilmListe wird abgehängt (ASCII&FTXT)
    @{fg shadow}@{bg shine} Liste speichern... @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} S @{fg text}@{bg background} - Die FilmListe wird abgespeichert (FTXT)
    @{fg shadow}@{bg shine}~~~~~~~~~~~~~~~~~~~~~~~~~~~~@{fg text}@{bg background}
    @{fg shadow}@{bg shine} Liste sortieren    @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} M @{fg text}@{bg background} - Die FilmListe wird alphabetisch sortiert
    @{fg shadow}@{bg shine} Liste umdrehen     @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} R @{fg text}@{bg background} - Die FilmListe wird invertiert
    @{fg shadow}@{bg shine} Liste löschen      @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} C @{fg text}@{bg background} - Die FilmListe wird gelöscht
    @{fg shadow}@{bg shine}~~~~~~~~~~~~~~~~~~~~~~~~~~~~@{fg text}@{bg background}
    @{fg shadow}@{bg shine} Über XLToolskitGUI         @{fg text}@{bg background} - über das Programm
    @{fg shadow}@{bg shine} Über CanDo         @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} I @{fg text}@{bg background} - über die Lizenspolitik von CanDo
    @{fg shadow}@{bg shine} Hilfe              @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} H @{fg text}@{bg background} - ruft die Online AmigaGuide-Hilfe auf
    @{fg shadow}@{bg shine}~~~~~~~~~~~~~~~~~~~~~~~~~~~~@{fg text}@{bg background}
    @{fg shadow}@{bg shine}@{b} Beenden            @{fg shine}@{bg shadow}  A  @{ub}@{bg shine}@{fg shadow} Q @{fg text}@{bg background} - Beendet das Programm

    @{fg shadow}@{bg shine}@{b} Bilder pro Sek. @{ub}@{bg background}@{fg text}

    @{fg shadow}@{bg shine}    7.5   @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} 1 @{fg text}@{bg background}  Wenn Sie hier irgendwelche
    @{fg shadow}@{bg shine}    8     @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} 2 @{fg text}@{bg background}  Veränderungen vornehmen,
    @{fg shadow}@{bg shine}    9     @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} 3 @{fg text}@{bg background}  dann sollten Sie danach
    @{fg shadow}@{bg shine}    10    @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} 4 @{fg text}@{bg background}  einen DoppelKlick auf den
    @{fg shadow}@{bg shine}  * 12    @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} 5 @{fg text}@{bg background}  aktuellen Listeneintrag
    @{fg shadow}@{bg shine}    12.5  @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} 6 @{fg text}@{bg background}  machen.
    @{fg shadow}@{bg shine}    15    @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} 7 @{fg text}@{bg background}  Dadurch wird die richtige
    @{fg shadow}@{bg shine}    20    @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} 8 @{fg text}@{bg background}  Abspielgeschwindigkeit
    @{fg shadow}@{bg shine}    25    @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} 9 @{fg text}@{bg background}  automatisch ermittelt
    @{fg shadow}@{bg shine}    30    @{fg shine}@{bg shadow}@{b}  A  @{ub}@{bg shine}@{fg shadow} 0 @{fg text}@{bg background}  und übernommen.

@endnode

