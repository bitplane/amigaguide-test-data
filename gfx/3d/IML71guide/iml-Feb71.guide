@{b}Date:@{ub}         @{"Thu, 8 Feb 1996 20:38:25 +119304028 " link day.08 }
@{b}From:@{ub}         @{" Ing. Alexander Owen Wallace  " link from 0025} @{i}<awallace@alpha1.sal.uadec.mx> @{ui}
