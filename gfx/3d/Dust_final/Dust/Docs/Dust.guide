@NODE Befehle "4.4 Beschreibung aller Befehle"

 Die Befehle sind nach folgenden Themen geordnet:

  @{" 1. Laden und Speichern von Objekten                  " LINK cmds1}
  @{" 2. Modifizieren oder Erzeugen von Einzelobjekten     " LINK cmds2}
  @{" 3. Modifizieren oder Erzeugen von Objekt-Sequenzen   " LINK cmds3}
  @{" 4. Modifizieren von Objektattributen                 " LINK cmds4}
  @{" 5. Information zu bestimmten Objekt-Komponenten      " LINK cmds5}
  @{" 6. Funktionen für Programmierer                      " LINK cmds6}
  @{" 7. Verschiedene Funktionen (Fenster, Interface, ...) " LINK cmds7}

 Bemerkung: Befehlsbezeichner werden hier zur Hervorhebung groß geschrieben,
            in Dust müssen sie allerdings KLEIN angegeben werden.

@ENDNODE

@NODE cmds1 "1. Laden und Speichern von Objekten"
@{" EXTRACTGROUPOBJ   " LINK extractgroupobj} alle Objekte einer TDDD-Group in separate Layer laden
@{" FILETYPE          " LINK filetype} Objekt-Format einer Datei ausgeben
@{" JOINGROUPOBJ      " LINK joingroupobj} TDDD-group in ein einzelnes Objekt umwandeln
@{" LOAD              " LINK load} ein Object(TDDD/LW/VS/Particle-Format) laden
@{" LOADGROUPOBJ      " LINK loadgroupobj} Laden eines Objektes aus einer Objekt-Gruppe (TDDD-Group-Object)
@{" LOADSEQ           " LINK loadseq} eine Objekt-Sequenz laden (TDDD/LW/VS/Particle-Format)
@{" SAVE              " LINK save} Objekte speichern (im SFORMAT)
@{" SAVELW            " LINK savelw} Objekte im Lightwave-Format speichern
@{" SAVEMC4D          " LINK savemc4d} Objekte im MaxonCinema4D-Format speichern
@{" SAVEP             " LINK savep} Partikel-Objekte speichern (DUST-Format)
@{" SAVEPSEQ          " LINK savepseq} eine Partikel-Objekt-Sequenz speichern
@{" SAVEPOBJ          " LINK savepobj} Partikel-Objekte speichern (im SFORMAT)
@{" SAVESEQ           " LINK saveseq} eine Objekt-Sequenz speichern (im SFORMAT)
@{" SAVESPHERES       " LINK savespheres} ein sphere-object als TDDD-Group abspeichern (Besonders sinnvoll für Blob-Modellierung)
@{" SAVETDDD          " LINK savetddd} Objekte als Imagine-Objekte speichern
@{" SAVEVS            " LINK savevs} Objekte als Videoscape-Objekte speichern
@{" SHOWTDDD          " LINK showtddd} Zeigt die Hunks (Objekte) einer TDDD-Datei an
@ENDNODE

@NODE cmds2 "2. Modifizieren oder Erzeugen von Einzelobjekten"
@{" ADDFACE           " LINK addface} eine Fläche oder ein neues Object erzeugen
@{" ADDSGROUP         " LINK addsgroup} eine Fläche einer Subgroup zufügen/Subgroup erzeugen
@{" AXALIGN0          " LINK axalign0} setzen der Ausrichtung des lok. Objektkoord.-sys. auf 0,0,0
@{" AXPOS             " LINK axpos} Ändern der Position des lok. Objektkoord.-sys.
@{" AXSIZE            " LINK axsize} Ändern der Größe des lokalen Objektkoordinatensystems
@{" CDEFORM           " LINK cdeform} locale kontrollierte Metamorphose
@{" CDEFORMINTERP     " LINK cdeforminterp} locale kontrollierte Metamorphose mit Interpolation des Zielobjektes
@{" CENTERAXIS        " LINK centeraxis} lokales Koordinatensystem zentrieren
@{" CHECKOBJECT       " LINK checkobject} Objekt überprüfen und fehlerhafte Kanten, Flächen, Punkte löschen
@{" COPY              " LINK copy} Objekte kopieren
@{" COPYP             " LINK copyp} Partikel-Objekte kopieren
@{" COPYPPOS          " LINK copyppos} Partikel-Positionen kopieren (um ANIMP*FUNC zu kombinieren)
@{" COPYPROT          " LINK copyprot} Partikel-Drehwinkel kopieren (um ANIMP*FUNC zu kombinieren)
@{" COPYPSCL          " LINK copypscl} Partikel-Skalierungsfaktoren kopieren (um ANIMP*FUNC zu kombinieren)
@{" CUTSG             " LINK cutsg} Subgroup einschließlich Punkten, Flächen und Kanten löschen
@{" DISPLACE          " LINK displace} Displacement-Map (ähnlich wie Imagine's "Applique")
@{" DISTORT           " LINK distort} Objekte verbeulen
@{" EXPANDSG          " LINK expandsg} Subgroup um ihre Randflächen erweitern
@{" EXPLODE           " LINK explode} realistische Explosionen
@{" EXPLODEFRAME      " LINK explodeframe} realistische Explosionen
@{" EXTRACTSG         " LINK extractsg} neues Objekt nach Vorgabe einer Subgroup erzeugen
@{" FUNC              " LINK func} Punkte eines Objektes algorithmisch verändern
@{" INSERTPOINT       " LINK insertpoint} einen Punkt in eine Fläche einfügen (wie Imagine's "fracture")
@{" JOIN              " LINK join} zwei Objekte verbinden
@{" JOINP             " LINK joinp} zwei Partikel-Objekte verbinden
@{" JOINSGROUP        " LINK joinsgroup} zwei oder mehrere Subgroups verbinden
@{" KILL              " LINK kill} Objekte löschen
@{" KILLFREEPOINTS    " LINK killfreepoints} unbenutzte Punkte löschen
@{" KILLEDGE          " LINK killedge} Kanten löschen
@{" KILLFACE          " LINK killface} Flächen löschen
@{" KILLP             " LINK killp} Partikelobjekte löschen
@{" KILLPOINT         " LINK killpoint} Punkte löschen
@{" KILLSGROUP        " LINK killsgroup} eine oder mehrere Subgroups löschen
@{" LATTICE           " LINK lattice} Flächen extrudieren, um gitterähnliches Object zu erzeugen
@{" MERGE             " LINK merge} unnötige Punkte löschen (schnell)
@{" MORPHFRAME        " LINK morphframe} Dreiecks-Metamorphose
@{" O2P               " LINK o2p} Zwei Objekte in in Partikel-Objekt konvertieren
@{" O2S               " LINK o2s} Erzeugen eines sphere-objects
@{" P2O               " LINK p2o} ein Partikel-Objekt in ein normales Objekt konvertieren
@{" PMORPH            " LINK pmorph} Morph-Preprocessor
@{" POSITIVE          " LINK positive} Bewegen eines Objektes in den positiven Halbraum
@{" PPOSFUNC          " LINK pposfunc} Positionen der Partikel algorithmisch verändern
@{" PROTFUNC          " LINK protfunc} Drehwinkel der Partikel algorithmisch verändern
@{" PSCLFUNC          " LINK psclfunc} Skalierungsfaktoren der Partikel algorithmisch verändern
@{" PWAVE1DFRAME      " LINK pwave1dframe} Transversal-/Longitudinal- Partikel-Welle entlang der x-Achse
@{" PWAVE2DFRAME      " LINK pwave2dframe} Transversal-/Longitudinal- Partikel-Welle entlang der x-y-Ebene
@{" PWAVE3DFRAME      " LINK pwave3dframe} 3D-Partikel-Welle
@{" RANDOMPPOS        " LINK randomppos} Partikel-Position verändern
@{" RANDOMPROT        " LINK randomprot} Partikel-Drehwinkel verändern
@{" RANDOMPSCL        " LINK randompscl} Partikel-Größe verändern
