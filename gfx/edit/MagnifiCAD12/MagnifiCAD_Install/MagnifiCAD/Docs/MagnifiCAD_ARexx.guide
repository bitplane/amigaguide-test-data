@node "RX_ADDLAYER" "ARexx Command: ADDLAYER"

   @{b}ADDLAYER@{ub} [@{u}number@{uu}] [@{u}name@{uu}]

   Adds a layer to the current project. The layer
   number and name can be given as arguments. If no
   arguments are given, the layer will be given a
   number and name.

 @{fg shine}Arguments@{fg text}
 
   @{u}number@{uu}   Number of the new layer. If the layer
            number of a previously created layer
            is given, an error will be returned.
   
   @{u}name@{uu}     Name of the new layer. If the layer
            name of a previously created layer
            is given, an error will be returned.
 
 @{fg shine}Examples@{fg text}
 
   ADDLAYER
   ADDLAYER 'number=10'
   ADDLAYER 'name="Layer 2"'
   ADDLAYER 'number=10' 'name="This is a new layer"'
@endnode

@node "RX_BAR" "ARexx Command: BAR"

   @{b}BAR@{ub} [@{u}name@{uu}] [@{u}state@{uu}]

   Opens or closes the given bar.

 @{fg shine}Arguments@{fg text}
 
   @{u}name@{uu}     Name of the bar. Must be one of:
            
            TEXTINFO  - the TextInfo bar.
            COORDSNAP - the CoordSnap bar.
   
   @{u}state@{uu}    The action to perform on the bar.
            Must be one of:
            
            OPEN  - open the bar.
            CLOSE - close the bar.
 
 @{fg shine}Examples@{fg text}
 
   BAR OPEN TEXTINFO
   BAR CLOSE COORDSNAP
@endnode

@node "RX_CLOSE" "ARexx Command: CLOSE"

   @{b}CLOSE@{ub} [@{u}FORCE@{uu}]

   Closes the current project. If the project has
   been changed since last saving, a requester
   will ask if you want to save before closing.

 @{fg shine}Arguments@{fg text}
 
   @{u}FORCE@{uu}    Suppress the 'change'-requester, just
            close without saving the project.
   
 @{fg shine}Examples@{fg text}
 
   CLOSE
   CLOSE FORCE
@endnode

@node "RX_COPY" "ARexx Command: COPY"

   @{b}COPY@{ub} 

   Copy the selected elements (if any) to the
   Clipboard.
   
   If there are any elements in the Clipboard,
   they will be deleted.
   
 @{fg shine}Examples@{fg text}
 
   COPY
@endnode

@node "RX_CREATESYMBOL" "ARexx Command: CREATESYMBOL"

   @{b}CREATESYMBOL@{ub} [@{u}filename@{uu}]

   Saves the selected elements as a symbol in the file
   specified by the user.

 @{fg shine}Arguments@{fg text}
 
   @{u}filename@{uu} Name of the new symbol to be created.
            If this argument is not specified, a
            requester will be shown, asking the user
            to enter a name.
 
 @{fg shine}Examples@{fg text}
 
   CREATESYMBOL
   CREATESYMBOL 'table'
   CREATESYMBOL '"Table #2"'
@endnode

@node "RX_CUT" "ARexx Command: CUT"

   @{b}CUT@{ub} 

   Cuts the selected elements from the current
   project. The elements will be placed in the
   Clipboard buffer.
   
   The command 'PASTE' can be used to place the
   contents of the clipboard into the current
   project.

 @{fg shine}Examples@{fg text}
 
   CUT
@endnode

@node "RX_DELETE" "ARexx Command: DELETE"

   @{b}DELETE@{ub} [@{u}LAYER@{uu}] [@{u}x1@{uu} @{u}y1@{uu}] [@{u}x2@{uu} @{u}y2@{uu}]

   Deletes the layer or elements specified in the
   arguments. If no argument is given, this command
   deletes the currently selected elements.

 @{fg shine}Arguments@{fg text}
 
   @{u}LAYER@{uu}    Deletes the current layer.
   
   @{u}x1@{uu} @{u}y1@{uu}
            Specifying this one coordinate pair makes
            MagnifiCAD select the element (if any) that
            goes through the specified point, and
            deleting that element.
   
   @{u}x2@{uu} @{u}y2@{uu}
            Specifying a second coordinate pair makes
            MagnifiCAD select all elements within the
            rectangle enclosed by (x1,y1),(x2,y2), and
            deleting these elements.

 @{fg shine}Examples@{fg text}
 
   DELETE
   DELETE LAYER
   DELETE 0 0
   DELETE '-100' '50'
   DELETE '-100' '-100' '100 '100'
@endnode

@node "RX_DISPLAY" "ARexx Command: DISPLAY"

   @{b}DISPLAY@{ub} @{u}requester@{uu}

   Displays the specified requester on screen.

 @{fg shine}Arguments@{fg text}
 
   @{u}requester@{uu}   Must be one of these requester
               names (shows the given requester):
            
               ABOUT
               COLORSETTINGS
               ELEMENT
               GRIDSETTINGS
               LAYERS
               MACROSETTINGS
               PICKSETTINGS
               POLYSETTINGS
               PRINTSETTINGS
               PROJECT
               SCREENSETTINGS
               UNITSETTINGS
               VIEWS
               ZOOMSETTINGS
 
 @{fg shine}Examples@{fg text}
 
   DISPLAY ABOUT
   DISPLAY COLORSETTINGS
@endnode

@node "RX_DRAW" "ARexx Command: DRAW"

   @{b}DRAW@{ub} [@{u}type@{uu}] [@{u}coords@{uu}] [@{u}radius@{uu}]

   Draws an element of the given type with the given
   coordinates. If the element type is not given, the
   current drawing element tool will be used.

 @{fg shine}Arguments@{fg text}
 
   @{u}type@{uu}     Type of element to draw. This must be one
            of:
               
               POLYCURVE @{u}x1@{uu} @{u}y1@{uu} [@{u}xn@{uu} @{u}yn@{uu}]
               POLYLINE @{u}x1@{uu} @{u}y1@{uu} [@{u}xn@{uu} @{u}yn@{uu}]
               LINE @{u}x1@{uu} @{u}y1@{uu} @{u}x2@{uu} @{u}y2@{uu}
               POINT @{u}x1@{uu} @{u}y1@{uu} 
               RECTANGLE @{u}x1@{uu} @{u}y1@{uu} @{u}x2@{uu} @{u}y2@{uu}
               POLYFORM @{u}x1@{uu} @{u}y1@{uu} @{u}x2@{uu} @{u}y2@{uu}
               CIRCLE @{u}x1@{uu} @{u}y1@{uu} @{u}radius@{uu} 
               ELLIPSE @{u}x1@{uu} @{u}y1@{uu} @{u}x-radius@{uu} @{u}y-radius@{uu}
               ARC @{u}x1@{uu} @{u}y1@{uu} @{u}x2@{uu} @{u}y2@{uu} @{u}degrees@{uu}
               TEXT @{u}x1@{uu} @{u}y1@{uu} [@{u}text@{uu}]
               
            The element type chosen decides how the
            coords argument should be interpreted.
   
   @{u}coords@{uu}   Coordinates for the given element.
            (x1,y1) is the starting point for all
            elements. (xn,yn) are the next points,
            interpreted differently for each element
            type.
            
 
   @{u}radius@{uu}   Radius for the given element.
   
   @{u}degrees@{uu}  Degrees for an arc, measured from the
            starting point.
 
   @{u}text@{uu}     Text for the TEXT element.
        
 @{fg shine}Examples@{fg text}
 
   DRAW LINE 0 0 100 100
   DRAW CIRCLE 50 50 30
   DRAW TEXT 10 10 '"Title Text"'
@endnode

@node "RX_EXPLODE" "ARexx Command: EXPLODE"

   @{b}EXPLODE@{ub}

   Explodes (fragments) the currently selected
   elements (if any).
   
   The elements will be changed like this:
   
   POLYFORM - RECTANGLE - POLYCURVE
   CIRCLE   - ELLIPSE   - ARC
   
            explodes into
   
              POLYLINE
   
         which explode into
   
                LINE
   
 @{fg shine}Examples@{fg text}
 
   EXPLODE
@endnode

@node "RX_FAULT" "ARexx Command: FAULT"

   @{b}FAULT@{ub} @{u}error@{uu}

   Returns the error description for the error number
   supplied.
   
   NOT IMPLEMENTED YET (command will do nothing).

 @{fg shine}Arguments@{fg text}
 
   @{u}error@{uu}  Number of the error.  

 @{fg shine}Returns@{fg text}
   
   The command returns the error text.
      
 @{fg shine}Examples@{fg text}
 
   FAULT 10
@endnode

@node "RX_GET" "ARexx Command: GET"

   @{b}GET@{ub} @{u}var@{uu}

 @{fg shine}Alias@{fg text}
   
   GETATTR
 
   Gets the value of a specific variable in MagnifiCAD.

 @{fg shine}Arguments@{fg text}
 
   @{u}var@{uu}  Name of variable to get the contents of.
        Must be one of the variables in the table
        beneath: 
        
        @{"ARexx GET/SET Variables" LINK "Variables"}
 
 @{fg shine}Returns@{fg text}
   
   Returns the value of the given variable.
   
 @{fg shine}Examples@{fg text}
 
   GET color
   GETATTR printgrid
@endnode


@node "Variables" "ARexx: GET/SET Variables"

 @{u}Variable       Type    Returns                  @{uu}
        
 color          number  Current color
     
 colordepth     number  The depth of the screen
                        (number of bitplanes)

 colorvalue     number  The value of the current
                        color    

 copy           bool    The Self/Copy modifier

 createicons    bool    The Create Icons? Setting
                           
                        FALSE = No icons
                        TRUE = Create icons for files

 generate       number  The Generate modifier

 grid           bool    Grid
                        
                        FALSE = Off
                        TRUE  = On

 gridresolution number  Resolution of grid

 gridtype       number  Type of grid to draw
                        
                        0 = Dot
                        1 = Line

 hatch          number  Current Hatch

 layer          number  Number of current layer

 layername      string  Name of current layer

 layernumber    number  Number of current layer

 layerstate     bool    State of current layer
                        
                        FALSE = Hide
                        TRUE  = Show

 level          number  Current Topological Level
                        
                        0 = Element
                        1 = Line
                        0 = Point

 linestyle      number  Current Line Style
                        
                        0-7

 lineweight     number  Current Line Weight
                        
                        0-thin ->
                        3-very thick

 printaxis      bool    PrintAxis Setting
 
                        FALSE = No axis
                        TRUE  = Print Axis

 printborder    bool    PrintBorder Setting
 
                        FALSE = No border
                        TRUE  = Print a border on
                                each page

 printdirection number  Direction of printing
                        
                        0 = Portrait
                        1 = Landscape

 printgrid      bool    PrintGrid Setting
                        
                        FALSE = No grid
                        TRUE  = Print the grid

 printscale     number  Scale of printed drawing
                        
                        1+

 printtype      number  Type of printout
                        
                        0 = Extents
                        1 = Current Window

 filetype       number  The Type of File for this
                        project.
                        
                        0=MagnifiCAD
                        1=DXF
                            
 name           string  Project Name

 preferences    string  Preferences Link

 screenmode     number  Current screenmode

 startx         real    X coordinate of current
                        starting point
 
 starty         real    Y coordinate of current
                        starting point

 units          number  Current unit setting
                        
                        0=Metre
                        1=Decimetre
                        2=Centimetre
                        3=Millimetre

 view           number  Number of current view
                           
 workbench      bool    Workbench Status
                        
                        FALSE = Closed
                        TRUE  = Open
 
 x              real    Current X coordinate
 
 y              real    Current Y coordinate
 
 zoombyfactor   bool    Zoom By Factor Setting
                        
                        TRUE = ZoomByFactor

 zoomfactor     number  Current Zoom Factor
                        
                        1+
                        
 @{u}                                             @{uu}
 
 NB: Variables of type 'real' is actually processed
     as strings, but must be a decimal number.

@endnode

@node "RX_GROUP" "ARexx Command: GROUP"

   @{b}GROUP@{ub} 

   Groups the currently selected elements. The
   elements will be placed in a group, and will be
   selectable as a group only.

 @{fg shine}Examples@{fg text}
 
   GROUP
@endnode

@node "RX_HELP" "ARexx Command: HELP"

   @{b}HELP@{ub} [@{u}topic@{uu}] 

   Displays help on the specified topic, or if no
   topic is given, displays the main help page.

 @{fg shine}Arguments@{fg text}
 
   @{u}topic@{uu}   The topic to display.
   
 @{fg shine}Examples@{fg text}
 
   HELP
   HELP 'pick'
   HELP 'rx_group'
@endnode

@node "RX_MAGNIFICADTOBACK" "ARexx Command: MAGNIFICADTOBACK"

   @{b}MAGNIFICADTOBACK@{ub} 

   Moves the MagnifiCAD screen behind any other
   screens.
 
 @{fg shine}Examples@{fg text}
 
   MAGNIFICADTOBACK
@endnode

@node "RX_MAGNIFICADTOFRONT" "ARexx Command: MAGNIFICADTOFRONT"

   @{b}MAGNIFICADTOFRONT@{ub}

   Moves the MagnifiCAD screen to the front. 
 
 @{fg shine}Examples@{fg text}
 
   MAGNIFICADTOFRONT
@endnode

@node "RX_MIRROR" "ARexx Command: MIRROR"

   @{b}MIRROR@{ub}

   Mirrors the currently selected elements.
   
   NOT IMPLEMENTED YET.

 @{fg shine}Arguments@{fg text}

   ---
    
 @{fg shine}Examples@{fg text}
 
   MIRROR
@endnode

@node "RX_MOVE" "ARexx Command: MOVE"

   @{b}MOVE@{ub} [@{u}x@{uu} @{u}y@{uu}] [@{u}TO@{uu}] [@{u}BACK@{uu}] [@{u}FRONT@{uu}]

   Moves the currently selected elements by the given
   values (x,y), or move the selected elements to the
   back or front of the layer (back,front). 

 @{fg shine}Arguments@{fg text}
 
   @{u}x@{uu} @{u}y@{uu}      When x and y is given, the elements will
            be moved in the coordinate system.
   
   @{u}BACK@{uu}     Move the elements to the back of the
            layer.

   @{u}FRONT@{uu}    Move the elements to the front of the
            layer.

   @{u}TO@{uu}       Optional (does nothing).
 
 @{fg shine}Examples@{fg text}
 
   MOVE 100 100
   MOVE '-10' '-30'
   MOVE TO BACK
   MOVE FRONT
@endnode

@node "RX_NEW" "ARexx Command: NEW"

   @{b}NEW@{ub} [@{u}FORCE@{uu}]

   Opens a new project. If a project is already open,
   and has been changed, a requester will ask the user
   if the current project is to be saved.

 @{fg shine}Arguments@{fg text}
 
   @{u}FORCE@{uu}    Suppress the requester if the project
            has been changed.
   
 @{fg shine}Examples@{fg text}
 
   NEW
   NEW force
@endnode

@node "RX_OPEN" "ARexx Command: OPEN"

   @{b}OPEN@{ub} [@{u}FORCE@{uu}] [@{u}filename@{uu}]

   Opens a previously saved project. If the current
   project has been changed, a requester will ask the
   user if the project should be saved.

 @{fg shine}Arguments@{fg text}
 
   @{u}FORCE@{uu}    Suppress the 'changes' requester.
   
   @{u}filename@{uu} Name of the project to be opened.
            If this argument is not given, a requester
            will ask the user for a filename.
 
 @{fg shine}Examples@{fg text}
 
   OPEN
   OPEN FORCE
   OPEN FORCE 'myproject'
   OPEN 'myproject.cd2'
@endnode

@node "RX_PALETTE" "ARexx Command: PALETTE"

   @{b}PALETTE@{ub} [@{u}name@{uu}] [@{u}state@{uu}]

   Opens or closes the given palette.

 @{fg shine}Arguments@{fg text}
 
   @{u}name@{uu}     Name of the palette. Must be one of:
            
            TOOL     - the tools palette.
            COLOR    - the color palette.
            HATCH    - the hatch palette.
   
   @{u}state@{uu}    The action to perform on the palette.
            Must be one of:
            
            OPEN  - open the palette.
            CLOSE - close the palette.
 
 @{fg shine}Examples@{fg text}
 
   PALETTE TOOL OPEN
   PALETTE OPEN COLOR
   PALETTE CLOSE HATCH
@endnode

@node "RX_PAN" "ARexx Command: PAN"

   @{b}PAN@{ub} @{u}x@{uu} @{u}y@{uu}

   Moves the on-screen view by x,y.

 @{fg shine}Arguments@{fg text}
 
   @{u}x@{uu} @{u}y@{uu}   Move the view by x,y.
   
 @{fg shine}Examples@{fg text}
 
   PAN '30' '100'
   PAN 10 20
@endnode

@node "RX_PASTE" "ARexx Command: PASTE"

   @{b}PASTE@{ub}

   Paste the elements in the Clipboard into the
   current project window. 
   
   The commands 'CUT' or 'COPY' can be used to place
   elements from a project into the Clipboard.

 @{fg shine}Examples@{fg text}
 
   PASTE
@endnode

@node "RX_PICK" "ARexx Command: PICK"

   @{b}PICK@{ub} [@{u}x1@{uu} @{u}y1@{uu}] [@{u}x2@{uu} @{u}y2@{uu}] [@{u}ALL@{uu}]

 @{fg shine}Alias@{fg text}
   
   @{b}SELECT@{ub}
   
   Pick/Select the elements at (x1,y1), the elements
   enclosed by (x1,y1) and (x2,y2), or all elements.

   Previously selected elements will be unselected.
   
 @{fg shine}Arguments@{fg text}
 
   @{u}x1@{uu} @{u}y1@{uu}   Select the elements which cross the point
           (x1,y1).

   @{u}x2@{uu} @{u}y2@{uu}   Select the elements which is enclosed by
           the points (x1,y1) and (x2,y2).
 
   @{u}ALL@{uu}     Select all the elements.           
 
 @{fg shine}Examples@{fg text}
   
   PICK
   PICK 100 100
   PICK '-50' '-50' 100 100
   PICK ALL
   
   SELECT
   SELECT ALL
@endnode

@node "RX_PLACESYMBOL" "ARexx Command: PLACESYMBOL"

   @{b}PLACESYMBOL@{ub} [@{u}name@{uu}] [@{u}x@{uu} @{u}y@{uu}]

   Places a symbol in the current project window, at
   the point defined by (x,y).

 @{fg shine}Arguments@{fg text}
 
   @{u}name@{uu}     Name of the symbol. If this argument 
            is not given, a requester will let the 
            user select a symbol from the currently
            set symbol library.
   
   @{u}x@{uu} @{u}y@{uu}      Coordinates for the placement of the
            symbol. If no coordinates are given,
            the symbol will be moveable by the user
            when loaded.
 
 @{fg shine}Examples@{fg text}
 
   PLACESYMBOL
   PLACESYMBOL 'desk'
   PLACESYMBOL 'desk' 100 100
@endnode

@node "RX_PRINT" "ARexx Command: PRINT"

   @{b}PRINT@{ub} [@{u}PROMPT@{uu}] 

   Prints the current project with the settings 
   from the 'Print Settings' requester.
   
 @{fg shine}Arguments@{fg text}
 
   @{u}PROMPT@{uu}   If this argument is given, the print
            routine will display a requester with
            progression information.
   
 @{fg shine}Examples@{fg text}
 
   PRINT
   PRINT PROMPT
@endnode

@node "RX_QUIT" "ARexx Command: QUIT"

   @{b}QUIT@{ub} [@{u}FORCE@{uu}] 

   Quits the program. If the current project has been
   changed after last saving, the 'changes' requester
   will be displayed, asking the user if the project
   should be saved before quitting the program.

 @{fg shine}Arguments@{fg text}
 
   @{u}FORCE@{uu}   Suppress the 'changes' requester.
   
 @{fg shine}Examples@{fg text}
 
   QUIT
   QUIT FORCE
@endnode

@node "RX_REDRAW" "ARexx Command: REDRAW"

   @{b}REDRAW@{ub} 

   Redraws the screen from the project element
   buffer.

 @{fg shine}Examples@{fg text}
 
   REDRAW
@endnode

@node "RX_REQUEST" "ARexx Command: REQUEST"

   @{b}REQUEST@{ub} [@{u}title@{uu}] [@{u}text@{uu}] [@{u}gadgets@{uu}]

   Displays a requester with the given title and text,
   allowing the user to make a selection.

 @{fg shine}Arguments@{fg text}
 
   @{u}title@{uu}    The requester's title. If not
            given, it will be set to the program
            name and version.
   
   @{u}text@{uu}     Text to display in the requester.

   @{u}gadgets@{uu}  Text for the buttons. There can be up
            to 3 buttons in the requester. If this
            argument is not given, there will be 2
            buttons with the texts 'OK' and 'Cancel'.

 @{fg shine}Returns@{fg text}
 
   Returns the number of the selected gadget.
   
   0 = the 'Cancel' gadget.
   1 = the 'OK' gadget.
   2 = the optional gadget.
   
 @{fg shine}Examples@{fg text}
 
   REQUEST '"OK to continue?"'
   REQUEST 'title="Continuation Requester"'
           'text="OK to continue?"'
           '"OK"|"Cancel"|"Maybe?"'
@endnode

@node "RX_REQUESTFILE" "ARexx Command: REQUESTFILE"

   @{b}REQUESTFILE@{ub} [@{u}title@{uu}]

   Displays a file requester, allowing the user to
   select a file.

 @{fg shine}Arguments@{fg text}
 
   @{u}title@{uu}    Title of the requester. This usually 
            indicates what type of file the user is
            expected to select.

 @{fg shine}Returns@{fg text}
        
   Returns the name of the selected file.
   
 @{fg shine}Examples@{fg text}
 
   REQUESTFILE
   REQUESTFILE '"Select a drawing file..."'
@endnode

@node "RX_ROTATE" "ARexx Command: ROTATE"

   @{b}ROTATE@{ub} @{u}x@{uu} @{u}y@{uu} @{u}rot@{uu}

   Rotates the currently selected elements by
   'rot' degrees around the point (x,y).

 @{fg shine}Arguments@{fg text}
 
   @{u}x@{uu} @{u}y@{uu}     Point to rotate the elements around.
           Note that this can be a point anywhere,
           not just a point in one of the elements.
   
   @{u}rot@{uu}     Degrees to rotate the elements.
 
 @{fg shine}Examples@{fg text}
 
   ROTATE 100 100 90
@endnode

@node "RX_RX" "ARexx Command: RX"

   @{b}RX@{ub} [@{u}CONSOLE@{uu}] [@{u}ASYNC@{uu}] [@{u}command@{uu}]

   Sends an ARexx command directly to the programs
   ARexx Port.

   NOT IMPLEMENTED.
   
 @{fg shine}Arguments@{fg text}
 
   @{u}CONSOLE@{uu}   -
   
   @{u}ASYNC@{uu}     If this argument is given, the
             command will be sent asynchroneously.

   @{u}command@{uu}   The command to send. 
        
 @{fg shine}Examples@{fg text}
 
   RX
@endnode

@node "RX_SAVE" "ARexx Command: SAVE"

   @{b}SAVE@{ub} [@{u}PROJECT@{uu}] [@{u}PREFERENCES@{uu}] [@{u}AS@{uu}] [@{u}filename@{uu}]

   Saves the current project or preferences settings.

 @{fg shine}Arguments@{fg text}
 
   @{u}PROJECT@{uu}  If this argument is given, the 
            current project is saved.
   
   @{u}PREFERENCES@{uu} If this argument is given, the
            current preferences settings are saved.
            
            Note that if none of the two above
            arguments is given, the program will
            default to 'PROJECT'.

   @{u}AS@{uu}       Optional variable (does nothing).
   
   @{u}filename@{uu} Filename to save the project or
            preferences settings under. If no filename
            is given, the previously used name will be
            used. If no name exists, a requester will
            ask the user for a new filename.
            
 @{fg shine}Examples@{fg text}
 
   SAVE
   SAVE 'myproject'
   SAVE PROJECT AS 'myproject.cd2'
   SAVE PREFERENCES 'myprefs'
@endnode

@node "RX_SAVEVIEW" "ARexx Command: SAVEVIEW"

   @{b}SAVEVIEW@{ub} [@{u}name@{uu}]

   Saves the current view in the Views list for this
   for the current project. 

 @{fg shine}Arguments@{fg text}
 
   @{u}name@{uu}    Name of the new view. If this argument
           is not given, a requester will ask the user
           to enter a name for the view.
   
 @{fg shine}Examples@{fg text}
 
   SAVEVIEW
   SAVEVIEW 'myview'
@endnode

@node "RX_SCALE" "ARexx Command: SCALE"

   @{b}SCALE@{ub} @{u}x@{uu} @{u}y@{uu} @{u}scale@{uu}

   Scales the currently selected elements by 'scale'
   in relation to the point (x,y).

 @{fg shine}Arguments@{fg text}
 
   @{u}x@{uu} @{u}y@{uu}      The point to use as scale reference.
   
   @{u}scale@{uu}    The scale to apply to the elements.
            The scale is given in a number in relation
            to the original elements, i.e. a scale of
            0.5 will make the elements half the size
            of the originals.
 
 @{fg shine}Examples@{fg text}
 
   SCALE 100 100 '0.5'
@endnode

@node "RX_SET" "ARexx Command: SET"

   @{b}SET@{ub} @{u}var@{uu}=@{u}value@{uu}
 
 @{fg shine}Alias@{fg text}
   
   SETATTR
   
   Sets the value of a specific variable in MagnifiCAD.

 @{fg shine}Arguments@{fg text}
 
   @{u}var@{uu}   Name of variable to set.
        Must be one of the variables in the table
        beneath. 
        
        @{"ARexx GET/SET Variables" LINK "Variables"}
        
 @{fg shine}Examples@{fg text}
 
   SET 'color=10'
   SET 'name="My Project"'
   SETATTR 'printgrid=TRUE'
@endnode


@node "RX_UNGROUP" "ARexx Command: UNGROUP"

   @{b}UNGROUP@{ub}

   Ungroups previously grouped elements. This command
   operates on the currently selected elements.

 @{fg shine}Examples@{fg text}
 
   UNGROUP
@endnode


@node "RX_ZOOM" "ARexx Command: ZOOM"

   @{b}ZOOM@{ub} [@{u}ALL@{uu}] [@{u}OUTBYFACTOR@{uu}] [@{u}INBYFACTOR@{uu}] 
        [@{u}IN@{uu} @{u}x1@{uu} @{u}y1@{uu} @{u}x2@{uu} @{u}y2@{uu}]

   Zooms the current view.

 @{fg shine}Arguments@{fg text}
 
   @{u}ALL@{uu}      Zoom to fit all elements in the current
            window.
   
   @{u}OUTBYFACTOR@{uu} Zoom out by the factor set in the
            'ZoomFactor' setting.
        
   @{u}INBYFACTOR@{uu} Zoom in by the factor set in the 
            'ZoomFactor' setting.
            
   @{u}IN@{uu} @{u}x1@{uu} @{u}y1@{uu} @{u}x2@{uu} @{u}y2@{uu} Zoom in to fit the rectangle
            given by (x1,y1),(x2,y2) in the current
            window.
 
 @{fg shine}Examples@{fg text}
 
   ZOOM ALL
   ZOOM INBYFACTOR
   ZOOM OUTBYFACTOR
   ZOOM IN 0 0 100 100
@endnode



@node "RX_" "ARexx Command: "

   @{b} @{ub} [@{u} @{uu}] [@{u} @{uu}]

   This is a template!

 @{fg shine}Arguments@{fg text}
 
   @{u}number@{uu}   Number of the new layer. If the layer
            number of a previously created layer
            is given, an error will be returned.
   
   @{u}name@{uu}     Name of the new layer. If the layer
            name of a previously created layer
            is given, an error will be returned.
 
 @{fg shine}Examples@{fg text}
 
   G
@endnode

