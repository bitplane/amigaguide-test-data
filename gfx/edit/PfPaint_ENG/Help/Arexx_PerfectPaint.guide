@NODE "GradientEx" "Gradient example"

    pp_EffectOn
    /* Activate Effect mode */

    pp_Gradient 0 2 100 100
    /* Activate Gradient effect
       range=0
       Type=2 (Radian sun)
       100, 100: center of the sun */

    pp_ClearRange 0
    /* Clear Range=0 */

    pp_setRange 0 4 0 0 0
    /* Fill range 0
       at position=4, put rgb color (0,0,0) */

    pp_setRange 0 19 255 255 255
    /* Fill range 0
       at position=19, put rgb color (255,255,255) */

    pp_CircleF 100 100 100
    /* Draw a circle */
    

@ENDNODE

