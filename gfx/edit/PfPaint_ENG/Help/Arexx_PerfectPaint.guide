    fonte$: font name

		@{" Text example " link extexte}

@ENDNODE
@NODE "extexte" "Text example"

/* example */

.......

   pp_TextAntialiasing 2
     /* antialiasing High */
     /* without this command, current antialiasing is used */

   pp_TextEffect 1 2
     /* effect Outline */     
     /* without this command, current effect is used */

   pp_TextFontName 'CGTimes.font'
     /* without this command, current font is used */

   pp_TextSize 50
     /* without this command, current size is used */

   pp_TextStyle 0
     /* No  Style */
     /* without this command, current style is used */

   pp_TextMake 'Hello*everybody'
     /* Build text brush: Hello everybody */
     /* with pp_TextMake "", current text is used */
   
   pp_TextDraw 100 100
     /* draw text on the current picture */
   
.......


@ENDNODE
@NODE "TextRotate" "TextRotate"

    pp_TextRotate x

    x: Rotation of the current font. (Outline font only)

    @{" Text example " link extexte}

@ENDNODE
@NODE "TextItalic" "TextItalic"

