@remark **********************************************************************
@remark **********************************************************************
@node "Referenz" "Referenz"


@{b}Befehle@{ub}

  @{" ABOUT     " link "ABOUT" 0} -- Informationen
  @{" ANG       " link "ANG" 0} -- Winkel Modifizierer
  @{" ARC3B     " link "ARC3B" 0} -- Kreisbogen 3 Punkt
  @{" ARC3L     " link "ARC3L" 0} -- Kreisbogen 3 Punkt
  @{" ARCSE     " link "ARCSE" 0} -- Kreisbogen Startwinkel-Endpunkt
  @{" ARROW     " link "ARROW" 0} -- Pfeil
  @{" BAKOFF    " link "BAKOFF" 0} -- keine Sicherungsdatei (*.BAK) erzeugen
  @{" BAKON     " link "BAKON" 0} -- Sicherungsdatei erzeugen
  @{" BEZIER    " link "BEZIER" 0} -- Bezierkurve
  @{" BOX       " link "BOX" 0} -- Rechteck
  @{" BREAK     " link "BREAK" 0} -- Bereich aus Element ausschneiden
  @{" BSPLINE   " link "BSPLINE" 0} -- B-Spline Kurve
  @{" CEN       " link "CEN" 0} -- Mittelpunkt (=Zentrum) Modifizierer
  @{" CFGAH     " link "CFGAH" 0} -- Pfeilspitzen Einstellungen (für neue Elemente)
  @{" CFGDM     " link "CFGDM" 0} -- Bemaßungs Einstellungen (für neue Elemente)
  @{" CFGTX     " link "CFGTX" 0} -- Text Einstellungen (für neue Elemente)
  @{" CHANGE    " link "CHANGE" 0} -- Ändere Ebene,Farbe,Linienmodus,... von (alten) Elementen
  @{" CHARH     " link "CHARH" 0} -- Ändere Pfeilspitzen Eigenschaften
  @{" CHCOL     " link "CHCOL" 0} -- Ändere Farbe von Element(en)
  @{" CHCURVE   " link "CHCURVE" 0} -- Ändere Kurventyp (Bezier,[B-]Spline)
  @{" CHFIL     " link "CHFIL" 0} -- Ändere Füllmodus von Element(en)
  @{" CHFNAME   " link "CHFNAME" 0} -- Ändere Dateinamen (Zeichnung Umbenennen)
  @{" CHLAY     " link "CHLAY" 0} -- Ändere Ebene (Folie) von Element(en)
  @{" CHSTY     " link "CHSTY" 0} -- Ändere Linienmodus von Element(en)
  @{" CHTXF     " link "CHTXF" 0} -- Ändere Zeichensatz
  @{" CHTXH     " link "CHTXH" 0} -- Ändere Textgröße
  @{" CIR2P     " link "CIR2P" 0} -- Kreis 2 Punkte (2 Punkte auf Kreis und Durchmesser)
  @{" CIR3P     " link "CIR3P" 0} -- Kreis 3 Punkte
  @{" CIRCP     " link "CIRCP" 0} -- Kreis Mittelpunkt-Punkt auf Kreis
  @{" CIRRC     " link "CIRRC" 0} -- Kreis Radius-Mittelpunkt
  @{" CIRTN     " link "CIRTN" 0} -- Kreis tangential
  @{" CLEAR     " link "CLEAR" 0} -- Lösche Variable(n)
  @{" CLFONT    " link "CLFONT" 0} -- Erzeuge Zeichensatz aus Zeichnung
  @{" COLOR     " link "COLOR" 0} -- Farbe
  @{" COMP      " link "COMP" 0} -- Datenbasis aufräumen, gelöschte Elemente werden entfernt
  @{" COPY      " link "COPY" 0} -- Kopiere Element(e)
  @{" COPYARR   " link "COPYARR" 0} -- Kopiere Element(e) als Feld (Matrix)
  @{" COPYCIR   " link "COPYCIR" 0} -- Kopiere Element(e) als Kreisfeld
  @{" COPYMIR   " link "COPYMIR" 0} -- Spiegelkopie
  @{" COPYROT   " link "COPYROT" 0} -- Drehkopie
  @{" DARROW    " link "DARROW" 0} -- Doppelpfeil (Pfeilspitze an beiden Enden)
  @{" DATAOFF   " link "DATAOFF" 0} -- Data-Snap Aus
  @{" DATAON    " link "DATAON" 0} -- Data-Snap An
  @{" DIROFF    " link "DIROFF" 0} -- Kein Dateirequester, Abfrage über Konsole
  @{" DIRON     " link "DIRON" 0} -- Dateirequester benutzen
  @{" DISPV     " link "DISPV" 0} -- Zeige Variable(n)
  @{" DTRANS    " link "DTRANS" 0} -- Dynamische Transformation von Elementen
  @{" ECHO      " link "ECHO" 0} -- Zeige Text auf Konsole
  @{" ECHOFF    " link "ECHOFF" 0} -- Kein Echo
  @{" ECHON     " link "ECHON" 0} -- Echo ermöglichen
  @{" ELL2S     " link "ELL2S" 0} -- Ellipse
  @{" ELLARC    " link "ELLARC" 0} -- Elliptischer Bogen
  @{" ELLCA     " link "ELLCA" 0} -- Ellipse, Kreis mit Winkel zur Zeichenebene
  @{" EPT       " link "EPT" 0} -- Endpunkt Modifizierer
  @{" ERASE     " link "ERASE" 0} -- Lösche Element(e)
  @{" FASE      " link "FASE" 0} -- Fase erzeugen
  @{" FILLET    " link "FILLET" 0} -- Abrundung erzeugen
  @{" FLIP      " link "FLIP" 0} -- Kreisbogen invertieren
  @{" FLIST     " link "FLIST" 0} -- Elemente Listen > in Datei
  @{" FMODE     " link "FMODE" 0} -- Füllmodus (neuer Elemente)
  @{" FMODES    " link "FMODES" 0} -- Füllmodus Requester
  @{" FRAMEOFF  " link "FRAMEOFF" 0} -- Stützpolygon von Kurven nicht zeigen
  @{" FRAMEON   " link "FRAMEON" 0} -- Stützpolygon von Kurven zeigen
  @{" FREEHAND  " link "FREEHAND" 0} -- Freihandlinie
  @{" FREEZE    " link "FREEZE" 0} -- Ebene (Folie) einfrieren
  @{" GRIDOFF   " link "GRIDOFF" 0} -- Gitter ausschalten
  @{" GRIDON    " link "GRIDON" 0} -- Gitter einschalten
  @{" GRIDVAL   " link "GRIDVAL" 0} -- Unsichtbare Gitterteilung
  @{" GRIDXY    " link "GRIDXY" 0} -- Gitterabstand
  @{" GROUP     " link "GROUP" 0} -- Gruppe (Block) erzeugen
  @{" GSNAPOFF  " link "GSNAPOFF" 0} -- Gitterfang ausschalten
  @{" GSNAPON   " link "GSNAPON" 0} -- Gitterfang einschalten
  @{" HATCH     " link "HATCH" 0} -- Schraffur
  @{" HELP      " link "HELP" 0} -- Hilfetext abrufen
  @{" HIDE      " link "HIDE" 0} -- Ebene (Folie) ausblenden
  @{" ICONSON   " link "ICONSON" 0} -- Piktogramme (.info-Dateien) erzeugen
  @{" ICONSOFF  " link "ICONSON" 0} -- keine Piktogramme (.info-Dateien) erzeugen
