@node "CHARH" "CHARH - interner Befehl"

@{b}Syntax@{ub}
   CHARH

@{b}Funktion@{ub}
   Ändert die Parameter von Elementen mit Pfeilspitzen.

@{b}Siehe auch@{ub}
   @{" CFGAH " link "CFGAH" 0}, @{" CFGDM " link "CFGDM" 0}
@endnode

@remark ******
@node "CHCOL" "CHCOL - interner Befehl"

@{b}Syntax@{ub}
   CHCOL

@{b}Funktion@{ub}
   Ändert die Farbe von Elementen.

