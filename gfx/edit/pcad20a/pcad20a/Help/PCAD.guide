  @{" LDFONT    " link "LDFONT" 0} -- Lade Zeichensatz
  @{" LDICON    " link "LDICON" 0} -- >Lade Button<
  @{" LDIM      " link "LDIM" 0} -- Lineare Bemaßung
  @{" LDSHELL   " link "LDSHELL" 0} -- Lade Einstellungen
  @{" LINE      " link "LINE" 0} -- Linie
  @{" LIST      " link "LIST" 0} -- Liste von Elementen
  @{" LISTA     " link "LISTA" 0} -- ...
  @{" LMODE     " link "LMODE" 0} -- Linienmodus (neuer Elemente)
  @{" LMODES    " link "LMODES" 0} -- Linienmodus Requester
  @{" LOAD      " link "LOAD" 0} -- Lade (Öffne) Zeichnung
  @{" LOADP     " link "LOADP" 0} -- (Teil-)Zeichnung Einfügen
  @{" LSFONT    " link "LSFONT" 0} -- Zeige alle geladenen Zeichensätze
  @{" MDP       " link "MDP" 0} -- Mittelpunkt (einer Strecke) Modifizierer
  @{" MELT      " link "MELT" 0} -- Ebene (Folie) auftauen
  @{" MELTALL   " link "MELTALL" 0} -- alle Ebenen auftauen
  @{" MENU      " link "MENU" 0} -- Menüdefinition laden
  @{" MIRR      " link "MIRR" 0} -- Element(e) spiegeln
  @{" MOVE      " link "MOVE" 0} -- Element(e) verschieben
  @{" NEWIND    " link "NEWIND" 0} -- Neues Zeichenfenster öffnen
