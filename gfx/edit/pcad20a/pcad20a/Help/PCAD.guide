@endnode

@remark ******
@node "CHFNAME" "CHFNAME - interner Befehl"

@{b}Syntax@{ub}
   CHFNAME;@{ "Dateiname" link "filerequester" 0}

@{b}Funktion@{ub}
   Gibt der aktuellen Zeichnung (Datei) einen neuen Namen.
   Die Zeichnung wird unter dem neuen Namen noch nicht gesichert!

@{b}Siehe auch@{ub}
   @{" SAVE " link "SAVE" 0}, @{" SAVEAS " link "SAVEAS" 0}
