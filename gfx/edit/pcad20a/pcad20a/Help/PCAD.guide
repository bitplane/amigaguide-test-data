@node "CHANGE" "CHANGE - interner Befehl"

@{b}Syntax@{ub}
   CHANGE

@{b}Funktion@{ub}

@{b}Siehe auch@{ub}
   @{" CHARH " link "CHARH" 0}, @{" CHCURVE " link "CHCURVE" 0}, @{" CHCOL " link "CHCOL" 0}, @{" CHLAY " link "CHLAY" 0}
@endnode

