@remark ******
@node "ZOOM" "ZOOM - interner Befehl"

@{b}Syntax@{ub}
   ZOOM;<faktor>

@{b}Funktion@{ub}
   Bildauschnitt/Ansicht vergrößern bzw. verkrleinern.

   <faktor> <real/distance>

   <faktor> @{b}< 1.0@{ub}   "Verkleinern"ą der Zeichnung:
                    Die Details erscheinen kleiner (wie Weitwinkel)
                    Der Bildauschnitt wird größer (relativ zum Gesamtbild)

   <faktor> @{b}> 1.0@{ub}   "Vergößern"ą der Zeichnung:
                    Details erscheinen größer (wie Tele o. Lupe)
                    Der Bildauschnitt wird kleiner (relativ zum Gesamtbild)

@{b}Siehe auch@{ub}
   @{" ZOOML " link "ZOOML" 0}

ą)@{i} Die Zeichnung selbst, d.h. die Daten werden natürlich @{b}nicht@{ub} verändert. @{ui}
@endnode

@remark ******
@node "ZOOMA" "ZOOMA - interner Befehl"

@{b}Syntax@{ub}
   ZOOMA

@{b}Funktion@{ub}
