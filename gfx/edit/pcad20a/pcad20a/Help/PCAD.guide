@node "CHCURVE" "CHCURVE - interner Befehl"

@{b}Syntax@{ub}
   CHCURVE

@{b}Funktion@{ub}
   Ändert den Kurventyp von Kurvenelementen.

@{b}Siehe auch@{ub}
   @{" BEZIER " link "BEZIER" 0}, @{" FRAMEON " link "FRAMEON" 0}, @{" SPLINE " link "SPLINE" 0}
@endnode

