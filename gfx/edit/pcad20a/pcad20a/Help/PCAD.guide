@remark ******
@node "ELL2S" "ELL2S - interner Befehl"

@{b}Syntax@{ub}
   ELL2S;<mittelpunkt>;<1.scheitel>;<konj.durchmesser>|<2.scheitel>

@{b}Funktion@{ub}
   Erzeugt eine Ellispe.
   Die Hauptachse @{i}a @{ui} bzw. Nebenachse @{i}b @{ui} wird durch den <mittelpunkt> und
   den <1.scheitel> bestimmt. Der Betrag vom anderen konj. Durchmesser (@{i}a @{ui}bzw. @{i}b @{ui})
   wird durch <konj.durchmesser> oder den Punkt <2.scheitel> bestimmt.

   <mittelpunkt>        (point)
   <1.scheitel>         (point)
   <konj.durchmesser>   (real/numeric)
   <2.scheitel>         (point)

@{b}Siehe auch@{ub}
   @{" ELLARC " link "ELLARC" 0}, @{" ELLCA " link "ELLCA" 0}
@endnode

@remark ******
@node "ELLARC" "ELLARC - interner Befehl"

@{b}Syntax@{ub}
   ELLARC;<mittelpunkt>;<1.scheitel>;<konj.durchmesser>|<2.scheitel>;<startwinkel>|<startpunkt>;<bogenweite>|<endpunkt>

@{b}Funktion@{ub}
   Erzeugt einen elliptischen Bogen.
   Die zugrundeliegende Ellipse wird durch <mittelpunkt> <1.scheitel>
   <konj.durchmesser> bzw. <2.scheitel> wie bei @{"ELL2S" link "ELL2S" 0} bestimmt.
   Der Anfangswinkel (gegen Uhrzeigersinn) wird durch <startwinkel> bzw.
   <startpunkt> bestimmt, die Bogenweite durch den <endpunkt>
   bzw. <bogenweite>.

   <mittelpunkt>        (point)
   <1.scheitel>         (point)
   <konj.durchmesser>   (real/numeric)
   <2.scheitel>         (point)

   <startwinkel>        (real/numeric)
   <startpunkt>         (point)
   <bogenweite>         (real/numeric)
   <endpunkt>           (point)

@{b}Siehe auch@{ub}
   @{" ARCSE " link "ARCSE" 0}, @{" ELL2S " link "ELL2S" 0}
@endnode

@remark ******
@node "ELLCA" "ELLCA - interner Befehl"

@{b}Syntax@{ub}
   ELLCA;<winkel>;<mittelpunkt>;<hauptachse>

@{b}Funktion@{ub}
   Erzeugt eine Ellipse.
   Die Ellipse wird durch die Projektion eines Kreises, der schräg zur
   Zeichenebene liegt, bestimmt:

      a = r; @{i}r = Radius vom Kreis @{ui}
      b = cos <winkel>;

   <winkel>       (real/angle)
   <mittelpunkt>  (point)
   <hauptachse>   (point)

@{b}Siehe auch@{ub}
   @{" ELL2S " link "ELL2S" 0}
@endnode

@remark ******
@node "EPT" "EPT - interner Befehl"

@{b}Syntax@{ub}
   EPT;<suchpunkt>

@{b}Funktion@{ub}
   Koordinaten @{"Modifizierer" link "modifiers"0} für Endpunkte.
   Durch <suchpunkt> wird der Punkt bestimmt in dessen Nähe nach einem
   (Linien-,Bogen-)Endpunkt gesucht wird, der dann zurückgegeben wird.

@endnode

@remark ******
@node "ERASE" "ERASE - interner Befehl"

@{b}Syntax@{ub}
   ERASE;{Selektion}

@{b}Funktion@{ub}
   "Löscht" die ausgewählten Elemente {Selektion}.
   Wenn Elemente gelöscht werden, so werden diese vorerst nur als gelöscht
   gekennzeichnet.

@{b}Siehe auch@{ub}
   @{" COMP " link "COMP" 0}, @{" UNDO " link "UNDO" 0}, @{" UNERASE " link "UNERASE" 0}
@endnode

@remark ******
@node "FASE" "FASE - interner Befehl"

@{b}Syntax@{ub}
   FASE;<abstand>;<ecke>[<2.elemenet>|<lage>];<kürzen>; ...

@{b}Funktion@{ub}
   Erzeugt eine Fase.
   Die Geometrie wird durch den @{"<abstand>" link "PCAD:Help/fase.pic/main" } und zwei Elemente bestimmt.
   Falls sich zwei Elemente im Punkt <ecke> gerade berühren, so genügt die
   Eingabe der <ecke>. Anderenfalls wird ein weiterer Punkt abgefragt,
   durch den ggf. das zweite Element oder die eindeutige Lage bestimmt
   werden.
   Desweiteren gibt es die Option, die alten Elemente zu <kürzen>.
   Durch die Eingabe weiterer Punkte können zusätzliche Fasen erzeugt
   mit gleichem Abstand werden.

   <abstand>      (real/distance)
   <ecke>         (point)
   <2.elemenet>   (point)
   <lage>         (point)
   <kürzen>       (Y/N)

@{b}Siehe auch@{ub}
   @{" BREAK " link "BREAK" 0}, @{" FILLET " link "FILLET" 0}, @{" TRIM " link "TRIM" 0}
@endnode

@remark ******
@node "FILLET" "FILLET - interner Befehl"

@{b}Syntax@{ub}
   FILLET;<radius>;<ecke>[<2.elemenet>|<lage>];<kürzen>; ...

@{b}Funktion@{ub}
   Erzeugt eine Abrundung mit dem Radius <radius>.
   Der Befehl FILLET verhält sich analog zum Befehl @{" FASE " link "FASE" 0}, nur daß
   ein neuer Kreisbogen statt einer Linie erzeugt wird.

@{b}Siehe auch@{ub}
   @{" BREAK " link "BREAK" 0}, @{" CIRTN " link "CIRTN" 0}, @{" FASE " link "FASE" 0}, @{" TRIM " link "TRIM" 0}
@endnode

@remark ******
@node "FLIP" "FLIP - interner Befehl"

@{b}Syntax@{ub}
   FLIP;<element pick>

@{b}Funktion@{ub}
   Invertiert die Bogenparameter eines Kreisbogens, der durch den Punkt
   <element pick> bestimmt wird.

      neue Bogenweite = 360° - alte Bogenweite;
      neuer Anfangswinkel = alter Endwinkel;

   Nach zweimaligen FLIP des selben Kreisbogens erhält man wieder den
   ersten.

@{b}Siehe auch@{ub}
   @{" TRIM " link "TRIM" 0}
@endnode

