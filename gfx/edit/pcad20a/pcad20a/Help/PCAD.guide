@remark ******
@node "LINE" "LINE - interner Befehl"


@{b}Syntax@{ub}
   LINE;<startpunkt>;<endpunkt>;...

@{b}Funktion@{ub}
   Erzeugt ein Linien durch zwei Punkte in aktueller Farbe, Linienmodus
   und Ebene (Folie).
   Nach dem Endpunkt wird wieder nach dem Startpunkt der nächsten Linie
   gefragt. Dabei wird der vorherige (End-)Punkt als neuer Startpunkt
   (in eckigen Klammern) vorgeschlagen. Dieser kann mit rechter Maustaste
   übernommen werden.
   Bei der Abfrage nach dem Enpunkt kann mit @{"RMB" link "Bedienung" 97} abgebrochen werden.
   ESC bricht immer ab.

@{b}Siehe auch@{ub}
   @{" PATH " link "PATH" 0}, @{" POLY " link "POLY" 0}, @{" TRIM " link "TRIM" 0}
@endnode

@remark ******
@node "LIST" "LIST - interner Befehl"

@{b}Syntax@{ub}
   LIST;{Selektion}

@{b}Funktion@{ub}
   Die Parameter der ausgewählten Elemente {Selektion} werden aufgelistet.
   Die Liste kann mit ESC beendet werden.

@{b}Siehe auch@{ub}
   @{" FLIST " link "FLIST" 0}
@endnode

@remark ******
@node "LISTA" "LISTA - interner Befehl"

@{b}Syntax@{ub}
   LIST;

@{b}Funktion@{ub}
   Listet ALLE Elemente.

@{b}Anmerkung@{ub}
   Dieser Befehl ist nur zur Fehlersuche gedacht.
   Für den normalen Gebrauch sollte LIST verwendet werden.

@{b}Siehe auch@{ub}
   @{ " LIST " link "LIST" 0}
@endnode

@remark ******
@node "LMODE" "LMODE - interner Befehl"

@{b}Syntax@{ub}
   LMODE;<nummer>

@{b}Funktion@{ub}
   Legt den Linienmodus neuer Elemente fest.

@{b}Siehe auch@{ub}
   @{" CHSTY " link "CHSTY" 0}, @{" FMODE " link "FMODE" 0}, @{" LMODES " link "LMODES" 0}
@endnode

@remark ******
@node "LMODES" "LMODES - interner Befehl"

@{b}Syntax@{ub}
   LMODES

@{b}Funktion@{ub}
   Legt das @{"Linienmuster" link "Formate" 73} neuer Elemente fest.
   Dazu erscheint ein Requester, mit der Auswahl möglicher Linienmuster.

@{b}Siehe auch@{ub}
   @{" FMODES " link "FMODES" 0}, @{" LMODE " link "LMODE" 0}
@endnode

@remark ******
@node "LOAD" "LOAD - interner Befehl"

@{b}Syntax@{ub}
   LOAD;@{"Dateiname" link "filerequester" 0}

@{b}Funktion@{ub}
   Öffnet eine andere Zeichnung.
   Falls die aktuelle Zeichnung verändert und noch nicht gesichert wurde
   erscheint eine entsprechende Meldung, bei der man dann zwischen
   [Continue] [Save First] und [Cancel] wählen kann.

      [Continue]     Die Änderungen der aktuellen Zeichnung gehen verloren.

      [Save First]   Die aktuelle wird erst gesichert bevor der
                     Dateirequester erscheint.

      [Cancel]       Der Vorgang wird abgebrochen, es wird keine neue
                     Zeichnung geladen.

   Falls man [Continue] gewählt hat kann man später noch im Dateirequester
   Abbrechen; die aktuelle Zeichnung bleibt dann.

@{b}Siehe auch@{ub}
   @{" REVERT " link "REVERT" 0}, @{" SAVE " link "SAVE" 0}
@endnode

@remark ******
@node "LOADP" "LOADP - interner Befehl"

@{b}Syntax@{ub}
   LOADP;@{"Dateiname" link "filerequester" 0};<einsetzpunkt>;<skalierung>;<drehung>

@{b}Funktion@{ub}
   Fügt das Teil (=Zeichnung) "Dateiname" in die aktuelle Zeichnung ein.
   Die neuen Elemente werden relativ zum <einsetzpunkt> positioniert,
   um den Faktor <skalierung> vergrößert/verkleinert und schließlich mit dem
   Winkel <drehung> um den <einsetzpunkt> rotiert.
   Alle neuen Elemente werden zu einer Gruppe zusammengefaßt, die den Namen der
   eingefügten Datei erhält.

   <einsetzpunkt> (point)
   <skalierung>   (real/distance)
   <drehung>      (real/angle)

@{b}Siehe auch@{ub}
   @{" SAVEP " link "SAVEP" 0}, @{" UNGROUP " link "UNGROUP" 0}
@endnode

@remark ******
@node "LSFONT" "LSFONT - interner Befehl"

@{b}Syntax@{ub}
   LSFONT

@{b}Funktion@{ub}
   Geladene PCAD Zeichensätze anzeigen.

@{b}Siehe auch@{ub}
   @{" LDFONT " link "LDFONT" 0}
@endnode

@remark ******
@node "MDP" "MDP - interner Befehl"

@{b}Syntax@{ub}
   MDP;<element pick>

@{b}Funktion@{ub}
   Koordinaten @{"Modifizierer" link "modifiers"0} für (Strecken-)Mittelpunkte.
   Durch den Punkt <element pick> wird eine Kontur bestimmt, deren
   Mittelpunkt (soweit möglich) zurückgegeben wird.

   Der Modifizierer "MDP" entspricht dem Modifizierer "PER;0.5"

@{b}Siehe auch@{ub}
   @{" CEN " link "CEN" 0}, @{" PER " link "PER" 0}
@endnode

@remark ******
@node "MELT" "MELT - interner Befehl"

@{b}Syntax@{ub}
   MELT;<ID nummer>

@{b}Funktion@{ub}
   Ebene/Folie "auftauen" (freigeben).

   <ID nummer>   (integer)

@{b}Siehe auch@{ub}
   @{" FREEZE " link "FREEZE" 0}, @{" LAYERS " link "LAYERS" 0}, @{" MELTALL " link "MELTALL" 0}
@endnode

@remark ******
@node "MELTALL" "MELTALL - interner Befehl"

@{b}Syntax@{ub}
   MELTALL

@{b}Funktion@{ub}
   Alle Ebene/Folie "auftauen" (freigeben).

@{b}Siehe auch@{ub}
   @{" FREEZE " link "FREEZE" 0}
@endnode

@remark ******
@node "MENU" "MENU - interner Befehl"

@{b}Syntax@{ub}
   MENU;@{"Dateiabfrage" link "filerequester" 0}

@{b}Funktion@{ub}
   Lädt neue Menu-Definition.
   Dazu wird der Benutzer nach einem entsprechenden Dateinamen
   gefragt.

@{b}Siehe auch@{ub}
   @{"Menü-Dateiformat" link "Formate" 2}
@endnode

@remark ******
@node "MIRR" "MIRR - interner Befehl"

@{b}Syntax@{ub}
   MIRR;{Selektion};<1.punkt>;<2.punkt>

@{b}Funktion@{ub}
   Spiegeln von Elementen.
   Die ausgewählten Elemente {Selektion} werden an der Achse
   [<1.punkt>;<2.punkt>] gespiegelt.

@{b}Siehe auch@{ub}
   @{" COPYMIR " link "COPYMIR" 0}
@endnode

@remark ******
@node "MOVE" "MOVE - interner Befehl"
@{b}Syntax@{ub}
   MOVE;{Selektion};<von>;<nach>

@{b}Funktion@{ub}
   Verschieben von Elementen.
   Die ausgewählten Elemente {Selektion} werden vom Punkt <von> zum
   Punkt <nach> verschoben.

@{b}Siehe auch@{ub}
   @{" COPY " link "COPY" 0}
@endnode

@remark ******
@node "NEWIND" "NEWIND - interner Befehl"

@{b}Syntax@{ub}
   NEWIND;<1.ecke>;<2.ecke>;{Fenster}

@{b}Funktion@{ub}
   Öffnet neues Fenster.

@{b}Siehe auch@{ub}
   @{" ZOOM " link "ZOOM" 0}
@endnode

@remark ******
@node "ON" "ON - interner Befehl"
@{b}Syntax@{ub}
   ON;<element pick>

@{b}Funktion@{ub}
   Koordinaten @{"Modifizierer" link "modifiers"0} für Element-Kontur.
   Falls beim Punkt <element pick> ein Element liegt, so wird der
   nächstgelegene Punkt auf dessen Kontur zurückgegeben.

@endnode

@remark ******
@node "ORTHOFF" "ORTHOFF - interner Befehl"

@{b}Syntax@{ub}
   ORTHOFF

@{b}Funktion@{ub}
   Orthogonalmodus abschalten.

@{b}Siehe auch@{ub}
   @{" ORTHON " link "ORTHON" 0}
@endnode

@remark ******
@node "ORTHON" "ORTHON - interner Befehl"

@{b}Syntax@{ub}
   ORTHON

@{b}Funktion@{ub}
   Schaltet den Orthogonalmodus ein.
   Dies ist ein Fangmodus, bei dem nur Punkte horizontal oder vertikal zum
   vorherigen eingegeben werden (können). Er läßt sich auch mit dem
   Raster-Fang kombinieren.

@{b}Siehe auch@{ub}
   @{" DATAON " link "DATAON" 0}, @{" GSNAPON " link "GSNAPON" }, @{" ORTHOFF " link "ORTHOFF" 0}
@endnode

@remark ******
@node "PAN" "PAN - interner Befehl"
@{b}Syntax@{ub}
   PAN;<von>;<nach>

@{b}Funktion@{ub}
   Zeichnung (Ausschnitt) verschieben.

@{b}Siehe auch@{ub}
   @{" NEWIND " link "NEWIND" 0}, @{" ZOOM " link "ZOOM" 0}
@endnode

@remark ******
@node "PATH" "PATH - interner Befehl"

@{b}Syntax@{ub}
   PATH;<1.Punkt>;<2.Punkt>;<3.Punkt>;...[;<126.Punkt>]

@{b}Funktion@{ub}
   Erzeugt einen Linienzug.
   Ein solcher Linienzug ist ein eigenes Element und ist daher auf max. 126
   Punkte (=125 Linien) begrenzt.

@{b}Siehe auch@{ub}
   @{" FREEHAND " link "FREEHAND" 0}, @{" LINE " link "LINE" 0}, @{" POLY " link "POLY" 0}
@endnode

@remark ******
@node "PER" "PER - interner Befehl"

@{b}Syntax@{ub}
   PER;<teilung>;<element pick>

@{b}Funktion@{ub}
   Koordinaten @{"Modifizierer" link "modifiers"0} für (Strecken-)Teilung.
   Durch den Punkt <element pick> wird eine Kontur (i.d.R. eine Linie o. 
   Kreisbogen) bestimmt, deren Teilung (soweit möglich) zurückgegeben wird.

   Der Modifizierer "PER;0.5" entspricht dem Modifizierer "MDP",
   "PER;1.0" und "PER;0.0" entsprechen dem Modifizierer "EPT".

   <teilung>   (real/distance)   @{i}typischerweise [0 .. 1.0] @{ui}

@{b}Siehe auch@{ub}
   @{" CEN " link "CEN" 0}, @{" EPT " link "EPT" 0}, @{" MDP " link "MDP" 0}
@endnode

@remark ******
@node "PLOT" "PLOT - interner Befehl"

@{b}Syntax@{ub}
   PLOT

@{b}Funktion@{ub}
   Zeichnung drucken.
   Es erscheint ein Requester, mit dem verschiedene Parameter eingestellt
   werden können.

@{b}Siehe auch@{ub}
   @{" Durckereigenschaften " link "Formate" 65}
@endnode

@remark ******
@node "PND" "PND - interner Befehl"

@{b}Syntax@{ub}
   PND;<element pick>

@{b}Funktion@{ub}
   Lot.
   Koordinaten @{"Modifizierer" link "modifiers"0} für das Lot vom aktuellen Punkt auf das
   Element welches durch den Punkt <element pick> spezifiziert wird.

@{b}Siehe auch@{ub}
   @{" ANG " link "ANG" 0}, @{" REFP " link "REFP" 0}
@endnode

@remark ******
@node "POLY" "POLY - interner Befehl"

@{b}Syntax@{ub}
   POLY<1.Punkt>;<2.Punkt>;<3.Punkt>;...[;<126.Punkt>]

@{b}Funktion@{ub}
   Erzeugt ein Polygon.
   Die Anzahl der Ecken eines Polygons ist auf max. 126 Punkte (=125 Linien) begrenzt.

@{b}Siehe auch@{ub}
   @{" PATH " link "PATH" 0}, @{" RPOLY " link "RPOLY" 0}
@endnode

@remark ******
@node "PRL" "PRL - interner Befehl"

@{b}Syntax@{ub}
   PRL

@{b}Funktion@{ub}
   Parallel.
   Koordinaten @{"Modifizierer" link "modifiers"0} für Parallelen durch den aktuellen Punkt zu
   dem Element welches durch den Punkt <element pick> spezifiziert wird.

@{b}Siehe auch@{ub}
   @{" ANG " link "ANG" 0}, @{" REFP " link "REFP" 0}
@endnode

@remark ******
@node "PVSOFF" "PVSOFF - interner Befehl"

@{b}Syntax@{ub}
   PVSOFF

@{b}Funktion@{ub}
   Dateiversionen abschalten.

@{b}Siehe auch@{ub}
   @{" PVSON " link "PVSON" 0}
@endnode

@remark ******
@node "PVSON" "PVSON - interner Befehl"

@{b}Syntax@{ub}
   PVSON

@{b}Funktion@{ub}
   Dateiversionen einschalten.
   Beim Speichern einer Zeichnung wird die letzte Version nie
   überschrieben, sondern in "Dateiname.pcd.@{b}N@{ub}" umbenannt.

      WORK.PCD    aktuelle (neueste,jüngste) Zeichnung
      WORK.PCD.6  vorherige Version der Zeichnung  (größtes @{b}N@{ub})
      ....
      WORK.PCD.2
      WORK.PCD.1  älteste Version der Zeichnung

@{b}Siehe auch@{ub}
   @{" BAKON " link "BAKON" 0}, @{" PVSOFF " link "PVSOFF" 0}, @{" Backupdateien " link "Datei" 128}
@endnode

@remark ******
@node "QUERY" "QUERY - interner Befehl"

@{b}Syntax@{ub}
   QUERY;<arexxname>;<pcadname>

@{b}Funktion@{ub}
   PCAD Variable einer ARexx Variablen zuweisen.
   Falls die PCAD Variable <pcadname> existiert, wird diese der ARexx
   Variablen <arexxname> zugewiesen.

   Dieser Befehl funktioniert nur, wenn er von einem ARexx-Script aus
   aufgerufen wird.

   <arexxname> (string)
   <pcadname>  (string)

@{b}Siehe auch@{ub}
   @{" RX " link "RX"0}, @{" VAR " link "VAR"0}
@endnode

@remark ******
@node "QUIT" "QUIT - interner Befehl"

@{b}Syntax@{ub}
   QUIT

@{b}Funktion@{ub}
   Beendet PCAD.
   Falls die Zeichnung seit der letzten Sicherung verändert wurde, so
   erscheint eine entprechende Abfrage, bei der man wählen kann, ob man
   das Programm trotzdem beenden will oder zuvor noch sichern oder die Aktion
   stornieren (d.h. mit PCAD weiterarbeiten) will.

@{b}Siehe auch@{ub}
   @{" SAVE " link "SAVE"0}
@endnode

@remark ******
@node "RDIM" "RDIM - interner Befehl"

@{b}Syntax@{ub}
   RDIM;<zentrum>;<radius>;<lage>;<textposition>

@{b}Funktion@{ub}
   Radius Bemaßung.

   <zentrum>      (point)
   <radius>       (point)
   <lage>         (point)
   <textposition> (point)

@{b}Siehe auch@{ub}
   @{" CFGDM " link "CFGDM" 0}, @{" LDIM " link "LDIM" 0}, @{" RDIMCA " link "RDIMCA" 0}
@endnode

@remark ******
@node "RDIMCA" "RDIMCA - interner Befehl"

@{b}Syntax@{ub}
   RDIMCA;<element pick>;<lage>;<textposition>

@{b}Funktion@{ub}
   Radius Bemaßung für Kreise und Bögen.
   Wie RDIM, allerdings werden Zentrum und Radius automatisch durch den
   ausgewählten Kreis(Bogen) bestimmt. Kreis(Bogen) wird durch den Punkt
   <element pick> spezifiziert.

@{b}Siehe auch@{ub}
   @{" CFGDM " link "CFGDM" 0}, @{" LDIM " link "LDIM" 0}, @{" RDIM " link "RDIM" 0}
@endnode

@remark ******
@node "REFP" "REFP - interner Befehl"

@{b}Syntax@{ub}
   REFP;<referenzpunkt>

@{b}Funktion@{ub}
   Legt einen neuen <referenzpunkt> fest.
   Der Referenzpunkt ist für relative Koordinateneingabe und verschiedene
   @{"Modifizierer" link "modifiers"0} von Bedeutung.

@{b}Siehe auch@{ub}
   @{" TRACKREL " link "TRACKREL" 0}
@endnode

@remark ******
@node "REGEN" "REGEN - interner Befehl"

@{b}Syntax@{ub}
   REGEN

@{b}Funktion@{ub}
   Zeichnung neu Aufbauen.

   Einige Befehle (v.a. für das Ein- und Ausblenden von Ebenen/Folien)
   bauen die Zeichnung nicht automatisch neu auf, um verschiedene
   Befehle dieses Typs kombinieren zu können ohne daß die Zeichnung
   jedesmal neu aufgebaut wird.

@endnode

@remark ******
@node "REVERT" "REVERT - interner Befehl"

@{b}Syntax@{ub}
   REVERT

@{b}Funktion@{ub}
   Zuletzt gesicherte Version der Zeichnung laden.

   @{i}"zuletzt gesichert" bezieht sich @{b}nicht @{ub}auf @{"automatische" link "Datei" 85}
   Sicherungen wie z.B. @{"#?.BAK" link "Datei" 128} Dateien.@{ui}

@{b}Siehe auch@{ub}
   @{" LOAD " link "LOAD" 0}, @{" SAVE " link "SAVE" 0}
@endnode

@remark ******
@node "RMAICON" "RMAICON - interner Befehl"

@{b}Syntax@{ub}
   RMAICON ???

@{b}Funktion@{ub}
   @{i}obsolete @{ui}

@endnode

@remark ******
@node "RMICON" "RMICON - interner Befehl"
@{b}Syntax@{ub}
   RMICON ???

@{b}Funktion@{ub}
   @{i}obsolete @{ui}

@endnode

@remark ******
@node "ROT" "ROT - interner Befehl"

@{b}Syntax@{ub}
   ROT;{Selektion};<winkel>;<drehpunkt>

@{b}Funktion@{ub}
   Elemente drehen.
   Die ausgewählten Elemente {Selektion} werden mit <winkel> um den
   <drehpunkt> rotiert.

@{b}Siehe auch@{ub}
   @{" COPYROT " link "COPYROT" 0}, @{" MOVE " link "MOVE" 0}
@endnode

@remark ******
@node "RPOLY" "RPOLY - interner Befehl"

@{b}Syntax@{ub}
   RPOLY;<ecken>;<mittelpunkt>;<eckpunkt>

@{b}Funktion@{ub}
   Regelmäßiges Polygon.
   Es wird ein regelmäßiges Polygon mit <ecken> Ecken erzeugt.
   Es muß mind. drei <ecken>, aber nicht mehr als 126 haben.

   <ecken>        (integer)
   <mittelpunkt>  (point)
   <eckpunkt>     (point)

@{b}Siehe auch@{ub}
   @{" POLY " link "POLY" 0}
@endnode

@remark ******
@node "RX" "RX - interner Befehl"

@{b}Syntax@{ub}
   RX;<scriptname>

@{b}Funktion@{ub}
   @{" ARexx " link "Scripts" 14} Script explizit aufrufen.

@endnode

@remark ******
@node "SAVE" "SAVE - interner Befehl"

@{b}Syntax@{ub}
   SAVE

@{b}Funktion@{ub}
   Zeichnung (Datei) sichern.
   Gelöschte (= als gelöscht gekennzeichnete) Elemente werden nicht
   mitgesichert.

@{b}Siehe auch@{ub}
   @{" LOAD " link "LOAD" 0}, @{" SAVEAS " link "SAVEAS" 0}, @{" SAVEP " link "SAVEP" 0}
@endnode

@remark ******
@node "SAVEAS" "SAVEAS - interner Befehl"

@{b}Syntax@{ub}
   SAVEAS;@{"Dateiname" link "filerequester" 0}

@{b}Funktion@{ub}
   Sichert die aktuelle Zeichnung (Datei) unter einem anderen Namen.
   Falls diese Datei bereits existiert, wird gefragt, ob sie überschrieben
   werden soll.

   Die aktuelle Zeichnung behält ihren Namen.

@{b}Siehe auch@{ub}
   @{" CHFNAME " link "CHFNAME" 0}, @{" SAVE " link "SAVE" 0}
@endnode

@remark ******
@node "SAVEP" "SAVEP - interner Befehl"

@{b}Syntax@{ub}
   SAVEP;@{"Dateiname" link "filerequester" 0};{Selektion};<ursprung>

@{b}Funktion@{ub}
   Teil sichern.
   Die ausgewählten Elemente {Selektion} werden in einer neuen Datei
   gesichert. Es entsteht eine komplette Zeichnung mit dem angegebenen
   <ursprung>, die mit @{"LOAD" link "LOAD"} oder @{"LOADP" link "LOADP"} geöffnet werden kann.

@{b}Siehe auch@{ub}
   @{" SAVE " link "SAVE" 0}
@endnode

@remark ******
@node "SCALE" "SCALE - interner Befehl"

@{b}Syntax@{ub}
   SCALE;{Selektion};<faktor>;<zentrum>

@{b}Funktion@{ub}
   Die ausgewählten Elemente {Selektion} werden um den angegebenen <faktor>
   bezüglich einem <zentrum> vergrößert bzw. verkleinert.

   <faktor>    (real/distance)
   <zentrum>   (point)

@{b}Siehe auch@{ub}
   @{" SCALEXY " link "SCALEXY" 0}
@endnode

@remark ******
@node "SCALEXY" "SCALEXY - interner Befehl"

@{b}Syntax@{ub}
   SCALEXY;{Selektion};<Xfaktor>;<Yfaktor>;<zentrum>

@{b}Funktion@{ub}
   Die ausgewählten Elemente {Selektion} werden bezüglich einem <zentrum>
   vergrößert/verkleinert bzw. verzerrt.

   <Xfaktor>   (real/distance)
   <Yfaktor>   (real/distance)
   <zentrum>   (point)

@{b}Siehe auch@{ub}
   @{" SCALE " link "SCALE" 0}
@endnode

@remark ******
@node "SEGSEK" "SEGSEK - interner Befehl"

@{b}Syntax@{ub}
   SEGSEK;<modus>

@{b}Funktion@{ub}
   Bestimmt die Darstellung neuer (elliptischer)Bögen.

   Gefüllte Bogen-Elemente können als (Kreis-)Sektor oder Segment
   dargestellt werden.

   <modus>  (Y/N)

@{b}Siehe auch@{ub}
   @{" FMODE " link "FMODE" 0}
@endnode

@remark ******
@node "SET" "SET - interner Befehl"

@{b}Syntax@{ub}
   SET;<name>;<wert>

@{b}Funktion@{ub}
   Ändert den <wert> der Variablen <name>.

@{b}Siehe auch@{ub}
   @{" VAR " link "VAR" 0}
@endnode

@remark ******
@node "SETBKTIME" "SETBKTIME - interner Befehl"

@{b}Syntax@{ub}
   SETBKTIME;<minuten>

@{b}Funktion@{ub}
   Bestimmt den Zeitintervall zwischen den @{"automatischen Sicherungen" link "Datei" 85}.

@{b}Siehe auch@{ub}
   @{" BAKON " link "BAKON"0}, @{" PVSON " link "PVSON"0}
@endnode

@remark ******
@node "SHOW" "SHOW - interner Befehl"

@{b}Syntax@{ub}
   SHOW;<nummer>

@{b}Funktion@{ub}
   Blendet die Ebene/Folie mit der ID <nummer> ein (und markiert sie als
   sichtbar).

@{b}Siehe auch@{ub}
   @{" HIDE " link "HIDE" 0}, @{" REGEN " link "REGEN"}, @{" SHOWALL " link "SHOWALL" 0}
@endnode

@remark ******
@node "SHOWALL" "SHOWALL - interner Befehl"

@{b}Syntax@{ub}
   SHOWALL

@{b}Funktion@{ub}
   Alle Ebenen (Folien) werden als sichtbar markiert.
   Ein Neuzeichnen finden noch nicht statt.

@{b}Siehe auch@{ub}
   @{" HIDEALL " link "HIDEALL" 0}, @{" SHOW " link "SHOW"}, @{" REGEN " link "REGEN"}
@endnode

@remark ******
@node "SMODE" "SMODE - interner Befehl"

@{b}Syntax@{ub}
   SMODE

@{b}Funktion@{ub}
   Bestimmt den Auswahlmodus einer Elemente-{Selektion}.

   Der std. Modus ist "Dialog", bei dem alle möglichen Selektionstypen
   durch logische Verknüpfung (AND,OR,NOT) kombiniert werden können.

   Im Modus "Each" wird jedes Element durch einen Punkt (=Mausklick)
   selektiert.

@endnode

@remark ******
@node "SPECIAL" "SPECIAL - interner Befehl"

@{b}Syntax@{ub}
   SPECIAL ???

@{b}Funktion@{ub}
   @{i}Keine Funktion.@{ui}

@endnode

@remark ******
@node "SPLINE" "SPLINE - interner Befehl"

@{b}Syntax@{ub}
   SPLINE;<1.Punkt>;<2.Punkt>;<3.Punkt>;...[;<126.Punkt>]

@{b}Funktion@{ub}
   Erzeugt eine Splinekurve, die durch die Punkte <1.Punkt>;<2.Punkt>
   <3.Punkt>;...[;<126.Punkt>] verläuft. Die Kurve muß durch mind.
   drei Punkte spezifiziert werden, jedoch nicht mehr als 126.

   @{i}Für Splinekurven muß ein lineares Gleichungssystem vom Grad @{b}n @{ub}
   (n=Anzahl der Punkte) gelöst werden, was auf langsamen Rechnern einige
   Zeit dauern kann und so den Bildschirmaufbau u.U. erheblich verlangsamt. @{ui}

@{b}Siehe auch@{ub}
   @{" CHCURVE " link "CHCURVE" 0}, @{" BEZIER " link "BEZIER" 0}, @{" FRAMEON " link "FRAMEON" 0}
@endnode

