  @{" UNERASE   " link "UNERASE" 0} -- Gelöschte Elemente wieder aktivieren
  @{" UNGROUP   " link "UNGROUP" 0} -- Gruppe (Block) auflösen
  @{" VAR       " link "VAR" 0} -- Variable erzeugen
  @{" VOID      " link "VOID" 0} -- Leerfunktion
  @{" WORKLAYER " link "WORKLAYER" 0} -- Arbeitsebene (Folie) festlegen
  @{" XHAIROFF  " link "XHAIROFF" 0} -- (großes) Fadenkreuz ausschalten
  @{" XHAIRON   " link "XHAIRON" 0} -- (großes) Fadenkreuz einschalten
  @{" ZOOM      " link "ZOOM" 0} -- Ausschnitt vergrößern bzw. verkleinern
  @{" ZOOMA     " link "ZOOMA" 0} -- Gesamt ("Zoom All")
  @{" ZOOME     " link "ZOOME" 0} -- Gesamt
  @{" ZOOML     " link "ZOOML" 0} -- letzter Ausschnitt ("Zoom Last")
  @{" ZOOMW     " link "ZOOMW" 0} -- neuer Ausschnitt ("Zoom Window")


@{b}Sonderzeichen bei Koordinateneingabe@{ub}

  @{" @ " link "Relativkoordinaten" 0} -- Relativkoordinaten
  @{" < " link "Polarkoordinaten" 0} -- Polarkoordinaten
  @{" ~ " link "Turtlegrafik" 0} -- "Turtlegrafik"

;-)
@endnode

@remark **********************************************************************
@node "ABOUT" "ABOUT - interner Befehl"

@{b}Syntax@{ub}
   ABOUT

@{b}Funktion@{ub}
   Öffnet einen Requester mit Informationen über das Programm.

@{b}Siehe auch@{ub}
@endnode

@remark ******
@node "ANG" "ANG - interner Befehl"

@{b}Syntax@{ub}

@{b}Funktion@{ub}

@{b}Siehe auch@{ub}
@endnode

@remark ******
@node "ARC3B" "ARC3B - interner Befehl"

@{b}Syntax@{ub}
   ARC3B;<startpunkt>;<endpunkt>;<punkt auf kreisbogen>

@{b}Funktion@{ub}
   Zeichnet einen Kreisbogen, der durch die 3 Punkte <startpunkt> <endpunkt>
   und <punkt auf kreisbogen> definiert ist.
   Dieser Befehl ist bis aus die Reihenfolge der Punkte identisch
   mit ARC3L.

@{b}Siehe auch@{ub}
   @{" ARC3L " link "ARC3L" 0}, @{" ARCSE " link "ARCSE" 0}
@endnode

@remark ******
@node "ARC3L" "ARC3L - interner Befehl"

@{b}Syntax@{ub}
   ARC3L;<startpunkt>;<punkt auf kreisbogen>;<endpunkt>

@{b}Funktion@{ub}
   Zeichnet einen Kreisbogen, der durch die 3 Punkte <startpunkt>
   <punkt auf kreisbogen> und <endpunkt> definiert ist.
   Dieser Befehl ist bis aus die Reihenfolge der Punkte identisch
   mit ARC3B.

@{b}Siehe auch@{ub}
   @{" ARC3B " link "ARC3B" 0}, @{" ARCSE " link "ARCSE" 0}
@endnode

@remark ******
@node "ARCSE" "ARCSE - interner Befehl"

@{b}Syntax@{ub}
   ARCSE;<zentrum>;<startpunkt>;<endpunkt>|<bogenweite>

@{b}Funktion@{ub}
   Zeichnet einen Kreisbogen, der durch den Mittelpunkt <zentrum>,
   einen <startpunkt> und einen <endpunkt> definiert wird.
   Durch <zentrum> und <startpunkt> werden Lage und Radius, sowie der
   Anfangswinkel (gegen Uhrzeigersinn) bestimmt. Durch den <endpunkt> wird
   die Bogenweite festgelegt. Statt einem <endpunkt> kann man auch die
   <bogenweite> eingeben.

   <zentrum>      (point)
   <startpunkt>   (point)
   <endpunkt>     (point)
   <bogenweite>   (real/numeric)

@{b}Beispiel@{ub}
   
   @{i}Zentrum=(0,0); Radius=Wurzel(2); Bogenstart=45°; Bogenweite=135° @{ui}
   arcse; 0,0; 1,1; -1,0

   @{i}gleichbedeutend mit @{ui}
   arcse; 0,0; 1,1; 135

@{b}Siehe auch@{ub}
   @{" ARC3B " link "ARC3B" 0}, @{" ARC3L " link "ARC3L" 0}
@endnode

@remark ******
@node "ARROW" "ARROW - interner Befehl"

@{b}Syntax@{ub}
   ARROW;<1.Punkt>;<2.Punkt>;...[;<126.Punkt>]

@{b}Funktion@{ub}
   Erzeugt einen Linienzug mit einer Pfeilspitze am Anfang.
   Der Linienzug ist durch die Punkte <1.Punkt> bis <letzter Punkt> gegeben
   und muß mind. 2 Punkte enthalten, jedoch nicht mehr als 126.
   Die Pfeilspitze wird mit den aktuellen Werten erzeugt.

@{b}Siehe auch@{ub}
   @{" CFGAH " link "CFGAH" 0}, @{" DARROW " link "DARROW" 0}
@endnode

@remark ******
@node "BAKOFF" "BAKOFF - interner Befehl"

@{b}Syntax@{ub}
   BAKOFF

@{b}Funktion@{ub}
   Keine Backupdateien #?.BAK erzeugen.

@{b}Siehe auch@{ub}
   @{" BAKON " link "BAKON" 0}, @{" PVSOFF " link "PVSOFF" 0}, @{" SETBKTIME " link "SETBKTIME" 0}
@endnode

@remark ******
@node "BAKON" "BAKON - interner Befehl"

@{b}Syntax@{ub}
   BAKON

@{b}Funktion@{ub}
   Backupdateien #?.BAK beim Speichern (@{"SAVE,SAVEAS,SAVEP" link "SAVE" 0}) erzeugen.

@{b}Beispiel@{ub}

   "WORK.PCD"        aktuelle Zeichnung
   "WORK.PCD.BAK"    vorherige Version der Zeichnung

@{b}Siehe auch@{ub}
   @{" BAKOFF " link "BAKOFF" 0}, @{" PVSON " link "PVSON" 0}, @{" SETBKTIME " link "SETBKTIME" 0}
@endnode

@remark ******
@node "BEZIER" "BEZIER - interner Befehl"

@{b}Syntax@{ub}
   BEZIER;<1.Punkt>;<2.Punkt>;<3.Punkt>;...[;<126.Punkt>]

@{b}Funktion@{ub}
   Erzeugt eine Bezier-Kurve, die durch das Stützpolygon <1.Punkt> bis
   <letzter Punkt> definiert wird.
   Das Stützpolygon muß mindestens 3 Punkte enthalten, jedoch nicht mehr
   als 126.

@{b}Siehe auch@{ub}
   @{" CHCURVE " link "CHCURVE" 0}, @{" FRAMEON " link "FRAMEON" 0}, @{" SPLINE " link "SPLINE" 0}
@endnode

@remark ******
@node "BOX" "BOX - interner Befehl"
@{b}Syntax@{ub}
   BOX;<links oben>;<rechts unten>

@{b}Funktion@{ub}
   Erzeugt ein rechteckiges Polygon, das durch die 2 Eckpunkte
   <links oben> und <rechts unten> definiert wird.

@{b}Siehe auch@{ub}
   @{" POLY " link "POLY" 0}, @{" RPOLY " link "RPOLY" 0}
@endnode

@remark ******
@node "BREAK" "BREAK - interner Befehl"

@{b}Syntax@{ub}
   BREAK;<element pick>;<startpunkt>;<endpunkt>

@{b}Funktion@{ub}
   "Bricht" einen Bereich aus einem Element.
   Das zu bearbeitende Element wird durch den <element pick> Punkt
   bestimmt. Die Punkte <startpunkt> und <endpunkt> legen den Bereich fest,
   welcher herausgebrochen/entfernt wird.
   Falls notwendig bestimmt der Punkt <element pick> das zu entfernende
   Fragment (z.B. bei Kreisen).

@{b}Anmerkung@{ub}
   Diese Funktion verändert u.U. den Element-Typ:
      Kreis -> Kreisbogen
      Polygon -> Linie/Linienzug
   Bei Kreisen o. Polygonen wird derjenige Teil entfernt, auf dem alle 3 Punkte
   <element pick> <startpunkt> und <endpunkt> liegen.

@{b}Siehe auch@{ub}
   @{" TRIM " link "TRIM" 0}
@endnode

@remark ******
@node "BSPLINE" "BSPLINE - interner Befehl"

@{b}Syntax@{ub}
   BSPLINE;<1.Punkt>;<2.Punkt>;<3.Punkt>;...[;<126.Punkt>]

@{b}Funktion@{ub}

@{b}Siehe auch@{ub}
   @{" SPLINE " link "SPLINE" 0}
@endnode

@remark ******
@node "CEN" "CEN - interner Befehl"

@{b}Syntax@{ub}
   CEN;<element pick>

@{b}Funktion@{ub}
   Koordinaten @{"Modifizierer" link "modifiers"0} für (Kreis/bogen-)Mittelpunkt.
   Durch den Punkt <element pick> wird ein Element bestimmt, dessen
   Mittelpunkt/Zentrum (soweit möglich) zurückgegeben wird.

@{b}Siehe auch@{ub}
   @{" MDP " link "MDP" 0}
@endnode

@remark ******
@node "CFGAH" "CFGAH - interner Befehl"

@{b}Syntax@{ub}
   CFGAH;<type>;<öffnungswinkel>;<größe>

@{b}Funktion@{ub}
   Legt die aktuellen Werte für neue Pfeile (Pfeilspitzen) fest.
   <type>            (integer) Nummer des @{"Pfeilspitzentyps" link "PCAD:Help/Arrowheads.pic/main"}
   <öffnungswinkel>  (real/angle)
   <größe>           (real/distance)

@{b}Siehe auch@{ub}
   @{" ARROW " link "ARROW" 0}, @{" CHARH " link "CHARH"}, @{" DARROW " link "DARROW" 0}
@endnode

@remark ******
@node "CFGDM" "CFGDM - interner Befehl"

@{b}Syntax@{ub}
   CFGDM

@{b}Funktion@{ub}
   Bestimmt die Werte für neue Bemaßungen.
   Dazu wird ein entsprchender Requester geöffnet.

@{b}Siehe auch@{ub}
   @{" CFGAH " link "CFGAH" 0}, @{" LDIM " link "LDIM" 0}, @{" RDIM " link "RDIM" 0}
@endnode

@remark ******
@node "CFGTX" "CFGTX - interner Befehl"

@{b}Syntax@{ub}
   CFGTX

@{b}Funktion@{ub}
   Legt die aktuellen Werte für neue Text-Elemente fest.

@{b}Siehe auch@{ub}
   @{" CHTXF " link "CHTXF" 0}, @{" CHTXH " link "CHTXH" 0}
@endnode

