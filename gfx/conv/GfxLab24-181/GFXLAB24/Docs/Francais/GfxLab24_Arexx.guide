@endnode

@node "ARexxRemoveIsolatedPixel" "ARexx port : Remove Isolated Pixels"

 @{b} Nom de la commande:@{ub} @{"RemIsolated" link "GfxLab24.guide/OP_RemoveIsolatedPixels" 0}

  @{b}Syntaxe:@{ub} RemIsolated <THRES> <CONTEXT> [BANK†1-5]

  @{b}ParamÍtres:@{ub}

    <THRES> : La seuil de sensibilitť de†l'opťrateur.
