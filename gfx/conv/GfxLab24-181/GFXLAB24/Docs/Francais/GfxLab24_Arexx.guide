@endnode

@node "ARexxDispersePixel" "ARexx port : Disperse Pixel"

 @{b} Nom de la commande:@{ub} @{"DispersePixel" link "GfxLab24.guide/OP_DispersePixels" 0}

  @{b}Syntaxe:@{ub} DispersePixel <RADIUS> <PROBA> [BANK†1-5]

  @{b}ParamÍtres:@{ub}

    <RADIUS> : Le rayon d'action de l'opťration,†en pixels.

