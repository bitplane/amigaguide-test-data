@node "ARexxConvolve" "ARexx port : Convolve"

 @{b} Nom de la commande:@{ub} @{"Convolve" link "GfxLab24.guide/OP_Convolution" 0}

  @{b}Syntaxe:@{ub} Convolve <FILENAME> [THRES] [BANK†1-5]

  @{b}ParamÍtres:@{ub}

    <FILENAME> : Un nom de fichier de type†Convolve. Il doit contenir
