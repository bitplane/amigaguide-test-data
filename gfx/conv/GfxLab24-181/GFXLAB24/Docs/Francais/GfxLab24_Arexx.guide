@endnode

@node "ARexxQuake" "ARexx port : Quake"

 @{b} Nom de la commande:@{ub} @{"Quake" link "GfxLab24.guide/OP_Quake" 0}

  @{b}Syntaxe:@{ub} Quake <RADIUS> [DIRECTION] [BANK†1-5]

  @{b}ParamÍtres:@{ub}

