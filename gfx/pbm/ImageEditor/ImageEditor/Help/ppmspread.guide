@DATABASE "ppmspread.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: ColorDisplace [ppmspread]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}ColorDisplace@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Displace a portable pixmap's pixels by a random amount.@{UB}@{LINE}
@{PAR}Reads a portable pixmap as input. Moves every pixel around a bit relative to its original position.
Amount determines by how many pixels a pixel is to be moved around at most.@{LINE}
@{PAR}Pictures processed with this filter will seem to be somewhat dissolved or unfocussed (although they appear more coarse than images processed by something like Convolve).@{LINE}
@{PAR}See also @{" Convolve " LINK "pnmconvol.guide/MAIN"} and @{" ColorShift " LINK "ppmshift.guide/MAIN"}.@{LINE}
@{PAR}[@{B}ppmspread@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1993 by Frank Neumann @{UI}@{FG TEXT}@{LINE}

@ENDNODE

