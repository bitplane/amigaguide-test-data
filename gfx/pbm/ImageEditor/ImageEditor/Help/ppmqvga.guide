@DATABASE "ppmqvga.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: ColorTo8bit [ppmqvga]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}ColorTo8bit@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Quantize the colors in a portable pixmap down to 8 planes.@{UB}@{LINE}
@{PAR}Reads a portable pixmap as input. Chooses 256 colors to best represent the image,
maps the existing colors to 8 planes, and writes a portable pixmap as output.@{LINE}
@{PAR}See also @{" ColorDither " LINK "ppmdither.guide/MAIN"} and @{" ColorReduce " LINK "ppmquant.guide/MAIN"}.@{LINE}
