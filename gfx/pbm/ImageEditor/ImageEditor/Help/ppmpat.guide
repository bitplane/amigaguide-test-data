@DATABASE "ppmpat.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Loader: ˛Pattern [ppmpat]"
@TOC "Loader.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}˛Pattern@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Create a tileable pattern pixmap.@{UB}@{LINE}
@{PAR}Produces a portable pixmap of the specified width and height, with a pattern in it.
The various different pattern types are:@{LINE}
@{LINDENT 8}@{LINE}
@{B}Gingham check pattern@{UB} @{TAB}@{FG HIGHLIGHT} @{I}tileable @{UI}@{FG TEXT}@{LINE}
@{B}Complex Gingham pattern@{UB} @{TAB}@{FG HIGHLIGHT} @{I}tileable @{UI}@{FG TEXT}@{LINE}
@{B}Madras plaid@{UB} @{TAB}@{TAB}@{TAB}@{FG HIGHLIGHT} @{I}tileable @{UI}@{FG TEXT}@{LINE}
@{B}Tartan plaid@{UB} @{TAB}@{TAB}@{TAB}@{FG HIGHLIGHT} @{I}tileable @{UI}@{FG TEXT}@{LINE}
@{B}Random Color gradients@{UB} @{TAB}@{FG HIGHLIGHT} @{I}not tileable @{UI}@{FG TEXT}@{LINE}
@{B}Squiggley tubular pattern@{UB} @{TAB}@{FG HIGHLIGHT} @{I}tileable @{UI}@{FG TEXT}@{LINE}
@{B}Camouflage pattern@{UB} @{TAB}@{TAB}@{FG HIGHLIGHT} @{I}not tileable @{UI}@{FG TEXT}@{LINE}
@{B}ultra-bright Camouflage@{UB} @{TAB}@{FG HIGHLIGHT} @{I}not tileable @{UI}@{FG TEXT}@{LINE}
@{LINDENT 4}
@{PAR}See also @{" ˛Clouds " LINK "ppmforge.guide/CLOUDS"}, @{" ˛Stars " LINK "pnmtile.guide/STARS"} and @{" Tile " LINK "pnmtile.guide/MAIN"}.@{LINE}
