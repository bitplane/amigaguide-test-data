@DATABASE "pnmcat.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Operator: Concatenate [pnmcat]"
@TOC "Operator.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}Concatenate@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Concatenate a bunch of portable anymaps.@{UB}@{LINE}
@{PAR}Reads portable anymaps as input. Concatenates them either left to right or top to bottom, and produces a portable anymap as output.@{LINE}
@{PAR}If the anymaps are not all the same height or width, the smaller ones have to be justified with the largest.
By default, they get centered, but you can specify one side or the other.
So, Horizontal Left would stack the anymaps on top of each other, flush with the left edge.@{LINE}
Fillcolor specify what color to use to fill in the extra space when doing this justification.@{LINE}
@{PAR}[@{B}pnmcat@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1989 by Jef Poskanzer @{UI}@{FG TEXT}@{LINE}

@ENDNODE
