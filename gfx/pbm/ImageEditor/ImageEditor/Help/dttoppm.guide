@DATABASE "dttoppm.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Loader: Universal [dttoppm]"
@TOC "Loader.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}Universal@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Convert any Picture file into a portable pixmap.@{UB}@{LINE}
@{PAR}This is a very simple program to convert any picture file into a PPM file,
if a datatype is available for that picture file.
V43/44 datatype are supported to be able to convert 24bit file formats.@{LINE}
@{PAR}[@{B}dttoppm@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1998 by Thore Boeckelmann @{UI}@{FG TEXT}@{LINE}

@ENDNODE
