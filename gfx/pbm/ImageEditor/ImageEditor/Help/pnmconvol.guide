@DATABASE "pnmconvol.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Operator: Convolve [pnmconvol]"
@TOC "Operator.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}Convolve@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}General convolution on a portable anymap.@{UB}@{LINE}
@{PAR}Convolution means replacing each pixel with a weighted average of the nearby pixels.
The weights and the area to average are determined by the convolution matrix.
The unsigned numbers in the convolution file are offset by maxval/2 to make signed numbers,
and then normalized, so the actual values in the convolution file are only relative.@{LINE}
@{PAR}@{FG HIGHLIGHT}The convolution file will usually be a graymap, so that the same convolution gets applied to each color component.@{FG TEXT}@{LINE}
@{PAR}See also @{" Filter " LINK "pnmnlfilt.guide/MAIN"}.@{LINE}
@{PAR}[@{B}pnmconvol@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1991 by Jef Poskanzer @{UI}@{FG TEXT}@{LINE}

@ENDNODE
