@DATABASE "pgmnoise.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Loader: ¹Noise [pgmnoise]"
@TOC "Loader.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}¹Noise@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Create a graymap made up of white noise.@{UB}@{LINE}
@{PAR}Creates a portable graymap that is made up of random pixels with gray values in the range of 0 to 255.
The graymap has a size of width * height pixels.@{LINE}
@{PAR}These images are useful for multiplying with other images,
using the @{" Arithmetic " LINK "pnmarith.guide/MAIN"} operator,
or coloring with the @{" GreyToColor " LINK "pgmtoppm.guide/MAIN"} converter.@{LINE}
