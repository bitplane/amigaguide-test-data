@DATABASE "pnmarith.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Operator: Arithmetic [pnmarith]"
@TOC "Operator.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}Arithmetic@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Perform arithmetic on two portable anymaps.@{UB}@{LINE}
@{PAR}Reads two portable anymaps as input.
Performs the specified arithmetic operation,
and produces a portable anymap as output.
The two input anymaps must be the same width and height.@{LINE}
@{PAR}The arithmetic is performed between corresponding pixels in the two anymaps,
as if maxval was 1.0, black was 0.0, and a linear scale in between.
Results that fall outside of [0..1) are truncated.@{LINE}
@{PAR}See also @{" Paste " LINK "pnmpaste.guide/MAIN"} and @{" Invert " LINK "pnminvert.guide/MAIN"}.@{LINE}
@{PAR}[@{B}pnmarith@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1991 by Jef Poskanzer @{UI}@{FG TEXT}@{LINE}

@ENDNODE
