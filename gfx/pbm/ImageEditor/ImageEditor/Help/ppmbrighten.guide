@DATABASE "ppmbrighten.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: ColorSaturation [ppmbrighten]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}ColorSaturation@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Change an images Saturation and Value from an HSV map.@{UB}@{LINE}
@{PAR}Reads a portable pixmap as input. Converts the image from RGB space to HSV space and changes the Value and Saturation as a percentage.@{LINE}
@{PAR}The Value and Saturation exist between -100% and 400%.@{LINE}
@{PAR}See also @{" GreyContrast " LINK "pgmnorm.guide/MAIN"} and @{" ColorContrast " LINK "ppmnorm.guide/MAIN"}.@{LINE}
