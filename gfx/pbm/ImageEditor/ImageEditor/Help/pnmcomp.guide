@DATABASE "pnmcomp.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Operator: Compose [pnmcomp]"
@TOC "Operator.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}Compose@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Composite two portable anymap files together.@{UB}@{LINE}
@{PAR}Reads in a portable any map image and put a overlay image upon it, with optional alpha image mask.@{LINE}
@{PAR}The alpha PGM file allows you to also add an alpha mask file to the compositing process,
the range of max and min can be swapped by using the invert option.@{LINE}
@{PAR}The X- and Y-Offsets can be negative, allowing you to shift the overlay and alpha image off the top corner of the screen.@{LINE}
@{PAR}@{FG HIGHLIGHT}Overlay and alpha image must have the same dimensions.@{FG TEXT}@{LINE}
@{PAR}See also @{" ColorMixer " LINK "ppmmix.guide/MAIN"}.@{LINE}
@{PAR}[@{B}pnmcomp@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1992 by David Koblas @{UI}@{FG TEXT}@{LINE}

@ENDNODE
