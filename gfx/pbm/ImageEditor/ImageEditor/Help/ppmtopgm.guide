@DATABASE "ppmtopgm.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: ColorToGrey [ppmtopgm]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}ColorToGrey@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Convert a portable pixmap into a portable graymap.@{UB}@{LINE}
@{PAR}Reads a portable pixmap as input. Produces a portable graymap as output.
The quantization formula used is 0.299 Red + 0.587 Green + 0.114 Blue.@{LINE}
@{PAR}Note that although there is a pgmtoppm program, it is not necessary for simple conversions from pgm to ppm,
because any ppm program can read pgm (and pbm) files automagically. pgmtoppm is for colorizing a pgm file.@{LINE}
@{PAR}See also @{" GreyToColor " LINK "pgmtoppm.guide/MAIN"}.@{LINE}
@{PAR}[@{B}ppmtopgm@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1989 by Jef Poskanzer @{UI}@{FG TEXT}@{LINE}

@ENDNODE
