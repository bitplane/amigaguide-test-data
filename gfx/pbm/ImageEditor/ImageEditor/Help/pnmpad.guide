@DATABASE "pnmpad.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Operator: Pad [pnmpad]"
@TOC "Operator.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}Pad@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Add borders to portable anymap.@{UB}@{LINE}
@{PAR}Reads a portable anymap as input.
Outputs a portable anymap with extra borders of the sizes specified.
The colour of the borders can be set to black or white.@{LINE}
@{PAR}See also @{" Crop " LINK "pnmcrop.guide/MAIN"} and @{" Paste " LINK "pnmpaste.guide/MAIN"}.@{LINE}
