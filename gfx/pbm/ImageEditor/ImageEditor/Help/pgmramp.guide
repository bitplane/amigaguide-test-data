@DATABASE "pgmramp.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Loader: ¹Ramp [pgmramp]"
@TOC "Loader.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}¹Ramp@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Create a specified grayscale ramp.@{UB}@{LINE}
@{PAR}Generates a graymap of the specified size containing a black-to-white ramp,
with one of the following directions:@{LINE}
@{LINDENT 16}@{LINE}
@{B}Vertical@{UB} @{TAB}@{TAB}@{FG HIGHLIGHT} @{I}left to right @{UI}@{FG TEXT}@{LINE}
@{B}Horizontal@{UB} @{TAB}@{TAB}@{FG HIGHLIGHT} @{I}top to bottom @{UI}@{FG TEXT}@{LINE}
@{B}Rectangular@{UB} @{TAB}@{FG HIGHLIGHT} @{I}highlighting @{UI}@{FG TEXT}@{LINE}
@{B}Elliptical@{UB} @{TAB}@{TAB}@{FG HIGHLIGHT} @{I}circle whole @{UI}@{FG TEXT}@{LINE}
@{LINDENT 4}
@{PAR}These ramps are useful for multiplying with other images,
using the @{" Arithmetic " LINK "pnmarith.guide/MAIN"} operator,
or coloring with the @{" GreyToColor " LINK "pgmtoppm.guide/MAIN"} converter.@{LINE}
@{PAR}[@{B}pgmramp@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1989 by Jef Poskanzer @{UI}@{FG TEXT}@{LINE}

@ENDNODE
