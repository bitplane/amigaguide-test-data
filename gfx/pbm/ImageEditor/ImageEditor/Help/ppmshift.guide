@DATABASE "ppmshift.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: ColorShift [ppmshift]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}ColorShift@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Shift lines of a portable pixmap left or right by a random amount.@{UB}@{LINE}
@{PAR}Reads a portable pixmap as input. Shifts every row of image data to the left or right by a certain amount.
The shifting determines by how many pixels a row is to be shifted at most.@{LINE}
@{PAR}The resulting picture looks like an image being reflected on a water surface with slight ripples.@{LINE}
@{PAR}See also @{" ColorDisplace " LINK "ppmspread.guide/MAIN"}.@{LINE}
@{PAR}[@{B}ppmshift@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1993 by Frank Neumann @{UI}@{FG TEXT}@{LINE}

@ENDNODE
