@node "1" "What is it?"

@{b}That is it:@{ub}@{line}
@{line}
This is a Graphic User Interface for the program TransADF.
It gives you the possibility to control the shell based programm through a GUI.@{line}

@endnode

@node "2" "What does it do?"

@{jcenter}
@{b}Supported options:@{ub}@{line}
@{line}
- Read/Write ADF Filese@{line}
- Verifying@{line}
- Set Start-Track@{line}
- Set End-track@{line}

@endnode

@node "3" "What is needed?"

@{jcenter}
@{b}Requirements:@{ub}@{line}
@{line}
@{line}
- Amiga@{line}
- AOS3.0 or higher@{line}
- TransADF in C:@{line}

@endnode

@node "4" "Installation!"

@{u}Installation:@{uu}@{line}
@{line}
Nothing special. Copy the complet directory to the place wherever you want to have it.@{line}
@{line}

@endnode

@node "5" "Menu!"

@{b}Menu:@{ub}@{line}
@{line}
@{line}
  Project/About@{line}
    Programmers info@{line}
@{line}
  Project/Quit@{line}
    Quit the GMP-G. Current settings will be saved.@{line}
@{line}
@{line}
  Program/ResetTo Defaults@{line}
    Restore the GUI to defult values.@{line}
@{line}
  Program/Status@{line}
    Tells you, if the TransADF is found on systemor not.@{line}

@endnode

