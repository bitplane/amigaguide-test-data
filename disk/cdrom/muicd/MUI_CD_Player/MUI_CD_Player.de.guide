  @{"Joypad-Steuerung" link joypad}
  @{"Beim Start Fenster öffnen" link popup}
  @{"Lautstärkeregler" link volumecontrol}
  @{"Balance-Regler" link balancecontrol}
  @{"Positions-Schieber" link positionslider}
