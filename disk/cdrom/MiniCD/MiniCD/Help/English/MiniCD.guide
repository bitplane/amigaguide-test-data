@node AREXX "ARexx"

@{b}ARexx@{ub}
@{b}=====@{ub}

One of the big features of MiniCD is CD control by ARexx. MiniCD creates it's own ARexx port named @{i}MINICD.1@{ui}. There are some basic functions.


@{b}TABLE OF CONTENTS@{ub}

minicd/@{"mcd_quit" link AREXX_QUIT}
minicd/@{"mcd_hide" link AREXX_HIDE}
minicd/@{"mcd_about" link AREXX_ABOUT}
minicd/@{"mcd_help" link AREXX_HELP}
minicd/@{"mcd_play" link AREXX_PLAY}
minicd/@{"mcd_stop" link AREXX_STOP}
minicd/@{"mcd_pause" link AREXX_PAUSE}
minicd/@{"mcd_eject" link AREXX_EJECT}
@endnode

@node AREXX_QUIT "ARexx: mcd_quit"

   @{b}NAME@{ub}
        mcd_quit -- quits from minicd

   @{b}SYNOPSIS@{ub}
        mcd_quit

   @{b}FUNCTION@{ub}
        Quits immediately from MiniCD.

   @{b}RESULT@{ub}
        none
@endnode

@node AREXX_HIDE "ARexx: mcd_hide"

   @{b}NAME@{ub}
        mcd_hide -- hide all windows

   @{b}SYNOPSIS@{ub}
        mcd_hide

   @{b}FUNCTION@{ub}
        Hides all MiniCD windows.

   @{b}RESULT@{ub}
        none
@endnode

@node AREXX_ABOUT "ARexx: mcd_about"

   @{b}NAME@{ub}
        mcd_about -- returns about string

   @{b}SYNOPSIS@{ub}
        mcd_about

   @{b}FUNCTION@{ub}
        Returns about string to the user.

   @{b}RESULT@{ub}
        About string
@endnode

@node AREXX_HELP "ARexx: mcd_help"

   @{b}NAME@{ub}
        mcd_help -- opens minicd help

   @{b}SYNOPSIS@{ub}
        mcd_help

   @{b}FUNCTION@{ub}
        Loads and opens minicd help.

   @{b}RESULT@{ub}
        none
@endnode

@node AREXX_PLAY "ARexx: mcd_play"

   @{b}NAME@{ub}
        mcd_play -- play a given track

   @{b}SYNOPSIS@{ub}
        mcd_play TRACK/N

   @{b}FUNCTION@{ub}
        Starts playing a given track.

   @{b}RESULT@{ub}
        none
@endnode

@node AREXX_STOP "ARexx: mcd_stop"

   @{b}NAME@{ub}
        mcd_stop -- stop playing a CD

   @{b}SYNOPSIS@{ub}
        mcd_stop

   @{b}FUNCTION@{ub}
        Stop playing a CD.

   @{b}RESULT@{ub}
        none
@endnode

@node AREXX_PAUSE "ARexx: mcd_pause"

   @{b}NAME@{ub}
        mcd_pause -- pauses or resumes playing

   @{b}SYNOPSIS@{ub}
        mcd_pause

   @{b}FUNCTION@{ub}
        Pauses or resumes playing current track.

   @{b}RESULT@{ub}
        none
@endnode

@node AREXX_EJECT "ARexx: mcd_eject"

   @{b}NAME@{ub}
        mcd_eject -- eject CD

   @{b}SYNOPSIS@{ub}
        mcd_eject

   @{b}FUNCTION@{ub}
        Ejects a CD.

   @{b}RESULT@{ub}
        none
@endnode
