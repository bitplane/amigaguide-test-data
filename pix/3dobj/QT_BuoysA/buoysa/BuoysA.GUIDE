@node "GRD" "GUARDIAN BUOY"

 GRD.ibj

 @{b}GUARDIAN BUOY@{ub}                                                      GRD-1/LMN
 ============================================================================
 @{u}CLASSIFICATION@{uu}: GUARDIAN BUOY

 @{u}MODEL@{uu}: GRD-1

 @{u}RANGE@{uu}: 8.21x10^13 km

 @{u}TELEMETRY/CHANNELS@{uu}: 10,215

 @{u}BUOY FEATURES@{uu}:
   standard package
   beta sensor package
   communication software
   electromagnetic software
   electronic counter measure
   fempto second data collection
   field detectors
   imaging system
   interstellar communication
   long range particle detectors
   multi-frequency beacon
   multi-phased array sensor
   ship analysis software
   short term high output phaser

 @{u}DESCRIPTION@{uu}: These are used to protect sensitive areas from small ships.  The
buoy cannot stop a starship.  When comprmised it will explode with a 1000 cubic
meter blast radius.

 @{u}TEXTURES@{uu}: Metals2,Dirt,FireBall (all standard Imagine textures)
@endnode

