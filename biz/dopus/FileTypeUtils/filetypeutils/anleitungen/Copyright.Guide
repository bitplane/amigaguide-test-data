@NODE "Copyright" "Copyright und Verteilungsbedingungen"
@PREV "MAIN"
@TOC "MAIN"


    @{"" ""}@{bg shine}  Copyright  @{bg back}@{"" ""}


    FileTypeInfo.Check                Ausnahmen:
