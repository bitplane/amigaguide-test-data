@{" Entfernen " Link Entfernen}

@{b}Diagramm (Grafik-Fenster)@{ub}
@{" Öffne Verwalter " Link Öffne_Verwalter}
@{" Neu zeichnen " Link Neu_Zeichnen}
@{" Größe nach " Link Größe_nach}
@{" Speichern (ILBM) " Link Speichern_(ILBM)}
@{" Drucken " Link Drucken..}
@{" Kopieren (ILBM)" Link Kopieren_(ILBM)}
@{" Schließen " Link Schließen.}

@{b}Teildiagramm (Diagramm-Verwalter)@{ub}
@{" Ausschneiden " Link Ausschneiden.}
