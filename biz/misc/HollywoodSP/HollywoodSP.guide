@NODE V6LibGfxLayer "Guía de 'Hollywood'"

@{b}Capas@{ub}

  @{"Introducción                      " LINK LayersIntroduction}
  żQué es una capa? ĄLea este apartado en primer lugar!


  @{"AddMove()                         " LINK AddMove}
  Ańade un objeto a la lista de movimiento

  @{"ClearMove()                       " LINK ClearMove}
  Vacía una lista de movimiento

  @{"CreateLayer()                     " LINK CreateLayer}
  Crea una nueva capa

  @{"DisableLayers()                   " LINK DisableLayers}
  Desactiva las capas para la visualización actual

  @{"DoMove()                          " LINK DoMove}
  Genera la salida gráfica de una lista de movimiento

  @{"EnableLayers()                    " LINK EnableLayers}
