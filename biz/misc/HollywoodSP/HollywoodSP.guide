  @{"IsMusic()                         " LINK IsMusic}
  Comprueba si un fichero de música tiene un formato soportado

  @{"IsMusicPlaying()                  " LINK IsMusicPlaying}
  Comprueba si la música se está reproduciendo actualmente

  @{"OpenMusic()                       " LINK OpenMusic}
  Abre la música/melodía

  @{"PauseMusic()                      " LINK PauseMusic}
  Pausa la música actualmente en reproducción

  @{"PlayMusic()                       " LINK PlayMusic}
  Inicia la reproducción de la música

  @{"ResumeMusic()                     " LINK ResumeMusic}
  Retoma la música pausada

  @{"SeekMusic()                       " LINK SeekMusic}
  Salta a una posición especificada en una música

  @{"SetMusicVolume()                  " LINK SetMusicVolume}
  Modifica el volumen de la música

  @{"StopMusic()                       " LINK StopMusic}
  Detiene la reproducción de la música

  Las funciones siguientes  sólo pueden ser utilizadas cuando @{"PlayMusic()" LINK PlayMusic} está
  reproduciendo un módulo de @{u}Protracker@{uu}:

  @{"GetPatternPosition()              " LINK GetPatternPosition}
  Obtiene la posición del patrón del módulo actual

  @{"GetSongPosition()                 " LINK GetSongPosition}
  Obtiene la posición de la canción en el módulo actual

  @{"PlaySubsong()                     " LINK PlaySubsong}
  Reproduce una canción

  @{"WaitPatternPosition()             " LINK WaitPatternPosition}
  Espera a que la posición del patrón especificado se alcance

  @{"WaitSongPosition()                " LINK WaitSongPosition}
  Espera a que la posición de la canción especificada se alcance

  Las  funciones  siguientes  se  utilizaban  en  @{u}Hollywood@{uu} 1.x para reproducir
  módulos  de  @{u}Protracker@{uu}.   Aún pueden utilizarse puesto que @{u}Hollywood@{uu} 2.0 las
  emula.   Para  nuevos  guiones,  sin  embargo,  es preferible que utilice las
  nuevas funciones musicales que se han indicado líneas más atrás.

  @{"FreeModule()                      " LINK FreeModule}
  Libera un módulo

  @{"IsModule()                        " LINK IsModule}
  Determina si un módulo está en un formato soportado

  @{"LoadModule()                      " LINK LoadModule}
  Carga un módulo

  @{"PauseModule()                     " LINK PauseModule}
  Pausa el módulo actualmente en reproducción

  @{"PlayModule()                      " LINK PlayModule}
  Inicia la reproducción de un módulo

  @{"ResumeModule()                    " LINK ResumeModule}
  Retoma la reproducción de un módulo pausado

  @{"StopModule()                      " LINK StopModule}
  Detiene la reproducción actual del módulo


                                                           @{">> Versión original" LINK "HollywoodEN.guide/V6LibSoundMusic"}

@ENDNODE
@REMARK *ššššššššššššššššššššššššššššššššššššššššššššššššššššššššššššššššššššš*
@NODE V6LibSoundMisc "Guía de 'Hollywood'"

@{b}Funciones variadas de sonido@{ub}

  @{"IsSound()                         " LINK IsSound}
