  #LANGUAGE_GREEK              Griego
  #LANGUAGE_HUNGARIAN          Húngaro
  #LANGUAGE_ITALIAN            Italiano
  #LANGUAGE_NORWEGIAN          Noruego
  #LANGUAGE_POLISH             Polaco
  #LANGUAGE_PORTUGUESE         Portugués
  #LANGUAGE_RUSSIAN            Ruso
  #LANGUAGE_SPANISH            Espańol
