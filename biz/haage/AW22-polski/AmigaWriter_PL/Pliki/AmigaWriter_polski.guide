   @{"Pola tekstowe                       " link textbox}
   @{"Formaty                             " link formats}
   @{"Grafika                             " link gfx}
   @{"Dzielenie wyrazów                   " link hyphen}
   @{"Drukowanie                          " link print}

   @{"Odnoôniki                           " link reference}

