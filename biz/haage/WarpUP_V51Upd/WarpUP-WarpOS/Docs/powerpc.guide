        @{"InsertPPC" link InsertPPC}, @{"AddTailPPC" link AddTailPPC}, @{"AddHeadPPC" link AddHeadPPC}, @{"RemovePPC" link RemovePPC}, @{"RemHeadPPC" link RemHeadPPC},
        @{"EnqueuePPC" link EnqueuePPC}, @{"FindNamePPC" link FindNamePPC}, @{"NewListPPC" link NewListPPC}, @{"powerpc/listsPPC.i" link "include:powerpc/listsPPC.i/Main"}

