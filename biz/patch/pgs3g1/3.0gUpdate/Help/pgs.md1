@node DELETEGUIDES

@{U}@{FG Highlight}DELETEGUIDES                                                                @{FG Text}@{UU}

Purpose: Deletes existing guide(s) from a master page.

Syntax:  @{b}deleteguides@{ub} [HORIZONTAL | VERTICAL]
         <AT position/D MPG name//S>

Format:  @{U}Parameter@{UU}  @{U}Values to enter@{UU}
         HORIZONTAL specifies horizontal guides
         VERTICAL   specifies vertical guides
         AT         are the position(s) of the guide(s) to delete.
         MPG        is the master page name and side.

Example: deleteguides vertical at 2.5 mpg left

See also @{"ADDGUIDES" link addguides} and @{"SETGUIDES" link PageStream3:Help/PGS.MD6/setguides}.

@{" Command Format    " link PageStream3:Help/PGS.MSU/FORM}
@{" DOCUMENT, CHAPTER, WINDOW, PAGE, MASTERPAGE, MPG, STYLETAG & ARTICLE " link PageStream3:Help/PGS.MSU/WIND}
@toc PageStream3:Help/PGS.HEL/MAIN
@endnode

@node DELETEMASTERPAGE

@{U}@{FG Highlight}DELETEMASTERPAGE                                                            @{FG Text}@{UU}

Purpose: Delete an existing master page in a document or chapter.

Syntax:  @{b}deletemasterpage@{ub} [MASTERPAGE name/S]

Format:  @{U}Parameter@{UU}  @{U}Values to enter@{UU}
         MASTERPAGE is the master page name. (Default=current)

Example: deletemasterpage 'Two Column Master Page'

@{" Command Format    " link PageStream3:Help/PGS.MSU/FORM}
@{" DOCUMENT, CHAPTER, WINDOW, PAGE, MASTERPAGE, MPG, STYLETAG & ARTICLE " link PageStream3:Help/PGS.MSU/WIND}
@toc PageStream3:Help/PGS.HEL/MAIN
@endnode

@node DELETEOBJECT

@{U}@{FG Highlight}DELETEOBJECT                                                                @{FG Text}@{UU}

Purpose: Deletes selected object(s).

Syntax:  @{b}deleteobject@{ub} [DOCUMENT name/S | WINDOW name/S | OBJECTID number/I]

Format:  @{U}Parameter@{UU}  @{U}Values to enter@{UU}
         DOCUMENT   is the document name. (Default=current)
         WINDOW     is the window name. (Default=current)
         OBJECTID   is the number of the object to manipulate.

Example: deleteobject document 'project.doc'

See also @{"CUTOBJECT" link cutobject}

@{" Command Format    " link PageStream3:Help/PGS.MSU/FORM}
@{" Object ID numbers " link PageStream3:Help/PGS.MSU/IDNU}
@{" DOCUMENT, CHAPTER, WINDOW, PAGE, MASTERPAGE, MPG, STYLETAG & ARTICLE " link PageStream3:Help/PGS.MSU/WIND}
@toc PageStream3:Help/PGS.HEL/MAIN
@endnode

@node DELETEPAGE

@{U}@{FG Highlight}DELETEPAGE                                                                  @{FG Text}@{UU}

Purpose: Deletes page(s) in a document.

Syntax:  @{b}deletepage@{ub} [PAGE number/S] [TO number/S] [ALERT]

Format:  @{U}Parameter@{UU}  @{U}Values to enter@{UU}
         PAGE       is the number of the first page to delete.
                    (Default=current)
         TO         is the number of the last page to delete.
         ALERT      opens an alert requester.

Example: deletepage page 5 to 7
         deletepage page 'Project.doc~5' to 7

@{" Command Format    " link PageStream3:Help/PGS.MSU/FORM}
@{" DOCUMENT, CHAPTER, WINDOW, PAGE, MASTERPAGE, MPG, STYLETAG & ARTICLE " link PageStream3:Help/PGS.MSU/WIND}
@toc PageStream3:Help/PGS.HEL/MAIN
@endnode

@node DELETESTYLETAG

@{U}@{FG Highlight}DELETESTYLETAG                                                              @{FG Text}@{UU}

Purpose: Deletes a style tag.

Syntax:  @{b}deletestyle@{ub} <STYLETAG name/S>

Format:  @{U}Parameter@{UU}  @{U}Values to enter@{UU}
         STYLETAG   is the name of the style to delete.

Example: deletestyletag styletag 'Body Text'

@{" Command Format    " link PageStream3:Help/PGS.MSU/FORM}
@{" DOCUMENT, CHAPTER, WINDOW, PAGE, MASTERPAGE, MPG, STYLETAG & ARTICLE " link PageStream3:Help/PGS.MSU/WIND}
