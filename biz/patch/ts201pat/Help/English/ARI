@remark *** COMMAND DEFINITIONS ***

@node VERSION

Command:  @{FG Highlight}VERSION@{FG Text}

Purpose:  Gets the version number of TypeSmith and stores it in the
          RESULT variable.

Format:   version @{FG Fill}(no parameters)@{FG Text}

Note:     The result must be divided by 100 to get the actual version
          number.
@prev GET_FILE
@toc SUBJ
@endnode

@node TO_FRONT

Command:  @{FG Highlight}TO_FRONT@{FG Text}

Purpose:  Bring the TypeSmith screen to the front.

Format:   to_front @{FG Fill}(no parameters)@{FG Text}
@toc SUBJ
@endnode

@node TO_BACK

Command:  @{FG Highlight}TO_BACK@{FG Text}

Purpose:  Send the TypeSmith screen to the back.

Format:   to_back @{FG Fill}(no parameters)@{FG Text}
@toc SUBJ
@endnode

@node SET_SCALE

Command:  @{FG Highlight}SET_SCALE@{FG Text}

Purpose:  Sets the view scale of the active character window.

Format:   set_scale <x>

Where:    x  is the 1:x scale factor (integer).

Errors:   RC=5  Value out of range.
          RC=10 No font loaded.
@toc SUBJ
@endnode

@node SHOW_FILLED

Command:  @{FG Highlight}SHOW_FILLED@{FG Text}

Purpose:  Shows characters as filled or outlined.

Format:   show_filled <x>

Where:    x  is 0 (outlined) or 1 (filled).

Errors:   RC=10 No font loaded.
@toc SUBJ
@endnode

@node SHOW_TEMPLATE

Command:  @{FG Highlight}SHOW_TEMPLATE@{FG Text}

Purpose:  Shows the bitmap template for the active character window.

Format:   show_template <x>

Where:    x  is 0 (hidden) or 1 (shown).

Errors:   RC=5  No template for the current character.
          RC=10 No font loaded.
@toc SUBJ
@endnode

@node SIZE_WINDOW

Command:  @{FG Highlight}SIZE_WINDOW@{FG Text}

Purpose:  Sets the size of the current character window.

Format:   size_window <'x  y'>

Where:    x  is the horizontal size, in pixels (integer).
          y  is the vertical size, in pixels (integer).

Errors:   RC=10 No font loaded.
@toc SUBJ
@endnode

@node GOTO_CHAR

Command:  @{FG Highlight}GOTO_CHAR@{FG Text}

Purpose:  Changes the character in the active character window to the
          specified character.

Format:   goto_char <x>

Where:    x  is the decimal character number (integer).

Errors:   RC=5  Value out of range.
          RC=10 No font loaded.
@toc SUBJ
@endnode

@node QUIT

Command:  @{FG Highlight}QUIT@{FG Text}

Purpose:  Exits TypeSmith

Format:   quit @{FG Fill}(no parameters)@{FG Text}

Errors:   <none>
@toc SUBJ
@endnode

@node OPEN_DMF

Command:  @{FG Highlight}OPEN_DMF@{FG Text}

Purpose:  Opens a Soft-Logik DMF file and displays character 65.

Format:   open_dmf <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=20  Could not open or not a DMF file.
@toc SUBJ
@endnode

@node SAVE_DMF

Command:  @{FG Highlight}SAVE_DMF@{FG Text}

Purpose:  Saves the current font outline as a Soft-Logik DMF file.

Format:   save_dmf <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=5  Could not save file.
          RC=10 Font outline not open.
@toc SUBJ
@endnode

@node OPEN_FM

Command:  @{FG Highlight}OPEN_FM@{FG Text}

Purpose:  Opens a Soft-Logik FM file. A font outline must already by open.

Format:   open_fm <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=5  Could not open file or not a FM file.
          RC=10 No font loaded.
@toc SUBJ
@endnode

@node SAVE_FM

Command:  @{FG Highlight}SAVE_FM@{FG Text}

Purpose:  Saves the current font metric as a Soft-Logik FM file.

Format:   save_fm <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=5  Could not save file.
          RC=10 Font metric not open.
@toc SUBJ
@endnode

@node IMPORT_PFB

Command:  @{FG Highlight}IMPORT_PFB@{FG Text}

Purpose:  Imports a PostScript Type 1 PFB file and displays character 65.

Format:   import_pfb <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=20 Could not find file or not a PFB file.
@toc SUBJ
@endnode

@node EXPORT_PFB

Command:  @{FG Highlight}EXPORT_PFB@{FG Text}

Purpose:  Exports the current font outline as a PostScript Type 1 PFB file.

Format:   export_pfb <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=5  Could not save file.
          RC=10 Font outline not open.
@toc SUBJ
@endnode

@node IMPORT_AFM

Command:  @{FG Highlight}IMPORT_AFM@{FG Text}

Purpose:  Imports a PostScript Type 1 AFM file. A font outline must
          already by open.

Format:   import_afm <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=5  Could not find file or not an AFM file.
          RC=10 Font outline not open.
@toc SUBJ
@endnode

@node EXPORT_AFM

Command:  @{FG Highlight}EXPORT_AFM@{FG Text}

Purpose:  Exports the current font metric as a PostScript Type 1 AFM file.

Format:   export_afm <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=5  Could not save file.
          RC=10 Font metric not open.
@toc SUBJ
@endnode

@node IMPORT_PFM

Command:  @{FG Highlight}IMPORT_PFM@{FG Text}

Purpose:  Imports a PostScript Type 1 PFM file. A font outline must
          already by open.

Format:   import_pfm <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=5  Could not find file or not a PFM file.
          RC=10 Font outline not open.
@toc SUBJ
@endnode

@node IMPORT_IF

Command:  @{FG Highlight}IMPORT_IF@{FG Text}

Purpose:  Imports a Compugraphic Intellifont file and displays character
          65.

Format:   import_if <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=10 Could not find file or not an Intellifont file.
@toc SUBJ
@endnode

@node EXPORT_IF

Command:  @{FG Highlight}EXPORT_IF@{FG Text}

Purpose:  Exports the current font outline and metric as a Compugraphic
          Intellifont file.

Format:   export_if <'filename1 | [filename2] | [1]'>

Where:    filename1  is the complete file path and name for the
                     Intellifont file.
          filename2  is the complete file path and name for the
                     Gold Disk files (i.e., .dat and .metric files).
          1          toggles on the generation of hints.

Errors:   RC=5  Could not save file.
          RC=10 Font outline and/or metric not open.

@toc SUBJ
@endnode

@node EXPORT_PS

Command:  @{FG Highlight}EXPORT_PS@{FG Text}

Purpose:  Exports the current font outline and metric as a PostScript
          Type 3 file.

Format:   export_ps <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=5  Could not save file.
          RC=10 Font outline and/or metric not open.
@toc SUBJ
@endnode

@node IMPORT_TEMPLATE

Command:  @{FG Highlight}IMPORT_TEMPLATE@{FG Text}

Purpose:  Imports and displays an IFF ILBM bitmap template for the
          current character.

Format:   import_template <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=10 Could not find file or not an IFF ILBM file.
@toc SUBJ
@endnode

@node IMPORT_DR2D

Command:  @{FG Highlight}IMPORT_DR2D@{FG Text}

Purpose:  Imports an IFF DR2D drawing and pastes it into the current
          character.

Format:   import_dr2d <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=5  Could not find file or not an IFF DR2D file.
          RC=10 Font outline not open.
@toc SUBJ
@endnode

@node EXPORT_DR2D

Command:  @{FG Highlight}EXPORT_DR2D@{FG Text}

Purpose:  Exports the current character outline as an IFF DR2D file.

Format:   export_dr2d <'filename'>

Where:    filename  is the complete file path and name.

Errors:   RC=5  Could not save file.
          RC=10 Font outline not open.
@toc SUBJ
@endnode

@node NEW_FONT

Command:  @{FG Highlight}NEW_FONT@{FG Text}

Purpose:  Starts a new font with default values, and displays character
          65 in a character window.

Format:   new_font @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=20  Out of memory.
          RC=10  Could not open window.
@toc SUBJ
@endnode

@node NEW_METRIC

Command:  @{FG Highlight}NEW_METRIC@{FG Text}

Purpose:  Clears the current font metric and generates a new font metric.

Format:   new_metric <'track space'>

Where:    track  is the tracking value as a percentage (integer).
          space  is the space character width in character units (integer).

Errors:   RC=10  Font outline not open.
          RC=5   Unable to generate new metrics.
@toc SUBJ
@endnode

@node NEXT_FONT

Command:  @{FG Highlight}NEXT_FONT@{FG Text}

Purpose:  Activates the first view of the next font. If the last font is
          reached, the first font will be activated. The name of the font
          made active will be returned and stored in the RESULT variable
          if successful.

Format:   next_font @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  Font outline is not open.
          RC=5   Only one open font.
@toc SUBJ
@endnode

@node NEW_VIEW

Command:  @{FG Highlight}NEW_VIEW@{FG Text}

Purpose:  Opens a new view window for the active font showing a
          specified character. Returns the number of the new view in the
          RESULT variable if successful.

Format:   new_view <char>

Where:    char   is the ASCII number of the character to view (integer).

Errors:   RC=10  Font outline is not open.
          RC=5   Out of memory or value out of range.
@toc SUBJ
@endnode

@node NEXT_VIEW

Command:  @{FG Highlight}NEXT_VIEW@{FG Text}

Purpose:  Activates the next view of the same font. If the last view is
          reached, the first view will be activated. The view number of
          the view made active will be returned and stored in the RESULT
          variable if successful.

Format:   next_view @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  Font outline is not open.
          RC=5   Only one open view.
@toc SUBJ
@endnode

@node GET_VIEW

Command:  @{FG Highlight}GET_VIEW@{FG Text}

Purpose:  Gets the identification number of the current view and stores
          it in the RESULT variable.

Format:   get_view @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  No open view.
@toc SUBJ
@endnode

@node CLOSE_FONT

Command:  @{FG Highlight}CLOSE_FONT@{FG Text}

Purpose:  Closes the active font and all its associated views.

Format:   close_font @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  No font to close.
@toc SUBJ
@endnode

@node CLOSE_VIEW

Command:  @{FG Highlight}CLOSE_VIEW@{FG Text}

Purpose:  Closes the active view.

Format:   close_view @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  No view to close.
@toc SUBJ
@endnode

@node MOVE_CHAR

Command:  @{FG Highlight}MOVE_CHAR@{FG Text}

Purpose:  Moves a character to another character position. Existing
          paths in the new character position will be erased. This
          command also copies metric information and updates kerning
          pairs.

Format:   move_char <'num1 num2'>

Where:    num1  is the character to move (integer between 0 and 255).
          num2  is the character position to move to (integer between 0
                and 255).

Errors:   RC=10  No outline font loaded.
          RC=5   Value out of range.
@toc SUBJ
@endnode

@node MOVETO

Command:  @{FG Highlight}MOVETO@{FG Text}

Purpose:  Move pen to a specified position.

Format:   moveto <'x  y'>

Where:    x  is the horizontal coordinate (integer).
          y  is the vertical coordinate (integer).

Errors:   RC=10  No outline font loaded.
@toc SUBJ
@endnode

@node LINETO

Command:  @{FG Highlight}LINETO@{FG Text}

Purpose:  Draw a line in the path in progress from the current pen
          position to the specified position which becomes the new pen
          position.

Format:   lineto <'x  y'>

Where:    x  is the horizontal coordinate (integer).
          y  is the vertical coordinate (integer).

Errors:   RC=10  No outline font loaded.
@toc SUBJ
@endnode

@node CURVETO

Command:  @{FG Highlight}CURVETO@{FG Text}

Purpose:  Draw a bÕzier curve in the path in progress from the current
          pen position to the specified position which becomes the new
          pen position.

Format:   curveto <'bcpx1 bcpy1 bcpx2 bcpy2x y'>

Where:    bcpx1 is the horizontal coordinate of control point 1 (integer).
          bcpy1 is the vertical coordinate of control point 1 (integer).
          bcpx2 is the horizontal coordinate of control point 2 (integer).
          bcpy2 is the vertical coordinate of control point 2 (integer).
          x     is the horizontal coordinate (integer).
          y     is the vertical coordinate (integer).

Errors:   RC=10  No outline font loaded.
@toc SUBJ
@endnode

@node CLOSEPATH

Command:  @{FG Highlight}CLOSEPATH@{FG Text}

Purpose:  Closes the path in progress. If the pen position is not the
          same as the startpoint of the path (the moveto), a straight
          line will be drawn to that position.

Format:   closepath @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  No outline font loaded.
@toc SUBJ
@endnode

@node SELECT_ALL

Command:  @{FG Highlight}SELECT_ALL@{FG Text}

Purpose:  Selects all points in all paths in the current character.

Format:   select_all @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  No font outline loaded.
          RC=5   No paths in character.
@toc SUBJ
@endnode

@node UNSELECT_ALL

Command:  @{FG Highlight}UNSELECT_ALL@{FG Text}

Purpose:  Deselects all points in all paths.

Format:   unselect_all @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  No font outline loaded.
@toc SUBJ
@endnode

@node FIRST_PATH

Command:  @{FG Highlight}FIRST_PATH@{FG Text}

Purpose:  Selects the first point of the first path in the current
          character.

Format:   first_path @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=5  No paths in character.
          RC=10 No font outline loaded.
@toc SUBJ
@endnode

@node SELECT_PATH

Command:  @{FG Highlight}SELECT_PATH@{FG Text}

Purpose:  Selects all the points in the current path.

Format:   select_path @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No font outline loaded.
          RC=10 No point is selected.
          RC=10 No paths in character.
          RC=5  Activation failed.
@toc SUBJ
@endnode

@node NEXT_PATH

Command:  @{FG Highlight}NEXT_PATH@{FG Text}

Purpose:  Selects the startpoint of the next path in the current
          character.

Format:   next_path @{FG Fill}(no parameters)@{FG Text}

Notes:    If the last path is currently selected, this selects the
          startpoint of the first path. One point must be selected prior
          to executing this command.

Errors:   RC=10 More than one point is selected or no font outline loaded.
          RC=10 No point is selected.
          RC=5  Only one path.
@toc SUBJ
@endnode

@node PREVIOUS_PATH

Command:  @{FG Highlight}PREVIOUS_PATH@{FG Text}

Purpose:  Selects the startpoint of the previous path in the current
          character.

Format:   previous_path @{FG Fill}(no parameters)@{FG Text}

Notes:    If the first path is currently selected, this selects the
          startpoint of the last path. One point must be selected prior
          to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=5  Only one path.
@toc SUBJ
@endnode

@node GOTO_START

Command:  @{FG Highlight}GOTO_START@{FG Text}

Purpose:  Deselects the current point and selects the first point in the
          current path.

Format:   goto_start @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
@toc SUBJ
@endnode

@node NEXT_POINT

Command:  @{FG Highlight}NEXT_POINT@{FG Text}

Purpose:  Deselects the current point and selects the next point in the
          current path.

Format:   next_point @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
          RC=5  No next point.
@toc SUBJ
@endnode

@node PREVIOUS_POINT

Command:  @{FG Highlight}PREVIOUS_POINT@{FG Text}

Purpose:  Deselects the current point and selects the previous point in
          the current path.

Format:   previous_point @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
          RC=5  No previous point.
@toc SUBJ
@endnode

@node SELECT_AREA

Command:  @{FG Highlight}SELECT_AREA@{FG Text}

Purpose:  Selects all the points inside of a specified area.

Format:   select_area <'x1 y1 x2 y2'>

Where:    x1  is the horizontal coordinate of the area's upper left corner.
          y1  is the vertical coordinate of the area's upper left corner.
          x2  is the horizontal coordinate of the area's bottom right corner.
          y2  is the vertical coordinate of the area's bottom right corner.

Errors:   RC=10 No font outline loaded.
          RC=5  Value out of range or nothing to select.
@toc SUBJ
@endnode

@node GET_NUMPATHS

Command:  @{FG Highlight}GET_NUMPATHS@{FG Text}

Purpose:  Gets the number of paths in the current character and stores
          it in the RESULT variable.

Format:   get_numpaths @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10 No font outline loaded.
@toc SUBJ
@endnode

@node GET_NUMPOINTS

Command:  @{FG Highlight}GET_NUMPATHS@{FG Text}

Purpose:  Gets the number of points in the current path and stores it in
          the RESULT variable.

Format:   get_numpoints @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
          RC=5  Path started but not closed.
@toc SUBJ
@endnode

@node GET_POINTX

Command:  @{FG Highlight}GET_POINTX@{FG Text}

Purpose:  Gets the horizontal coordinate of the selected point and
          stores it in the RESULT variable.

Format:   get_pointx @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
@toc SUBJ
@endnode

@node GET_POINTY

Command:  @{FG Highlight}GET_POINTY@{FG Text}

Purpose:  Gets the vertical coordinate of the selected point and stores
          it in the RESULT variable.

Format:   get_pointy @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
@toc SUBJ
@endnode

@node GET_PREV_BCPX

Command:  @{FG Highlight}GET_PREV_BCPX@{FG Text}

Purpose:  Gets the horizontal coordinate of the previous bÕzier control
          point (curve handle) for the selected point and stores it in
          the RESULT variable.

Format:   get_prev_bcpx @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
          RC=5  previous segment is not a CURVETO.
@toc SUBJ
@endnode

@node GET_PREV_BCPY

Command:  @{FG Highlight}GET_PREV_BCPY@{FG Text}

Purpose:  Gets the vertical coordinate of the previous bÕzier control
          point (curve handle) for the selected point and stores it in
          the RESULT variable.

Format:   get_prev_bcpy @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
          RC=5  previous segment is not a CURVETO.
@toc SUBJ
@endnode

@node GET_NEXT_BCPX

Command:  @{FG Highlight}GET_NEXT_BCPX@{FG Text}

Purpose:  Gets the horizontal coordinate of the next bÕzier control point
          (curve handle) for the selected point and stores it in the
          RESULT variable.

Format:   get_next_bcpx @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
          RC=5  next segment is not a CURVETO.
@toc SUBJ
@endnode

@node GET_NEXT_BCPY

Command:  @{FG Highlight}GET_NEXT_BCPY@{FG Text}

Purpose:  Gets the vertical coordinate of the next bÕzier control point
          (curve handle) for the selected point and stores it in the
          RESULT variable.

Format:   get_next_bcpy @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
          RC=5  next segment is not a CURVETO.
@toc SUBJ
@endnode

@node GET_PATHDIRECTION

Command:  @{FG Highlight}GET_PATHDIRECTION@{FG Text}

Purpose:  Gets the path direction for the current path and stores it in
          the RESULT variable.

Format:   get_pathdirection @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Results:  0: clockwise
          1: counterclockwise

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
@toc SUBJ
@endnode

@node GET_PREVIOUS_TYPE

Command:  @{FG Highlight}GET_PREVIOUS_TYPE@{FG Text}

Purpose:  Gets the type of the segment before the selected point and
          stores it in the RESULT variable.

Format:   get_previous_type @{FG Fill}(no parameters)@{FG Text}

Notes:    One point must be selected prior to executing this command.

Results:  'c': curveto
          'l': lineto
          'm': moveto

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
@toc SUBJ
@endnode

@node GET_CHAR_NUM

Command:  @{FG Highlight}GET_CHAR_NUM@{FG Text}

Purpose:  Gets the ASCII value for the current character and stores it
          in the RESULT variable.

Format:   get_char_num @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  No font open.
@toc SUBJ
@endnode

@node GET_VERSION

Command:  @{FG Highlight}GET_VERSION@{FG Text}

Purpose:  Gets the font version number and stores it in the RESULT
          variable.

Format:   get_version @{FG Fill}(no parameters)@{FG Text}

Note:     The result format is %ld.%ld where the first number is the
          version and the second is the revision.

Errors:   RC=10  No font open.
@toc SUBJ
@endnode

@node GET_WIDTH

Command:  @{FG Highlight}GET_WIDTH@{FG Text}

Purpose:  Gets the width of the current character and stores it in the
          RESULT variable.

Format:   get_width <char>

Where:    char   is the ASCII character number (integer).

Errors:   RC=10 No font open or no metrics data present.
          RC=5  Value out of range.
@toc SUBJ
@endnode

@node SET_COMPOSITION

Command:  @{FG Highlight}SET_COMPOSITION@{FG Text}

Purpose:  Sets a composition reference for a character.

Format:   set_composition <'char n comp x y'>

Where:    char  is the ASCII character number (integer).
          n     is the composition reference number (integer).
          comp  is is the referenced ASCII character number (integer).
          x     is the horizontal offset (integer).
          y     is the vertical offset (integer).

Note:     If comp=0, then the lookup table will be terminated. The last
          composition entry MUST be a zero.

Errors:   RC=10 No font open.
          RC=5  Value out of range.
          RC=5  No more compositons to add

@toc SUBJ
@endnode

@node SET_POINT

Command:  @{FG Highlight}SET_POINT@{FG Text}

Purpose:  Changes the coordinates of the current point.

Format:   set_point <'x y pbcpx pbcpy nbcpx nbcpy'>

Where:    x     is the horizontal coordinate (integer).
          y     is the vertical coordinate (integer).
          pbcx  is the horizontal coordinate of the previous bÕzier
                control point (curve handle) (integer).
          pbcy  is the vertical coordinate of the previous bÕzier
                control point (curve handle) (integer).
          nbcx  is the horizontal coordinate of the next bÕzier control
                point (curve handle) (integer).
          nbcy  is the vertical coordinate of the next bÕzier control
                point (curve handle) (integer).

Notes:    One point must be selected prior to executing this command. If
          either the previous segment or the next segment is a LINETO,
          specify 0 for the BCP positions. (Out of range values will be
          ignored.) If both the previous and next segments are LINETO's,
          the BCP positions may be set to 0, or they may be omitted.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
@toc SUBJ
@endnode

@node SET_PATHDIRECTION

Command:  @{FG Highlight}SET_PATHDIRECTION@{FG Text}

Purpose:  Changes the path direction for the current path.

Format:   set_pathdirection <x>

Where:    x  is 0 (clockwise) or 1 (counterclockwise).

Notes:    One point must be selected prior to executing this command.

Errors:   RC=10 More than one point is selected.
          RC=10 No point is selected.
          RC=10 No font outline loaded.
@toc SUBJ
@endnode

@node SET_FONTNAME

Command:  @{FG Highlight}SET_FONTNAME@{FG Text}

Purpose:  Sets the font name.

Format:   set_fontname <font>

Where:    font  is the font name (string).

Errors:   RC=10  No font open.
          RC=10  Illegal font name.
@toc SUBJ
@endnode

@node SET_FAMILY

Command:  @{FG Highlight}SET_FAMILY@{FG Text}

Purpose:  Sets the font family name.

Format:   set_family <family>

Where:    family  is the font family name (string).

Errors:   RC=10  No font open.
          RC=10  Illegal family name.
@toc SUBJ
@endnode

@node SET_WEIGHT

Command:  @{FG Highlight}SET_WEIGHT@{FG Text}

Purpose:  Sets the font weight name.

Format:   set_weight <weight>

Where:    weight  is the font weight (string).

Errors:   RC=10  No font open.
          RC=10  Illegal font weight name.
@toc SUBJ
@endnode

@node SET_FULLNAME

Command:  @{FG Highlight}SET_FULLNAME@{FG Text}

Purpose:  Sets the full font name.

Format:   set_fullname <name>

Where:    name  is the full font name (string).

Errors:   RC=10  No font open.
          RC=10  Illegal full name.
@toc SUBJ
@endnode

@node SET_FONTID

Command:  @{FG Highlight}SET_FONTID@{FG Text}

Purpose:  Sets the font identification number.

Format:   set_fontid <n>

Where:    n  is the font id (integer).

Errors:   RC=10  No font open.
@toc SUBJ
@endnode

@node SET_NOTICE

Command:  @{FG Highlight}SET_NOTICE@{FG Text}

Purpose:  Sets the font notice.

Format:   set_notice <notice>

Where:    notice  is the font notice (string).

Errors:   RC=10  No font open.
          RC=10  Illegal font notice.
@toc SUBJ
@endnode

@node SET_VERSION

Command:  @{FG Highlight}SET_VERSION@{FG Text}

Purpose:  Sets the font version number.

Format:   set_version <version>

Where:    version  is the font notice (integer).

Note:     Enter a version number with the decimal moved two places to
          the right. (i.e., Enter 100 instead of 1.00, or 2345 instead
          of 23.45.)

Errors:   RC=10  No font open.
@toc SUBJ
@endnode

@node SET_WIDTH

Command:  @{FG Highlight}SET_WIDTH@{FG Text}

Purpose:  Sets the width of the current character.

Format:   set_width <'char width'>

Where:    char   is the ASCII character number (integer).
          width  is the character width in character units (integer).

Errors:   RC=10  No font open.
          RC=10  No metrics data,
          RC=5   Value out of range.
@toc SUBJ
@endnode

@node ROTATE

Command:  @{FG Highlight}ROTATE@{FG Text}

Purpose:  Rotates the selected points and/or paths about the center of
          their bounding box.

Format:   rotate <ra>

Where:    ra  is the rotation angle in degrees (integer between -360 to
          360).

Errors:   RC=10  No points are selected (at least 2 points must be selected)
          RC=10  No font loaded.
          RC=5   Rotation failed or value out of range.
@toc SUBJ
@endnode

@node SKEW

Command:  @{FG Highlight}SKEW@{FG Text}

Purpose:  Skews the selected points and/or paths about the center of
          their bounding box.

Format:   skew <sa>

Where:    sa  is the skew angle in degrees (integer between -360 to 360).

Errors:   RC=10  No points are selected (at least 2 points must be selected)
          RC=10  No font loaded.
          RC=5   Skew operation failed or value out of range.
@toc SUBJ
@endnode

@node SCALE

Command:  @{FG Highlight}SCALE@{FG Text}

Purpose:  Scales the selected points and/or paths about the center of
          their bounding box.

Format:   scales <'x y'>

Where:    x  is the horizontal scaling factor in percent (integer between
             1 and 500).
          y  is the vertical scaling factor in percent (integer between
             1 and 500).

Errors:   RC=10  No points are selected (at least 2 points must be selected)
          RC=10  No font loaded.
          RC=5   Scaling failed or values out of range.
@toc SUBJ
@endnode

@node FLIP

Command:  @{FG Highlight}FLIP@{FG Text}

Purpose:  Flips the selected points and/or paths about the center of
          their bounding box.

Format:   flip <d>

Where:    d  is 0 (horizontal flip) or x=1 (vertical flip).

Errors:   RC=10  No points are selected (at least 2 points must be selected)
          RC=10  No font loaded.
          RC=5   Flip operation failed or value out of range.
@toc SUBJ
@endnode

@node MOVE

Command:  @{FG Highlight}MOVE@{FG Text}

Purpose:  Moves the selected points and/or paths the specified horizontal
          and vertical amounts.

Format:   flip <'mx my'>

Where:    mx  is the horizontal distance to move (integer).
          my  is the vertical distance to move (integer).

Errors:   RC=10  No points are selected.
          RC=10  No font loaded.
@toc SUBJ
@endnode

@node COPY

Command:  @{FG Highlight}COPY@{FG Text}

Purpose:  Copies the selected points and/or paths to the clipboard.

Format:   copy @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  No points are selected.
          RC=10  No font loaded.
@toc SUBJ
@endnode

@node CUT

Command:  @{FG Highlight}CUT@{FG Text}

Purpose:  Cuts the selected points and/or paths to the clipboard.

Format:   cut @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  No points are selected.
          RC=10  No font loaded.
@toc SUBJ
@endnode

@node PASTE

Command:  @{FG Highlight}PASTE@{FG Text}

Purpose:  Pastes the clipboard contents to the current character window.

Format:   paste ['x y']

Where:    x  is the horizontal coordinate of the top left corner of the
             paths to paste.
          y  is the vertical coordinate of the top left corner of the
             paths to paste.

Notes:    If x and y are not specified, the clipboard contents will be
          pasted at the same position as they were when copied or cut to
          the clipboard.

Errors:   RC=10  No font loaded.
@toc SUBJ
@endnode

@node DELETE

Command:  @{FG Highlight}DELETE@{FG Text}

Purpose:  Removes the selected points and/or paths from the character.

Format:   delete @{FG Fill}(no parameters)@{FG Text}

Errors:   RC=10  No points are selected.
          RC=10  No font loaded.
@toc SUBJ
@endnode

@node BEEPSCREEN

Command:  @{FG Highlight}BEEPSCREEN@{FG Text}

Purpose:  Beeps the screen to warn the user that an error has occurred.
          The screen will be flashed or the speakers will beep depending
          on the user's Preferences/Sound setting.

Format:   beepscreen <x>

Where:    x  is 0 (beeps the TypeSmith screen only) or x=1 (beeps all
          screens).
@toc SUBJ
@endnode

@node DISPLAY_ALERT

Command:  @{FG Highlight}DISPLAY_ALERT@{FG Text}

Purpose:  Opens an alert requester to notify the user of something.

Format:   display_alert <'message|positive[|negative]'>

Where:    message   is the message to display in the alert requester
                    (string).
          positive  is the name of the positive gadget (string).

Options:  negative  is the name of the negative gadget (string).

Errors:   RC=5  if the Negative gadget is selected.
          RC=10 Invalid arguments

Example:  display_alert 'Select a gadget.|Ok|Cancel'
@toc SUBJ
@endnode

@node GET_STRING

Command:  @{FG Highlight}GET_STRING@{FG Text}

Purpose:  Opens a requester to request input from the user. Gets a string
          from a text gadget and stores it in the RESULT variable.

Format:   get_string <'message|positive|negative'>

Where:    message   is the message to display in the requester (string).
          positive  is the name of the positive gadget (string).
          negative  is the name of the negative gadget (string).

Notes:    The user input will be stored in RESULT only if the Positive
          gadget is selected.

Errors:   RC=5  if the Negative gadget is selected.
          RC=10 Invalid arguments

Example:  get_string 'Enter text:|Ok|Cancel'
@toc SUBJ
@endnode

@node GET_FILE

Command:  @{FG Highlight}GET_FILE@{FG Text}

Purpose:  Opens an ASL open file requester to request that the user
          select a file path and name, which will be stored in the
          RESULT variable.

Format:   get_file <'title|positive|path|[file]'>

Where:    title     is the title of the file requester (string).
          positive  is the name of the positive gadget (string).
          path      is the default file path (string).
          file      is the default default filename (string).

Notes:    The filepath and name entered will be stored in RESULT only if
          the Positive gadget is selected.

Errors:   RC=5  if the Negative gadget is selected.
          RC=10 Invalid arguments

Examples: get_file 'Select File...|Ok|TypeSmith/TSfonts|Untitled.dmf'
          get_file 'Select File...|Ok|ram:|'
@next VERSION
@toc SUBJ
@endnode
