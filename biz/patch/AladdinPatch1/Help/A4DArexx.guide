@node Main "Aladdin 4D Arexx Commands"

Press F4 to launch an Arexx program.  Aladdin 4D Arexx programs use the
extension ".alad".  The Aladdin 4D Arexx port is "ALADDIN4D.1".

   @{" OpenProject            " link OpenProject }
   @{" Render                 " link Render }
   @{" RenderAnim             " link RenderAnim }
   @{" RequestFile            " link RequestFile }
   @{" RequestNotify          " link RequestNotify }
   @{" RequestResponse        " link RequestResponse }
   @{" RMotionBlur            " link RMotionBlur }
   @{" RPermission            " link RPermission }

@endnode


@node Template ""



   @{b}FORMAT@{ub}

   @{b}FUNCTION@{ub}

   @{b}INPUTS@{ub}
      @{u}Filename@{uu}

   @{b}RESULT@{ub}
      None.

@endnode


@node OpenProject "OpenProject"

OPENPROJECT

   @{b}FORMAT@{ub}
      OpenProject Filename

   @{b}FUNCTION@{ub}
      Load a project from disk, overwriting the current project.

   @{b}INPUTS@{ub}
      @{u}Filename@{uu}
         Name of the new project to load.  If not specified, a file
         requester is presented.

   @{b}RESULT@{ub}
      None.

@endnode

@node Render "Render"

RENDER

   @{b}FORMAT@{ub}
      Render Frame/N,Filename,IFF/S,DEEP/S,PRODRAW/S

   @{b}FUNCTION@{ub}
      Render a single frame from the current project.

   @{b}INPUTS@{ub}
      @{u}Frame@{uu}
         Frame number to render, starting with 1.

      @{u}Filename@{uu}
         Optional filename to save the frame as.

      @{u}IFF, DEEP, PRODRAW@{uu}
         Format to save the frame as.

   @{b}RESULT@{ub}
      None.

@endnode

@node RenderAnim "RenderAnim"

RENDERANIM

   @{b}FORMAT@{ub}
      RenderAnim FileName,Deep/S,Framestore/S,IFF/S,Anim/S,Frames/N,Start/N,End/N

   @{b}FUNCTION@{ub}
      Render animation of the current project.

   @{b}INPUTS@{ub}
      @{u}Filename@{uu}
         Basename of frames to save, or the name of the animation to save,
         depending on the following settings.

      @{u}Deep, Framestore, IFF, Anim@{uu}
         Type of file(s) to save.  "Anim" type generates only a single IFF ANIM
         file, all others generate a sequence of files with numeric extensions.

      @{u}Frames@{uu}
         Specify total number of frames in the animation.

      @{u}Start, End@{uu}
         Specify starting and ending frames.

   @{b}RESULT@{ub}
      None.

@endnode


@node RequestNotify "RequestNotify"

REQUESTNOTIFY

   @{b}FORMAT@{ub}
      RequestNotify Text/A

   @{b}FUNCTION@{ub}
      Display an information requester.  Does not return until the user
      clicks the Okay gadget.

   @{b}INPUTS@{ub}
      @{u}Text@{uu}
         Text to be displayed in the requester.

   @{b}RESULT@{ub}
      None.

@endnode


@node RequestResponse "RequestResponse"

REQUESTRESPONSE

   @{b}FORMAT@{ub}
      RequestResponse Text/A

   @{b}FUNCTION@{ub}
      Display a boolean requester.  Does not return until the user either
      clicks the Okay or Cancel gadget.

   @{b}INPUTS@{ub}
      @{u}Text@{uu}
         Text to be displayed in the requester.

   @{b}RESULT@{ub}
      If the user clicks Cancel, a return code of 203 is returned.  Otherwise
      a 0 return code is returned.

@endnode


@node RequestFile "RequestFile"

REQUESTFILE

   @{b}FORMAT@{ub}
      RequestFile Title/A,InitialPath,InitialFile

   @{b}FUNCTION@{ub}
      Display a standard file requester.  Does not return until the user
      selects a file or cancels the requester.

   @{b}INPUTS@{ub}
      @{u}Title@{uu}
         File requester's title bar text.  Note that if the text begins
         with an "S" it is assumed that this is a Save requester.

      @{u}InitialPath@{uu}
         Initial path for the requester.

      @{u}InitialFile@{uu}
         Initial filename for the requester.

   @{b}RESULT@{ub}
      If the requester is cancelled, a return code of 203 is returned.

      Otherwise, the result string contains the full path of the file
      selected.

      In addition, the variables FILEREQ.FILE and FILEREQ.PATH are set
      to the individual file and path components of the file selected.

@endnode

@node RMotionBlur "RMotionBlur"

RMOTIONBLUR

   @{b}FORMAT@{ub}
      RMotionBlur Frames/N,Length

   @{b}FUNCTION@{ub}
      Change motion blur settings.

   @{b}INPUTS@{ub}
      @{u}Frames@{uu}
         Number of motion blur frames, must be > 1.

      @{u}Length@{uu}
         Motion blur length, from 0.0 - 1.0.

   @{b}RESULT@{ub}
      None.

@endnode

@node RPermission "RPermission"

RPERMISSION

   @{b}FORMAT@{ub}
      RPermission On/S,Off/S,
         Light/S,Fill/S,Phong/S,Gouraud/S,Textures/S,Transparency/S,Flares/S,
         Fountains/S,Gases/S,Shadows/S,Background/S,Foreground/S,Overlay/S,Fog/S,
         Rounding/S,MotionBlur/S,Composite/S

   @{b}FUNCTION@{ub}
      Change render permission settings.

   @{b}INPUTS@{ub}

   @{b}RESULT@{ub}
      None.

   @{b}EXAMPLES@{ub}
      RPermission Gases On
      RPermission Background Foreground Off

@endnode

