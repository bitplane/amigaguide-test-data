@node HookSparkle "Hook Sparkle"

HOOK SPARKLE (2.6)

   @{b}FORMAT@{ub}
      Hook Sparkle
	 Brightness/S,Hue/S,Saturation/S,Value/S,
	 MinThresh/N,MaxThresh/N,Angle/N,Width/N,Height/N,
	 AngleVary/N,SizeVary/N,Blend/N,
	 PixelColor/S,White/S,DrawColor/S

   @{b}FUNCTION@{ub}
      Run the Sparkle hook.

   @{b}INPUTS@{ub}
      @{u}Brightness, Hue, Saturation, Value@{uu}
	 Select threshold method.

      @{u}MinThresh, MaxThresh@{uu}
	 Minimum and maximum threshold values.	Pixels found between these
	 two values will be sparkled.

      @{u}Angle@{uu}
	 Angle of sparkles.

      @{u}Width, Height@{uu}
	 Width and height of sparkles.

      @{u}AngleVary@{uu}
	 Sparkle angle variance method:
	    0=None, 1=Brightness, 2=Hue, 3=Saturation, 4=Value, 5=In, 6=Out,
	    7=Up, 8=Down, 9=Left, 10=Right

      @{u}SizeVary@{uu}
	 Sparkle size variance method:
	    0=None, 1=Brightness, 2=Hue, 3=Saturation, 4=Value, 5=In, 6=Out,
	    7=Up, 8=Down, 9=Left, 10=Right

      @{u}Blend@{uu}
	 Blend setting (0-255).

      @{u}PixelColor, White, DrawColor@{uu}
	 Color of sparkles.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookSpherize "Hook Spherize"

HOOK SPHERIZE (2.0)

   @{b}FORMAT@{ub}
      Hook Spherize
	 RotX/N,RotY/N,PosX/N,PosY/N,PosZ/N,Size/N,Ambient/N,TileX/N,Ti
	 leY/N,LightX/N,LightY/N,LightZ/N,LightR/N,LightG/N,LightB/N,Ba
	 ckR/N,BackG/N,BackB/N,Black/S,Main/S,SwapTile/S,SwapScale/S,Dr
	 awColor/S,Shiny/S,Aspect/S,AntiAlias/S

   @{b}FUNCTION@{ub}
      Run the Spherize hook.

   @{b}INPUTS@{ub}
      @{u}RotX, RotY@{uu}
	 Texture X and Y rotation angles.

      @{u}PosX, PosY, PosZ@{uu}
	 Position of the sphere in 3D space.

      @{u}Size@{uu}
	 Size adjustment of the sphere.  Positive values increase the
	 size of the sphere, negative values decrease the size of the
	 sphere.

      @{u}Ambient@{uu}
	 Ambient light level.

      @{u}TileX, TileY@{uu}
	 Number of tiles in the horizontal and vertical direction.

      @{u}LightX, LightY, LightZ@{uu}
	 Light source direction.

      @{u}LightR, LightG, LightB@{uu}
	 Light color.

      @{u}BackR, BackG, BackB@{uu}
	 Background color (overrides settings below).

      @{u}Black, Main, SwapTile, SwapScale, DrawColor@{uu}
	 Background color specification.

      @{u}Shiny@{uu}
	 Enable the shiny hot spot.

      @{u}Aspect@{uu}
	 Apply aspect correction.

      @{u}AntiAlias@{uu}
	 Apply anti-aliasing.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookSplash "Hook Splash"

HOOK SPLASH (3.0)

   @{b}FORMAT@{ub}
      Hook Splash  Increment/N, Number_Splashes/N, Seed/N, Light_Source/N,
		   Highlight/N, Density/N, Height/N,
		   WRAPAROUND/S, BOUNCE/S, Smoothing/N,
		   QSave_Off/S, QSave_Read_Write/S, QSave_Write/S, QSave_Read/S,
		   Antialiase_Off/S, Antialiase_On/S,
		   DROP/S, RAIN/S, SURFER/S, SWIRL/S, LINE/S, ARC/S,
		   Begin_At/N, End_At/N,
		   Start_X/N, Start_Y/N, End_X/N, End_Y/N,
		   Drop_Radius/N, Arc_Radius/N, Spacing/N, Add_Splash/N,
		   Do_Splashes/S, File/F/K


   @{b}FUNCTION@{ub}
      Run the Splash hook.  Splash puts a water drop ripple effect onto
      an image.  The image looks like you are viewing it through the
      surface of water.

   @{b}INPUTS@{ub}

      @{u}Increment@{uu}
	 Produce later frames of the Splash effect.  (0 to 999 through GUI and
	 0 to 2,000,000,000 through ARexx port)

      @{u}Number_Splashes@{uu}
	 The number of splash effects to apply.  (1 to 30 through GUI and
	 1 to 255 through ARexx port)

      @{u}Seed@{uu}
	 Random number seed that is used when generating Rain coordinates
	 and generating the Surfers path.  (0 to 9,999,999)

      @{u}Light_Source@{uu}
	 Angle of the light source.  (0 to 360)

      @{u}Highlight@{uu}
	 Brightness of light source.  (0 to 255)

      @{u}Density@{uu}
	 This controls how long it takes for a splash to die out.  (1 to 16,
	 16 is for splashes that take the longest to die out)

      @{u}Height@{uu}
	 Strength of a splash.	(0 to 2000)

      @{u}WRAPAROUND@{uu}
      @{u}BOUNCE@{uu}
	 Mutually exclusive keywords for selecting how a splash behaves
	 when it reaches the edge of the image.

	    WRAPAROUND - Waves travel to the opposite side.
	    BOUNCE     - Wave bounce off the edge of the image.

      @{u}Smoothing@{uu}
	 Blurs the internal Splash buffer before it is applied to the
	 image.  This will remove some low level noise in the buffer
	 that is generated during splash processing.

      @{u}QSave_Off@{uu}
      @{u}QSave_Read_Write@{uu}
      @{u}QSave_Write@{uu}
      @{u}QSave_Read@{uu}
	 Mutually exclusive keywords for selecting how the quick save
	 file is used.	Splash uses internal buffers to generate the
	 splash effect.  Without a quick save file, Splash would always
	 have to regenerate the splash buffers starting at increment 0.
	 This would be slow for animations.  Using a quick save file
	 lets splash save and reuse the buffers that were generated
	 in a previous execution of splash.  Splash only uses valid
	 quick save files.  A quick save file is valid if the quick
	 save file has the same width and height as the present image
	 buffer and the increment you want to generate now comes after
	 the last increment that was used to generate the quick save file.

	    QSave_Off	     - Do not use the quick save file.
	    QSave_Read_Write - Read the quick save file before generating
			       the next increment then save a new quick
			       save file.  This is the normal option when
			       using the quick save file.
	    QSave_Write      - Only save the new quick save file.  Use this
			       option when you want make sure you don't read
			       a previous quick save file.  Such as when
			       you change an already generated splash's
			       options so that the quick save file is now
			       wrong.
	    QSave_Read	     - Only read the quick save file before
			       generating the next increment.  Use this
			       option when you want make sure you don't write
			       to the quick save file.	Such as when you are
			       fine tuning a splash's options and that splash
			       occurs at the end of a long splash effect that
			       has already been saved.

      @{u}Antialiase_Off@{uu}
      @{u}Antialiase_On@{uu}
	 Mutually exclusive keywords for selecting whether Splash will use
	 antialiasing when applying the the splash to a buffer.

	    Antialiase_Off - Faster but not as smooth.
	    Antialiase_On  - Slower but smoother ripples.

      @{u}DROP@{uu}
      @{u}RAIN@{uu}
      @{u}SURFER@{uu}
      @{u}SWIRL@{uu}
      @{u}LINE@{uu}
      @{u}ARC@{uu}
	 Mutually exclusive keywords for selecting the splash type.

	    DROP   - Put one drop right where you tell it to.
	    RAIN   - Puts random drops over the whole area.
	    SURFER - Random moving spot traveling over the image.
	    SWIRL  - Spot that moves in a circle.
	    LINE   - Draws a line of spots between two points.
	    ARC    - Draws an arc of spots between two points.

      @{u}Begin_At@{uu}
	 This splash type starts affecting the image after the Increment
	 reaches Begin_At. (0 to 999 through GUI and
	 0 to 2,000,000,000 through ARexx port)

      @{u}End_At@{uu}
	 This splash type quits affecting the image after the Increment
	 reaches End_At. (0 to 999 through GUI and
	 0 to 2,000,000,000 through ARexx port)

      @{u}Start_X@{uu}
      @{u}Start_Y@{uu}
	 These are x,y coordinates.  (0 to image width and 0 to image height)
	 For DROP, this is the center of the drop.
	 For SWIRL, this is the center of the swirl's circle.
	 For LINE, this is the starting point of the line.
	 For ARC, this is the starting point of the arc.
	 This is ignored for all other splash types.

      @{u}End_X@{uu}
      @{u}End_Y@{uu}
	 These are x,y coordinates.  (0 to image width and 0 to image height)
	 For LINE, this is the ending point of the line.
	 For ARC, this is the ending point of the arc.
	 This is ignored for all other splash types.

      @{u}Drop_Radius@{uu}
	 For RAIN, this is the maximum radius of a rain drop.  For all
	 other splash types it is the splash radius.  (1 to 1000)

      @{u}Arc_Radius@{uu}
	 For SWIRL, this is the radius of the circle.  A negative radius
	 reverses the swirl direction.
	 For ARC, this is the radius of the arc drawn between the
	 start x,y and the end x,y points.  A negative radius bows the
	 arc in the opposite direction.
	 This is ignored for all other splash types.
	 (-1000 to 1000)

      @{u}Spacing@{uu}
	 For SWIRL, LINE and ARC, this is the pixel spacing between
	 successive drops.
	 For SURFER, this is roughly the maximum pixel spacing between
	 the successive drops.
	 For RAIN, this is the speed at which the rain drops occur per
	 increment.
	 ( 1 to 255)

      @{u}Add_Splash@{uu}
	 This tells Splash to save the entered splash parameters as
	 data for this splash number.  The splash can be executed
	 later by calling the splash hook with the Do_Splashes keyword.
	 This ARexx only parameter lets you build up a large number of
	 splashes to be executed at one time.  (1 to 255 through ARexx port)

      @{u}Do_Splashes@{uu}
	 This is an ARexx only parameter that tells Splash to use the
	 parameters that were entered in previous ARexx commands using
	 Add_Splash.  Use the Number_Splashes parameter to specify the
	 total number of splashes to be processed.

      @{u}File@{uu}
	 Always the last ARexx parameter.  The name of a Splash Load
	 style file.  The options from the file are loaded before the
	 Add_Splash parameters are loaded and before the other ARexx inputs
	 are applied.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookStraw "Hook Straw"

HOOK STRAW (2.0)

   @{b}FORMAT@{ub}
      Hook Straw Size/N,Seed/N,Density/N,MinAngle/N,MaxAngle/N

   @{b}FUNCTION@{ub}
      Run the Straw hook.

   @{b}INPUTS@{ub}
      @{u}Size@{uu}
	 Length of the straw lines, in pixels.

      @{u}Seed@{uu}
	 Random number seed.  If not specified, a seed is calculated
	 from the current system time.

      @{u}Density@{uu} (2.6)
	 Density of lines.  Default is 3.

      @{u}MinAngle, MaxAngle@{uu} (2.6)
	 Minimum and maximum angles at which to draw the lines, given
	 in degrees from 0 - 360.  (0 = right, 180 = left, proceeding
	 counterclockwise.)

   @{b}RESULT@{ub}
      None.

@endnode

@node HookSwirl "Hook Swirl"

HOOK SWIRL (2.0)

   @{b}FORMAT@{ub}
      Hook Swirl
	 Angle,Strength/N,Dissolve/N,Red/N,Green/N,Blue/N,CenterX/N,Cen
	 terY/N,OuterRad/N,InnerRad/N,Blend/N,Stretch/S,AntiAlias/S

   @{b}FUNCTION@{ub}
      Run the Swirl hook.

   @{b}INPUTS@{ub}
      @{u}Angle@{uu}
	 Angle of rotation, in degrees.  Positive angles rotate
	 clockwise, negative angles rotate counter-clockwise.
	 Fractional angles are accepted.

      @{u}Strength@{uu}
	 Strength of the sucking toward the center (0 - 100).

      @{u}Dissolve@{uu}
	 Dissolve between main and swap (0 - 100).

      @{u}Red, Green, Blue@{uu}
	 RGB value of background color.  Defaults to (0, 0, 0) (black).

      @{u}CenterX, CenterY@{uu}
	 Center of rotation, in pixels.  Defaults to the center of the
	 image.

      @{u}OuterRad, InnerRad@{uu}
	 Outer and inner radius of the effect, in pixels.  Defaults to
	 affecting the entire image.

      @{u}Blend@{uu}
	 Percentage of edge blending (0 - 100).

      @{u}Stretch@{uu}
	 Stretch switch.

      @{u}AntiAlias@{uu}
	 If specified, performs anti-aliasing on the effect.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookText "Hook Text"

HOOK TEXT (2.0)

   @{b}FORMAT@{ub}
      Hook Text
	 Font/K,Size/K/N,AntiAlias/S,Border/S,Remap/S,Left/S,Center/S,R
	 ight/S,Bold/S,Italic/S,Underline/S,Text/M

   @{b}FUNCTION@{ub}
      Run the Text hook.

   @{b}INPUTS@{ub}
      @{u}Font, Size@{uu}
	 Name and size of the font to use.

      @{u}AntiAlias@{uu}
	 Generate anti-aliased text.

      @{u}Border@{uu}
	 Generate extra space around the sides of the text brush.

      @{u}Remap@{uu}
	 Remap colorfonts to the current ImageFX palette.

      @{u}Left, Center, Right@{uu}
	 Text justification for multiple lines.

      @{u}Bold, Italic, Underline@{uu}
	 Text attributes.

      @{u}Text
@{uu}
	 One or more lines of text.  See examples below for the proper
	 way to specify more than one line of text.

   @{b}RESULT@{ub}
      None.

   @{b}EXAMPLES@{ub}
      Hook Text Font helvetica.font Size 15 Text=“Line One” Text=“Line
	 Two”

@endnode

@node HookTile "Hook Tile"

HOOK TILE (2.0)

   @{b}FORMAT@{ub}
      Hook Tile
	 Width/N,Height/N,Horiz/N,Vert/N,Hue/N,Value/N,Blend/N,Black/S,
	 White/S,Main/S,Swap/S,DrawColor/S

   @{b}FUNCTION@{ub}
      Run the Tile hook.

   @{b}INPUTS@{ub}
      @{u}Width, Height@{uu}
	 Width and height of each tile, in pixels.

      @{u}Horiz, Vert@{uu}
	 Horizontal and vertical displacement, in pixels.

      @{u}Hue, Value@{uu}
	 Hue and Value variance, in percent (0-100).

      @{u}Blend@{uu}
	 Blend variance, in percent (0-100).

      @{u}Black, White, Main, Swap, DrawColor@{uu}
	 Background pixel setting.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookVideoFilter "Hook VideoFilter"

HOOK VIDEOFILTER (2.0)

   @{b}FORMAT@{ub}
      Hook VideoFilter
	 ChromaLim/N,ComposLim/N,PAL/S,FlagHot/S,ReduceSat/S

   @{b}FUNCTION@{ub}
      Run the VideoFilter hook.

   @{b}INPUTS@{ub}
      @{u}ChromaLim@{uu}
	 Specify the Chroma Limit setting (1-256).

      @{u}ComposLim@{uu}
	 Specify the Composite Limit setting (1-256).

      @{u}PAL@{uu}
	 Perform calculations for PAL video.

      @{u}FlagHot@{uu}
	 Mark pixels that would be affected.

      @{u}ReduceSat@{uu}
	 Reduce Saturation flag.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookWarp "Hook Warp"

HOOK WARP (2.0)

   @{b}FORMAT@{ub}
      Hook Warp
	 Strength/N,CenterX/N,CenterY/N,Red/N,Green/N,Blue/N,OuterRad/N
	 ,InnerRad/N,Blend/N,Pinch/S,Punch/S,AntiAlias/S,Stretch/S

   @{b}FUNCTION@{ub}
      Run the Warp hook for Pinch and Punch effects.

   @{b}INPUTS@{ub}
      @{u}Strength@{uu}
	 Strength of the pinch or punch, in percent (-100 to 100).

      @{u}CenterX, CenterY@{uu}
	 Center of the effect, in pixels.  Defaults to the center of
	 the image.

      @{u}Red, Green, Blue@{uu}
	 RGB value of background pixels.  Defaults to (0, 0, 0), black.

      @{u}OuterRad, InnerRad@{uu}
	 Outer and inner radius of the effect, in pixels.  Defaults to
	 affecting the entire image.

      @{u}Blend@{uu}
	 Edge blending percentage (0-100).

      @{u}Pinch, Punch@{uu}
	 Specifies the type of effect.	Pinch pinches toward the
	 center.  Punch punches outward from the center.

      @{u}AntiAlias@{uu}
	 Select anti-aliasing for the effect.

      @{u}Stretch@{uu}
	 Stretch switch.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookWave "Hook Wave"

HOOK WAVE (2.0)

   @{b}FORMAT@{ub}
      Hook Wave
	 Amplitude/N,Length/N,Angle,Dampen/N,Distance/N,CenterX/N,Cente
	 rY/N,Red/N,Green/N,Blue/N,OuterRad/N,InnerRad/N,Blend/N,Dissol
	 ve/N,Inward/S,Outward/S,Equal/S,AntiAlias/S,Stretch/S

   @{b}FUNCTION@{ub}
      Run the Wave hook.

   @{b}INPUTS@{ub}
      @{u}Amplitude@{uu}
	 Amplitude of the waves.

      @{u}Length@{uu}
	 Wave length, in pixels.

      @{u}Angle@{uu}
	 Angle of the wave, in degrees (0-360).  Fractional values are
	 accepted.  Varying this value will animate a wave.

      @{u}Dampen@{uu}
	 Dampening percentage (0-100).

      @{u}Distance@{uu}
	 Distance the wavefront is from center, in pixels.

      @{u}CenterX, CenterY@{uu}
	 Center of the wave, in pixels.  Defaults to the center of the
	 image.

      @{u}Red, Green, Blue@{uu}
	 RGB value of background pixels.  Defaults to (0, 0, 0), black.

      @{u}OuterRad, InnerRad@{uu}
	 Outer and inner radius of the effect, in pixels.  Defaults to
	 affecting the entire image.

      @{u}Blend@{uu}
	 Edge blending percentage (0-100).

      @{u}Dissolve@{uu}
	 Dissolve amount between main and swap.

      @{u}Inward, Outward, Equal@{uu}
	 Type of wave dampening to use.

      @{u}AntiAlias@{uu}
	 Apply anti-aliasing to the effect.

      @{u}Stretch@{uu}
	 Stretch switch.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookWireless "Hook Wireless"

HOOK WIRELESS (2.6)

   @{b}FORMAT@{ub}
      Hook Wireless File/K

   @{b}FUNCTION@{ub}
      Run the Wireless hook.

   @{b}INPUTS@{ub}
      @{u}File@{uu}
	 Project file to load and use.

   @{b}RESULT@{ub}
      None.

@endnode

