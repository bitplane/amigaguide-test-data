@node HookRemoveDefect "Hook RemoveDefect"

HOOK REMOVEDEFECT (2.6)

   @{b}FORMAT@{ub}
      Hook RemoveDefect
	       Radius/N,Difference/N,Constrain/K,Replace/K,
	       MinR/N,MinG/N,MinB/N,MaxR/N,MaxG/N,MaxB/N

   @{b}FUNCTION@{ub}
      Run the RemoveDefect hook.

   @{b}INPUTS@{ub}
      @{u}Radius@{uu}
	 Radius of pixels to examine.

      @{u}Difference@{uu}
	 Difference setting.

      @{u}Constrain@{uu}
	 Constrain method.  Must be one of "None", "Horizontal", or "Vertical".

      @{u}Replace@{uu}
	 Replacement method.  Must be one of "Average" or "Median".

      @{u}MinR, MinG, MinB@{uu}
	 Minimum RGB threshold below which pixels are ignored.

      @{u}MaxR, MaxG, MaxB@{uu}
	 Maximum RGB threshold above which pixels are ignored.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookRotate "Hook Rotate"

HOOK ROTATE (2.0)

   @{b}FORMAT@{ub}
      Hook Rotate
	 Angle,Red/N,Green/N,Blue/N,CenterX/N,CenterY/N,OuterRad/N,Inne
	 rRad/N,Blend/N,AntiAlias/S,Resize/S,Aspect/S

   @{b}FUNCTION@{ub}
      Run the Rotate hook.

   @{b}INPUTS@{ub}
      @{u}Angle@{uu}
	 Angle of rotation in degrees.	Positive values rotate
	 clockwise, negative values rotate counter-clockwise.
	 Fractional values are accepted.

      @{u}Red, Green, Blue@{uu}
	 Color used to fill in background pixels.  Defaults to 0, 0, 0
	 (black).

      @{u}CenterX, CenterY@{uu}
	 Center of rotation, in pixels.  Defaults to the center of the
	 image.

      @{u}OuterRad, InnerRad@{uu}
	 Outer and inner radius of the rotation, in pixels.  Defaults
	 to affecting the entire image.

      @{u}Blend@{uu}
	 Blending to apply to edges (0 - 100).

      @{u}AntiAlias@{uu}
	 If specified, the results will be anti-aliased.

      @{u}Resize@{uu}
	 If specified, the buffer will be resized such that the entire
	 rotated image fits in the buffer.  Otherwise, some edges of
	 the image will be cropped.

      @{u}Apsect@{uu}
	 If specified, the aspect ratio of the image will be accounted
	 for during the rotation.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookScatter "Hook Scatter"

HOOK SCATTER (3.0)

   @{b}FORMAT@{ub}
      Hook Scatter
	 CelSize/N,Seed/N,ThresholdMin/N,ThresholdMax/N,Source/N,
	 Type/N,CoordX/N,CoordY/N,DisplaceMin/N,DisplaceMax/N,Angle/N

   @{b}FUNCTION@{ub}
      Run the Scatter hook.

   @{b}INPUTS@{ub}
      @{u}CelSize@{uu}
	 Size of cels, in pixels, into which the image will be broken.

      @{u}Seed@{uu}
	 Random seed.

      @{u}ThresholdMin@{uu}
      @{u}ThresholdMax@{uu}
	 Minimum and Maximum intensities of pixels, those with colors
	 outside this range will be unaffected. Range 0 - 255.

      @{u}Source@{uu}
	 Source for color of revealed pixels:
	    0 = Swap buffer
	    1 = Exchange with destination pixels
	    2 = Black
	    3 = White
	    4 = Draw color

      @{u}Type@{uu}
	 Type of effect:
	    0 = Radial In
	    1 = Radial Out
	    2 = Linear
	    3 = Swirl In
	    4 = Swirl Out

      @{u}CoordX@{uu}
      @{u}CoordY@{uu}
	 X and Y coordinates of pixel, used as center of radial or
	 swirl effects or direction of motion for linear.

      @{u}DisplaceMin@{uu}
      @{u}DisplaceMax@{uu}
	 Minimum and maximum displacement of cel from original
	 position, range is 0 to 1024 pixels.

      @{u}Angle@{uu}
	 For Swirl In/Out effects, defines the angular path around
	 the X, Y coordinate. Range -360 to +360 degrees.

   @{b}RESULT@{ub}
      None.

@endnode

