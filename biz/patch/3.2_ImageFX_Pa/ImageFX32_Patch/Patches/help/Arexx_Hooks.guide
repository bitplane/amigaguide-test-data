@node HookDeInterlace "Hook DeInterlace"

HOOK DEINTERLACE

   @{b}FORMAT@{ub}
      Hook DeInterlace

   @{b}FUNCTION@{ub}
      Run the DeInterlace hook.

   @{b}INPUTS@{ub}
      None.

   @{b}RESULT@{ub}
