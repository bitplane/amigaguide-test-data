      @{u}Size, SizeVar, SizeMin, SizeMax@{uu}
	 Size variance settings.

      @{u}Angle, AngleVar, AngleMin, AngleMax@{uu}
	 Angle variance settings.

      @{u}Blend, BlendVar, BlendMin, BlendMax@{uu}
	 Blend variance settings.

      @{u}Bright, BrightVar, BrightMin, BrightMax@{uu}
	 Brightness variance settings.

      @{u}Brush, RedVar, GreenVar, BlueVar@{uu}
	 Brush variance settings.

      @{u}Main, Swap, Alpha, Black, White, DrawColor@{uu}
	 Background color specification.

      @{u}File@{uu}
	 PaintFX project file to load.	The settings above will
	 override the settings in the file.

   @{b}RESULT@{ub}
