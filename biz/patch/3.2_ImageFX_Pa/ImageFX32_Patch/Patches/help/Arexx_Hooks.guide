   @{b}FORMAT@{ub}
      Hook PaintFX
	 Brush,Strokes/N,Layer/N,LayerXVar/N,LayerYVar/N,Size/N,SizeVar
	 /N,SizeMin/N,SizeMax/N,Angle/N,AngleVar/N,AngleMin/N,AngleMax/
	 N,Blend/N,BlendVar/N,BlendMin/N,BlendMax/N,Bright/N,BrightVar/
	 N,BrightMin/N,BrightMax/N,Brush/N,RedVar/N,GreenVar/N,BlueVar/
	 N,Main/S,Swap/S,Alpha/S,Black/S,White/S,DrawColor/S,File/K

