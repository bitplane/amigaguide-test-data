@endnode

@node HookPerspective "Hook Perspective"

HOOK PERSPECTIVE (2.0)

   @{b}FORMAT@{ub}
      Hook Perspective
	 RotX/N,RotY/N,RotZ/N,TransX/N,TransY/N,TransZ/N,ScaleX/N,Scale
	 Y/N,Red/N,Green/N,Blue/N,Handle/N,Main/S,Swap/S,DrawColor/S,
	 AntiAlias/N

   @{b}FUNCTION@{ub}
      Run the Perspective hook.

   @{b}INPUTS@{ub}
      @{u}RotX, RotY, RotZ@{uu}
	 X, Y, and Z rotation angles.

      @{u}TransX, TransY, TransZ@{uu}
	 X, Y, and Z translation values.

      @{u}ScaleX, ScaleY@{uu}
	 X and Y scaling values.

      @{u}Red, Green, Blue@{uu}
	 Background color (overrides settings below).

      @{u}Handle@{uu}
	 Set the rotation handle.  0=center, 1=upper left, 2=upper right,
	 3=lower left, 4=lower right.

      @{u}Main, Swap, DrawColor@{uu}
	 Set background as main, swap, or current draw color.

      @{u}AntiAlias@{uu}
	 Apply anti-aliasing.

   @{b}RESULT@{ub}
      None.

