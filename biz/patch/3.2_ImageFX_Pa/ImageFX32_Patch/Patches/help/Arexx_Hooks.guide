@node HookLensFlare "Hook LensFlare"

HOOK LENSFLARE (2.0)

   @{b}FORMAT@{ub}
      Hook LensFlare
	 File,Type/N,Radius/N,Bright/N,CenterX/N,CenterY/N,Red/N,Green/N,
	 Blue/N,GlowR/N,GlowG/N,GlowB/N,Rotation/N,NPoints/N,Anamorphic/N,
	 OffsetAngle/N,Random/N

   @{b}FUNCTION@{ub}
      Run the LensFlare hook.

   @{b}INPUTS@{ub}
      @{u}File@{uu}
	 LensFlare file from which to retrieve settings.

      @{u}Type@{uu}
	 Type of Lens Flare.  Types are:

	   0	  Small
	   1	  Medium
	   2	  Large
	   3	  None

      @{u}Radius@{uu}
	 Radius of the flare in pixels.

      @{u}Bright@{uu}
	 Brightness of the flare.

      @{u}CenterX, CenterY@{uu}
	 Center of the flare, in pixels.

      @{u}Red, Green, Blue@{uu}
	 Color of the flare.

      @{u}GlowR, GlowG, GlowB@{uu}
	 Color of the glow.

      @{u}Rotation@{uu}
	 Rotation angle of main flare, range 0-360 degrees.

      @{u}NPoints@{uu}
	 Number of points in Medium- or Large-Type flare.

      @{u}Anamorphic@{uu}
	 Set anamorphic flag, 0=off, 1=on.

      @{u}OffsetAngle@{uu}
	 Offset angle of the two parts of a Large flare.

      @{u}Random@{uu}
	 Random seed for Small flare.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookLightning "Hook Lightning"

HOOK LIGHTNING (2.0)

   @{b}FORMAT@{ub}
      Hook Lightning
	 StartX/N,StartY/N,StartZ/N,EndX/N,EndY/N,EndZ/N,
	 RadiusR,RadiusG,RadiusB,Red/N,Green/N,Blue/N,
	 ContrastR/N,ContrastG/N,ContrastB/N,
	 Deviation/N,OGlowRad/N,OGlowR/N,OGlowG/N,OGlowB/N,
	 IGlowRad/N,IGlowR/N,IGlowG/N,IGlowB/N,Probability/N,
	 SegLenMin/N,SegLenMax/N,SegMin/N,SegMax/N,AngleMin/N,AngleMax/N,
	 Seed/N,SeedLen/N,SeedCount/N,SeedRad/N,SeedAngle/N,
	 Radius/N,Paint/N,BoltCount/N,File/K,Line/K/N,LineCount/K/N


   @{b}FUNCTION@{ub}
      Run the Lightning hook.

   @{b}INPUTS@{ub}
      @{u}StartX, StartY, StartZ@{uu}
	 Starting position of bolt, in pixels.

      @{u}EndX, EndY, EndZ@{uu}
	 Ending position of bolt, in pixels.

      @{u}RadiusR, RadiusG, RadiusB@{uu}
	 Radius of bolt, in pixels.  Fractional values are allowed.

      @{u}Red, Green, Blue@{uu}
	 Color of bolt.

      @{u}ContrastR, ContrastG, ContrastB@{uu}
	 Contrast of bolt.

      @{u}Deviation@{uu}
	 Deviation setting.

      @{u}OGlowRad, OGlowR, OGlowG, OGlowB@{uu}
	 Outer glow radius and color.

      @{u}IGlowRad, IGlowR, IGlowG, IGlowB@{uu}
	 Inner glow radius and color.

      @{u}Probability@{uu}
	 Probability setting.

      @{u}SegLenMin, SegLenMax@{uu}
	 Minimum and maximum segment length.

      @{u}SegMin, SegMax@{uu}
	 Minimum and maximum segment size.

      @{u}AngleMin, AngleMax@{uu}
	 Minimum and maximum angle settings.

      @{u}Seed, SeedLen, SeedCount, SeedRad, SeedAngle@{uu}
	 Random seed values.

      @{u}Radius@{uu} (2.6)
	 Branch radius percent.  (0 - 100)

      @{u}Paint@{uu} (2.6)
	 Painting order.
	       0 = Branch / Bolt
	       1 = Bolt / Branch
	       2 = Bolt Only
	       3 = Branches Only

      @{u}BoltCount@{uu} (2.6)
	 Count of number of segments in bolt (Count% in GUI).

      @{u}File@{uu}
	 Load settings from the given file.  Other parameters given
	 will override the settings in the file.

      @{u}Line@{uu} (2.6)
	 Line to select when loading a project file. Any other
	 parameters on the command line will override this line's
	 settings.

      @{u}LineCount@{uu} (2.6)
	 Number of Line parameter sets to load from
	 "env:ImageFX/Lightning/x", where "x" has the format "Line_%d".
	 This is to get around being unable to pass the parameters
	 from multiple lines on the command line, simply create a
	 parameter line using the template above (up to and including
	 Paint), save it in the appropriate environment variable,
	 then invoke Lightning with "hook lightning linecount n".

   @{b}RESULT@{ub}
      None.

@endnode

