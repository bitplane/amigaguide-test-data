@node HookAntiAlias "Hook AntiAlias"

HOOK ANTIALIAS (2.0)

   @{b}FORMAT@{ub}
      Hook AntiAlias Mode/N,Threshold/N

   @{b}FUNCTION@{ub}
      Run the AntiAlias hook.

   @{b}INPUTS@{ub}
      @{u}Mode@{uu}
	 AntiAlias mode.  0 = EdgeDetect, 1 = Interpolate, 2 =
	 Convolve.

      @{u}Threshold@{uu}
	 Threshold amount.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookAntique "Hook Antique"

HOOK ANTIQUE

   @{b}FORMAT@{ub}
      Hook Antique

   @{b}FUNCTION@{ub}
      Run the Antique hook.

   @{b}INPUTS@{ub}
      None.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookApplyTexture "Hook ApplyTexture"

HOOK APPLYTEXTURE (2.0)

   @{b}FORMAT@{ub}
      Hook ApplyTexture Name,Light/N,Depth/N,Shiny/S,Shading/S

   @{b}FUNCTION@{ub}
      Run the ApplyTexture hook.

   @{b}INPUTS@{ub}
      @{u}Name@{uu}
	 Name of texture file.	Must include full path.

      @{u}Light@{uu}
	 Light direction (0-7).

      @{u}Depth@{uu}
	 Depth of texture (0-255).

      @{u}Shiny@{uu}
	 Creates a shiny texture when set.

      @{u}Shading@{uu}
	 Enables shading when set.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookBubble "Hook Bubble"

HOOK BUBBLE (2.6)

   @{b}FORMAT@{ub}
      Hook Bubble
	       Frame/N,Count/N,MinRadius/N,MaxRadius/N,
	       Bright/N,SpecTight/N,Seed/N,XRate/N,YRate/N,
	       MinHue/N,MaxHue/N,Saturation/N,Value/N,
	       Blend/N,Tint/S,Specular/S,Overlap/S,
	       AntiAlias/S,InvertY/S,File/K

   @{b}FUNCTION@{ub}
      Run the Bubble hook.

   @{b}INPUTS@{ub}
      @{u}Frame@{uu}
	 Frame number.

      @{u}Count@{uu}
	 Number of bubble to generate.

      @{u}MinRadius, MaxRadius@{uu}
	 Minimum and maximum radii for the bubbles.

      @{u}Bright@{uu}
	 Light brightness.

      @{u}SpecTight@{uu}
	 Size of specular reflection.

      @{u}Seed@{uu}
	 Random seed.

      @{u}XRate, YRate@{uu}
	 Horizontal and vertical speed.

      @{u}MinHue, MaxHue@{uu}
	 Minimum and maximum hue values that bubbles may be tinted with.
	 Tint must also be selected.

      @{u}Saturation@{uu}
	 Saturation of the bubbles.
	 Tint must also be selected.

      @{u}Value@{uu}
	 Value variance of the bubbles.
	 Tint must also be selected.

      @{u}Blend@{uu}
	 Blend percentage (1-100).

      @{u}Tint@{uu}
	 Tint the bubbles according to the tinting parameters.

      @{u}Specular@{uu}
	 Create specular highlights on the bubbles.

      @{u}Overlap@{uu}
	 Allow bubbles to overlap each other.

      @{u}AntiAlias@{uu}
	 Anti-alias the bubbles.

      @{u}InvertY@{uu}
	 Invert the image painted onto the bubbles.

      @{u}File@{uu}
	 Storage file from which to read settings.  Other parameters specified
	 will override the settings from the file.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookChangeColor "Hook ChangeColor"

HOOK CHANGECOLOR (2.0)

   @{b}FORMAT@{ub}
      Hook ChangeColor SR/N,SG/N,SB/N,DR/N,DG/N,DB/N,Closeness/N

   @{b}FUNCTION@{ub}
      Run the ChangeColor hook.

   @{b}INPUTS@{ub}
      @{u}SR, SG, SB@{uu}
	 Source color in RGB format.

      @{u}DR, DG, DB@{uu}
	 Color to change to in RGB format.

      @{u}Closeness@{uu}
	 Closeness value to apply to source colors (1-255).

   @{b}RESULT@{ub}
      None.

@endnode

@node HookCineMatte "Hook CineMatte"

HOOK CINEMATTE

   @{b}FORMAT@{ub}
      Hook CineMatte  BlueScreen/S, GreenScreen/S, RedScreen/S, CyanScreen/S,
	 MagentaScreen/S, YellowScreen/S, AutoDetectScreen/S, DetectAnyColor/S,
	 OutputMatteAndKeyedFG/S, OutputComposite/S, OutputMatteAndComposite/S,
	 OutputMatte/S, OutputKeyedFG/S,
	 DynamicRange/S, DynamicRangeOff/S,
	 ForceBlack/N, ForceWhite/N, Gamma/N, Protection/N,
	 LightColorRed/N, LightColorGreen/N, LightColorBlue/N,
	 ScreenRemoval/N, Blend/N, NoiseFilter/N,
	 CorrectionRed/N, CorrectionGreen/N, CorrectionBlue/N,
	 CleanPlate/S/K, CleanPlateError/N, MatteBlur/N, MatteChoking/N,
	 File/F/K


   @{b}FUNCTION@{ub}
      Run the CineMatte hook.

   @{b}INPUTS@{ub}
      @{u}BlueScreen, GreenScreen, RedScreen,@{uu}
      @{u}CyanScreen, MagentaScreen, YellowScreen,@{uu}
      @{u}AutoDetectScreen, DetectAnyColor@{uu}
	 Select the color screen to process.

	 AutoDetectScreen samples the foreground image to detect the most
	 frequent color from the RGBCMY color set.  Then it makes the
	 matte using that screen color.  So if the foreground image is
	 mostly blue it would make the matte using the BlueScreen code.

	 DetectAnyColor samples the foreground image to detect the most
	 frequent 24 bit color value.  Then it makes the Matte
	 using special non-color specific matte code.  This code does not
	 work as well as the color specific code but it can sometimes
	 make a matte for colors that are not pure enough for the
	 RGBCMY code.

      @{u}OutputMatteAndKeyedFG, OutputComposite,@{uu}
      @{u}OutputMatteAndComposite, OutputMatte, OutputKeyedFG@{uu}
	 Select the type of output.

      @{u}DynamicRange, DynamicRangeOff@{uu}
	 Turns dynamic range option on or off.

      @{u}ForceBlack@{uu}
	 Force matte values that are almost black to be black.
	 (0 to 255)

      @{u}ForceWhite@{uu}
	 Force matte values that are almost white to be white.
	 (0 to 255)

      @{u}Gamma@{uu}
	 Remove the halo that can sometimes be seen around the subject.
	 (0 to 255)

      @{u}Protection@{uu}
	 Lets you add in or remove the screen's color from the foreground
	 areas that are in semi-transparent parts of the matte.
	 (-255 to 256)	Negative values add in the screen color.

      @{u}LightColorRed, LightColorGreen, LightColorBlue@{uu}
	 Add back this color to replace the screen color that was removed
	 by Protection.
	 (0 to 255)

      @{u}ScreenRemoval@{uu}
	 Amount of background removal.
	 (0 to 255)

      @{u}Blend@{uu}
	 Amount to blend foreground into the composite.
	 (0 to 255)

      @{u}NoiseFilter@{uu}
	 Smooths the foreground image before generating the matte.  This
	 does not change the foreground image that is mixed into the outputs.
	 (0 to 255)

      @{u}CorrectionRed, CorrectionGreen, CorrectionBlue@{uu}
	 Add this RGB color to each foreground image value before making
	 the matte.  Allows you to make the foreground image more
	 blue (or green or red...) before calculating the matte.  This does
	 not change the foreground image that is mixed into the outputs.
	 (0 to 255)

      @{u}CleanPlate@{uu}
	 This is an image of the blue (or green or red...) screen without
	 the foreground subjects in it.  CineMatte will compare this
	 image to the foreground image while making the matte.	If the two
	 images are close enough, the matte value will be 0 (transparent).
	 All other foreground image areas are processed normally using the
	 screen color.	See CleanPlateError.

      @{u}CleanPlateError@{uu}
	 Sets how much of a difference there can be between the CleanPlate
	 image and the foreground image and still have a transparent matte.
	 (0 to 255)

      @{u}MatteBlur@{uu}
	 Do a Gaussian blur of the matte.  Done after MatteChoking.
	 (0 to 255)

      @{u}MatteChoking@{uu}
	 Shrink (negative values) or expand the matted areas.
	 (-255 to 255)

      @{u}File@{uu}
	 Always the last ARexx parameter.  The name of a CineMatte Load
	 style file.  The options from the file are loaded before the
	 other ARexx inputs are processed.


   @{b}RESULT@{ub}
      None.


   @{b}OBSOLETE INPUTS@{ub}
      These ARexx parameter names have been changed for the new CineMatte.
      At this time they still work but all new ARexx scripts should use
      the new parameter names.


      @{u}OutputBoth@{uu}
	 Replaced by OutputMatteAndComposite.

      @{u}Darken@{uu}
	 Replaced by ForceBlack.

      @{u}Brighten@{uu}
	 Replaced by ForceWhite.

      @{u}RemoveHalo@{uu}
	 Replaced by Gamma.

      @{u}RestoreRed@{uu}
	 Replaced by LightColorRed.

      @{u}RestoreGreen@{uu}
	 Replaced by LightColorGreen.

      @{u}RestoreBlue@{uu}
	 Replaced by LightColorBlue.

      @{u}RemoveBG@{uu}
	 Replaced by ScreenRemoval.

@endnode

@node HookClouds "Hook Clouds"

HOOK CLOUDS (3.0)

   @{b}FORMAT@{ub}
      Hook Clouds
	 INCREMENT=FRAME/K/N, NUMCLOUDS=NUM/K/N, LOAD/K,
	 SAVE/K, CLOUD=CD/K/N, SEED=SD/K/N, MESHSIZE=MS/K/N,
	 FRACTALDIMENSION=FD/K/N, POWERSCALE=PS/K/N,COLORMODE=CM/K,
	 PAINTMODE=PM/K/N, BLEND=BD/K/N, THRESHOLD=TH/K/N
	 XVELOCITY=XV/K/N, YVELOCITY=YV/K/N, TURBULENCESEED=TS/K/N,
	 TURBULENCERATE=TR/K/N, TURBULENCEAMOUNT=TA/K/N

   @{b}FUNCTION@{ub}
      Run the Clouds hook.

   @{b}INPUTS@{ub}
      @{u}INCREMENT@{uu}
	 Which frame to create.
	 (1 to 32768)

      @{u}NUMCLOUDS@{uu}
	 The number of cloud layers.
	 (1 to 8)

      @{u}LOAD@{uu}
	 Load a parameter file.

      @{u}SAVE@{uu}
	 Save the current state in a parameter file.

      @{u}CLOUD@{uu}
	 Options following this keyword will set the parameters for
	 the specified cloud layer.
	 (1 to 8)

      @{u}SEED@{uu}
	 Sets the seed for the random number generator.
	 (1 to 65536)

      @{u}MESHSIZE@{uu}
	 Sets the Meshsize.
	 Must be a power of 2 (8, 16, 32, 64...).

      @{u}FRACTALDIMENSION@{uu}
	 Sets the fractal dimension.
	 (1 to 300)

      @{u}POWERSCALE@{uu}
	 Sets the power scale
	 (1 to 1000)

      @{u}COLORMODE@{uu}
	 Sets the color palette.  Use one of the following options:
	 BLUESKY, GREYSCALE, FIRE, REDFIRE, BLACKFIRE, NIGHTSKY, SUNSET
	 MIST, LANDSCAPE, FUNKY, DRAW1, DRAW2, DRAW3, DRAW4, DRAW5,
	 DRAW6, DRAW7

      @{u}PAINTMODE@{uu}
	 How the current layer is combined with the main buffer.  Choose
	 one of the following options:	PAINT, ADD, ADDMAX, SUBTRACT,
	 TRANSLUCENT

      @{u}BLEND@{uu}
	 Sets the blend level for the current layer.
	 (0 to 255)

      @{u}THRESHOLD@{uu}
	 Sets the threshold for the current layer.
	 (0 to 255)

      @{u}XVELOCITY, YVELOCITY@{uu}
	 Sets the velocity of the cloud layer in the x or y direction.
	 (-256 to 256)

      @{u}TURBULENCESEED@{uu}
	 Sets the seed for the turbulence animation.
	 (0 to 65536)

      @{u}TURBULENCERATE@{uu}
	 Sets how quickly the turbulence animation happens.
	 (0 to 255)

      @{u}TURBULENCEAMOUNT@{uu}
	 Sets the scale of detail for the turbulence animation.
	 (0 to 10)

      @{u}NOTES:@{uu}
	  The Clouds Hook uses Fractal Synthesis in order to generate
	  realistic looking clouds.  Up to 8 layers are specified.  Each
	  layer is created in turn and combined with the main buffer.  So
	  layer 1 will appear on top of the background, layer 2 will appear
	  on top of layer 1 and so on.

	  Due to the layered nature of the Clouds Module, the ARexx format
	  may be a little different than other IFX Hooks.

	  Keywords are required.  Since Cloud levels can be defined in any
	  order, keywords are used to keep the module from getting confused.

	  The Clouds Module will apply all keywords in the order found.  If
	  you specify a keyword twice for the same parameter, the second
	  instance will take effect.  This means that you can load a file
	  and then change specific parameters like the FRAME number to set
	  up individual frames in an animation.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookColorBalance "Hook ColorBalancing"

HOOK COLORBALANCING (2.6)

   @{b}FORMAT@{ub}
      Hook ColorBalancing
	 SampleX/N,SampleY/N,SampleArea/N,White/S,Black/S,
	 DrawColor/S,Red/N,Green/N,Blue/N

   @{b}FUNCTION@{ub}
      Run the ColorBalancing hook.

   @{b}INPUTS@{ub}
      @{u}SampleX, SampleY@{uu}
	 Sampling coordinates of the source image.

      @{u}SampleArea@{uu}
	 Area of pixels to sample.

      @{u}White, Black@{uu}
	 Perform white or black balancing.

      @{u}DrawColor@{uu}
	 Color balance to the current draw color.

      @{u}Red, Green, Blue@{uu}
	 Color balance to the given custom RGB color.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookComposite "Hook Composite"

HOOK COMPOSITE (2.0)

   @{b}FORMAT@{ub}
      Hook Composite
	 Op/A,Blend/N,Closeness/N,Include/N,Exclude/N,Red/N,Green/N,Blue/N,
	 FromH/N,FromS/N,FromV/N,ToH/N,ToS/N,ToV/N,MatchMain/S,MatchSwap/S,
	 MatchEither/S,AlphaFrisket/S,AlphaMask/S,AlphaTexture/S,AlphaMatte/S,
	 SwapScale/S

   @{b}FUNCTION@{ub}
      Run the Composite hook.

   @{b}INPUTS@{ub}
      @{u}Op@{uu}
	 Composite operation to perform.  Must be one of the following:

	       Merge	   Matte       FastMatte  HSVMatte
	       Add	   Subtract    Multiply   Divide
	       Sum	   Difference  Minimum	  Maximum
	       ImageMap    And	       Or	  Xor
	 2.1:  Dissolve    Screen      Illuminate Color
	       Softlight   Hardlight

      @{u}Blend@{uu}
	 Blend percentage (0-100).

      @{u}Closeness@{uu}
	 Closeness setting for include and exclude range colors or
	 matte colors (1-255).

      @{u}Include, Exclude@{uu}
	 Include and Exclude range settings (0-8).

      @{u}Red, Green, Blue@{uu}
	 For Matte composites, specifies the RGB value to matte with.

      @{u}FromH, FromS, FromV, ToH, ToS, ToV@{uu}
	 For HSVMatte composites, specifies the from and to HSV values.

      @{u}MatchMain, MatchSwap, MatchEither@{uu}
	 Specifies which buffer the include and exclude is matched on.
	 Defaults to MatchMain.

      @{u}AlphaFrisket, AlphaMask, AlphaTexture@{uu}
	 Specifies how the alpha channel is used in the composite.  If
	 none are specified, the alpha channel is not used.

      @{u}SwapScale@{uu}
	 If specified, the swap buffer is scaled to match the region
	 being composited.  Otherwise, the swap buffer is tiled.

   @{b}RESULT@{ub}
      None.

@endnode

@node HookCrystallize "Hook Crystallize"

HOOK CRYSTALLIZE (2.0)

   @{b}FORMAT@{ub}
      Hook Crystallize GridX/N,GridY/N,Perturb/N,Glint/N,Seed/N

   @{b}FUNCTION@{ub}
      Run the Crystallize hook.

   @{b}INPUTS@{ub}
      @{u}GridX, GridY@{uu}
	 Grid sizes.

      @{u}Perturb@{uu}
	 Perturbation.

      @{u}Glint@{uu}
	 Glint.

      @{u}Seed@{uu}
	 Random seed.

   @{b}RESULT@{ub}
      None.

@endnode

