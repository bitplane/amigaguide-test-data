@Node main "main" "MAIN"

                     @{fg shine}@{b}@{u}LIGA Version 4.0 @{ub}@{uu}@{fg text}
                     by Miroslaw Siedlarz
                     Copyright © 1997. Release Date

                     @{" Introduction          " link "Intro"}
                     @{" Before You Load Liga  " link "Load"}
