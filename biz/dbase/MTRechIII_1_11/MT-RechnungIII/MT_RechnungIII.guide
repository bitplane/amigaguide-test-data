    ( 31) Skonto vorhanden? (true/false)
    ( 32) Skontosatz
    ( 33) [ Skontowert ] @{"Grosses Währungsformat" link GWF}
    ( 34) [ MWSt Skonto ] @{"kleines Währungsformat" link KWF}
    ( 35) [ Rechnungssumme ] @{"Grosses Währungsformat" link GWF}
    ( 36) [ Rechnungssumme - Zu/Ab ] @{"Grosses Währungsformat" link GWF}
