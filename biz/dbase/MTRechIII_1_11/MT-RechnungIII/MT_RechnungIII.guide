                                                  2 = monetärer Zuschlag je Verpackungseinheit
                                                  3 = monetärer Zuschlag je Lieferntenverpackungseinheit
                                                  4 = monetärer Zuschlag absolut
                                                  5 = prozentualer Abschlag
                                                  6 = monetärer Abschlag je Einheit
                                                  7 = monetärer Abschlag je Verpackungseinheit
                                                  8 = monetärer Abschlag je Lieferntenverpackungseinheit
