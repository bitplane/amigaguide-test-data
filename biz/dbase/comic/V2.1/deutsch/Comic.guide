@PREV Programmpunkte
@TOC MAIN
@NEXT MAIN
@TITLE "Weitere Information"




         @{" Diskettenbetrieb " link Diskettenbetrieb}
         @{" Betrieb mit geringem Speicher " link BetriebmitgeringemSpeicher}
