  @{b}Ernstes Kapitel@{ub}

    @{"Das Konzept" link "GCBProdukte:GCBAllg.guide/Das Konzept" 0}         Das Konzept von GCBNotiz
    @{"Bedienung" link "Bedienung" 0}           Bedienungsanleitung für Leseratten
    @{"Neuerungen" link "Neuerungen" 0}          Was hat sich getan

  @{b}Verschiedenes@{ub}

    @{"Rechtliches" link "GCBProdukte:GCBRecht.guide/main" 0}         Wann sind Sie offizieller Nutzer
    @{"Garantie" link "GCBProdukte:GCBRecht.guide/Garantie" 0}            Ich garantiere für nichts
    @{"Copyright" link "GCBProdukte:GCBRecht.guide/Copyright" 0}           Nicht zuviel weitergeben
    @{"Registrierung" link "GCBProdukte:GCBRecht.guide/Registrierung" 0}       Wie werden Sie offizieller Nutzer
    @{"Updates" link "GCBProdukte:GCBRecht.guide/Update" 0}             Wie bleiben Sie offizieller Nutzer
    @{"Adresse" link "GCBProdukte:GCBRecht.guide/Adresse" 0}             Wohin mit allem darüber
    @{"Anforderungen" link "GCBProdukte:GCBAllg.guide/Anforderungen" 0}       Welcher Rechner arbeitet mit GCBNotiz
    @{"Wie ..." link "Wie ..." 0}             Einige Vorgehen zur Programmnutzung
