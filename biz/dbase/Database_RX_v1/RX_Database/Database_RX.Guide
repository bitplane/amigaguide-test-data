@node "Load" "Load"
@next "Save"
@prev "Menus"

                         Load
                         ----

     Shortcut key:  Right Alt L

     This option will load the file "pres.data" if it is  available.

@endnode

@node "Save" "Save"
@next "Quit"
@prev "Load"

                         Save
                         ----

     Shortcut key:  Right Alt S

     This option will save the database info to the file
 "pres.data".

@endnode

