	Address value MyPort	/* Change ARexx address to that port */
	MyFGRN = 5		/* Set MyFGRN to family 5 */
	GETPRINCIPAL MyFGRN 	/* Issue command */
	Say "IRN of principal of family:" RESULT
@ENDNODE

