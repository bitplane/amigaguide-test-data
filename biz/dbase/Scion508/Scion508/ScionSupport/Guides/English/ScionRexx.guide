	MyFGRN = 5		/* Set MyFGRN to family 5 */
	GETMARRIAGEDATE MyFGRN	/* Issue command to Scion Genealogist */
	Say "Date of marriage is:" RESULT
	GETMARRIAGEDATE MyFGRN 1 /* Issue command to Scion Genealogist */
	Say "'Numeric' date of marriage is:" RESULT

See also @{" GETxxxDATE Numeric Format " LINK GETXXXNUMERIC}.
@ENDNODE

