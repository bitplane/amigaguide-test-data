@node "143 Routine · Delete_CDVR" "Routine · Delete_CDVR"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Delete_CDVR
 
If TextFrom("F_Appointments")<>""
	Let APPOINTMENT="A2K:A2KData/Appoint/Appointment_"||SD||"."||THISMONTH||"."||THISYEAR
	Let APPOINTMENT1="Ram:A2KData/Appoint/Appointment_"||SD||"."||THISMONTH||"."||THISYEAR
	Dos "Delete >NIL:"|||APPOINTMENT
	Dos "Delete >NIL:"|||APPOINTMENT1
	IfError
	Else
		If NOT EXISTS(APPOINTMENT)
			PrintText SD,((SD+FIRSTDAY)//7)*BW+A_X_1+(G_HS%4*3),((SD+FIRSTDAY)%7)*BH+A_Y_1+2*(G_BH+L_VS)
			Do "Clear_LIST"
			Do "Clear_DATA"
			SetText "F_Appointments",""
		EndIf
	EndIf
EndIf
@endnode
 
@node "144 Routine · Clear_DATA" "Routine · Clear_DATA"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Clear_DATA
 
Loop CNT,0,24
