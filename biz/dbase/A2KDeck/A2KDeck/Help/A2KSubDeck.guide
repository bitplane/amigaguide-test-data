@node "129 Routine · Done" "Routine · Done"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Done
 
SendToParentDeck RtnHandler,False,Name,Add1,CustIndex
Let DefNameListWinX=WindowX,DefNameListWinY=WindowY
Do "Set Prefs"
SaveVariable A2KPrefs,"A2K:A2K.Prefs"
SaveVariable A2KPrefs,"Ram:A2K.Prefs"
If ObjectAttached("Customer Info")
	SetObjectState "CustomerWindow",On
	DetachObject "NamesWindow"
Else
	Quit
EndIf
@endnode
 
