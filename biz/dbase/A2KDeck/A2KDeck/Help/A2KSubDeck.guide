@node "2 Routine · Get_FONT.PREFS" "Routine · Get_FONT.PREFS"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get_FONT.PREFS
 
Local READFILE="ENV:sys/font.prefs",X=0,SizeVar="",FontVar=""
If EXISTS(READFILE)=TRUE
	IfError
		Let SysDefText="topaz",SysDefTextSize=8
	Else
		If FileSize(READFILE)>""
			GetFileInfo READFILE,FILECNT
			SetFileBufferSize Limit(1,1024,Integer(FILECNT%1024))
			OpenFile READFILE,"WORKFILE",READONLY ,OLDFILE 
			FileReadChars "WORKFILE",X,223
			FileReadChars "WORKFILE",SizeVar,1,HEX 
			FileReadChars "WORKFILE",X,2
			FileReadChars "WORKFILE",FontVar,30
			Let SysDefTextSize=HexToInteger(SizeVar)
			Let SysDefText=GetWord(FontVar,1,".")
			Close "WORKFILE"
		Else
			Let SysDefText="topaz",SysDefTextSize=8
		EndIf
	EndIf
Else
	Let SysDefText="topaz",SysDefTextSize=8
EndIf
GetFontInfo SCREEN ,ScreenText,ScreenTextSize
Let GOS=ScreenTextSize+3
@endnode
 
@node "3 Routine · Get_PUBSCREEN.PREFS" "Routine · Get_PUBSCREEN.PREFS"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get_PUBSCREEN.PREFS
 
Loop CNT,1,10
	If NOT PUBSCREENEXISTS("Tax_PubScreen."||CNT)
		ExitLoop
	EndIf
EndLoop
Let PROG.PUBSCRTITLE="Tax_PubScreen."||CNT
@endnode
 
@node "4 Routine · FileType ErrorCheck" "Routine · FileType ErrorCheck"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} FileType ErrorCheck
 
Let ER="You Have A Problem",ERD="This Means that You are using the wrong type of Data file."
Let TempFileName=FileName
If MATCH(FILETYPE(TempFileName),"CDVR")
	Let TempFile=LoadVariable(TempFileName)
EndIf
If MATCH(FILETYPE(TempFileName),"Picture","Brush")
	LoadPalette TempFileName,"DefPalBuf",ASNEEDED 
EndIf
If MATCH(FILETYPE(TempFileName),"Unknown")
	Let ET=Errortext
	If ET="Invalid variable name"
		DisposeAll
		Do "Make Def"
		Do "Set Prefs"
		SaveVariable A2KPrefs,"Ram:A2K.prefs"
	Else
		Let AFR=AskForResponse(ER||Char(10)||ET,"Error...")
	EndIf
EndIf
@endnode
 
@node "5 Routine · ShowBrush" "Routine · ShowBrush"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} ShowBrush
 
Let WBL=WindowBorderLeft,WBT=WindowBorderTop,WW=WindowWidth,WBR=WindowBorderRight,WH=WindowHeight,WBB=WindowBorderBottom
ClearWindow
ShowBrushEfx Arg1,WBL,WBT,"Tile",0.000,WW-WBR-WBL,WH-WBT-WBB
IfError
EndIf
@endnode
 
@node "6 Routine · Click" "Routine · Click"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Click
 
SetDrawMode JAM1 
SetPen 5
AreaRectangle Arg1,Arg2,Arg3,Arg4
DrawBorder Arg1,Arg2,Arg3,Arg4,BEVEL ,1,2
SetPrintFont "topaz",8
SetPrintStyle PLAIN ,1,2
SetPen 2,1
PrintText Arg5,Arg1+18-Arg6,Arg2+3
@endnode
 
@node "7 Routine · Get Fields" "Routine · Get Fields"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get Fields
 
Let FieldNames[1]=Arg1,FieldNames[2]=Arg2,FieldNames[3]=Arg3,FieldNames[4]=Arg4,FieldNames[5]=Arg5
Let FieldNames[6]=Arg6,FieldNames[7]=Arg7,FieldNames[8]=Arg8,FieldNames[9]=Arg9,FieldNames[10]=Arg10
@endnode
 
@node "8 Routine · Make Sys Dir" "Routine · Make Sys Dir"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Make Sys Dir
 
If Not Exists("A2K:A2KData")
	Dos "C:MakeDir A2K:A2KData"
EndIf
If Not Exists("A2K:A2KData/DistData")
	Dos "C:MakeDir A2K:A2KData/DistData"
ElseIf Exists("A2K:A2KData/DistData/Dist.Data")
	Dos "C:Copy A2K:A2KData/StockData/Dist.Data Ram:A2KData/DistData"
EndIf
If Not Exists("A2K:A2KData/StockData")
	Dos "C:MakeDir A2K:A2KData/StockData"
ElseIf Exists("A2K:A2KData/StockData/Stock.Data")
	Dos "C:Copy A2K:A2KData/StockData/Stock.Data Ram:A2KData/StockData"
EndIf
If Not Exists("A2K:A2KData/OrderData")
	Dos "C:MakeDir A2K:A2KData/OrderData"
ElseIf Exists("A2K:A2KData/OrderData/Order.Data")
	Dos "C:Copy A2K:A2KData/OrederData/Order.Data Ram:A2KData/OrderData"
EndIf
If Not Exists("A2K:A2KData/CustData")
	Dos "C:MakeDir A2K:A2KData/CustData"
ElseIf Exists("A2K:A2KData/CustData/Cust.Data")
	Dos "C:Copy A2K:A2KData/CustData/Cust.Data Ram:A2KData/CustData"
EndIf
If Not Exists("A2K:A2KData/Appoint")
	Dos "C:MakeDir A2K:A2KData/Appoint"
EndIf
If Exists("A2K:A2K.prefs")
	Dos "C:Copy A2K:A2K.prefs Ram:"
EndIf
If Exists("A2K:A2K.tax")
	Dos "C:Copy A2K:A2K.tax Ram:"
EndIf
@endnode
 
@node "9 Routine · Make Ram Dir" "Routine · Make Ram Dir"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Make Ram Dir
 
If Not Exists("Ram:A2KData")
	Dos "C:MakeDir Ram:A2KData"
EndIf
If Not Exists("Ram:A2KData/DistData")
	Dos "C:MakeDir Ram:A2KData/DistData"
EndIf
If Not Exists("Ram:A2KData/StockData")
	Dos "C:MakeDir Ram:A2KData/StockData"
EndIf
If Not Exists("Ram:A2KData/OrderData")
	Dos "C:MakeDir Ram:A2KData/OrderData"
EndIf
If Not Exists("Ram:A2KData/CustData")
	Dos "C:MakeDir Ram:A2KData/CustData"
EndIf
If Not Exists("Ram:A2KData/PrintData")
	Dos "C:MakeDir Ram:A2KData/PrintData"
EndIf
If Not Exists("Ram:A2KData/Appoint")
	Dos "C:MakeDir Ram:A2KData/Appoint"
EndIf
@endnode
 
@node "10 Routine · Set Prefs" "Routine · Set Prefs"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Set Prefs
 
Let A2KPrefs.Date=DefDate,A2KPrefs.Note=DefNote,A2KPrefs.DistDir=DefDistDir,A2KPrefs.DataDir=DefDataDir
Let A2KPrefs.OrdDir=DefOrdDir,A2KPrefs.CustDir=DefCustDir,A2KPrefs.PenA=DefPenA,A2KPrefs.PenB=DefPenB
Let A2KPrefs.PenC=DefPenC,A2KPrefs.BGPic=DefBGPic,A2KPrefs.TBGPic=DefTBGPic,A2KPrefs.DBGPic=DefDBGPic
Let A2KPrefs.OBGPic=DefOBGPic,A2KPrefs.CBGPic=DefCBGPic,A2KPrefs.PBGPic=DefPBGPic,A2KPrefs.PalDir=DefPalDir
Let A2KPrefs.Palette=DefPalBuf,A2KPrefs.DefPrefsWinX=DefPrefsWinX,A2KPrefs.DefPrefsWiny=DefPrefsWinY
Let A2KPrefs.DefTaxWinX=DefTaxWinX,A2KPrefs.DefTaxWiny=DefTaxWiny,A2KPrefs.DefListWinX=DefListWinX
Let A2KPrefs.DefListWiny=DefListWiny,A2KPrefs.DefNameListWinX=DefNameListWinX,A2KPrefs.DefNameListWiny=DefNameListWinY
Let A2KPrefs.DefCustWinX=DefCustWinX,A2KPrefs.DefCustWinY=DefCustWinY,A2KPrefs.DefStockWinX=DefStockWinX
Let A2KPrefs.DefStockWiny=DefStockWiny
@endnode
 
@node "11 Routine · Set Def" "Routine · Set Def"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Set Def
 
Let DefDate=A2KPrefs.Date,DefNote=A2KPrefs.Note,DefDistDir=A2KPrefs.DistDir,DefDataDir=A2KPrefs.DataDir
Let DefOrdDir=A2KPrefs.OrdDir,DefCustDir=A2KPrefs.CustDir,DefBGPic=A2KPrefs.BGPic,DefTBGPic=A2KPrefs.TBGPic
Let DefDBGPic=A2KPrefs.DBGPic,DefOBGPic=A2KPrefs.OBGPic,DefCBGPic=A2KPrefs.CBGPic,DefPBGPic=A2KPrefs.PBGPic
Let DefPenA=A2KPrefs.PenA,DefPenB=A2KPrefs.PenB,DefPenC=A2KPrefs.PenC,DefPalBuf=A2KPrefs.Palette,DefPalDir=A2KPrefs.PalDir
Let DefPrefsWinX=A2KPrefs.DefPrefsWinX,DefPrefsWinY=A2KPrefs.DefPrefsWinY,DefTaxWinX=A2KPrefs.DefTaxWinX
Let DefTaxWinY=A2KPrefs.DefTaxWinY,DefListWinX=A2KPrefs.DefListWinX,DefListWiny=A2KPrefs.DefListWiny
Let DefNameListWinX=A2KPrefs.DefNameListWinX,DefNameListWiny=A2KPrefs.DefNameListWiny,DefCustWinX=A2KPrefs.DefCustWinX
Let DefCustWinY=A2KPrefs.DefCustWinY,DefStockWinX=A2KPrefs.DefStockWinX,DefStockWiny=A2KPrefs.DefStockWiny
@endnode
 
@node "12 Routine · Make Def" "Routine · Make Def"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Make Def
 
Let N=0,DefNote="$",DefDate="DMY"
Do "Make Ram Dir"
Do "Make Sys Dir"
Let DefDistDir="A2K:A2KData/DistData",DefDataDir="A2K:A2KData/StockData"
Let DefOrdDir="A2K:A2KData/OrderData",DefCustDir="A2K:A2KData/CustData"
Let DefPenA=1,DefPenB=2,DefPenC=3
If Exists("A2K:BGPics/Default.bg")
	Let DefBGPic="A2K:BGPics/Default.bg",DefTBGPic="A2K:BGPics/Default.bg",DefDBGPic="A2K:BGPics/Default.bg"
	Let DefOBGPic="A2K:BGPics/Default.bg",DefCBGPic="A2K:BGPics/Default.bg",DefPBGPic="A2K:BGPics/Default.bg"
Else
	Let DefBGPic="",DefTBGPic="",DefDBGPic="",DefOBGPic="",DefCBGPic="",DefPBGPic=""
EndIf
If Exists("A2K:Palette")
	Let DefPalBuf="Palette",DefPalDir="A2K:Palette"
	LoadPalette "Palette",DefPalBuf,ASNEEDED 
Else
	ClipBrush 10,20,40,40,"PaletteBrush"
	SaveBrush "PaletteBrush","A2K:Palette"
	Let DefPalBuf="Palette",DefPalDir="A2K:Palette"
	LoadPalette "Palette",DefPalBuf,ASNEEDED 
EndIf
Let DefPrefsWinX=0,DefPrefsWiny=0,DefTaxWinX=0,DefTaxWiny=0,DefListWinX=0,DefListWiny=0,DefNameListWinX=0
Let DefNameListWiny=0,DefStockWinX=0,DefStockWiny=0
@endnode
 
@node "13 Routine · Set_PROG.VARS" "Routine · Set_PROG.VARS"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Set_PROG.VARS
 
Let PROG.SCRTITLE=DECKNAME|||"Version 1.0"|||"(14-Dec-00)"|||" "|||"Public Screen"||":"|||Char(34)||PROG.PUBSCRTITLE||Char(34)
Let PROG.SCRTITLE=PROG.SCRTITLE|||" "|||GetWord(THEDATE,2,"/")||"-"||GetWord(THEDATE,1,"/")||"-"||GetWord(THEDATE,3,"/")
Loop CNT,0,24
	Let DATA[CNT]=""
EndLoop
MakeDocument "Days"
Loop CNT,6
	NewLine
EndLoop
Loop CNT,31
	Type CNT,NEWLINE 
EndLoop
Loop CNT,12
	NewLine
EndLoop
Let ST=0,LID=24,FLD=10
@endnode
 
@node "14 Routine · Draw Card" "Routine · Draw Card"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Draw Card
 
Let APen=DefPenA,BPen=DefPenB,CPen=DefPenC
SetPrintFont "topaz",8
SetPrintStyle PLAIN ,2,1
SetDrawMode JAM1 
SetPen APen,5
PrintText "Text1",62,239
SetPen BPen,5
PrintText "Text2",122,239
SetPen CPen,5
PrintText "Text3",186,239
Do "Currency",DefNote
@endnode
 
@node "15 Routine · Currency" "Routine · Currency"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Currency
 
If NOT ObjectAttached("F_Currency")
	ReattachObject "F_Currency"
EndIf
SetText "F_Currency","            "
If Arg1="$"
	SetText "F_Currency","$... Dollars"
ElseIf Arg1="Ł"
	SetText "F_Currency","Ł... Pounds"
ElseIf Arg1="F"
	SetText "F_Currency","F... Francs"
ElseIf Arg1="M"
	SetText "F_Currency","M... Mark"
ElseIf Arg1="DM"
	SetText "F_Currency","DM... Mark"
ElseIf Arg1="D"
	SetText "F_Currency","D... Dina"
ElseIf Arg1="G"
	SetText "F_Currency","G... Gilda"
ElseIf Arg1="R"
	SetText "F_Currency","R... Rupe"
ElseIf Arg1="L"
	SetText "F_Currency","L... Lira"
ElseIf Arg1="Y"
	SetText "F_Currency","Y... Yen"
ElseIf Arg1="K"
	SetText "F_Currency","K... PNG"
ElseIf Arg1="B"
	SetText "F_Currency","B... "
ElseIf Arg1="Z"
	SetText "F_Currency","Z... Zwoty"
ElseIf Arg1="E"
	SetText "F_Currency","E... Euro"
EndIf
DetachObject "F_Currency"
ReattachObject "B_Currency"
@endnode
 
@node "16 Routine · Load BackPic" "Routine · Load BackPic"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load BackPic
 
SetFileRequestMode REGULARMODE ,REJECTICONS 
Let FileName=AskForFileName(Arg1,"Select Picture To Load...")
If FileOf(FileName)<>""
	Do "FileType ErrorCheck"
	If Error
	EndIf
	Do "ShowBrush",FileName
	IfError
	EndIf
	ReattachObject "PrefsObjects"
Else
	Let DefBGPic=""
EndIf
Let DefBGPic=FileName
Let Av[1]=FileName,Av[2]=Arg2,Av[3]=Arg3,Av[4]=Arg4,Av[5]=Arg5,Av[6]=Arg6,N=Arg6
If Av[6]>1
	Let Av[N]=Av[1],DefTBGPic=Av[2],DefDBGPic=Av[3],DefOBGPic=Av[4],DefCBGPic=Av[5]
EndIf
Let DefPBGPic=FileName
Do "Set Prefs"
SaveVariable A2KPrefs,"Ram:A2K.Prefs"
Do "Set Fields"
SetText "F_PBGPic",FileName
SetObjectState "F_PBGPic",On
Do "Draw Card"
Do "Currency",DefNote
@endnode
 
@node "17 Routine · Load Dir" "Routine · Load Dir"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load Dir
 
SetFileRequestMode REGULARMODE ,REJECTICONS 
Let DirName=AskForFileName(Arg1,"Select Directory & File To Load...")
If FileOf(DirName)<>""
	Let Arg1=PathOf(DirName)
ElseIf DirName<>""
	Let Arg1=DirName
Else
	Let Arg1="A2K:A2KData/"||Arg3
EndIf
Do "Set Prefs"
SaveVariable A2KPrefs,"Ram:A2K.Prefs"
Do "Set Fields"
SetObjectState Arg2,On
Do "Currency",DefNote
@endnode
 
@node "18 Routine · Load File" "Routine · Load File"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load File
 
SetFileRequestMode REGULARMODE ,REJECTICONS 
Let FileName=AskForFileName("A2K:A2K.Prefs","Select Prefs File To Load...")
If FileOf(FileName)<>""
	Do "FileType ErrorCheck"
	Let A2KPrefs=LoadVariable(FileName)
	IfError
		Do "Make Def"
		Do "Set Prefs"
	EndIf
	Do "Set Prefs"
	Do "Set Def"
	Do "Make Ram Dir"
	SaveVariable A2KPrefs,"A2K:A2K.Prefs"
	SaveVariable A2KPrefs,"Ram:A2K.Prefs"
Else
	Do "Make Def"
	Do "Set Prefs"
	SaveVariable A2KPrefs,"A2K:A2K.Prefs"
	SaveVariable A2KPrefs,"Ram:A2K.Prefs"
EndIf
@endnode
 
@node "19 Routine · Set State" "Routine · Set State"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Set State
 
SetObjectState "B_Text 1",Off
SetObjectState "B_Text 2",Off
SetObjectState "B_Text 3",Off
SetObjectState "B_Text "||Arg1,On
@endnode
 
@node "20 Routine · Set Fields" "Routine · Set Fields"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Set Fields
 
SetText "F_DistDir",DefDistDir
SetText "F_DataDir",DefDataDir
SetText "F_OrderDir",DefOrdDir
SetText "F_CustDir",DefCustDir
SetText "F_PBGPic",DefPBGPic
SetText "F_PalDir",DefPalDir
@endnode
 
@node "21 BeforeAttachment · " "BeforeAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}BeforeAttachment@{fg text}@{ub} 
 
SetAutoFileRequester FALSE
Do "Get_FONT.PREFS"
Do "Get_PUBSCREEN.PREFS"
Do "Set_PROG.VARS"
Dos "C:Assign A2K: """||(TheCurrentDirectory)||""""
@endnode
 
@node "22 AfterAttachment · " "AfterAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AfterAttachment@{fg text}@{ub} 
 
SetAutoFileRequester FALSE
AttachObject "PrefsWindow"
@endnode
 
@node "23 Window · BootWindow" "Window · BootWindow"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Window@{fg text}@{ub} BootWindow
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} 0,0
	@{fg highlight}WindowObjects@{fg text} NONE 
	@{fg highlight}Size@{fg text} 1,1
	@{fg highlight}NumberOfColors@{fg text} 2
	@{fg highlight}WindowFlags@{fg text} NONE 
	@{fg highlight}VisualEffects@{fg text} NONE ,NONE 
@{b}EndScript@{ub}
@endnode
 
@node "24 Window · PrefsWindow" "Window · PrefsWindow"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Window@{fg text}@{ub} PrefsWindow
 
@{b}NoAttach@{ub}
@{b}Definition@{ub}
	Origin DefPrefsWinX,DefPrefsWinY
	Title "A2K Preferences..."
	WindowObjects CLOSEBUTTON DEPTHBUTTONS DRAGBAR 
	Size 250,300
	DefaultColors 1,0,4
	WindowFlags ACTIVATE TOFRONT 
	VisualEffects NONE ,NONE 
@{b}EndScript@{ub}
@{b}OnCloseButton@{ub}
	Let DefPrefsWinX=WindowX,DefPrefsWinY=WindowY
	Do "Set Prefs"
	SaveVariable A2KPrefs,"A2K:A2K.Prefs"
	SaveVariable A2KPrefs,"Ram:A2K.Prefs"
	FlushAll
	Quit
@{b}EndScript@{ub}
@{b}BeforeAttachment@{ub}
	If Exists("Ram:A2K.prefs")
		Let A2KPrefs=LoadVariable("Ram:A2K.prefs")
		Do "Set Def"
	ElseIf Exists("A2K:A2K.Prefs")
		Let A2KPrefs=LoadVariable("A2K:A2K.Prefs")
		Do "Set Def"
		Do "Make Ram Dir"
		SaveVariable A2KPrefs,"Ram:A2K.Prefs"
	ElseIf Not Exists("A2K:A2K.Prefs")
		If Not Exists("A2K:A2KData")
			Dos "C:MakeDir A2K:A2KData"
		EndIf
		Do "Load File"
	EndIf
@{b}EndScript@{ub}
@{b}AfterAttachment@{ub}
	If DefBGPic<>""
		Do "ShowBrush",DefBGPic
	EndIf
	AttachObject "PrefsObjects"
@{b}EndScript@{ub}
@{b}Resource "PrefsObjects"@{ub}
	NoAttach
	AfterAttachment
		Do "Draw Card"
		If DefDate="DMY"
			SetObjectState "DMY",On
		ElseIf DefDate="MDY"
			SetObjectState "MDY",On
		EndIf
		Do "Currency",DefNote
		Do "Set Fields"
		SetObjectState "F_DistDir",On
	EndScript
	AreaButton "B_DistDir"
		Definition
			Origin 208,29
			Image "A2K:A2K.br/Dir.b0"
			AltImage "A2K:A2K.br/Dir.b1"
		EndScript
		OnRelease
			Do "Load Dir",DefDistDir,"F_DistDir","DistData"
		EndScript
@endnode
 
@node "25 AreaButton · B_DataDir" "AreaButton · B_DataDir"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AreaButton@{fg text}@{ub} B_DataDir
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} 208,59
	@{fg highlight}Image@{fg text} "A2K:A2K.br/Dir.b0"
	@{fg highlight}AltImage@{fg text} "A2K:A2K.br/Dir.b1"
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	Do "Load Dir",DefDataDir,"F_DataDir","StockData"
@{b}EndScript@{ub}
@endnode
 
@node "26 AreaButton · B_OrderDir" "AreaButton · B_OrderDir"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AreaButton@{fg text}@{ub} B_OrderDir
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} 208,89
	@{fg highlight}Image@{fg text} "A2K:A2K.br/Dir.b0"
	@{fg highlight}AltImage@{fg text} "A2K:A2K.br/Dir.b1"
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	Do "Load Dir",DefOrdDir,"F_OrderDir","OrderData"
@{b}EndScript@{ub}
@endnode
 
@node "27 AreaButton · B_CustDir" "AreaButton · B_CustDir"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AreaButton@{fg text}@{ub} B_CustDir
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} 208,119
	@{fg highlight}Image@{fg text} "A2K:A2K.br/Dir.b0"
	@{fg highlight}AltImage@{fg text} "A2K:A2K.br/Dir.b1"
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	Do "Load Dir",DefCustDir,"F_CustDir","CustData"
@{b}EndScript@{ub}
@endnode
 
@node "28 AreaButton · B_PictDir" "AreaButton · B_PictDir"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AreaButton@{fg text}@{ub} B_PictDir
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} 208,149
	@{fg highlight}Image@{fg text} "A2K:A2K.br/File.b0"
	@{fg highlight}AltImage@{fg text} "A2K:A2K.br/File.b1"
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	Do "Load BackPic",DefBGPic,DefTBGPic,DefDBGPic,DefOBGPic,DefCBGPic,1
@{b}EndScript@{ub}
@endnode
 
@node "29 AreaButton · B_PalDir" "AreaButton · B_PalDir"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AreaButton@{fg text}@{ub} B_PalDir
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} 208,180
	@{fg highlight}Image@{fg text} "A2K:A2K.br/File.b0"
	@{fg highlight}AltImage@{fg text} "A2K:A2K.br/File.b1"
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	SetFileRequestMode REGULARMODE ,REJECTICONS 
	Let FileName=AskForFileName(DefPalBuf,"Select Picture or Brush to load...")
	If FileOf(FileName)<>""
		Let DefPalBuf=FileName
		Do "FileType ErrorCheck"
		IfError
		EndIf
		ShowPalette DefPalBuf
	Else
		Let DefPalBuf="A2K:Palette"
	EndIf
	Do "Set Prefs"
	SaveVariable A2KPrefs,"Ram:A2K.Prefs"
	Do "Set Fields"
	SetObjectState "F_PalDir",On
	Do "Draw Card"
	Do "Currency",DefNote
@{b}EndScript@{ub}
@endnode
 
@node "30 AreaButton · B_Currency" "AreaButton · B_Currency"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AreaButton@{fg text}@{ub} B_Currency
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} 18,209
	@{fg highlight}Border@{fg text} ROLLO 
	@{fg highlight}Highlight@{fg text} NONE 
	@{fg highlight}Size@{fg text} 180,14
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	If ObjectAttached("F_Currency")
		DetachObject "F_Currency"
	EndIf
	Let N=N+1
	If N=1
		Let DefNote="$"
	ElseIf N=2
		Let DefNote="Ł"
	ElseIf N=3
		Let DefNote="F"
	ElseIf N=4
		Let DefNote="M"
	ElseIf N=5
		Let DefNote="DM"
	ElseIf N=6
		Let DefNote="D"
	ElseIf N=7
		Let DefNote="G"
	ElseIf N=8
		Let DefNote="R"
	ElseIf N=9
		Let DefNote="L"
	ElseIf N=10
		Let DefNote="Y"
	ElseIf N=11
		Let DefNote="K"
	ElseIf N=12
		Let DefNote="B"
	ElseIf N=13
		Let DefNote="Z"
	ElseIf N=14
		Let DefNote="E"
	EndIf
	If N=14
		Let N=0
	EndIf
	Do "Currency",DefNote
	ReattachObject "B_Currency"
	Do "Set Prefs"
	SaveVariable A2KPrefs,"Ram:A2K.Prefs"
	SetObjectState "F_DistDir",On
@{b}EndScript@{ub}
@{b}OnClick@{ub}
	If NOT ObjectAttached("F_Currency")
		ReattachObject "F_Currency"
		DetachObject "F_Currency"
	EndIf
@{b}EndScript@{ub}
@endnode
 
@node "31 AreaButton · B_Tax" "AreaButton · B_Tax"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AreaButton@{fg text}@{ub} B_Tax
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} 206,209
	@{fg highlight}Border@{fg text} BEVEL 
	@{fg highlight}Text@{fg text} "Tax"
	@{fg highlight}Font@{fg text} "topaz",8
	@{fg highlight}Highlight@{fg text} NONE 
	@{fg highlight}Size@{fg text} 30,14
@{b}EndScript@{ub}
@{b}BeforeAttachment@{ub}
	Do "Click",206,209,30,14,"Tax",15
@{b}EndScript@{ub}
@{b}AfterAttachment@{ub}
	ReattachObject "B_Tax"
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	ReattachObject "B_Tax"
	Do "Set Prefs"
	SaveVariable A2KPrefs,"Ram:A2K.Prefs"
	If Not ObjectAttached("Tax Card")
		AttachObject "Tax Card"
		SetObjectState "TaxWindow",ON
	Else
		SetObjectState "TaxWindow",ON
	EndIf
@{b}EndScript@{ub}
@{b}OnClick@{ub}
	Do "Click",206,209,30,14,"Tax",15
@{b}EndScript@{ub}
@endnode
 
