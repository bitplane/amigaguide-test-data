	@{fg highlight}ShortCutKey@{fg text} "L"
@{b}EndScript@{ub}
@{b}Occurred@{ub}
	SetFileRequestMode REGULARMODE ,REJECTICONS 
	Let FileName=AskForFileName("A2K:A2K.Tax","Select File To Load...")
	If FileOf(FileName)<>""
