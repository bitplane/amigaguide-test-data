	Let Col=ScreenColors
	Let Cnt=Cnt+1
	If CurrButt=""
		Let CurrButt=1
	EndIf
	Do "Set State",CurrButt
	SetPen Cnt,5
	If CurrButt=1
		Let DefPenA=Cnt
	ElseIf CurrButt=2
		Let DefPenB=Cnt
	ElseIf CurrButt=3
		Let DefPenC=Cnt
	EndIf
	Do "Draw Card"
	If Cnt=Col
		Let Cnt=0
	EndIf
@{b}EndScript@{ub}
