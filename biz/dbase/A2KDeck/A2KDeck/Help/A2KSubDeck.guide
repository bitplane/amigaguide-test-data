SetObjectState "B_GST",Off
SetObjectState "B_PST",Off
SetObjectState "B_VAT1",Off
SetObjectState "B_VAT2",Off
SetObjectState Arg1,On
SetObjectState Arg2,On
@endnode
 
@node "59 BeforeAttachment · " "BeforeAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}BeforeAttachment@{fg text}@{ub} 
 
If Exists("A2K:A2K.Prefs")
	Let A2KPrefs=LoadVariable("A2K:A2K.Prefs")
	Do "Set Def"
EndIf
Let APen=DefPenA,BPen=DefPenB,CPen=DefPenC
@endnode
 
@node "60 AfterAttachment · " "AfterAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AfterAttachment@{fg text}@{ub} 
 
Let RtnHandler=Arg1
@endnode
 
@node "61 Window · TaxWindow" "Window · TaxWindow"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Window@{fg text}@{ub} TaxWindow
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} DefTaxWinX,DefTaxWinY
	@{fg highlight}Title@{fg text} "Tax..."
	@{fg highlight}WindowObjects@{fg text} CLOSEBUTTON DEPTHBUTTONS DRAGBAR 
	@{fg highlight}Size@{fg text} 140,160
	@{fg highlight}DefaultColors@{fg text} 1,0,4
	@{fg highlight}WindowFlags@{fg text} ACTIVATE TOFRONT 
	@{fg highlight}VisualEffects@{fg text} NONE ,NONE 
@{b}EndScript@{ub}
@{b}OnCloseButton@{ub}
	DoObjectScript "M_Quit",OCCURRED 
@{b}EndScript@{ub}
@{b}AfterAttachment@{ub}
	If DefBGPic<>""
		Do "ShowBrush",DefPBGPic
	EndIf
	SetPrintFont "topaz",8
	SetPrintStyle PLAIN ,B,1
	SetPen APen,5
	SetDrawMode JAM1 
	PrintText "Tax",30,34
	PrintText "GST",30,54
	PrintText "PST",30,74
	PrintText "VAT1",22,94
	PrintText "VAT2",22,114
	AttachObject "TaxObjects"
@{b}EndScript@{ub}
@{b}Resource "TaxObjects"@{ub}
	NoAttach
	AfterAttachment
		Do "Click",41,132,68,14,"Save"
		ReattachObject "B_Save"
		SetInteger ".Tax",Arg2
		If Arg2=""
			Let CurrButton="B_Tax"
		Else
			Let CurrButton=Arg3
		EndIf
		SetObjectState "B_Tax",ON
		SetObjectState ".Tax",ON
		If Exists("Ram:A2K.Tax")
			Let A2KTax=LoadVariable("Ram:A2K.Tax")
		ElseIf Exists("A2K:A2K.Tax")
			Let A2KTax=LoadVariable("A2K:A2K.Tax")
			SaveVariable A2KTax,"Ram:A2K.Tax"
		ElseIf Not Exists("A2K:A2K.Tax")
			Let A2KTax=GetDBObjects
			SaveVariable A2KTax,"Ram:A2K.Tax"
		EndIf
		Do "Set Tax Fields"
	EndScript
	IntegerField ".Tax"
		Definition
			Limits 0,99
			InitialInteger 0
			Origin 60,31
			Size 24,12
			Border INVERT BEVEL 
			MaxFieldLength 2
			Font "topaz",8
			TextColors 1,5
			AltTextColors 1,5
		EndScript
		OnRelease
			Let CurrButton="Tax"
			Do "Set Tax State","B_Tax",".Tax"
			Do "Save To Ram"
			SendToParentDeck RtnHandler,True,IntegerFrom(".Tax"),CurrButton
		EndScript
@endnode
 
