@node "101 AfterAttachment · " "AfterAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AfterAttachment@{fg text}@{ub} 
 
ReattachObject "B_List"
ReattachObject "B_<"
ReattachObject "B_>"
ReattachObject "B_Save"
ReattachObject "B_New"
ReattachObject "B_Delete"
ReattachObject ".Comments"
Do "Get Fields",".Name",".Add1",".Add2",".Sub",".State",".PostCode",".Email",".Phn",".Mob"
Dispose CustDataBase
If Exists("Ram:A2KData/CustData/CustName.Data")
	Let CustDataBase=LoadVariable("Ram:A2KData/CustData/CustName.Data")
	Do "Get CustEntry",1
ElseIf Exists(DefCustDir||"/CustName.Data")
	Let CustDataBase=LoadVariable(DefCustDir||"/CustName.Data")
	SaveVariable CustDataBase,"Ram:A2KData/CustData/CustName.Data"
	Do "Get CustEntry",1
ElseIf Not Exists(DefCustDir||"CustName.Data")
	SetFileRequestMode REGULARMODE ,REJECTICONS PATTERNFIELD 
	SetFileRequestPattern "#?.Data"
	Let FileName=AskForFileName(DefCustDir||"/.Data","Select File To Load...")
	If FileOf(FileName)<>""
		Let CustDataBase=LoadVariable(FileName)
		IfError
		EndIf
		SaveVariable CustDataBase,"Ram:A2KData/CustData/CustName.Data"
		SaveVariable CustDataBase,"Ram:A2KData/CustData/"||FileOf(FileName)
	Else
		Let CustIndex=1
		Let CustDataBase[CustIndex]=GetDBObjects
		SaveVariable CustDataBase,"Ram:A2KData/CustData/CustName.Data"
	EndIf
EndIf
Do "Get CustEntry",1
