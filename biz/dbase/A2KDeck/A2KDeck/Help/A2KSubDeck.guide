@node "86 Routine · Search For" "Routine · Search For"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Search For
 
Local NewStockIndex
SetSearchArrayFlags NOCASE FORWARD SUBSTRING 
Let NewStockIndex=SearchArray(StockDataBase,Arg1,"."||Arg2,StockIndex+1)
If Not SearchFound
	Let NewStockIndex=SearchArray(StockDataBase,Arg1,"."||Arg2)
EndIf
If SearchFound
	Do "Get Entry",NewStockIndex
EndIf
@endnode
 
@node "87 Routine · Load Data" "Routine · Load Data"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load Data
 
WorkWithDocument "List Stock"
Clear DOCUMENT 
If Exists("Ram:A2KData/StockData/Stock.Data")
	Let StockDataBase=LoadVariable("Ram:A2KData/StockData/Stock.Data")
	SortArray StockDataBase,INTEGER ,".VS"
	Let StockIndex=FirstArrayIndex(StockDataBase)
	While SearchFound
		Type LeftJustify(StockDataBase[StockIndex].VS,11)
		Type "  "
		Type LeftJustify(StockDataBase[StockIndex].Des,20)
		NewLine
		Let StockIndex=NextArrayIndex(StockDataBase,StockIndex)
	EndLoop
	Delete CHARACTER ,-1
	MoveCursorTo STARTOF DOCUMENT 
	Let StockIndex=1
EndIf
@endnode
 
