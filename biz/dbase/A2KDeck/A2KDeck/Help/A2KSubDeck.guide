@node "121 TextMenu · M_Load" "TextMenu · M_Load"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}TextMenu@{fg text}@{ub} M_Load
 
@{b}Definition@{ub}
	@{fg highlight}AttachTo@{fg text} MENU ,"Project..."
	@{fg highlight}Text@{fg text} "Load..."
	@{fg highlight}ShortCutKey@{fg text} "L"
@{b}EndScript@{ub}
@{b}Occurred@{ub}
	SetFileRequestMode REGULARMODE ,REJECTICONS PATTERNFIELD 
	SetFileRequestPattern "#?.Data"
	Let FileName=AskForFileName(DefCustDir||"/.Data","Select File To Load...")
	If FileOf(FileName)<>""
		Let CustDataBase=LoadVariable(FileName)
		IfError
		EndIf
		SaveVariable CustDataBase,"Ram:A2KData/CustData/CustName.Data"
		SaveVariable CustDataBase,"Ram:A2KData/CustData/"||FileOf(FileName)
	Else
		Let CustIndex=1
		Let CustDataBase[CustIndex]=GetDBObjects
		SaveVariable CustDataBase,"Ram:A2KData/CustData/CustName.Data"
	EndIf
	Do "Get CustEntry",1
@{b}EndScript@{ub}
@endnode
 
