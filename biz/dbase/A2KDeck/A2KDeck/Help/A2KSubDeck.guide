EndLoop
@endnode
 
@node "145 Routine · WorkOn_LIST" "Routine · WorkOn_LIST"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} WorkOn_LIST
 
GetPropPosition "P_Lines",Z,ST
Let ST=Limit(0,14,ST)
Loop CNT,10
	SetText "F_T_"||CNT,FormatValue(ST+(CNT-1),"00")||":00"
	SetText "F_A_"||CNT,DATA[ST+(CNT-1)]
EndLoop
@endnode
 
@node "146 Routine · Search_APPOINTMENTS" "Routine · Search_APPOINTMENTS"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Search_APPOINTMENTS
 
SetPen 2
Loop SD,DAYS
	If EXISTS("A2K:A2KData/Appoint/Appointment_"||SD||"."||THISMONTH||"."||THISYEAR)
		If THISYEAR=YEAR AND SMONTH=MONTH AND SD=SDAY
			SetPrintStyle BOLD SHADOW ,1,2
			PrintText SDAY,((SD+FIRSTDAY)//7)*32+12+(8%4*3),((SD+FIRSTDAY)%7)*17+42+2*(18)
			SetPrintStyle PLAIN 
		Else
			PrintText SD,((SD+FIRSTDAY)//7)*32+12+(8%4*3),((SD+FIRSTDAY)%7)*17+42+2*(18)
		EndIf
	EndIf
EndLoop
SetPen 1
@endnode
 
@node "147 Routine · Save_CDVR" "Routine · Save_CDVR"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Save_CDVR
 
If TextFrom("F_Appointments")<>""
	Let APPOINTMENT="A2K:A2KData/Appoint/Appointment_"||SD||"."||THISMONTH||"."||THISYEAR
	Let APPOINTMENT1="Ram:A2KData/Appoint/Appointment_"||SD||"."||THISMONTH||"."||THISYEAR
	SaveVariable DATA,APPOINTMENT
	SaveVariable DATA,APPOINTMENT1
	IfError
	EndIf
EndIf
@endnode
 
@node "148 Routine · Redraw_MONTH" "Routine · Redraw_MONTH"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Redraw_MONTH
 
WorkWithDocument "Days"
MoveCursorTo STARTOF DOCUMENT 
PositionOnLine DOW
Loop CTO,0,5
	Loop CTI,0,6
		SetPen 5
		AreaRectangle 12+(CTI*32)+2,42+2*(14)+4+(CTO*17)+1,28,15
		SetPen 1
		SetPrintFont "topaz",8
		PrintText THELINE,12+(CTI*32)+(8%4*3),42+2*(14+4)+(CTO*17)
		If THELINENUMBER-6=DAYS
			MoveCursorTo ENDOF DOCUMENT 
		Else
			MoveCursor DOWN 
		EndIf
	EndLoop
EndLoop
If SMONTH=MONTH AND THISYEAR=YEAR
	SetPrintStyle BOLD SHADOW ,1,2
	SetPen 1
	PrintText SDAY,(TDB//7)*32+12+(8%4*3),(TDB%7)*17+42+2*(14+4)
	SetPrintStyle PLAIN 
EndIf
SetText "F_Item",SMONTH|||THISYEAR
@endnode
 
@node "149 Routine · On_MOUSECLICK" "Routine · On_MOUSECLICK"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} On_MOUSECLICK
 
DrawBorder 12+(LASTX*32),42+2*(14)+4+(LASTY*17),32,17,BEVEL ,2,1
Let THISX=(MOUSEX-12)%32,THISY=(MOUSEY-42-14-14-4)%17,LASTX=THISX,LASTY=THISY,BLOCK=THISY*7+THISX
Let SD=BLOCK-FIRSTDAY
DrawBorder 12+(THISX*32),42+2*(14)+4+(THISY*17),32,17,BEVEL ,1,2
If SD>0 AND SD<=DAYS
	Do "Load_CDVR"
Else
	Do "Clear_LIST"
EndIf
@endnode
 
@node "150 Routine · Get_FACTOR" "Routine · Get_FACTOR"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get_FACTOR
 
Let FACTOR1=THISYEAR*365+THISDAY+31*(THISMONTH-1),FACTOR1=IfThen(THISMONTH<3,FACTOR1,FACTOR1-(4*THISMONTH+23)%10)
Let AYEAR=IfThen(THISMONTH<3,THISYEAR-1,THISYEAR),FACTOR=FACTOR1+AYEAR%4-(AYEAR%100+1)*3%4,DAYOFWEEK=FACTOR//7
Let SMONTH=Case(THISMONTH,"January","February","March","April","May","June","July","August","September","October")
Let SMONTH=IfThen(THISMONTH>10,Case(GetChars(THISMONTH,2,1),"November","December"),SMONTH)
Let DAYS=Case(THISMONTH,31,28,31,30,31,30,31,31,30,31),DAYS=IfThen(THISMONTH>10,Case(GetChars(THISMONTH,2,1),30,31),DAYS)
Let DAYS=IfThen(DAYS=28,IfThen(THISYEAR//4=0 OR THISYEAR//400=0,29,28),DAYS),FIRSTDAY=(FACTOR-THISDAY)//7-1
Let DOW=6-FIRSTDAY,TDB=SDAY+FIRSTDAY
Let THEDAY=IfThen(SMONTH=MONTH AND THISYEAR=YEAR,Case((TDB//7)+1,"Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"),THEDAY)
@endnode
 
@node "151 Routine · Load_CDVR" "Routine · Load_CDVR"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load_CDVR
 
Let APPOINTMENT="A2K:A2KData/Appoint/Appointment_"||SD||"."||THISMONTH||"."||THISYEAR
SendToParentDeck RtnHandler,True,SD||"."||THISMONTH||"."||THISYEAR
Do "Clear_LIST"
Do "Clear_DATA"
If NOT EXISTS(APPOINTMENT)
	Do "Clear_LIST"
	Do "Clear_DATA"
Else
	Let DATA=LoadVariable(APPOINTMENT)
	IfError
		Do "Clear_LIST"
	Else
		Do "WorkOn_LIST"
	EndIf
EndIf
SetText "F_Appointments",Case(THISX+1,"Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday")||","|||SD|||SMONTH|||THISYEAR
@endnode
 
