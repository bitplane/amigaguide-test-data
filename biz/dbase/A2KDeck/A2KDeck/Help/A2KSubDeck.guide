@endnode
 
@node "134 Routine · WorkOn_BATCH" "Routine · WorkOn_BATCH"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} WorkOn_BATCH
 
Do "Get_FACTOR"
Do "Clear_LIST"
Do "Clear_DATA"
Do "Redraw_MONTH"
@endnode
 
@node "135 Routine · Reset_DATE" "Routine · Reset_DATE"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Reset_DATE
 
If SMONTH<>MONTH OR THISYEAR<>YEAR
	Let THISMONTH=GETWORD(THISDATE,1,"/")
	Let THISYEAR=YEAR
	Do "WorkOn_BATCH"
EndIf
@endnode
 
@node "136 Routine · Print_CDVR" "Routine · Print_CDVR"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Print_CDVR
 
If TextFrom("F_Appointments")<>""
	MakeDocument "TEMP"
	WorkWithDocument "TEMP"
	Clear DOCUMENT 
	Type "",NEWLINE 
	Type "",NEWLINE 
	Type "Appointments:"|||TextFrom("F_Appointments"),NEWLINE 
	Type "",NEWLINE 
	Loop CNT,0,23
		Type "  "||FormatValue(CNT,"00")||":00 "|||DATA[CNT],NEWLINE 
	EndLoop
	;SaveDocument "TEMP","PRT:"
	SaveDocument "TEMP","Ram:A2KData/Appoint/Appointment_Doc"||SD||"."||THISMONTH||"."||THISYEAR"
	SaveDocument "TEMP","A2K:A2KData/Appoint/Appointment_Doc"||SD||"."||THISMONTH||"."||THISYEAR"
	IfError
	EndIf
EndIf
@endnode
 
@node "137 Routine · Get_LOWER" "Routine · Get_LOWER"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get_LOWER
 
Let THISMONTH=THISMONTH-1
If THISMONTH=0
	Let THISMONTH=12
	Let THISYEAR=IfThen(THISYEAR-1<1,THISYEAR=0,THISYEAR-1)
EndIf
Do "WorkOn_BATCH"
@endnode
 
@node "138 Routine · Get_HIGHER" "Routine · Get_HIGHER"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get_HIGHER
 
Let THISMONTH=THISMONTH+1
If THISMONTH=13
	Let THISMONTH=1
	Let THISYEAR=IfThen(THISYEAR+1>9999,THISYEAR=0,THISYEAR+1)
EndIf
Do "WorkOn_BATCH"
@endnode
 
@node "139 Routine · Get_DATE" "Routine · Get_DATE"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get_DATE
 
Let THISDATE=THEDATE,THISMONTH=0+GETWORD(THISDATE,1,"/"),THISDAY=0+GETWORD(THISDATE,2,"/")
Let THISYEAR=GETWORD(THISDATE,3,"/"),SDAY=THISDAY,THISYEAR=IfThen(THISYEAR>=90,1900+THISYEAR,2000+THISYEAR)
Let MONTH=Case(THISMONTH,"January","February","March","April","May","June","July","August","September","October")
Let MONTH=IfThen(THISMONTH>10,Case(GetChars(THISMONTH,2,1),"November","December"),MONTH),YEAR=THISYEAR,DAY=THISDAY
@endnode
 
@node "140 Routine · Clear_LIST" "Routine · Clear_LIST"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Clear_LIST
 
SetText "F_Appointments",""
SetPropPosition "P_Lines",Z,0
Loop CNT,10
	SetText "F_T_"||CNT,FormatValue(CNT-1,"00")||":00"
	SetText "F_A_"||CNT,""
EndLoop
@endnode
 
