@node "125 Routine · Send Info" "Routine · Send Info"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Send Info
 
Let Name=CustDataBase[CustIndex].Name
Let Add1=CustDataBase[CustIndex].Add1
SendToParentDeck RtnHandler,True,Name,Add1,CustIndex,CustDataBase[CustIndex]
@endnode
 
@node "126 Routine · Load Data" "Routine · Load Data"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load Data
 
WorkWithDocument "List Names"
Clear DOCUMENT 
If Exists("Ram:A2KData/CustData/CustName.Data")
	Let CustDataBase=LoadVariable("Ram:A2KData/CustData/CustName.Data")
	Let CustIndex=FirstArrayIndex(CustDataBase)
	While SearchFound
		Type LeftJustify(CustDataBase[CustIndex].Name,11)
		Type "  "
		Type LeftJustify(CustDataBase[CustIndex].Add1,20)
		NewLine
		Let CustIndex=NextArrayIndex(CustDataBase,CustIndex)
	EndLoop
	Delete CHARACTER ,-1
	MoveCursorTo STARTOF DOCUMENT 
	Let CustIndex=1
EndIf
@endnode
 
@node "127 BeforeAttachment · " "BeforeAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}BeforeAttachment@{fg text}@{ub} 
 
If Exists("A2K:A2K.Prefs")
	Let A2KPrefs=LoadVariable("A2K:A2K.Prefs")
	Do "Set Def"
EndIf
@endnode
 
