@node rxactivatedbwindow "AktywujDBOkno" 
@toc ARexxFuncInd

@{b}@{u}AktywujDBOkno@{ub}@{uu}


@{b}Nazwa:@{ub} @{b}AktywujDBOkno@{ub} -- Aktywuje okno bazydanych's(8) 

@{b}Streszczenie:@{ub} @{b}AktywujDBOkno Projekt/K@{ub}
   @{b}RC@{ub} = @{i}Sukces@{ui} 

@{b}Funkcja:@{ub} Aktywuje Okno maski okresonej bazydanych.
Skupione dane wejsciowe uzytkownika zmienia sie na tym oknie. To
nie ma zadnego efektu na pracy wywolywanych skryptow ARexx'a. Jesli
baza danych jest ukryta ta komenda nie robi niczego.

@{b}Argumenty:@{ub} @{b}Projekt@{ub} - Nazwa bazydanych do
aktywacji. 

@{b}rezultaty:@{ub} @{b}RC@{ub} - Sukces

@{b}Skladnia angielska:@{ub}
@{b}ActivateDBWindow Project/K@{ub}

@endnode 


@node rxactivatefield "Aktywujpole" 
@toc ARexxFuncInd

@{b}@{u}Aktywujpole@{ub}@{uu}


@{b}Nazwa:@{ub} @{b}Aktywujpole@{ub} - Aktywuje pole w masce. 

@{b}Streszczenie:@{ub} @{b}Aktywujpole poleID/A@{ub}
   @{b}RC@{ub} = @{i}Sukces@{ui} 

@{b}Funkcja:@{ub} Aktywuje pole z okreslonym ID w masce. Tylko
pola, ktore pojawiaja sie jako ciag znakow lub gadzet longint moga
byc aktywowane. Jesli projekt lub okno nie jest aktywne, pole nie
moze byc aktywowane. Ta komenda moze byc wywolana tylko w trybie
rekordow.

@{b}Argumenty:@{ub} @{b}poleID@{ub} - ID pola do aktywacji. 

@{b}rezultaty:@{ub} @{b}RC@{ub} - Zero jesli pole zostalo
zaktywowane. 

@{b}Skladnia angielska:@{ub}
@{b}ActivateField FieldID/A@{ub}

@endnode 


@node rxactiveindex "aktywneIndex" 
@toc ARexxFuncInd

@{b}@{u}aktywneIndex@{ub}@{uu}


@{b}Nazwa:@{ub} @{b}aktywneIndex@{ub} -- kontroluje aktywny index 

@{b}Streszczenie:@{ub} @{b}aktywneIndex
Index/K,nastepny/S,poprzedni/S,bezhistorii/S,Sila/S,Var/K@{ub}
   @{b}RC@{ub} = @{i}Sukces@{ui}
   @{b}Rezultat@{ub} = @{i}aktywne Index@{ui} 

@{b}Funkcja:@{ub} Ta komenda kontroluje aktywny index. Mozesz
okreslic index przez nazwe lub aktywowac @{b}nastepny@{ub} 
lub @{b}poprzedni@{ub} index w  
@{"historii indexu" Link indexhistory}. Nazwa nowo aktywowanego
indexu bedzie zwrocona. Jesli nie okreslisz zadnego @{b}Index@{ub}, 
@{b}nastepny@{ub} lub @{b}poprzedni@{ub}, tylko nazwa aktywnego
indexu bedzie zwrocona.

@{b}Argumenty:@{ub} @{b}Index@{ub} - Aktywuj okreslony index.
   @{b}nastepny@{ub} - Aktywuj nastepny index w historii.
   @{b}poprzedni@{ub} - Aktywuj poprzedni index w historii.
   @{b}bezhistorii@{ub} - Nie sledz tej zmiany w historii indexu.
   @{b}Sila@{ub} - Tlumi wszystkie ostrzezenia. 

@{b}rezultaty:@{ub} @{b}RC@{ub} - Sukces. @{b}Rezultat@{ub} - Nazwa
od teraz aktywnego indexu.

@{b}Skladnia angielska:@{ub}
@{b}ActiveIndex Index/K,Next/S,Prev/S,NoHistory/S,Force/S,Var/K@{ub}

@endnode 
@node rxactiverecord "aktywnerekord" 
@toc ARexxFuncInd

@{b}@{u}aktywnerekord@{ub}@{uu}


@{b}Nazwa:@{ub} @{b}aktywnerekord@{ub} -- kontroluje aktywny rekord 

@{b}Streszczenie:@{ub} @{b}aktywnerekord Rekord/K/N,Pierwszy/S,Ostatni/S,nastepny/S,poprzedni/S,Var/K@{ub}
   @{b}RC@{ub} = @{i}Sukces@{ui} 
   @{b}Rezultat@{ub} = @{i}nowy aktywny rekord@{ui} 

@{b}Funkcja:@{ub} z @{b}aktywnerekord@{ub} mozesz kontrolowac
aktywny rekord w zaadresowanej bazie danych. Mozesz aktywowac
rekord okreslony przez numer rekordu, @{b}Pierwszy@{ub}, 
@{b}Ostatni@{ub} lub @{b}nastepny@{ub} lub @{b}poprzedni@{ub}
rekord pokrewny do biezaco aktywnego rekordu. Numer nowo aktywnego
rekordu bedzie zwrocony. Jesli nie okreslisz zadnego z pieciu
pierwszych argumentow, tylko numer aktywnego rekordu bedzie
zwrocony i pozycja nie bedzie zmieniona. Ta komenda moze byc
wywolana tylko w trybie rekordow.

@{b}Argumenty:@{ub} @{b}Rekord@{ub} - Aktywuj okreslony rekord. 
   @{b}Pierwszy@{ub} - Aktywuj Pierwszy rekord. 
   @{b}Ostatni@{ub} - Aktywuj Ostatni rekord. 
   @{b}nastepny@{ub} - Aktywuj rekord po biezaco aktywnym rekordzie.
   @{b}poprzedni@{ub} - Aktywuj rekord przed biezaco aktywnym
rekordem.
   

@{b}rezultaty:@{ub} @{b}RC@{ub} - Sukces
   @{b}Rezultat@{ub} - numer teraz aktywnego rekord. 

@{b}Skladnia angielska:@{ub}
@{b}ActiveRecord Record/K/N,First/S,Last/S,Next/S,Prev/S,Var/K@{ub}

@endnode 


@node rxaddlvfieldentry "dodajLVpolepozycje" 
@toc ARexxFuncInd

@{b}@{u}dodajLVpolepozycje@{ub}@{uu}


@{b}Nazwa:@{ub} @{b}dodajLVpolepozycje@{ub} - dodaj pozycje do pola
listowego 

@{b}Streszczenie:@{ub} @{b}dodajLVpolepozycje
poleID/A,Rekord/K/N,Listapozycji/K/N@{ub} 
   @{b}RC@{ub} = @{i}Sukces@{ui} 

@{b}Funkcja:@{ub} dodaje nowa pozycje po okreslonych pozycjach
okreslonego pola listowego. Jesli zadna pozycja nie jest okreslona,
pozycja bedzie dodana jako ostatnia pozycja. Bedzie zawierac 
@{b}poczatkowa zawartosc@{ub} ustalona w requesterze pola. By
zmienic zawartosc, uzyj @{b}@{"ustalpole" link rxsetfield}@{ub}. Ta
komenda moze byc wywolana tylko w trybie rekordow.

@{b}Argumenty:@{ub} @{b}poleID@{ub} - ID pola listowego 
   @{b}rekord@{ub} - numer rekordu do zmiany 
   @{b}Listapozycji@{ub} - numer pozycji, po ktorej pozycje beda
dodawane
   Liczona od 1. 0 dla dodania pozycji na szczycie Listy. 

@{b}rezultaty:@{ub} @{b}RC@{ub} - Sukces 

@{b}Skladnia angielska:@{ub}
@{b}AddLVFieldEntry FieldID/A,Record/K/N,ListEntry/K/N@{ub} 

@endnode 


@node rxaddrecord "dodajRekord" 
@toc ARexxFuncInd

@{b}@{u}dodajRekord@{ub}@{uu}


@{b}Nazwa:@{ub} @{b}dodajRekord@{ub} - dodaj nowy rekord do bazydanych 

@{b}Streszczenie:@{ub} @{b}dodajRekord rekord/K/N,nieaktywny/S,Var/K@{ub}
   @{b}RC@{ub} = @{i}Sukces@{ui}
   @{b}Rezultat@{ub} = @{i}pozycja rekordu@{ui} 

@{b}Funkcja:@{ub} Tworzy nowy rekord i dodaje go do zaadresowanej
bazy danych. rekord bedzie zawierac poczatkowe wartosci. Komenda
moze byc tylko wywolana w trybie rekordow.

@{b}Argumenty:@{ub} @{b}rekord@{ub} - rekord, po ktorym nowy rekord
bedzie umieszczony w bazie danych. Zanotuj prosze, ze Fiasco moze
wybrac inna pozycje dla rekordu. To moze sie zdazyc np.w przypadku
uzycia automatycznego sortowania. Jesli nie okreslony, rekord
bedzie umiejscowiony po rekordzie aktywnym.
   @{b}nieaktywny@{ub} - rekord nie bedzie aktywowany. 
   

@{b}rezultaty:@{ub} @{b}RC@{ub} - Sukces 
   @{b}Rezultat{ub} - Rzeczywista pozycja nowego rekordu. 

@{b}Skladnia angielska:@{ub}
@{b}AddRecord Record/K/N,Inactive/S,Var/K@{ub}

@endnode 


@node rxcalculateformula "KalkulujFormule" 
@toc ARexxFuncInd

@{b}@{u}KalkulujFormule@{ub}@{uu}


@{b}Nazwa:@{ub} @{b}KalkulujFormule@{ub} - Kalkuluje formule. 

@{b}Streszczenie:@{ub} @{b}kalkulujFormule Formula/A,rekord/K/N,Var/K@{ub}
   @{b}RC@{ub} = @{i}Sukces@{ui}
   @{b}Rezultat@{ub} = @{i}Rezultat kalkulacji@{ui} 

@{b}Funkcja:@{ub} Klkuluje formule i zwraca rezultat. Jesli pola
odwoluja sie do formuly, wartosci pol biezacego lub okreslonego
rekordu w adresowanej bazie danych beda uzyte. Ta komenda moze byc
wywolana tylko w trybie rekordow.

@{b}Argumenty:@{ub} @{b}Formula@{ub} - Formula do kalkulacji.
   @{b}rekord@{ub} - rekord do uzycia jako biezacy dla kalkulacji. 

@{b}rezultaty:@{ub} @{b}RC@{ub} - Sukces.
   @{b}Rezultat@{ub} - Rezultat kalkulacji. 

@{b}Skladnia angielska:@{ub}
@{b}CalculateFormula Formula/A,Record/K/N,Var/K@{ub}

@endnode 


@node rxclear "Czysc" 
@toc ARexxFuncInd

@{b}@{u}Czysc@{ub}@{uu}


@{b}Nazwa:@{ub} @{b}Czysc@{ub} -- Czysci Projekt 

@{b}Streszczenie:@{ub} @{b}Czysc sila/S@{ub} 
   @{b}RC@{ub} = @{i}Sukces@{ui} 

@{b}Funkcja:@{ub} Kasuje wszystkie dane w zaadresowanym projekcie. 
Bedzie on w stanie prawie jak po uzyciu @{b}nowy@{ub}. Jesli nie
okreslisz @{b}Sila@{ub}, ta komenda robi dokladnie to samo co 
@{b}@{"Projekt/Wyczysc" link MnErase}@{ub}. To oznacza, ze jest
mozliwe, ze otworzy sie requester, ktory zapyta cie czy chcesz 
zapisac biezacy projekt przez zatwierdzeniem lub anulowaniem.
By poprzedzic to, okresl parametr @{b}sila@{ub}. To wytlumi
wszystkie ostrzezenia.

@{b}Argumenty:@{ub} @{b}sila@{ub} - tlumi wszystkie ostrzezenia. 

@{b}rezultaty:@{ub} @{b}RC@{ub} - Nie rozwny zero, jesli uzytkownik
anulowal requester ostrzezenia.

@{b}Skladnia angielska:@{ub}
@{b}Clear Force/S@{ub} 

@endnode 


@node rxclonerecord "dublujrekord" 
@toc ARexxFuncInd

@{b}@{u}dublujrekord@{ub}@{uu}


@{b}Nazwa:@{ub} @{b}dublujrekord@{ub} -- kopiuj rekord

@{b}Streszczenie:@{ub} @{b}dublujrekord rekord/K/N,To/K/N@{ub}
   @{b}RC@{ub} = @{i}Sukces@{ui} 

@{b}Funkcja:@{ub} Tworzy dokladna kopie aktywnego lub okreslonego
rekordu i umieszcza go na okreslonej pozycji w aktywnym indexie.
Moze takze wywierac wplyw na inne indexy. Ta komenda moze byc
wywolana tylko w trybie rekordow.

@{b}Argumenty:@{ub} @{b}rekord@{ub} - numer rekordu do sklonowania.
   @{b}do@{ub} - numer rekordu, po ktorym nowy rekord bedzie
umieszczony. 

@{b}rezultaty:@{ub} @{b}RC@{ub} - Sukces 

@{b}Skladnia angielska:@{ub}
@{b}CloneRecord Record/K/N,To/K/N@{ub}

@endnode 


@node rxclose "Zamknij" 
@toc ARexxFuncInd

@{b}@{u}Zamknij@{ub}@{uu}


@{b}Nazwa:@{ub} @{b}Zamknij@{ub} -- zamyka projekt bazydanych 

@{b}Streszczenie:@{ub} @{b}zamknij sila/S@{ub} 
   @{b}RC@{ub} = @{i}Sukces@{ui} 

@{b}Funkcja:@{ub} Zamyka adresowany projekt. Jesli nie okresliles 
@{b}Force@{ub}, ta komenda robi dokladnie to samo co 
@{b}@{"Projekt/Wyjscie" link MnQuit}@{ub}. To oznacza, ze jest
mozliwe, ze otworzy sie requester, ktory zapyta ci czy chcesz
zapisac biezacy projekt przed zatwierdzeniem lub anulowaniem. By to
poprzedzic okresl parametr @{b}sila@{ub}. To wytlumi wszystkie
ostrzezenia.

@{b}Argumenty:@{ub} @{b}sila@{ub} - wytlumia wszystkie ostrzezenia.

@{b}rezultaty:@{ub} @{b}RC@{ub} - Nie rowny zero, jesli uzytkownik
anulowal requester ostrzezen. 

