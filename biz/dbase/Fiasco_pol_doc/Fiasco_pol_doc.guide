@node rxcreatefield "utworzpole" 
@toc ARexxFuncInd

@{b}@{u}utworzpole@{ub}@{uu}


@{b}Nazwa:@{ub} @{b}utworzpole@{ub} - tworzy pole 
   

@{b}Streszczenie:@{ub} @{b}utworzpole Typ/A,polelistowe/S,ID/A@{ub}
   @{b}RC@{ub} = @{i}Sukces@{ui} 

@{b}Funkcja:@{ub} tworzy nowe pole w zaadresowanej bazie danych.
Atrybuty beda zawierac domyslne wartosci. Bedzie ono w liscie i
masce ukryte. By zmienic atrybuty naswoje wlasne potrzeby i
spowodowac by stalo sie widoczne mozesz uzyc komendy 
@{b}@{"ustalAttr" link rxsetattr}@{ub}. Ta komenda moze byc
wywolana tylko w trybie maski.

@{b}Argumenty:@{ub} @{b}Typ@{ub} - Typ pola. 
   @{b}polelistowe@{ub} - okresl, jesli ole ma byc polem listowym.
   @{b}ID@{ub} - ID nowego pola. Komenda odmowi dzialania jesli ID
   juz istnieje.
   
@{b}rezultaty:@{ub} @{b}RC@{ub} - Sukces. 

@{b}Skladnia angielska:@{ub}
@{b}CreateField Type/A,Listview/S,ID/A@{ub}

@endnode 

@node rxcutrecord "Tnijrekord" 
