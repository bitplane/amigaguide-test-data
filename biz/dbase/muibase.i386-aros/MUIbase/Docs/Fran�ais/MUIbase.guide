   Voir aussi @{"GETADMINMODE" link "GETADMINMODE"}, @{"SETADMINMODE" link "SETADMINMODE"}, @{"SHA1SUM" link "SHA1SUM"}, dťmo @{b}Users.mb@{ub}.


