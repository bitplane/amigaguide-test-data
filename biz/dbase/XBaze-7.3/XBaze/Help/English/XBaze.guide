@{fg highlight}@{B}@{U}Settings@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Project settings:@{fg text}@{UB}
  @{" Informations   " LINK PRJSETS}
  @{" Protection     " LINK PASSETS}
  @{" ARexx          " LINK ARXSETS}
  @{" Menu           " LINK MENUSETS}

@{" Program settings " LINK PRGSETS}

@ENDNODE
///
/// Settings - informations
@NODE PRJSETS "Project settings - Informations"

@{fg highlight}@{B}@{U}Project settings - Informations@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Calling:@{fg text}@{UB}
  Main window:
    @{B}menu:@{UB}      Project|Settings...

@{fg highlight}@{B}Description:@{fg text}@{UB}
  Edits informations about project.

@{fg highlight}@{B}Gadgets:@{fg text}@{UB}
  @{B}Author@{UB}
    Project author.

  @{B}Version@{UB}
    Project version.

  @{B}Description:@{UB}
    Short information about project.

  @{B}Show "About project..." on startup@{UB}
    If you select this option, when someone loads a project, the program
    shows a requester with the basic information about the project.

