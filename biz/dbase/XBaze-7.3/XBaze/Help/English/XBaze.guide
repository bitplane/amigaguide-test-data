///
/// Attributes - variable
@NODE VAR "Variable"

@{fg highlight}@{B}@{U}Variable@{fg text}@{UB}@{UU}

  Variable is a string starting from "%" character. Variable is
  changed to proper value.
  In that text gadget, in which you can use variables, on the right
  side of gadgets you can see "«" gadget, which calls list containing
  all variables with their descriptions.

@ENDNODE
///
/// Attributes - ARexx program
@NODE PRGRX "ARexx program for field"

@{fg highlight}@{B}@{U}ARexx program for field@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Calling:@{fg text}@{UB}
  @{"New project window:" LINK DEFINITION}
    @{B}gadget:@{UB}    ARexx...

  Main window:
    @{B}menu:@{UB}      Field|Properties|ARexx...
    @{B}popupmenu:@{UB} Properties|ARexx...

  @{"Design window:" LINK VIEW}
    @{B}menu:@{UB}      Field|ARexx...
    @{B}popupmenu:@{UB} ARexx...
    @{B}shortcut:@{UB}  [Shift] [<doubleclick on the field>]

@{fg highlight}@{B}Description:@{fg text}@{UB}
  ARexx program will be run when you specify any value for the field.

@{fg highlight}@{B}Gadgets:@{fg text}@{UB}
  @{B}Program@{UB}
    Program which will be run.

  @{B}Console@{UB}
    Console, where all returned values from program will be shown.

