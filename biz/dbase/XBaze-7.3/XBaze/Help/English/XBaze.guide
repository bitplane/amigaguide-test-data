///
/// Description - Menu
@NODE MENU "Menu"

@{fg highlight}@{B}@{U}Menu@{fg text}@{UB}@{UU}

  @{B}*@{UB}
    @{B}Reopen@{UB}
      Reopens current project.
    @{B}<project name>@{UB}
      Opens that project.

  @{B}Project@{UB}
    @{B}New...@{UB}
      @{"Creates new project" LINK NEWPROJECT}.
    @{B}Open...@{UB}
      Opens selected project.
    @{B}Close@{UB}
      Removes current project from memory.
    @{B}Define...@{UB}
      @{"Defines field of database" LINK DEFINITION}.
    @{B}Save@{UB}
      Saves current project.
    @{B}Save as...@{UB}
      Saves current project with new name.
    @{B}Print...@{UB}
      @{"Prints project" LINK Printing}.
    @{B}Settings...@{UB}
      @{"Project and programme settings" LINK SETTINGS}.
    @{B}Iconify@{UB}
      Iconifies program.
    @{B}Quit@{UB}
      Ends working with the program.

  @{B}View@{UB}
    @{B}Main@{UB}
      Brings back this view, which was written with project.
    @{B}Other...@{UB}
      Loads view.
    @{B}Design@{UB}
      Opens @{"Design view" LINK VIEW} window.

  @{B}Record@{UB}
    @{B}Undo@{UB}
      Undoes last changes in the record.
    @{B}Cut@{UB}
      Cuts record to the buffer.
    @{B}Copy@{UB}
      Copies record to the buffer.
    @{B}Paste@{UB}
      Pastes record from the buffer.
    @{B}Erase@{UB}
      Erases all fields.
    @{B}Reset@{UB}
      Sets default values in all fields.
    @{B}Insert@{UB}
      @{B}One@{UB}
        Adds new record.
      @{B}Many...@{UB}
        Adds requested number of records.
      @{B}File...@{UB}
        Adds records from selected project.
    @{B}Delete@{UB}
      @{B}Current@{UB}
        Deletes current record.
       @{B}Marked@{UB}
        Deletes only marked records.
       @{B}Unmarked@{UB}
        Deletes only unmarked records.
      @{B}Range...@{UB}
        Deletes records from defined range.
      @{B}All@{UB}
        Deletes all records.
    @{B}Mark@{UB}
      @{B}Current@{UB}
        Marks current record.
      @{B}Fitted...@{UB}
        Marks fields using search criterion.
      @{B}Toggle@{UB}
        Toggles all marks. Record which is unmarked will be marked,
        and record which is marked will be unmarked.
      @{B}All@{UB}
        Marks all records.
    @{B}Unmark@{UB}
      @{B}Current@{UB}
        Unmarks current record.
      @{B}Fitted...@{UB}
        Unmarks fields using search criterion.
      @{B}Toggle@{UB}
        Toggles all marks. Record which is unmarked will be marked,
        and record which is marked will be unmarked.
      @{B}All@{UB}
        Unmarks all records.
    @{B}Sort@{UB}
      @{B}By...@{UB}
        @{"Sorts records" LINK SORTING}.
      @{B}By <field name>@{UB}
        Sorts by field name.

  @{B}Field@{UB}
    @{B}Undo@{UB}
      Undoes last changes in the field
    @{B}Cut@{UB}
      Cuts content of selected field to clipboard.
    @{B}Copy@{UB}
      Copies content of selected field to clipboard.
    @{B}Paste@{UB}
      Pastes content of clipboard to selected field
    @{B}Erase@{UB}
      Erases content of selected field.
    @{B}Reset@{UB}
      Sets initial field value.
    @{B}Browse...@{UB}
      Opens @{"browser" LINK BROWSING} window.
    @{B}Statistics...@{UB}
      Opens @{"statistics" LINK STATISTICS} window.
    @{B}Sort@{UB}
      @{B}A-Z@{UB}
        Sorts in ascending order.
      @{B}Z-A@{UB}
        Sorts in descending order.
    @{B}Properties@{UB}
      @{B}Definition...@{UB}
        Opens @{"field definition" LINK DEFINITION} window.
      @{B}Attributes...@{UB}
        for the following field type:
          @{" String      " LINK STRINGATRR}
          @{" Amount      " LINK STRINGATRR}
          @{" Boolean     " LINK BOOLEANATRR}
          @{" Cycle       " LINK CYCLEATRR}
          @{" Button      " LINK BUTTONATRR}
          @{" Text        " LINK TEXTATRR}
      @{B}ARexx...@{UB}
        @{"Sets ARexx program for field" LINK PRGRX}.
      @{B}Label...@{UB}
        Opens @{"label" LINK LABELS} window.

  @{B}Navigation@{UB}
    @{B}Find...@{UB}
      @{"Finds element in the project" LINK SEARCHING}.
    @{B}Find next@{UB}
      Searchs project from current to the last record using previously
      defined searching criterion.
    @{B}Find prev@{UB}
      Searchs project from current to the first record using previously
      defined searching criterion.
    @{B}Go to...@{UB}
        Goes to specified record.
    @{B}Next@{UB}
      @{B}Record@{UB}
        Goes to next record.
      @{B}Marked@{UB}
        Goes to next marked record.
      @{B}Unmarked@{UB}
        Goes to next unmarked record.
    @{B}Prev@{UB}
      @{B}Record@{UB}
        Goes to previous record.
      @{B}Marked@{UB}
        Goes to previous marked record.
      @{B}Unmarked@{UB}
        Goes to previous unmarked record.
    @{B}First@{UB}
      @{B}Record@{UB}
        Goes to the first record.
      @{B}Marked@{UB}
        Goes to the first marked record.
      @{B}Unmarked@{UB}
        Goes to the first unmarked record.
    @{B}Last@{UB}
      @{B}Record@{UB}
        Goes to the last record.
      @{B}Marked@{UB}
        Goes to the last marked record.
      @{B}Unmarked@{UB}
        Goes to the last unmarked record.

  @{B}ARexx@{UB}
    @{B}Execute program...@{UB}
      Executes selected ARexx program.

@ENDNODE
///
///Description - shortcuts
@NODE SHORTCUTS "Shortcuts"

@{fg highlight}@{B}@{U}Shortcuts@{fg text}@{UB}@{UU}

@{fg highlight}@{B}General rule@{fg text}@{UB}
  @{B}[LEFT AMIGA] [<key>]@{UB}
    Shortcuts for gadgets.

  @{B}[RIGHT AMIGA] [<key>]@{UB}
    Shortcuts for menu.

  @{B}[HELP]@{UB}
    Opens window with amigaguide documentation.

@{fg highlight}@{B}Operations on records:@{fg text}@{UB}
  @{B}[Num 9]/[CURSOR LEFT]@{UB}
    Jumps to the previous record.

  @{B}[Num 3]/[CURSOR RIGHT]@{UB}
    Jumps to the next record.

  @{B}[Num 7]/[Shift] [CURSOR LEFT]@{UB}
    Jumps to the first record.

  @{B}[Num 1]/[Shift] [CURSOR RIGHT]@{UB}
    Jumps to the last record.

  @{B}[Num 5]@{UB}
    Jumps to specified record.

  @{B}[RIGHT Alt] [Num 9]/[CURSOR LEFT]@{UB}
    Jumps to the previous marked record.

  @{B}[RIGHT Alt] [Num 3]/[CURSOR RIGHT]@{UB}
    Jumps to the next marked record.

  @{B}[RIGHT Alt] [Num 7]/[CURSOR LEFT]@{UB}
    Jumps to the first marked record.

  @{B}[RIGHT Alt] [Num 1]/[CURSOR RIGHT]@{UB}
    Jumps to the last marked record.

  @{B}[LEFT Alt] [Num 9]/[CURSOR LEFT]@{UB}
    Jumps to the previous unmarked record.

  @{B}[LEFT Alt] [Num 3]/[CURSOR RIGHT]@{UB}
    Jumps to the next unmarked record.

  @{B}[LEFT Alt] [Num 7]/[CURSOR LEFT]@{UB}
    Jumps to the first unmarked record.

  @{B}[LEFT Alt] [Num 1]/[CURSOR RIGHT]@{UB}
    Jumps to the last unmarked record.


  @{B}[Num 0]/[Num +]@{UB}
    Inserts record.

  @{B}[Shift] [Num 0]/[Num +]@{UB}
    Adds requested number of records.

  @{B}[Ctrl] [Num 0]/[Num +]@{UB}
    Inserts records from selected file.


  @{B}[Num .]/[Num -]@{UB}
    Deletes current record.

  @{B}[PRAWY Alt] [Num .]/[Num -]@{UB}
    Deletes all marked records.

  @{B}[LEWY Alt] [Num .]/[Num -]@{UB}
    Deletes all unmarked records.

  @{B}[Ctrl] [Num .]/[Num -]@{UB}
    Deletes all records.

  @{B}[Shift] [Num .]/[Num -]@{UB}
    Deletes records from selected range.

@{fg highlight}@{B}Fields operations:@{fg text}@{UB}
  @{B}[TAB]@{UB}
    Jumps to the next field.

  @{B}[Shift] [TAB]@{UB}
    Jumps to the previous field.

  @{B}[<field shortcut>]/[Enter]/[SPACE]@{UB}
    Activates field.

  @{B}[Shift] [<field shortcut>]/[Enter]/[SPACE]@{UB}
    STRINGS            : Opens predefined values window.

  @{B}[LEFT Alt] [<field shortcut>]@{UB}
    Sets field as current without activation.

  @{B}[Alt] [Enter]/[SPACE]@{UB}
    Inserts to the field content of the field from previous record.

  @{B}[CURSOR DOWN]@{UB}
    STRINGS            : Inserts next value from predefined values
                         list.
    MULTILINE STRINGS  : Scrolls down.
    CYCLES             : Sets next value.

  @{B}[CURSOR UP]@{UB}
    STRINGS            : Inserts previous value from predefined values
                         list.
    MULTILINE STRINGS  : Scrolls up.
    CYCLES             : Sets previous value.

@{fg highlight}@{B}When field is active (cursor is in it) then:@{fg text}@{UB}
  @{B}[Enter]/[TAB]@{UB}
    Jumps to the next field.

  @{B}[Shift] [Enter]/[TAB]@{UB}
    Jumps to the previous field.

  @{B}[LEFT AMIGA] [Q]@{UB}
    Brings back last content of the field (UNDO).

  @{B}[LEFT AMIGA] [X]@{UB}
    Clears content of the field.

  @{B}[Shift] [CURSOR RIGHT]@{UB}
    Cursor jumps to the end of text in the field.

  @{B}[Shift] [CURSOR LEFT]@{UB}
    Cursor jumps to the beginning of text in the field.

  @{B}[Shift] [BACKSPACE]@{UB}
    Deletes all characters from cursor to the beginning of line.

  @{B}[Shift] [Del]@{UB}
    Deletes all characters from cursor to the end of line.



@{fg highlight}@{B}Mouse:@{fg text}@{UB}
  @{B}[<doubleclick close by the field>]@{UB}
    @{"Views" LINK BROWSING} by that field.

  @{B}[Shift] [<doubleclick close by the field>]@{UB}
    @{"Edits field" LINK DEFINITION}.

  @{B}[Alt] [<doubleclick close by the field>]@{UB}
    @{"Edits field attributes" LINK OPTIONS}.

  @{B}[Ctrl] [<doubleclick close by the field>]@{UB}
    @{"Edits label" LINK LABELS}.

  @{B}[Ctrl] [Shift] [<doubleclick close by the field>]@{UB}
    Hides field.

  @{B}[<right mouse button on field>]@{UB}
    Opens context menu.

  @{B}[Shift] [<right mouse button on field>]@{UB}
    Opens context menu for field content edition.

  @{B}[Alt] [<right mouse button on field>]@{UB}
    Sets field as current without activation.

  @{" Multiline fields " LINK MULTILINE}

@ENDNODE
///
/// Description - multiline fields
@NODE MULTILINE "Attendance of multiline fields"

@{fg highlight}@{B}@{U}Attendance of multiline fields@{fg text}@{UB}@{UU}

You can freely mark text to cut, copy or delete. When you press any
alfanumerical  key, marked text will be replaced by pressed character.
Pressing cursor keys moves cursor to the beginning or to the end of
marked text.

If you want to mark fragment of the text, set cursor in place where
you want to begin, and holding SHIFT key click mouse at the end of
marking text.

Another way to select text is doubleclick at the word which we want to
mark. If we doubleclick at space between two words, all spaces between
this two words will be marked.

@{fg highlight}@{B}Shortcuts:@{fg text}@{UB}
  @{B}[TAB]@{UB}
    Activates next field.

  @{B}[Shift] [TAB]@{UB}
    Activates previous field.

  @{B}[Shift] [CURSOR UP]@{UB}
    Moves cursor to the beginning of the current or (if cursor is
    currently at the beginning of current page) previous page.
    
  @{B}[Shift] [CURSOR DOWN]@{UB}
    Moves cursor to the end of current or (if cursor is currently at the
    end of current page) next page.

  @{B}[Ctrl]/[Shift] [CURSOR RIGHT]@{UB}
    Moves cursor to the end of current line.

  @{B}[Ctrl]/[Shift] [CURSOR LEFT]@{UB}
    Moves cursor to the beginning of current line.

  @{B}[Shift] [BACKSPACE]@{UB}
    Deletes all text from cursor to the beginning of line.

  @{B}[Shift] [Del]@{UB}
    Deletes all text from cursor to the end of line.

  @{B}[Ctrl] [CURSOR UP]@{UB}
    Moves cursor to the first line of text.

  @{B}[Ctrl] [CURSOR DOWN]@{UB}
    Moves cursor to the last line of text.

  @{B}[Alt] [CURSOR RIGHT]@{UB}
    Moves cursor to the beginning of the next word.

  @{B}[Alt] [CURSOR LEFT]@{UB}
    Moves cursor to the beginning of the previous word.

  @{B}[Alt] [CURSOR UP]@{UB}
    Moves cursor to the beginning of text.

  @{B}[Alt] [CURSOR DOWN]@{UB}
    Moves cursor to the end of text.

  @{B}[Alt] [BACKSPACE]@{UB}
    Deletes text from cursor to the beginning of word.

  @{B}[Alt] [Del]@{UB}
    Deletes text from cursor to the end of word.

  @{B}[Ctrl] [X]@{UB}
    Deletes whole line in which cursor is placed.

  @{B}[RIGHT AMIGA] [E]@{UB}
    Deletes all text from gadget.

  @{B}[RIGHT AMIGA] [V]@{UB}
    Pastes text from clipboart at currently cursor position.

  @{B}[RIGHT AMIGA] [A]@{UB}
    Marks all text.

@{fg highlight}@{B}When text is marked:@{fg text}@{UB}
  @{B}[BACKSPACE]@{UB}
    Deletes all marked text.

  @{B}[Del]@{UB}
    Deletes all marked text.

  @{B}[RIGHT AMIGA] [X]@{UB}
    Cuts marked text to the clipboard.

  @{B}[RIGHT AMIGA] [C]@{UB}
    Copys marked text to the clipboard.

  @{B}[RIGHT AMIGA] [V]@{UB}
    Replaces marked text by text which is in the clipboard.

  @{B}[<any alfanumerical key>]@{UB}
    Replaces marked text by pressed character.

@ENDNODE
///
/// Description - running
@NODE RUNNING "Running"

@{fg highlight}@{B}@{U}Running program@{fg text}@{UB}@{UU}

You can start XBaze from Workbench by doubleclicking on its icon, or
from the shell. You can specify @{"arguments (in shell) or tooltypes" LINK TOOLTYPES}.

@ENDNODE
///
/// Description - tooltypes
@NODE TOOLTYPES "Arguments and tooltypes"

@{fg highlight}@{B}@{U}Arguments and tooltypes@{fg text}@{UB}@{UU}

@{B}FILE@{UB}
  Name of the file which will be automatically loaded after program
  starts (only shell).

@{B}PUBSCREEN@{UB}
  Name of public screen on which XBaze will open main window. If
  program couldn't find specified public screen, main window will be
  opened at the Workbench screen.

@{B}FONT@{UB}
  Font which will be used by program, syntax:
  <font name/font size>

@{B}NOICONS@{UB}
  Disables saving icons for projects.

@{B}LOCALESORT@{UB}
  If this option is enabled, all strings will be compared through
  function in the system locale.library. If you sort databases in
  english or polish language you don't have to specify that option.

@{B}IGNSAVEDWINPOS@{UB}
  Program will ignore saved window positions.

@{B}DATADIR@{UB}
  Directory from which files will be placed in "*" menu. This makes
  easier opening often used projects.

@{B}VIEWFILE@{UB}
  File with the view (only shell). You must specify FILE parameter.
  
@{B}STARTICONIFIED@{UB}
  Program starts as iconified.

@{B}PROGRESSINDICATOR@{UB}
  Enables progress indicator.

@{B}USESCREENFONTINREQS@{UB}
  Selected font will be used only in main window.

@{B}STATPRECISION@{UB}
  Attribute for this keyword is number of digits after comma used
  within statistics option.

@{B}LEFTTOOLBAR@{UB}
  Toolbar will be placed on left window border. If this tooltype will
  be disabled, toolbar will be placed on bottom window border.

@{B}NOSIZEABLE@{UB}
  Main window won't have resizing gadget.

@{B}NONAVBUTTS@{UB}
  Gadgets to navigate through recrods won't be placed at the botttom
  window border.

@{B}3DLOOK@{UB}
  Navigation gadgets will have 3D-look.

You can also change settings mentioned above from main program using
menu @{"Project|Settings..." LINK PRGSETS}.

@ENDNODE
///
/// Field - definitions
@NODE DEFINITION "Field definition window"

@{fg highlight}@{B}@{U}Field definition window@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Calling:@{fg text}@{UB}
  Main window:
    @{B}menu:@{UB}      Project|New...
               Field|Properties|Definition...
    @{B}popupmenu:@{UB} Properties|Definition...
    @{B}shortcut:@{UB}  [Shift] [<doubleclick close by the field>]

  @{"Design view:" LINK VIEW}
    @{B}menu:@{UB}      Field|Definition...
    @{B}popupmenu:@{UB} Definition...
    @{B}shortcut:@{UB}     [<doubleclick on the field>]

@{fg highlight}@{B}Description:@{fg text}@{UB}
  Basic elements of the database are fields and record (containig
  fields). In this window you can edit fields, it means you can
  create, modify or delete fields.
  
@{fg highlight}@{B}Attentions:@{fg text}@{UB}
  In project must be specified one or more visible fields with set
  "Saveable" flag.

@{fg highlight}@{B}Shortcuts:@{fg text}@{UB}
  @{B}[RIGHT AMIGA] [Del]@{UB}
    Deletes field.

  @{B}[Alt] [CURSOR UP]/[CURSOR DOWN]@{UB}
    Moves field one position up/down.

  @{B}[CURSOR UP]/[CURSOR DOWN]@{UB}
    Moves cursor one position up/dowm.

@{fg highlight}@{B}Gadgets:@{fg text}@{UB}
  @{B}Field@{UB}
    In this gadged you can see list of all fields. You can select any
    field from this list to modify it, for example: change name,
    delete field or change attributes. Gadget below this list is used
    for typing name for selected field. Field name isn't unique name,
    that means that you can specify many fields with the same name.
    But using fields with the same name could comlicate writing ARexx
    scripts. Gadget on the left side of the list is used to change
    succession of the fields.
    
  @{B}Add@{UB}
    Adds new field to the list.

  @{B}Delete@{UB}
    Deletes field from the list.

  @{B}Type@{UB}
    Selects @{"field type" LINK TYPES}.

  @{B}Label...@{UB}
    Sets @{"field label" LINK LABELS}.

  @{B}Attributes...@{UB}
    for field type:
      @{" String      " LINK STRINGATRR}
      @{" Amount      " LINK STRINGATRR}
      @{" Boolean     " LINK BOOLEANATRR}
      @{" Cycle       " LINK CYCLEATRR}
      @{" Button      " LINK BUTTONATRR}
      @{" Text        " LINK TEXTATRR}

  @{B}ARexx...@{UB}
    Sets @{"ARexx program" LINK PRGRX}

  @{B}Hidden@{UB}
    When you set this flag, this field will be invisible, but you
    still be able to sort and search by this field.

  @{B}Saveable@{UB}
    Here you can specify if content of this field will be saved in
    specified record or not. Disabling this flag is usefull with ARexx
    scripts in which is important that content of the field does not
    change with change of the record.

  @{B}New line@{UB}
    Places field in new line.

@ENDNODE
///
/// Field - types
@NODE TYPES "Fields types"

@{fg highlight}@{B}@{U}Fields types@{fg text}@{UB}@{UU}

@{B}String@{UB}
  You can write alfanumerical strings to this type of field. You can
  create multiline fields, and also create mostly used values for this
  field (predefined values) for easy putting it in by simply selecting
  it form list which is called by button by right side of the field.
  You can specify starting content of field, which will be set when
  you add new record and you can specify default content which will be
  set, when user leaves this field empty. You can also use variables,
  thanks to this it is possible to put to the field: current date,
  time, etc.

@{B}Amount@{UB}
  Like above, but this field will be treated as amount during sorting.

@{B}Boolean@{UB}
  Realized as CHECKBOX gadget, field could be at two states. You can
  specify different text to the FALSE and TRUE states. If you not
  specify this, program will use default text (TRUE, FALSE). You can
  specify starting value.

@{B}Cycle@{UB}
  Realized as cycle gadget. You can select one position from the list.
  You can specify starting value.

@{B}Button@{UB}
  This is simple button, by which you can run another program, show
  picture or play music using external program.

@{B}Text@{UB}
  Read only field. Thanks to variables system you can show in this
  field: time of record creation, project creation or many other
  things. You can change text in this field only by ARexx port.
  
@ENDNODE
///
/// Field - labels
@NODE LABELS "Field label"

@{fg highlight}@{B}@{U}Field label@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Calling:@{fg text}@{UB}
  @{"Field definition window:" LINK DEFINITION}
    @{B}gadget:@{UB}    Label...

  Main window:
    @{B}menu:@{UB}      Field|Properties|Label...
    @{B}popupmenu:@{UB} Properties|Label...
    @{B}shortcut:@{UB}  [Ctrl] [<doubleclick close by the field>]

  @{"Design view window:" LINK VIEW}
    @{B}menu:@{UB}      Field|Label...
    @{B}popupmenu:@{UB} Label...
    @{B}shortcut:@{UB}  [Ctrl] [<doubleclick on the field>]

@{fg highlight}@{B}Description:@{fg text}@{UB}
  Here you can specify field label and label attributes.
  Field label could be: Highlabel, Label or No label. You can specify
  that using cycle gadget. In field below it you can specify name of
  the label. Default name for label is name of the field.
      Label     - sets colour of label to black
      Highlabel - sets colour of label to white
      No label  - hides label

@{fg highlight}@{B}Gadgets:@{fg text}@{UB}
  @{B}Bold@{UB}
    Label will be written with bold style.

  @{B}Italic@{UB}
    Label will be written with italic style.

  @{B}Underline@{UB}
    Label will be underlined.

@ENDNODE
///
/// Field - attributes
@node OPTIONS "Fields attributes

@{fg highlight}@{B}@{U}Fields attributes@{fg text}@{UB}@{UU}

  @{fg highlight}@{B}Attributes for field type:@{UB}@{fg text}
      @{" String      " LINK STRINGATRR}
      @{" Amount      " LINK STRINGATRR}
      @{" Boolean     " LINK BOOLEANATRR}
      @{" Cycle       " LINK CYCLEATRR}
      @{" Button      " LINK BUTTONATRR}
      @{" Text        " LINK TEXTATRR}

@endnode
///
/// Attributes - STRING and AMOUNT
@NODE STRINGATRR "Attributes for string and amount fields"

@{fg highlight}@{B}@{U}Attributes for string and amount fields@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Calling:@{fg text}@{UB}
  @{"Field definition window:" LINK DEFINITION}
    @{B}gadget:@{UB}    Attributes...

  Main window:
    @{B}menu:@{UB}      Field|Properties|Attributes...
    @{B}popupmenu:@{UB} Properties|Attributes...
    @{B}shortcut:@{UB}  [Alt] [<doubleclick close by the field>]

  @{"Design window:" LINK VIEW}
    @{B}menu:@{UB}      Field|Attributes...
    @{B}popupmenu:@{UB} Attributes...
    @{B}shortcut:@{UB}  [Alt] [<doubleclick on the field>]

@{fg highlight}@{B}Description:@{fg text}@{UB}
  Edits additional field features.

@{fg highlight}@{B}Gadgets:@{fg text}@{UB}
  @{B}Alignment@{UB}
    Sets text alignment in field.

  @{B}Max characters@{UB}
    Maximum number of characters which user will be able to put to
    this field.

  @{B}Size@{UB}
    Width of field counted in characters.

  @{B}Number of lines@{UB}
    Number of lines.

  @{B}Shortcut@{UB}
    Key character which will activate given field.

  @{B}Initial value@{UB}
    This value will be inserted automatically by program into all new
    records. @{"Variables" LINK VAR} can also be used.

  @{B}Default value@{UB}
    This is default value which will be placed into field when user
    leaves this field empty. @{"Variables" LINK VAR} can also be used.

  @{B}Inject characters@{UB}
    Characters specified in this gadged will be injected by this field.

  @{B}Reject characters@{UB}
    Characters specified in this gadged will be rejected by this field.

  @{B}Predefined values...@{UB}
    @{"Edits predefined values" LINK PREDEF}

  @{B}Replace mode@{UB}
    Enables replace mode.

  @{B}URL address@{UB}
    Enables of this gadget causes that to this field will be added
    gadget, which will call web browser with value of this field as
    URL address.

@ENDNODE
///
/// Attributes - predefined values
@NODE PREDEF "Predefined values"

@{fg highlight}@{B}@{U}Predefined values@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Calling:@{fg text}@{UB}
  @{"Field attributes window:" LINK STRINGATRR}
    gadget: Predefined values...

@{fg highlight}@{B}Description:@{fg text}@{UB}
  Here you can make list of values which you often insert into this
  field. These values will be available when you press "«" gadget on
  the right side of the field.
  
@{fg highlight}@{B}Shortcuts:@{fg text}@{UB}
  @{B}[RIGHT AMIGA] [Del]@{UB}
    Removes element

  @{B}[Alt] [CURSOR UP]/[CURSOR DOWN]@{UB}
    Moves element one position up/down

  @{B}[CURSOR UP]/[CURSOR DOWN]@{UB}
    Moves cursor one position up/down

@{fg highlight}@{B}Gadgets:@{fg text}@{UB}
  @{B}Value@{UB}
    In this gadget you can see all predefined values as list. You can
    select any of this values to delete or change name. You can edit
    name in gadget below list. Gadget on the right side of the list is
    used to change succession of elements.

  @{B}Add@{UB}
    Adds new element to list.

  @{B}Delete@{UB}
    Removes selected element.

@ENDNODE
///
/// Attributes - CYCLE
@NODE CYCLEATRR "Attributes for cycle field"

@{fg highlight}@{B}@{U}Attributes for cycle field@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Calling:@{fg text}@{UB}
  @{"New project window:" LINK DEFINITION}
    @{B}gadget:@{UB}    Attributes...

  Main window:
    @{B}menu:@{UB}      Field|Properties|Attributes...
    @{B}popupmenu:@{UB} Properties|Attributes...
    @{B}shortcut:@{UB}  [Alt] [<doubleclick close by the field>]

  @{"Design window:" LINK VIEW}
    @{B}menu:@{UB}      Field|Attributes...
    @{B}popupmenu:@{UB} Attribute...
    @{B}shortcut:@{UB}  [Alt] [<doubleclick on the field>]

@{fg highlight}@{B}Description:@{fg text}@{UB}
  In this window you can specify field attributes and make list from
  which you can select values in cycle field.

@{fg highlight}@{B}Shortcuts:@{fg text}@{UB}
  @{B}[RIGHT AMIGA] [Del]@{UB}
    Removes element

  @{B}[Alt] [CURSOR UP]/[CURSOR DOWN]@{UB}
    Moves element one position up/down

  @{B}[CURSOR UP]/[CURSOR DOWN]@{UB}
    Moves cursor one position up/down

@{fg highlight}@{B}Gadgets:@{fg text}@{UB}
  @{B}Value@{UB}
    In this gadget as list you can saw all predefined values. You can
    select any of this values to delete or change name. You can edit
    name in gadget below list. Gadget on the right side of the list is
    used to change succession of elements.

  @{B}Add@{UB}
    Adds new element to list.

  @{B}Delete@{UB}
    Removes selected element.

  @{B}Size@{UB}
    Width of field in characters.

  @{B}Shortcut@{UB}
    Shortcut key which will activate this field.

@ENDNODE
///
/// Attributes - BOOLEAN
@NODE BOOLEANATRR "Attributes for boolean field"

@{fg highlight}@{B}@{U}Attributes for boolean field@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Calling:@{fg text}@{UB}
  @{"New project window:" LINK DEFINITION}
    @{B}gadget:@{UB}    Attributes...

  Main window:
    @{B}menu:@{UB}      Field|Properties|Attributes...
    @{B}popupmenu:@{UB} Properties|Attributes...
    @{B}shortcut:@{UB}  [Alt] [<doubleclick close by the field>]

  @{"Design window:" LINK VIEW}
    @{B}menu:@{UB}      Field|Attributes...
    @{B}popupmenu:@{UB} Attributes...
    @{B}shortcut:@{UB}  [Alt] [<doubleclick on the field>]

@{fg highlight}@{B}Description:@{fg text}@{UB}
