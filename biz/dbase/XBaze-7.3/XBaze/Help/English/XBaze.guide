@{fg highlight}@{B}Gadgets:@{fg text}@{UB}
  @{B}True@{UB}
    Text for "True" state, that means when field is marked.

  @{B}False@{UB}
    Text for "False" state, that means when field is unmarked.

  @{B}Shortcut@{UB}
    Shortcut key which will activate this field.

  @{B}Initial value@{UB}
    Value for this field which will be set in new record.

@ENDNODE
///
/// Attributes - BUTTON
@NODE BUTTONATRR "Attributes for button field"

@{fg highlight}@{B}@{U}Attributes for button field@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Calling:@{fg text}@{UB}
  @{"New project window:" LINK DEFINITION}
    @{B}gadget@{UB}:    Attributes...

  Main window:
    @{B}menu:@{UB}      Field|Properties|Attributes...
    @{B}popupmenu:@{UB} Properties|Attributes...
    @{B}shortcut:@{UB}  [Alt] [<doubleclick close by the field>]

  @{"Design window:" LINK VIEW}
    @{B}menu:@{UB}      Field|Attributes...
    @{B}popupmenu:@{UB} Attributes...
    @{B}shortcut:@{UB}  [Alt] [<doubleclick on the field>]

@{fg highlight}@{B}Description:@{fg text}@{UB}
  This field doesn't store any values. It used only to launch other programs.

@{fg highlight}@{B}Gadgets:@{fg text}@{UB}
  @{B}Command@{UB}
    Name of program which will be launched. You can use @{"variables" LINK VAR}, so
    you will be able to set argumets for program from any field.

  @{B}Console@{UB}
    Console, where all return values from program will be shown.

  @{B}Size@{UB}
    Width of field in characters.

  @{B}Shortcut@{UB}
    Shortcut key which will activate this field.

@ENDNODE
///
/// Attributes - TEXT
@NODE TEXTATRR "Attributes for text field"

@{fg highlight}@{B}@{U}Attributes for text field@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Calling:@{fg text}@{UB}
  @{"New project window:" LINK DEFINITION}
    @{B}gadget@{UB}:    Attributes...

  Main window:
    @{B}menu:@{UB}      Field|Properties|Attributes...
    @{B}popupmenu:@{UB} Properties|Attributes...
