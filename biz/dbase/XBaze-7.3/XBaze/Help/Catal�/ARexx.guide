@NODE GETFIELD "GETFIELD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}GETFIELD <nom del camp>@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Retorna el contingut del camp.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    Retorna  una cadena  pels camps cicle  (no el  número de posició  de la
    llista del cicle), i l'estat pels camps booleans.
    Si no especifiqueu el nom del camp (sensible a les majúscules), l'ordre
    retorna el valor del camp actual.

  @{B}RC:@{UB}
    Retorna -1 quan el camp especificat no existeix.

@ENDNODE


@NODE TOGLLEMARKS "TOGLLEMARKS"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}TOGLLEMARKS@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Commuta els assenyalaments dels registres.  Si un registre no es troba
    assenyalat hi quedarŕ i viceversa.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    -
  @{B}RC:@{UB}
    -

@ENDNODE


@NODE TRUEGETFIELD "TRUEGETFIELD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}TRUEGETFIELD <nom del camp>@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Retorna el contingut del camp.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    Com a @{"GETFIELD" LINK GETFIELD} amb la diferčncia que retorna el número
    de posició en els camps cicle, i booleŕ pels camps booleans.

  @{B}RC:@{UB}
    Retorna -1 quan el camp especificat no existeix.

@ENDNODE


@NODE GETFIELDTYPE "GETFIELDTYPE"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}GETFIELDTYPE <nom del camp>@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Retorna el text que descriu el tipus de camp.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    Depen  del tipus de camp  ("Cadena",  "Quantitat",  "Booleŕ",  "Cicle",
    "Botó", "Text").
    Si no especifiqueu el nom del camp (sensible a les majúscules), l'ordre
    retorna el tipus del camp actual.
  @{B}RC:@{UB}
    -

@ENDNODE


@NODE SEARCHONLYMARKED "SEARCHONLYMARKED"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}SEARCHONLYMARKED <valor>@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Quan entreu "1", el programa cerca només els registres assenyalats.
    Amb "0" el programa cerca tots els registres.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    Si no especifiqueu algun valor, el programa retorna el valor actual
    d'aquesta opció.
  @{B}RC:@{UB}
    -

@ENDNODE


@NODE SETFIELD "SETFIELD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}SETFIELD <nom del camp>[,<valor>]@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Insereix el valor especificat en el camp especificat.  Pels camps booleans
    només seran acceptats valors numčric (=0 - fals, <>0 - vertader). Pel camp
    cicle s'ha d'especificar el número de posició de l'ítem a la llista.
    'valor' és un parŕmetre opcional.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    -
  @{B}RC:@{UB}
    Retorna -1, quan el camp especificat no existeix.

@ENDNODE


@NODE SETSEARCHOPERATOR "SETSEARCHOPERATOR"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}SETSEARCHOPERATOR <valor>@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Defineix l'operador de comparació per la cadena cercada en el contingut
    del camp actual.  L'operador és  definit pel  camp  actual.  Els valors
    entrats es corresponen amb el botó cicle de la finestra de recerca.


@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    -
  @{B}RC:@{UB}
    Si hi ha algun error la funció retorna -1.

@ENDNODE


@NODE SETSEARCHSTRING "SETSEARCHSTRING"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}SETSEARCHSTRING <patró de recerca>@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Defineix el patró de recerca pel camp actual.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    -
  @{B}RC:@{UB}
    Si hi ha algun error la funció Retorna -1.

@ENDNODE


@NODE CURRENTFIELD "CURRENTFIELD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}CURRENTFIELD <nom del camp>@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Defineix el camp especificat com a camp actiu (sensible a les majúscules).
    No pot ser un camp de  'TEXT'  o no tenir el parŕmetre  'Desable' activat.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    Si no s'especifica argument,  aquesta ordre retorna el nom del camp actiu.
  @{B}RC:@{UB}
    Retorna -1, quan el camp especificat no existeix.

@ENDNODE


@NODE FINDNEXTRECORD "FINDNEXTRECORD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}FINDNEXTRECORD@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    El programa inicia la recerca  des del registre actual  fins al darrer.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    Número del registres trobat. Si la funció no troba registres retorna 0.
  @{B}RC:@{UB}
    Quan no hi ha especificat un patró de recerca pel camp, retorna -1.

@ENDNODE


@NODE FINDPREVREORD "FINDPREVRECORD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}FINDPREVRECORD@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    El programa inicia  la recerca  des del registre actual  cap al primer.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    Número de registres trobats. Si la funció no troba registres retorna 0.
  @{B}RC:@{UB}
    Quan no hi ha especificat un patró de recerca pel camp, retorna -1.

@ENDNODE


@NODE FINDRECORD "FINDRECORD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}FINDRECORD@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    El programa inicia  la recerca  des del  registre actual  fins al darrer.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    Número dels registres trobats. Si la funció no troba registres retorna 0.
  @{B}RC:@{UB}
    Quan no hi ha especificat un patró de recerca pel camp, retorna -1.

@ENDNODE


@NODE FIRSTFIELD "FIRSTFIELD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}FIRSTFIELD@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Activa el primer camp.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    El nom del camp.
  @{B}RC:@{UB}
    -

@ENDNODE


@NODE LASTFIELD "LASTFIELD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}LASTFIELD@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Activa el darrer camp.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    El nom del camp.
  @{B}RC:@{UB}
    -

@ENDNODE


@NODE NEXTFIELD "NEXTFIELD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}NEXTFIELD@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Activa el camp següent.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    El nom del camp.
  @{B}RC:@{UB}
    Retorna -1, quan el camp no existeix.

@ENDNODE


@NODE PREVFIELD "PREVFIELD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}PREVFIELD@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Activa el camp anterior.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    El nom del camp.
  @{B}RC:@{UB}
    Retorna -1, quan previous camp no existeix.

@ENDNODE


@NODE RETRYINPUT "RETRYINPUT"

@{fg highlight}@{B}@{fg text}Sintaxi:@{fg text}@{UB}
  @{B}RETRYINPUT@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Activa el camp que ha cridat el guió ARexx.  Si el programa ha estat
    cridat per haver canviat el contingut  del camp,  el camp següent no
    serŕ activat.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    -
  @{B}RC:@{UB}
    -

@ENDNODE


@NODE ACTIVATEFIELD "ACTIVATEFIELD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}ACTIVATEFIELD <nom del camp>@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Activa el botó del camp especificat per <nom del camp>.
    Es pot usar només en els camps  "Cadena" i "Quantitat".
    Si no s'especifica un <nom de camp>, s'activarŕ el botó
    del camp actual.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    -
  @{B}RC:@{UB}
    Retorna -1,  quan el camp especificat  no existeix o el
    tipus de camp és incorrecte.

@ENDNODE


@NODE CURRENTRECORD "CURRENTRECORD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}CURRENTRECORD <número de registre>@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Salta al registre especificat.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    Si no s'especifica argument,  la funció retorna el
    número del registre actual.
  @{B}RC:@{UB}
    Quan el registre especificat estŕ fora del rang la
    funció retorna -1.

@ENDNODE


@NODE FIRSTRECORD "FIRSTRECORD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}FIRSTRECORD@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Salta al primer registre.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    El número de registre
  @{B}RC:@{UB}
    -

@ENDNODE


@NODE LASTRECORD "LASTRECORD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}LASTRECORD@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Salta al darrer registre.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    El número de registre.
  @{B}RC:@{UB}
    -

@ENDNODE


@NODE NEXTRECORD "NEXTRECORD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}NEXTRECORD@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Salta al registre següent.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    El número de registre.
  @{B}RC:@{UB}
    Retorna -1 quan el registre no existeix.

@ENDNODE


@NODE PREVRECORD "PREVRECORD"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
  @{B}PREVRECORD@{UB}

@{fg highlight}@{B}Descripció:@{fg text}@{UB}
    Salta al registre anterior.

@{fg highlight}@{B}Retorna:@{fg text}@{UB}
  @{B}RESULTAT:@{UB}
    El número de registre.
  @{B}RC:@{UB}
    Retorna -1 quan el registre no existeix.

@ENDNODE


@NODE DEL "DEL"

@{fg highlight}@{B}Sintaxi:@{fg text}@{UB}
