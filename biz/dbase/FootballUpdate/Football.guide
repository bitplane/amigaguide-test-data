    A variety of options to choose from :

  @{" Create League     " LINK createl}
  @{" Open League       " LINK openl}
  @{" Documentation     " LINK docs}

  @{" Display League    " LINK displeag}
  @{" League Results    " LINK leagres}
  @{" Team Results      " LINK teamres}
  @{" Team Statistics   " LINK teamsta}
  @{" Enter Scores      " LINK escores}
  @{" League Information" LINK linfo}

  More Options ------------->>>@{" Update League Settings " LINK updset}
                               @{" Rename League Datafile " LINK renldf}
