           D0                        A0

           @{"time_t" Link "sys/commtime.h/Main" 12} MsqlTimeToUnixTime(char *);

@{b}   FUNCTION@{ub}
           MsqlTimeToUnixTime( ) converts an mSQL time value to a standard
           UNIX time value.  The mSQL time value must be a character string
           in the 24 hour format of "HH:MM:SS" and the returned value will be
           the number of seconds since @{"1" Link "setjmp.h/Main" 14} Jan 1970 (the normal UNIX format).

