@node "15020" "Präpositionen die der Zeitbezeichnung dienen"

 @{b}Präpositionen die der Zeitbezeichnung dienen.@{ub}

 sieh auch @{" Präpositionen die der Ortbezeichnung dienen " link "15040" 0}
           @{" Andere Präpositionen                        " link "15060" 0}

 @{b}after@{ub}   nach, z.B. after midnight - nach der Mitternacht
 @{b}at@{ub}      um, np. at five o'clock - um fünf Uhr, auch: at noon - zu
                  Mittag, at midnight - um Mitternacht
 @{b}before@{ub}  vor, np. before dinner - vor dem Mittagessen
 @{b}between@{ub} zwischen, np. between eight and nine - zwischen acht und
                  neun Uhr
 @{b}by@{ub}      bis, bis zum, z.B. by 7th July - bis zum 7 Juli
 @{b}during@{ub}  während, z.B. during the war - während des Krieges
 @{b}for@{ub}     durch, hindurch, z.B. for two weeks - zwei Wochen hindurch
 @{b}from@{ub}    ab, z.B. from Sunday - ab Sonntag
 @{b}in@{ub}      in, z.B. in June - im Juni, in summer - im Sommer,
                  in 1970 - in 1970, in the 20th century - im 20 Jahrhundert,
                  auch: in the evening - am Abend, in the morning - am Morgen,
                  in two minutes - in zwei Minuten
 @{b}on@{ub}      an, z.B. on Sunday - am Sonntag, on January 15th - am
                  15 Januar
 @{b}since@{ub}   seit, z.B. since 1980 - seit 1980
 @{b}till@{ub}    bis z.B. till 4 o'clock - bis 4 Uhr
 @{b}to@{ub}      zu, insbesondere in Redewendung from...to - von...bis, z.B.
                  from Monday to Wednesday - von Montag bis Mittwoch
 @{b}until@{ub}   bis, z.B. until tomorrow - bis morgen

@endnode

@node "15040" "Präpositionen die der Ortbezeichnung dienen"

 @{b}Präpositionen die der Ortbezeichnung dienen.@{ub}

sieh auch @{" Präpositionen die der Zeitbezeichnung dienen " link "15020" 0}
          @{" Andere Präpositionen                         " link "15060" 0}

 @{b}above@{ub}       über, z.B. above the clouds - über den Wolken
 @{b}across@{ub}      durch,über, z.B. across the street - über die Straße
 @{b}against@{ub}     gegen, z.B. against the wall - gegen die Wand
 @{b}along@{ub}       entlang, z.B. along the wall - Die Wand entlang
 @{b}among@{ub}       zwischen (betrifft mehr als zwei Gegenstände oder Personen),
             z.B. among the hills - zwischen den Hügeln
 @{b}at@{ub}          auf, bei, in, zu,
             z.B. at home - zu Hause, at church - in der Kirche,
             at work - in der Arbeit, at the bus-stop - an der Bushaltestelle,
             at the door - bei der Tür, at school - in der Schule,
             at the cinema - im Kino, at the bank - im Bank,
             at her sister's - bei ihrer Schwester,
             at the grocer's - im Lebensmittelgeschäft
 @{b}behind@{ub}      hinter, z.B. behind the door - hinter der Tür
 @{b}below@{ub}       unter, z.B. below the window - unter dem Fenster
 @{b}beside@{ub}      neben, z.B. beside the house - neben dem Haus
 @{b}between@{ub}     zwischen (betrifft zwei Gegenstände oder Personen),
             z.B. between you and me - zwischen mir und dir
 @{b}beyond@{ub}      außen, hinter z.B. beyond the horizon - hinter dem Horizont
 @{b}by@{ub}          bei, neben, z.B. by the window - neben dem Fenster
 @{b}down@{ub}        hinunter, runter z.B. down the river - den Fluß
             hinunter, aber: down the street - die Straße entlang
 @{b}from@{ub}        aus, von, z.B. from London - aus London
 @{b}in@{ub}          in, z.B. in London - in London, in England - in England
             aber: in the sky - am Himmel
 @{b}in front of@{ub} vor, England in front of the house - vor dem Haus
 @{b}inside@{ub}      in, z.B. inside the box - in dem Kästchen
 @{b}into@{ub}        hinein, z.B. into the house - das Haus hinein
 @{b}near@{ub}        nah, in der Nähe, z.B. near the railway station - in der
             Nähe von dem Bahnhof
 @{b}on@{ub}          auf, z.B. on the table - auf dem Tisch
 @{b}onto@{ub}        hinauf
 @{b}out of@{ub}      hinaus, aus, z.B. out of prison - aus dem Gefängnis
 @{b}outside@{ub}     Außen, z.B. outside the building - außen dem Gebäude
 @{b}over@{ub}        über, z.B. over his head - über seinem Kopf
 @{b}round@{ub}       rund um, z.B. round the table - rund um den Tisch
 @{b}through@{ub}     durch, z.B. through the window - durchs Fenster
 @{b}to@{ub}          nach, z.B. to Warsaw - nach Warszawa
 @{b}towards@{ub}     in der Richtung von z.B. towards him - in seiner Richtung
 @{b}under@{ub}       unter, z.B. under the bed - unter dem Bett
 @{b}up@{ub}          hinauf, hinab z.B. up the stairs - die Treppe hinauf
 @{b}within@{ub}      innen

@endnode

@node "15060" "Andere Präpositionen"

 @{b}Andere Präpositionen.@{ub}

sieh auch @{" Präpositionen die der Zeitbezeichnung dienen " link "15020" 0}
          @{" Präpositionen die der Ortbezeichnung dienen  " link "15040" 0}

 @{b}against@{ub}  gegen, zuwider, trotz  z.B. against his opinion - trotz seiner Meinung
 @{b}besides@{ub}  außerdem
 @{b}by @{ub}      mit, durch z.B. by bus - mit dem Bus, by radio - durch Radio
 @{b}except@{ub}   außer
 @{b}in w, @{ub}   in, mit, z.B. in a hurry - in einer Eile, in ink - mit Tinte
