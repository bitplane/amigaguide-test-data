@node FEATURE_DESC "Some nice blurb!"

@{b}Features@{ub}

 @{b}>!<@{ub} Alter all major Archie features via click interface,

 @{b}>!<@{ub} Status window,

 @{b}>!<@{ub} Operation via mouse or hotkeys,

