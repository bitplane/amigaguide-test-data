@Node "MiamiClosePF" "RxLibnet Functions - MiamiClosePF"

  @{b}MiamiClosePF@{ub} - closes a packet filter

  @{b}Synopsis@{ub}
    call MiamiClosePF(pfID)
    <pfID/N>

  @{b}Function@{ub}
    Closes a packet filter created with CreatPF .

  @{b}Inputs@{ub}
    pfID - the packet filter ID

  @{b}Result@{ub}
    none

  @{b}Note@{ub}
    This function works only if Miami is running.

  @{b}See@{ub}
    @{"MiamiCreatePF" LINK "MiamiCreatePF"} @{"MiamiPFNext" LINK "MiamiPFNext"}

@EndNode

@Node "MiamiCreatePF" "RxLibnet Functions - MiamiCreatePF"

  @{b}MiamiCreatePF@{ub} - creates a packet filter

  @{b}Synopsis@{ub}
    pfID =  MiamiCreatePF(dev,signal,maxPks)
    <dev>,<signal/N>,[maxPks/N]

  @{b}Function@{ub}
    Creates a packet filter and returns its id .
    A packet filter will receive every in-out coming packet on
    the interface "dev" .

    "signal" is a rmh.library/AllocSignal allocated signal, that
    will be set any time a packet is received .

    maxPks is the max number of packets to store; it must be an
    integer greater than 1 .

  @{b}Inputs@{ub}
    dev - an interface name
    signal - the signal to use
    maPks - max number of packets to store

  @{b}Result@{ub}
    pfID - an integer:
                o -1 error
                o the ID of the filter otherwise

  @{b}Example@{ub}
    pf.rexx

  @{b}Note@{ub}
    This function works only if Miami is running.

  @{b}See@{ub}
    @{"MiamiClosePF" LINK "MiamiClosePF"} @{"MiamiPFNext" LINK "MiamiPFNext"}

@EndNode

@Node "MiamiDisallowDns" "RxLibnet Functions - MiamiDisallowDns"

  @{b}MiamiDisallowDns@{ub} - controls extern dns-lookup

  @{b}Synopsis@{ub}
    call MiamiDisallowDns(1|0)
    [status/N]

  @{b}Function@{ub}
    Controls extern DNS lookup.
    If status is 0 extern dns-lookup is disabled.
    If status is 1 extern dns-lookup is enabled.
    Default value for status is 0.

  @{b}Inputs@{ub}
    status - the status

  @{b}Result@{ub}
    none

  @{b}Note@{ub}
    This function works only if Miami is running.

@EndNode

@Node "MiamiGetPid" "RxLibnet Functions - MiamiGetPid"

  @{b}MiamiGetPid@{ub} - returns Miami's internal process descriptor

  @{b}Synopsis@{ub}
    pid = MiamiGetPid()
    -

  @{b}Function@{ub}
    Returns Miami's internal process descriptor as packed chars.
    This value is needed when you want to manipulates routes
    directly (see ip2if.rexx).

    If you need just a Process ID (e.g. like in icmp echo packets)
    use pragma("ID") .

  @{b}Inputs@{ub}
    none

  @{b}Result@{ub}
    pif - the ID

  @{b}Note@{ub}
    This function works only if Miami is running.

@EndNode

@Node "MiamiIFIndexToName" "RxLibnet Functions - MiamiIFIndexToName"

  @{b}MiamiIFIndexToName@{ub} - returns an interface ID from an interface name

  @{b}Synopsis@{ub}
    ifname = MiamiIFIndexToName(index)
    <index/N>

  @{b}Function@{ub}
    Returns an interface name from an interface index.

  @{b}Inputs@{ub}
    index - an interface index

  @{b}Result@{ub}
    ifname - an interface name or an empty string if index
             is not valid
  @{b}Note@{ub}
    This function works only if Miami is running.

@EndNode

@Node "MiamiIFNameToIndex" "RxLibnet Functions - MiamiIFNameToIndex"

  @{b}MiamiIFNameToIndex@{ub} - returns an interface name from an interface ID

  @{b}Synopsis@{ub}
    ifindex = MiamiIFNameToIndex(name)
    <name>

  @{b}Function@{ub}
    Returns an interface index from an interface name .

  @{b}Inputs@{ub}
