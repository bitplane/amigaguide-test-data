@EndNode

@Node "MiamiPCapCompile" "RxLibnet Functions - MiamiPCapCompile"

  @{b}MiamiPCapCompile@{ub} - compiles a pcap expression

  @{b}Synopsis@{ub}
    filter = MiamiPCapCompile(expr,interface,prom)
    <expr>,[interface],[prom/]

  @{b}Function@{ub}
    Compiles the pcap expression for the specified interface,
    or the "suitable" one if any, with promiscuous set if
    specified.

    Returns a string that can be used with MiamiPCapMatch() or Null()
    for failure; the reason of the failure can be found in "PACAPERR" .
    The filter can be freed with DROP .

  @{b}Inputs@{ub}
    expr - the pcap expression
    interface - the interface to compile expr for
    prom - promiscuous flag

  @{b}Result@{ub}
    filter - the compiled expression or null() for failure

  @{b}Note@{ub}
    This function works only if Miami is running.

  @{b}See@{ub}
    @{"MiamiPCapMatch" LINK "MiamiPCapMatch"}

@EndNode

@Node "MiamiPCapMatch" "RxLibnet Functions - MiamiPCapMatch"

  @{b}MiamiPCapMatch@{ub} - matches a compiled pcap expression on a packet

  @{b}Synopsis@{ub}
    res = MiamiPCapMatch(filter,packet)
    <filter>,<packet>

  @{b}Function@{ub}
    Matches a filter created with MiamiPCapCompile() with a
    packet returned by MiamiPFNext() (or what else).

  Input
    filter - a compiled pcap expression
    packet - the packet

  @{b}Result@{ub}
    res - an ARexx boolean

  @{b}Note@{ub}
    This function works only if Miami is running.

  @{b}See@{ub}
    @{"MiamiPCapCompile" LINK "MiamiPCapCompile"}

@EndNode

@Node "MiamiSetSocksConn" "RxLibnet Functions - MiamiSetSocksConn"

  @{b}MiamiSetSocksConn@{ub} - set the dest addr for the next bind

  @{b}Synopsis@{ub}
    res=MiamiSetSocksConn(remote)
    <remote/V>

  @{b}Function@{ub}
    Sets the destination address for the next SOCKS bind() request.

  @{b}Inputs@{ub}
    remote - an ARexx stem name set as a sockaddr_in

  @{b}Result@{ub}
    res - an ARexx boolean

  @{b}Note@{ub}
    This function works only if Miami is running.

@EndNode

@Node "MiamiSupportsIPV6" "RxLibnet Functions - MiamiSupportsIPV6"

  @{b}MiamiSupportsIPV6@{ub} - checks if Miami supports IPv6

  @{b}Synopsis@{ub}
    res=MiamiSupportsIPV6()
    --

  @{b}Function@{ub}
    Checks if the running version of Miami supports the IPv6 protocol.

  @{b}Inputs@{ub}
    none

  @{b}Result@{ub}
    res - an ARexx boolean.

  @{b}Note@{ub}
    This function works only if Miami is running.

@EndNode

@Node "ParseURI" "RxLibnet Functions - ParseURI"

  @{b}ParseURI@{ub} - parses a URI

  @{b}Synopsis@{ub}
    res=ParseURI(uri,stem)
    <uri>,<stem/V>

  @{b}Function@{ub}
    Parses the URI 'uri' and writes in 'stem' the fields:
        o Scheme
        o Hostinfo
        o User
        o Password
        o Hostname
        o Port
        o Path
        o Query
        o Fragment

  @{b}Inputs@{ub}
    uri  - the uri to parse
    stem - where to write the fields

  @{b}Result@{ub}
    res - an ARexx boolean

  @{b}Note@{ub}
    This function is really primitive, parse only http scheme
    and it is supposed to grow in the future. Anyway, the
    fields used will remain valid.

  @{b}See@{ub}
    @{"UnParseURI" LINK "UnParseURI"}

@EndNode

@Node "UnParseURI" "RxLibnet Functions - UnParseURI"

  @{b}UnParseURI@{ub} - un-parses URI components

  @{b}Synopsis@{ub}
    us=UnParseURI(uri,flags)
    <uri/V>,[flags]

  @{b}Function@{ub}
    Un-parses URI component as defined in 'uri' to an URI string.

    The fields read from 'uri' are:
        o Scheme
        o HostName
        o User
        o Password
        o Port
        o Path
        o Query
        o Fragment

    'flags' is one or more of:
        o OmitSitePart
        o OmitUser
        o OmitPassword
        o RevealPassword
        o OmitPathInfo
        o omitQuery

  @{b}Inputs@{ub}
    uri   - a stem where the URI components are defined
    flags - see above

  @{b}Result@{ub}
    us - the un-parsed URI string

  @{b}See@{ub}
    @{"ParseURI" LINK "ParseURI"}

@EndNode

@Node "ReadICMP" "RxLibnet Functions - ReadICMP"

  @{b}ReadICMP@{ub} - parses an ICMP packet

  @{b}Synopsis@{ub}
    call ReadICMP(pkt,stem)
    <pkt>,<stem/V>

  @{b}Function@{ub}
    Fills stem with an icmp header read from pkt.
    pkt must at least 28 bytes or an error 18 is generated.

    The fields set are:
        o TYPE
        o CODE
        o CKSUM
    (Yessss too lazi to make a better icmp parser  :)

  @{b}Inputs@{ub}
    pkt - the packet
    stem - an ARexx stem name

  @{b}Result@{ub}
    none

@EndNode

@Node "ReadIP" "RxLibnet Functions - ReadIP"

  @{b}ReadIP@{ub} - parses an ip packet

  @{b}Synopsis@{ub}
    call ReadIP(pkt,stem)
    <pkt>,<stem/V>

  @{b}Function@{ub}
    Fills stem with an ip header read from pkt.
    pkt must at least 20 bytes or an error 18 is generated.

    The fields set are:
        o V
        o HL
        o TOS
        o LEN
        o ID
        o OFF
        o TTL
        o P
        o SUM
        o SRC in dotted form
        o DST in dotted form

  @{b}Inputs@{ub}
    pkt - the packet
    stem - an ARexx stem name

  @{b}Result@{ub}
    none

@EndNode

@Node "ReadTCP" "RxLibnet Functions - ReadTCP"

  @{b}ReadTCP@{ub} - parses a TCP packet

  @{b}Synopsis@{ub}
    call ReadTCP(pkt,stem)
    <pkt>,<stem/V>

  @{b}Function@{ub}
    Fills stem with a tcp header read from pkt.
    pkt must at least 20 bytes or an error 18 is generated.

    The fields set are:
      o SPORT
      o DPORT
      o SEQ
      o ACK
      o OFF
      o X2
      o FLAGS
      o WIN
      o SUM
      o URP

   @{b}Inputs@{ub}
     pkt - the packet
     stem - an ARexx stem name

   @{b}Result@{ub}
     none

@EndNode

@Node "ReadUDP" "RxLibnet Functions - ReadUDP"

  @{b}ReadUDP@{ub} - parses an UDP packet

  @{b}Synopsis@{ub}
    call ReadUDP(pkt,stem)
    <pkt>,<stem/V>

  @{b}Function@{ub}
    Fills stem with an udp header read from pkt.
    pkt must at least 8 bytes or an error 18 is generated.

    The fields set are:
        o SPORT
        o DPORT
        o ULEN
        o SUM

  @{b}Inputs@{ub}
    pkt - the packet
    stem - an ARexx stem name

  @{b}Result@{ub}
    none

@EndNode

@Node "SockAtMark" "RxLibnet Functions - SockAtMark"

  @{b}SockAtMark@{ub} - checks if a socket is in OOB status

  @{b}Synopsis@{ub}
    res=SockAtMark(socketfd)
    <socketfd/N>

  @{b}Function@{ub}
    Checks if the socket is in out of band status.

  @{b}Inputs@{ub}
    socketfd - the socket to check

  @{b}Result@{ub}
    res - an ARexx boolean

  @{b}Note@{ub}
    This function works only if Miami is running.

@EndNode

@Node "DecodeB64" "RxLibnet Functions - DecodeB64"

  @{b}DecodeB64@{ub} - decode base64 data

  @{b}Synopsis@{ub}
    res=DecodeB64(source,dest,opt)
    <source>,<dest>,[opt]

  @{b}Function@{ub}
    Decodes a base64 encoded stream of data.

    source may be a string or a file name.
    dest may be an ARexx var name or a file name.

    opt is one of:
        o STRING
          source is a string rather than a file name
        o VAR
          dest is an ARexx var name rather than a
          file name
        o NTCHECKERR
          don't check for illegal chars or incomplete
          data during decoding

    If dest is an ARexx var, data size must be < 32767.


  @{b}Inputs@{ub}
    source - the sorce of data
    dest - where to store the @{b}Result@{ub}
    opt - options


  @{b}Result@{ub}
    res - an ARexx boolean
          On failure, RC contains the reason:
          1 - AmigaDOS error
          2 - incomplete stream of data
          3 - illegal chars in data


  @{b}See@{ub}
    @{"EncodeB64" LINK "EncodeB64"}

@EndNode

@Node "EncodeB64" "RxLibnet Functions - EncodeB64"

  @{b}EncodeB64@{ub} - encodes data

  @{b}Synopsis@{ub}
    res=EncodeB64(source,dest,opt,maxLineLen)
    <source>,<dest>,[opt],[maxLineLen/N]

  @{b}Function@{ub}
    Base64 encodes a stream of data.

    source may be a string or a file name.
    dest may be an ARexx var name or a file name.

    opt is one of:
        o STRING
          source is a string rather than a file name
        o VAR
          dest is an ARexx var name rather than a
          file name
        o UNIX
          add a '\\n' at end of lines rather than a
          '\\r\\n'

    If dest is an ARexx var, data size must be < 32767.


  @{b}Inputs@{ub}
    source - the sorce of data
    dest - where to store the @{b}Result@{ub}
    opt - options
    maxLineLen - if dest is a file (VAR not specified
                 in opt), lines are cut every 72 chars
                 by default; maxLineLen specifies a
                 new value. If 0 lines cutting is
                 suppressed. It must be a non negative
                 integral value.

  @{b}Result@{ub}
    res - an ARexx boolean
          On failure, RC contains the reasone:
          1 - AmigaDOS error

  @{b}See@{ub}
    @{"DecodeB64" LINK "DecodeB64"}

@EndNode

@Node "URLEncode" "RxLibnet Functions - URLEncode"

  @{b}URLEncod@{ub}e- RFC 1738 data encoding

  @{b}Synopsis@{ub}
    res=URLEncode(url)
    <url>

  @{b}Function@{ub}
    Encodes 'url' based on RFC 1738 rules.
    E.g.
        "http://www.serchit.com?search=< Amiga >" --->
        "http://www.serchit.com?search=%3C%20Amiga%20%3E"


  @{b}Inputs@{ub}
    url - the string to encode


  @{b}Result@{ub}
    res - 'url' encoded


  @{b}See@{ub}
    @{"URLDecode" LINK "URLDecode"}

@EndNode

@Node "URLDecode" "RxLibnet Functions - URLDecode"

  @{b}URLDecod@{ub}e- RFC 1738 data decoding

  @{b}Synopsis@{ub}
    res=URLDecode(url)
    <url>

  @{b}Function@{ub}
    Decodes 'url' based on RFC 1738 rules.
    E.g.
        "http://www.serchit.com?search=%3C%20Amiga%20%3E"  --->
        "http://www.serchit.com?search=< Amiga >"


  @{b}Inputs@{ub}
    url - the string to decode


  @{b}Result@{ub}
    res - 'url' decoded


  @{b}See@{ub}
    @{"URLEncode" LINK "URLEncode"}

@EndNode

@Node "MD5" "RxLibnet Functions - MD5"

  @{b}MD5@{ub} - Computes the MD5 Message-Digest

  @{b}Synopsis@{ub}
    dig=MD5(source,opt)
    <source>,[opt]

  @{b}Function@{ub}
    Computes the MD5 Message-Digest for 'source'.

    'opt' may be one of:
        o STRING - 'source' is a string (default)
        o FILE   - 'source' is a file name


  @{b}Inputs@{ub}
    source - the source of data
    opt - options regarding 'source' type


  @{b}Result@{ub}
    dig - the MD5 digest string for 'source'
          or an empty string if 'source' was
          a file, that can't be opened

@EndNode

@Node "Note" "RxLibnet Note"

  @{u}Note@{uu}


    1. Pointers to deallocate the local environment in the library
       base is saved in the fields pr_ExitCode and pr_ExitData of the
       Process structure of the macro. At exit a chain of
       pr_ExitCode(pr_ExitData) is called. Details are avaible on
       request.

    2. Some functions are avaible only if a peculiar stack is running
       or installed:

        o  Miami functions are available only if Miami is running;
        o  Miami packets filter functions are available only if a
           registered version of Miami is running;
        o  Genesis functions are available only if Genesis is installed;
        o  usergroup functions are available only if the stack running
           offers the usergroup.library .

        When a function is not available, the user is informed via a
        requester and an ARexx error 15 (function not found) is
        returned.

        Miami-registered-only functions returns error if used with
        Miami not registered.

        rxsocket.library/IsLibOn() can be used to test the environment.

@EndNode

