  @{b}Note@{ub}
    This function works only if Miami is running.

@EndNode

@Node "MiamiOnOffLine" "RxLibnet Functions - MiamiOnOffLine"

  @{b}MiamiOnOffLine@{ub} - controls Miami online status

  @{b}Synopsis@{ub}
    call MiamiOnOffLine(interface,status)
    <interface>,[status/N]

  @{b}Function@{ub}
    Switch the status of the interface.

    If status is 0 the interface is put offline.
    If status is 1 the interface is put online.
    Default value for status is 0.

    The functions doesn't wait for the switching to
    complete and always returns 1.

  @{b}Inputs@{ub}
    interface - an interface name
    status - the status to put the interface

  @{b}Result@{ub}
    none

  @{b}Note@{ub}
    This function works only if Miami is running.

@EndNode

@Node "MiamiIsOnLine" "RxLibnet Functions - MiamiIsOnLine"

  @{b}MiamiIsOnLine@{ub} - checks the status of an interface

  @{b}Synopsis@{ub}
    res=MiamiIsOnLine(interface)
    <interface>

  @{b}Function@{ub}
    Checks if the given interface is online.

  @{b}Inputs@{ub}
    interface - an interface name

  @{b}Result@{ub}
    res - an ARexx boolean

  @{b}Note@{ub}
    This function works only if Miami is running.

@EndNode

