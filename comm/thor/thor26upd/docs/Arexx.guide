@TOC FSE_Commands

@{u}The NEWLINE command@{uu}

@{b}Template:@{ub}
        ,

@{b}Purpose:@{ub}
   The same as a <return> press.

@{b}Specifications:@{ub}
   -

@{b}Result:@{ub}
   Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
   -

@{b}Example:@{ub}
   address 'THOR_FSE.01'

   /* ten new lines */

   do i = 1 to 10
      NEWLINE
   end

@endnode

