@node RECIPIENT "FSE/Information/Recipient"
@TOC FSE_Commands

@{u}The RECIPIENT command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Return the name of the receiver of the message in the
	editor.

@{b}Specifications:@{ub}


@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	In a normal reply-situation, SENDER=RECIPIENT if it isn't
	forwarded.

@{b}Example:@{ub}
	options results
	address 'THOR_FSE.01'

	RECIPIENT
	INSERTSTRING 'This message is addressed to '||result

@endnode

@node RECIPIENTADDR "FSE/Information/RecipientAddr"
@TOC FSE_Commands

@{u}The RECIPIENTADDR command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Returns the address of the receiver of the message in the
	editor.

@{b}Specifications:@{ub}


@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	options results
	address 'THOR_FSE.01'

	RECIPIENTADDR
	INSERTSTRING 'This message is addressed to the address '||result

@endnode

@node SENDER "FSE/Information/Sender"
@TOC FSE_Commands

@{u}The SENDER command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Return the sender of the message in the editor.

@{b}Specifications:@{ub}
	The name returned by this command will be the name of
	the person who wrote the message that this message is a
	reply to. When replying a message in THOR this name will
	be the same as that returned by the @{"RECIPIENT" Link RECIPIENT} command.
	When the message is forwarded the names may differ.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	options results
	address 'THOR_FSE.01'

	SENDER
	if(result ~= "") then INSERTSTRING 'This message is a ...
	reply to a message written by '||result
	else exit

@endnode

@node SENDERADDR "FSE/Information/SenderAddr"
@TOC FSE_Commands

@{u}The SENDERADDR command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Return the address to the sender of the message in the editor.

@{b}Specifications:@{ub}
	The address returned by this command will be the address of
	the person who wrote the message that this message is a
	reply to. When replying a message in THOR this address will
	be the same as that returned by the @{"RECIPIENTADDR" Link RECIPIENTADDR} command.
	When the message is forwarded the addresses may differ.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	options results
	address 'THOR_FSE.01'

	SENDERADDR
	if(result ~= "") then INSERTSTRING 'This message is a ...
	reply to a message written by '||result
	else exit

@endnode

@node SENDERDATE "FSE/Information/SenderDate"
@TOC FSE_Commands

@{u}The SENDERDATE command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Return the date and/or time at which the message in the 
	editor was written.

@{b}Specifications:@{ub}
	-

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	options results
	address 'THOR_FSE.01'

	SENDERDATE
	INSERTSTRING 'This message is dated: '||result

@endnode

@node CONFERENCE "FSE/Information/Conference"
@TOC FSE_Commands

@{u}The CONFERENCE command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Returns the original conference of the message in the FSE.

@{b}Specifications:@{ub}
	The conference name returned here is the conference that
	the message you are replying to was originally in.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	options results
	address 'THOR_FSE.01'

	CONFERENCE
	if(result ~= "") then do 
		INSERTSTRING 'Reply to a message in conference '||result
	end
	else exit

@endnode

@node XPOS "FSE/Information/XPos"
@TOC FSE_Commands

@{u}The XPOS command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Return cursor X-value.

@{b}Specifications:@{ub}
	-

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	options results
	address 'THOR_FSE.01'

	XPOS
	INSERTSTRING 'The cursor is now on character ...
	'||result||' on the line.'

@endnode

@node YPOS "FSE/Information/YPos"
@TOC FSE_Commands

@{u}The YPOS command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Return cursor Y-value.

@{b}Specifications:@{ub}
	-

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	options results
	address 'THOR_FSE.01'

	YPOS
	INSERTSTRING 'The cursor is now on line number ...
	'||result||'.'

@endnode

@node AUTOINDENT "FSE/Information/AutoIndent"
@TOC FSE_Commands

@{u}The AUTOINDENT command@{uu}

@{b}Template:@{ub}
	STATUS

@{b}Purpose:@{ub}
	Change and/or return current AutoIndent status.

@{b}Specifications:@{ub}
	Valid specifiers are ON=Y=YES and OFF=N=NO.  Returns ON
	or OFF depending on the current status.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	options results
	address 'THOR_FSE.01'

	AUTOINDENT
	INSERTSTRING 'The current AutoIndent status is: ...
	'||result

	AUTOINDENT OFF
	INSERTSTRING 'AutoIndent is now OFF'

@endnode

@node OVERWRITE "FSE/Information/OverWrite"
@TOC FSE_Commands

@{u}The OVERWRITE command@{uu}

@{b}Template:@{ub}
        STATUS

@{b}Purpose:@{ub}
	Change and/or return current Overwrite/Insert status.

@{b}Specifications:@{ub}
	Valid specifiers are ON=Y=YES and OFF=N=NO.  Returns ON
	or OFF depending on the current status.  

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	options results
	address 'THOR_FSE.01'

	OVERWRITE
	if(result = "OFF") then INSERTSTRING 'Insert is ON.'
	else if(result = "ON") then INSERTSTRING 'Overwrite is ON.'

@endnode

@node BACKSPACE "FSE/SpecificCommands/BackSpace"
@TOC FSE_Commands

@{u}The BACKSPACE command@{uu}

@{b}Template:@{ub}
        NUMBER

@{b}Purpose:@{ub}
	Delete the character to the left of the current cursor
	position.

@{b}Specifications:@{ub}
        NUMBER is the number of backspaces to insert.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	options results
	address 'THOR_FSE.01'

	/* Delete from cursor to left margin */

	XPOS
	BACKSPACE result

@endnode

@node BEGOFFILE "FSE/SpecificCommands/BegOfFile"
@TOC FSE_Commands

@{u}The BEGOFFILE command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Move cursor to the beginning of the file.

@{b}Specifications:@{ub}
        Opposite of the @{"ENDOFFILE" Link ENDOFFILE} command.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	BEGOFFILE

@endnode

@node BEGOFLINE "FSE/SpecificCommands/BegOfLine"
@TOC FSE_Commands

@{u}The BEGOFLINE command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Move cursor to the first character on the current line.

@{b}Specifications:@{ub}
	Note that this does not include whitespace.  Opposite of
	the @{"ENDOFLINE" Link ENDOFLINE} command.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	BEGOFLINE

@endnode

@node DELETELINES "FSE/SpecificCommands/DeleteLines"
@TOC FSE_Commands

@{u}The DELETELINES command@{uu}

@{b}Template:@{ub}
        LINES

@{b}Purpose:@{ub}
	Delete a number of lines.

@{b}Specifications:@{ub}
	LINES is the number of lines to delete.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	/* Delete ten lines */

	DELETELINES 10

@endnode

@node ENDOFFILE "FSE/SpecificCommands/EndOfFile"
@TOC FSE_Commands

@{u}The ENDOFFILE command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Move cursor to the position behind the last character in
	the text.

@{b}Specifications:@{ub}
	Opposite of the @{"BEGOFFILE" Link BEGOFFILE} command.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	ENDOFFILE

@endnode

@node ENDOFLINE "FSE/SpecificCommands/EndOfLine"
@TOC FSE_Commands

@{u}The ENDOFLINE command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Move cursor to the position behind the last character
	on the current line.

@{b}Specifications:@{ub}
        Opposite of the @{"BEGOFLINE" Link BEGOFLINE} command.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	ENDOFLINE

@endnode

@node INCLUDEFILE "FSE/SpecificCommands/IncludeFile"
@TOC FSE_Commands

@{u}The INCLUDEFILE command@{uu}

@{b}Template:@{ub}
        NAME

@{b}Purpose:@{ub}
	Include file.

@{b}Specifications:@{ub}
	If no NAME is specified, a filerequester will open
	requesting a name form one from the user.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	INCLUDEFILE 's:startup-sequence'

	/* Request file from user */

	INCLUDEFILE

@endnode

@node INSERTBUFFERLINES "FSE/SpecificCommands/InsertBufferLines"
@TOC FSE_Commands

@{u}The INSERTBUFFERLINES command@{uu}

@{b}Template:@{ub}
        LINES

@{b}Purpose:@{ub}
	Insert lines from the buffer.

@{b}Specifications:@{ub}
	Inserts lines deleted with CTRL-Y or @{"DELETELINES" Link DELETELINES}. Same as 
	CTRL-B. LINES is the number of lines to insert.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	/* Delete ten lines and reinsert them five lines below */

	DELETELINES 10
	SETPOS Y 5
        INSERTBUFFERLINES 10

@endnode

@node INSERTINPUT "FSE/SpecificCommands/InsertInput"
@TOC FSE_Commands

@{u}The INSERTINPUT command@{uu}

@{b}Template:@{ub}
        STRING/A/F

@{b}Purpose:@{ub}
	Insert string asynchronously

@{b}Specifications:@{ub}
        The string will be inserted as if it were typed at the
	keyboard and may include control-codes like CTRL-B,
	CTRL-QY etc.  Strings inserted with INSERTINPUT will be
	noticed by i.e. macro-learning (as opposed to 
	@{"INSERTSTRING" Link INSERTINPUT}).

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	INSERTINPUT 'String....'

@endnode

@node INSERTLINES "FSE/SpecificCommands/InsertLines"
@TOC FSE_Commands

@{u}The INSERTLINES command@{uu}

@{b}Template:@{ub}
        LINES

@{b}Purpose:@{ub}
	Insert one or more empty lines at the current cursor
	position (same as CTRL-O).

@{b}Specifications:@{ub}
	-

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	INSERTLINES 7

@endnode

@node INSERTSTRING "FSE/SpecificCommands/InsertString"
@TOC FSE_Commands

@{u}The INSERTSTRING command@{uu}

@{b}Template:@{ub}
        STRING/A/F

@{b}Purpose:@{ub}
	Insert the string supplied synchronously.

@{b}Specifications:@{ub}
	Will not be noticed by i.e. macro-learning (as opposed
	to @{"INSERTINPUT" Link INSERTINPUT}).

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	INSERTSTRING 'String!'

@endnode

@node INSERTTAG "FSE/SpecificCommands/InsertTag"
@TOC FSE_Commands

@{u}The INSERTTAG command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Ask THOR for a tag and include it at current cursor
	position.

@{b}Specifications:@{ub}
	-

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	ENDOFFILE
	INSERTTAG

@endnode

@node NEWLINE "FSE/SpecificCommands/NewLine"
@TOC FSE_Commands

@{u}The NEWLINE command@{uu}

@{b}Template:@{ub}
        ,

@{b}Purpose:@{ub}
	The same as a <return> press.

@{b}Specifications:@{ub}
	-

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	/* ten new lines */

	do i = 1 to 10
		NEWLINE
	end

@endnode

@node PASTECLIP "FSE/SpecificCommands/PasteClip"
@TOC FSE_Commands

@{u}The PASTECLIP command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Paste clipboard contents at current cursor position.

@{b}Specifications:@{ub}
	-

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

        PASTECLIP

@endnode

@node PLAYMACRO "FSE/SpecificCommands/PlayMacro"
@TOC FSE_Commands

@{u}The PLAYMACRO command@{uu}

@{b}Template:@{ub}
        MACRO

@{b}Purpose:@{ub}
	Play macro number 1-20 asynchronously.

@{b}Specifications:@{ub}
	MACRO is the macro number to play.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	PLAYMACRO 9

@endnode

@node SAVEFILE "FSE/SpecificCommands/SaveFile"
@TOC FSE_Commands

@{u}The SAVEFILE command@{uu}

@{b}Template:@{ub}
        FILENAME

@{b}Purpose:@{ub}
	Save file.  If no name specified, requests one from
	user.

@{b}Specifications:@{ub}
	-

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	WARN is returned when an error has occured.

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	/* save file as 't:temp' */

	SAVEFILE 't:temp'

        /* let the user choose filename */

	SAVEFILE

@endnode

@node SETPOS "FSE/SpecificCommands/SetPos"
@TOC FSE_Commands

@{u}The SETPOS command@{uu}

@{b}Template:@{ub}
	X/K,Y/K

@{b}Purpose:@{ub}
	Move cursor to a specific position.

@{b}Specifications:@{ub}
	Note that 0 is a valid argument that does not affect the
	cursor.  You may also leave out any arguments.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
        A WARN is returned if any of the coordinates are out of
	range.

@{b}Example:@{ub}
	address 'THOR_FSE.01'

	/* place cursor on char number 10 on line 2 */
	SETPOS X 10 Y 2

	/* moves cursor to (10,10) */
	SETPOS 10,10

	/* moves cursor to position 10 on this line */
	SETPOS 10

	/* moves cursor to line 10 with unchanged X-value */
	SETPOS 0 10
	SETPOS Y 10

@endnode

@node RequestNotify "FSE/Requesters/RequestNotify"
@TOC FSE_Commands

@{u}The REQUESTNOTIFY command@{uu}

@{b}Template:@{ub}
	TEXT/A,BUTTONTEXT=BT/A

@{b}Purpose:@{ub}
	Will open a requester with some information text in it,
	specified to the command.

@{b}Specifications:@{ub}
	TEXT can contain upto 300 characters and will be prosessed like
	the signature in THOR.  This means that variables like $ver and
	$time can be used and will be translated.  Max number of
	characters is 300, this this is @{i}after@{ui} any variables you 
	use have been expanded, so with $time and $ver the limit for the
	text in is about 280 characters.

	BUTTONTEXT is the text to be in the gadgets and the shortcut can
	be set with '_' in front of the key that is to act as a
	shortcut.  The text for each gadget is separated with a '|', and
	it's possible to define 1 or more gadgets.

@{b}Result:@{ub}
	If the command is not known to THOR or wrong parameters are
	specified, the command will return 10.  The command will return
	0 when the user chooses a gadget, and result will contain the
	number of the gadget selected.  The value in result will be 1
	(TRUE) for leftmost (positive) response, then each consecutive
	response will return 1 more, the rightmost (false) response will
	return 0 (FALSE) in result.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	options results
	address 'THOR.01'

	THORTOFRONT

	REQUESTNOTIFY TEXT '"The time is now: $time\n\nOK will return ...
	1, MAYBE will return 2\nand CANCEL will return 0"' BT ...
	'"_OK|_MAYBE|_CANCEL"'

	retval = result

	if(retval = 0) then do
	    say 'User pressed CANCEL'
	end

	if(retval = 1) then do
	    say 'User pressed OK'
	end

	if(retval = 2) then do
	    say 'User pressed MAYBE'
	end

@endnode

@node RequestString "FSE/Requesters/RequestString"
@TOC FSE_Commands

@{u}The REQUESTSTRING command@{uu}

@{b}Template:@{ub}
	TITLETEXT=TITLE/A,BUTTONTEXT=BT/A,INITIALSTRING=ID,MAXCHARS/N/A

@{b}Purpose:@{ub}
	Will open a requester which accepts any string input you give
	it, upto MAXCHARS number of characters.

@{b}Specifications:@{ub}
	BUTTONTEXT is the text to be in the gadgets and the shortcut can
	be set with '_' in front if the key that is to act as a
	shortcut.  The text for each gadget is separated with a '|', and
	it's possible to define 1 or more gadgets, although more than
	two gadgets won't do any good.  If a single gadget it used, the
	command can only be canceled by entering no text in the gadget.
	2 gadgets, no more and no less, is highly recommended for this
	requester.

@{b}Result:@{ub}
	If nothing is entered, the requester is canceled or fails for
	some other reason, the command will return 10.  Will return 0 on
	success and result will contain the string entered.

@{b}Warning:@{ub}
	Note that the MAXCHARS can't be higher than 1000.

@{b}Example:@{ub}
	options results
	address 'THOR.01'

	THORTOFRONT

	REQUESTSTRING TITLE '"Enter something:"' BT '"_Ok|_Cancel"' ID '"Some text"'
	MAXCHARS 40

	say result

@endnode

@node NOP "FSE/General/NOP"
@TOC FSE_Commands

@{u}The NOP command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Do nothing but return a value.

@{b}Specifications:@{ub}
	The NOP (NO-oPeration) instruction is provided to
	control the binding of ELSE clauses in compound IF
	statements.

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
	address 'THOR_FSE.01'  /* or 'THOR.01' */

	if i = j then			/* First (outer) IF */
		if j = k then a = 0	/* Inner IF */
			else NOP	/* Binds to inner IF */
		else a = a + 1		/* Binds to outer IF */

@endnode
