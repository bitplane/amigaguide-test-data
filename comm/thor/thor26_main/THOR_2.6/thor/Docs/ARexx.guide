	MAXMSGLENGTH
	say 'This editor has a maximum of '||result||' line(s).'

@endnode

@node MSGFILENAME "FSE/Information/MSGFileName"
@TOC FSE_Commands

@{u}The MSGFILENAME command@{uu}

@{b}Template:@{ub}
	,

@{b}Purpose:@{ub}
	Return the filename of the file currently being edited.

@{b}Specifications:@{ub}
	-

@{b}Result:@{ub}
	Will return 0 on success and 10 on failure.

@{b}Warning:@{ub}
	-

@{b}Example:@{ub}
