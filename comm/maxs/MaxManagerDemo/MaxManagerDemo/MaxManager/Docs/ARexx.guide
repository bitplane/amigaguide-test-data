@node CMD_EXPORT "EXPORT"

   @{b}NAME@{ub}
       EXPORT

   @{b}SYNOPSIS@{ub} 
       EXPORT

   @{b}FUNCTION@{ub} 
       Exports selected files for BBS. Source sections have to be file
       section

   @{b}INPUTS@{ub} 
       None

   @{b}OUTPUTS@{ub} 
       None

@endnode

@node CMD_FILE_PATH "FILE_PATH"

   @{b}NAME@{ub}
       FILE_PATH

   @{b}SYNOPSIS@{ub} 
       FILE_PATH PATH/A

   @{b}FUNCTION@{ub} 
       Sets filepath used for import/export functions

   @{b}INPUTS@{ub} 
       New filepath

   @{b}OUTPUTS@{ub} 
       None

@endnode

@node CMD_IMPORT "IMPORT"

   @{b}NAME@{ub}
       IMPORT

   @{b}SYNOPSIS@{ub} 
       IMPORT

   @{b}FUNCTION@{ub} 
       Imports selected files into the filebase. Source have to be file
       requester (PAGE 1), destination have to be file section. Only
       unique files will be imported as normally

   @{b}INPUTS@{ub} 
       None

   @{b}OUTPUTS@{ub} 
       None

@endnode

