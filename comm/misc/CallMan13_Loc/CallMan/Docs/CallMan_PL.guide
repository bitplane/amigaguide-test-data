      @{" Okno szybkiego dzwonienia  " link "Usage_QuickDial" }
      @{" Okno poîâczenia            " link "Usage_Call"      }
      @{" Okno analizatora           " link "Usage_Analyze"   }
      @{" Okno preferencji           " link "Usage_Prefs"     }
