@NODE MAIN "Foodfight"


                             Foodfight v 1.1
                    A game for DLG & Cli-based BBS systems
                     Originally designed by Patrick Baker
                    Rewritten and compiled by Basil Barnes

                         @{" Acknowledgments " LINK ACKNOWLEDGE}
                         @{" Install DLG     " LINK INSTALLDLG}
