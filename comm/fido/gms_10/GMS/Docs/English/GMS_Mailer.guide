@Next "cfgModem"
@Prev "cfgHandshakes"
@Toc  "MailerSettings"

Log options
***********

 @{" LogFile " Link "LogFile"}
 @{" LogCallerID " Link "LogCallerID"}
 @{" LocalizeLog " Link "LocalizeLog"}
 @{" LocalizeLogDate " Link "LocalizeLogDate"}
 @{" MaxLogLines " Link "MaxLogLines"}
 @{" MaxLogSecs " Link "MaxLogSecs"}

 @{" LogDebugger " Link "LogDebugger"}
 @{" LogInformation " Link "LogInformation"}
 @{" LogLink " Link "LogLink"}
 @{" LogModem " Link "LogModem"}
 @{" LogOutside " Link "LogOutside"}
 @{" LogScheduler " Link "LogScheduler"}
 @{" LogSecurity " Link "LogSecurity"}
 @{" LogSession " Link "LogSession"}
 @{" LogSystem " Link "LogSystem"}
 @{" LogTransfer " Link "LogTransfer"}

@EndNode

@Node "LogFile" "GMS_Mailer.guide/MailerSettings/Log/LogFile"
@Next "LogCallerID"
@Prev ""
@Toc  "cfgLog"

Name:      LogFile=<filename>

   Set the name of log file.


Example:   LogFile=Mail:GMS_Mailer.Log

@EndNode

@Node "LogCallerID" "GMS_Mailer.guide/MailerSettings/Log/LogCallerID"
@Next "LocalizeLog"
@Prev "LogFile"
@Toc  "cfgLog"

Name:      LogCallerID=<filename>

   Set the name of CallerID log file.


Example:   LogCallerID=Mail:GMS_Mailer.IDLog

@EndNode

@Node "LocalizeLog" "GMS_Mailer.guide/MailerSettings/Log/LocalizeLog"
@Next "LocalizeLogDate"
@Prev "LogCallerID"
@Toc  "cfgLog"

Name:      LocalizeLog=<boolean>

   Enable/disable log localization.


Example:   LocalizeLog=YES

@EndNode

@Node "LocalizeLogDate" "GMS_Mailer.guide/MailerSettings/Log/LocalizeLogDate"
@Next "MaxLogLines"
@Prev "LocalizeLog"
@Toc  "cfgLog"

Name:      LocalizeLogDate=<boolean>

   Enable/disable date log localization.


Example:   LocalizeLogDate=YES

@EndNode

@Node "MaxLogLines" "GMS_Mailer.guide/MailerSettings/Log/MaxLogLines"
@Next "MaxLogSecs"
@Prev "LocalizeLogDate"
@Toc  "cfgLog"

Name:      MaxLogLines=<lines>

   This allows you to specify the number of log-lines that will be buffered,
i.e. after so many lines have been written to the logfile, the file will be
flushed (closed and reopened, in order to force all the data to disk).  


Example:   MaxLogLines=5

@EndNode

@Node "MaxLogSecs" "GMS_Mailer.guide/MailerSettings/Log/MaxLogSecs"
@Next "LogDebugger"
@Prev "MaxLogLines"
@Toc  "cfgLog"

Name:      MaxLogSecs=<seconds>

   This specifies the number of seconds that may expire before GMS_Mailer
will flush the logfile.


Example:   MaxLogSecs=8

@EndNode

@Node "LogDebugger" "GMS_Mailer.guide/MailerSettings/Log/LogDebugger"
@Next "LogInformation"
@Prev "MaxLogSecs"
@Toc  "cfgLog"

Name:      LogDebugger=<level>

Level=<Silent|Terse|Discreet|Verbose|Talkative|Excessive|Annoying|Monologue>

   Sets the value for <LogDebugger> keyword.

Level        Text
-----        ----
Terse        "No EMSI figerprint"
Verbose      "EMSI-Send: %s"
Verbose      "EMSI-Rec: %s"
Annoying     "EMSI-Send: %s"  (EMSI_DAT)
Annoying     "EMSI-Rec: %s"   (EMSI_DAT)
Verbose      "YooHoo-Send: %s"
Verbose      "YooHoo-Rec: %s"


Example:   LogDebugger=Monologue

@EndNode

@Node "LogInformation" "GMS_Mailer.guide/MailerSettings/Log/LogInformation"
@Next "LogLink"
@Prev "LogDebugger"
@Toc  "cfgLog"

Name:      LogInformation=<level>

Level=<Silent|Terse|Discreet|Verbose|Talkative|Excessive|Annoying|Monologue>

   Sets the value for <LogInformation> keyword.

Level        Text
-----        ----
Silent       " Name: %s (%s)"
Discreet     "  AKA: %s"
Terse        "SysOp: %s"
Discreet     "Place: %s (%s)"
Excessive    "Flags: %s"
Talking      "Using: %s"
Annoying     "Offer: %s"
Excessive    "Hold: %s"
Excessive    "Keep: %s"
Verbose      "TrxID: %s/%s"
Verbose      "TrxID: %s"


Example:   LogInformation=Monologue

@EndNode

@Node "LogLink" "GMS_Mailer.guide/MailerSettings/Log/LogLink"
@Next "LogModem"
@Prev "LogInformation"
@Toc  "cfgLog"

Name:      LogLink=<level>

Level=<Silent|Terse|Discreet|Verbose|Talkative|Excessive|Annoying|Monologue>

   Sets the value for <LogLink> keyword.

Level        Text
-----        ----
Excessive    "Connection made at %ld Bd"
Verbose      "Line is busy"
Verbose      "Modem reported error"
Verbose      "Voice answer"
Verbose      "No connection"
Verbose      "No dial tone"
Silent       "Carrier lost"
Discreet     "Baudrate too low"


Example:   LogLink=Terse

@EndNode

@Node "LogModem" "GMS_Mailer.guide/MailerSettings/Log/LogModem"
@Next "LogOutside"
@Prev "LogLink"
@Toc  "cfgLog"

Name:      LogModem=<level>

Level=<Silent|Terse|Discreet|Verbose|Talkative|Excessive|Annoying|Monologue>

   Sets the value for <LogModem> keyword.

Level        Text
-----        ----
Silent       "Modem not ready"
Talkative    "Initializing modem"
Silent       "Initializing modem failed"
Verbose      "Hanging up modem"
Annoying     "Already hung up"
Silent       "Could not hang up"
Excessive    "Hang up completed"
Talkative    "Dialing modem"
Talkative    "Answering modem"
Terse        "%s" (CONNECT, NO CARRIER, BUSY, VOICE, NO DIALTONE, ...)
Discreet     "%s" (RINGING)


Example:   LogModem=Silent

@EndNode

@Node "LogOutside" "GMS_Mailer.guide/MailerSettings/Log/LogOutside"
@Next "LogScheduler"
@Prev "LogModem"
@Toc  "cfgLog

Name:      LogOutside=<level>

Level=<Silent|Terse|Discreet|Verbose|Talkative|Excessive|Annoying|Monologue>

   Sets the value for <LogOutside> keyword.

Level        Text
-----        ----
Discreet     "Spawning %s: "%s""
Silent       "Can't spawn %s (Error %ld)"
Talkative    "%s returned (%ld)"
Verbose      "Executing %s: "%s""
Silent       "Can't execute %s (Error %ld)"
Silent       "Can't open BBS input/output file"


Example:   LogOutside=Silent

@EndNode

@Node "LogScheduler" "GMS_Mailer.guide/MailerSettings/Log/LogScheduler"
@Next "LogSecurity"
@Prev "LogOutside"
@Toc  "cfgLog"

Name:      LogScheduler=<level>

Level=<Silent|Terse|Discreet|Verbose|Talkative|Excessive|Annoying|Monologue>

   Sets the value for <LogScheduler> keyword.

Level        Text
-----        ----
Silent       "GMS Mailer v%s opened"
Silent       "GMS Mailer v%s closed"
Verbose      "Waiting for call"
Discreet     "Incoming call detected"
Terse        "Calling %s"
Talkative    "Calling %s (%s)"
Terse        "Phone %s"


Example:   LogScheduler=Monologue

@EndNode

@Node "LogSecurity" "GMS_Mailer.guide/MailerSettings/Log/LogSecurity"
@Next "LogSession"
@Prev "LogScheduler"
@Toc  "cfgLog"

Name:      LogSecurity=<level>

Level=<Silent|Terse|Discreet|Verbose|Talkative|Excessive|Annoying|Monologue>

   Sets the value for <LogSecurity> keyword.

Level        Text
-----        ----
Silent       "Password-protected session"
Verbose      "Expected %s and got %s"
Silent       "Bad password on other end (remote: "%s")"
Silent       "Bad password (remote: "%s")"
Terse        "Bad password for AKA %s (remote: "%s")"
Excessive    "Unlisted system"
Silent       "%s exceeds account limits"
Silent       "Can't find node %s"


Example:   LogSecurity=Silent

@EndNode

@Node "LogSession" "GMS_Mailer.guide/MailerSettings/Log/LogSession"
@Next "LogSystem"
@Prev "LogSecurity"
@Toc  "cfgLog"

Name:      LogSession=<level>

Level=<Silent|Terse|Discreet|Verbose|Talkative|Excessive|Annoying|Monologue>

   Sets the value for <LogSession> keyword.

Level        Text
-----        ----
Terse        "Session connect time %ld:%02ld"
Verbose      "Session aborted"
Silent       "Remote system does not respond"
Excessive    "Begin of session"
Discreet     "Protocol: %s/%s"
Excessive    "Call successful"
Excessive    "Call failed"
Excessive    "End of send"
Silent       "No common protocol available"


Example:   LogSession=Terse

@EndNode

@Node "LogSystem" "GMS_Mailer.guide/MailerSettings/Log/LogSystem"
@Next "LogTransfer"
@Prev "LogSession"
@Toc  "cfgLog"

Name:      LogSystem=<level>

Level=<Silent|Terse|Discreet|Verbose|Talkative|Excessive|Annoying|Monologue>

   Sets the value for <LogSystem> keyword.

Level        Text
-----        ----
Silent       "Disk I/O error"
Terse        "User break"
Silent       "Not implemented"
Silent       "Out of memory"
Silent       "Can't access inbound directory"
Silent       "Can't access outbound directory"
Silent       "Can't open "%s""
Terse        "File "%s" is in use"
Annoying     "Flagging file as sent"
Excessive    "Deleting file"
Excessive    "Truncating file"
Annoying     "Deleting %s"
Silent       "Internal error"
Silent       "Value of DropBBSSecs too low, corrected to 10"


Example:   LogSystem=Silent

@EndNode

@Node "LogTransfer" "GMS_Mailer.guide/MailerSettings/Log/LogTransfer"
@Next ""
@Prev "LogSystem"
@Toc  "cfgLog"

Name:      LogTransfer=<level>

Level=<Silent|Terse|Discreet|Verbose|Talkative|Excessive|Annoying|Monologue>

   Sets the value for <LogTransfer> keyword.

Level        Text
-----        ----
Terse        "Transfer cancelled"
Talkative    "Timeout"
Talkative    "CRC error"
Terse        "Too many retries"
Excessive    "Transferring "%s" as "%s""
Excessive    "File transfer okay"
Excessive    "File transfer failed"
Excessive    "File skipped"
Silent       "Sending %s (%ld bytes)"
Verbose      "Sent %s (%ld bytes) successful"
Silent       "Receiving %s (%ld bytes)"
Discreet     "Resuming transfer from offset %ld"
Verbose      "Received %s (%ld bytes) successful"
Discreet     "Renaming inbound file %s to %s"
Silent       "Receiving %s failed"
Silent       "Sending %s failed"
Silent       "Skipped %s failed"
Silent       "Took %ld:%02ld, Cps: %ld, Total Cps: %ld, Efficiency: %ld%%"
Silent       "Recv %s (%ld bytes) as %s"
Silent       "Send %s (%ld bytes) as %s"


Example:   LogTransfer=Monologue

@EndNode

@Node "cfgModem" "GMS_Mailer.guide/MailerSettings/Modem"
@Next "cfgSeriale"
@Prev "cfgLog"
@Toc  "MailerSettings"

Modem options
*************

 @{" Answer " Link "Answer"}
 @{" ArqString " Link "ArqString"}
 @{" ModemAnswer " Link "ModemAnswer"}
 @{" ModemInit " Link "ModemInit"}
 @{" ModemDialPre " Link "ModemDialPre"}
 @{" ModemDialPost " Link "ModemDialPost"}
 @{" ModemHangUp " Link "ModemHangUp"}
