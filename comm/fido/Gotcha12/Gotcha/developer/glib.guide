@Node "GL_ExtraDel" "gotcha.library/GL_ExtraDel"
@{fg shine}gotcha.library/GL_ExtraDel@{fg text}

NAME
@{fg shine}   @{"GL_ExtraDel" Link "work:Gotcha/developer/glib.guide/GL_ExtraDel"} -- Delete an data entry
@{fg text}
