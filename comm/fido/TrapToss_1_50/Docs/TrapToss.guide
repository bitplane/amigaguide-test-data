@NODE 11.3 "MultiNet Setupá"
  11.3. @{B}MultiNet Setup@{UB}

       Here is a sample TrapToss configuration file for MultiNet
     Nodes (should be named MAIL:TrapToss.Cfg or MAIL:Fido.Cfg):

     ; ************************************************************************
     ; ***                                                                  ***
     ; ***           Sample MultiNet TrapToss.Cfg file for Nodes            ***
     ; ***                  »»»»»»»»»»»»»»»»»»»»»                           ***
     ; *** ---------------------------------------------------------------- ***
     ; ***  This file is a tiny setup for TrapToss to import and export     ***
     ; ***  EchoMail. Please modify to suit your personal needs.            ***
     ; *** ---------------------------------------------------------------- ***
     ; ***  TrapToss.Cfg is compatible to the GCF (Global @{"Configuration" link 4}     ***
     ; ***  File) Standard. If you want to use it in conjunction with other ***
     ; ***  programs using the GCF, TrapList, for instance, simply rename   ***
     ; ***  this file as "FIDO.CFG"                                         ***
     ; ************************************************************************

     ; ************************************************************************
     ; ***  PUBLIC SECTION -- accessible by other programs, insert global   ***
     ; ***  ¡¡¡¡¡¡¡¡¡¡¡¡¡¡    information here...                           ***
     ; ************************************************************************

     ; Here comes my full 4-dimensional fido Address as well as my fake Address
     @{"NODE" link 7.26}     2:310/6.0
     @{"AKA" link 7.2}      2:3160/0 2:3164/0
     @{"POINTNET" link 7.30} 3160

     @{"DOMAIN" link 7.11} "AmigaNet"  39:200/6  39:* 40:* 41:*
     @{"DOMAIN" link 7.11} "GlobalNet" 54:6101/6 51:* 52:* 53:* 54:*
     @{"DOMAIN" link 7.11} "FidoNet"

     @{"ORIGIN" link 7.27}   "The Mad House, Vienna, Austria [Zyxel 16K8]"
     @{"TIMEZONE" link 8.53} "CET"

     @{"INBOUND" link 7.18}      "Mail:Inbound"
     @{"OUTBOUND" link 7.28}     "Mail:Outbound"
     @{"NODELISTPATH" link 7.24} "Nodelist:"

     ; ************************************************************************
     ; ***  TRAPTOSS PRIVATE SECTION -- Here goes information exclusively   ***
     ; ***  ¡¡¡¡¡¡¡¡¡¡¡¡¡¡¡¡¡¡¡¡¡¡¡¡    accessible by TrapToss...           ***
     ; ************************************************************************

     ;Section Identifier
     [TrapToss]

     @{"UNATTENDED" link 7.43}      ; this is an unattended system

     @{"LOGLEVEL" link 7.22} 4      ; some logging
     @{"LOGFILE" link 7.21} Mail:TrapToss.Log

     @{"SCREENMODE" link 7.38} None ; no screen desired

     @{"FORCE4DMO" link 7.15}       ; I run the new TrapDoor

     @{"LINKMSGS" link 7.20}        ; replylink messages
     @{"DUPCHECK" link 7.12}        ; and check for duplicates

     ; I have a Nodelist for these Zones, so allow bouncing there
     @{"BOUNCE" link 7.6} 1:* 2:* 4:* 5:* 6:* 9:* 41:* 40:*

     ; put mail on Hold for Points
     @{"CHANGE" link 7.7} Crash  Hold 2:310/6.* *:3160/* 39:200/6.* 54:6101/6.*
     @{"CHANGE" link 7.7} Direct Hold 2:310/6.* *:3160/* 39:200/6.* 54:6101/6.*
     @{"CHANGE" link 7.7} Normal Hold 2:310/6.* *:3160/* 39:200/6.* 54:6101/6.*

     ; select EchoMail flavour for other Nodes
     @{"CHANGE" link 7.7} Normal Hold   2:310/15  2:242/25   2:281/100 2:302/810
     @{"CHANGE" link 7.7} Normal Crash  2:310/3   2:310/11   2:310/30
     @{"CHANGE" link 7.7} Normal Direct 2:253/140 41:200/401 41:243/12

     ; what to do with Netmail for these Nodes
     @{"SEND" link 7.39} Crash  2:310/12 2:310/19 2:310/30 2:310/42  2:310/90  2:2/527
     @{"SEND" link 7.39} Direct 2:310/2  2:310/5  2:310/8  2:310/10  2:310/13  2:313/11 2:241/7504
     @{"SEND" link 7.39} Hold   2:310/15 2:310/42 2:242/25 2:281/100 2:302/810

     ; route the rest of the Netmail
     @{"ROUTE" link 7.34} Direct 2:253/140   253/140.* 253/*.*
     @{"ROUTE" link 7.34} Crash  2:310/30    341/23.*
     @{"ROUTE" link 7.34} Crash  2:310/1     310/1.*  31/0.*
     @{"ROUTE" link 7.34} Crash  2:310/0     310/0.*  310/7.*
     @{"ROUTE" link 7.34} Hold   2:313/1     313/1.*  313/0.*
     @{"ROUTE" link 7.34} Crash  2:310/11    310/11.* 1:*   3:*   4:*   5:* 6:* \
                              2/3.*    2/4.* 2/5.* 2/6.*
     @{"ROUTE" link 7.34} Crash  2:310/3     310/3.* *

     ; these Nodes want LHArc compressed mail
     @{"PACKER" link 7.29} "LhArc -x0 -f -u -m a" 310/19 310/42 310/6.3 310/6.4 310/6.7

     ; Packertypes:    ARC    ZOO       LHARC    ZIP         ARJ          Others
     ;------------------------------------------------------------------------------
     @{"DEFAULTUNPACKERS" link 7.10} "Pkax" "Zoo x:O" "Lha e" "UnZip -xnj" "UnArj e -y" "rx XArc e"

     ; remove my Points from the seen-bys, but
     ; don't forget to add myself again!

     @{"FORDOMAIN" link 8.24} FidoNet   @{"STRIP" link 8.51} 2:310/6.* 2:3160/*
     @{"FORDOMAIN" link 8.24} FidoNet   @{"ADD" link 8.2}   2:310/6

     @{"FORDOMAIN" link 8.24} AmigaNet  @{"STRIP" link 8.51} 39:200/6.* 39:3160/*
     @{"FORDOMAIN" link 8.24} AmigaNet  @{"ADD" link 8.2}   39:200/6

     @{"FORDOMAIN" link 8.24} GlobalNet @{"STRIP" link 8.51} 54:6101/6.* 54:3160/*
     @{"FORDOMAIN" link 8.24} GlobalNet @{"ADD" link 8.2}   54:6101/6


     ; Finally, here are my @{"Areas" link 4.4}:
