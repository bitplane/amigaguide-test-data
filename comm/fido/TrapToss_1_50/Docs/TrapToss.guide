     ;key areaname           directory               Nodes who get it (I must be first!)
     ;»»» »»»»»»»»           »»»»»»»»»               »»»»»»»»»»»»»»»»
     @{"NETMAIL" link 7.25} MAIL_DIR       MAIL:matrix              310/6

