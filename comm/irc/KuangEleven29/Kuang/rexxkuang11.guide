@Node "KRAND" "rexxkuang11.library/KRAND"

@{b}    NAME@{ub}
        KRAND - Return random number.

@{b}    ALIASES@{ub}
        RXK11_KRAND

@{b}    SYNOPSIS@{ub}
        ran = KRAND(min,max)

@{b}    FUNCTION@{ub}
        Returns a random number in the range of min >= ran <= max.

@{b}    INPUTS@{ub}
        min - The smallest random number to be returned.
        max . The biggest random number to be returned.

@{b}    RESULT@{ub}
        ran - The random number in the specific range.

@{b}    EXAMPLE@{ub}
        SAY KRAND(1,10)

@{b}    NOTES@{ub}
        If no arguments are specified KRAND assumes a range of 0-9.

@EndNode

@Node "LOADUSERS" "rexxkuang11.library/LOADUSERS"

@{b}    NAME@{ub}
        LOADUSERS - Reload the userlist.

@{b}    ALIASES@{ub}
        RXK11_LOADUSERS

@{b}    SYNOPSIS@{ub}
        error = LOADUSERS()

@{b}    FUNCTION@{ub}
        Reloads the userslist from disk (hardcoded as "Kuang11/Friends").

@{b}    RESULT@{ub}
        error  - TRUE (1) if the userlist was successfully loaded, FALSE (0)
                 otherwise.

@{b}    EXAMPLE@{ub}
        IF ~LOADUSERS() THEN SAY 'Unable to load userlist!'

@{b}    SEE ALSO@{ub}
        @{"SAVEUSERS()" Link "SAVEUSERS"}

@EndNode

@Node "OPENURL" "rexxkuang11.library/OPENURL"

@{b}    NAME@{ub}
        OPENURL - Open an URL using openurl.library.

@{b}    ALIASES@{ub}
        RXK11_OPENURL

@{b}    SYNOPSIS@{ub}
        error = OPENURL(url)

@{b}    FUNCTION@{ub}
        Sends the argument to openurl.library in order to open the URL in a web
        browser.

@{b}    INPUTS@{ub}
        url - An URL in the standard form.

@{b}    RESULT@{ub}
        error - TRUE (1) if successful, FALSE (0) otherwise.

@{b}    EXAMPLE@{ub}
        IF ~OPENURL('http://www.bestiality.com/dogs/rexx/walky.gif')
        THEN SAY 'Unable to satisfy sexual perversions.'

@EndNode

@Node "SAVEUSERS" "rexxkuang11.library/SAVEUSERS"

@{b}    NAME@{ub}
        SAVEUSERS - Save the userlist to disk.

@{b}    ALIASES@{ub}
        RXK11_SAVEUSERS

@{b}    SYNOPSIS@{ub}
        error = SAVEUSERS()

@{b}    FUNCTION@{ub}
        Collects the data pertaining to each user in the userlist and saves it to
        disk (hardcoded as "Kuang11/Friends").

@{b}    RESULT@{ub}
        error - TRUE (1) if the list was successfully saved, FALSE (0) otherwise.

@{b}    EXAMPLE@{ub}
        IF SAVEUSERS() THEN SAY 'Userlist successfully saved.'
        ELSE SAY 'Damn.'

@{b}    SEE ALSO@{ub}
        @{"LOADUSERS()" Link "LOADUSERS"}

@EndNode

@Node "SETUSERFLAGS" "rexxkuang11.library/SETUSERFLAGS"

@{b}    NAME@{ub}
        SETUSERFLAGS - Change an user's flags.

@{b}    ALIASES@{ub}
        RXK11_SETUSERFLAGS

@{b}    SYNOPSIS@{ub}
        error = SETUSERFLAGS(user,flags)

@{b}    FUNCTION@{ub}
        Replaces the flags of an user with a new set.

@{b}    INPUTS@{ub}
        user - The name of an user in the userlist.
        flags - The new flag string to set for the user.

@{b}    RESULT@{ub}
        error - TRUE (1) if user was found and flags set, FALSE (0)
                otherwise.

@{b}    EXAMPLE@{ub}
        IF SETUSERFLAGS('Bob','db') THEN SAY 'New flags for Bob: db'

@{b}    SEE ALSO@{ub}
        @{"SETUSERNAME()" Link "SETUSERNAME"}

@EndNode

@Node "SETUSERNAME" "rexxkuang11.library/SETUSERNAME"

@{b}    NAME@{ub}
        SETUSERNAME - Rename an user.

@{b}    ALIASES@{ub}
        SETUSERNICK, RENAMEUSER, RXK11_SETUSERNAME

@{b}    SYNOPSIS@{ub}
        error = SETUSERNAME(user,newname)

@{b}    FUNCTION@{ub}
        Changes an user's name. If newname=oldname case will still be corrected.

@{b}    INPUTS@{ub}
        user - The current name of an user in the userlist.
        newname - The name the user should be renamed to.

@{b}    RESULT@{ub}
        error = TRUE (1) if the user was found and name changed, FALSE (0) otherwise.

@{b}    EXAMPLE@{ub}
        IF SETUSERNAME('Bob','BoB') THEN SAY 'Bob renamed to BoB'

@{b}    SEE ALSO@{ub}
        @{"SETUSERFLAGS()" Link "SETUSERFLAGS"}

@EndNode

@Node "SFINDUSER" "rexxkuang11.library/SFINDUSER"

@{b}    NAME@{ub}
        SFINDUSER - Find an user in the userlist.

@{b}    ALIASES@{ub}
        FINDUSER, RXK11_SFINDUSER

@{b}    SYNOPSIS@{ub}
        found = SFINDUSER(stemvar,host,flags,patterned,comparenicks)

@{b}    FUNCTION@{ub}
        Checks the userlist for the first user matching the hostmask and flags given
        and puts the user details into stemvar.

@{b}    INPUTS@{ub}
        stemvar - The name of the stem variable which will be set to the results.
        host - A hostmask in the form user@host.
        flags - The string containing flags the user must have to match.
        patterned - Enable two way patterned matching of host.
                    (You have to specify the string 'PM' as input.)
                    (optional)
        comparenicks - Enable the comparison of the nick portion of host.
                       (You have to specify the string 'NK' as input.)
                       (optional)

@{b}    RESULT@{ub}
        found - FALSE (0) if no user was found or an error occured, TRUE (1) otherwise.
        stamvar.K_NAME - The name of the found user.
        stamvar.K_HOST - The first host matching mask of the found user.
        stamvar.K_FLAGS - The flags of the found user.

@{b}    EXAMPLE@{ub}
        IF SFINDUSER(fu,'*@*.microsoft.com','') THEN SETUSERFLAGS(fu.K_NAME,'db')

@{b}    NOTES@{ub}
        If passing '' as stemvar name, stemvar will be named 'K_USER' by default.
        Userlist is kept in memory to speed up operations.
        If passed host is a numeric ip SFINDUSER tries to resolve it into a named ip.
        Note that internally both the userlist hostmasks and the passed hostmask
        are split into nick, username and host portions. If patterned option is not
        used only pattern characters (like ?, * or #?) in userlist hostmasks are
        considered. With patterned option enabled pattern characters are also parsed
        in the passed hostmask, otherwise they are treated like normal characters.
        Nick matches can be enabled with the comparenicks option.
        Note you have to specify the keywords 'PM' or 'NK' to enable patterned or
        comparenicks option.
        Overall this function includes every feature and bugfix it should have had in
        'old' rexxkuang11.library.

@EndNode

@Node "SGETNUMIP" "rexxkuang11.library/SGETNUMIP"

@{b}    NAME@{ub}
        SGETNUMIP - Set a stem variable to the numeric ip(s) of a host.

@{b}    ALIASES@{ub}
        RXK11_SGETNUMIP

@{b}    SYNOPSIS@{ub}
        ips = SGETNUMIP(stemvar,ip)

@{b}    FUNCTION@{ub}
        Finds the ip(s) of a given host and writes the result to a stem variable.

@{b}    INPUTS@{ub}
        stemvar - The name of the stem variable which will be set to the results.
        ip - The name of the host ip(s) are to be found.

@{b}    RESULT@{ub}
        ips - The number of ip(s) found for the host. If 0, an error may have
              occured.
        stamvar.0 - The number of ip(s) found.
        stamvar.1-stamvar.x - The found ip(s).

@{b}    EXAMPLE@{ub}
        SAY 'Numeric IPs of ppp-69.fuck.com are:'
        DO i = 1 TO SGETNUMIP(ips,'ppp-69.fuck.com')
        SAY ips.i

@{b}    SEE ALSO@{ub}
        @{"GETDOMAIN()" Link "GETDOMAIN"}, @{"GETNUMIP()" Link "GETNUMIP"}, @{"SRESOLVE()" Link "SRESOLVE"}

@EndNode

@Node "SGETUSER" "rexxkuang11.library/SGETUSER"

@{b}    NAME@{ub}
        SGETUSER - Get an user's information.

@{b}    ALIASES@{ub}
        GETUSER, RXK11_SGETUSER

@{b}    SYNOPSIS@{ub}
        error = SGETUSER(stemvar,name)

@{b}    FUNCTION@{ub}
        Sets a stem variable containing the user's data.

@{b}    INPUTS@{ub}
        stemvar - The name of the stem variable which will be set to the results.
        name - The name of the user whose information is to be retrieved.

@{b}    RESULT@{ub}
        error - TRUE (1) if successful, FALSE (0) otherwise.
        stemvar.K_NAME - The name of the user (same as name input).
        stemvar.K_FLAGS - The flag string set for the user.
        stemvar.K_HOSTS.K_COUNT - The number of hosts defined for the user.
        stemvar.K_HOSTS.x - The users list of hosts.
                            (while 1 >= x <= stemvar.K_HOSTS.K_COUNT)

@{b}    EXAMPLE@{ub}
        IF SGETUSER(u,'Fred') THEN SAY 'Fred''s flags are:' u.K_FLAGS

@{b}    NOTES@{ub}
        If passing '' as stemvar name, stemvar will be named 'K_USER' by default.

@{b}    SEE ALSO@{ub}
        @{"SGETUSERS()" Link "SGETUSERS"}

@EndNode

@Node "SGETUSERS" "rexxkuang11.library/SGETUSERS"

@{b}    NAME@{ub}
        SGETUSERS - Put the userlist into a stem variable.

@{b}    ALIASES@{ub}
        GETUSERS, RXK11_SGETUSERS

@{b}    SYNOPSIS@{ub}
        error = SGETUSERS(stemvar)

@{b}    FUNCTION@{ub}
        Sets a stem variable to contain the userlist data.

@{b}    INPUTS@{ub}
        stemvar - The name of the stem variable which will be set to the results.

@{b}    RESULT@{ub}
        error - TRUE (1) on success, FALSE (0) otherwise.
        stemvar.K_COUNT - The number of users in the list.
        stemvar.x.K_NAME - The name of user x.
        stemvar.x.K_FLAGS - The flag string set for user x.
        stemvar.x.K_HOSTS.K_COUNT - The number of hosts defined for user x.
        stemvar.x.K_HOSTS.x - A list of hosts set for user x.

@{b}    EXAMPLE@{ub}
        SGETUSERS(gu);SAY 'There are' gu.K_COUNT 'users in the list.'

@{b}    NOTES@{ub}
        If passing '' as stemvar name, stemvar will be named 'K_USER' by default.

@{b}    SEE ALSO@{ub}
        @{"SGETUSER()" Link "SGETUSER"}

@EndNode

@Node "SRESOLVE" "rexxkuang11.library/SRESOLVE"

@{b}    NAME@{ub}
        SRESOLVE - Do a complete resolve on a specified host.

@{b}    ALIASES@{ub}
        RXK11_SRESOLVE

@{b}    SYNOPSIS@{ub}
        error = SRESOLVE(stemvar,ip)

@{b}    FUNCTION@{ub}
        Resolves a host and puts the collected data into a stemvar.

@{b}    INPUTS@{ub}
        stemvar - The name of the stem variable which will be set to the results.

@{b}    RESULT@{ub}
        error - TRUE (1) if successful, FALSE (0) otherwise.
        stemvar.K_NAME - The host name of the specified ip.
        stemvar.K_ALIAS.K_COUNT - The number of aliases for the ip.
        stemvar.K_ALIAS.x - The aliases of the specified ip.
        stemvar.K_ADDRESS.K_COUNT - The number of numeric ip(s) for the ip.
        stemvar.K_ADDRESS.x - The numeric ip(s) of the specified ip.

@{b}    SEE ALSO@{ub}
        @{"GETDOMAIN()" Link "GETDOMAIN"}, @{"GETNUMIP()" Link "GETNUMIP"}, @{"SGETNUMIP()" Link "SGETNUMIP"}

@EndNode

@Node "STRLOWER" "rexxkuang11.library/STRLOWER"

@{b}    NAME@{ub}
        STRLOWER - Return the lower equivalent of a string.

@{b}    ALIASES@{ub}
        LOWER, RXK11_STRLOWER

@{b}    SYNOPSIS@{ub}
        newstr = STRLOWER(str)

@{b}    FUNCTION@{ub}
        Converts the characters of a string from any case to lowercase.

@{b}    INPUTS@{ub}
        str - The string to be converted to lowercase.

@{b}    RESULT@{ub}
        newstr - The converted string.

@{b}    EXAMPLE@{ub}
        SAY STRLOWER('THIS STRING IS IN LOWERCASE')

@{b}    NOTES@{ub}
        Uses utility.library/ToLower thus if locale.library is present country
        specific code is used.

@EndNode

@Node "STRREPLACE" "rexxkuang11.library/STRREPLACE"

@{b}    NAME@{ub}
        STRREPLACE - Replace one string with another in a string.

@{b}    ALIASES@{ub}
        RXK11_STRREPLACE

@{b}    SYNOPSIS@{ub}
        newstr - STRREPLACE(str, changetostr, changestr)

@{b}    FUNCTION@{ub}
        Replaces all instances of items found in changestr found in str with the
        matching items in changetostr.

@{b}    INPUTS@{ub}
        str - The string which is to be operated on.
        changetostr - The list of replacement strings, seperated by ','.
        changestr - The list of strings to be replaced, seperated by ','.

@{b}    RESULT@{ub}
        newstr - A copy of str with the appropriate strings replaced.

@{b}    EXAMPLE@{ub}
        SAY STRREPLACE('Amiga sucks, Windows rulez !','kicks,should be dumped',
                       'sucks,rulez')

@{b}    NOTES@{ub}
        Actually a quite powerful function as its not limited in arguments.
        You can also simply cut out words or even whole sentences by specifying
        an empty string ('') as changetostr.

@EndNode

@Node "UNDERLINE" "rexxkuang11.library/UNDERLINE"

@{b}    NAME@{ub}
        UNDERLINE - Add underline style codes to string.

@{b}    ALIASES@{ub}
        UND, RXK11_UNDERLINE

@{b}    SYNOPSIS@{ub}
        undstr . UNDERLINE(str)

@{b}    FUNCTION@{ub}
        Adds underline style codes (ASCII 0x1F) to the beginning and end of a
        string.

@{b}    INPUTS@{ub}
        str - The string to be underlined.

@{b}    RESULT@{ub}
        undstr - A copy of str surrounded by underline style codes.

@{b}    EXAMPLE@{ub}
        ADDRESS AMIRC.1 "ECHO" UNDERLINE('I'm written in underline')

@{b}    SEE ALSO@{ub}
        @{"BOLD()" Link "BOLD"}, @{"INVERSE()" Link "INVERSE"}

@EndNode
