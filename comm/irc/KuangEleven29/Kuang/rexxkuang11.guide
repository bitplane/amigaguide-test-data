@Node "BACKGROUND" "rexxkuang11.library/--background--"

@{b}    PURPOSE@{ub}
        The rexxkuang11.library provides several functions for Kuang Eleven.
        Its main purpose is to speed up userlist and string modification while
        giving easy interface to things like http file retrieve or opening
        url's in a browser fromout arexx.
@EndNode

@Node "ADDUSER" "rexxkuang11.library/ADDUSER"

@{b}    NAME@{ub}
        ADDUSER - Add a new user to the userlist.

@{b}    ALIASES@{ub}
        RXK11_ADDUSER

@{b}    SYNOPSIS@{ub}
        error = ADDUSER(name,flags,hostmask)

@{b}    FUNCTION@{ub}
        Adds a new user to the userlist with the specified parameters.

@{b}    INPUTS@{ub}
        name - The name to be given to the new user.
        flags - The flags for the new user.
        hostmask - The hostmask (only one) for the new user, in user@host form.

@{b}    RESULT@{ub}
        error - TRUE (1) if the user was successfully added, FALSE (0) otherwise.

@{b}    EXAMPLE@{ub}
        IF ADDUSER('Bob','oxipcs','*.foo.com') THEN SAY 'User added.'

@{b}    SEE ALSO@{ub}
        @{"DELETEUSER()" Link "DELETEUSER"}

@EndNode

@Node "ADDUSERHOST" "rexxkuang11.library/ADDUSERHOST"

@{b}    NAME@{ub}
        ADDUSERHOST - Adds a host to the user's hostlist.

@{b}    ALIASES@{ub}
        RXK11_ADDUSERHOST

@{b}    SYNOPSIS@{ub}
        error = ADDUSERHOST(user,host)

@{b}    FUNCTION@{ub}
        Adds a host to the user's hostlist.

@{b}    INPUTS@{ub}
        user - The name of the user in the userlist.
        host - The hostmask to be added to the hostlist of the user.

@{b}    RESULT@{ub}
        error - TRUE (1) if the host was successfully added, FALSE (0) otherwise.

        RC - 2 : if user has already the given host.
             1 : if no such user in userlist.

@{b}    EXAMPLE@{ub}
        ADDUSERHOST('Bob','my.newhost.net')

@{b}    SEE ALSO@{ub}
        @{"DELETEUSERHOST()" Link "DELETEUSERHOST"}

@EndNode

@Node "BOLD" "rexxkuang11.library/BOLD"

@{b}    NAME@{ub}
        BOLD - Add bold style codes to string.

@{b}    ALIASES@{ub}
        BLD, RXK11_BOLD

@{b}    SYNOPSIS@{ub}
        bldstr = BOLD(str)

@{b}    FUNCTION@{ub}
        Adds bold style codes (ASCII 0x02) to the beginning and end of a string.

@{b}    INPUTS@{ub}
        str - The string to be emboldened.

@{b}    RESULT@{ub}
        bldstr - A copy of str surrounded by bold style codes.

@{b}    EXAMPLE@{ub}
        ADDRESS AMIRC.1 "ECHO" BOLD('I''m written in bold')

@{b}    SEE ALSO@{ub}
        @{"INVERSE()" Link "INVERSE"}, @{"UNDERLINE()" Link "UNDERLINE"}

@EndNode

@Node "CHECKVERSION" "rexxkuang11.library/CHECKVERSION"

@{b}    NAME@{ub}
        CHECKVERSION - Check that the version of a file is sufficient.

@{b}    ALIASES@{ub}
        RXK11_CHECKVERSION

@{b}    SYNOPSIS@{ub}
        check = CHECKVERSION(filename,version)

@{b}    FUNCTION@{ub}
        Check that the version of a file is sufficient.

@{b}    INPUTS@{ub}
        filename - A valid DOS path to the file.
        version - A version in version.revision format.

@{b}    RESULT@{ub}
        check - -1: if the file was a lesser version.
                 0: if the file was the same version.
                 1: if the file was a greater version.

        RC - 0: if the file couldn't be opened.
             1: if the file was opened successfully but no version string was found.
             2: if version string could be found but no proper version.revision string.
             3: if everything gone fine.

@{b}    EXAMPLE@{ub}
        check = CHECKVERSION("Myfile", "5.16")
        IF RC ~= 3 THEN SAY "Error checking file version"
        ELSE IF check < 0 THEN SAY "File is out of date"

@{b}    NOTES@{ub}
        Note this function returns everytime a proper value even if something fails !
        This behaviour is to ensure proper working of Kuang11UPD.amirx in any case.
        An RC code of 1 makes it return 0 making it not try to download anything while
        RC 0 and 2 make it return -1 so an update is downloaded in any case.
        An RC of 3 makes it compare the file version with the supplied version and
        the relation of both versions is returned.
        Note also that a version of 5.05 and 5.5 is the SAME! Version and revision
        are treated independantely like it should be.

@{b}    SEE ALSO@{ub}
        @{"GETVERSION()" Link "GETVERSION"}, @{"GETVERSTR()" Link "GETVERSTR"}

@EndNode

@Node "DELETEUSER" "rexxkuang11.library/DELETEUSER"

@{b}    NAME@{ub}
        DELETEUSER - Remove an user from the userlist.

@{b}    ALIASES@{ub}
        RXK11_DELETEUSER

@{b}    SYNOPSIS@{ub}
        error = DELETEUSER(user)

@{b}    FUNCTION@{ub}
        Removes an user from the userlist if they exist.

@{b}    INPUTS@{ub}
        user - The name of the user in the userlist.

@{b}    RESULT@{ub}
        error - TRUE (1) if the user was found and deleted, FALSE (0) otherwise.

@{b}    EXAMPLE@{ub}
        IF DELETEUSER('Bob') THEN SAY 'Deleted user Bob'

@{b}    SEE ALSO@{ub}
        @{"ADDUSER()" Link "ADDUSER"}

@EndNode

@Node "DELETEUSERHOST" "rexxkuang11.library/DELETEUSERHOST"

@{b}    NAME@{ub}
        DELETEUSERHOST - Remove a host from a user's hostlist.

@{b}    ALIASES@{ub}
        RXK11_DELETEUSERHOST

@{b}    SYNOPSIS@{ub}
        error = DELETEUSERHOST(user,host)

@{b}    FUNCTION@{ub}
        Remove the specified host from a user's list of hosts, if it exists.
        If the host is the last defined for the user, it will be not deleted.

@{b}    INPUTS@{ub}
        user - The name of the user in the userlist.
        host - The host to be removed from the hostlist.

@{b}    RESULT@{ub}
        error  - TRUE (1) if the host was successfully added, otherwise FALSE (0).

        RC - 1: User does not have this host.
             2: User has only one host.
             3: No such User.

@{b}    EXAMPLE@{ub}
        DELETEUSERHOST('Bob','*.myoldhost.com')

@{b}    SEE ALSO@{ub}
        @{"ADDUSERHOST()" Link "ADDUSERHOST"}

@EndNode

@Node "FCOUNTLINES" "rexxkuang11.library/FCOUNTLINES"

@{b}    NAME@{ub}
        FCOUNTLINES - Count the number of lines in a file.

@{b}    ALIASES@{ub}
        RXK11_FCOUNTLINES

@{b}    SYNOPSIS@{ub}
        lines = FCOUNTLINES(filename)

@{b}    FUNCTION@{ub}
        Count the number of lines in a file.

@{b}    INPUTS@{ub}
        filename - A valid DOS path to the file.

@{b}    RESULT@{ub}
        lines - The number of lines, or -1 if unsuccessful.

@{b}    EXAMPLE@{ub}
        SAY 'Kickfile contains' FCOUNTLINES('Kickfile') 'lines.'

@{b}    BUGS@{ub}
        Crap error returning.

@{b}    SEE ALSO@{ub}
        @{"FCOUNTSTRLINES()" Link "FCOUNTSTRLINES"}, @{"FGETLINES()" Link "FGETLINES"}, @{"FSEARCH()" Link "FSEARCH"}

@EndNode

@Node "FCOUNTSTRLINES" "rexxkuang11.library/FCOUNTSTRLINES"

@{b}    NAME@{ub}
        FCOUNTSTRLINES - Count the number of a given line in a file.

@{b}    ALIASES@{ub}
        RXK11_FCOUNTSTRLINES

@{b}    SYNOPSIS@{ub}
        lines = FCOUNTSTRLINES(filename,line)

@{b}    FUNCTION@{ub}
        Opens a file and counts the number of lines which exactly match the
        string line.

@{b}    INPUTS@{ub}
        filename - A valid DOS path to the file.
        line - The line to count.

@{b}    RESULT@{ub}
        lines - The number of occurencies of line found in the file or -1
                if the file could not be opened.

@{b}    EXAMPLE@{ub}
        FCOUNTSTRLINES('Kickfile','@KICK')

@{b}    NOTES@{ub}
        Does only compare the beginning of a file line to the provided line.
        It doesn't check if line occur somewhere in the file.

@{b}    SEE ALSO@{ub}
        @{"FCOUNTLINES()" Link "FCOUNTLINES"}, @{"FGETLINES()" Link "FGETLINES"}, @{"FSEARCH()" Link "FSEARCH"}

@EndNode

@Node "FGETLINES" "rexxkuang11.library/FGETLINES"

@{b}    NAME@{ub}
        FGETLINES - Returns the lines in a file after a certain line.

@{b}    ALIASES@{ub}
        RXK11_FGETLINES

@{b}    SYNOPSIS@{ub}
        text = FGETLINES(filename,str,strnum)

@{b}    FUNCTION@{ub}
        Reads a file and searches for the strnum instance of str. It returns all
        lines between this and the next instance of str (or EOF), seperated by NL
        characters.

@{b}    INPUTS@{ub}
        filename - A valid DOS path to the file.
        str - The marker string.
        strnum - The instance number of the marker string.

@{b}    RESULT@{ub}
        text - The text between the marker and end marker (or EOF), or '' if
               unsuccessful.

@{b}    EXAMPLE@{ub}
        SAY FGETLINES('Moo','@COW',42)

@{b}    SEE ALSO@{ub}
        @{"FCOUNTSTRLINES()" Link "FCOUNTSTRLINES"}, @{"FSEARCH()" Link "FSEARCH"}

@EndNode

@Node "FSEARCH" "rexxkuang11.library/FSEARCH"

@{b}    NAME@{ub}
        FSEARCH - Find a line in a file starting with a specific string.

@{b}    ALIASES@{ub}
        RXK11_FSEARCH

@{b}    SYNOPSIS@{ub}
        text = FSEARCH(filename, str)

@{b}    FUNCTION@{ub}
        Finds the first line in a file starting with the string str.

@{b}    INPUTS@{ub}
        filename - A valid DOS path to the file.
        str - The string starting the line to find.

@{b}    RESULT@{ub}
        text - The whole line found, or '' if not found or an error occured.

@{b}    EXAMPLE@{ub}
        SAY 'Current setting:' FSEARCH('Config','CONFIRMDELETE')

@{b}    SEE ALSO@{ub}
        @{"FCOUNTSTRLINES()" Link "FCOUNTSTRLINES"}, @{"FGETLINES()" Link "FGETLINES"}

@EndNode

@Node "FWRITEURL" "rexxkuang11.library/FWRITEURL"

@{b}    NAME@{ub}
        FWRITEURL - Store the contents of an URL to a file.

@{b}    ALIASES@{ub}
        RXK11_FWRITEURL

@{b}    SYNOPSIS@{ub}
        error = FWRITEURL(filename,url,screen,proxy,nocache,auth,quiet)

@{b}    FUNCTION@{ub}
        Recieves the contents of an URL if the service is HTTP.
        Saves the contents to the file with the path filename, and pops up a small
        progress GUI while transferring.

@{b}    INPUTS@{ub}
        filename - A valid DOS path to the file to be written.
        url - An URL in the standard form. (with http:// as prefix)
        screen - The name of the public screen for the transfer window to appear on.
                 (optional)
        proxy - A proxy server in host:port form. (optional)
        nocache - Discourages the proxy server from returning a cached version of
                  the target. (optional)
        auth - A web site authentification in username:password form. (optional)
        quiet - Discourages the transfer window to be opened. (optional)

@{b}    RESULT@{ub}
        error - TRUE (1) if successful, FALSE (0) otherwise.
        FWRITEURL_ERROR - The http error code if an error occured.
        FWRITEURL_CPS - The average cps during transfer.

        A file will be created.

@{b}    EXAMPLE@{ub}
        IF ~FWRITEURL('T:Porno.pic',
                      'http://www.bestiality.com/dogs/rexx/Walky.gif')
        THEN SAY 'Unable to satisfy sexual perversions.'

@{b}    NOTES@{ub}
        This function overwrites delete protected files to ensure proper update
        of Kuang Eleven.
        In future this function will support HTTP/1.1 resume.

@EndNode

@Node "GETDOMAIN" "rexxkuang11.library/GETDOMAIN"

@{b}    NAME@{ub}
        GETDOMAIN - Get the hostname or mask describing the static part of a host.

@{b}    ALIASES@{ub}
        RXK11_GETDOMAIN

@{b}    SYNOPSIS@{ub}
        domain = GETDOMAIN(host)

@{b}    FUNCTION@{ub}
        Returns a hostname or hostmask which describes the static portion of a
        host.

@{b}    INPUTS@{ub}
        host - The address of the host to find the static domain of.

@{b}    RESULT@{ub}
        domain - The resulting hostname or mask.

@{b}    EXAMPLE@{ub}
        SAY 'User's domain is:' GETDOMAIN('ppp-69.fuck.com')

@EndNode

@Node "GETNUMIP" "rexxkuang11.library/GETNUMIP"

@{b}    NAME@{ub}
        GETNUMIP - Return the numeric IP of a host.

@{b}    ALIASES@{ub}
        RXK11_GETNUMIP

@{b}    SYNOPSIS@{ub}
        numip = GETNUMIP(ip)

@{b}    FUNCTION@{ub}
        Finds the numeric IP of a given host.

@{b}    INPUTS@{ub}
        ip - The name of the host whose numeric IP is to be found.

@{b}    RESULT@{ub}
        numip - A string in the format a.b.c.d representing the first numeric IP
        of the host, or '' if none found.

@{b}    EXAMPLE@{ub}
        SAY 'Numeric IP of ppp-69.fuck.com is:' GETNUMIP('ppp-69.fuck.com')

@{b}    NOTE@{ub}
        This function only returns a numeric host as result.
        Should the passed ip to be found be numeric already then it will be
        returned unchanged.

@{b}    SEE ALSO@{ub}
        @{"GETDOMAIN()" Link "GETDOMAIN"}, @{"SGETNUMIP()" Link "SGETNUMIP"}, @{"SRESOLVE()" Link "SRESOLVE"}

@EndNode

@Node "GETVERSION" "rexxkuang11.library/GETVERSION"

@{b}    NAME@{ub}
        GETVERSION - Get the version $VER: string in any file.

@{b}    ALIASES@{ub}
        RXK11_GETVERSION

@{b}    SYNOPSIS@{ub}
        version = GETVERSION(filename)

@{b}    FUNCTION@{ub}
        Gets the version part of the $VER: string in any file.

@{b}    INPUTS@{ub}
        filename - A valid DOS path to the file.

@{b}    RESULT@{ub}
        version - The version part of the $VER: string if found or
                  '' if the file couldn't be opened.

@{b}    EXAMPLE@{ub}
        IF GETVERSION('Myfile')=='3.0' THEN SAY "MUIRexx sucks arse"

@{b}    SEE ALSO@{ub}
        @{"CHECKVERSION()" Link "CHECKVERSION"}, @{"GETVERSTR()" Link "GETVERSTR"}

@EndNode

@Node "GETVERSTR" "rexxkuang11.library/GETVERSTR"

@{b}    NAME@{ub}
        GETVERSTR - Get the version $VER: string in any file.

@{b}    ALIASES@{ub}
        RXK11_GETVERSTR

@{b}    SYNOPSIS@{ub}
        verstr = GETVERSTR(filename)

@{b}    FUNCTION@{ub}
        Gets the version $VER: string in any file.

@{b}    INPUTS@{ub}
        filename - A valid DOS path to the file.

@{b}    RESULT@{ub}
        verstr - The complete version string (excluding $VER: prefix) or
                 '' if the file couldn't be opened.

@{b}    SEE ALSO@{ub}
        @{"CHECKVERSION()" Link "CHECKVERSION"}, @{"GETVERSION()" Link "GETVERSION"}

@EndNode

@Node "INVERSE" "rexxkuang11.library/INVERSE"

