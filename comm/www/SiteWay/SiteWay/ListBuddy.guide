@node MENUS "ListBuddy Hilfe:  Menübedienung"

 @{Menu_Title " Project "}
 @{Menu_ItemKS " New             " "N"} - Eine neue, leere Projekt-Datei erstellen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Open...         " "O"} - Eine existierende Projekt-Datei öffnen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Save            " "S"} - Die aktuelle Projekt speichern.
 @{Menu_ItemKS " Save as...      " "A"} - Das aktuelle Projekt unter neuem Namen speichern.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Preview         " "P"} - Die aktuelle Liste zur Vorschau an Browser übergeben.
 @{Menu_ItemKS " Export          " "E"} - Die aktuelle Liste als HTML-Datei/Snipplet speichern.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Help            " "H"} - Dieses Dokument aufrufen und anzeigen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " about CanDo...  " "?"} - Dialogfenster mit Infos über die Programmiersprache anzeigen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Quit            " "Q"} - Alles schließen und das Programm beenden.


 @{Menu_Title " Edit "}
 @{Menu_ItemKS " Cut             " "X"} - Den aktuellen Text ausschneiden.
 @{Menu_ItemKS " Copy            " "C"} - Den aktuellen Text kopieren.
 @{Menu_ItemKS " Paste           " "V"} - Den Inhalt der Kopie einfügen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Reset           " "R"} - Den Originaltext der Projekt-Datei einfügen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Delete          " "D"} - Den aktuellen Text löschen.

@endnode

