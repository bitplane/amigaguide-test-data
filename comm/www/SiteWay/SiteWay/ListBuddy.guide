@node PROLOG "ListBuddy Hilfe:  EINLEITUNG"
@smartwrap
@font helvetica.font 13
@toc MAIN
@{jleft}@{lindent 8}

@{Title_Header "V O R W O R T"}
@{Title_String "Ein paar generelle, einleitende"}
@{Title_Footer "Worte zu den HTML-Listen."}
@{lindent 8}


@{bold "D"}ieses Programm unterstützt zwei Listen-Tags der HTML 3.2 Spezifikation nicht,
da sie auch kein einziger Browser anzeigen kann. Es handelt sich dabei um die Tags:@{par}

    @{bold "<MENU></MENU>"} @{white "(Deutsch: Menü)"}@{par}

und@{par}

    @{bold "<DIR></DIR>"} @{white "(Deutsch: Verzeichnis)"}.@{par}

Unterstützt werden:@{par}

@{" UL " link "UL"} · @{bold "<UL></UL>"} @{par}
    |_@{white "Einleitung und Ausleitung der"} @{bold "Aufzählungsliste"} - (Englisch: @{bold "U"}nordered @{bold "L"}ist)@{par}
       |_@{italic "Listenattribut: "} <UL... ...@{blue "COMPACT"}> @{par}
       |_@{italic "Aufzählungssymbol: "} <UL... ...@{blue "TYPE"}="Circle|Square|Disk"> @{par}

@{" OL " link "OL"} · @{bold "<OL></OL>"} @{par}
    |_@{white "Einleitung und Ausleitung der"} @{bold "Numernliste"} - (Englisch: @{bold "O"}rdered @{bold "L"}ist)@{par}
       |_@{italic "Listenattribut: "} <OL... ...@{blue "COMPACT"}> @{par}
       |_@{italic "Präfixum: "} <OL... ...@{blue "TYPE"}="A|a|I|i"> @{par}
       |_@{italic "Präfixumstart: "} <OL... ...@{blue "START"}="[variabler Wert]"> @{par}

@{" DL " link "DL"} · @{bold "<DL></DL>"} @{par}
    |_@{white "Einleitung und Ausleitung der"} @{bold "Definitionsliste"} - (Englisch: @{bold "D"}efinition @{bold "L"}ist)@{par}
       |_@{italic "Listenattribut: "} <DL... ...@{blue "COMPACT"}> @{par}

@{" DT " link "DL"} · @{bold "<DT></DT>"} @{par}
    |_@{white "Einleitung und Ausleitung des"} @{bold "Definitionstitels"} - (Englisch: @{bold "D"}efinition @{bold "T"}erm)@{par}

@{" DD " link "DL"} · @{bold "<DD></DD>"} @{par}
    |_@{white "Einleitung und Ausleitung des"} @{bold "Definitionstextes"} - (Englisch: @{bold "D"}efinition @{bold "D"}ata)@{par}

Unterstützt werden zusätzlich:@{par}

@{" PRE " link "FLOAT"} · @{bold "<PRE></PRE>"} @{par}
    |_@{white "Einleitung und Ausleitung des"} @{bold "formatierten Textabschnittes"} - (Englisch: @{bold "P"}reformated)@{par}
       |_@{italic "Sektionsattribut: "} <PRE... ...@{blue "WIDTH"}=[numerischer Wert]> @{par}

@endnode

