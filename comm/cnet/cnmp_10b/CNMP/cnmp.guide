             list.

@ENDNODE
@NODE PermitEntry() "PermitEntry"

@{b}   NAME@{ub}
   PermitEntry -- Sends a message of type @{"CNMP_ENTRYPERMIT" Link CNMP_ENTRYPERMIT} to a remote port.

@{b}   SYNOPSIS@{ub}
   PermitEntry(rmessage, echostring, cluster)

   void PermitEntry(struct @{"CNMPMsg" Link include:cnmp/cnmp.h/Main 30} *, char *, struct @{"CnmpCluster" Link "include:cnmp/cnmp.h/Main" 125} *)

@{b}   FUNCTION@{ub}
   Sends a message of type CNMP_ENTRYPERMIT to a remote port. You must
   be in possesion of a message received from that remote port as that
   message is where PermitEntry gets the port information from.  Usually,
   this message is sent after receipt of a @{"CNMP_ENTRYCONFIRM" Link CNMP_ENTRYCONFIRM} message if
   the remote port is to be allowed to enter/share the CNMP network of
   message ports.

@{b}   INPUTS@{ub}
   rmessage - a pointer to a CNMPMsg received from the remote port
              (ie. a message received using the @{"GetCNMPMsg()" Link GetCNMPMsg()} function)
   echostring - a string that will be displayed to the remote user when his
                port receives the CNMP_ENTRYPERMIT message.
   cluster - the CnmpCluster that was initialized and returned by @{"InitCNMP()" Link InitCNMP()}

@{b}   RESULT@{ub}
   none

@ENDNODE
@NODE HandleNT_REPLYMSG() "HandleNT_REPLYMSG"

@{b}   NAME@{ub}
   HandleNT_REPLYMSG -- Tells CNMP to take care of/reply to messages of type
                        NT_REPLYMSG.

@{b}   SYNOPSIS@{ub}
   HandleNT_REPLYMSG(message)

   void HandleNT_REPLYMSG(struct @{"CNMPMsg" Link include:cnmp/cnmp.h/Main 30} *)

@{b}   FUNCTION@{ub}
   Tells CNMP to take care of/reply to messages of type NT_REPLYMSG. Usually,
   this function is called as soon as @{"HandleIO" Link HandleIO()} returns with the
   @{"ReplyMsg_Event" Link ReplyMsg_Event} bit set and you have gotten the message pointer using
   @{"GetNTReplyMsg()" Link GetNTReplyMsg()}.

@{b}   INPUTS@{ub}
   message - a pointer to the message received from the function
             GetNTReplyMsg()

@{b}   RESULT@{ub}
   none


@ENDNODE
@NODE GetPermission() "GetPermission"

@{b}   NAME@{ub}
   GetPermission -- Asks a remote port for permission to enter/join the
                    set of shared/networked message ports.

@{b}   SYNOPSIS@{ub}
   success = GetPermission(portnum, cluster)

   BOOL GetPermission(LONG, struct @{"CnmpCluster" Link "include:cnmp/cnmp.h/Main" 125} *)

@{b}   FUNCTION@{ub}
   This function sends a message of type @{"CNMP_ENTRYCONFIRM" Link CNMP_ENTRYCONFIRM} to the CNMP message
   port opened on the specified CNet port number.

@{b}   INPUTS@{ub}
   portnum = the CNet port number of the remote CNMP message port.
   cluster - the CnmpCluster that was initialized and returned by @{"InitCNMP()" Link InitCNMP()}

@{b}   RESULT@{ub}
   success = TRUE if message sent, FALSE if error.

@ENDNODE
@NODE RefuseEntry() "RefuseEntry"

@{b}   NAME@{ub}
   RefuseEntry -- Signals a remote port (one that has sent us a
                  @{"CNMP_ENTRYCONFIRM" Link CNMP_ENTRYCONFIRM} message) that it is not allowed to
                  enter/use the shared set of CNMP ports.

@{b}   SYNOPSIS@{ub}
   RefuseEntry(remotemsg, echostr, cluster)

