    ( Logon.Logon.txt           "BBS:Texte/Login.txt" )
    ( Logon.News.txt            "BBS:Texte/News.txt" )
    ( Logoff.GoodBye.txt        "BBS:Texte/GoodBye.txt" )
    ( Menu.Transfer.txt         "BBS:Texte/Menu.Files.txt" )
    ( Menu.Games.txt            "BBS:Texte/Menu.Games.txt" )
    ( Menu.Main.txt             "BBS:Texte/Menu.Main.txt" )
    ( Menu.Message.txt          "BBS:Texte/Menu.Message.txt" )
    ( Menu.Prefs.txt            "BBS:Texte/Menu.Prefs.txt" )
    ( Menu.Stats.txt            "BBS:Texte/Menu.Stats.txt" )
    ( Message.End.txt           "BBS:Texte/Message.End.txt" )
    ( Message.Start.txt         "BBS:Texte/Message.Start.txt" )
    ( Message.SendTo.txt        "BBS:Texte/Message.SendTo.txt" )
    ( Message.User.txt          "BBS:Messages/%User" )
    ( Prefs.Lines.txt           "BBS:Texte/Prefs.Lines.txt" )
    ( Stats.History.txt         "BBS:Texte/Stats.History.txt" )
    ( Stats.LastUsers.txt       "BBS:Texte/Stats.LastUsers.txt" )
    ( Stats.SystemInfo.txt      "BBS:Texte/Stats.SystemInfo.txt" )
    ( Stats.Userlist.txt        "BBS:Texte/Stats.Userlist.txt" )
    ( Transfer.SearchFiles.txt  "BBS:Texte/SearchFiles.txt" )
    ( Transfer.Download.txt     "BBS:Texte/Transfer.Download.txt" )
    ( Transfer.Upload.txt       "BBS:Texte/Transfer.Upload.txt" )
)
( @{"Configs" link "config.configs" 0}
    ( BBS:MicroBBS.cfg.lager )
    ( BBS:MicroBBS.cfg.cd0 )
)
( @{"Externals" link "config.externals" 0}
    ( AfterSession.ext          "BBS:Commands/Aftersession" )
    ( AddLastUser.ext           "BBS:Commands/AddLastUser "%User" %Node %Connect" )
    ( GenUserList.ext           "BBS:Commands/GenUserList" )
    ( SayLogon.ext              "C:Run RexxC:RX 'Address PLAY SAY "-v28 Logon: %User !"" )
    ( SetWho.ext                "C:Echo "   %Node    %User ist online." TO T:Who.%Node" )
)
( @{"Spawns" link "config.spawns" 0}
    ( ShowLogonStats.spw        "BBS:Commands/ShowLoginStats %Calls %Files %AllCalls %AllFiles" )

    ( NuclearWar.spw            "BBS:Doors/StartNuclearWar "%User"" )
