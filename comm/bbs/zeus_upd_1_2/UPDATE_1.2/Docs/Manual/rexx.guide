   SEE ALSO

@rem </PRE>
@endnode

@node "SetMsgArea"
@toc Msg
@rem <PRE>

   NAME
                SetMsgArea -- Sets the configuration of a message area.

   SYNOPSIS
                SetMsgArea [AREA <Area Number>] [NAME <Area Name>] [TAGNAME <Tag Name>]
                                          [BASETYPE <Local|Echomail|Netmail|UUCP|PvtUUCP|Bulletin]
                                          [MAXMSGS <Number>] [LOWACC <Number>] [HIGHACC <Number>]
                                          [ADDRESS <FidoNet Address>] [ORIGIN <Number>]
                                          [EXECUTABLE <Number>] [USENET <UseNet Base>]
                                          [MSGLIB <Message Library>] [GENDER <Male|Female|N/A>]
                                          [AGE <Minimum Age>] [(NO)KLUDGES] [(NO)PATHS] [(NO)SEENBYS]
                                          [(NO)PRIVATE] [(NO)HIASCII] [(NO)QUOTING] [(NO)ALIAS]
                                          [(NO)USERDELMSGS] [(NO)MODERATOR] [(NO)TEXTSTYLES]
                                          [(NO)ANSIBASE] [(NO)MASKOUT] [SAVE] [REMOVEALL] [RELOAD]

   FUNCTION

   INPUTS

   RESULT

   RC
                 0 -- Configuration changed
                 5 -- Could not add message area
                10 -- Bad arguments
                20 -- Out of memory

   EXAMPLE
                /*
                ** Add an example FidoNet echo
                */

                Number = '100'

                /* Add new entry, area number 100 */

                SetMsgArea 'Area' '"'Number'"'

                /* Set area details */

                SetMsgArea 'Area' '"'i'"' 'Name'                 '"'area'"'
                SetMsgArea 'Area' '"'i'"' 'TagName'         '"'area'"'
                SetMsgArea 'Area' '"'i'"' 'BaseType'         '"Echomail"'
                SetMsgArea 'Area' '"'i'"' 'MaxMsgs'         '200'
                SetMsgArea 'Area' '"'i'"' 'LowAcc'                 '0'
                SetMsgArea 'Area' '"'i'"' 'HighAcc'         '255'
                SetMsgArea 'Area' '"'i'"' 'Address'         '1:234/567.8@fidonet'
                SetMsgArea 'Area' '"'i'"' 'Origin'                 '0'
                SetMsgArea 'Area' '"'i'"' 'MsgLib'                 '"mbzeus.library"'
                SetMsgArea 'Area' '"'i'"' 'Gender'                 '"N/A"'
                SetMsgArea 'Area' '"'i'"' 'Age'                         '0'

                SetMsgArea 'Area' '"'i'"' 'Quoting'
                SetMsgArea 'Area' '"'i'"' 'TextStyles'

                SetMsgArea 'Save'

                SetMsgArea 'Reload'

   NOTES

   SEE ALSO
                Zeus:Rexx/MsgTxtCfgCompiler.rexx, GetMsgArea,
                Zeus:Rexx/AddMsgAreas.rexx

@rem </PRE>
@endnode

@node "SetMsgFilter"
@toc Msg
@rem <PRE>

   NAME
                SetMsgFilter -- Sets a read filter used by LoadMsg.

   SYNOPSIS
                SetMsgFilter [NEW <Date>] [AFTER <Date>] [TO <String>] [FROM <String>]
                                                 [SUBJECT <String>] [TEXT <String>] [BEFORE <Date>]
                                                 [COMPLETE] [PARTIAL] [AND] [OR]
        

   FUNCTION

   INPUTS

   RESULT

   RC
                 0 -- Filter set
                 5 -- Bad arguments
                20 -- Fatal error

   EXAMPLE
                /*
                ** Find some messages from Humple Groodfig
                */

                fin  = 0
                Name = 'Humple Groodfig'

                GetPointer 'Low'
                if RC = 0 then do
                        StartPtr = RESULT

                        SetMsgFilter 'From' '"'Name'"'
                        SetMsgFilter 'Complete'

                        do until fin = 1
                                LoadMsg StartPtr 'NoText'
                                if RC = 0 then do
                                        Write '"Message number 'RESULT' is from 'Name'!\n"'

                                        FreeMsg
                                        end
                                else if RC = 1|RC = 4         then  FreeMsg
                                else if RC = 3                         then  iterate
                                else                                                                         fin = 1
                                end

                        DeleteMsgFilter
                        end
                else
                        Write '"Could not get low pointer for area!\n"'

   NOTES

   SEE ALSO

@rem </PRE>
@endnode

@node "SetPointers"
@toc Msg
@rem <PRE>

   NAME
                SetPointers -- Sets message retreival pointers in a message area.

   SYNOPSIS
                SetPointers [AREA <Area Number>] [LOW <Number>] [HIGH <Number>]
                                                [HSBN <Number>]

   FUNCTION

   INPUTS

   RESULT

   RC
                 0 -- Set pointers
                 5 -- Bad arguments
                10 -- Could not set pointers
                20 -- Fatal error

   EXAMPLE
                SetPointers 

   NOTES

   SEE ALSO

@rem </PRE>
@endnode

@node "GetTopicThread"
@toc Msg
@rem <PRE>

   NAME
                GetTopicThread -- Returns start message number of a topic.

   SYNOPSIS
                GetTopicThread <FIRST|LAST|NEXT|PREVIOUS>

   FUNCTION
                Returns a message number from the current topic, as set
                by rexxMsgCommands/GetTopic.

                GetTopicThread requires that a successful call to
                rexxMsgCommands/GetTopic has been made.

                GetTopicThread activates control code %2090.

   INPUTS
                FIRST   - Return the first message in the topic.
                LAST        - Return the last message in the topic.
                NEXT        - Return the next topic. Requires that function
                          has been called with FIRST or LAST argument
                          previously.
                NEXT        - Return the previous topic. Requires that function
                          has been called with FIRST or LAST argument
                          previously.
        

   RESULT
                Message number returned.

   RC
                0  - Message number returned.
                5  - No more messages in thread.
                10 - Bad arguments
                20 - Fatal error

   EXAMPLE

   NOTES

   SEE ALSO
                See rexxMsgCommands/ScanTopics, rexxMsgCommands/GetTopic

@rem </PRE>
@endnode

@node "GiveTemplates"
@toc Msg
@rem <PRE>

   NAME
                GiveTemplates -- Sets the current users message templates.

   SYNOPSIS
                GiveTemplates [MSG]

   FUNCTION
                Assigns the correct user template for message and
                file access according to the access level of the
                current online user.

                This function copies the User Limits for the access
                level as defined in Prefs/Templates into their user
                account.

                Message Limits affected by GiveTemplates:

                Maximum Messages written per Day.

                File Limits affected by GiveTemplates:

                File Ratio
                Byte Ratio
                Free Files
                Free Bytes
                Maximum Number of Bytes per Day.
                Maximum Number of Files per Day.

   INPUTS
                MSG  -- Give Message Templates only.
                FILE -- Give File Templates only.

   RESULT
                None.

   RC
                0  - Template Limits assigned.
                20 - Fatal error.

   EXAMPLE
                /*
                ** New user initialisation
                */

                MakeNewUser '"'UName'"'
                User = RESULT

                if User ~= 0 then do
                        PutOnline User

                        GiveTemplates
                        end
                else
                        Write '"Could not add new user!\n"'

   NOTES

   SEE ALSO
       @{"CopyTemplateLimits" link "CopyTemplateLimits"} @{"GetTemplate" link "GetTemplate"} @{"SetTemplates" link "SetTemplates"}

@rem </PRE>
@endnode

@node "SetMsgData"
@toc Msg
@rem <PRE>

   NAME
                SetMsgData -- Sets information about a message to be saved by WriteMsg.

   SYNOPSIS
                SetMsgData [TO <Addresse>] [FROM <Sender>] [SUBJECT <String>]
                                          [FILEATTACH] [ANON] [DELRECV] [PRIVATE] [CRASH] [HOLD]
                                          [DIRECT] [DESTADDRESS <FidoNet Address>] [CROSSREPLY]
                                          [FORWARD <Area Number> <Message Number> <File Name>]
                                          [ROUTE <FidoNet Address>] [FROMADDRESS <FidoNet Address>]
                                          [REPLY <Message Number> <FileName>] [AREA <Area Number>]
                                          [CLEAR] 

   FUNCTION
                Affects the message header of a new message. When starting
                a new message this function should be called with
                the 'CLEAR' argument only- to initialise the message
                structure and make it ready for use.

                Once the message structure has been fully initialised,
                rexxMsgCommands/WriteMsg will write it out to the message
                database.

                SetMsgData 'CLEAR' sets the following defaults:

                    FROM        - Name/Alias (depending on message base
                                  type) of online user.
                    AREA        - Current message area.
                    PRIVATE     - On if current message base is
                                  "Private"
                    FROMADDRESS - Network bases only. The address
                                  defined in the message area structure.

   INPUTS
                CLEAR       - Initialise the message structure to default
                              values.

                TO          - Addresse of this message.
                FROM        - The author of this message.
                SUBJECT     - The topic this message relates to.
                FILEATTACH  - One or more files are attached to this
                              message (names on subject line).
                ANON        - Sender of message wishes to remain anonymous.
                DELRECV     - Message should be deleted after the
                              addresse of the message receives it.
                PRIVATE     - Message is private.
                CRASH       - Netmail bases only. This message should be
                              sent "Crashmail".
                HOLD        - Netmail bases only. This message should be
                              sent "Holdmail".
                DIRECT      - Netmail bases only. This message should be
                              sent "Directmail".
                DESTADDRESS - The destination FidoNet address of this
                              message. 
                CROSSREPLY  - This message is a reply to a message posted
                              in a different message base.
                FORWARD     - This message is a forward from another
                              message in this area. This argument takes
                              another two values. These values can be
                              omitted if you wish to use the currently
                              loaded message as the message to forward.
                              In this case, a successful call to
                              rexxMsgCommands/LoadMsg should have been
                              made.
                        AREA   - The message area the message to forward can
                                 be found.
                        NUMBER - The number of the message in this base to
                                 forward.
                ROUTE       - Netmail bases only. The FidoNet address to
                              route this message via.
                FROMADDRESS - Netmail bases only. The address this message
                              originated from.
                REPLY       - This message is a reply to <Message Number> in
                              the current base and the quotes, if the
                              message area to write in is a "Quoting" base,
                              should be output to <FileName>
                AREA        - This message should be written in message area
                              <AreaNumber>
                             

   RESULT
                None.

   RC
                 0 -- Data changed
                 2 -- Bad FidoNet address
                 5 -- Bad arguments
                10 -- Error quoting message
                20 -- Fatal error

   EXAMPLE
                SetMsgData 'Clear'
                call delete( 'T:MsgText.'Line )

                SetMsgData 'To'      '"Bill Frompkins"'
                SetMsgData 'Subject' '"Your spleen operation!"'

                /* Don't want just anyone hearing about it! */

                SetMsgData 'Private'

                GetEditor 'Tag' 'Msg'
                Interpret RESULT

                Write '"[32mSend Message? "'
                GetYesNo Yes
                if RC = 0 then do
                        WriteMsg 'T:MsgText.'Line        
                        end
                else
                        Write '"Aborted!\n"'

   NOTES

   SEE ALSO
                rexxMsgCommands/LoadMsg

@rem </PRE>
@endnode

@node "UpdateMsgPointer"
@toc Msg
@rem <PRE>

   NAME
                UpdateMsgPointer -- Sets the last read message in a message area.

   SYNOPSIS
                UpdateMsgPointer [AREA <Area Number>] [NUMBER <Message Number>]
                                                          [NOCHECK]

   FUNCTION
       Updates the user's last read message pointer.

   INPUTS
       AREA    -- number of area to set
       NUMBER  -- highest message number the user has read.
       NOCHECK -- [not used at this time]

   RESULT

   RC

   EXAMPLE
                 0 -- Set high pointer
                 5 -- Bad arguments
                20 -- Fatal error

   NOTES

   SEE ALSO

@rem </PRE>
@endnode

