@{" SEC_CONFACC2.. " Link SEC_CONFACC2} --------------------------------
@{" SECF_DOWNLOAD. " Link SECF_DOWNLOAD} N
@{" SECF_UPLOAD... " Link SECF_UPLOAD} N
@{" SECF_READMSGS. " Link SECF_READMSGS} N
@{" SECF_ENTERMSG. " Link SECF_ENTERMSG} N
@{" SECF_PAGE..... " Link SECF_PAGE} N
@{" SECF_COMMENT.. " Link SECF_COMMENT} N
@{" SECF_BULLETINS " Link SECF_BULLETINS} N
@{" SECF_LISTFILES " Link SECF_LISTFILES} N
@{" SECF_NEWFILES. " Link SECF_NEWFILES} N
@{" SECF_ZIPPY.... " Link SECF_ZIPPY} N
@{" SECF_RUNDOOR.. " Link SECF_RUNDOOR} N
@{" SECF_JOINCONF. " Link SECF_JOINCONF} N
@{" SECF_MSGAREAC. " Link SECF_MSGAREAC} N
@{" SECF_CHANGEINF " Link SECF_CHANGEINF} N
@{" SECF_RELOGIN.. " Link SECF_RELOGIN} N
@{" SECF_TAGED.... " Link SECF_TAGED} N
@{" SECF_VIEWSTATS " Link SECF_VIEWSTATS} N
@{" SECF_VIEWTIME. " Link SECF_VIEWTIME} N
@{" SECF_HYDRA.... " Link SECF_HYDRA} N
@{" SECF_EXPERT... " Link SECF_EXPERT} N
@{" SECF_EALL..... " Link SECF_EALL} N
@{" SECF_FIDOMSG.. " Link SECF_FIDOMSG} N
@{" SECF_PRIVMSG.. " Link SECF_PRIVMSG} N
@{" SECF_READALL.. " Link SECF_READALL} N
@{" SECF_USERED... " Link SECF_USERED} N
@{" SECF_VIEWLOG.. " Link SECF_VIEWLOG} N
@{" SECF_SYSOPDL.. " Link SECF_SYSOPDL} N
@{" SECF_USERLIST. " Link SECF_USERLIST} N
@{" SECF_DELETEANY " Link SECF_DELETEANY} N
@{" SECF_SHELL.... " Link SECF_SHELL} N
@{" SECF_WHO...... " Link SECF_WHO} N
@{" SECF_MOVE..... " Link SECF_MOVE} N
