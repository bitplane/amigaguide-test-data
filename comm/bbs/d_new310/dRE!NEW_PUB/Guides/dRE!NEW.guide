@node "Tooltypes" "...available tooltypes..."
 
 @{b}Available Tooltypes@{ub}
 
 @{b}NAME@{ub}      @{fg shine}HEADER@{fg text}
@{b} INPUT@{ub}     @{fg fill}ALPHANUMERIC@{fg text}
@{b} SYPNOSIS@{ub}  The full path to the header you wish to diplay above the filelist
           disabling will occur a screenclear

@{b} NAME@{ub}      @{fg shine}FILE_COLOR@{fg text}
@{b} INPUT@{ub}     @{fg fill}NUMERIC@{fg text}
@{b} SYPNOSIS@{ub}  A valid ANSI color code in a range of (31-37)
@{b} DEFAULT@{ub}   21

@{b} NAME@{ub}      @{fg shine}FAKE_COLOR@{fg text}
@{b} INPUT@{ub}     @{fg fill}NUMERIC@{fg text}
@{b} SYPNOSIS@{ub}  A valid ANSI color code in a range of (31-37)
@{b} DEFAULT@{ub}   35

@{b} NAME@{ub}      @{fg shine}FILES_PER_LINE@{fg text}
@{b} INPUT@{ub}     @{fg fill}NUMERIC@{fg text}     
@{b} SYPNOSIS@{ub}  Range between 1 and 6, this will take effect to the output
           how many files are placed in one line.
@{b} DEFAULT@{ub}   6

@{b} NAME@{ub}      @{fg shine}SORT_BY_NAME@{fg text}
@{b} INPUT@{ub}     @{fg fill}NONE (SWITCH)@{fg text}     
@{b} SYPNOSIS@{ub}  Set this Tooltype to sort all files by name.
@{b} DEFAULT@{ub}   OFF

@{b} NAME@{ub}      @{fg shine}MAKE_LOWER@{fg text}
@{b} INPUT@{ub}     @{fg fill}NONE SWITCH@{fg text}     
@{b} SYPNOSIS@{ub}  Will change all filenames to lowercase
@{b} DEFAULT@{ub}   OFF

@{b} NAME@{ub}      @{fg shine}MAKE_UPPER@{fg text}
@{b} INPUT@{ub}     @{fg fill}NONE SWITCH@{fg text}     
@{b} SYPNOSIS@{ub}  Will change all filenames to uppercase
@{b} DEFAULT@{ub}   OFF

@{b} NAME@{ub}      @{fg shine}SHOW_DATE@{fg text}
@{b} INPUT@{ub}     @{fg fill}NONE (SWITCH)@{fg text}     
@{b} SYPNOSIS@{ub}  En/disabling the datline below the door
@{b} DEFAULT@{ub}   OFF

                         @{b}@{fg shine}- --------------------- -@{ub}@{fg text}
                           @{b}ANSI code description@{ub}
                         @{b}@{fg shine}- --------------------- -@{ub}@{fg text}

                   21 - ANSI OFF
                   30 - black              34 - darkblue
                   31 - white/red          35 - magneta
                   32 - green              36 - cyan
                   33 - yellow             37 - red/white
@endnode

