  @{" ZMapabsender " Link "ZMAPABS"                }        Absender für die Z-MAP`s
  @{" neue Bretter " Link "NetzdatenneueBretter"   }        wohin mit neuen Brettern
  @{" Netzboxname  " Link "NetzdatenNetzname"      }        Mailboxname/Netzname
  @{" Zeitzone     " Link "NetzdatenZeitzone"      }        für die Header
  @{" Brief KB     " Link "NetzdatenBriefKB"       }        maximale Größe
  @{" Pufferkopien " Link "NetzdatenKopien"        }        Anzahl der Kopien  
  @{" Wahlversuche " Link "NetzdatenWahlversuche"  }        Anzahl der Wahlversuche
  @{" Wahlpause    " Link "NetzdatenWahldelay"     }        Pause zwischen den Anrufen
  @{" Neuwahlversuche " Link "Neuversuche"         }     bis der Netzanruf erfolgreich ist
  @{" MsgID Haltezeit " Link "NetzdatenHaltezeit"  }     in Tage angeben
