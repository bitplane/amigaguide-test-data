@ENDNODE
@NODE StandardPortprio "Prometheus Explorer 1994-96 © Rudolf Lau"

@{FG Highlight} - Portprio - @{FG Text}

Default: 0

@ENDNODE
@NODE StandardSorterprio "Prometheus Explorer 1994-96 © Rudolf Lau"

