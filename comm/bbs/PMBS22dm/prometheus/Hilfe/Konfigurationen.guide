  @{" Puffermem " Link "Puffermem"}                         @{" Editortext " Link "DimEditortext"}
  @{" Lesepuffer " Link "Lesepuffer"}                        @{" Briefkasten " Link "DimBriefkasten"}
  @{" Schreibpuffer " Link "Schreibpuffer"}  

  @{" Ende " Link "SpeicherEnde"}

@ENDNODE
