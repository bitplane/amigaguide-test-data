     @{" Sysoplogin " Link "ServerSysopLogin"}            @{i}Shortcut @{ui} @{b}AMIGA + S@{ub}
     @{" Sysopoberflšche " Link "Prometheus:Hilfe/SysopOberFlšche.guide/MAIN"}       @{i}Shortcut @{ui} @{b}AMIGA + .@{ub}
     @{" SchloŖ " Link "ServerSchloŖ"}                @{i}Shortcut @{ui} @{b}AMIGA + Ŗ@{ub}
     @{" Netzanruf " Link "ServerNetzcall"}             @{i}Shortcut @{ui} @{b}AMIGA + L@{ub}
     @{" Iconify " Link "ServerIconify"}               @{i}Shortcut @{ui} @{b}AMIGA + I@{ub}
     @{" Puffer sortieren " Link "Serversort"}      @{i}Shortcut @{ui} @{b}AMIGA + P@{ub}
