@DATABASE "pmbsonline.guide"
@REMARK    pmbsonline.guide & pmbsonline.doc von Mirko Thöle

@NODE MAIN "pmbsonline.doc"

                             @{b}pmbsonline.library@{ub}

@{"pt_OpenPrometheus      " LINK "pt_OpenPrometheus"} Öffnet den Prometheusport
@{"pt_ClosePrometheus     " LINK "pt_ClosePrometheus"} Schliesst die Prometheusschnittstelle
@{"pt_Send                " LINK "pt_Send"} Sendet einen String ueber das Modem und Bildschirm
@{"pt_Read                " LINK "pt_Read"} Liest beliebig viele Zeichen von der Tastatur ein.
@{"pt_BlueRead            " LINK "pt_BlueRead"} Liest beliebig viele Zeichen von der Tastatur ein.
@{"pt_Quit                " LINK "pt_Quit"} Signalisiert PMBS Schliessung des Programmes.
@{"pt_AnsiStatus          " LINK "pt_AnsiStatus"} Prueft ob der User Ansi anhat
@{"pt_AskUser             " LINK "pt_AskUser"} Liefert den Namen eines eingeloggten Users.
@{"pt_AskLog              " LINK "pt_AskLog"} Fragt nach Consolen oder Modemlogin.
@{"pt_AskBoxname          " LINK "pt_AskBoxname"} Fragt nach dem Namen der Mailbox.
@{"pt_ReceiveFile         " LINK "pt_ReceiveFile"} Empfaengt ein File ueber das Modem.
@{"pt_Sendfile            " LINK "pt_Sendfile"} Sendet ein File ueber das Modem.
@{"pt_CheckCarrier        " LINK "pt_CheckCarrier"} Prueft ob ein Carrier besteht.
@{"pt_Typefile            " LINK "pt_Typefile"} Sendet ein TextFile ueber das Modem.
@{"pt_GetChar             " LINK "pt_GetChar"} Liefert sofort eine gedrueckte Taste zurueck.
@{"pt_Command             " LINK "pt_Command"} Fuehrt einen Prometheus Befehl aus.
@{"pt_Arexx               " LINK "pt_Arexx"} Fuehrt einen Promehteus-ArexxBefehl aus.

@ENDNODE

@NODE "pt_OpenPrometheus" "pmbsonline.library/pt_OpenPrometheus()"
@{b}

   NAME@{ub}
       pt_OpenPrometheus - Öffnet den Prometheusport@{b}

   SYNOPSIS@{ub}
       PMBSPort = pt_OpenPrometheus(Portnummer)
                                     d0

       LONG pt_OpenPrometheus(LONG);@{b}

   FUNCTION@{ub}
       Diese Routine öffnet den Port zu Prometheus.
       Dies muss immer gemacht werden, wenn Portbefehle genutzt werden.@{b}

   INPUTS@{ub}
       Portnummer -- Eine Nummer von 0-9 (0 = Mainport)@{b}

   RESULTS@{ub}
       PMBSPort -- Adresse des Prometheusportes.@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}
       @{"pt_ClosePrometheus()" LINK "pt_ClosePrometheus"};@{b}

   BUGS@{ub}
       Diese Funktion gibt immer eine Adresse zurueckt, auch bei einem FAIL

@ENDNODE
@NODE "pt_ClosePrometheus" "pmbsonline.library/pt_ClosePrometheus()"
@{b}

   NAME@{ub}
       pt_ClosePrometheus - Schliesst die Prometheusschnittstelle@{b}

   SYNOPSIS@{ub}
       pt_ClosePrometheus(PMBSPort)
                            d0

       void pt_ClosePrometheus(LONG);@{b}

   FUNCTION@{ub}
       Diese Routine schliesst den mit @{"pt_OpenPrometheus()" LINK "pt_OpenPrometheus"} geöffneten
       PrometheusPort. Dies muss immer am ende gemacht werden.@{b}

   INPUTS@{ub}
       PMBSPort -- Adresse des Prometheusportes.@{b}

   RESULTS@{ub}@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}
       @{"pt_OpenPrometheus()" LINK "pt_OpenPrometheus"};@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_Send" "pmbsonline.library/pt_Send()"
@{b}

   NAME@{ub}
       pt_Send - Sendet einen String ueber das Modem und Bildschirm@{b}

   SYNOPSIS@{ub}
       pt_Send(PMBSPort, String)
                 d0        a0

       void pt_Send(LONG, char *);@{b}

   FUNCTION@{ub}
       Diese  Routine senden den Text mit Umlautwandlung auf den Bildschirm
       und ueber das Modem.@{b}

   INPUTS@{ub}
       PMBSPort -- Adresse des Prometheusportes.
       String   -- Pointer auf einen mit 0 abgeschlossenen String.@{b}

   RESULTS@{ub}@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_Read" "pmbsonline.library/pt_Read()"
@{b}

   NAME@{ub}
       pt_Read - Liest beliebig viele Zeichen von der Tastatur ein.@{b}

   SYNOPSIS@{ub}
       pt_Read(PMBSPort, Zeichen, Buffer)
                 d0        a1       a0

       void pt_Read(LONG, LONG, char *);@{b}

   FUNCTION@{ub}
       Mit dieser Funktion kann man beliebig viele Zeichen eingeben lassen.
       Das Ergebnis im Buffer ist IMMER mit einem 0-Byte abgeschlossen.@{b}

   INPUTS@{ub}
       PMBSPort -- Adresse des Prometheusportes.
       Zeichen  -- Anzahl der einzugebenen Zeichen.
       Buffer   -- Pointer  auf  einen  Bereich, in  dem  der  Text  mit 0
                   abgeschlossen geschrieben wird@{b}

   RESULTS@{ub}
       Siehe Buffer@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}
        @{"pt_BlueRead()" LINK "pt_BlueRead"}, @{"pt_GetChar()" LINK "pt_GetChar"};@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_BlueRead" "pmbsonline.library/pt_BlueRead()"
@{b}

   NAME@{ub}
       pt_BlueRead - Liest beliebig viele Zeichen von der Tastatur ein.@{b}

   SYNOPSIS@{ub}
       pt_BlueRead(PMBSPort, Zeichen, Buffer)
                     d0        a1       a0

       void pt_BlueRead(LONG, LONG, char *);@{b}

   FUNCTION@{ub}
       Mit dieser Funktion kann man beliebig viele Zeichen eingeben lassen.
       Das Ergebnis im Buffer ist IMMER mit einem 0-Byte abgeschlossen.
       Der Bereich, in dem der Text eingegeben wird ist Blau unterlegt.@{b}

   INPUTS@{ub}
       PMBSPort -- Adresse des Prometheusportes.
       Zeichen  -- Anzahl der einzugebenen Zeichen.
       Buffer   -- Pointer  auf  einen  Bereich, in  dem  der  Text  mit 0
                   abgeschlossen geschrieben wird@{b}

   RESULTS@{ub}
       Siehe Buffer@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}
        @{"pt_Read()" LINK "pt_Read"}, @{"pt_GetChar()" LINK "pt_GetChar"};@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_Quit" "pmbsonline.library/pt_Quit()"
@{b}

   NAME@{ub}
       pt_Quit - Signalisiert PMBS Schliessung des Programmes.@{b}

   SYNOPSIS@{ub}
       pt_Quit(PMBSPort)
                  d0

       void pt_Quit(LONG);@{b}

   FUNCTION@{ub}
       Diese  Funktion  signalisiert  Prometheus, dass das externe Programm
       beendet ist. Sie muss vor @{"pt_ClosePrometheus()" LINK "pt_ClosePrometheus"} aufgerufen werden.@{b}

   INPUTS@{ub}
       PMBSPort -- Adresse des Prometheusportes.@{b}

   RESULTS@{ub}@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}
        @{"pt_ClosePrometheus()" LINK "pt_ClosePrometheus"};@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_AnsiStatus" "pmbsonline.library/pt_AnsiStatus()"
@{b}

   NAME@{ub}
       pt_AnsiStatus - Prueft ob der User Ansi anhat@{b}

   SYNOPSIS@{ub}
       Emulation = pt_AnsiStatus(PMBSPort)
                                   d0

       LONG pt_AnsiStatus(LONG);@{b}

   FUNCTION@{ub}
       Hiermit kann man pruefen, ob der eingeloggte User die Ansi-Emulation
       angeschaltet hat.@{b}

   INPUTS@{ub}
       PMBSPort -- Adresse des Prometheusportes.@{b}

   RESULTS@{ub}
       Emulation -- 0 == Ansi aus, 1 == Ansi an.@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_AskUser" "pmbsonline.library/pt_AskUser()"
@{b}

   NAME@{ub}
       pt_AskUser -  Liefert den Namen eines eingeloggten Users.@{b}

   SYNOPSIS@{ub}
       pt_AskUser(PMBSPort, Buffer)
                     d0       a0

       void pt_AskUser(LONG, char *);@{b}

   FUNCTION@{ub}
       Diese Funktion liefert den Usernamen desjenigen, der das Programm
       aufgerufen hat.@{b}

   INPUTS@{ub}
       PMBSPort -- Adresse des Prometheusportes.
       Buffer   -- Pointer  auf  einen  Bereich, in  dem  der  Text  mit 0
                   abgeschlossen geschrieben wird@{b}

   RESULTS@{ub}
       Siehe Buffer@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_AskLog" "pmbsonline.library/pt_AskLog()"
@{b}

   NAME@{ub}
       pt_AskLog - Fragt nach Consolen oder Modemlogin.@{b}

   SYNOPSIS@{ub}
       Logtyp = pt_AskLog(PMBSPort)
                          d0

       LONG pt_AskLog(LONG);@{b}

   FUNCTION@{ub}
       Mit dieser Funktion kann man erfragen ob der User sich von der
       Console eingeloggt hat, oder mit dem Modem.@{b}

   INPUTS@{ub}
       PMBSPort -- Adresse des Prometheusportes.@{b}

   RESULTS@{ub}
       Liefert 0 wenn Consolenlogin
       Liefert 1 wenn Modemlogin@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_AskBoxname" "pmbsonline.library/pt_AskBoxname()"
@{b}

   NAME@{ub}
       pt_AskBoxname - Fragt nach dem Namen der Mailbox.@{b}

   SYNOPSIS@{ub}
       pt_AskLog(PMBSPort, Buffer)
                            d0

       void pt_AskLog(LONG, char *);@{b}

   FUNCTION@{ub}
       Diese Funktion liefert in Buffer den Namen der Mailbox.
       Buffer ist mit einem 0-Byte abgeschlossen.@{b}

   INPUTS@{ub}
       PMBSPort -- Adresse des Prometheusportes.@{b}

   RESULTS@{ub}
       Buffer -- Name der Mailbox mit einem 0-Byte abgeschlossen.@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_ReceiveFile" "pmbsonline.library/pt_ReceiveFile()"
@{b}

   NAME@{ub}
       pt_ReceiveFile - Empfaengt ein File ueber das Modem.@{b}

   SYNOPSIS@{ub}
       pt_ReceiveFile(PMBSPort)
                        d0

       void pt_ReceiveFile(LONG);@{b}

   FUNCTION@{ub}
       Diese Funktion empfaengt ein oder mehrere Files ueber das
       Modem in das aktuelle Verzeichniss.
       Die/den Filenamen muss der Programmierer selber herausbekommen.
       Es empfiehlt sich vorher mit dem Prometheus-Arexxbefehl SETCD
       in ein leeres Verzeichniss zu wechseln.@{b}

   INPUTS@{ub}
       PMBSPort -- Adresse des Prometheusportes.@{b}

   RESULTS@{ub}@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}
       @{"pt_Sendfile()" LINK "pt_Sendfile"}@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_Sendfile" "pmbsonline.library/pt_Sendfile()"
@{b}

   NAME@{ub}
       pt_Sendfile - Sendet ein File ueber das Modem.@{b}

   SYNOPSIS@{ub}
       pt_Sendfile(PMBSPort, Filename)
                      d0         a0

       void pt_Sendfile(LONG, char *);@{b}

   FUNCTION@{ub}
       Diese Funktion sendet ein File an den User.@{b}

   INPUTS@{ub}
       PMBSPort  --  Adresse des Prometheusportes.
       Filename  --  Ein Pointer auf einen mit einem 0-Byte abgeschlossenen
                     Filenamen.@{b}
   RESULTS@{ub}@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}
       @{"pt_ReceiveFile()" LINK "pt_ReceiveFile"}@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_CheckCarrier" "pmbsonline.library/pt_CheckCarrier()"
@{b}

   NAME@{ub}
       pt_CheckCarrier - Prueft ob ein Carrier besteht.@{b}

   SYNOPSIS@{ub}
       Carrier pt_CheckCarrier(PMBSPort)
                               d0

       LONG pt_CheckCarrier(LONG);@{b}

   FUNCTION@{ub}
       Mit  dieser  Funktion  kann  man  ueberpruefen  ob  noch ein Carrier
       besteht.@{b}

   INPUTS@{ub}
       PMBSPort  --  Adresse des Prometheusportes.@{b}

   RESULTS@{ub}
       Carrier -- entaehlt eine 0, wenn kein Carrier besteht.
                  entaehlt eine 1, wenn ein Carrier besteht.@{b}

   EXCEPTIONS@{ub}
       In Carrier steht immer eine 0, wenn ein Consolenlogin besteht.@{b}


   SEE ALSO@{ub}
       @{"pt_AskLog()" LINK "pt_AskBoxname"}@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_Typefile" "pmbsonline.library/pt_Typefile()"
@{b}

   NAME@{ub}
       pt_Typefile - Sendet ein TextFile ueber das Modem.@{b}

   SYNOPSIS@{ub}
       pt_Typefile(PMBSPort, Filename)
                     d0          a1

       void pt_Typefile(LONG, char *);@{b}

   FUNCTION@{ub}
       TypeFile  gibt  den  Inhalt  eines TextFiles ueber die Serielle aus.
       Beachtet wird hierbei unter anderem auch das Paging.@{b}

   INPUTS@{ub}
       PMBSPort  --  Adresse des Prometheusportes.
       Filename  --  Pointer  auf  einen  mit  einem 0-Byte abgeschlossenen
                     Filenamen.@{b}

   RESULTS@{ub}@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_GetChar" "pmbsonline.library/pt_GetChar()"
@{b}

   NAME@{ub}
       pt_GetChar - Liefert sofort eine gedrueckte Taste zurueck.@{b}

   SYNOPSIS@{ub}
       pt_GetChar(PMBSPort, Buffer)
                     d0      a0

       void pt_GetChar(LONG, char *);@{b}

   FUNCTION@{ub}
       Diese  Funktion  springt  immer  SOFORT  zurück!  Wenn der User also
       nichts gedrückt hat, wird auch nur ein 0 Byte zurück gegeben!  Diese
       Funktion  ist also nur in einer Schleife sinnvoll!  Sie liefert wenn
       überhaupt  in  den  Buffer  einen  Buchstaben + 0 Byte zurück.  Wenn
       nichts gedrückt wurde halt nur ein 0 Byte@{b}

   INPUTS@{ub}
       PMBSPort  --  Adresse des Prometheusportes.@{b}

   RESULTS@{ub}
       Buffer   --   Pointer  auf  einen  Buffer,  in  dem  Prometheus  den
                     eingegebenen  Buchstaben  schreibt.  Buffer wird IMMER
                     mit einem 0-Byte abgeschlossen.@{b}
   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}
       @{"pt_Read()" LINK "pt_Read"}, @{"pt_BlueRead()" LINK "pt_BlueRead"}@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_Command" "pmbsonline.library/pt_Command()"
@{b}

   NAME@{ub}
       pt_Command - Fuehrt einen Prometheus Befehl aus.@{b}

   SYNOPSIS@{ub}
       pt_Command(PMBSPort, String)
                     d0      a0

       void pt_Command(LONG, char *);@{b}

   FUNCTION@{ub}
       Mit  dieser Funktion ist es moeglich einen Prometheus eigenen Befehl
       auszufuehren (I *, B *).@{b}

   INPUTS@{ub}
       PMBSPort  --  Adresse des Prometheusportes.
       String    --  Pointer  auf einen mit 0 abgeschlossenen String Dieser
                     String  muss  ein  Prometheus  Befehl  wie B * oder so
                     etwas sein!@{b}

   RESULTS@{ub}@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}
       @{"pt_Arexx()" LINK "pt_Arexx"}:@{b}

   BUGS@{ub}

@ENDNODE
@NODE "pt_Arexx" "pmbsonline.library/pt_Arexx()"
@{b}

   NAME@{ub}
       pt_Arexx - Fuehrt einen Promehteus-ArexxBefehl aus.@{b}

   SYNOPSIS@{ub}
       pt_Arexx(PMBSPort, String, Buffer)
                     d0      a0    a1

       void pt_Arexx(LONG, char *,  char *);@{b}

   FUNCTION@{ub}
       Mit  dieser  Funktion  ist  es  moeglich  die  kompletten Prometheus
       eigenen Arexx-Befehle zu nutzen.@{b}

   INPUTS@{ub}
       PMBSPort  --  Adresse des Prometheusportes.
       String    --  Pointer auf einen  mit  einem  0-Byte  abgeschlossenen
                     Bereich, der als  ArexxBefehl  an  Prometheus gesendet
                     wird.@{b}

   RESULTS@{ub}
        Buffer -- Pointer auf einen Bereich, nach dem Prometheus den Result
                  des ArexxBefehles schreibt.@{b}

   EXCEPTIONS@{ub}@{b}

   SEE ALSO@{ub}
       @{"pt_Command()" LINK "pt_Command"}:@{b}

   BUGS@{ub}

@ENDNODE
