@SMARTWRAP
@{U}@{B}Der interne Interpreter@{UB}

            @{" Allgemeines     " LINK DIR_INTERPRET}

1.) @{B}Die Steuerungskommandos@{UB}

            @{" Batchbefehle    " LINK STEU_BATCH}

2.) @{B}Die Datenfelder@{UB}

