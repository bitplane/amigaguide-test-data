@NODE "TMS" "TMS"
@TOC "MAIN"
@{fg highlight}@{b}                 T e m p e s t   M a s t e r   S e r v e r@{ub}@{fg text}
                 
                @{b}Tempest Master Server v1.0 Demo (25-Sep-94)@{ub}

                  `TMS' © Copyright 1994 by Richard Vinco
                            All rights reserved

