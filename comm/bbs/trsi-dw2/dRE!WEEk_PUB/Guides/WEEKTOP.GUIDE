@node "MENU_Install" "Menu Install..."
 
 @{b}MENUITEM INSTALL@{ub}
 
 This item has the same function as the @{"install button" link "Install" 0}.
@endnode

@node "MENU_Change" "Menu Change..."
 
 @{b}MENUITEM CHANGE@{ub}
 
 This item has the same function as the @{"change button" link "Change" 0}.
@endnode

@node "MENU_Reset" "Menu Reset..."
 
 @{b}MENUITEM RESET@{ub}
 
 This Item has the same function as the @{"reset button" link "Reset" 0}.
@endnode

@node "MENU_Remove" "Menu Remove..."
 
 @{b}MENUITEM REMOVE@{ub}
 
 This Item has the same function as the @{"remove button" link "Remove" 0}.
@endnode

@node "MENU_Edit" "Menu Edit..."
 
 @{b}MENUITEM EDITDATA@{ub}
 
 Here will popup another window with a list of all user from the dre!week data
 of the actual conference. Select a user by @{b}double-click@{ub} or by pressing the 
 @{u}edit@{uu} button to change it`s values. After editing press @{u}save@{uu} to keep the
 new values or press @{u}abort@{uu} to hold the old values.
 
 Also you`re able to remove a user from the database just select`em nd press
 the @{u}remove@{uu} button.
 
 @{b}NOTE:@{ub} @{fg shine}This option is non functional in this version of the preferences program,
       but it will be implemented in the next version.@{fg text}
@endnode

@node "MENU_About" "Menu About..."
 
 @{b}MENUITEM ABOUT@{ub}
 
 Here a requester will popup with some informations about this program.
@endnode

@node "MENU_Help" "Menu Help..."
 
 @{b}MENUITEM HELP@{ub}
 
 @{b}@{fg shine}The preferences-program of dre!week support the standard amigaguide help.@{ub}@{fg text}

 This means you can move your mouse button about any gadget or pull-down the
 menu move the mouse to the correct item you wish to know help and press your
 help key, the GUI will try to launch the amigaguide helpfile with the 
 @{b}correct@{ub} node.
 
 @{b}By choosing this item the amigaguide will be displayed with the main-node.@{ub}
@endnode

@node "MENU_Quit" "Menu Quit..."
 
 @{b}MENUITEM QUIT@{ub}
 
 Choose this item to quit the preferences program for dre!week.
@endnode

@node "SaveBytes" "Save less Upload bytes"
 
 @{b}Save less Upload bytes...@{ub}
 
 If you have defined a @{"min. U/L Byte ratio" link "MinBytes" 0}, and a User uploads less than this
 amount of bytes, you can save this bytes to the dat file, and if he uploads
 next day more he will get this amount of bytes to the new uploaded bytes.
@endnode

@node "AllTimeBull" "Create Alltime Bulletin"
 
 @{b}CHECKMARK CREATE ALLTIME BULLETIN@{ub}
 
 If you enable this switch, dRE!WEEk will create a Bulletin with all the best
 uploader of the current week`s.
 
 @{b}NOTE:@{ub} !!! To use this option you @{b}MUST@{ub} define a @{"Bulletinpath" link "BullPath" 0} !!!
@endnode

@node "WeeklyBull" "Create Weekly Bulletin"
 
 @{b}CHECKMARK CREATE WEEKLY BULLETIN@{ub}
 
 If you enable this switch, dRE!WEEk will create at the end of each period a
 Bulletin file with the final result of the last week.
 
 @{i}The outputfile will be posted in your defined bulletin path named
 dRE!WEEk.Conf<CONFNUM>.week<WEEKNUM>, just add this path to your Bulletins.
 In further time I`ll add a weektop viewer to the dRE!WEEk package.@{ui}

@{b} NOTE:@{ub} !!! To use this option you @{b}must@{ub} define a bulletin path !!!
@endnode

@node "UnUsed1" "UnUsed Checkbox..."
 
 @{b}CHECKMARK Unused@{ub}
 
 This Gadget is not in use...
@endnode

@node "UnUsed2" "UnUsed Checkbox..."
 
 @{b}CHECKMARK Unused@{ub}
 
 This Gadget is not in use...
@endnode

@node "BullPath" "Enter Bulletinpath..."
 
 @{b}STRINGGADGET BULLETIN PATH@{ub}
 
 Here you must enter the bulletin path to output the weekly (and/or) alltime
 bulletins.
@endnode

@node "GetBullPath" "Get Bulletinpath via ASL Requester..."
 
 @{b}THE GETBULLETINPATH BUTTON@{ub}
 
 Press this button to popup an ASL requester to choose the path to output the
 weektop bulletins...
@endnode

