@node "dRE!jOiN" "How to use..."
 
 @{b}HOW TO USE dRE!jOiN v1.2@{ub}
 
  @{"áá" link "ConfMenu" 0} - The Conference Menu
  @{"áá" link "FastJoin" 0} - The Fastjoin commands
  @{"áá" link "Directjoin" 0} - Joining conferences directly via Ie: `J 2`
  @{"áá" link "Tooltypes" 0} - Available Tooltypes
  @{"áá" link "Headerfile" 0} - The Headerfile
@endnode

@node "ConfMenu" "The Conference Menu..."
 
 THE CONFERENCE MENU
 
 Here you can choose your preferred conference to join, if relative 
 conferences are switched on, the user will see @{u}only@{uu} those conferences
 he has access to. Otherwise he will see @{u}all@{uu} conferences but all those he
 hasn`t access to are marked with another color and @{u}NOT@{uu} accessable from
 the door.
 
 If a conference is protected with a password, the door will ask the user
 for the defined pw, if he failed to enter the pw in your given range of
 possible fails, the door will search for the @{"DROPDTR" link "Tooltypes" 0} tooltype, if found
 dre!join will @{u}drop@{uu} the user and @{u}writes a remark to the callerslog@{uu}.
 
 The menu is @{u}full@{uu} cursor supported (@{u}also PC key`s@{uu}) you can move the cursor
 in each way (up/down/left/right).
 
 View Tooltypes for more informations...
@endnode

@node "FastJoin" "The Fastjoin commands"
 
 @{b}JOIN CONFERENCES WITH '>' OR '<'@{ub}
 
 You also can join conferences with the arrows left or right, dre!join will
 test if the user has access to the next or previous conference if so, it
 will check for the password, if one is given it will ask for it, if the
 user failed to enter the right pw in your given range of possible pw
 failures he will drop the user if you have set the tooltype @{"DROPDTR" link "Tooltypes" 0}.
 
 If the hasn`t access to the choosen conference dre!join will display it`s 
 confmenu and the user can choose via the menu his preferred conference.
 The same will happen if there is no higher or lower conference available.
@endnode

@node "Directjoin" "Join conferences directly  "
 
 @{b}DIRECT JOIN WITH J <CONFNUM>@{ub}
 
 You are also able to join conferences with the J <confnum> command, the door
 will read the first given argment after the J command and will try to access
 the conference, if the access is denied the user will see the conference
 menu and can choose from the his preferred conference.
 
 @{u}Password protection with the dropdtr feature is also supported.@{uu}
@endnode

@node "Tooltypes" "All available tooltypes"
 
 ALL AVAILABLE TOOLTYPES
 
 @{b}@{fg fill}NAME:@{ub}@{fg text}     @{b}LOGFILE@{ub}
 @{b}@{fg fill}INPUT:@{ub}@{fg text}    @{fg shine}NONE (BOOLEAN)@{fg text}
 @{b}@{fg fill}SYPNOSIS:@{ub}@{fg text} If this tooltype is set, dre!join will all actions to the
           Callerslog
 
 @{b}@{fg fill}NAME:@{ub}@{fg text}     @{b}DUALLIST@{ub}
 @{b}@{fg fill}INPUT:@{ub}@{fg text}    @{fg shine}NOT IMPLEMETED RIGHT NOW@{fg text}
 @{b}@{fg fill}SYPNOSIS:@{ub}@{fg text} ---
 
 @{b}@{fg fill}NAME:@{ub}@{fg text}     @{b}SHOW_CONF@{ub}
 @{b}@{fg fill}INPUT:@{ub}@{fg text}    @{fg shine}NONE (BOOLEAN)@{fg text}
 @{b}@{fg fill}SYPNOSIS:@{ub}@{fg text} If this tooltype is set, dre!join will show the user his actual
           conference
 
 @{b}@{fg fill}NAME:@{ub}@{fg text}     @{b}PW_OVERRIDE@{ub}
 @{b}@{fg fill}INPUT:@{ub}@{fg text}    @{fg shine}NUMERIC (RANGE 1 - ????)@{fg text}
 @{b}@{fg fill}SYPNOSIS:@{ub}@{fg text} All Users with the same or higher accesslevel are skipped for
           the conference password entry
 
 @{b}@{fg fill}NAME:@{ub}@{fg text}     @{b}DROPDTR@{ub}
 @{b}@{fg fill}INPUT:@{ub}@{fg text}    @{fg shine}NONE (BOOLEAN)@{fg text}
 @{b}@{fg fill}SYPNOSIS:@{ub}@{fg text} If this tooltype is set the users are droped from your BBS after
           a valid conference password failure
 
 @{b}@{fg fill}NAME:@{ub}@{fg text}     @{b}DROP_DTR_AFTER@{ub}
 @{b}@{fg fill}INPUT:@{ub}@{fg text}    @{fg shine}NUMERIC (RANGE 1 - ????)@{fg text}
 @{b}@{fg fill}SYPNOSIS:@{ub}@{fg text} Here you set the possible conference password failures, after this
           value the user will dropped from your bbs if the DROPDTR tooltype
           is set.
 
 @{b}@{fg fill}NAME:@{ub}@{fg text}     @{b}HEADER_PATH@{ub}
 @{b}@{fg fill}INPUT:@{ub}@{fg text}    @{fg shine}ALPHANUMERIC@{fg text}
 @{b}@{fg fill}SYPNOSIS:@{ub}@{fg text} Here you can specify the headerpath to your own header.
           @{u}NOTE: This tooltype must be setted.@{uu}
 
 @{b}@{fg fill}NAME:@{ub}@{fg text}     @{b}HEADER_LINES@{ub}
 @{b}@{fg fill}INPUT:@{ub}@{fg text}    @{fg shine}NUMERIC (RANGE 1 - ????)@{fg text}
 @{b}@{fg fill}SYPNOSIS:@{ub}@{fg text} The number of lines of your own headerfile. @{b}DON`T COUNT THE CTRL&L@{ub}
 
 @{b}@{fg fill}NAME:@{ub}@{fg text}     @{b}PW.<CONFNUM>@{ub}
 @{b}@{fg fill}INPUT:@{ub}@{fg text}    @{fg shine}NUMERIC (VALID CONFERENCE NUMBER)@{fg text}
 @{b}@{fg fill}SYPNOSIS:@{ub}@{fg text} Here you can define the conference password`s
           PW.4=Password means the conference #4 is protected with the 
           pw `password`
@endnode

@node "Headerfile" "The Headerfile"
 
 @{b}THE HEADERFILE@{ub}
 
 You can add individual your own conference header just replace the file
 dRE!jOiN.header the the DOORS:dRE!jOiN/ drawer against your own header
 file, here you have to attent that`s dre!join make @{b}NO@{ub} screenclear, you self
 have to do this. Next important thing is you have to @{u}count@{uu} your headerlines
 and to change the tooltype @{"HEADER_LINES" link "Tooltypes" 0} in the program icon. This is really
 important because dre!join @{b}HAS@{ub} to know where the first conference line is.
@endnode

