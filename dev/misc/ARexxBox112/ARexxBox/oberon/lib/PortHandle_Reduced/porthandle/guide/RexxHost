  BT := BasicTypes,
  d := Dos,
  e := Exec,
  P := PublicPorts,
  rx := Rexx;

TYPE
  RexxHostPtr = POINTER TO RexxHost;
  RexxHost = RECORD (P.PublicPort) 
@{b}    replies : LONGINT;@{ub}
@{b}    extension : ARRAY 10 OF CHAR;@{ub}
@{b}    PROCEDURE (VAR rxh:RexxHost) ReplyMsg(rxmsg: rx.RexxMsgPtr; primary: LONG@{ub}
INT; secondary: e.ADDRESS; result: BT.DynString);
@{b}    PROCEDURE (VAR rxh:RexxHost) FreeCommand(rxmsg: rx.RexxMsgPtr);@{ub}
@{b}    PROCEDURE (VAR rxh:RexxHost) CreateCommand(buff: ARRAY OF CHAR; fh: d.Fil@{ub}
eHandlePtr): rx.RexxMsgPtr;
@{b}    PROCEDURE (VAR rxh:RexxHost) MsgToRexx(rxCmdMsg: rx.RexxMsgPtr): rx.RexxM@{ub}
sgPtr;
@{b}    PROCEDURE (VAR rxh:RexxHost) HandleResult(rxCmdMsg: rx.RexxMsgPtr);@{ub}
@{b}    PROCEDURE (VAR rxh:RexxHost) SendCommand(buff: ARRAY OF CHAR; fh: d.FileH@{ub}
andlePtr): rx.RexxMsgPtr;
@{b}    PROCEDURE (VAR rxh:RexxHost) HandleCommand(rxmsg: rx.RexxMsgPtr);@{ub}
@{b}    PROCEDURE (VAR rxh:RexxHost) HandleFunction(rxmsg: rx.RexxMsgPtr);@{ub}
@{b}    PROCEDURE (VAR rxh:RexxHost) Uninit;@{ub}
