@node examples
6. EXAMPLES

Example ONE:

MODULE  'fpu/68881_single','fpu/68881_test'

PROC main()
  IF f_testiffpu()
    WriteF('(6*2)/4=\d\n',f_tointeger(f_div(f_mul(6.0,2.0),4.0)))
  ELSE
    WriteF('Sorry, FPU is needed to calculate (6*2)/4 ! ;-)\n')
  ENDIF
ENDPROC


Example TWO:

MODULE  'fpu/68881_single','fpu/68881_test'

PROC main()
  DEF value,ok,s[30]:STRING
  IF f_testiffpu()
    value,ok:=RealVal(arg)
    IF ok>0
       WriteF('Sine of \s rad is \s\n',arg,RealF(s,f_sin(value),4))
    ELSE
       WriteF('Sorry, this value isn''t a GOOD NUMBER !\n')
    ENDIF
  ELSE
    WriteF('Sorry, FPU is needed !\n')
  ENDIF
ENDPROC

Example THREE:

MODULE  'fpu/68881_single','fpu/68881_test'

PROC main()
  IF f_testiffpu()
    IF f_cmp(3.1,3.0)=1 THEN WriteF('3.1 is bigger than 3.0 ! (incredible!)\n')
  ELSE
    WriteF('Sorry, FPU is needed ! ;-)\n')
  ENDIF
ENDPROC

Ok. That's all folks!
@endnode

