                      opi.plastic <opi@amigascne.org>
                amiga+linux+net+grass+ascii+scene = phuunnn

--BOUNDARY.1982633976.1
Content-Disposition: attachment; filename="gtshape.asc"

INCLUDE "inc:winc"
FindScreen 0:winc{0,200,80}

px=5
py=10


Repeat
  Read plik$
  If plik$="end!" Then Goto doga
  LoadShape x,plik$
  GTShape 0,x,px,py,0,x
  x+1:px+20
  If px>200 Then px=5:py+20
Forever

.doga

AttachGTList 0,0

Repeat
  VWait
Until Event=$200
End


.dane
Data$ "dopus5:IMAGES/3D.SMALL"
Data$ "dopus5:IMAGES/ADDICON.SMALL"
Data$ "dopus5:IMAGES/ADDRESSBOOK.SMALL"
Data$ "dopus5:IMAGES/ALL.SMALL"
Data$ "dopus5:IMAGES/AMIGA.SMALL"
Data$ "dopus5:IMAGES/AMOSAIC1.SMALL"
Data$ "dopus5:IMAGES/AMOSAIC2.SMALL"
Data$ "dopus5:IMAGES/AREXX.SMALL"
Data$ "dopus5:IMAGES/ARRANGELS.SMALL"
Data$ "dopus5:IMAGES/ASSIGN.SMALL"
Data$ "dopus5:IMAGES/ASSIGN2.SMALL"
Data$ "dopus5:IMAGES/BAR"
Data$ "dopus5:IMAGES/BLANKER.SMALL"
Data$ "dopus5:IMAGES/BLANKER2.SMALL"
Data$ "dopus5:IMAGES/C.SMALL"
Data$ "dopus5:IMAGES/Cache.SMALL"
Data$ "dopus5:IMAGES/CALCULATOR.SMALL"
Data$ "dopus5:IMAGES/CD.SMALL"
Data$ "end!"

