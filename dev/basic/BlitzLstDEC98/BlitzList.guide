--BOUNDARY.2016584656.2
Content-Disposition: attachment; filename="tree.txt"

;SIMPLE Source for pointer
;Binary tree
;
;               n
;             /   \
;            n     n
;           / \   / \
;          ...........



;A Recursive Binary Tree structure

NEWTYPE.tree
  node.w
  *left.tree  ;Tree pointers, not a tree: location of a tree
  *right.tree
End NEWTYPE



;Allocate a new tree
Function.l  NewTree{}

  *a.tree=AllocMem(SizeOf.tree,1)
  *a\left=0  ;No branch: null pointer
  *a\right=0

  Function Return *a ; Pointer is a long

End Statement




;Recursive exploration of tree
Statement WriteTree{*a.tree}

      If (*a=0) ; ?No tree
        Print "."
        Statement Return
      Else
        WriteTree{*a\left}   ;first print left tree
        Print *a\node,"->"
        WriteTree{*a\right}  ;2nd   print right tree
      EndIf

End Statement




;Free mem  recursively
Statement FreeTree{*a.tree}

  If(*a=0)
    Statement Return
  Else
    FreeTree{*a\left}
    FreeTree{*a\right}
    FreeMem *a, SizeOf.tree
  EndIf

End Statement



;Build a tree  ------------- >              1    <- a
                      ;                    / \
;root                 ;           (1)->   2   3  <- (2)
*a.tree=NewTree{}     ;                      /
*a\node=1             ;                     4    <- (3)
*a\left=NewTree{}     ;                    / \
                      ;           (4)->   5   6  <- (6)
;some branch
;(1)
*b.tree=*a\left
*b\node=2

;(2)
*a\right=NewTree{}
*b.tree=*a\right
*b\node=3

;(3)
*b\left=NewTree{}
*b\left\node=4
*b=*b\left

;(4)
*b\left=NewTree{}
*b\left\node=5

;(5)
*b\right=NewTree{}
*b\right\node=6

;Write and free
WriteTree{*a}
FreeTree{*a}

MouseWait


End


--BOUNDARY.2016584656.2--




@ENDNODE
