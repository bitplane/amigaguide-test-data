Hello Andreas

On 21-D=E9c-98, you wrote:

> Hi Vincent
> Am 21-Dez-98 schrieb v.demongodin@wanadoo.fr:
> =

>> =

>> =

>> Andreas Falkenhahn wrote:

>>    Movem.l SaveRegister,a4-a6
> that works with the Nprint example but if I want to do
> something like:
> =

> newproc:
  MOVEM.l SaveRegister,a4-a6 <<Sorry: I will say immediatly after newproc=
as a geta4
> While Not Joyb(0)=3D1
>         Vwait
> Wend
> button=3D1
> =

> RTS
> =

> Then new task crashes. But why? Can`t I use CreateNewProc()
> to create some kind of subtask which always works in the background?
> How to it then? Btw: I`m also coding a bit in AmigaE and CreateNewProc(=
)
> works fine there (with a geta4() and storea4() ) before and behind
> the procedure.
>> =


Try to synchronise tasks with signals or msgports to avoid trouble. (see
code after).

Who want to make a multithread library for Blitz  :-)))    (Like Java  ;-=
)

Vincent.

-- =

-Vincent Demongodin-
OLD A1200 - 68030 50MHZ -  32 MO - DD 500Mo =

  =


--BOUNDARY.2015271664.1
Content-Disposition: attachment; filename="MultiTask.ascii"

; Multithread test - this is only a test
; Not an absolute method
; Use LoadSeg to create new task, and msgPort to communicate
; Vincent Demongodin 1998
; Make amigalibs.res resident


;How to share nprint...
Statement myNPrint{s$}


  SHARED printSem.l

  ObtainSemaphore_ printSem
  DefaultOutput
  NPrint s$
  ReleaseSemaphore_ printSem

End Statement




Statement Child{n.l}


  SHARED *parent.Task,maskBegin.l

  Signal_ *parent,maskBegin

  ;Do something
  Window n,50*n,50*n,100,100,$1|$2|$3|$4|$400|$1000,"fenetre "+Str$(n),0,1

  For i=1 To 100
    Use Window n ;
    WBox Rnd(100),Rnd(100),Rnd(100),Rnd(100),n+1
  Next

  ;Why, i don't know, but without Guru comes
  Delay_ 250

  myNPrint{ "Child "+Str$(n)+" +RIP"}
  Free Window n

End Statement


.Begin

Stop

SetErr
  End
End SetErr


WbToScreen 0

NBChild=3   ;Val(Par$(1))
#STACKSIZE=8192

printSem.l=AllocMem(SizeOf.SignalSemaphore,1)
InitSemaphore_ printSem


*parent.Task=FindTask_(0)
sig.l=-1
sig=AllocSignal_(sig)
If sig=-1 Then Goto Die
mask.l=0 BitSet sig
nbDie=0


sigBegin.l=-1
sigBegin=AllocSignal_(sigBegin)
If sigBegin=-1 Then Goto Die
maskBegin.l=0 BitSet sigBegin


Dim  procTags.TagItem(4)


procTags(2)\ti_Tag=#NP_Entry,?go            ; Point d'entree du process
procTags(3)\ti_Tag=#NP_StackSize,#STACKSIZE ; Taille de la pile
procTags(4)\ti_Tag=#TAG_END,$00000000



For k.l=1 To NBChild

  ;title DES PROCESS
  title$="Test"+Str$(k)+Chr$(0)
  procTags(1)\ti_Tag=#NP_Name,&title$


  MOVEM.l a5-a6,save
  *p.Process=CreateNewProc_(&procTags(1))

  s.l=Wait_(maskBegin)

Next

myNPrint{"In  parent k="+Str$(k)}


;Wait for childs death
Repeat
  s.l=Wait_(mask)
  nbDie=nbDie+1
Until nbDie=NBChild


.Die
myNPrint{ "<Enter> to quit..."}
DefaultInput
byebye$=Edit$(1)

FreeMem printSem, SizeOf.SignalSemaphore

End




.go:
  MOVEM.l save,a5-a6

  myNPrint{"Begin Child"+Str$(k)}

  Child{k}

  myNPrint{"Death of child, k="+Str$(k)}
  Signal_ *parent,mask

  RTS


.save
Dc.l 0,0,0


--BOUNDARY.2015271664.1--




@ENDNODE
