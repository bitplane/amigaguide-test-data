=2Esetupmui
MUIApplicationTitle       "PEN"
MUIApplicationVersion     "$VER: PEN"
MUIApplicationCopyright   "(C) 1998 by PEN"
MUIApplicationAuthor      "PEN DISPLAY"
MUIApplicationDescription "PEN"
MUIApplicationBase        "PEN"

MUISlider 4,0,255,0
MUISlider 5,0,255,0
MUISlider 6,0,255,0

MUINewObject 1,"Pendisplay.mui",0
MUIAddObjsVGroup 0,4,5,6,1
MUICreateVGroup 0

MUICreateWindow 2,"Pen","PDIS",0
MUIAddSubWindow 2

If MUICreateApplication<>True
  NPrint "Failed to create application!"
  End
EndIf

MUIApplicationObj 3

MUINotifyApp 2,#MUIA_Window_CloseRequest,1,1
MUINotifyApp 4,#MUIA_Slider_Level,#MUIV_EveryTime,2
MUINotifyApp 5,#MUIA_Slider_Level,#MUIV_EveryTime,2
MUINotifyApp 6,#MUIA_Slider_Level,#MUIV_EveryTime,2

MUIOpenWindow 2

=2Ewaitio
Repeat
  ev.l=3DMUIWaitEvent
  Select ev
        Case 1
            End
        Case 2
            r=3DMUIGet(4,#MUIA_Slider_Level):g=3DMUIGet(5,#MUIA_Slider_Le=
vel):b=3DMUIGet(6,#MUIA_Slider_Level)
            MUIDoMethod 1,#MUIM_Pendisplay_SetRGB,&r,&g,&b
  End Select
Forever



