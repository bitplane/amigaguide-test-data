Encoding: plain (7/8 bit)
Content-Disposition: attachment; filename="ReadSource1.asc"
X-MD2-FilePath: Ram Disk:ReadSource1.asc

If Exists(0,"lvl$")
	If ReadFile (0,"lvl$")
		FileInput 0
			Repeat 
				;What ever you want here
				filedata$=edit$(128)
				nprint filedata$
			Until EOF(0)=True
		CloseFile 0
	Endif
Endif

;DefaultInput

;Use Window 


--=_=8<==MD2367265CE-A2D24D8==8<=_=
Encoding: plain (7/8 bit)
Content-Disposition: attachment; filename="ReadSource2.asc"
X-MD2-FilePath: Ram Disk:ReadSource2.asc

lvl$="Ram:TEST"
If Exists(lvl$) 
	If ReadFile (0,lvl$)
		FileInput 0
			Repeat 
				;What ever you want here
				filedata$=edit$(128)
				nprint filedata$
			Until EOF(0)=True
		CloseFile 0
	Endif
Endif

