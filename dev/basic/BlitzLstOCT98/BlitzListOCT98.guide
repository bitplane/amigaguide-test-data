site web : http://perso.wanadoo.fr/supersport/


--BOUNDARY.7589.1130.269664672.1
Encoding: quoted-printable

; Ask a password printing a * per character
; Demande un mot de passe en affichant * pour chaque caractere
; Date : 06/10/98 - changed : 11/10/98
; By   : Cyanure
; Other : I hope it's not too late

WBStartup
NoCli

FindScreen 0

Window 0,20,20,400,200,$1000,"Password ...",1,2
Print "Enter password : "

chaine$=3D""
Repeat
  ev.l=3DWaitEvent
  If ev.l=3D$400                          ; keypressed ?
    car$=3DInkey$
    If car$<>Chr$(13) AND (car$<Chr$(129) OR car$>Chr$(139))
    ; if not Return and not a function key, nor Help then :

      If car$<>" " AND car$<>Chr$(9) AND car$<>Chr$(127) AND car$<>Chr$(8=
) AND (car$<Chr$(27) OR car$>Chr$(31))
        Print "*"
        chaine$+car$
      EndIf

    EndIf
  EndIf
Until car$=3DChr$(13)                     ; until you validate pressing
                                        ; the 'return key'

NPrint ""                               ; Show the password (to remove ;-=
)

Delay_ 100                              ; Wait for 2 seconds

Free Window 0

End


--BOUNDARY.7589.1130.269664672.1--




