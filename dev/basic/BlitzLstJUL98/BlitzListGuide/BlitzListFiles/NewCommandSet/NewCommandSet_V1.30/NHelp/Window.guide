@DATABASE Window V1.30
$VER: Window V1.30 (26.07.1998) by Laboureur -> AlphaSOUND <- Frédéric
@NODE MAIN "Window V1.30"

    @{b}Window V1.30 General Information:@{ub}

  * Blitz Basic II library number         : #47
  * Library size when linked to executable: 792 bytes
  * Number of commands                    : 22
  * Ressources automatically freed at end : Yes
  * Blitz Basic II libraries now obsolete :
      - basic/windowslib.obj


    @{b}Commands summary:@{ub}

  @{" NWindow          " LINK NWindow} Command (WindowID)
  @{" NWMouseX         " LINK NWMouseX} Function (Word)
  @{" NWMouseY         " LINK NWMouseY} Function (Word)
  @{" NWindowWidth     " LINK NWindowWidth} Function (Word)
  @{" NWindowHeight    " LINK NWindowHeight} Function (Word)
  @{" NWindowX         " LINK NWindowX} Function (Word)
  @{" NWindowY         " LINK NWindowY} Function (Word)
  @{" NWRastPort       " LINK NWRastPort} Function (Long)
  @{" NWColour         " LINK NWColour} Statement
  @{" NWLocate         " LINK NWLocate} Statement
  @{" NWPrint          " LINK NWPrint} Statement
  @{" NWindowTextStyle " LINK NWindowTextStyle} Statement
  @{" NWMove           " LINK NWMove} Statement
  @{" NWSize           " LINK NWSize} Statement
  @{" NWindowFont      " LINK NWindowFont} Statement
  @{" NWPlot           " LINK NWPlot} Statement
  @{" NWBox            " LINK NWBox} Statement
  @{" NActivate        " LINK NWActivate} Statement
  @{" UseWindow        " LINK NUseWindow} Statement
  @{" CloseWindow      " LINK NCloseWindow} Statement
  @{" NInitWindow      " LINK NInitWindow} Command (Boolean)
  @{" NWindowID        " LINK NWindowID} Function (Long)

@ENDNODE


@NODE NWindow

    @{b}SYNTAX@{ub}
  WindowID.l = NWindow(#Window, TagList)

    @{b}FUNCTION@{ub}
  Open a new window according  to  the  specified  taglist.  The  window
  opened  become  the  used window. You don't need to use the NUseWindow
  command to set it. If the WindowID is NULL, the window can't be opened.

  Here is a quick list  of  all  valid  windowtags  (for  more  details,
  consult the commodore autodocs):

  #WA_Left
  #WA_Top
  #WA_Width
  #WA_Height
  #WA_DetailPen
  #WA_BlockPen
  #WA_IDCMP

  #WA_Flags
  #WA_Gadgets
  #WA_Checkmark
  #WA_Title

  #WA_ScreenTitle
  #WA_CustomScreen
  #WA_SuperBitMap

  #WA_MinWidth
  #WA_MinHeight
  #WA_MaxWidth
  #WA_MaxHeight

  #WA_InnerWidth
  #WA_InnerHeight

  #WA_PubScreenName
  #WA_PubScreen
  #WA_PubScreenFallBack
  #WA_WindowName

  #WA_Colors

  #WA_Zoom
  #WA_MouseQueue
  #WA_BackFill
  #WA_RptQueue

  ; Booleans..

  #WA_SizeGadget
  #WA_DragBar
  #WA_DepthGadget
  #WA_CloseGadget
  #WA_Backdrop
  #WA_ReportMouse
  #WA_NoCareRefresh
  #WA_Borderless
  #WA_Activate
  #WA_RMBTrap
  #WA_WBenchWindow
  #WA_SimpleRefresh
  #WA_SmartRefresh

  #WA_SizeBRight
  #WA_SizeBBottom

  ; V39+

  #WA_AutoAdjust
  #WA_GimmeZeroZero
  #WA_MenuHelp
  #WA_NewLookMenus
  #WA_AmigaKey
  #WA_NotifyDepth
  #WA_Pointer
  #WA_BusyPointer
  #WA_PointerDelay
  #WA_TabletMessages
  #WA_HelpGroup
  #WA_HelpGroupWindow

@ENDNODE


@NODE NWMouseX

    @{b}SYNTAX@{ub}
  x.w = NWMouseX

    @{b}FUNCTION@{ub}
  Return the actual mouse position from the left of the used window.

@ENDNODE


@NODE NWMouseY

    @{b}SYNTAX@{ub}
  y.w = NWMouseY

    @{b}FUNCTION@{ub}
  Return the actual mouse position from the  top  of  the  used  window.
  Values can be positive or negative.

@ENDNODE


@NODE NWindowWidth

    @{b}SYNTAX@{ub}
  width.w = NWindowWidth

    @{b}FUNCTION@{ub}
  Return the width in pixel of the used window.

@ENDNODE


@NODE NWindowHeight

    @{b}SYNTAX@{ub}
  height.w = NWindowHeight

    @{b}FUNCTION@{ub}
  Return the height in pixel of the used window.

@ENDNODE


@NODE NWindowX

    @{b}SYNTAX@{ub}
  x.w = NWindowX

    @{b}FUNCTION@{ub}
  Return the left position in pixel of the used window.

@ENDNODE


@NODE NWindowY

    @{b}SYNTAX@{ub}
  y.w = NWindowY

    @{b}FUNCTION@{ub}
  Return the top position in pixel of the used window.

@ENDNODE


@NODE NWRastPort

    @{b}SYNTAX@{ub}
  rastport.l = NWRastPort

    @{b}FUNCTION@{ub}
  Return the rastport of the used window. RastPort is  very  useful  for
  advanced  coder  to  use  the  AmigaOS external graphic function under
  Blitz 2.

@ENDNODE


@NODE NWColour

    @{b}SYNTAX@{ub}
  NWColour(FrontColour, BackColour)

    @{b}STATEMENT@{ub}
  Set the default back and front colour for graphic function and text display.

  Functions affected by NWColour:

  NWBox, NWPrintFast, NWPlot.

@ENDNODE


@NODE NWLocate

    @{b}SYNTAX@{ub}
  NWLocate(x,y)

    @{b}FUNCTION@{ub}
  Set the text cursor to given position (for NWPrintFast).

@ENDNODE


@NODE NWPrint

    @{b}SYNTAX@{ub}
  NWPrint(String$)

    @{b}STATEMENT@{ub}
  Display the given string  on  the  used  window  at  position  set  by
  NWLocate and with the colours set by NWColour. You can use NWTextStyle
  to change the output style (bold, italic, underline).

@ENDNODE


@NODE NWTextStyle

    @{b}SYNTAX@{ub}
  NWTextStyle(Style)

    @{b}STATEMENT@{ub}
  Set the style for futur window textoutput (NWPrintFast).

  The legal Style values are:

    0 = Nothing
    1 = Underline
    2 = Bold
    4 = Italic

  You can mix it if needed (Bold+Italic will be 2+4 = 6)

@ENDNODE


@NODE NWMove

    @{b}SYNTAX@{ub}
  NWMove(x,y)

    @{b}STATEMENT@{ub}
  Move the window to the specified coordinates.

@ENDNODE


@NODE NWSize

    @{b}SYNTAX@{ub}
  NWSize(width, height)

    @{b}STATEMENT@{ub}
  Resize the window to given dimensions.

@ENDNODE


@NODE NWindowFont

    @{b}SYNTAX@{ub}
  NWindowFont(FontID)

    @{b}STATEMENT@{ub}
  Set the window current font to given FontID.

  FontID MUST be an legal IntuiFont Pointer. You can use the NFont library
  to load any font and pass the NFontID pointer to this function.

@ENDNODE


@NODE NWPlot

    @{b}SYNTAX@{ub}
  NWPlot(x,y)

    @{b}STATEMENT@{ub}
  Draw a plot of the active color (set by NWColour) on the used window.

@ENDNODE


@NODE NWBox

    @{b}SYNTAX@{ub}
  NWBox(x1, y1, x2, y2)

    @{b}STATEMENT@{ub}
  Draw a filled box of the active color (set by NWColour) on the used window.

  NOTE: coordinates must be given in the right order (x1 < x2 and y1 < y2)

@ENDNODE


@NODE NWActivate

    @{b}SYNTAX@{ub}
  NWActivate

    @{b}STATEMENT@{ub}
  Activate the used window.

@ENDNODE


@NODE NUseWindow

    @{b}SYNTAX@{ub}
  NUseWindow(#Window)

    @{b}STATEMENT@{ub}
  Change the used window to given window.

@ENDNODE


@NODE NCloseWindow

    @{b}SYNTAX@{ub}
  NCloseWindow(#Window)

    @{b}STATEMENT@{ub}
  Close the given window.

@ENDNODE


@NODE NInitWindow

    @{b}SYNTAX@{ub}
  result.l = NInitWindow(#NumWindowMax)

    @{b}FUNCTION@{ub}
  Init all the Window environnement for later use.  You  must  put  this
  functions  on  top  of your source code if you want to use the NWindow
  commands. You can test the result to see if the  Window  envirronement
  is right initialized.

  #NumWindowMax : Maximum number of window to handle.

@ENDNODE


@NODE NWindowID

    @{b}SYNTAX@{ub}
  WindowID.l = NWindowID

    @{b}FUNCTION@{ub}
  Return the Intuition Window pointer. Very useful.

@ENDNODE

