@NODE NSetGadgetText

    @{b}SYNTAX@{ub}
  NSetGadgetText &Text$

    @{b}STATEMENT@{ub}
  Set the text of the next created gadgets. Every gadget type  allows  to
  have  text  fitted  with it. You must store the text within a variable
  before to pass it trough this statement.

@ENDNODE


@NODE NSetGadgetFont

    @{b}SYNTAX@{ub}
  NSetGadgetFont FontID

    @{b}STATEMENT@{ub}
  Set the font which will be use by the next created gadgets.

@ENDNODE


@NODE NSetGadgetFlags

    @{b}SYNTAX@{ub}
  NSetGadgetFlags &Text$

    @{b}STATEMENT@{ub}
  Set the flags for the next created gadgets.

@ENDNODE


@NODE NGetCheckBoxState

    @{b}SYNTAX@{ub}
  state.b = NGetCheckBoxState(#GadgetID)

    @{b}FUNCTION@{ub}
  Return the state  of  the  specified  CheckBox  gadget.  If  NULL  the
  CheckBox is not set or the gadget isn't found (bad #GadgetID).

@ENDNODE


@NODE NUseGadgetList

    @{b}SYNTAX@{ub}
  NUseGadgetList #GadgetList

    @{b}STATEMENT@{ub}
  Set the specified Gadgetlist as used.

@ENDNODE


@NODE NCreateGadgetList

    @{b}SYNTAX@{ub}
  result.l = NCreateGadgetList(#GadgetList, ScreenID)

    @{b}FUNCTION@{ub}
  Try to allocate the ressource to futur  gadgetlist.  The  ScreenID  is
  needed, so be sur to pass it !

@ENDNODE


@NODE NAttachGadgetList

    @{b}SYNTAX@{ub}
  NUseGadgetList #GadgetList, WindowID

    @{b}STATEMENT@{ub}
  Attach the specified gadgetlist to an opened window specified  by  the
  WindowID. Gadgets are automatically refreshed.

@ENDNODE


  @{" NMenuTitle        " LINK NMenuTitle} Statement
  @{" NMenuItem         " LINK NMenuItem} Statement
  @{" NMenuSubItem      " LINK NMenuSubItem} Statement
  @{" NMenuBar          " LINK NMenuBar} Statement
  @{" NMenuSubBar       " LINK NMenuSubBar} Statement
  @{" NCreateMenu       " LINK NCreateMenu} Function (long)
  @{" NAttachMenu       " LINK NAttachMenu} Statement
  @{" NSetMenuColour    " LINK NSetMenuColour} Statement


@NODE NMenuTitle

    @{b}SYNTAX@{ub}
  NMenuTitle Title$

    @{b}STATEMENT@{ub}
  Create an title entry for the actual menu

@ENDNODE


@NODE NMenuItem

    @{b}SYNTAX@{ub}
  NMenuItem MenuID, Text$, &ShortCut

    @{b}STATEMENT@{ub}
  Create an item entry for the actual menu.

@ENDNODE


@NODE NMenuSubItem

    @{b}SYNTAX@{ub}
  NMenuSubItem MenuID, Text$, &ShortCut

    @{b}STATEMENT@{ub}
  Create an subitem entry for the actual menu.

@ENDNODE


@NODE NMenuBar

    @{b}SYNTAX@{ub}
  NMenuBar

    @{b}STATEMENT@{ub}
  Create an separator bar for the actual menu.

@ENDNODE


@NODE NMenuSubBar

    @{b}SYNTAX@{ub}
  NMenuSubBar

    @{b}STATEMENT@{ub}
  Create an separator bar for the actual menu.

@ENDNODE


@NODE NCreateMenu

    @{b}SYNTAX@{ub}
  NCreateMenu #Menu

    @{b}STATEMENT@{ub}
  It create the menu defined before.

@ENDNODE


@NODE NAttachMenu

    @{b}SYNTAX@{ub}
  NAttachMenu #Menu, WindowID

    @{b}STATEMENT@{ub}
  Attach the specified menu to the given window.

@ENDNODE


@NODE NSetMenuColour

    @{b}SYNTAX@{ub}
  NSetMenuColour colour

    @{b}STATEMENT@{ub}
  Set the front menu colour for  futur  created  menu.  Must  be  called
  before the create menu command or it willn't have any effects.

@ENDNODE
