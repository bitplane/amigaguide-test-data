@DATABASE GadTools V1.30
$VER: GadTools V1.30 (26.07.1998) by Laboureur -> AlphaSOUND <- Frédéric
@NODE MAIN "GadTools V1.30"

    @{b}GadTools V1.30 General Information:@{ub}

  * Blitz Basic II library number         : #46
  * Library size when linked to executable: 2072 bytes
  * Number of commands                    : 29
  * Ressources automatically freed at end : Yes
  * Blitz Basic II libraries now obsolete :
      - basic/gadgetslib.obj
      - basic/menuslib.obj
      - basic/bbgtlib.obj

    @{b}Commands summary:@{ub}

  @{" NInitGadTools     " LINK NInitGadTools} Command (long)
  @{" NWEvent           " LINK NWEvent} Function (long)
  @{" NEventID          " LINK NEventID} Function (word)

  Gadgets related commands:

  @{" NButtonGadget     " LINK NButtonGadget} Command (long)
  @{" NCheckBoxGadget   " LINK NCheckBoxGadget} Command (long)
  @{" NIntegerGadget    " LINK NIntegerGadget} Command (long)
  @{" NListViewGadget   " LINK NListViewGadget} Command (long)
  @{" NNumberGadget     " LINK NNumberGadget} Command (long)
  @{" NCycleGadget      " LINK NCycleGadget} Command (long)
  @{" NPaletteGadget    " LINK NPaletteGadget} Command (long)
  @{" NScrollerGadget   " LINK NScrollerGadget} Command (long)
  @{" NSliderGadget     " LINK NSliderGadget} Command (long)
  @{" NStringGadget     " LINK NStringGadget} Command (long)
  @{" NSetGadgetText    " LINK NSetGadgetText} Statement
  @{" NSetGadgetFont    " LINK NSetGadgetFont} Statement
  @{" NSetGadgetFlags   " LINK NSetGadgetFlags} Statement
  @{" NGetCheckBoxState " LINK NGetCheckBoxState} Function (boolean)
  @{" NUseGadgetList    " LINK NUseGadgetList} Statement
  @{" NCreateGadgetList " LINK NCreateGadgetList} Function (long)
  @{" NAttachGadgetList " LINK NAttachGadgetList} Statement

  Menu related commands:

  @{" NMenuTitle        " LINK NMenuTitle} Statement
  @{" NMenuItem         " LINK NMenuItem} Statement
  @{" NMenuSubItem      " LINK NMenuSubItem} Statement
  @{" NMenuBar          " LINK NMenuBar} Statement
  @{" NMenuSubBar       " LINK NMenuSubBar} Statement
  @{" NCreateMenu       " LINK NCreateMenu} Function (long)
  @{" NAttachMenu       " LINK NAttachMenu} Statement
  @{" NSetMenuColour    " LINK NSetMenuColour} Statement
@ENDNODE


@NODE NInitGadTools

    @{b}SYNTAX@{ub}
  NInitGadTools NumGadgetsMax, NumMenuMax, NumMenuItemMax

    @{b}COMMAND@{ub}
  Try to open the gadtools.library and initialize the gadtools
  environnement. You must put this command before any use of the
  new gadtools set.

@ENDNODE


@NODE NWEvent

    @{b}SYNTAX@{ub}
  Event.l = NWEvent(#GadgetList)

    @{b}FUNCTION@{ub}
  Return the last window event which has appened.

@ENDNODE


@NODE NEventID

    @{b}SYNTAX@{ub}
  EventID = NEventID

    @{b}FUNCTION@{ub}
  Return the last eventid which has appened. EventID are only useful  to
  identify an menu/gadgets which has been pushed.

@ENDNODE


@NODE NButtonGadget

    @{b}SYNTAX@{ub}
  NButtonGadget GadgetID, x, y, Width, Heigth, TagList

    @{b}COMMAND@{ub}
  Create a button gadget in the actual GadgetList. GadgetID will be  the
  number  returned  by  NEventID  command.  This  command can return the
  Intuition gadget pointer for advanced programmers.

@ENDNODE


@NODE NCheckBoxGadget

    @{b}SYNTAX@{ub}
  NCheckBoxGadget GadgetID, x, y, Width, Heigth, TagList

    @{b}COMMAND@{ub}
  Create a checkbox gadget in the actual GadgetList.  GadgetID  will  be
  the  number  returned by NEventID command. This command can return the Intuition
  gadget pointer for advanced programmers.

@ENDNODE


