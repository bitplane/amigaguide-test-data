From: Krzysiek Jonko <eteacher@amiga.org.pl>
Subject: Problem with CGFX screens
Date: Mon, 27 Jul 1998 07:07:12 +0100

I've very strange problem - this is the little part of my program. But
the screen opening procedure works correctly only on ECS/AGA machines.
When I'm opening screen by ASLscreen Request on CGFX - all is OK but if
I try to open ONE of the CGFX modes without ASL - program opens first
available CGFX mode with 320x256 resolution... Could anybody help me
wit correcting this erropr?

PS. Sorry for long example but I think it should be usable for some
people on the list I think.


    found=#L0
    *psl=LockPubScreenList_
    If *psl<>#L0
      *psn=*psl\lh_Head
      While (found=#L0 AND *psn<>#L0)
        If Peek$(*psn\psn_Node\ln_Name)=ScrName$ Then found=#L1
        *psn=*psn\psn_Node\ln_Succ
      Wend
      UnlockPubScreenList_
    EndIf
    If found<>#L0
    ;istniejacy PUBLIC screen
      GetPubScreen 0,ScrName$
      WYS =ScreenHeight: If WYS <400 Then FATAL{1}
      SZER=ScreenWidth : If SZER<640 Then FATAL{1}
      ScreensBitMap 0,1
      DEP=Depth(1)
    Else
;new PUBLIC screen
      If ID=0 ;wywolanie  ASL ScreenReq
        InitTagList 1,28

        AddTags 1,#ASLSM_InitialDisplayID    ,$8004
        AddTags 1,#ASLSM_InitialDisplayWidth ,640
        AddTags 1,#ASLSM_InitialDisplayHeight,512
        AddTags 1,#ASLSM_InitialDisplayDepth ,4
        AddTags 1,#ASLSM_InitialAutoScroll   ,True
        AddTags 1,#ASLSM_DoWidth             ,True
        AddTags 1,#ASLSM_DoHeight            ,True
        AddTags 1,#ASLSM_DoDepth             ,True
        AddTags 1,#ASLSM_DoAutoScroll        ,True
        AddTags 1,#ASLSM_DoOverscanType      ,1
        AddTags 1,#ASLSM_MinWidth            ,640
        AddTags 1,#ASLSM_MinHeight           ,400
        AddTags 1,#ASLSM_MinDepth            ,3

        *sreq.SMode=0
        *sreq=AllocAslRequest_(2,TagList(1))
        ok   =AslRequest_(*sreq,TagList(1))
        If ok<>0
          ID  =*sreq\DisplayID
          WYS =*sreq\DisplayHeight
          SZER=*sreq\DisplayWidth
          DEP =*sreq\DisplayDepth
          OVR =*sreq\OverscanType
        Else
          End ;abort ASL Screen Request
        EndIf
        If (*sreq) Then FreeAslRequest_(*sreq)
        Free TagList(1)
      EndIf

      MyFontSize=12
      MyFontAttr.TextAttr\ta_Name = &FNT$,MyFontSize,0,0
;paleta
      Dim scr0_pens.w(21)
      scr0_pens(0)=-1
      scr0_pens(1)= #L0: scr0_pens(2)=#L0: scr0_pens(3)=#L0
      scr0_pens(4)= #L0: scr0_pens(5)=#L0: scr0_pens(6)=#L0
      scr0_pens(7)= #L0: scr0_pens(8)=#L0: scr0_pens(9)=#L0

      mysig.l=AllocSignal_(-1): If mysig=#L0 Then mysig=-1
      Title$="Electronic Teacher v2.31"

      InitTagList 0,26
      AddTags     0,#SA_Width,SZER,  #SA_Height,WYS,#SA_Depth,DEP
      AddTags     0,#SA_DetailPen,  1,#SA_BlockPen,  2,#SA_Title,&Title$
      AddTags     0,#SA_Font     ,MyFontAttr          ,#SA_PubName,&ScrName$
      AddTags     0,#SA_PubSig,mysig, #SA_PubTask ,  0,#SA_DisplayID,ID
      AddTags     0,#SA_Pens,&scr0_pens(0),#SA_AutoScroll,True
      AddTags     0,#SA_Overscan,OVR

      *myscreen.Screen=OpenScreenTagList_(0,TagList(0))
      Free TagList 0

      If *myscreen.Screen=#L0 Then FATAL{2} ;screen not opened
      FindScreen 0,Title$  : PubScreenStatus_ *myscreen,0

    EndIf
 Else
    FATAL{3} ;no icon
  EndIf

