@NODE "Mail.236" "Re: Game Editors, OS, Screentag, MUI"
From: Curt Esser <camge@ix.netcom.com>
Date: Fri, 17 Jul 1998 22:02:16 -0500
Subject: Re: Game Editors, OS, Screentag, MUI

Warning: This is a message in MIME format. Your mail reader does not
support MIME. Some parts of this message will be readable as plain text.
To see the rest, you will need to upgrade your mail reader.


--BOUNDARY.1746351616.2

Hi Dermot,

On 17-Jul-98, Dermot Smyth wrote:
> Hi,

> Then I noticed the Screentags command which I think
> said would let you use all the screen modes - I presume
> this means 256 colour modes as well? But I can't make
> head nor tail of it (like most things in the manual).
> 
> Does anyone have an example/docs of this command?

I've attached it.  I also included a mode requester so you can get the mode ID
number that you want to use.

You will need amigalibs.res  in your compiler options.

Later...
-- 
Avoid reality at all costs.

                                    Yours electronically,
                                    Curt Esser
                                    camge@ix.netcom.com
                                    http://members.xoom.com/Curt_Esser/


--BOUNDARY.1746351616.2
Content-Disposition: attachment; filename="ScreenTaglist.asc"

WBStartup

WBenchToFront_

NoCli

WbToScreen 1



LoadFont 0,"topaz.font",8                  ;load test screen's font
*fn=3DAddr IntuiFont (0)                     ;pointer to screen font



NEWTYPE.SMode                              ;for the mode requester
  DisplayID.l
  DisplayWidth.l
  DisplayHeight.l
  DisplayDepth.w
  OverscanType.w
End NEWTYPE

sm$=3D"Select A Screen Mode:"                ;title for mode requester

If NTSC=3DTrue                               ;set default screen mode
  imode.l=3D$19004                           ;NTSC hi-res lace for NTSC
  iheight.w=3D400
Else
  imode.l=3D$29004                           ;PAL hi-res laced for PAL
  iheight.w=3D512
EndIf

Dim SMRtags.TagItem(19)                        ;taglist for mode requeste=
r

SMRtags(0)\ti_Tag=3D#ASLSM_InitialLeftEdge,160
SMRtags(1)\ti_Tag=3D#ASLSM_InitialTopEdge,10
SMRtags(2)\ti_Tag=3D#ASLSM_InitialWidth,320
SMRtags(3)\ti_Tag=3D#ASLSM_InitialHeight,200
SMRtags(4)\ti_Tag=3D#ASLSM_InitialDisplayID,imode
SMRtags(5)\ti_Tag=3D#ASLSM_InitialDisplayDepth,3
SMRtags(6)\ti_Tag=3D#ASLSM_InitialDisplayWidth,640
SMRtags(7)\ti_Tag=3D#ASLSM_InitialDisplayHeight,iheight
SMRtags(8)\ti_Tag=3D#ASLSM_InitialOverscanType,1
SMRtags(9)\ti_Tag=3D#ASLSM_InitialInfoOpened,0   ;set to 1 for "propertie=
s" window
SMRtags(10)\ti_Tag=3D#ASLSM_DoDepth,1
SMRtags(11)\ti_Tag=3D#ASLSM_DoOverscanType,1
SMRtags(12)\ti_Tag=3D#ASLSM_DoWidth,1
SMRtags(13)\ti_Tag=3D#ASLSM_DoHeight,1
SMRtags(14)\ti_Tag=3D#ASLSM_MinHeight,200
SMRtags(15)\ti_Tag=3D#ASLSM_MinWidth,320
SMRtags(16)\ti_Tag=3D#ASLSM_MinDepth,3
SMRtags(17)\ti_Tag=3D#ASLSM_TitleText,&sm$
SMRtags(18)\ti_Tag=3D#TAG_DONE

;
; ScreenMode requester returns the ScreenMode structure
;

*sreq.SMode=3D0
*sreq=3DAllocAslRequest_(2,&SMRtags(0)\ti_Tag)
ok.b=3DAslRequest_(*sreq,&SMRtags(0)\ti_Tag)

If ok<>0

  ;------- read the results into variables
  ;this part is not really necessary, but makes it easier to
  ;just make up the screen without using the requester every time
  ;these results could be saved into a "prefs" file

  Display.l=3D*sreq\DisplayID
  Oscan.w=3D*sreq\OverscanType
  Dpth.w=3D*sreq\DisplayDepth
  Widh.l=3D*sreq\DisplayWidth
  Heit.l=3D*sreq\DisplayHeight

  ;------- now make the "Program's" screen --------------------
  ; we will make it up in back and pop to front when ready


  Dim SCRtags.TagItem(12)
  SCRtags(0)\ti_Tag=3D#SA_DisplayID,Display
  SCRtags(1)\ti_Tag=3D#SA_Overscan,Oscan
  SCRtags(2)\ti_Tag=3D#SA_Depth,Dpth
  SCRtags(3)\ti_Tag=3D#SA_Width,Widh
  SCRtags(4)\ti_Tag=3D#SA_Height,Heit
  SCRtags(5)\ti_Tag=3D#SA_Top,0
  SCRtags(6)\ti_Tag=3D#SA_Left,0
  SCRtags(7)\ti_Tag=3D#SA_AutoScroll,1         ;autoscroll is on!
  SCRtags(8)\ti_Tag=3D#SA_Pens,?DriPens        ;List of 13 Dripens
  SCRtags(9)\ti_Tag=3D#SA_Behind,1             ;make screen in back of di=
splay
  SCRtags(10)\ti_Tag=3D#SA_ShowTitle,0
  SCRtags(11)\ti_Tag=3D#TAG_DONE

  ScreenTags 0,"Test Screen",& SCRtags(0)    ;open the screen

  Window 1,10,10,300,100,$1000|$8,"Screen info",1,0  ;and a small window
  NPrint "$"+Hex$(Display)
  NPrint "Depth=3D",Dpth
  NPrint "Press close gadget to end"

  ShowScreen 0                               ;now bring screen to the fro=
nt


  Repeat
    ev.l=3DWaitEvent
  Until ev=3D$200


Else
  Request "","Cancelled!","OK"
  End
EndIf
If (*sreq) Then FreeAslRequest_(*sreq)


End

Even
DriPens
Dc.w  0,1,1,2,1,3,1,0,2,1,2,1,-1




--BOUNDARY.1746351616.2--





@ENDNODE
