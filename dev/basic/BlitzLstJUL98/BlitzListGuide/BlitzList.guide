-- 
Peter Thor, Coder Asm/Blitz/C/C++
Irc: Joru (irc.stealth.net, #AmigaSWE/#Amiga/#Amigascne)
ICQ: 11277616,  Alt-EMail: Joru@hotmail.com
Creative Amigans at: www.ping.be/sillycat
.- Amiga is it! -.

--BOUNDARY.7509.2204.120792464.1

Statement GoBusy{w}    ;set Busy-Pointer for window w
  Dim ti.TagItem(3)

  ti(0)\ti_Tag=#WA_BusyPointer,True
  ti(1)\ti_Tag=#WA_PointerDelay,True
  ti(1)\ti_Tag=#TAG_DONE

  *win.Window=Peek.l(Addr Window(w))
  If *win<>0 Then void.w=SetWindowPointerA_(*win, &ti(0) )
  Activate w

End Statement

Statement UnBusy{w}    ;set Normal Pointer for window w
  Dim ti.TagItem(2)

  ti(0)\ti_Tag=#WA_BusyPointer,False
  ti(1)\ti_Tag=#TAG_DONE

  *win.Window=Peek.l(Addr Window(w))
  If *win<>0 Then void.w=SetWindowPointerA_(*win, &ti(0) )
  Activate w
End Statement


--BOUNDARY.7509.2204.120792464.1--





