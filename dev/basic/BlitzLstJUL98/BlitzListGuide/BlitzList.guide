example how to do it in the manual of the Techno-Sound-Turbo 2 Sampler. Maybe
it helps you.

-- 

Tranquilizer/ Secretly!
Mike Delling

PROFESSIONALS DON'T USE MICRO$OFT!





@ENDNODE
@NODE "Mail.103" "OS Windows and gadgets"
	(envelope-from rsdm@eee.rgu.ac.uk)
    7 Jul 98 08:55:29 GMT+1
From: "David McMinn" <rsdm@eee.rgu.ac.uk>
Date: Tue, 7 Jul 1998 08:55:19 +0100
Subject: OS Windows and gadgets

 Sorry I've forgotten who wanted this stuff. Its example code for OS Windows and gadgets 
and printing to the window, using OpenWindowTagList_. You may also want to consider 
using WindowTags (Blitz2 command, don't know what lib) as this does the same as 
OWTL_.

Anyway, heres the OS example (watch out some lines may have been wrapped):

-----8<-----8<-----8<-----8<-----8<-----8<-----8<-----8<-----
; You could always use the WindowTags Blitz2 command, and
; then you could use Blitz2 commands for everything else!!

; Make sure that updated blitzlibs:amigalibs.res is resident
; ==========================================================

WBStartup

; Copies a string from source and returns destination
Function.l getstring{*source.b}
  counter.w = 0
  *name.b = AllocMem_(108, #MEMF_ANY|#MEMF_CLEAR)
  If (*name)
    While (Peek.b(*source+counter) <> 0)
      Poke.b *name+counter, Peek.b(*source+counter)
      counter+1
    Wend
    Function Return *name
  Else
    Function Return #NULL
  End If
End Function


; Define some stuff for window
#WFLG_SMART_REFRESH = 0
#IDCMP = 
#IDCMP_MOUSEBUTTONS|#IDCMP_MOUSEMOVE|#IDCMP_GADGETDOWN|#IDCMP_
GADGETUP
#IDCMP = #IDCMP | 
#IDCMP_CLOSEWINDOW|#IDCMP_VANILLAKEY|#IDCMP_INTUITICKS
#FLAGS = 
#WFLG_SMART_REFRESH|#WFLG_CLOSEGADGET|#WFLG_DRAGBAR|#WFLG_DEPT
HGADGET|#WFLG_SIZEGADGET|#WFLG_ACTIVATE

; And also the window
Dim wtags.TagItem(20)
wtags(0)\ti_Tag=#WA_PubScreen,#NULL
wtags(1)\ti_Tag=#WA_IDCMP,#IDCMP
wtags(2)\ti_Tag=#WA_Flags,#FLAGS
wtags(3)\ti_Tag=#WA_Title,?wtit
wtags(4)\ti_Tag=#WA_MinWidth,100
wtags(5)\ti_Tag=#WA_MinHeight,50
wtags(6)\ti_Tag=#WA_MaxWidth,400
wtags(7)\ti_Tag=#WA_MaxHeight,200
wtags(8)\ti_Tag=#WA_Left,320
wtags(9)\ti_Tag=#WA_Top,11
wtags(10)\ti_Tag=#WA_Width,300
wtags(11)\ti_Tag=#WA_Height,200
wtags(12)\ti_Tag=#TAG_END,#TAG_DONE

; Open window and make sure that it HAS
*mywindow.FixWindow = OpenWindowTagList_(#NULL, &wtags(0))
If *mywindow = #NULL Then End

; Get visual info for screen (needed by Gadtools)
vi.l = GetVisualInfoA_(*mywindow\WScreen, #NULL)
If vi = #NULL Then Goto nomem

; Create a couple of lists for the GTListView, by getting names of all
; libraries in the LibList.
*execbase.ExecBase = Peek.l(4)
*mynode.Node = *execbase\LibList\lh_Head
DEFTYPE.List *mylist1, *mylist2
DEFTYPE.Node *ptr
*mylist1 = AllocMem_(SizeOf.List, #MEMF_ANY|#MEMF_CLEAR)
If (*mylist1 = 0) Then Goto nomem
!NewList{*mylist1}
*mylist2 = AllocMem_(SizeOf.List, #MEMF_ANY|#MEMF_CLEAR)
If (*mylist2 = 0) Then Goto nomem
!NewList{*mylist2}
While *mynode\ln_Succ
  *ptr = AllocMem_(SizeOf.Node, #MEMF_ANY|#MEMF_CLEAR)
  If *ptr
    *ptr\ln_Name = getstring{*mynode\ln_Name}
    AddTail_ *mylist1, *ptr
  End If
  *mynode = *mynode\ln_Succ
Wend
*mynode = *execbase\LibList\lh_Head
While *mynode\ln_Succ
  *ptr = AllocMem_(SizeOf.Node, #MEMF_ANY|#MEMF_CLEAR)
  If *ptr
    *ptr\ln_Name = getstring{*mynode\ln_Name}
    AddTail_ *mylist2, *ptr
  End If
  *mynode = *mynode\ln_Succ
Wend

; Bubble Sort one of the lists
found.w = True
temp.l = *mylist1\lh_TailPred\ln_Succ
While found
  *ptr = *mylist1\lh_Head
  found = False
  While (*ptr\ln_Succ <> temp)
    If Peek$(*ptr\ln_Name) > Peek$(*ptr\ln_Succ\ln_Name)
      f.l = *ptr\ln_Succ\ln_Name
      *ptr\ln_Succ\ln_Name = *ptr\ln_Name
      *ptr\ln_Name = f
      found = True
    End If
    *ptr = *ptr\ln_Succ
  Wend
  temp = *ptr
Wend

; Create a tag for GTLV
Dim gtags.TagItem(2)
gtags(0)\ti_Tag=#GTLV_Labels,*mylist1

; To remove labels from a list, call gt_setgadgetattrsa_ with the tag set
; to #GTLV_Labels,#NULL
; To replace the labels call gt_setgadgetattrsa_ with the tag set as above

; And create NewGadget structures for the Gadtools gadgets
Dim gtgads.NewGadget(2)
gtgads(0)\ng_LeftEdge = 20,36,100,50,?b,*mywindow\WScreen\Font,0,$8,vi,0
gtgads(1)\ng_LeftEdge = 20,20,100,14,?a,*mywindow\WScreen\Font,1,$10,vi,0

; Use gadtools functions to create gadgets from NewGadget structures
DEFTYPE.Gadget *gad, *gadlist, *lvgad
*gadlist = #NULL
*gad = CreateContext_(&*gadlist)
*gad = CreateGadgetA_(#LISTVIEW_KIND, *gad, &gtgads(0), &gtags(0))
*lvgad=*gad ; Remember address of gtlv, for later
*gad = CreateGadgetA_(#BUTTON_KIND, *gad, &gtgads(1), 0)

; Draw gadgets on window
AddGList_ *mywindow, *gadlist, -1, -1, #NULL
RefreshGList_ *gadlist, *mywindow, #NULL, -1
GT_RefreshWindow_ *mywindow, #NULL

quit.w = 0
signalset.l = 1 ASL *mywindow\UserPort\mp_SigBit

; Get IntuiText set up for printing in window
it.IntuiText\FrontPen = 1,0,0,0,0,*mywindow\WScreen\Font,0,0
y.w = 11

DEFTYPE.Node *sparetool

While (quit = 0)
  Wait_(signalset)
  *message.IntuiMessage = GT_GetIMsg_(*mywindow\UserPort)
  While (*message <> #NULL)
    class.l = *message\Class
    code.w = *message\Code        ; Like EventCode blitz2 command
    *ptr = *message\IAddress      ; Returns address of gadget hit
    qual.w = *message\_Qualifier  ; Like Qualifier blitz2 command
    GT_ReplyIMsg_ *message
    Select class
      Case #IDCMP_GADGETUP
        ; Print "GadgetHit" from gadget address
        *g.Gadget = *ptr
        NPrint "Gadget = ",UStr$(*g\GadgetID)," Code = ",code

      Case #IDCMP_CLOSEWINDOW
        quit = 1

      Case #IDCMP_VANILLAKEY
        ; Play around with gtlistview if keys are pressed
        Select Chr$(code)
          Case "L"
            gtags(0)\ti_Data = #NULL
            GT_SetGadgetAttrsA_ *lvgad, *mywindow, #NULL, &gtags(0)
            Exchange *mylist1, *mylist2
            gtags(0)\ti_Data = *mylist1
            GT_SetGadgetAttrsA_ *lvgad, *mywindow, #NULL, &gtags(0)

          Case "A"
            If *sparetool
              gtags(0)\ti_Data = #NULL
              GT_SetGadgetAttrsA_ *lvgad, *mywindow, #NULL, &gtags(0)
              AddHead_ *mylist1, *sparetool
              gtags(0)\ti_Data = *mylist1
              GT_SetGadgetAttrsA_ *lvgad, *mywindow, #NULL, &gtags(0)
              *sparetool=0
            End If

          Case "D"
            If *sparetool=0
              gtags(0)\ti_Data = #NULL
              GT_SetGadgetAttrsA_ *lvgad, *mywindow, #NULL, &gtags(0)
              *sparetool=RemHead_(*mylist1)
              gtags(0)\ti_Data = *mylist1
              GT_SetGadgetAttrsA_ *lvgad, *mywindow, #NULL, &gtags(0)
            End If

          Default
            it\IText = UStr$(code)
            PrintIText_ *mywindow\RPort, &it, 4, y
            y+8
        End Select
    End Select
    *message = GT_GetIMsg_(*mywindow\UserPort)
  Wend
Wend

; Remove entire gadget list from window, free screen
; visual info Then Free gadget List and close window
RemoveGList_ *mywindow, *gadlist, -1
If vi Then FreeVisualInfo_ vi
FreeGadgets_ *gadlist
nomem:
CloseWindow_ *mywindow

; Free lists created for GTLV
*ptr = RemHead_(*mylist1)
While *ptr
  If *ptr\ln_Name
    FreeMem_ *ptr\ln_Name,108
  End If
  FreeMem_ *ptr, SizeOf.Node
  *ptr = RemHead_(*mylist1)
Wend
FreeMem_ *mylist1, SizeOf.List
*ptr = RemHead_(*mylist2)
While *ptr
  If *ptr\ln_Name
    FreeMem_ *ptr\ln_Name,108
  End If
  FreeMem_ *ptr, SizeOf.Node
  *ptr = RemHead_(*mylist2)
Wend
FreeMem_ *mylist2, SizeOf.List


End

; All the strings are hardcoded into the program because they need to be
; kept for the entire length. Alternatively, use variables that do not get
; changed during the run of the program.
Even
wtit:Dc.b "Press my keys",0
a:Dc.b "Button",0
b:Dc.b "Listview",0
Even


.oO_David_McMinn_Oo.



@ENDNODE
@NODE "Mail.104" "OS Functions Part 1 to 3a"
 Sun, 19 Jul 1998 05:36:43 +0100 (BST)
 <blitz-list@netsoc.ucd.ie>; Sun, 19 Jul 1998 00:48:42 -0400 (EDT)
