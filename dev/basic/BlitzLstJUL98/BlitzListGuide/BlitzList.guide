	|   John Mason  :  ah210@chebucto.ns.ca   | 
	|  Amiga 1200 020/882 3.0 10MB RAM 80M HD |
	|  A 500 68020/68881 3.1 7MB RAM 170M HD  | 
	|http://chebucto.ns.ca/~ah210/Profile.html|




@ENDNODE
@NODE "Mail.257" "File Notification"
Date: 08 Apr 98 20:20:28 GMT
X-Plug: Xenolink, No. 1 BBS Software for the Amiga!
From: bml@darkside.demon.co.uk (Simon Archer)
Subject: File Notification

On 12 Jul 98 John Mason wrote about 'File Notification'.

It might be easier to do it this way:

; set up the notify request
t = 0
Repeat
  t + 1
Until AddNotify(t,"Ram:") = True

; use:
If CheckNotify..
EndIf
;in the main event loop

; and then use this to clear the notify before you quit
RemNotify(t)

or if you really need the meassageport way of doing things:

;/* Watch a File by notification
;   pops up a requester when a File gets modified.
;   USAGE: watch <File>
;   EXAMPLE: run >NIL: watch >NIL: s:startup-sequence       */

WBStartup
WbToScreen 0
NoCli
WBenchToFront_
sigreturned.l = 0
DEFTYPE .l
If NumPars > 0
  myfile$ = Par$(1)
  sig.l = AllocSignal_(-1)
Else
  Window 0,0,0,400,100,$2140e,"Watch Output",1,2
  NPrint "Enter a file or directory!"
  myfile$ = Edit$(80)
  *win.Window = Peek.l(Addr Window(0))
  sig = *win\UserPort\mp_SigBit
  *myport.MsgPort = *win\UserPort
EndIf
              ;/* we want To be signalled */
NPrint "Signal = ",sig
If sig = -1 Then Stop
task.l = FindTask_(0)                 ; this will return pointer to its self
nreq.NotifyRequest\nr_Name = &myfile$                      ;/* fill in
structure */
nreq\nr_Flags = #NRF_SEND_SIGNAL
nreq\nr_Port = task                     ;/* union port/task */
nreq\nr_SignalNum = sig
If StartNotify_(nreq) = True
  If *win
    NPrint("Now watching: "+myfile$)
    WLocate 10,50
  EndIf
  sigreturned = Wait_(1LSL sig)
  body$ = "File "+myfile$+" modified!";+Chr$(10)+"Signal =
"+Hex$(Str$(sigreturned))
  EasyRequest "Output",body$,"Damn!"
  EndNotify_(nreq)
Else
  NPrint("Could NOT watch "+myfile$)
EndIf
FreeSignal_(sig)
End





@ENDNODE
