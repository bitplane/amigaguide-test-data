@NODE "Mail_656" "More about icons..."
 for scott@online.u-net.com; Sat, 24 Apr 1999 21:22:11 +0000
From: James L Boyd <jamesboyd@all-hail.freeserve.co.uk>
Date: Sat, 24 Apr 1999 21:21:17 +0000
Subject: More about icons...

--BOUNDARY.1748035440.2

Hi, 

Well, after posting that message about the IconDeluxe source
being "out there", I had a go myself at trying to load an icon's
image as a bitmap and blitting it to a window...

Can anyone tell why this isn't working? I get a weird error, which
I can't even find in the manual (surprise), "Offset out of range".

I think it might be to do with the way I've bracketed it, so I've
pasted in the code I "borrowed" from IconDeluxe...anyone? Please? :)

I've highlighted the problem as .Problem...

If anyone's already managed to do this, can I have a look please?


See ya,
-- 
<tsb>
<sb>James L Boyd - jamesboyd@all-hail.freeserve.co.uk
<sb>Member of Team *AMIGA*, and *Dogbert's New Ruling Class.*
<sb>Connected from Dundee, Scotland. 
<sb>(http://surf.to/all-hail/)
<tsb>

Good morning, doctors. I have taken the liberty of removing 
Windows 95 from my hard drive.
-- HAL's first words contest winner, judged by Arthur C. Clarke.

--BOUNDARY.1748035440.2
Content-Disposition: attachment; filename="IconPic.asc"
Encoding: quoted-printable
Content-Description: Poor attempt at icon image loading

Function.l LoadIcon {icon$}
  *icon.DiskObject=3DGetDiskObjectNew_ (&icon$)
  Function Return *icon
End Function

Function.l UnSelectedIconImage {*icon.DiskObject}
  If *icon
    *image.Image=3D*icon\do_Gadget\GadgetRender
    Function Return *image
  EndIf
End Function

Function.l SelectedIconImage {*icon.DiskObject}
  If *icon
    *image.Image=3D*icon\do_Gadget\SelectRender
    Function Return *image
  EndIf
End Function

Function.w IconWidth {*icon.DiskObject}
  If *icon
    width.w=3D*icon\do_Gadget\Width
    Function Return width
  EndIf
End Function

Function.w IconHeight {*icon.DiskObject}
  If *icon
    height.w=3D*icon\do_Gadget\Height
    Function Return height
  EndIf
End Function

Function.b IconDepth {*icon.DiskObject}
  If *icon
    *image.Image=3D*icon\do_Gadget\GadgetRender
    deep.w=3D*image\Depth
    Function Return deep
  EndIf
End Function

Statement FreeIcon {*icon.DiskObject}
  If *icon
    FreeDiskObject_ *icon
  EndIf
End Statement

FindScreen 0

Window 0,20,20,320,100,$20140f,"",1,2

*win.Window=3DPeek.l(Addr Window(0))

*rp.RastPort=3D*win\RPort

*icon=3DLoadIcon {"Sys:utilities/multiview"}

If *icon

  *unselected.Image =3D UnSelectedIconImage {*icon}
  *selected.Image   =3D SelectedIconImage {*icon}
  width.w           =3D IconWidth {*icon}
  height.w          =3D IconHeight {*icon}
  deep.w            =3D IconDepth {*icon}

  NPrint "Unselected image location : ",  *unselected
  NPrint "Selected image location   : ",  *selected
  NPrint "Icon width                : ",  width
  NPrint "Icon height               : ",  height
  NPrint "Icon depth                : ",  deep

 *bm.BitMap=3DAllocBitMap_ (width,height,deep,#BMF_DISPLAYABLE|#BMF_CLEAR=
,0)

  If *bm

    *bm\BytesPerRow =3D ((width+15)/16)*2  ; see original below...
    *bm\Rows        =3D height-1           ; don't know why...

=2EProblem

    For plane.b=3D1 To 8
      *bm\Planes [plane] =3D *unselected\ImageData+(plane*(*bm\BytesPerRo=
w)*(*bm\Rows))
    Next plane

;------------------------------------------------------------------------=
--

=2EOriginal

; Original C source :

;   //Set up a BitMap For the normal image
;   BM[0].BytesPerRow =3D ((WorkIcon->do_Gadget.Width+15)/16)*2;
;   BM[0].Rows =3D WorkIcon->do_Gadget.Height - 1;
;   BM[0].Depth =3D ((struct Image *)WorkIcon->do_Gadget.GadgetRender)->D=
epth;
;   //Calculate the address of each plane For the BitMap
;   For(Plane=3D0;Plane<BM[0].Depth;Plane++)
;      BM[0].Planes[Plane] =3D (PLANEPTR)(((Int)(((struct Image *)
;      WorkIcon->do_Gadget.GadgetRender)->ImageData))+
;      Plane*BM[0].BytesPerRow*BM[0].Rows);


;------------------------------------------------------------------------=
--

  ; eventually, hopefully :

  If BltBitMapRastPort_ (*bm,0,0,*rp,10,10,width,height,$C0)=3D0
    Request "","Blit failure!","OK"
  EndIf

  FreeBitMap_ *bm

  EndIf ; from "If *bm..."

  FreeIcon {*icon}

Else Request "","Didn't get icon!","ABORT!"
EndIf

MouseWait
End



--BOUNDARY.1748035440.2

