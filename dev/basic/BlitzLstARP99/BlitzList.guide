GTButton 0,2,50,10,30,15,"2",$0
GTButton 0,3,90,10,30,15,"3",$0
GTButton 0,4,10,35,30,15,"4",$0
GTButton 0,5,50,35,30,15,"5",$0
GTButton 0,6,90,35,30,15,"6",$0
GTButton 0,7,10,60,30,15,"7",$0
GTButton 0,8,50,60,30,15,"8",$0
GTButton 0,9,90,60,30,15,"9",$0
GTButton 0,10,10,85,110,15,"Enter",$0
GTText 0,11,50,110,70,15,"",$0,""
Window 0,0,0,150,150,$0001|$0002|$0004|$0008,"Assembler Input",0,1
AttachGTList 0,0
Window 1,150,0,150,100,$0001|$0002|$0004|$0008,"Assembler Output",0,1

Macro INP
Use Window 0
num$=""
  Repeat
    Select WaitEvent
      Case $200 ;close gadget hit
        exit=1
      Case $40  ;gadget hit
        Select GadgetHit
          Case 0
            num$=num$+"0"
            GTSetString 0,11,num$
          Case 1
            num$=num$+"1"
            GTSetString 0,11,num$
          Case 2
            num$=num$+"2"
            GTSetString 0,11,num$
          Case 3
            num$=num$+"3"
            GTSetString 0,11,num$
          Case 4
            num$=num$+"4"
            GTSetString 0,11,num$
          Case 5
            num$=num$+"5"
            GTSetString 0,11,num$
          Case 6
            num$=num$+"6"
            GTSetString 0,11,num$
          Case 7
            num$=num$+"7"
            GTSetString 0,11,num$
          Case 8
            num$=num$+"8"
            GTSetString 0,11,num$
          Case 9
            num$=num$+"9"
            GTSetString 0,11,num$
          Case 10
            exit=1
        End Select
    End Select
  Until exit=1
  num=Val(num$)
  PutReg d0,num
End Macro

Macro OUT
GetReg d0,num
Use Window 1
NPrint num
End Macro


    !INP
    MOVE.b d0,d1
    MOVE.l d4,-(a7)
    !INP
    MOVE.b (a7)+,d2
    MOVE.b d0,d2
    CMP.b d1,d2
    BGT.b GREAT
    MOVE.b d2,d0
    !OUT
    MOVE.b d1,d0
    !OUT
GREAT:
    MOVE.b d1,d0
    !OUT
    MOVE.b d2,d0
    !OUT
    MouseWait
    End


