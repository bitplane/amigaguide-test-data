<tsb>

--BOUNDARY.272717320.1
Content-Disposition: attachment; filename="SoundStudio.ASC"

;
; Small octamixplayer.library conversion
; By Robert Hutchinson 1999. SD Software.
;
; FREELY distributable
;

  ;--- Module path.. MMD3 only!
  ;
  FilePath$="CUCD27:CUCD/Sound/Modules/oss.sunrise"

  ;--- Module frequency
  ;
  Freqy.l=22000

  alloc.l=GetPlayerM_
  If alloc<>0
    FreePlayerM_
    NPrint "Cant Allocate resources!.."
    End
  EndIf

  ;--- Check for MMD3 fileformat...
  ;
  If ReadFile(0,FilePath$)
    FileInput 0
    fileform$=Inkey$(4)
    If fileform$<>"MMD3"
      CloseFile 0
      FreePlayerM_
      End
    EndIf
    CloseFile 0
  Else
    NPrint "Cant load file: "+FilePath$
    FreePlayerM_
    End
  EndIf

  ;--- Load and play...
  ;
  *OurMod.l=LoadModule_FastM_(&FilePath$)
  SetMixingFrequency_(Freqy)
  PlayModuleM_ *OurMod

  ;--- Wait...
  ;
  MouseWait

  ;--- Stop, Free and end..
  ;
  StopPlayerM_
  UnLoadModuleM_ *OurMod
  FreePlayerM_

  End




--BOUNDARY.272717320.1
