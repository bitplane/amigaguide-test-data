@NODE "Mail_916" "Weird machine hangups"
 for scott@online.u-net.com; Wed, 14 Apr 1999 12:30:49 +0100
From: Gareth Griffiths <gaz@jokerd.freeserve.co.uk>
Date: Wed, 14 Apr 1999 12:26:45 +0100
Organization: Joker Developments
Subject: Weird machine hangups

--BOUNDARY.3588760.1

Hi,
   I've attached the source code (entire) to my mod player (atm) as yet it
doesnt really have any outstanding features, it just displays a gui with a
few buttons, and you just click on load etc. etc.

I've also attached the default shapes for it. copy this file to workbench:t/
or just change the src code.

Please could you test it to see if it hangs your machine before the gui
appears. I don't know if its an enforcer hit, cos I ain't got an 030MMU. 

cheers.   
Cya!
-- 
/---------------------------------------+------------------\
| Gareth Griffiths (Joker Developments) | A1200 w/ 680EC20 |
| E-Mail: gaz@jokerd.freeserve.co.uk    | 2mb + 8mb Fast   |
| WWW:    www.jokerd.freeserve.co.uk    | 773mb HD, 8x CD  |
| ICQ:    GazChap (31023012)            | 56k Modem        |
\---------------------------------------+------------------/

--BOUNDARY.3588760.1
Content-Disposition: attachment; filename="mp22.asc"
Encoding: binary
Content-Description: ascii source code for modplayer 2.2

.initprog
  WBStartup : NoCli : CloseEd : FindScreen 0
  MaxLen f$=192 : MaxLen p$=192 : MaxLen m$=192+192
  v$="$VER: Mod Player 2.2 (15-04-99)"
  imgpath$="" : stmod$=""
  setpath$="PROGDIR:Settings"
  *scr.Screen = Peek.l(Addr Screen(0))
  fonty.w = *scr\Font\ta_YSize
  ptmod=False : medmod=False
  ptplay=False : medplay=False : setmed=False
  SetInt 5
    PlayMed
    VWait
  End SetInt

.loadsettings
  s=ReadFile(1,setpath$)
  If s=True
    FileInput 1
    imgpath$=Edit$(192)
    stmod$=Edit$(192+192)
    CloseFile 1
    DefaultInput
  Else
    noshapes=True
  EndIf

.checksettings
  If imgpath$<>""
    noshapes=False
    If stmod$<>""
      stmod=True
    Else
      stmod=False
    EndIf
    Goto initgads
  Else
    noshapes=True
    If stmod$<>""
      stmod=True
    Else
      stmod=False
    EndIf
    Goto initgads
  EndIf

.initgads
  If noshapes=True Then DecodeShapes 1,?defimgs
  If noshapes=False
    LoadShape 1,imgpath$+"off_load.iff"
    LoadShape 2,imgpath$+"on_load.iff"
    LoadShape 3,imgpath$+"off_rew.iff"
    LoadShape 4,imgpath$+"on_rew.iff"
    LoadShape 5,imgpath$+"off_play.iff"
    LoadShape 6,imgpath$+"on_play.iff"
    LoadShape 7,imgpath$+"off_ff.iff"
    LoadShape 8,imgpath$+"on_ff.iff"
    LoadShape 9,imgpath$+"off_stop.iff"
    LoadShape 10,imgpath$+"on_stop.iff"
    LoadShape 11,imgpath$+"off_eject.iff"
    LoadShape 12,imgpath$+"on_eject.iff"
  EndIf

.initgui
  sw=ShapeWidth(1) : sh=ShapeHeight(1)
  ww=fonty.w+((6*sw)+3) : wh=sh+fonty.w*2
  wx=(WBWidth/2)-(ww/2) : wy=(WBHeight/2)-(wh/2)
  For count=1 To 6
    ShapeGadget 1,(sw*count)+(2-sw),2,0,count,(2*count)+(1-2),((2*count)+(1-2)+1)
  Next count

  Window 1,wx,wy,ww,wh,5134,"MOD Player",1,2,1
  CatchDosErrs
  If stmod$<>"" Then Goto load

.mainloop
  If medplay=True
    Disable 1,2 : Disable 1,4
    Redraw 1,2 : Redraw 1,4
  EndIf
  If ptplay=True
    Enable 1,2 : Enable 1,4
    Redraw 1,2 : Redraw 1,4
  EndIf
  Repeat
    ev.l=WaitEvent
    If ev=$200
      End
    EndIf
    If ev=$40
      Select EventWindow
        Case 1
          Select GadgetHit
            Case 1
              Goto load
            Case 2
              Goto rew
            Case 3
              Goto play
            Case 4
              Goto ff
            Case 5
              Goto _stop
            Case 6
              Goto eject
          End Select
      End Select
    EndIf
  Until ev=$200
  End

.load
  If stmod$<>""
    m$=stmod$
    Goto checkmod
  EndIf
  m$=ASLFileRequest$("Load...",p$,f$)
  If m$="" Then Goto mainloop
  checkmod:
  If Exists(m$)
    If OpenFile(0,m$)=True
      FileInput 0 : h$=Edit$(4) : CloseFile 0 : DefaultInput
      If h$="MMD0" OR h$="MMD1"
        medmod=True : ptmod=False
      Else
        medmod=False : ptmod=True
      EndIf
    EndIf
  Else
    r=RTEZRequest("Error","The selected file does not exist!"," OK ")
    Goto mainloop
  EndIf

  If medmod=True AND ptmod=False
    LoadMedModule 0,m$
    StartMedModule 0
    ptplay=False : medplay=True
    Goto play
  EndIf
  If ptmod=True AND medmod=False
    s=LoadTrackerModule(0,m$)
    If CheckTrackerID(0)=True
      ptplay=True : medplay=False
      Goto play
    Else
      r=RTEZRequest("Error","Not a valid module. It might be PP'd."," OK ")
      Goto mainloop
    EndIf
  EndIf

.play
  If ptmod=True AND ptplay=True
    s=StartTracker(0)
    setmed=False
    Goto mainloop
  EndIf
  If medmod=True AND medplay=True
    setmed=True
    PlayMed
    Goto mainloop
  EndIf

.rew
  If ptmod=True AND ptplay=True
    pos=GetModulePosition
    ModulePositionJump(pos-1)
    Goto mainloop
  EndIf

.ff
  If ptmod=True AND ptplay=True
    pos=GetModulePosition
    ModulePositionJump(pos+1)
    Goto mainloop
  EndIf

._stop
  StopTracker : StopMed
  Goto mainloop

.eject
  If ptmod=True
    FreeTrackerModule 0
    Goto mainloop
  EndIf
  If medmod=True
    Free MedModule 0
    Goto mainloop
  EndIf

.incbin
  INCDIR "Workbench:T/"
  defimgs: IncBin "MP22defimgs.shp"

--BOUNDARY.3588760.1
