You robbed my idea man;, oh well,.. take a look at this:

;
; NewIcons via the newicon.library in Blitz
; By Robert Hutchinson 20/04/1999
;
; Feel free to use this program in anyway you wish.
; Email me with any bugs or changes please:
;
;   loki@napalmdeath.freeserve.co.uk
;

  ; o--> NewIcon base!
  ;/
  NEWTYPE .NewIconBase
    nib_Lib.Library

    *nib_SegList
    nib_Precision.l
    nib_Flags.l
    nib_DPMode.l
    nib_FOMod.l
    nib_Reserved.l
  End NEWTYPE

  ;  o--> This mask can be used to isolate the user
  ; /     preferences part of the flags
  ;/
  #NIFLG_PUBMASK      = $0FFFF

  ; o--> Library base flags
  ;/
  #NIFLG_DO_DITHER    = $00001
  #NIFLG_RESERVED     = $00002
  #NIFLG_RTGMODE      = $00004
  #NIFLG_NOBORDER     = $00008
  #NIFLG_TRANSPARENT  = $00010
  #NIFLG_TRANSDRAG    = $00020

  ; o--> System flags (0xFFFF0000) - These are READ-ONLY!
  ;/
  #NIFLG_IS_DISABLED  = $10000
  #NIFLG_LIBRTG       = $20000
  #NIFLG_LIBDIT       = $40000

  #NIDPM_NEVER        = 0
  #NIDPM_WBONLY       = 1
  #NIDPM_ALL          = 2

  #NIFOM_NONE         = 0
  #NIFOM_OUTLINE      = 1
  #NIFOM_SHADOW       = 2

  NEWTYPE .ChunkyImage
    Width.w
    Height.w
    NumColors.w
    Flags.w
    *Palettez.b
    *ChunkyData.b
  End NEWTYPE

  #CIF_COLOR_0_TRANSP = 0
  #CIF_DEFAULT        = 1

  NEWTYPE .NewDiskObject
    *ndo_StdObject.DiskObject
    *ndo_NormalImage.ChunkyImage
    *ndo_SelectedImage.ChunkyImage
  End NEWTYPE

  NEWTYPE .NewIconsPrefs
    version.w
    flags.l
    precision.l
    dpmode.l
    fomode.l
  End NEWTYPE

;
; Commands that should be availible to you by now.....
;
;  FreeNewDiskObject_
;  FreeRemappedImage_
;  GetDefNewDiskObject_
;  GetNewDiskObject_
;  PutNewDiskObject_
;  RemapChunkyImage_

WbToScreen 0
WBenchToFront_

DEFTYPE .NewIconBase *NewIconBase
DEFTYPE .NewDiskObject *ourstruct
;DEFTYPE .Image *ournewimage
Dim List *ournewimage.Image(2)


;*ourstruct\ndo_NormalImage\Flags=#CIF_COLOR_0_TRANSP

OurIcon$="Work:NewIconsV4/Extras"
*ourstruct=GetNewDiskObject_(&OurIcon$)
If *ourstruct
  NPrint "File loaded ok!"
Else
  NPrint "File failed to load!"
  End
EndIf

If *ourstruct\ndo_NormalImage
  *ournewimage(0)=RemapChunkyImage_(*ourstruct\ndo_NormalImage,Peek.l(Addr Screen(0)))
  If *ournewimage(0)
    NPrint "Remapped Normal ok!"
  Else
    NPrint "Failed to remap Normal!"
    FreeNewDiskObject_(*ourstruct)
    End
  EndIf
Else
  NPrint "No NewIcon Normal Image within Icon, Terminating..."
  End
EndIf

If *ourstruct\ndo_SelectedImage
  *ournewimage(1)=RemapChunkyImage_(*ourstruct\ndo_SelectedImage,Peek.l(Addr Screen(0)))
  If *ournewimage(1)
    NPrint "Remapped Selected image ok!"
  Else
    NPrint "Failed to remap Selected image!"
    FreeNewDiskObject_(*ourstruct)
    End
  EndIf
Else
  NPrint "No NewIcon Selected Image within Icon, Continuing..."
  NoSelected=1
EndIf

ImgW=*ourstruct\ndo_NormalImage\Width
ImgH=*ourstruct\ndo_NormalImage\Height

NPrint "Opening window!"
Window 0,0,0,ImgW+10,(ImgH*2)+11,$0,"",0,1
DefaultOutput

NPrint "Drawing image to window..."
DrawImage_ RastPort(0),*ournewimage(0),5,5
If NoSelected=0
  DrawImage_ RastPort(0),*ournewimage(1),5,6+ImgH
EndIf
MouseWait

NPrint "Freeing our newicon structure"
FreeNewDiskObject_(*ourstruct)

NPrint "All done!"
End


