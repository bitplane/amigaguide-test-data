> DEFTYPE .Window NewWin
> 
>   Title$="A Test Window!"
> 
>   NewWin\LeftEdge   = 0
>   NewWin\TopEdge    = 0
>   NewWin\Width      = 400
>   NewWin\Height     = 100
>   NewWin\DetailPen  = 3
>   NewWin\BlockPen   = 2
>   NewWin\IDCMPFlags = IDCMP_MOUSEBUTTONS
>   NewWin\Flags      = #WFLG_SIZEBBOTTOM|#WFLG_CLOSEGADGET|#WFLG_SIZEGADGET|#WFLG_DEPTHGADGET|#WFLG_DRAGBAR|#WFLG_ACTIVATE
>   NewWin\MinWidth   = 20
