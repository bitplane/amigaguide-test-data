Encoding: plain (7/8 bit)
Content-Disposition: attachment; filename="Bank-aMIGA_dUDE0001.ASCII"
X-MD2-FilePath: Ram Disk:Bank-aMIGA_dUDE0001.ASCII

; Andrew Guard
; aMIGA_dUDE@assign.u-net.com
; Author of ProPassWord as my sins.
; Shows how to use memory bank.
; This probley the only thing I have ever learnt for Blitz manual, the BANK commaneds.
; Sunday 11/04/99

; This will make the dummy data for system to work on
; Why not use Functions, simple they are slow!

SDebugTraker.b=True

If WriteFile(0,"Ram:Use_PPW")
  FileOutput 0
    NPrint "You should use PPW!"
    NPrint "And if you do you know why you chose it!"
    NPrint "Because I respect the power of the POKE."
    NPrint "Whilsed wrighting this example this source my"
    NPrint "Amiga Crashed because of typo!"
  CloseFile 0
EndIf

DefaultOutput ; re-diverts output data to Shell.

;Now for securtes on how Bank's work.  (If you lone 1000 from them they have you but if you lone 10Million you have them)

LoadBank 0,"RAM:Use_PPW"

Gosub ProcBankLocations
Gosub ProcExampleBANK

SaveBank 0,"RAM:Use_PPW_now"

FreeBank 0

LoadBank 0,"RAM:Use_PPW_now"

Gosub ProcBankLocations
Gosub ProcExampleBANK

SaveBank 0,"RAM:Use_PPW_now_m8"

End

ProcBankLocations:

  ;NOTE : This is very important memory must (MUST) be a long number.
  ;If it isn't your Amiga WILL CRASH!  Or you lame work will sooner or latter CRASH someone's Amiga.
  ;You can also CRASH Amiga if you try write data were you haven't reserve memory.
  ;Amiga owns will not thank you if you don't make shore of this!!!

  SBank0.l=Bank(0) ;You don't have do this why but it my style
  SBankSize0.l=BankSize(0)
  SBankEnd0.l=SBank0.l+SBankSize0.l
  SBankLive0.l=SBank0.l

  If SDebugTraker.b=True
    NPrint "Bank      "+Str$(SBank0.l)
    NPrint "Bank size "+Str$(SBankSize0.l)
    NPrint "Bank end  "+Str$(SBankEnd0.l)
    NPrint "Bank live "+Str$(SBankLive0.l)
  EndIf
Return

ProcExampleBANK:

  ; The code if not write corectly can get very dangers.
  ; If you are meassing about with this source you should understand this
  ; YOUR AMIGA CAN AND WILL CRASH IF YOU ARE NOT CAREFULL!
  ; This is truly fast way of working but can give endless grief if your not
  ; carefull.  Now don't say I didn't tell you this!
  ; Your Amiga can crash and if douse you will lose everything!
  ; This soruce is for educational purposes only.
  ; I make no clames about it fitness of use in your programes or relibility.
  ; You can use all this source in programes if you want to.

  ; You must respect the POKE, becuase it will not respect you!
  ; You will learn!
  ; IE ow no, I have lost all coding because I didn't respect the POKE.

  ; Do not underestimate how dangers this source could be!

  If SBankSize0.l>0
    Repeat
      SData.b=Peek.b(SBankLive0.l)
      ;This douse a (.b) Byte grab which is 1=Byte with a Range of +-128
      ;You can change this to (.w) Word which is 2=Bytes with a Range of +-32768
      ;(.l) Long 4=Bytes with a Range of +-2147483648
      ;To use .w/.l neads some big changes how this works. Be very carefull!
      If SDebugTraker.b=True
        NPrint Str$(SBankLive0.l)+"  "+Str$(SData.b)
      EndIf
      Poke.b SBankLive0.l,Xor(SData.b,1)
      SBankLive0.l+1 ;This vaule canhge depending on .b/.w/.l
    Until SBankLive0.l=SBankEnd0.l
  Else
    NPrint "There is no data!"
    End
  EndIf
Return


--=_=8<==MD237108125-3D563487==8<=_=

