Encoding: plain (7/8 bit)
Content-Disposition: attachment; filename="changetooltype.asc"
X-MD2-FilePath: Ram Disk:changetooltype.asc

; icon$=icon you want to read
; tool$=tooltype you're looking for
; value$=new tooltype value

Function.l ChangeToolType {icon$,tool$,value$}

  If Right$(icon$,5)=".info" Then icon$=Left$(icon$,Len(icon$)-5)

  retcode.l=0

  *Icon.DiskObject=GetDiskObject_(&icon$)

  If *Icon
    offset.w=0
    tta.l=*Icon\do_ToolTypes
    Repeat
      temp$=Peek$(Peek.l(tta+offset))
      WaitTOF_
      If UCase$(Left$(temp$,Len(tool$))) = UCase$(tool$)
        newstring$=UCase$(tool$+"="+value$)
        WaitTOF_
        Poke.l tta+offset,&newstring$
        retcode=1
      End If
      offset+4
    Until temp$=""
    succ.l=PutDiskObject_(&icon$,*Icon)
    FreeDiskObject_ *Icon
    If succ
      retcode+2
    End If
  EndIf

  Function Return retcode

End Function



;========
;  DEMO
;========

succ.l = ChangeToolType {"Ram:test","MESSAGE","WAHAAAAY!"}

If succ
  If succ AND 1
    NPrint "Changed Tooltype"
  End If
  If succ AND 2
    NPrint "Saved Icon"
  End If
Else
  NPrint "Failed Everything"
End If

MouseWait
End



--=_=8<==MD2371DF6CF-64C7CEF6==8<=_=

