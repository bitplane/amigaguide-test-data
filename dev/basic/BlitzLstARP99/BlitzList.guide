--BOUNDARY.2015793936.1
Content-Disposition: attachment; filename="tasklist.txt"

; Description:  Lists the tasks running and waiting
; Type:         System

Forbid_
*e.ExecBase = Peek.l(4);NExecBase

NPrint"List of tasks waiting"
*node.Node = *e\TaskWait\lh_Head
While *node\ln_Succ
    NPrint Peek$(*node\ln_Name)
    *node=*node\ln_Succ
Wend

NPrint ""
NPrint ""

NPrint "list of tasks ready to run"
*node.Node = *e\TaskReady\lh_Head
While *node\ln_Succ
    NPrint Peek$(*node\ln_Name)
    *node=*node\ln_Succ
Wend
Permit_
ClickMouse
Stop
End



--BOUNDARY.2015793936.1

