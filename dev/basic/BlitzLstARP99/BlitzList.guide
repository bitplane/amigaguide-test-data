Encoding: binary



; These are the MCC tags for this class
; \/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/

#MUIM_Mailtext_CopyToClip            =$8057013c
#MUIA_Mailtext_IncPercent            =$80570103 ; /* v10 [ISG] */
#MUIA_Mailtext_Text                  =$80570105 ; /* v10 [ISG] */
#MUIA_Mailtext_QuoteChars            =$80570107 ; /* v10 [ISG] */
#MUIA_Mailtext_ForbidContextMenu     =$80570136 ; /* v18 [I..] */
#MUIA_Mailtext_ActionEMail           =$8057013a ; /* v19 [..G] */
#MUIA_Mailtext_ActionURL             =$8057013b ; /* v18 [..G] */
#MUIA_Mailtext_DisplayRaw            =$80570139 ; /* v18 [.SG] */
#MUIA_Mailtext_Wordwrap              =$8057013d ; /* v18 [.SG] */

; Of course you can put'em on another file qand include them


;**************************************************
;      Set up the needed application info         *
;**************************************************

  MUIApplicationTitle       "TEST"
  MUIApplicationVersion     "$VER: Example 1.0"
  MUIApplicationCopyright   ""
  MUIApplicationAuthor      ""
  MUIApplicationDescription ""
  MUIApplicationBase        "Test"

;**************************************************
;                  Build the GUI                  *
;**************************************************

  Title$="Test title"

  MUIAddTags 0,#MUIA_Frame,#MUIV_Frame_ReadList
  MUIAddTags 0,#MUIA_Mailtext_IncPercent,40
  MUIAddTags 0,#MUIA_Mailtext_Text,Null("Subject: Isto e #apenas# um *teste* - grim@ip.pt")
  MUINewObject 0,"Mailtext.mcc",0
  MUISimpleButton 1,Str$(AvailMem_(1))
                                                                                                                              

  MUIAddObjsVGroup 10,0,1
  MUICreateVGroup 10

;**************************************************
;*              Create the application            *
;**************************************************
  MUIAddTags      7,#MUIA_Window_Width,400

  MUICreateWindow 7,"EFMUILib Example","Example",10
  MUIAddSubWindow 7
  If MUICreateApplication<>True Then End
  MUIApplicationObj 8

;**************************************************
;*           Setup the MUI notifications          *
;**************************************************

  MUINotify 7,#MUIA_Window_CloseRequest,1,8,#MUIM_Application_ReturnID,-1

;**************************************************
;               Setup the main loop               *
;**************************************************

  MUIOpenWindow 7
  Repeat
    VWait
    ev.l=MUIWaitEvent
  Until ev=-1
  MUICloseWindow 7
  End


--BOUNDARY.2016139864.7
