Content-Disposition: attachment; filename="OpenWindowWithOS.ASC"
Encoding: binary

;
; Open an window completely with the OS in Blitz.
; By Rob Hutchinson 1999 -Some code ripped from a C source ;)
;

DEFTYPE .Window NewWin

  Title$="A Test Window!"

  NewWin\LeftEdge   = 0
  NewWin\TopEdge    = 0
  NewWin\Width      = 400
  NewWin\Height     = 100
  NewWin\DetailPen  = 3
  NewWin\BlockPen   = 2
  NewWin\IDCMPFlags = IDCMP_MOUSEBUTTONS
  NewWin\Flags      = #WFLG_SIZEBBOTTOM|#WFLG_CLOSEGADGET|#WFLG_SIZEGADGET|#WFLG_DEPTHGADGET|#WFLG_DRAGBAR|#WFLG_ACTIVATE
  NewWin\MinWidth   = 20
  NewWin\MinHeight  = 40
  NewWin\MaxWidth   = 640
  NewWin\MaxHeight  = 480
  NewWin\WScreen    = ActiveScreen
;  NewWin\Type       = 0x0001
  NewWin\Title      = &Title$

  *OurWin = OpenWindow_(&NewWin)
  Delay_(300)
  CloseWindow_ &NewWin



--BOUNDARY.271435056.1

