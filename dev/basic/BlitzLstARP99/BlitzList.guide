*rp.RastPort=3D*win\RPort

*icon=3DLoadIcon {"Sys:utilities/multiview"}

If *icon

  *unselected.Image =3D UnSelectedIconImage {*icon}
  *selected.Image   =3D SelectedIconImage {*icon}
  width.w           =3D IconWidth {*icon}
  height.w          =3D IconHeight {*icon}
  deep.w            =3D IconDepth {*icon}

  NPrint "Unselected image location : ",  *unselected
  NPrint "Selected image location   : ",  *selected
  NPrint "Icon width                : ",  width
  NPrint "Icon height               : ",  height
  NPrint "Icon depth                : ",  deep

 *bm.BitMap=3DAllocBitMap_ (width,height,deep,#BMF_DISPLAYABLE|#BMF_CLEAR=
,0)

  If *bm

    *bm\BytesPerRow =3D ((width+15)/16)*2  ; see original below...
    *bm\Rows        =3D height-1           ; don't know why...


=2ENoProblem                ;start with plane 0!

    For plane.b=3D0 To deep-1
      *bm\Planes [plane] =3D *unselected\ImageData+(plane*(*bm\BytesPerRo=
w)*(*bm\Rows))
