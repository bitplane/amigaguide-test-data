Content-Disposition: attachment; filename="MEDFuncs.asc"
Encoding: quoted-printable

; OctaMed Playing Routines v1.2
; Rick Hodger
;
; Created for "Dafel: Bloodline"
;
; Current maximum is for 5 med modules to be loaded at any one
; time, they are all loaded into fast mem. This can be altered
; by changing the #MAXMEDS constant, although you must remember
; that the '0' is used, so a maximum of 5 would actually be
; 0, 1, 2, 3, 4 and you should set the constant to '4'
;
; WARNING: COMMERCIAL USE OF FOLLOWING ROUTINES REQUIRES
; A LICENSE TO BE BOUGHT. INFORMATION ABOUT THIS CAN BE FOUND
; IN THE FILE 'LICENSE.DOC' WHICH IS CONTAINED WITH THE DEVELOPER
; INFORMATION IN THE SOUNDSTUDIO PACKAGE.
;
; Command List
; ------------
; result=3DCheckMEDLibs{}
; ShutMEDLibs{}
; result=3DInitMEDLibs{MIDI.b,PLAYER.b}
; MEDUnload{MODULENOS.l}
; result=3DMEDLoad{MODULENOS.l,FILENAME$}
; MEDPlay{MODULENOS.l}
; MEDStop{}
; MEDContinue{}
;
; See the autodocs for the libraries for other commands, specific
; to those libraries.
;
; History
; =3D=3D=3D=3D=3D=3D=3D
;
; 24.9.98
; -------
; First write.  Some bugs, including one in Blitz.
; Because Blitz doesn't readily recognise tokens with numbers
; in them it tries to use "PlayModule" instead of "PlayModule8_"
; The only way round this is to deactivate the trackerlib.obj
; in the acidlibs.
;
; 25.9.98
; -------
; Added continue function, changed InitMEDlibs{} so that it will
; close the players if they are already opened.
;
; 8.10.98
; --------
; Removed null() commands, shrinks the final exe of the test
; routines by 12 Kb (18540 bytes total). Optimised functions
; and statements. Added check in the play routine to run MEDStop{}
; if another med is already playing. Added ability to use CHIP mem
; as well as FAST mem. Added HQ mode, 14bit mode and mixing
; frequency, see autodocs for more info on these.
;
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D

#TEST=3D1           ; Use Built-in Test routine (1=3DUse/0=3DDon't use)
#FASTMEMMODE=3D1    ; Use FAST Mem (1=3DYes/0=3DNo)
#BUFFERSIZE=3D100   ; Buffer size for FAST Mem, must be divisable
                  ; by four. (Max of 400)
#MAXMEDS=3D4        ; Max number of meds at any one time.

#MED4CHN=3D0        ; Channel    }
#MED8CHN=3D1        ; Mode       } Don't change these!
#MED64CHN=3D2       ; Constants  }
#HQMODE=3D1         ; HQ mode for 8 channel meds, see autodocs.
#BIT14MODE=3D1      ; 14 Bit mode for 64 channel meds, see autodocs.
#MIXFREQ=3D15000    ; Frequency for 64 channel meds.
                  ; (Needs to be about 28800 for 50Hz screens)
#STOPPED=3D0
#PLAYING=3D1
#PAUSED=3D2

NEWTYPE.medinfo
  init.b
  playertype.b
  modules.l[#MAXMEDS]
  modtype.l[#MAXMEDS]
  status.b
  current.b
End NEWTYPE
Dim medinfo.medinfo(1)
medinfo(1)\init=3DFalse
medinfo(1)\status=3D#STOPPED

=2ECheckMEDLibs
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
; DESCRIPTION: Checks that the needed libraries are available.
; RESULT:      Returns true if ok, false otherwise.
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
Function CheckMEDLibs{}
  ;
  lib.l=3DOpenLibrary_("medplayer.library",7)
  If lib.l=3D0
    ret=3DFalse
  Else
    CloseLibrary_(lib.l)
    lib.l=3DOpenLibrary_("octaplayer.library",6)
    If lib.l=3D0
      ret=3DFalse
    Else
      CloseLibrary_(lib.l)
      lib.l=3DOpenLibrary_("octamixplayer.library",7)
      If lib.l=3D0
        ret=3DFalse
      Else
        CloseLibrary_(lib.l)
        ret=3DTrue
      EndIf
    EndIf
  EndIf
  ;
Function Return ret
End Function

=2EShutMEDLibs
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
; DESCRIPTION: Unloads the routines and libs.
;              DOES NOT UNLOAD MODULES!!!
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
Statement ShutMEDLibs{}
  SHARED medinfo()
  USEPATH medinfo(1)
  ;
  If \init=3DTrue
    Select \playertype
      Case #MED4CHN
        FreePlayer_
      Case #MED8CHN
        FreePlayerA_
      Case #MED64CHN
        FreePlayerM_
    End Select
    \init=3DFalse
  EndIf
  ;
End Statement

=2EInitMEDLibs
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
; DESCRIPTION: Initializes and loads the routines.
; SYNTAX:      InitMEDLibs{midi,player} - false=3Dno midi / true=3Duse mi=
di
;              Note: MIDI only works with 4 channel meds
;              'player' can be one of the three channel mode
;              constants.
; RESULT:      Returns true if ok, false otherwise.
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
Function InitMEDLibs{midi.b,player.b}
  SHARED medinfo()
  USEPATH medinfo(1)
  ;
  If \init=3DTrue
    ShutMEDLibs{}
  EndIf
  ;
  midi.b+1
  ;
  Select player.b
    Case #MED4CHN
      result=3DGetPlayer_(midi.b)
      \playertype=3D#MED4CHN
    Case #MED8CHN
      result=3DGetPlayerA_
      \playertype=3D#MED8CHN
      SetHQ_(#HQMODE)
    Case #MED64CHN
      result=3DGetPlayerM_
      \playertype=3D#MED64CHN
      Set14BitMode_(#BIT14MODE)
      SetMixingFrequency_(#MIXFREQ)
  End Select
  ;
  If result<>0
    FreePlayer_
    \init=3DFalse
    ret=3DFalse
  Else
    \init=3DTrue
    ret=3DTrue
  EndIf
  ;
Function Return ret
End Function

=2EMEDUnload
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
; DESCRIPTION: Unloads a module.
; SYNTAX:      MEDUnload{number}
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
Statement MEDUnload{num.l}
  SHARED medinfo()
  USEPATH medinfo(1)
  ;
  If \modules[num.l]>0
    UnLoadModule_(\modules[num.l])
    \modules[num.l]=3D0
    If num.l=3D\current Then \current=3D-1
  EndIf
  ;
End Statement

=2EMEDLoad
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
; DESCRIPTION: Loads a module to FAST mem.
;              (Set #FASTMEMMODE to 0 to use CHIP mem)
; SYNTAX:      MEDLoad{number,filename$}
; RESULT:      Returns true if ok, false otherwise.
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
Function MEDLoad{num.l,name$}
  SHARED medinfo()
  USEPATH medinfo(1)
  ;
  If \modules[num]>0
    MEDUnload{num.l}
  EndIf
  If Exists(name$)
    CNIF #FASTMEMMODE=3D1
      result.l=3DLoadModule_Fast_(&name$)
    CELSE
      result.l=3DLoadModule_(&name$)
    CEND
    If result>0
      ret=3DTrue
      \modules[num.l]=3Dresult
      \modtype[num.l]=3DRequiredPlayRoutine_(result)
      res=3DSetFastMemPlay_(#FASTMEMMODE,#BUFFERSIZE)
    Else
      NPrint result.l
      ret=3DFalse
    EndIf
  Else
    ret=3DFalse
  EndIf
  ;
Function Return ret
End Function

=2EMEDStop
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
; DESCRIPTION: Stops a currently playing module.
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
Statement MEDStop{}
  SHARED medinfo()
  USEPATH medinfo(1)
  ;
  If \status=3D#PLAYING AND \current>-1
    ;
    Select \playertype
      Case #MED4CHN
        StopPlayer_
      Case #MED8CHN
        StopPlayerA_
      Case #MED64CHN
        StopPlayerM_
    End Select
    ;
  EndIf
  ;
  \status=3D#STOPPED
  ;
End Statement

=2EMEDPlay
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
; DESCRIPTION: Plays and already loaded module.
; SYNTAX:      MEDPlay{number}
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
Statement MEDPlay{num.l}
  SHARED medinfo()
  USEPATH medinfo(1)
  ;
  If \status=3D#PLAYING Then MEDStop{}
  ;
  Select \modtype[num.l]
    Case #MED4CHN
      PlayModule_(\modules[num.l])
    Case #MED8CHN
      PlayModuleA_(\modules[num.l])
    Case #MED64CHN
      PlayModuleM_(\modules[num.l])
  End Select
  \status=3D#PLAYING
  \current=3Dnum.l
  ;
End Statement


=2EMEDContinue
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
; DESCRIPTION: Continues playing the last stopped module.
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
Statement MEDContinue{}
  SHARED medinfo()
  USEPATH medinfo(1)
  ;
  If \status=3D#STOPPED
    current.l=3D\current
    ;
    Select \modtype[current]
      Case #MED4CHN
        ContModule_(\modules[current])
      Case #MED8CHN
        ContModuleA_(\modules[current])
      Case #MED64CHN
        ContModuleM_(\modules[current])
    End Select
    ;
  EndIf
  ;
  \status=3D#PLAYING
  ;
End Statement


=2ETestIt
CNIF #TEST=3D1
  If CheckMEDLibs{}=3DTrue ; check the needed libraries are available
    NPrint "Libraries OK"
    ;
    If InitMEDLibs{Off,#MED4CHN}=3DTrue       ; initialize for 4 channels=
, no midi
      NPrint "Loading 4 channel support..."
      ;
      If MEDLoad{0,Par$(1)}=3DTrue ; Load the file (parameter 1) into slo=
t 0
        ;
        Select medinfo(1)\modtype[0]       ; Check the type of med
          Case #MED4CHN                    ; we've loaded.
            Print "4 channel MED loaded"
            ret=3DTrue
          Case #MED8CHN
            Print "8 channel MED loaded"
          Case #MED64CHN
            Print "64 channel MED loaded"
        End Select
        ;
        NPrint " at memory address $",Hex$(medinfo(1)\modules[0])
        ;
        If ret=3DFalse ; If it isn't a 4 channel med...
          ;
          If InitMEDLibs{0,medinfo(1)\modtype[0]} ; try to load the right=
 one.
            NPrint "Reloading channel support..."
          Else
            NPrint "Channel support failure!"
            ShutMEDLibs{}
            End
          EndIf
          ;
        EndIf
        ;
        contin:
        NPrint "Playing..."
        If playedalready=3DFalse
          MEDPlay{0}           ; Play the med in slot 0
        Else
          MEDContinue{}        ; continue playing if played already
        EndIf
        ;
        Repeat
          Delay_(4)
          If Joyb(0)=3D2        ; if rmb
            BLITZ             ; go into blitz mode
            VWait 250         ; for 5 secs
            AMIGA             ; then back to amiga mode
          EndIf
        Until Joyb(0)=3D1       ; continue playing til lmb
        playedalready=3DTrue
        ;
        MEDStop{}             ; Stop playing
        NPrint "Stopped"
        VWait 50
        ;
        Print "You wanna continue playing? "
        If Edit$(1)=3D"y" Then Goto contin
        ;
        MEDUnload{0}   ; remove the med from memory.
      Else
        NPrint "Module Loaded BAD"
      EndIf
      ;
      ShutMEDLibs{}    ; Close down the libraries.
    Else
      NPrint "Initialised BAD"
    EndIf
    ;
  Else
    NPrint "Libraries BAD"
  EndIf
  End
CEND

--BOUNDARY.21072272.1
Content-Disposition: attachment; filename="OSS_INCBIN.ASC"
Content-Description: Rob Hutchinson <loki@sdsoft.freeserve.co.uk>

;
; Small octamixplayer.library conversion
; By Robert Hutchinson 1999. SD Software.
;
; FREELY distributable
;

  ;--- Module path.. MMD3 only!
  ;
  FilePath$="work:oss.sunrise"

  ;--- Module frequency
  ;
  Freqy.l=20000

  alloc.l=GetPlayerM_
  If alloc<>0
    FreePlayerM_
    NPrint "Cant Allocate resources!.."
    End
  EndIf

Stop
;  *OurMod.l=LoadModule_FastM_(&FilePath$)
  SetMixingFrequency_(Freqy)

;  NPrint PeekTo$(*OurMod,0)
;  NPrint PeekTo$(?MEDMOD,0)

; Now this is the point where you originally told it to play straight from
; a chunk of memory, which is a big no-no. You have to get the libs
; to fix the med so it is then in a playable state using RelocModule_

  RelocModuleM_ ?MEDMOD

  PlayModuleM_ ?MEDMOD

  ;--- Wait...
  ;
  MouseWait

  ;--- Stop, Free and end..
  ;
  StopPlayerM_
;  UnLoadModuleM_ ?MEDMOD ; It'll automatically be freed when we quit
  FreePlayerM_

  End

MEDMOD
IncBin "work:oss.sunrise"








--BOUNDARY.21072272.1

