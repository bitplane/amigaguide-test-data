    MOVE.b d1,d0
    !OUT
GREAT:
    MOVE.b d1,d0
    !OUT
    MOVE.b d2,d0
    !OUT
    MouseWait
    End



--=_=8<==MD23726AEA5-2C0074F4==8<=_=

