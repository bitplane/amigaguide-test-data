@NODE "Mail_175" "Crawling Ants"
From: Curt Esser <camge@ix.netcom.com>
Date: Sat, 30 Oct 1999 07:30:24 -0500
Subject: Crawling Ants
X-UIDL: 6151eaa0586512064f94bf0bda6e6aae

--BOUNDARY.1747622032.1

Hi everybody,

Here is a corrected version of the crawling ants routine -
much simpler  (I was using the wrong OS function...)

Later...
-- 

                                    Yours electronically,
                                    Curt Esser
                                    camge@ix.netcom.com
                                    http://members.xoom.com/Curt_Esser/


--BOUNDARY.1747622032.1
Content-Disposition: attachment; filename="ants.asc"

;how to use crawling ants

;by Curt Esser  <camge@ix.netcom.com>
;last modified Oct 30 1999

;use and distribute as you like

;you'll need amigalibs.res

FindScreen 0
Window 0,0,0,320,180,$100e,"Drag a Box",-1,-1

;stick some junk in the window for the demo

WBox 20,20,59,100,7
WBox 160,45,223,170,2
WBox 38,90,310,144,1
WBox 97,19,157,111,3



*Windo.Window = Peek.l(Addr Window(0))
*port.RastPort=*Windo\RPort

Dim patrn.w(15)

patrn(0) = %1111111100000000  ;the patterns for the lines
patrn(1) = %1111111000000001  ;a 1 bit means draw
patrn(2) = %1111110000000011  ;a 0 bit means don't draw
patrn(3) = %1111100000000111  ;they MUST be words (16 bits)
patrn(4) = %1111000000001111
patrn(5) = %1110000000011111
patrn(6) = %1100000000111111
patrn(7) = %1000000001111111
patrn(8) = %0000000011111111
patrn(9) = %0000000111111110
patrn(10)= %0000001111111100
patrn(11)= %0000011111111000
patrn(12)= %0000111111110000
patrn(13)= %0001111111100000
patrn(14)= %0011111111000000
patrn(15)= %0111111110000000

delay.w=3

Repeat
  ev.l=WaitEvent

  Select ev

    Case$8                 ;mousebutton event!

      If MButtons=1        ;left button is down

        *port\LinePtrn = patrn(0)
        SetDrMd_ *port,2   ;inverse drawing

        left.w=WMouseX     ;get the starting point
        top.w=WMouseY

        While Joyb(0)=1

          right.w=WMouseX  ;the current mouse position
          bottom.w=WMouseY

          Move_ *port,left,top       ;set the drawing cursor

          Draw_ *port,right,top      ;draw the outline
          Draw_ *port,right,bottom
          Draw_ *port,left,bottom
          Draw_ *port,left,top

          Delay_(delay)              ;wait a bit

          Move_ *port,left,top       ;now erase it
          Draw_ *port,right,top
          Draw_ *port,right,bottom
          Draw_ *port,left,bottom
          Draw_ *port,left,top

          ptrn.b-1
          If ptrn <0 Then ptrn = 15  ;go to the next pattern
          *port\LinePtrn=patrn(ptrn)

        Wend                         ;button released - we're done...

        *port\LinePtrn=%1111111111111111   ;set back to full line drawing

        SetDrMd_ *port,1             ;restore the window's Jam mode

      EndIf

  End Select


Until ev=$200

End





--BOUNDARY.1747622032.1

