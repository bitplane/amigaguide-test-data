@NODE "Mail_474" "Mui NList Hook Example Here !!"
From: jean zydorczyk <jean.zydorczyk@libertysurf.fr>
Date: Wed, 15 Sep 1999 17:28:35 +0100
Subject: Mui NList Hook Example Here !!
X-UIDL: d982b8724f5576eff4c1018ba59e934b

--BOUNDARY.1748952736.2

Hi everyone,

    Here is my latest program. I've try to open multi-column with hook
function.  

    the program run, but it's not stable, because the Construct statement is
not very simple.

    I used allocvec_ for create an entry, but when the Pointer (*toto in
the program) was send to the Display statement, i losed the strings. 

    so, i used allocvec_ for store the strings, and used their pointers
in the entry newtype (*toto)

    If anyone know how to make a newtype who store a string ans not a
pointer of strings , then email me please ..

   

-- 
Jean ZYDORCZYK

Mail to: Jean.zydorczyk@libertysurf.fr

Current Projects:

    Filefrog.            :In Progress
    Bubble Bobble AGA   :In Progress



--BOUNDARY.1748952736.2
Content-Disposition: attachment; filename="Hook6.asc"
Encoding: quoted-printable

;*******************************************
;*                                         *
;*  MUI NLIST HOOK PROGRAMM                *
;*                                         *
;*  Written by Jean ZYDORCZYK              *
;*  E-Mail: Jean.zydorczyk@libertysurf.fr  *
;*                                         *
;*  Version 1.0 (Initial Release)          *
;*                                         *
;*******************************************


NEWTYPE.toto
  name$
  name2$
End NEWTYPE

WBStartup


!StackOpen{12000} ;Add 12k to the stack, as Suggested for NLists.

DEFTYPE.Hook chunkhook,chunkhook2,chunkhook3
chunkhook\h_Entry=3D?hook
chunkhook2\h_Entry=3D?hook2
chunkhook3\h_Entry=3D?hook3


  MOVE.l a5,globalbase

  MUIApplicationTitle       "Hook NList"
  MUIApplicationVersion     "$VER: Hook NList 1.0 (15.09.99)"
  MUIApplicationCopyright   ""
  MUIApplicationAuthor      "Jean Zydorczyk"
  MUIApplicationDescription "Hook NList"
  MUIApplicationBase        "Hool NList"

  #MUI_App                 =3D 0
    #MUI_Window1           =3D 1
      #MUI_GroupA1         =3D 2
        #MUI_GroupC1       =3D 3
          #MUI_NList1      =3D 4
          #MUI_NList1B     =3D 5
      #MUI_Add             =3D 6

  MUIAddTags   #MUI_NList1 ,#MUIA_NList_Title,True
  MUIAddTags   #MUI_NList1 ,#MUIA_NListview_Horiz_ScrollBar,1
  MUIAddTags   #MUI_NList1 ,#MUIA_NList_MultiSelect,#MUIV_NList_MultiSele=
ct_Always
  MUIAddTags   #MUI_NList1 ,#MUIA_NList_DisplayHook2, &chunkhook2
  MUIAddTags   #MUI_NList1, #MUIA_NList_ConstructHook2,&chunkhook
  MUIAddTags   #MUI_NList1, #MUIA_NList_DestructHook2, &chunkhook3
  MUIAddTags   #MUI_NList1, #MUIA_NList_Format,Null("BAR W=3D-1,BAR ")

  MUINewObject #MUI_NList1B,"NList.mcc",0
  MUINewObject #MUI_NList1 ,"NListview.mcc",#MUI_NList1B

  MUIAddObjsHGroup #MUI_GroupC1,#MUI_NList1
  MUIAddTags       #MUI_GroupC1,#MUIA_Group_HorizSpacing,5
  MUICreateHGroup  #MUI_GroupC1

  MUISimpleButton #MUI_Add,"Add Entry"

  MUIAddObjsVGroup #MUI_GroupA1,#MUI_GroupC1,#MUI_Add
  MUIAddTags       #MUI_GroupA1,#MUIA_Group_VertSpacing,5
  MUICreateVGroup  #MUI_GroupA1


  MUICreateWindow #MUI_Window1,"NLIST HOOK","NLSTHOOK",#MUI_GroupA1
  MUIAddSubWindow #MUI_Window1

  If MUICreateApplication<>True Then End
  MUIApplicationObj #MUI_App

  MUINotifyApp  #MUI_Window1,#MUIA_Window_CloseRequest,1,1
  MUINotifyApp  #MUI_NList1,#MUIA_NList_DoubleClick,1,3
  MUINotifyApp  #MUI_Add,#MUIA_Pressed,0,2
                                                                         =
                                                     =

  MUIOpenWindow #MUI_Window1

  ;*************************** MAIN *******************************

  DEFTYPE.toto jean
  DEFTYPE.l *ptr

  jean\name=3D"essai"
  jean\name2=3D"essai2"

  *ptr=3D&jean

  MUIDoMethod #MUI_NList1,#MUIM_NList_Insert,&*ptr,1,#MUIV_NList_Insert_B=
ottom

  jean\name=3D"jean"
  jean\name2=3D"the best"
  MUIDoMethod #MUI_NList1,#MUIM_NList_Insert,&*ptr,1,#MUIV_NList_Insert_B=
ottom

  Repeat
    ev.l=3DMUIEvent
    Select ev
      Case 2
        jean\name=3DRTEZGetString("name","enter the text",20)
        jean\name2=3DRTEZGetString("name2","enter the text2",20)
        MUIDoMethod #MUI_NList1,#MUIM_NList_Insert,&*ptr,1,#MUIV_NList_In=
sert_Bottom
      Case 3
        MUIDoMethod #MUI_NList1,#MUIM_NList_Remove,#MUIV_NList_Remove_Act=
ive
    End Select
    VWait
  Until ev=3D1

  !StackClose
  End

;**********************

Macro goto_hook
  JSR `1+6
End Macro

;**********************  CONSTRUCT STATEMENT

Runerrsoff
hook_jump:
Statement hook{*dahook.Hook, *ncm.NList_ConstructMessage,reg_a2.l}

  SHARED funcret.l

  DEFTYPE.toto *toto,*t
  *t=3D*ncm\entry

  *toto=3DAllocVec_(SizeOf.toto,#MEMF_FAST|#MEMF_PUBLIC|#MEMF_CLEAR)

  *str1.l=3DAllocVec_(Len(Peek$(&*t\name)),#MEMF_FAST|#MEMF_PUBLIC|#MEMF_=
CLEAR)
  *str2.l=3DAllocVec_(Len(Peek$(&*t\name2)),#MEMF_FAST|#MEMF_PUBLIC|#MEMF=
_CLEAR)

  Poke$ *str1,Peek$(&*t\name)
  Poke$ *str2,Peek$(&*t\name2)

  Poke.l *toto,*str1
  Poke.l *toto+4,*str2

  funcret=3D*toto
End Statement

;********************** DISPLAY STATEMENT

hook_jump2:
Statement hook2{*dahook.Hook, *ndm.NList_DisplayMessage,reg_a2.l}

  SHARED funcret.l
  DEFTYPE.toto *t
  *t=3D*ndm\entry
  If *t <> 0
    *ndm\strings[0]=3D&*t\name
    *ndm\strings[1]=3D&*t\name2
  Else
    *ndm\strings[0]=3DNull("jean")
    *ndm\strings[1]=3DNull("the best")
  EndIf
  funcret=3DTrue
End Statement

;********************** DESTRUCT STATEMENT

hook_jump3:
Statement hook3{*dahook.Hook, *ndm.NList_DestructMessage,reg_a2.l}

SHARED funcret.l
  DEFTYPE.toto *toto,*t
  *t=3D*ndm\entry
  If *t <>0
     FreeVec_ &*t\name
     FreeVec_ &*t\name2
     FreeVec_ *t
  EndIf
  funcret=3DTrue
End Statement


globalbase: Dc.l 0


;********************** CONSTRUCT HOOK

hook:

MOVEM.l   d1-d7/a0-a6,-(a7) ; Not d0!

MOVE.l    a0,d0
MOVE.l    a1,d1
MOVE.l    a2,d2

MOVE.l    globalbase,a5

!goto_hook{hook_jump}

GetReg d0,funcret

MOVEM.l   (a7)+,d1-d7/a0-a6 ; Not d0!

RTS

;********************** DISPLAY HOOK

Even
hook2:

MOVEM.l   d1-d7/a0-a6,-(a7) ; Not d0!

MOVE.l    a0,d0
MOVE.l    a1,d1
MOVE.l    a2,d2

MOVE.l    globalbase,a5

!goto_hook{hook_jump2}

GetReg d0,funcret

MOVEM.l   (a7)+,d1-d7/a0-a6 ; Not d0!

RTS

;********************** DESTRUCT HOOK

Even
hook3:

MOVEM.l   d1-d7/a0-a6,-(a7) ; Not d0!

MOVE.l    a0,d0
MOVE.l    a1,d1
MOVE.l    a2,d2

MOVE.l    globalbase,a5

!goto_hook{hook_jump3}

GetReg d0,funcret

MOVEM.l   (a7)+,d1-d7/a0-a6 ; Not d0!

