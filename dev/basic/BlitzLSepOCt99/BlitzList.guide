Content-Disposition: attachment; filename="Botch.ASC"



  WBStartup
  !StackOpen{16000}
  WbToScreen 0
  Use Screen 0

  ;####################################################################

      Macro NT +Chr$(0):End Macro

      Macro ES Chr$(27)+:End Macro
      Macro EM +Chr$(27)+:End Macro
      Macro EE +Chr$(27):End Macro

      Macro OL +Chr$(10):End Macro
      Macro ML +Chr$(10)+:End Macro

  ;####################################################################

  MUIApplicationTitle       "TESTY"
  MUIApplicationVersion     "$VER: TESTY"
  MUIApplicationCopyright   "TESTY"
  MUIApplicationAuthor      "TESTY"
  MUIApplicationDescription "TESTY"
  MUIApplicationBase        "TESTY"

  ;####################################################################

  #TEST_App                             = 0
    #TEST_Window1                       = 1
          #TEST_MainList                = 61
          #TEST_MainListView            = 62

  Dim PS$(200)

  PS$(01) = !ES"8A"
  PS$(02) = !ES"8B"
  PS$(03) = !ES"8C"
  PS$(04) = !ES"8D"

  #TEST_Maximum = 100

  ;####################################################################

  Dim *ben.b ((#TEST_Maximum)*4)
  Dim *blen.b((#TEST_Maximum))
  Dim TEST$  ((#TEST_Maximum)*4)

;  For TMP=0 To #TEST_Maximum*4
;    TEST$(TMP)=Chr$(0)
;    *ben(TMP)=&TEST$(TMP)
;  Next
;
;  For TMP=0 To #TEST_Maximum
;    *blen(TMP)=0
;  Next

  For A=0 To 16;#TEST_Maximum-1
    *blen(A)=&*ben((A*4))

    TEST$((A*4))   = "0" : *ben((A*4))  =&TEST$((A*4))
    TEST$((A*4)+1) = "1" : *ben((A*4)+1)=&TEST$((A*4)+1)
    TEST$((A*4)+2) = "2" : *ben((A*4)+2)=&TEST$((A*4)+2)
    TEST$((A*4)+3) = "3" : *ben((A*4)+3)=&TEST$((A*4)+3)
  Next


  MUIListHook On
  MUIAddTags   #TEST_MainList,#MUIA_Frame,#MUIV_Frame_InputList
  MUIList      #TEST_MainList,"BAR,BAR,BAR,",*blen()
  MUIListTitle #TEST_MainList,PS$(01),PS$(02),PS$(03),PS$(04)
  MUIListView  #TEST_MainListView,#TEST_MainList

  MUICreateWindow #TEST_Window1,"ARSE","TEST2",#TEST_MainListView
  MUIAddSubWindow #TEST_Window1

  If MUICreateApplication<>True
    JMP Do_CloseProgram
  EndIf
  MUIApplicationObj #TEST_App

  MUINotifyApp  #TEST_Window1,#MUIA_Window_CloseRequest,1,-1
  MUIOpenWindow #TEST_Window1

  Repeat
    VWait
    ev.l=MUIEvent
  Until ev=-1



  Do_CloseProgram
    !StackClose
    End



