Content-Disposition: attachment; filename="myfirstmuiprog.asc"

;# GazChap's first MUI proggy ;) #
#clickhit=0 : #close=0

MUIApplicationTitle "My first MUI prog"
MUIApplicationAuthor "Gareth Griffiths"
MUIApplicationCopyright "(C)1999 JD/FX"
MUIApplicationVersion "$VER: My first MUI prog 0.1beta"
MUIString 0,"Edit me!",192
MUISimpleButton 1,"Click me!"
MUIAddObjsVGroup 2,0,1
MUICreateVGroup 2
MUICreateWindow 3,"Test prog","TEST",2
MUIAddSubWindow 3
If MUICreateApplication<>True Then End
MUINotifyApp 1,#MUIA_Pressed,0,#clickhit
MUINotifyApp 3,#MUIA_Window_CloseRequest,1,#close
MUIOpenWindow 3
Repeat
  ev.l=MUIWaitEvent
  Select ev
    Case #clickhit
      MUIRequest 3,0,"Wahoo!","OK","You clicked the button!"
    Case #close
      End
  End Select
Forever





