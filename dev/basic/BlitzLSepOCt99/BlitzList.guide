; *********************************************************
;                   New ASL Library
;    Coded by AlphaSOUND - (c) 1998 Fantaisie software
; *********************************************************

; *********************************************************
;                     Example 1
;    Open the 3 ASL requesters one after other
; *********************************************************

; *********************************************************
;                     Begin INIT
; *********************************************************
;
;
; 31/01/1999
;   Use new taglist system.
;   Use NPeek$()

WBStartup

; Be sure to do ALL the Init stuff before try to END your
; program, else it will crash.
;
a.l =3D NInitASL

If a =3D 0
  NPrint "I Can't open the ASL.library V36+ !"
  NPrint "Bye bye..."
  NMouseWait
  End
EndIf

TagList.l =3D NInitTagList(10)




; *********************************************************
;            Start with the ASL file requester...
; *********************************************************


var1$ =3D "Amorel... NCS bugs ? No..."
var2$ =3D "It's YOUR fault !"
NResetTagList #ASLFR_TitleText    , &var1$
      NAddTag #ASLFR_InitialDrawer, &var2$
SelectedFile$ =3D NASLFileRequest(TagList)  ; Look, I use the default ASL=
 setting. Very quick ;-)

If SelectedFile$
  NPrint "File selected : ", SelectedFile$
  NPrint "Position and Size of the requester when quitting : "
  NPrint "Pos: (", NASLPosX, ",", NASLPosY, ") Size: ", NASLWidth, "*", N=
ASLHeight
Else
  NPrint "ASL File Requester cancelled."
EndIf



End


--BOUNDARY.1077651520.4

