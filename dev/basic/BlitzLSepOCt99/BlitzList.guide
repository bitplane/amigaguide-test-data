--BOUNDARY.19722320.1

Hello,

Here's a SaveIFF function I've written.

I've tried out various size pics (all loaded with the LoadBitMap command)
and they've all been able to save correctly.

Even has a ModeID parameter.

Can people try it out and send me any bug-reports (if any :)

I'll put in in with my DT-Pic functions, which will be updated shortly.

Cya,

    Leigh.

-- 

 A1200T - 040-33Mhz +16MbFast - 3.2Gig HD - 32x CD - ZIP

 EMail: mailto:lparry@ukonline.co.uk
 URL: http://web.ukonline.co.uk/lparry/

 Be alert - your country needs lerts.

--BOUNDARY.19722320.1
Content-Disposition: attachment; filename="Save_IFF.asc"
Encoding: binary

; Save IFF function
; By Leigh Parry  22-Oct-1999

; Saves out a bitmap to an iff file


; Pararmeters are :-
; Fyle.s      = Filename to save to
; *bm.BitMap  = Pointer the BitMap
;               (If using Blitz BitMap use  Addr BitMap(#))
; Palet       = Palette to save out to the file
; bwid        = REAL Width (To be stored in Header)
; valu        = ModeID to save in file  0=No Id
._Save_IFF
Function.l Save_IFF {Fyle.s,*bm.BitMap,Palet,bwid,valu}

  NEWTYPE .rgbcomp      :_red.l:_green.l:_blue.l: End NEWTYPE
  NEWTYPE .palettedata  :_numcols.w:_zero.w:_rgbs.rgbcomp[256]:_zero2.l: End NEWTYPE
  NEWTYPE .palette      :*_dat.palettedata:_numcols.w:_lowcol.w:_hicol.w:_speed.w:_var.w:_pad.b[114]: End NEWTYPE

  DEFTYPE.BitMapHeader   *bmhd
  DEFTYPE.l

  name$=Fyle.s
  modeid.l=valu

  bmwid=*bm\BytesPerRow
  bmhit=*bm\Rows
  bmdep=*bm\Depth
  bitmapsize=bmwid*bmhit*bmdep
  If bmwid*8=>bwid

    *bmhd\bmh_Width=bwid
    *bmhd\bmh_Height=bmhit
    *bmhd\bmh_Depth=bmdep
    *bmhd\bmh_Compression=0

    ID_ILBM=Asc("I")*$1000000+Asc("L")*$10000+Asc("B")*$100+Asc("M")
    ID_BMHD=Asc("B")*$1000000+Asc("M")*$10000+Asc("H")*$100+Asc("D")
    ID_CMAP=Asc("C")*$1000000+Asc("M")*$10000+Asc("A")*$100+Asc("P")
    ID_CAMG=Asc("C")*$1000000+Asc("A")*$10000+Asc("M")*$100+Asc("G")

    OK=0
    *iff.IFFHandle=AllocIFF_()
    If *iff
      lock.l=Open_(&name$,#MODE_NEWFILE)
      If lock
        *iff\iff_Stream=lock
        InitIFFasDOS_(*iff)
        ifferr.l=OpenIFF_(*iff,#IFFF_WRITE)
        If ifferr=0
          ifferr=PushChunk_(*iff,ID_ILBM,#ID_FORM,#IFFSIZE_UNKNOWN)
          If ifferr=0
            ifferr=PushChunk_(*iff,0,ID_BMHD,SizeOf.BitMapHeader)
            If ifferr=0
              ifferr=WriteChunkRecords_(*iff,*bmhd,SizeOf.BitMapHeader,1)
              If ifferr=1
                PopChunk_(*iff)
              End If
            End If
            ifferr=PushChunk_(*iff,0,ID_CMAP,#IFFSIZE_UNKNOWN)
            If ifferr=0
              *pal.palette=Addr Palette(Palet)
              penn=*pal\_numcols : paletsize=(penn)*3
              *padr=AllocVec_ (paletsize,0) ; change to ?
              If *padr
                For t = 0 To penn-1
                  cr.l=*pal\_dat\_rgbs[t]\_red MOD 256
                  cg.l=*pal\_dat\_rgbs[t]\_green MOD 256
                  cb.l=*pal\_dat\_rgbs[t]\_blue MOD 256
                  k.l=*padr+(t*3)
                  Poke.b k,cr : Poke.b k+1,cg : Poke.b k+2,cb
                Next t
                ifferr=WriteChunkBytes_(*iff,*padr,paletsize)
                If ifferr=paletsize
                  PopChunk_(*iff)
                End If
                FreeVec_ *padr
              End If
            End If
            If modeid
              ifferr=PushChunk_(*iff,0,ID_CAMG,4)
              If ifferr=0
                ifferr=WriteChunkBytes_(*iff,&modeid,4)
                If ifferr=4
                  PopChunk_(*iff)
                End If
              End If
            End If
            ifferr=PushChunk_(*iff,0,#ID_BODY,#IFFSIZE_UNKNOWN)
            If ifferr=0
              *badr=AllocVec_ (bitmapsize,0)
              If *badr
                iloffset=0 : bmoffset=0
                For y=0 To bmhit-1
                  For dep=0 To bmdep-1
                    For x=0 To bmwid-1
                      iloffset+1
                      Poke.b *badr+iloffset-1,Peek.b(*bm\Planes[dep]+bmoffset+x)
                    Next x
                  Next dep
                  bmoffset+bmwid
                Next y
                ifferr=WriteChunkBytes_(*iff,*badr,bitmapsize)
                If ifferr=bitmapsize
                  PopChunk_(*iff)
                  OK+1
                End If
                FreeVec_ *badr
              End If
            End If
            PopChunk_(*iff)
          End If
          CloseIFF_(*iff)
        End If
        Close_(lock)
      End If
      If OK=0 Then DeleteFile_(&name)
      FreeIFF_(*iff)
    End If
  End If
  Function Return OK
End Function


.
._Begin

WbToScreen 0
WBenchToFront_

*scr.Screen     = Peek.l(Addr Screen(0))
diswid          = *scr\Width
dishit          = *scr\Height
disdep          = *scr\BitMap\Depth

Window 0,0,0,600,200,$100E,"Save_IFF-demo",-1,-1

; let our window show any requesters
CatchDosErrs


modeid=$21000
.
._change_me

piccy$="dh3:pics/micsc/jarrechina.pic"

dest$ ="Ram:Save_IFF_example.iff"

BitMap 0,64,89,8
LoadBitMap 0,piccy$,0
*bm0=Addr BitMap(0)

NPrint "Pic Loaded, now saving."


suc=Save_IFF{dest$,*bm0,0,64,modeid}
If suc
  NPrint "Picture Exported"
Else
  NPrint "Not saved"
End If

Delay_200

Free Window 0

Free Screen 0
End


