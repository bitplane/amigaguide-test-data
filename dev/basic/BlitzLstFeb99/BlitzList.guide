--BOUNDARY.1747866304.2
Content-Disposition: attachment; filename="RI_Arexx.asc"
Encoding: quoted-printable
Content-Description: RI Arexx lib's dodgy arexx commands

WBStartup

l.l=3DRXCreatePort("THISisYOURproggysPORT.1")
r$=3DRXSendCommand("AMIRC.1",Chr$(34)+"GETMYNICK"+Chr$(34)); this returns=
 a string
r1=3DRXErrorCode ; this gets your error code if u want one
RXDeletePort

Print r$

ClickMouse
End

