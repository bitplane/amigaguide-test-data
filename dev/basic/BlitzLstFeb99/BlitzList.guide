on bikes...
-- Alan Partridge, /The Day Today/
--BOUNDARY.1747928312.1
Content-Disposition: attachment; filename="protect.asc"
Content-Description: Setting protection flags...

n$="ram:amigaboot.txt" ; change to a file you have!!!

If SetProtection_(&n$,#FIBB_DELETE) ; sets two other bits! ???
  Request "","Success!","OK"
Else Request "","Failed!","OK"
