@node "arguments" "Arguments"
@{PAR}@{LINE}
 @{b}@{u}Arguments@{ub}@{uu}
@{PAR}@{LINE}
@{b} - MPEGFILES@{ub}
@{PAR}@{LINE}
   MPEG Audio file(s) to load on startup.
@{PAR}@{LINE}
@{b} - PUBSCREEN@{ub}
@{PAR}@{LINE}
   Name of public screen to open the interface on.
@{PAR}@{LINE}
@{b} - CX_POPUP@{ub}
@{PAR}@{LINE}
   Popup program at start (default TRUE).
@{PAR}@{LINE}
@{b} - SKIPPLST@{ub}
@{PAR}@{LINE}
   Skip loading Playlist on startup.

@endnode

