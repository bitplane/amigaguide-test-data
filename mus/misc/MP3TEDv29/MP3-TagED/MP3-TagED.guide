@node "description" "Description"
@{PAR}@{LINE}
 @{b}@{u}Description@{ub}@{uu}
@{PAR}@{LINE}
 MP3-TagED is a GUI-based program to Add/Edit/Remove ID3 TAG@{LINE}
 in MPEG Audio Files.
@{PAR}@{LINE}
 See @{"history" link "history" 0} for all the new functions added.
@endnode

@node "systemrequirements" "System Requirements"
@{PAR}@{LINE}
 @{b}@{u}System Requirements@{ub}@{uu}
@{PAR}@{LINE}

   @{b}░@{ub} Requires at least kickstart v2.04+
   @{b}░@{ub} @{"gtLayout.library" link "gtlayout" 0} v40+
   @{b}░@{ub} @{"reqtools.library" link "reqtools" 0} v38+
   @{b}░@{ub} @{"popupmenu.library" link "popupmenu" 0} v8+
   @{b}░@{ub} @{"ACDB" link "acdbinfo" 0} to use the Import ACDB File function.
   @{b}░@{ub} A keyfile to Save TAG's - it's @{"FREE" link "keyfile"0}.

   This program has been tested sucessfully on the following configurations:

   @{b}░@{ub} A1200/030 50Mhz 32Mb RAM 1.4Gb HD 8xCD-ROM 1084 C= Monitor (@{"Complete List" link "complist1" 0})
   @{b}░@{ub} A4000/060 50Mhz 64Mb RAM ................................. (@{"Complete List" link "complist2" 0})
@endnode

@node "features" "Features"
@{PAR}@{LINE}
 @{b}@{u}Features@{ub}@{uu}
@{PAR}@{LINE}
   @{b}░@{ub} Uses @{"gtlayout.libray" link "gtlayout" 0} (font and screen mode sensitive).
   @{b}░@{ub} Can be opened on any public screen.
   @{b}░@{ub} AppIcon & AppWindow for Drag 'n' Drop.
   @{b}░@{ub} Commodity support.
   @{b}░@{ub} Read /áWrite / Delete MP3 ID-TAG.
   @{b}░@{ub} Multiple file support.
   @{b}░@{ub} Read files at startup.
   @{b}░@{ub} Fresh Genre list (sorted).
   @{b}░@{ub} Genre statistics.
   @{b}░@{ub} Import ACDB File.
   @{b}░@{ub} Import Playlists:
     @{b}-@{ub} SongPlayer
     @{b}-@{ub} AmigaAMP
     @{b}-@{ub} Amplifier
   @{b}░@{ub} MP3 Header information.
     @{b}-@{ub} ID
     @{b}-@{ub} Layer
     @{b}-@{ub} BitRate
     @{b}-@{ub} Frequency
     @{b}-@{ub} Mode
     @{b}-@{ub} Length
     @{b}-@{ub} FrameSize
   @{b}░@{ub} Rename files through program.
   @{b}░@{ub} Make filename from ID-TAG (configurable).
   @{b}░@{ub} Configurable filecomment.
   @{b}░@{ub} Export TAG information to following formats:
     @{b}-@{ub} ASCII
     @{b}-@{ub} AmigaGuide
     @{b}-@{ub} SongPlayer playlist
   @{b}░@{ub} Copy TAG to all loaded files.
   @{b}░@{ub} Default ID-TAG display if loaded MP3 hasn't got a TAG (configurable).
   @{b}░@{ub} It's EMailware.

@endnode

