@node "informationwindow" "InformationWindow"
@{PAR}@{LINE}
 @{b}@{u}Information Window@{ub}@{uu}
@{PAR}@{LINE}
   This window will show some information about the MP3 file@{LINE}
   you've selected.
@{PAR}@{LINE}
   The information you will get is:
@{PAR}@{LINE}
   @{fg highlight}-@{fg text} ID@{LINE}
   @{fg highlight}-@{fg text} Layer@{LINE}
   @{fg highlight}-@{fg text} BitRate@{LINE}
   @{fg highlight}-@{fg text} Frequency@{LINE}
   @{fg highlight}-@{fg text} Mode@{LINE}
   @{fg highlight}-@{fg text} Length@{LINE}
   @{fg highlight}-@{fg text} FrameSize
   @{fg highlight}-@{fg text} Copyright
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Close@{ub}
@{PAR}@{LINE}
   Close window and continue.
@endnode

@node "copytagwindow" "CopyTagWindow"
@{PAR}@{LINE}
 @{b}@{u}Copy Tag Window@{ub}@{uu}
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}SongName@{ub}
@{PAR}@{LINE}
   Select `@{fg highlight}SongName@{fg text}' and the program will copy it to all other loaded@{LINE}
   MPEG Audio files.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Artist@{ub}
@{PAR}@{LINE}
   Select `@{fg highlight}Artist@{fg text}' and the program will copy it to all other loaded@{LINE}
   MPEG Audio files.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Album@{ub}
@{PAR}@{LINE}
   Select `@{fg highlight}Album@{fg text}' and the program will copy it to all other loaded@{LINE}
   MPEG Audio files.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Year@{ub}
@{PAR}@{LINE}
   Select `@{fg highlight}Year@{fg text}' and the program will copy it to all other loaded@{LINE}
   MPEG Audio files.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Comment@{ub}
@{PAR}@{LINE}
   Select `@{fg highlight}Comment@{fg text}' and the program will copy it to all other loaded@{LINE}
   MPEG Audio files.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{ub}All
@{PAR}@{LINE}
   Select all fields.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{ub}None
@{PAR}@{LINE}
   Clear selected fields.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Start@{ub}
@{PAR}@{LINE}
   Write loaded ID3-TAG to all other loaded files.@{LINE}
   The program will start at top and write the ID3-TAG to@{LINE}
   all your files, it doesn't matter if you select the last@{LINE}
   file all other files will have the same ID3-TAG anyway.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Cancel@{ub}
@{PAR}@{LINE}
   Close window.
@endnode

@node "statuswindow" "Status Window"
@{PAR}@{LINE}
 @{b}@{u}Status Window@{ub}@{uu}
@{PAR}@{LINE}
 This window will show:
@{PAR}@{LINE}
@{b} @{ub}@{fg highlight}-@{b}@{fg text} Loaded File(s)@{LINE}
@{b} @{ub}@{fg highlight}-@{b}@{fg text} Total Size@{LINE}
@{b} @{ub}@{fg highlight}-@{b}@{fg text} Total duration (HH:MM:SS)@{LINE}
@{b} @{ub}@{fg highlight}-@{b}@{fg text} File(s) with TAG
@{b} @{ub}@{fg highlight}-@{b}@{fg text} Genre Statistics

 ------------------------------------------------------------------------------

 @{b}Genre Statistics Example:@{ub}

 @{PAR}@{LINE}
  -UNSET-                        @{fg fill}4@{fg text}   <-- @{fg shine}4@{fg text} loaded files has @{fg highlight}-UNSET-@{fg text} as genre.@{LINE}
  A Capella                      @{fg fill}0@{fg text}   <-- @{fg shine}0@{fg text} loaded files has @{fg highlight}A Capella@{fg text} as genre.@{LINE}
  Acid                           @{fg fill}27@{fg text}  <-- @{fg shine}27@{fg text} loaded files has @{fg highlight}Acid@{fg text} as genre.@{LINE}
  Acid Jazz                      @{fg fill}0@{fg text}@{LINE}
  Acid Punk                      @{fg fill}0@{fg text}@{LINE}
  Acoustic                       @{fg fill}4@{fg text}   <-- Etc...@{LINE}

 ------------------------------------------------------------------------------

 @{b}Ě@{ub} @{b}Save@{ub}
@{PAR}@{LINE}
   Save the information to a file.

   Program will check the active page and save the `viewed' information.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Close@{ub}
@{PAR}@{LINE}
   Close `Status' window.

@endnode

