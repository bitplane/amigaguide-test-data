@node "renamewindow" "RenameWindow"
@{PAR}@{LINE}
 @{b}@{u}Rename Window@{ub}@{uu}
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Rename@{ub}
@{PAR}@{LINE}
   Current filename.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}As@{ub}
@{PAR}@{LINE}
