@node "settingswindow1" "Settings Window"
@{PAR}@{LINE}
 @{b}@{u}Settings Window@{ub}@{uu}
@{PAR}@{LINE}
 @{b}General@{ub} @{"Export" link "settingswindow2" 0} @{"Default Tag" link "settingswindow3" 0} @{"Info Window" link "settingswindow4" 0}
 -----------------------------------------------------------------------------
 @{b}Ě Comment Format@{ub}
@{PAR}@{LINE}
   Set filecomment format.
@{PAR}@{LINE}
   % codes is used - press the [V] button and a menu will popup, then select the items you want.
@{PAR}@{LINE}
   %f @{fg highlight}:@{fg text} Path & FileName    %B @{fg highlight}:@{fg text} Bitrate@{LINE}
   %F @{fg highlight}:@{fg text} FileName           %L @{fg highlight}:@{fg text} Layer@{LINE}
   %l @{fg highlight}:@{fg text} Size of file       %S @{fg highlight}:@{fg text} Sampling Frequency@{LINE}
   %s @{fg highlight}:@{fg text} SongName           %M @{fg highlight}:@{fg text} Mode@{LINE}
   %a @{fg highlight}:@{fg text} Artist             %V @{fg highlight}:@{fg text} MPEG Version@{LINE}
   %b @{fg highlight}:@{fg text} Album              %E @{fg highlight}:@{fg text} Length Second(s)@{LINE}
   %y @{fg highlight}:@{fg text} Year               %G @{fg highlight}:@{fg text} Length Minute(s)@{LINE}
   %g @{fg highlight}:@{fg text} Genre              ==== Space ====
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}MP3 Directory@{ub}
@{PAR}@{LINE}
   Default directory to use in filerequester.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Space(s) To Underscore@{ub}
@{PAR}@{LINE}
   Convert spaces to Underscore ("@{fg highlight}_@{fg text}") in "@{fg highlight}Tag To FileName@{fg text}" function.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Tag To FileName@{ub}
@{PAR}@{LINE}
   Set filecomment format.
@{PAR}@{LINE}
   % codes is used - press the [V] button and a menu will popup, then select the items you want.
@{PAR}@{LINE}
   %F @{fg highlight}:@{fg text} FileName           %b @{fg highlight}:@{fg text} Album@{LINE}
   %l @{fg highlight}:@{fg text} Size of file       %y @{fg highlight}:@{fg text} Year@{LINE}
   %s @{fg highlight}:@{fg text} SongName           %g @{fg highlight}:@{fg text} Genre@{LINE}
   %a @{fg highlight}:@{fg text} Artist             ==== Space ====
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Load at Startup@{ub}
@{PAR}@{LINE}
   Load playlist at startup.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}PlayList@{ub}
@{PAR}@{LINE}
   PlayList file to load.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Save@{ub}
@{PAR}@{LINE} 
  Save settings and close window.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Use@{ub}
@{PAR}@{LINE}
   Use new settings and close window.
@{PAR}@{LINE}
 @{b}Ě@{ub} @{b}Cancel@{ub}
@{PAR}@{LINE}
   Cancel any changes you have made.
@endnode

