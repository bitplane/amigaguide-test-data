    @{"'Delay-N-Tap     Window'" LINK "P121"} DSP operator 
    @{"'Delay-Recursive Window'" LINK "P109"} DSP operator 
    @{"'Fir Filter      Window'" LINK "P102"} DSP operator 
    @{"'Flanger         Window'" LINK "P118"} DSP operator 
    @{"'Hum Remover     Window'" LINK "P124"} DSP operator 
    @{"'MultiFlanger    Window'" LINK "P112"} DSP operator 
    @{"'Noise Gate      Window'" LINK "P101"} DSP operator 
    @{"'Phase Inverter  Window'" LINK "NO_WND1"} DSP operator 
    @{"'Pitch Shift     Window'" LINK "P110"} DSP operator 
    @{"'Quantizer       Window'" LINK "P108"} DSP operator 
    @{"'Room            Window'" LINK "P113"} DSP operator 
    @{"'Skipper         Window'" LINK "P106"} DSP operator 
    @{"'Time Inverter   Window'" LINK "P111"} DSP operator 
    @{"'Time Stretch    Window'" LINK "P122"} DSP operator 
    @{"'Tone Control    Window'" LINK "P114"} DSP operator 

    Edit List Managers Enviroment
    @{"'ELM                        Window'" LINK "P503"} ELM main control
    @{"'MultiTrack Display         Window'" LINK "P507"} MultiTrack editor
    @{"'MultiTrack Mixer           Window'" LINK "P508"} MultiTrack mixer
    @{"'MultiTrack Control         Window'" LINK "P506"} MultiTrack main control
    @{"'Object                     Window'" LINK "P504"} MultiTrack object selector
    @{"'Markers                    Window'" LINK "P509"} MultiTrack markers
    @{"'Absolute Edit List Display Window'" LINK "P502"} Multitrack AEL display
    @{"'Relative Edit List Manager Window'" LINK "P500"} REL builder
