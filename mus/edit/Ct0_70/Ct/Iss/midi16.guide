@Node "midi16_commands" "Midi16.guide/Commands"
@Toc "main"


 @{u}@{b}Commands@{uu}@{ub}

  @{u}@{b}0Cxx - Set velocity@{uu}@{ub}

   Range $00 - $40

  @{u}@{b}3000 - Key off@{uu}@{ub}

  @{u}@{b}31xx - Set instrument@{uu}@{ub}

   Range $00 - $7f

  @{u}@{b}32xx - Set panoration@{uu}@{ub}

   Range $00 - $40 - $7f

  @{u}@{b}33xx - Set modulation@{uu}@{ub}

   Range $00 - $7f

  @{u}@{b}34xx - Set chorus@{uu}@{ub}

   Range $00 - $7f

  @{u}@{b}4000 - Turn general MIDI system on (system exlusive)@{uu}@{ub}

  @{u}@{b}4100 - GS reset@{uu}@{ub}

