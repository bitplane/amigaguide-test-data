@node RGS-Structure
struct RGS-File {
     Kennung "Poop"        (4 Bytes)
     Width=0x0000010e=270  (4 Bytes)
     Height=0x00000080=128 (4 Bytes)
     Bitplanes=0x00000040  (4 Bytes)
     ??=0x00000000         (4 Bytes)
     ??=0x00002000         (4 Bytes)
     Body                  (34560 Bytes)
     }

body : for(x=0;x<270;x++){
         for(y=0;y<128;y++){
           Colour[x,y];
           }
         }
@endnode
