@node "Edit_PosEdit" "PositionsEdit"

    
   @{u}@{fg shine}Position edieren@{uu}@{fg text}


  <   > ... Velocity stärker/schwächer

  1 - 8 ... Velociy-Grobstufen 1-8

  Space ... Position setzen

  <Del> ... Position löschen
  
 F1 - F8 .. Position in Track 1-8 setzen





