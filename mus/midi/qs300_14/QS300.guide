@Node SPECS "Yamaha QS300 Voices - QS300 Specifications"
@Font Xen.font 8
@{bpen 1}@{FG shine}@{b}Tone Generator@{ub}                                                                       ***@{FG text}@{bpen 0}
@{FG fill}Type@{FG text}                     AWM2 (Advanced Wave Memory 2)
@{FG fill}Maximum Polyphony@{FG text}        32 notes
@{FG fill}System Module@{FG text}            Normal (XG), TG-B (TG300B)
@{FG fill}Multi-timbral Capacity@{FG text}   Song mode:    24 (16 for Sequencer + 8 for Pattern tracks)
                         Pattern mode: 8
@{FG fill}Voices@{FG text}                   XG:     480, and 11 drum kits
                         TG300B: 579, and 10 drum kits
                         Preset: 128
                         User:   128, and 1 drum kit

@{bpen 1}@{FG shine}@{b}Sequencer@{ub}                                                                            ***@{FG text}@{bpen 0}
@{FG fill}Tracks@{FG text}                   Song mode:    19 (Tracks 1-16, Pattern, Chord, Tempo)
                         Pattern mode: 8  (Tracks 1-8)
                         Phrase mode:  1
@{FG fill}Data Capacity@{FG text}            Approx. 86,000 notes
                         10 Songs
                         100 Styles x 8 Sections (800 Patterns)
                         100 User Phrases
@{FG fill}Preset Phrases@{FG text}           3093
                         100 Preset Styles x 8 Sections (800 Patterns)
@{FG fill}Record Modes@{FG text}             Realtime, Step, Punch-in, Edit Insert
@{FG fill}Preset Chords@{FG text}            28 (including "Thru")
@{FG fill}Note Resolution@{FG text}          96 clocks/quarter note
@{FG fill}Edit modes@{FG text}               Song Edit, Phrase Edit
@{FG fill}Jobs@{FG text}                     Song:    24
                         Pattern: 7
                         Phrase:  15
@{FG fill}Song Chain@{FG text}               10 Songs
@{FG fill}Sequence File Format@{FG text}     SMF (Standard MIDI File), ESEQ, QY300

@{bpen 1}@{FG shine}@{b}General@{ub}                                                                              ***@{FG text}@{bpen 0}
@{FG fill}Keyboard@{FG text}                 61 keys, with initial touch and after touch
@{FG fill}Display@{FG text}                  240 x 64 dot graphic LCD (backlit, contrast control)
@{FG fill}External Memory@{FG text}          3.5" 2DD/2HD type floppy disk drive
@{FG fill}Connectors@{FG text}               PHONES, OUTPUT (L/MONO,R), FOOT VOLUME, FOOT CONTROLLER, 
                         SUSTAIN, MIDI IN/OUT/THRU, AC INLET
@{FG fill}Output Level@{FG text}             PHONES:      +7.0 dBm (33 ohm)
                         Main OUTPUT: +6.5 dBm (10 kohm)
@{FG fill}Power@{FG text}                    Consumption:  20 W
                         Requirements: U:120V, OTHER:220~240V
@{FG fill}Dimensions (W x D x H)@{FG text}   1067 x 371 x 121 mm (42" x 14-5/8" x 4-3/4")
@{FG fill}Weight@{FG text}                   13.0 kg (28 lbs., 10 oz.)
@{FG fill}Included Accessories@{FG text}     Factory Set & Demonstration Disk, Owner's Manual, power cord
@EndNode
