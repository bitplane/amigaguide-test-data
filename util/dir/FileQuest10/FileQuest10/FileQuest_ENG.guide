@node "Template" "TEMPLATE"

 @{b}The AmigaDOS template@{ub}


 Many commands have templates:


 @{fg shine}/A@{fg text}     Argument must be supplied.

 @{fg shine}/K@{fg text}     Argument must be with the keyword.

 @{fg shine}/S@{fg text}     The keyword is a switch (no value).
@endnode

@node "ABOUT" "ABOUT"

 @{b}ABOUT@{ub}


 Opens an About requester  with  information  about  FileQuest  and  the
 author.
@endnode

@node "ADDICON" "ADDICON"

 @{b}ADDICON@{ub}


 Adds an icon to a file.

 (Compatible with NewIcon, DefIcon).
@endnode

@node "CHANGE_SCREEN" "CHANGE_SCREEN"

 @{b}CHANGE_SCREEN WB|CUSTOM|LIKE_WB@{ub}


 This command lets you change the screen of FileQuest on the fly.


 @{fg shine}CHANGE_SCREEN WB@{fg text}           ReOpen FileQuest on the Workbench.

 @{fg shine}CHANGE_SCREEN CUSTOM@{fg text}       ReOpen FileQuest on a custom screen
                            defined with the Configurator.

 @{fg shine}CHANGE_SCREEN LIKE_WB@{fg text}      ReOpen FileQuest on a screen with the
                            same size and mode as the Workbench.
@endnode

@node "COMMENT" "COMMENT"

 @{b}COMMENT@{ub}


 Change the comment for selected dirs or files.
@endnode

@node "CONFIG" "CONFIG"

 @{b}CONFIG@{ub}


 Launch the FileQuest Configurator.
@endnode

@node "COPY" "COPY"

 @{b}COPY AS/S,CLONE/S@{ub}


 COPY:          Copy all selected files and directories.

 COPY AS:       Copy, using a new name.

 COPY CLONE:    Clone a file or dir.
@endnode

@node "DELETE" "DELETE"

 @{b}DELETE@{ub}


 Delete all selected files and directories.
@endnode

@node "GETSIZE" "GETSIZE"

 @{b}GETSIZE CLEAR/S@{ub}


 GETSIZE:           Displays the size of selected directories.

 GETSIZE CLEAR:     Clears the size of selected directories.
@endnode

@node "HIDE" "HIDE"

 @{b}HIDE@{ub}


 Hide the FileQuest GUI. To pop it up again, press the HOTKEY or use the
 Exchange program.
@endnode

@node "ICONIFY" "ICONIFY"

 @{b}ICONIFY@{ub}


 Iconify the GUI into an AppIcon.
@endnode

@node "LINK_TO_BUTTON" "LINK_TO_BUTTON"


 @{b}LINK_TO_BUTTON <NUM>@{ub}


 Define an action for the button <num>.


 Eg:    If in the popup-menu we enter this command:


        LINK_TO_BUTTON 1

        When the item is selected, it will perform the action defined in
        the first Action button.


        This avoids having to enter the same command many times.
@endnode

@node "LINK_TO_POPUP" "LINK_TO_POPUP"

 @{b}LINK_TO_POPUP <NUM>@{ub}


 Perform an action defined in a PopupMenu item.


 Eg:    If in an action-button, we enter the command:


        LINK_TO_POPUP 1

        When this button is selected, it will perform the action defined
        in the first item of the PopupMenu.

        This avoids having to enter the same command many times.


 @{u}WARNING@{uu}:

        An item separator is counted as an item.
@endnode

@node "MAKEDIR" "MAKEDIR"

 @{b}MAKEDIR ICON/S@{ub}

 Creates a directory, asking for the name, if omitted.

 If option @{fg shine}ICON@{fg text} is present, an icon will be created  for
 the directory.
@endnode

@node "MOVE" "MOVE"

 @{b}MOVE AS/S@{ub}


 Moves selected files/dirs.

 If option @{fg shine}AS@{fg text} is present, the new name will be asked for.
@endnode

@node "PARENT" "PARENT"

 @{b}PARENT@{ub}


 Reads the parent of the current directory.
@endnode

@node "PERFORM" "PERFORM"

 @{b}PERFORM@{ub}


 Perform an action on the file depending on its FileType.

 For each file, FileQuest will search for its type on its FileType  list
 and perform the command configured for the FileType.
@endnode

@node "PROTECT" "PROTECT"

 @{b}PROTECT@{ub}


 Edit the protection bits of files/dirs.
@endnode

@node "QUIT" "QUIT"

 @{b}QUIT NOCONFIRM/S@{ub}


 Quits FileQuest.

 If the  @{fg shine}NOCONFIRM@{fg text}  option  is  present,  FileQuest  will  quit  without
 confirmation.
@endnode

@node "RELABEL" "RELABEL"

 @{b}RELABEL@{ub}


 Renames the current volume.
@endnode

@node "RENAME" "RENAME"

 @{b}RENAME@{ub}


 Renames all selected files/dirs.
@endnode

@node "ROOT" "ROOT"

 @{b}ROOT@{ub}


 Go to the root of the current directory.
@endnode

@node "SELECT" "SELECT"

 @{b}SELECT DESEL/S,ALL/S,PATTERN/S,INV/S@{ub}


 This command selects or deselect entries.


 @{fg shine}ALL@{fg text}:       will affect all the entries.

 @{fg shine}PATTERN@{fg text}:   will affect entries matching a pattern.


 @{fg shine}DESEL@{fg text}:     deselect entries.

 @{fg shine}INV@{fg text}:       invert selection.



 @{i}Examples:@{ui}

 @{fg shine}SELECT ALL@{fg text}           : Select all entries.

 @{fg shine}SELECT INV@{fg text}           : Invert all entries.

 @{fg shine}SELECT DESEL ALL@{fg text}     : Deselect all entries.

 @{fg shine}SELECT PATTERN@{fg text}       : Select with pattern.

 @{fg shine}SELECT PATTERN DESEL@{fg text} : Deselect with pattern.

 @{fg shine}SELECT PATTERN INV@{fg text}   : Invert with pattern.
@endnode

@node "SWAP" "SWAP"

 @{b}SWAP@{ub}


 Swap the contents of the directory lists.
@endnode

@node "USER" "USER"

 @{b}USER@{ub}


 Displays information about the user, if registered.
@endnode

