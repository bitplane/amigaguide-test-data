 @{" FILENOTE " Link "UF_RX_FILENOTE"}               
 @{" FORMAT " Link "UF_RX_FORMAT"}             
 @{" HEXDUMP " Link "UF_RX_HEXDUMP"}              
 @{" LIST " Link "UF_RX_LIST"}           
 @{" MAKEDIR " Link "UF_RX_MAKEDIR"}              
 @{" MAKELINK " Link "UF_RX_MAKELINK"}               
 @{" MOVE " Link "UF_RX_MOVE"}           
 @{" PROTECT " Link "UF_RX_PROTECT"}              
 @{" QUIT " Link "UF_RX_QUIT"}           
 @{" RELABEL " Link "UF_RX_RELABEL"}              
