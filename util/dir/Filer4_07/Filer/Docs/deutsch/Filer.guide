@{b}ARGUMENTE@{ub}
     Keine.

@{b}RESULTAT@{ub}
     Keins.

@{b}KONFIGURATIOSBEISPIEL@{ub}
     KEY "NUMPAD 2","DOWN"

@{b}LESEN SIE AUCH@{ub}
     @{b}@{ub} @{"UP" Link "UF_RX_UP"}, @{"CURSORDOWN" Link "UF_RX_CURSORDOWN"}


