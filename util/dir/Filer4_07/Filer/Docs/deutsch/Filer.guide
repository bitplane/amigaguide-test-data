 @{" HOME " Link "UF_RX_HOME"}           
 @{" DOWN " Link "UF_RX_DOWN"}           
 @{" PAGEDOWN " Link "UF_RX_PAGEDOWN"}               
 @{" END " Link "UF_RX_END"}          
