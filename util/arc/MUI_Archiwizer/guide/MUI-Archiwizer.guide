		@{" PowerPacker " link a_pp} , @{" ZIP " link a_zip} , @{" GZip " link a_gzip} (dwa osobne programy do pakowania i rozpakowania),
		
		@{" UnARJ " link a_arj} , @{" UnRAR " link a_rar} (wyîâcznie rozpakowanie), 

		@{" DMS " link a_dms} , @{" ZOOM " link a_zoom} , @{" AMIPACK " link a_amp} , @{" PACKDEV " link a_packdev} (archiwizery dyskietkowe),


	@{u}oraz:@{uu}

