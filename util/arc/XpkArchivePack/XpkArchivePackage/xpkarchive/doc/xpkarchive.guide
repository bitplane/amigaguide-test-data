@{b}    SYNOPSIS@{ub}
        err = XarSetFileNoteA( tags )
        D0                      A0

        LONG XarSetFileNoteA(struct @{"TagItem" Link "TEXT_INCLUDE:utility/tagitem.h/Main" 31} *)


        err = XarSetFileNote( firsttag, ... )

