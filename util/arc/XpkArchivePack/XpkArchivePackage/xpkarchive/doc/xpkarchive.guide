@Node "XarUndeleteFile()" "xpkarchive.library/XarUndeleteFile"

@{b}    NAME@{ub}
        XarUndeleteFile()

@{b}    SYNOPSIS@{ub}
        err = XarUndeleteFile( xarlock )
        D0                    A0

        LONG XarUndelete( XarLock *)

@{b}    FUNCTION@{ub}

        Undelete a file that was marked in the archive as deleted. It is
        only possible to undelete a file, if it was only marked as deleted
        and it is not already removed from the archive. (However, then you
        won't get an arclock of this file or you are illegally using an
        (now) invalid arclock (that was kept after a call to
        XarDeleteFile().)


@{b}    INPUT@{ub}
        xarlock - xarlock obtained by @{"XarGetLock()" Link "XarGetLock()"},@{"XarNextLock()" Link "XarNextLock()"},
                  @{"XarPrevLock()" Link "XarPrevLock()"} or @{"XarFindFileA()" Link "XarFindFileA()"}

@{b}    RESULT@{ub}
        err - Error code


@{b}    SEE ALSO@{ub}
        @{"XarGetLock()" Link "XarGetLock()"},@{"XarNextLock()" Link "XarNextLock()"},@{"XarPrevLock()" Link "XarPrevLock()"},@{"XarFindFileA()" Link "XarFindFileA()"}

@EndNode

