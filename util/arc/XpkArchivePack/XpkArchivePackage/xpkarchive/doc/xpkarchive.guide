@{b}    NAME@{ub}
        XarNextGenerationA()


@{b}    SYNOPSIS@{ub}
        err = XarNextGenerationA( tags )
        D0                         A0

        LONG XarNextGenerationA(struct @{"TagItem" Link "TEXT_INCLUDE:utility/tagitem.h/Main" 31} *)


        err = XarNextGeneration( firsttag, ... )

