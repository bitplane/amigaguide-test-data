@node MENU_OPEN "TTManager Menus:  Project - New & Open"
@toc MENUS

@{u}@{b}Menus:@{ub}@{uu}

  @{bg shine}@{u}Project                 @{uu}@{bg background}
  @{bg shine}New...               @{bg shadow}@{fg shine}@{i}A @{ui}@{fg text}@{bg shine}N@{bg background}
  @{bg shine}Open...              @{bg shadow}@{fg shine}@{i}A @{ui}@{fg text}@{bg shine}O@{bg background}
             :


@{u}@{b}New@{ub}@{uu}
  Opens a file requester for an icon to open.  The selected file's icon will be
opened in a new window.

@{b}Menu Shortcut:@{ub}  <Right Amiga> N


@{u}@{b}Open@{ub}@{uu}
  Opens the selected file's icon in the current window.  The window's previous
contents are lost.  This operation cannot be undone.

@{b}Menu Shortcut:@{ub}  <Right Amiga> O
@endnode


@node MENU_SAVE "TTManager Menus:  Project - Save & Save As"
@toc MENUS

@{u}@{b}Menus:@{ub}@{uu}

