 "Close" KEY "Q"
 "Update" KEY " "
 "Select Contents" KEY "A"
 "Clean Up" KEY "."
 "Window"
 "All"
 "Only Icons" KEY "I"
 "All Files" KEY "S"
 "Icon" KEY "1"
 "Name" KEY "2"
 "Date" KEY "3"
 "Size" KEY "4"
 "Open"
 "Copy"
