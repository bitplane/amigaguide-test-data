@node CMD_PLAYFILE "PLAYFILE"

PLAYFILE "Fichier"

Joue le son dont le nom est "Fichier"

	Retour :	5 Le son est inactif
			0 Ordre envoyé à la tâche son

	Résultat :	######


Voir	@{"SOUND" link CMD_SOUND}		[ON|OFF]

@endnode

