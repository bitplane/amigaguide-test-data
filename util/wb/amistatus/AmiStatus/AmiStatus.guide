@node arexx "AREXX commands"
@{jcenter}@{u}@{b}AREXX commands@{ub}@{uu}

@{i}If Amistatus is running, the example links will launch the documented command.@{ui}
@{jleft}
	@{"newmessage" link newmsg} @{u}Name@{uu} @{u}Priority@{uu} @{u}Message@{uu} 
	 	@{"Example 1" system "rx test.rexx test1"} @{"Example 2" system "rx test.rexx test2"}
			
	@{"requester" link requester} @{u}Confirm button@{uu} @{u}Deny button@{uu} @{u}Hotkeys Message@{uu}
		@{"Example" system "rx test.rexx test3"}
	
	@{"gauge" link gauge} @{u}max number@{uu} @{u}current number@{uu} @{u}message string@{uu}			
		@{"Example" system "rx test.rexx test5"}
	
	@{"lastmsg" link lastmsg} @{u}popup or result@{uu}
		@{"Example" system "rx test.rexx test6"}
			
	@{"change" link changeprog} @{u}picture|clickaction|restore@{uu} @{u}icon #|program@{uu} @{u}picture path@{uu}
		@{"Example 1" system "rx test.rexx test7"} @{"Example 2" system "rx test.rexx test8"}
	
@{jcenter}@{b}Example Scripts@{ub}
@{jleft}	@{"test.rexx" link "test.rexx/MAIN"} Test scripts, the links above all use this.
	@{"miami.rexx" link "rexx/miami.rexx/MAIN"} Notification script for Miami/MiamiDX.
	@{"yam.rexx" link "rexx/yam.rexx/MAIN"} Notification script for YAM.
	@{"jabber.rexx" link "rexx/jabber.rexx/MAIN"} Notification script for JabberWocky.

	
@endnode

