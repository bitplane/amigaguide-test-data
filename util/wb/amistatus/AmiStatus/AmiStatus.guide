@endnode

@node characters "Escape characters"
@{jcenter}@{u}@{b}Escape Characters@{ub}@{uu}
@{jleft}	Some formatting options are available by using '#' as an escape code.

If AmiStatus is running, click @{"Here" system "rx test.rexx test4"} to see what it looks like.

		@{b}#N@{ub}	Inserts a new line.
				
				(CR, LF, return, whatever you want to call it)
		
		@{b}#B@{ub}	@{b}Boldfaces@{ub} text.
		
		@{b}#U@{ub}	@{u}Underlines@{uu} text.
		
		@{b}#I@{ub}	@{i}Italicizes@{ui} text. (I know I probably mis-spelled that)
		
		@{b}#n@{ub}	Normalizes the text.
		

@endnode

@node newmsg "newmessage"
@{jcenter}@{b}newmessage@{ub} @{u}Name@{uu} @{u}Priority@{uu} @{u}Message@{uu}
@{jleft}	Sends a new message for display. @{u}Name@{uu} refers to the program/category
that @{u}Message@{uu} belongs to. @{u}Priority@{uu} is the importance of the
message. You can also do some formatting with @{"Escape codes" link characters}.
@endnode


@node requester
@{jcenter}@{b}requester@{ub} @{u}Confirm button@{uu} @{u}Deny button@{uu} @{u}Hotkeys Message@{uu}
@{jleft}	Opens a Yes/No requester, returns the answer to result.
@endnode

@node gauge
@{jcenter}@{b}gauge@{ub} @{u}max number@{uu} @{u}current number@{uu} @{u}message string@{uu}
@{jleft}	Pops up a gas-gauge (unless you have it set to always show it), for allowing progress
meters from AREXX scripts.
@endnode

@node lastmsg
@{jcenter}@{b}lastmsg@{ub} @{u}popup or result@{uu}
@{jleft}	Opens the pop-up window showing the last message, if you use the "popup"
option. Otherwise, "result" will return the message to the result variable.
@endnode

@node changeprog
@{jcenter}@{b}change@{ub} @{u}picture|clickaction|restore@{uu} @{u}icon #|program@{uu} @{u}picture path@{uu}
@{jleft}	Changes the clickaction or picture of specified program. The @{u}restore@{uu} option restores
both the image @{b}AND@{ub} the clickaction.
@endnode

