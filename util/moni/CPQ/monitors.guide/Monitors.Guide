                                        ******************
                                        *@{b}  Compaq SVGA   @{ub}*
                                        ******************


                                 @{b} SPECIFICATIONS DU MONITEUR SVGA @{ub}



  @{b}Tube cathodique@{ub}                     14 pouces, déflexion 90°

  @{b}Phosphore/@{ub}                          P22, 0,28 mm
  @{b}séparation des@{ub}
  @{b}points@{ub}

  @{b}Réglages@{ub}                            Alimentation, Contraste, Luminosité
  @{b}externes@{ub}                            Centrage horizontal, Centrage vertical
                                      Dimensionnement vertical
                                      Dimensionnement horizontal

  @{b}Fréquences@{ub}
         Balayage horiz.              31,5 kHz/35,2 kHz/35,5 kHz/37,8 kHz
                                      (automatique)

         Balayage vertical            50 Hz - 90 Hz (automatique)




  @{b}Largeur de @{ub}                         50 MHz  (-3dB)
  @{b}bande vidéo@{ub}

  @{b}Affichage@{ub}                           Jusqu'ā 2400 caractčres  (80 X 30 lignes)

  @{b}Nombre de @{ub}                          Illimité
  @{b}couleurs affichées@{ub}

  @{b}Zone d'affichage@{ub}
           Horizontale                245 mm
           Verticale                  180 mm

  @{b}Résolutions@{ub}                         1024 x 768 (I)
  @{b}d'affichage@{ub}                         800 x 600
                                               640 x 480

  @{b}Source@{ub}                              100 - 240 V CA, 50/60 Hz
  @{b}d'alimentation@{ub}

  @{b}Température de@{ub}
  @{b}fonctionnement@{ub}                      +5°C ā +40°C (température ambiante)

  @{b}Humidité relative@{ub}                   10% ā 85% (sans condensation)

  @{b}Poids@{ub}                               net: 12,1 kg   brut: 14,5 kg

  @{b}Dimensions@{ub}                          largeur: 354 mm
                                               hauteur: 365 mm
                                               profondeur: 387 mm

  @{b}Terminal d'entrée@{ub}                   Connecteur signaux @{"15 broches" system "Pics/fastview Pics/SVGA"} avec cable

  @{b}Niveau du signal@{ub}
  @{b}d'entrée@{ub}
         Vidéo                        analogique: 0,7 V p-p (positif)
         Sync.                        niveau TTL, synchronisation séparée
                                      (positive/négative)



