@node Installation "AmiGOD - Installation"

				@{B}Installation@{ub}
				============

	- just copy the drawer "AmiGOD" :)
	- don't rename file 'AmiGOD.tests'

@endnode

@node Requirements "AmiGOD - Requirements"

				@{B}System Requirements@{ub}
				===================

	system :	Amiga 0S 3.0 or better (OS 2.0 not tested)
	processor :	68k, PPC
	memory :	0,2 MB RAM free
	software :	identify.library

@endnode

@node Tooltypes "AmiGOD - Tooltypes"

				@{b}Tooltypes@{ub}
				=========

USERFONT = YES|NO	default NO           - using user's font via tooltypes
FONT     = X.font	default Courier.font - font to use
SIZE     = number       default 13           - size of AmiGOD's font
LANGUAGE = xxx		default ENGLISH

 - where xxx is name of some file in drawer Languages
 - supported languages:

        - 'czech'       program & documentation!
        - 'deutsch'     program
        - 'english'     program & documentation!
        - 'francais'    program
        - 'italiano'    program
        - 'magyar'      program
        - 'polski'      program & documentation!
        - 'portuguese'  program
        - 'russian'     program
        - 'slovak'      program

@endnode

