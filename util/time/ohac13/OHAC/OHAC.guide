@node MENU_JUMP "OHAC Menus:  Project - Next Pubscreen"
@toc MENUS

@{u}@{b}Menus:@{ub}@{uu}

  @{bg shine}@{u}Project           @{uu}@{bg background}
  @{bg shine}Next Pubscreen @{bg shadow}@{fg shine}@{i}A @{ui}@{fg text}@{bg shine}J@{bg background}
          :


@{u}@{b}Next Pubscreen@{ub}@{uu}
   OHAC will close it's window and reopen on the next public screen.


@{b}Menu Shortcut:@{ub}  <Right Amiga> J
@endnode

@node MENU_HIDE "OHAC Menus:  Project - Iconify"
@toc MENUS

@{u}@{b}Menus:@{ub}@{uu}

  @{bg shine}@{u}Project           @{uu}@{bg background}
          :
  @{bg shine}Iconify        @{bg shadow}@{fg shine}@{i}A @{ui}@{fg text}@{bg shine}I@{bg background}
          :


@{u}@{b}Iconify@{ub}@{uu}
   OHAC will close it's window and open an icon on the Workbench screen.
Double-click on this icon to reopen OHAC's window.


@{b}Menu Shortcut:@{ub}  <Right Amiga> I


@{b}Notes:@{ub}
  o OHAC may be instructed to start in an iconified state by using
    the @{"ICONIFY" link OPT_HIDE} startup option.

  o The image OHAC uses for it's iconified state may be set with the
    @{"ICONIFIEDIMAGE" link OPT_HIDE} startup option.
@endnode

@node MENU_FONT "OHAC Menus:  Project - Change Font"
