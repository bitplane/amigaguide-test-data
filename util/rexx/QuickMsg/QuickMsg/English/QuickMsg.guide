 @{" Installation          " Link Installation}
 @{" Usage                 " Link Usage}
 @{" Examples              " Link Examples}
     @{" Examples 1 & 2    " Link Example_1}   ->  D=..., P=...
     @{" Example 3         " Link Example_3}   ->  FROM filename
     @{" Example 4         " Link Example_4}   ->  \n (line feed)
     @{" Example 5         " Link Example_5}   ->  " (double quote)
     @{" Examples 6 & 7    " Link Example_6}   ->  Batch usage, FILE filename
     @{" Example 8         " Link Example_8}   ->  M=...
     @{" Example 9         " Link Example_9}   ->  *FROM, *FILE
     @{" Example 10        " Link Example_10}   ->  W=..., H=...
