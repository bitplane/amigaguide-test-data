@node "--background--" "--background--"

--background-- :


 $(C): (1996, Rocco Coluccelli, Bologna)
 $VER: rexx_math.library 37.2 (25.03.97)

    rexx_math.library

    This sub-library of the rexxMOOS.library let ARexx programmers
    use any math function. This is only a preliminary version not
    optimized to support any FPU.

        abs()
        acos()
        acosh()
        asin()
        asinh()
        atan()
        atan2()
        atanh()
        ceil()
        cos()
        cosh()
        cot()
        csc()
        exp()
        fact()
        floor()
        log()
        log10()
        nint()
        pow()
        rnd()
        sec()
        sin()
        sinh()
        sqrt()
        tan()
        tanh()

    NOTES

        Is part of the MOOS package.

    TODO

        A procedure to evaluate a math expression directly into the
        library to drastically increase the speed performance.

    BUGS

        The conversion double=>string=>double reduces the precision of
        any result. A new atof()/ftoa() will replace the existing ones.

@endnode
@node "Abs" "rexx_math.library/Abs"

Abs :


    NAME

        Abs -- Absolute value.

    SYNOPSIS

        z = Abs(x)

    FUNCTION

        Returns the absolute value of x. The given argument, x, may be
        any real number.

    EXAMPLE

        SAY Abs(-0.291268)

@endnode
@node "ACos" "rexx_math.library/ACos"

ACos :


    NAME

        ACos -- ArcCosine function.

    SYNOPSIS

        z = ACos(x)

    FUNCTION

        Calculates the arccosine of x. The value of x must be in the
        range of [-1,1] (its absolute value is lower or equal to 1).

    EXAMPLE

        SAY ACos(-0.291268)

@endnode
@node "ACosH" "rexx_math.library/ACosH"

ACosH :


    NAME

        ACosH -- Hyperbolic arccosine function.

    SYNOPSIS

        z = ACosH(x)

    FUNCTION

        Calculates the hyperbolic arccosine of x. The value of x must
        be any real number greater or equal to 1.

    EXAMPLE

        SAY ACosH(1)

@endnode
@node "ASin" "rexx_math.library/ASin"

ASin :


    NAME

        ASin -- ArcSine function.

    SYNOPSIS

        z = ASin(x)

    FUNCTION

        Calculates the arcsine of x. The value of x must be in the
        range of [-1,1] (its absolute value is lower or equal to 1).

    EXAMPLE

        SAY ASin(-0.291268)

@endnode
@node "ASinH" "rexx_math.library/ASinH"

ASinH :


    NAME

        ASinH -- Hyperbolic arcsine function.

    SYNOPSIS

        z = ASinH(x)

    FUNCTION

        Calculates the hyperbolic arcsine of x. The value of x may be
        any real number.

    EXAMPLE

        SAY ASinH(-0.291268)

@endnode
@node "ATan" "rexx_math.library/ATan"

ATan :


    NAME

        ATan -- ArcTangent function.

    SYNOPSIS

        z = ATan(x)

    FUNCTION

        Calculates the arctangent of x. The value of x may be any
        real number.

    EXAMPLE

        SAY ATan(-0.291268)

@endnode
@node "ATan2" "rexx_math.library/ATan2"

ATan2 :


    NAME

        ATan2 -- ArcTangent of x/y.

    SYNOPSIS

        z = ATan2(x,y)

    FUNCTION

        Calculates the arctangent of x/y. The value of x may be any
        real number. The value of y might be not equal to zero, but
        the function returns the rigth value for the limit according
        with the sign of x.

    EXAMPLE

        SAY ATan2(1,0)  /* ==>  pi/2 */
        SAY ATan2(-1,0) /* ==> -pi/2 */

@endnode
@node "ATanH" "rexx_math.library/ATanH"

ATanH :


    NAME

        ATanH -- Hyperbolic arctangent function.

    SYNOPSIS

        z = ATanH(x)

    FUNCTION

        Calculates the hyperbolic arctangent of x. The value of x must
        be in the range of ]-1,1[.

    EXAMPLE

        SAY ATanH(-0.291268)

@endnode
@node "Ceil" "rexx_math.library/Ceil"

Ceil :


    NAME

        Ceil -- Get floating-point limits.

    SYNOPSIS

        z = Ceil(x)

    FUNCTION

        Returns the smallest whole number not less than the specified
        real number, x.

    EXAMPLE

        SAY Ceil(-0.291268)

@endnode
@node "Cos" "rexx_math.library/Cos"

Cos :


    NAME

        Cos -- Cosine function.

    SYNOPSIS

        z = Cos(x)

    FUNCTION

        Calculates the cosine of x. The value of x may be any
        real number.

    EXAMPLE

        SAY Cos(0)

@endnode
@node "CosH" "rexx_math.library/CosH"

CosH :


    NAME

        CosH -- Hyperbolic cosine function.

    SYNOPSIS

        z = CosH(x)

    FUNCTION

        Calculates the hyperbolic cosine of x. The value of x may be
        any real number.

    EXAMPLE

        SAY CosH(-0.291268)

@endnode
@node "Cot" "rexx_math.library/Cot"

Cot :


    NAME

        Cot -- CoTangent function.

    SYNOPSIS

        z = Cot(x)

    FUNCTION

        Calculates the cotangent of x. The value of x may be any
        real number.

    EXAMPLE

        SAY Cot(-0.291268)

@endnode
@node "Csc" "rexx_math.library/Csc"

Csc :


    NAME

        Csc -- Cosecant function.

    SYNOPSIS

        z = Csc(x)

    FUNCTION

        Calculates the cosecant of x. The value of x may be any
        real number, but not equal to (k + 1/2)Pi, k relative.

    EXAMPLE

        SAY Csc(0.5)

@endnode
@node "Exp" "rexx_math.library/Exp"

Exp :


    NAME

        Exp -- Exponential function.

    SYNOPSIS

        z = Exp(x)

    FUNCTION

        Calculates the exponential of x. The value of x may be any
        real number.

    EXAMPLE

        SAY Exp(-0.291268)

@endnode
@node "Fact" "rexx_math.library/Fact"

Fact :


    NAME

        Fact -- Factorial function.

    SYNOPSIS

        z = Fact(x)

    FUNCTION

        Calculates the factorial of x. The value of x must be any
        positive, integer number, lower than 170.

    EXAMPLE

        SAY Fact(5)

@endnode
@node "Floor" "rexx_math.library/Floor"

Floor :


    NAME

        Floor -- Get the floor of a real number.

    SYNOPSIS

        z = Floor(x)

    FUNCTION

        Calculates the largest integer not greater than x.

    EXAMPLE

        SAY Floor(-0.291268)

@endnode
@node "Log" "rexx_math.library/Log"

Log :


    NAME

        Log -- Natural logarithm function.

    SYNOPSIS

        z = Log(x)

    FUNCTION

        Calculates the natural logarithm of x. The value of x must be
        any real number greater than zero.

    EXAMPLE

        SAY Log(1)

@endnode
@node "Log10" "rexx_math.library/Log10"

Log10 :


    NAME

        Log10 -- Base 10 logarithm function.

    SYNOPSIS

        z = Log10(x)

    FUNCTION

        Calculates the base 10 logarithm of x. The value of x must
        be any real number greater than zero.

    EXAMPLE

        SAY Log10(1000)

@endnode
@node "NInt" "rexx_math.library/NInt"

NInt :


    NAME

        NInt -- Nearest integer of any value.

    SYNOPSIS

        z = NInt(x)

    FUNCTION

        Calculates the nearest integer of x. The value of x may
        be any real number.

    EXAMPLE

        SAY NInt(-0.291268)

@endnode
@node "Pow" "rexx_math.library/Pow"

Pow :


    NAME

        Pow -- Raise a number to a power.

    SYNOPSIS

        z = Pow(x,y)

    FUNCTION

        Raises the value of x to the power of y. The value of x must
        be greater than zero, but y may be any real number.

    EXAMPLE

        SAY Pow(2,32)

@endnode
@node "Rnd" "rexx_math.library/Rnd"

Rnd :


    NAME

        Rnd -- Generate a random number.

    SYNOPSIS

        z = Rnd()

    FUNCTION

        This function generates random numbers using the linear
        congruential algorithm. It returns values distributed uniformly
        over the interval from 0.0 up to but not including 1.0.

    EXAMPLE

        SAY Rnd()

@endnode
@node "Sec" "rexx_math.library/Sec"

Sec :


    NAME

        Sec -- Secant function.

    SYNOPSIS

        z = Sec(x)

    FUNCTION

        Calculates the secant of x. The value of x may be any
        real number, but not equal to any multiple of Pi.

    EXAMPLE

        SAY Sec(0.5)

@endnode
@node "Sin" "rexx_math.library/Sin"

Sin :


    NAME

        Sin -- Sine function.

    SYNOPSIS

        z = Sin(x)

    FUNCTION

        Calculates the sine of x. The value of x may be any
        real number.

    EXAMPLE

        SAY Sin(0)

@endnode
@node "SinH" "rexx_math.library/SinH"

SinH :


    NAME

        SinH -- Hyperbolic Sine function.

    SYNOPSIS

        z = SinH(x)

    FUNCTION

        Calculates the hyperbolic sine of x. The value of x may be
        any real number.

    EXAMPLE

        SAY SinH(-0.291268)

@endnode
@node "Sqrt" "rexx_math.library/Sqrt"

Sqrt :


    NAME

        Sqrt -- Square root function.

    SYNOPSIS

        z = Sqrt(x)

    FUNCTION

        Calculates the square root of x. The value of x must be any
        positive number (any real greater or equal to zero).

    EXAMPLE

        SAY Sqrt(4096)

@endnode
@node "Tan" "rexx_math.library/Tan"

Tan :


    NAME

        Tan -- Tangent function.

    SYNOPSIS

        z = Tan(x)

    FUNCTION

        Calculates the tangent of x. The value of x may be any
        real number.

    EXAMPLE

        SAY Tan(0)

@endnode
@node "TanH" "rexx_math.library/TanH"

TanH :


    NAME

        TanH -- Hyperbolic tangent function.

    SYNOPSIS

        z = TanH(x)

    FUNCTION

        Calculates the hyperbolic tangent of x. The value of x may be
        any real number.

    EXAMPLE

        SAY TanH(-0.291268)

@endnode

