@database NFloattextClass
@index "Classes.guide/Main"

@Node Main "RxMUI - NFloattext Class"


NFloattext class    @{"Index" link "Classes.guide/Main"} @{"Super" link "NListClass.guide/Main"}
@{u}                                                             @{uu}

  The NFloattext class is used to show a list made of a ascii
  text.

  A NFloattext object can only be added to a NListview object at
  NListview object creation time.

  NFloattext class is a subclass of NFloattext.mcc, so you must
  have NFloattext.mmc in MUI:Libs/MUI to use it. NFloattext.mcc
  is copyright of Gilles Masson.

  See @{"NList" LINK "NListClass.guide/Main"} @{"NListview" LINK "NListviewFunctions.guide/Main"}.

  @{u}                                                        @{uu}

 @{b}Attributes@{ub}

  @{fg shine}Align@{fg text}
  S IS
  One of:
     o Left
     o Center
     o Right
     o Justify

  @{fg shine}Justify@{fg text}
  B IS

  @{fg shine}Tabsize@{fg text}
  N IS

  @{fg shine}Text@{fg text}
  S IS

  @{u}                                                        @{uu}

 @{b}Methods@{ub}

  None defined

@EndNode

