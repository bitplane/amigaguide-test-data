/*E*/
/*S*/ Commande
/*S*/ ABOUT
@NODE "ABOUT" "Command About"

@{par}  Command: @{APEN 11}ABOUT@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    This command opens the FreshBar-About-Window.

@{par}  @{b}Arguments:@{ub}
@{par}    none

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ QUIT
@NODE "QUIT" "Command QUIT"

@{par}  Command: @{APEN 11}QUIT@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    This will close all windows and FreshBar will quit.

@{par}  @{b}Arguments:@{ub}
@{par}    none

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ CREATEBARWINDOW
@NODE "CREATEBARWINDOW" "Command CREATEBARWINDOW"

@{par}  Command: @{APEN 11}CREATEBARWINDOW@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    Creates a new barwindow. It won't be opend at this time.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}TITLE@{APEN 1}
@{par}      The name of the window. This Name appears in the windowtitlee.

@{par}    @{APEN 9}BUTTONTEXT@{APEN 1}
@{par}      This is the text for the button in the window. If not specified the
@{par}      button won't appear.

@{par}    @{APEN 9}SCREEN@{APEN 1}
@{par}      This is the name of the publicscreen you want the window to appear on.

@{par}    @{APEN 9}CLOSEGADGET/S@{APEN 1}
@{par}      If this argument is specified the window will have a close gadget.
@{par}      It behaves as the button.

@{par}  @{b}Result:@{ub}
@{par}    After that the variable RESULT contains the windowhandle.
@{par}    For further actions on this window this handle is necessary.
@{par}    e.g. @{" DELETEBARWINDOW " link "DELETEBARWINDOW"} handle

@ENDNODE
/*E*/
/*S*/ DELETEBARWINDOW
@NODE "DELETEBARWINDOW" "Command DELETEBARWINDOW"

@{par}  Command: @{APEN 11}DELETEBARWINDOW@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    Deletes a barwindow. If it's still open then it will be closed automatically.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ OPENBARWINDOW
@NODE "OPENBARWINDOW" "Command OPENBARWINDOW"

@{par}  Command: @{APEN 11}OPENBARWINDOW@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    This opens the window specified by the WINHANDLE-argument.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.
@{par}    @{APEN 9}TITLE@{APEN 1}
@{par}      This is the windowtitle which isn't necessary at all.

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ CLOSEBARWINDOW
@NODE "CLOSEBARWINDOW" "Command CLOSEBARWINDOW"

@{par}  Command: @{APEN 11}CLOSEBARWINDOW@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    This ARexx-Command closes the specified window but it is still necessary to
@{par}    delete it by the DELETEBARWINDOW-command.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ CLOSEALLBARWINDOWS
@NODE "CLOSEALLBARWINDOWS" "Command CLOSEALLBARWINDOWS"

@{par}  Command: @{APEN 11}CLOSEALLBARWINDOWS@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    This ARexx-Command closes all windows but it is still necessary
@{par}    to delete the windows by the DELETEBARWINDOW-command.

@{par}  @{b}Arguments:@{ub}
@{par}    none

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ ADDBAR
@NODE "ADDBAR" "Command ADDBAR"

@{par}  Command: @{APEN 11}ADDBAR@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    Creates a new bar in the specified window.
@{par}    This window needn't to be open.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called BarHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}    @{APEN 9}MAXVALUE/N@{APEN 1}
@{par}      The max. value of the bar (corresponds to 100%).

@{par}    @{APEN 9}CURRENTVALUE/N@{APEN 1}
@{par}      The current value of the bar.

@{par}    @{APEN 9}NAME/F@{APEN 1}
@{par}      The name of the bar. This name appears at the left of the bar.
@{par}      To use blanks the name must be qouted.

@{par}  @{b}Result:@{ub}
@{par}    After that the variable RESULT contains the barhandle of the new bar.
@{par}    For further actions on this bar this handle is necessary.
@{par}    z.B. @{" REMOVEBAR " link "REMOVEBAR"} handle

@ENDNODE
/*E*/
/*S*/ REMOVEBAR
@NODE "REMOVEBAR" "Command REMOVEBAR"

@{par}  Command: @{APEN 11}REMOVEBAR@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    Removes a bar from a window.
@{par}    This window needn't to be open.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called BarHandle you got from @{" creating " link "ADDBAR"}
@{par}      a Bar.

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ SETCURRENT
@NODE "SETCURRENT" "Command SETCURRENT"

@{par}  Command: @{APEN 11}SETCURRENT@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    Sets the current value of the specified bar.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called BarHandle you got from @{" creating " link "ADDBAR"}
@{par}      a Bar.

@{par}    @{APEN 9}VALUE/N/A@{APEN 1}
@{par}      The new current value of the bar. See also @{"SETMAXIMUM" LINK "SETMAXIMUM"}

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ SETMAXIMUM
@NODE "SETMAXIMUM" "Command SETMAXIMUM"

@{par}  Command: @{APEN 11}SETMAXIMUM@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    Sets the max. value of the specified bar.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called BarHandle you got from @{" creating " link "ADDBAR"} a Bar.

@{par}    @{APEN 9}VALUE/N/A@{APEN 1}
@{par}      The new max value of the bar (corresponds to 100%).

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ SETFILLPEN
@NODE "SETFILLPEN" "Command SETFILLPEN"

@{par}  Command: @{APEN 11}SETFILLPEN@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    Sets the foregroundcolor of the specified bar.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called BarHandle you got from @{" creating " link "ADDBAR"}
@{par}      a Bar.

@{par}    @{APEN 9}VALUE/N/A@{APEN 1}
@{par}      The new foregroundcolor of the bar. This is the pennumber of the palette
@{par}      of the current screen.

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ SETBACKPEN
@NODE "SETBACKPEN" "Command SETBACKPEN"

@{par}  Command: @{APEN 11}SETBACKPEN@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    Sets the backgroundcolor of the specified bar.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called BarHandle you got from @{" creating " link "ADDBAR"}
@{par}      a Bar.

@{par}    @{APEN 9}VALUE/N/A@{APEN 1}
@{par}      The new backgroundcolor of the bar. This is the pennumber of the palette
@{par}      of the current screen.

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ SETPROGRESSMODE
@NODE "SETPROGRESSMODE" "Command SETPROGRESSMODE"

@{par}  Command: @{APEN 11}SETPROGRESSMODE@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    Sets the type of the progress text in the specified bar.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called BarHandle you got from @{" creating " link "ADDBAR"}
@{par}      a Bar.

@{par}    @{APEN 9}MODE/N/A@{APEN 1}
@{par}      0:  no progresstext
@{par}      1:  percent-display (e.g.: 42%)
@{par}      2:  relation-display (e.g.: 42/150)

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ SETBARWINDOWWIDTH
@NODE "SETBARWINDOWWIDTH" "Command SETBARWINDOWWIDTH"

@{par}  Command: @{APEN 11}SETBARWINDOWWIDTH@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    Sets the Width of the specified Barwindow.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}    @{APEN 9}WIDTH/N/A@{APEN 1}
@{par}      The Width of the window in pixels. If this value is too low,
@{par}      the smallest possible windowsize will be used.

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ SETBARWINDOWPOS
@NODE "SETBARWINDOWPOS" "Command SETBARWINDOWPOS"

@{par}  Command: @{APEN 11}SETBARWINDOWPOS@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    This sets the position of a specified Barwindow.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}    @{APEN 9}X/N@{APEN 1}
@{par}      The X-position of the window in pixels.
@{par}      @{u}Special values:@{uu}
@{par}        -1: center horizontal
@{par}        -2: keep old position

@{par}    @{APEN 9}Y/N@{APEN 1}
@{par}      the Y-position of the window in pixels.
@{par}      @{u}special values:@{uu}
@{par}        -1: center vertical
@{par}        -2: keep old position

@{par}  @{b}Result:@{ub}
@{par}    none

@ENDNODE
/*E*/
/*S*/ TESTOKBUTTON
@NODE "TESTOKBUTTON" "Command TESTOKBUTTON"

@{par}  Command: @{APEN 11}TESTOKBUTTON@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Description:@{ub}
@{par}    Checks if the button, the shortcut, ESC or the close-gadget was pressed.

@{par}  @{b}Arguments:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      This argument is the so called WindowHandle you got from @{" creating " link "CREATEBARWINDOW"}
@{par}      a Window.

@{par}  @{b}Result:@{ub}
@{par}    After this command returns the ARexx-variable RESULT is 1 if the button, the Shortcut, ESC
@{par}    or close-gadget was pressed.

@ENDNODE
/*E*/
/*E*/

