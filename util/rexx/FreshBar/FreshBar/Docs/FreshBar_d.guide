/*E*/
/*S*/ Befehle
/*S*/ ABOUT
@NODE "ABOUT" "Befehl About"

@{par}  Befehl: @{APEN 11}ABOUT@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Es wird das Informationsfenster geöffnet

@{par}  @{b}Parameter:@{ub}
@{par}    Keine

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ QUIT
@NODE "QUIT" "Befehl QUIT"

@{par}  Befehl: @{APEN 11}QUIT@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Das Programm FreshBar wird beendet und alle Fenster geschlossen.

@{par}  @{b}Parameter:@{ub}
@{par}    Keine

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ CREATEBARWINDOW
@NODE "CREATEBARWINDOW" "Befehl CREATEBARWINDOW"

@{par}  Befehl: @{APEN 11}CREATEBARWINDOW@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Erstellt ein neues Balkenfenster. Es wird jedoch noch nicht geöffnet

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}TITLE@{APEN 1}
@{par}      Der Name des Fensters. Dieser Name erscheint in der Titelzeile.

@{par}    @{APEN 9}BUTTONTEXT@{APEN 1}
@{par}      Wird dieser Parameter angegeben, so enhält das Fenster einen Schalter
@{par}      mit dieser Beschriftung. Ob dieser Schalter gedrückt wurde, kann
@{par}      mit dem ARexx-Befehl @{" TESTOKBUTTON " link "TESTOKBUTTON"} abgefragt werden.

@{par}    @{APEN 9}SCREEN@{APEN 1}
@{par}      Mit diesem Parameter gibt man den Namen des öffentlichen Bildschirms
@{par}      an, auf dem das Fenster erscheinen soll.

@{par}    @{APEN 9}CLOSEGADGET/S@{APEN 1}
@{par}      Gibt man diese Option an, so besitzt das Fenster ein Schließsymbol.
@{par}      Es hat die gleiche Funktion wie der Schalter (BUTTONTEXT).

@{par}  @{b}Rückgabe:@{ub}
@{par}    Die Variable RESULT hat nach Ausführung des Befehls die Nummer des
@{par}    erzeugten Fensters, das sogenannte WindowHandle. Um weitere Aktionen
@{par}    auf dieses Fenster auszuführen muß immer dieses Handle angegeben werden.
@{par}    z.B. @{" DELETEBARWINDOW " link "DELETEBARWINDOW"} handle

@ENDNODE
/*E*/
/*S*/ DELETEBARWINDOW
@NODE "DELETEBARWINDOW" "Befehl DELETEBARWINDOW"

@{par}  Befehl: @{APEN 11}DELETEBARWINDOW@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Löscht ein Balkenfenster. Wenn es zu diesem Zeitpunkt noch offen
@{par}    ist, dann wird es ordnungsgemäß geschlossen.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ OPENBARWINDOW
@NODE "OPENBARWINDOW" "Befehl OPENBARWINDOW"

@{par}  Befehl: @{APEN 11}OPENBARWINDOW@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Mit diesem ARexx-Befehl wird das Fenster mit dem angegebenen
@{par}    Handle geöffnet, d.h. es erscheint auf dem Bildschirm.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.
@{par}    @{APEN 9}TITLE@{APEN 1}
@{par}      Dieser Parameter ist der Titel des Fensters. Er kann auch
@{par}      weggelassen werden.

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ CLOSEBARWINDOW
@NODE "CLOSEBARWINDOW" "Befehl CLOSEBARWINDOW"

@{par}  Befehl: @{APEN 11}CLOSEBARWINDOW@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Mit diesem ARexx-Befehl wird das Fenster mit dem angegebenen
@{par}    Handle geschlossen, d.h. es verschwindet vom Bildschirm.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ CLOSEALLBARWINDOWS
@NODE "CLOSEALLBARWINDOWS" "Befehl CLOSEALLBARWINDOWS"

@{par}  Befehl: @{APEN 11}CLOSEALLBARWINDOWS@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Mit diesem ARexx-Befehl werden alle Fenster geschlossen,
@{par}    d.h. sie verschwinden vom Bildschirm.

@{par}  @{b}Parameter:@{ub}
@{par}    Keine

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ CREATEBARWINDOW
@NODE "ADDBAR" "Befehl ADDBAR"

@{par}  Befehl: @{APEN 11}ADDBAR@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Erstellt einen neuen Balken in einem bestimmten Fenster.
@{par}    Das entsprechende Fenster muß dazu nicht offen sein.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}    @{APEN 9}MAXVALUE/N@{APEN 1}
@{par}      Der Maximalwert des Balkens. Dieser Wert stellt die 100% des
@{par}      Füllstandes dar.

@{par}    @{APEN 9}CURRENTVALUE/N@{APEN 1}
@{par}      Der aktuelle Wert des Balkens. Der Füllstand des Balkens wird
@{par}      durch das Verhältnis des aktuellen Wertes zum maximalen dargestellt.

@{par}    @{APEN 9}NAME/F@{APEN 1}
@{par}      Der Name des Balkens. Dieser Name erscheint links vor dem Balken.
@{par}      Um Leerzeichen zu beinhalten, muß dieser Parameter in Anfüh-
@{par}      rungszeichen gesetzt werden.

@{par}  @{b}Rückgabe:@{ub}
@{par}    Die Variable RESULT hat nach Ausführung des Befehls die Nummer des
@{par}    erzeugten Balkens, das sogenannte BarHandle. Um weitere Aktionen
@{par}    auf diesen Fenster auszuführen muß immer das WindowHandle und das
@{par}    BarHandle angegeben werden.
@{par}    z.B. @{" REMOVEBAR " link "REMOVEBAR"} handle

@ENDNODE
/*E*/
/*S*/ REMOVEBAR
@NODE "REMOVEBAR" "Befehl REMOVEBAR"

@{par}  Befehl: @{APEN 11}REMOVEBAR@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Entfernt einen neuen Balken aus einem bestimmten Fenster.
@{par}    Das entsprechende Fenster muß dazu nicht offen sein.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. BarHandle, das man beim @{" Erzeugen " link "ADDBAR"}
@{par}      des Balkens erhalten hat.

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ SETCURRENT
@NODE "SETCURRENT" "Befehl SETCURRENT"

@{par}  Befehl: @{APEN 11}SETCURRENT@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Setzt den aktuellen Wert eines bestimmten Balkens.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. BarHandle, das man beim @{" Erzeugen " link "ADDBAR"}
@{par}      des Balkens erhalten hat.

@{par}    @{APEN 9}VALUE/N/A@{APEN 1}
@{par}      Der aktuelle Wert des Balkens. Siehe auch @{"SETMAXIMUM" LINK "SETMAXIMUM"}

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ SETMAXIMUM
@NODE "SETMAXIMUM" "Befehl SETMAXIMUM"

@{par}  Befehl: @{APEN 11}SETMAXIMUM@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Setzt den maximalen Wert eines bestimmten Balkens.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. BarHandle, das man beim @{" Erzeugen " link "ADDBAR"}
@{par}      des Balkens erhalten hat.

@{par}    @{APEN 9}VALUE/N/A@{APEN 1}
@{par}      Der neue maximale Wert des Balkens. Hierbei handelt es sich
@{par}      um die 100% des Balkens. Beispiel: ist der Maximum-Wert auf
@{par}      sagen wir mal 42 und der aktuelle Wert @{"SETCURRENT" LINK "SETCURRENT"} auf 21,
@{par}      so ist der Balken zu Hältfe geüllt.

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ SETFILLPEN
@NODE "SETFILLPEN" "Befehl SETFILLPEN"

@{par}  Befehl: @{APEN 11}SETFILLPEN@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Setzt die Füllfarbe eines bestimmten Balkens.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. BarHandle, das man beim @{" Erzeugen " link "ADDBAR"}
@{par}      des Balkens erhalten hat.

@{par}    @{APEN 9}VALUE/N/A@{APEN 1}
@{par}      Die neue Füllfarbe des Balkens. Hierbei handelt es sich um
@{par}      die Farbnummer aus der aktuellen Palette des Bildschirms.

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ SETBACKPEN
@NODE "SETBACKPEN" "Befehl SETBACKPEN"

@{par}  Befehl: @{APEN 11}SETBACKPEN@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Setzt die Hintergrundfarbe eines bestimmten Balkens.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. BarHandle, das man beim @{" Erzeugen " link "ADDBAR"}
@{par}      des Balkens erhalten hat.

@{par}    @{APEN 9}VALUE/N/A@{APEN 1}
@{par}      Die neue Hintergrundfarbe des Balkens. Hierbei handelt es sich
@{par}      um die Farbnummer aus der aktuellen Palette des Bildschirms.

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ SETPROGRESSMODE
@NODE "SETPROGRESSMODE" "Befehl SETPROGRESSMODE"

@{par}  Befehl: @{APEN 11}SETPROGRESSMODE@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Setzt den Typ der Zahlenmäßigen Fortschrittsanzeige eines
@{par}    bestimmten Balkens.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}    @{APEN 9}BARHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. BarHandle, das man beim @{" Erzeugen " link "ADDBAR"}
@{par}      des Balkens erhalten hat.

@{par}    @{APEN 9}MODE/N/A@{APEN 1}
@{par}      0:  Keine Anzeige in Zahlen
@{par}      1:  Prozentanzeige (z.B.: 42%)
@{par}      2:  Verhältnisanzeige (z.B.: 42/150)

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ SETBARWINDOWWIDTH
@NODE "SETBARWINDOWWIDTH" "Befehl SETBARWINDOWWIDTH"

@{par}  Befehl: @{APEN 11}SETBARWINDOWWIDTH@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Setzt die Breite eines bestimmten Balkenfensters.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}    @{APEN 9}WIDTH/N/A@{APEN 1}
@{par}      Die Breite des Fensters in Pixeln. ist dieser Wert zu klein,
@{par}      so wird die kleinstmögliche Fenstergröße ermittelt und gesetzt.

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ SETBARWINDOWPOS
@NODE "SETBARWINDOWPOS" "Befehl SETBARWINDOWPOS"

@{par}  Befehl: @{APEN 11}SETBARWINDOWPOS@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Setzt die Position eines bestimmten Balkenfensters.

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}    @{APEN 9}X/N@{APEN 1}
@{par}      Die X-Position des Fensters in Pixeln.
@{par}      @{u}Spezialwerte:@{uu}
@{par}        -1: horizontal zentrieren
@{par}        -2: alte Position behalten

@{par}    @{APEN 9}Y/N@{APEN 1}
@{par}      Die Y-Position des Fensters in Pixeln.
@{par}      @{u}Spezialwerte:@{uu}
@{par}        -1: vertikal zentrieren
@{par}        -2: alte Position behalten

@{par}  @{b}Rückgabe:@{ub}
@{par}    Keine

@ENDNODE
/*E*/
/*S*/ TESTOKBUTTON
@NODE "TESTOKBUTTON" "Befehl TESTOKBUTTON"

@{par}  Befehl: @{APEN 11}TESTOKBUTTON@{APEN 1}
@{par}  -------------------------------------

@{par}  @{b}Funktion:@{ub}
@{par}    Prüft, ob Schalter, Shortcut, ESC oder Schließsymbol gedrückt wurde

@{par}  @{b}Parameter:@{ub}
@{par}    @{APEN 9}WINHANDLE/N/A@{APEN 1}
@{par}      Dieser Parameter ist das sog. WindowHandle, das man beim @{" Erzeugen " link "CREATEBARWINDOW"}
@{par}      des Fensters erhalten hat.

@{par}  @{b}Rückgabe:@{ub}
@{par}    RESULT ist nach Abarbeitung 1, wenn Schalter, Shortcut, ESC
@{par}    oder Schließsymbol gedrückt wurde

@ENDNODE
/*E*/
/*E*/

