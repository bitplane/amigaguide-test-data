@Node "RxChild"

  @{b}RxChild@{ub} - launches a child


  @{b}Synopsis@{ub}
    childID = RxChild(macro,flags,host,socketfd)
    <macro>,[flags].[host],[socketfd/N]


  @{b}Function@{ub}
    Launches a child macro.


  @{b}Inputs@{ub}
    macro    - the macro to launch
    flags    - one or more of
                   o NOIO
                   o RESULT
                   o STRING
                   o TOKEN
                   o SYNC
    host     - the default ARexx host for the child
    socketfd - pass this socket


  @{b}Result@{ub}
    childID - the child id
@EndNode

@Node "RxChildAmI"

  @{b}RxChildAmI@{ub} - tests if child


  @{b}Synopsis@{ub}
    res = RxChildAmI()
    -


  @{b}Function@{ub}
    Tests if the running macro is a child.


  @{b}Result@{ub}
    res - an ARexx boolean
@EndNode

@Node "RxChildFlags"

  @{b}RxChildFlags@{ub} - returns child flags


  @{b}Synopsis@{ub}
    res = RxChildFlags(childID)
    <childID/N>


  @{b}Function@{ub}
    Returns the child RexxTask flags.


  @{b}Inputs@{ub}
    childID - the id of a child


  @{b}Result@{ub}
    res - the child flags
@EndNode

@Node "RxChildFree"

  @{b}RxChildFree@{ub} - frees a child


  @{b}Synopsis@{ub}
    call RxChildFree(childID)
    <childID/N>


  @{b}Function@{ub}
    Frees any resources allocated for a child and halts
    it if running.


  @{b}Inputs@{ub}
    childID - the id of a child
    file - the file name
@EndNode

@Node "RxChildGetvar"

  @{b}RxChildGetvar@{ub} - gets a child var


  @{b}Synopsis@{ub}
    res = RxChildGetvar(childID,childVar,localVar)
    <childID/N>,<childVar/S>,<localVar/S>


  @{b}Function@{ub}
    Reads a child var and writes it in localVar.


  @{b}Inputs@{ub}
    childID - the id of a child
    childVar - the var to read
    localVar - where to write the value of childVar

  @{b}Result@{ub}
    res - an ARexx boolean
"GetSysTime"} @{"SubTime" LINK "SubTime"} @{"SetSysTime" LINK "SetSysTime"} .
@EndNode

@Node "RxChildHalt"

  @{b}RxChildHalt@{ub} - hatls a child


  @{b}Synopsis@{ub}
    call RxChildHalt(childID)
    <childID/N>


  @{b}Function@{ub}
    Halts a child.


  @{b}Inputs@{ub}
    childID - the id of a child
@EndNode

@Node "RxChildResult"

  @{b}RxChildResult@{ub} - returns child results


  @{b}Synopsis@{ub}
    res = RxChildResult(childID,res1,res2)
    <childID/N>,<res1/V>,[res2/V]


  @{b}Function@{ub}
    Returns the primary and secundary results of a child.
    Of course, the child must be ENDed.


  @{b}Inputs@{ub}
    childID - the id of a child
    res1 - where to write result1
    res2 - where to write result2


  @{b}Result@{ub}
    res - an ARexx boolean


  @{b}See@{ub}
    @{"or" LINK "or"} @{"wait" LINK "wait"} .
@EndNode

@Node "RxChildSelfSuspend"

  @{b}RxChildSelfSuspend@{ub} - self suspend this child


  @{b}Synopsis@{ub}
    res = RxChildSelfSuspend()
    -


  @{b}Function@{ub}
    If the running macro is a child, you can selft suspend
    it calling this function.


 @{b}Result@{ub}
    res - An ARexx boolean
@EndNode

@Node "RxChildSetVar"

  @{b}RxChildSetVar@{ub} - sets a child var


  @{b}Synopsis@{ub}
    res = RxChildSetVar(childID,var,value)
    <childID/N>,<var/S>,<value>


  @{b}Function@{ub}
    Sets a var of a child.


  @{b}Inputs@{ub}
    childID - the id of a child
    var - the var to set
    value - the value to set var to


  @{b}Result@{ub}
    res - an ARexx boolean
@EndNode

@Node "RxChildStatus"

  @{b}RxChildStatus@{ub} - returns the status of a child


  @{b}Synopsis@{ub}
    status = RxChildStatus(childID)
    <childID/N>


  @{b}Function@{ub}
    Returns the status of a child, one of:
        o RUN  the child is running
        o SUSP the child is suspended
        o END  the child ended


  @{b}Inputs@{ub}
    childID - the ID of a child


  @{b}Result@{ub}
    status - the status of the child
@EndNode

