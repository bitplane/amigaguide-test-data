@node "INSTALLING" "Installing the Bugger"
 @{b}How to Install@{ub}

 Copy 'WBStartup/StartupPlus' to the 'WBStartup' drawer
 Copy 'Prefs/SUPPrefs' to the 'Prefs' drawer
 Copy 'Libs/dospath.library' to 'Libs:'
 Copy 'Libs/wbstart.library' to 'Libs:'
 Copy 'SUPKeyFile' to 'ENV:' and 'ENVARC:'
 Copy 'StartupPlus.guide' to 'Help:'
@endnode