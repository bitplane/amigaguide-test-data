@Node "ADDPART"		"AFR.guide/Extern/Rexxport/AddPart     "

	Es werden zwei Dateipfade nach DOS-konventionen miteinander
	verkn■ft.

	full = AddPart('pad1','pad2')

	Enthðlt das zweite Argument einen ':' wird dieser in ganzer
	lðnge zur■ckgegeben.

@EndNode
@Node "PATHPART"		"AFR.guide/Extern/Rexxport/PathPart    "

	Es wird der letzte Teil eines Dateipfades abgeschnitten, der
	Teil w■rde in einem Filerequester entfernt, wenn in das
	■bergeordnete Verzeichnis gewechselt w■rde.

	string = PathPart('sys:AFR/AFR.guide') ,

	string ist dann 'sys:AFR/'.

	Es ist entweder ein Doppelpunkt an dem zur■ckgegebenen Namen,
	oder aber ein '/'. Damit ist in Rexx ein einfaches Handling
	mit den Dateinamen m—glich.

	Filepad = Dir || File

@EndNode
@Node "FILEPART"		"AFR.guide/Extern/Rexxport/FilePart    "

	Den Dateinamen eines kompletten Dateipfades erfragen.

	string = FilePart('sys:AFR/AFR.guide') ,

	string ist dann 'AFR.guide'.

@EndNode
@Node "EXTPART"		"AFR.guide/Extern/Rexxport/ExtPart     "

	Extension eines Dateinames erfragen.

	string = ExtPart('sys:AFR/AFR.guide') ,

	string ist dann '.guide'.

@EndNode
@Node "DELEXTPART"		"AFR.guide/Extern/Rexxport/DelExtPart  "

	Entfernt wird die Extension eines Dateinamens.


	string = DelExtPart('sys:AFR/AFR.guide') ,

	wird zu 'sys:AFR/AFR'.

@EndNode
@Node "MATCHPATTERN"		"AFR.guide/Extern/Rexxport/MatchPattern"

	ok = MatchPattern('patt','string')

@EndNode
@Node "BASECONV"		"AFR.guide/Extern/Rexxport/BaseConv"

	Konvertiert Zahlen (BIN/HEX/DEZ) in andere Formate.

	dez = BaseConv('%1000011000',D)

	hex = BaseConv('255')		/*  Hex ist default  */

	bin = BaseConv('$FFE1',B)

@EndNode
@Node "READFILE"		"AFR.guide/Extern/Rexxport/ReadFile"

	NP
	Soll eine Datei einlesen.

	bool = ReadFile('Datei',stemvar)


@EndNode
@Node "READZ"		"AFR.guide/Extern/Rexxport/ReadZ"

