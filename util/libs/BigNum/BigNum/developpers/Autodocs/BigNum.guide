@endnode


@node "BigNumSize" "_BigNum/BigNumSize   »»  BASE NAME = _BigNumBase"

   NAME
	BigNumSize -- Give the size of a BigNum

   SYNOPSIS
	res = BigNumSize( big )
	D0                A0

	int BigNumSize(PtrBigNum)

   INPUTS
	big	The bignum you want to know the size.

   RESULT
	The size in WORDs

   @{b}NOTES@{ub}
	The size can be interpreted as the lowest N that verify :

		abs(big) < 32768^N


@endnode


