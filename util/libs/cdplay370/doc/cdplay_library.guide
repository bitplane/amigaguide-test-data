@{b}

   NAME@{ub}
        CDPrev -- wählt den vorherigen Track an@{b}

   SYNOPSIS@{ub}
        result = CDPrev (request)
        D0                 A1

        ULONG CDPrev (struct CDRequest *);@{b}

   FUNCTION@{ub}
        Springt zum vorherigen Track. Wenn es keinen vorhergehenden
        Track gibt, hat der Aufruf keine Wirkung.@{b}

   INPUTS@{ub}
        request        --        "struct CDRequest *" des entsprechenden Drives@{b}

   RESULT@{ub}
        result        --        liefert im Fehlerfall einen von 0 verschiedenen
                        Wert, der dem Errorcode entspricht.@{b}

   BUGS@{ub}
        keine bekannt.@{b}

   SEE ALSO@{ub}
        @{"cdplay.library/CDNext()" LINK "CDNext"}

@ENDNODE
@NODE "CDStop" "cdplay.library/CDStop()"
@{b}

   NAME@{ub}
        CDStop -- stoppt die Wiedergabe einer Audio-CD@{b}

   SYNOPSIS@{ub}
        result = CDStop (request)
        D0                 A1

        ULONG CDStop (struct CDRequest *);@{b}

   FUNCTION@{ub}
        Stoppt die Wiedergabe einer Audio-CD, die zuvor mit @{"CDPlay()" LINK "CDPlay"}
        gestartet wurde.@{b}

   INPUTS@{ub}
        request        --        "struct CDRequest *" des entsprechenden Drives@{b}

   RESULT@{ub}
        result        --        liefert im Fehlerfall einen von 0 verschiedenen
                        Wert, der dem Errorcode entspricht.@{b}

   BUGS@{ub}
        keine bekannt.@{b}

   SEE ALSO@{ub}
        @{"cdplay.library/CDPause()" LINK "CDPause"}, @{"cdplay.library/CDPlay()" LINK "CDPlay"}

@ENDNODE
@NODE "CDUpdate" "cdplay.library/CDUpdate()"
@{b}

   NAME@{ub}
        CDUpdate -- aktualisiert alle Daten des CDRom´s die im laufenden
                    Betrieb veränderlich sind (z.B. CD-Wechsel)@{b}

   SYNOPSIS@{ub}
        result = CDUpdate (request)
        D0                   A1

        ULONG CDUpdate (struct CDRequest *);@{b}

   FUNCTION@{ub}
        Alle Daten über das SCSI-Device, die sich im laufenden Betrieb
        ändern können (also NICHT Herstellername etc.) werden mit dieser
        Funktion neu ermittelt und im CDRequest abgelegt. Dazu zählen
        Informationen über die CD, aber auch die Position (Zeit) auf der
        CD während des Audioplays.@{b}

   INPUTS@{ub}
        request        --        "struct CDRequest *", wird von @{"CDOpenDrive()" LINK "CDOpenDrive"}
                        geliefert@{b}

   RESULT@{ub}
        result        --        Fehlercode, der dem Rückgabewert der DoIO()
                        Funktion entspricht. Im Fehlerfall ist dies
                        ein von 0 verschiedener Wert.@{b}

   NOTES@{ub}
        Einige Funktionen rufen CDUpdate() von selber auf, ein Aufruf
        ist dann i.d.R. nicht mehr nötig. Zu diesen Funktionen gehören
        @{"cdplay.library/CDJump()" LINK "CDJump"}, @{"cdplay.library/CDNext()" LINK "CDNext"} und
        @{"cdplay.library/CDPrev()" LINK "CDPrev"}@{b}

   BUGS@{ub}
        keine bekannt@{b}

   SEE ALSO@{ub}
        @{"cdplay.library/CDJump()" LINK "CDJump"}, @{"cdplay.library/CDNext()" LINK "CDNext"},
        @{"cdplay.library/CDPrev()" LINK "CDPrev"}

@ENDNODE
