@DATABASE "cdplay_library"
@NODE MAIN "cdplay_library -- Inhalt"

                               @{b}cdplay.library@{ub}

@{"CDClose()" LINK "CDClose"}  @{"CDCloseDrive()" LINK "CDCloseDrive"}  @{"CDInquiry()" LINK "CDInquiry"}    @{"CDJump()" LINK "CDJump"}   @{"CDLockDrive()" LINK "CDLockDrive"}
@{"CDNext()" LINK "CDNext"}   @{"CDOpen()" LINK "CDOpen"}        @{"CDOpenDrive()" LINK "CDOpenDrive"}  @{"CDPause()" LINK "CDPause"}  @{"CDPlay()" LINK "CDPlay"}
@{"CDPrev()" LINK "CDPrev"}   @{"CDStop()" LINK "CDStop"}        @{"CDUpdate()" LINK "CDUpdate"}     

@ENDNODE
@NODE "CDClose" "cdplay.library/CDClose()"
@{b}

   NAME@{ub}
        CDClose -- schließt die Schublade des CDRom Laufwerkes@{b}

   SYNOPSIS@{ub}
        result = CDClose (request)
        D0                 A1

        ULONG CDClose (struct CDRequest *);@{b}

   FUNCTION@{ub}
        Schließt die Schublade des CDRom Laufwerkes.@{b}

   INPUTS@{ub}
        request        --        "struct CDRequest *" des entsprechenden
                        Drives@{b}

   RESULT@{ub}
        result        --        liefert im Fehlerfall einen von 0 verschiedenen
                        Wert, der dem Errorcode entspricht.@{b}

   NOTES@{ub}
        Wird nicht von allen Laufwerken unterstützt@{b}

   BUGS@{ub}
        keine bekannt.@{b}

   SEE ALSO@{ub}
        @{"cdplay.library/CDOpen()" LINK "CDOpen"}

@ENDNODE
@NODE "CDCloseDrive" "cdplay.library/CDCloseDrive()"
@{b}

   NAME@{ub}
        CDCloseDrive -- SCSI Device schließen und Speicher freigeben@{b}

   SYNOPSIS@{ub}
        result = CDCloseDrive (request)
        D0                       A1

        struct CDRequest *CDCloseDrive (struct CDRequest *);@{b}

   FUNCTION@{ub}
        Schließt ein mit @{"CDOpenDrive()" LINK "CDOpenDrive"} geöffnet Device und gibt den benutzten
        Speicher wieder frei.@{b}

   INPUTS@{ub}
        request        --        CDRequest des zu schließenden Devices, diese
                        Struktur wird von @{"CDOpenDrive()" LINK "CDOpenDrive"} geliefert.@{b}

   RESULT@{ub}
        result        --        Ergebniss des Kommandos, in der Regel muß alles
                        klappen und es wird TRUE geliefert.@{b}

   EXAMPLE@{ub}
        siehe @{"cdplay.library/CDOpenDrive()" LINK "CDOpenDrive"}@{b}

   BUGS@{ub}
        keine bakannt@{b}

   SEE ALSO@{ub}
        @{"cdplay.library/CDOpenDrive()" LINK "CDOpenDrive"}, @{"cdplay.library/CDUpdate()" LINK "CDUpdate"},
        @{"cdplay.library/CDInquiry()" LINK "CDInquiry"}

@ENDNODE
@NODE "CDInquiry" "cdplay.library/CDInquiry()"
@{b}

   NAME@{ub}
        CDInquiry -- liest spezifische Informationen aus dem Device aus@{b}

   SYNOPSIS@{ub}
        result = CDInquiry (inquiry, request)
        D0                    A0             A1

        ULONG CDInquiry (struct CDInquiry *, struct CDRequest *);@{b}

   FUNCTION@{ub}
        Liest Informationen aus dem SCSI-Device aus. Dazu gehören unter
        anderen Hersteller und Produkt, Features des Devices, Typ (CDRom,
        Festplatte, ...). Normalerweise wird diese Funktion nur einmal
        pro Device aufgerufen. @{"CDOpenDrive()" LINK "CDOpenDrive"} ruft die Funktion beim Öffnen
        auf, so das der normale Programmierer keine Verwendung haben
        dürfte.@{b}

   INPUTS@{ub}
        inquiry        --        "struct CDInquiry *", Struktur die mit den
                        erhätlichen Informationen des Devices ge-
                        füllt wird.
        request        --        "struct CDRequest *", wird von @{"CDOpenDrive()" LINK "CDOpenDrive"}
                        geliefert@{b}

   RESULT@{ub}
        result        --        Im Fehlerfall ein von 0 verschiedener Wert@{b}

   EXAMPLE@{ub}

        struct CDRequest *mycd;
        struct CDInquiry *myinq;

        if (mycd = @{"CDOpenDrive" LINK "CDOpenDrive"} ("scsi.device", 2))
        {
                if (!CDInquiry (myinq, mycd))
                {
                        /* erfolgreich */
                }
                else
                {
                        /* fehlgeschlagen ;(( */
                }

                @{"CDCloseDrive" LINK "CDCloseDrive"} (mycd);
        }@{b}

   NOTES@{ub}
        Wird normalerweise nie gebraucht.@{b}

   BUGS@{ub}
        keine bekannt@{b}

   SEE ALSO@{ub}
        @{"cdplay.library/CDOpenDrive()" LINK "CDOpenDrive"}, @{"cdplay.library/CDUpdate()" LINK "CDUpdate"}

@ENDNODE
@NODE "CDJump" "cdplay.library/CDJump()"
@{b}

   NAME@{ub}
        CDJump -- springt innerhalb eines Tracks vor/zurück@{b}

   SYNOPSIS@{ub}
        result = CDJump (offset, request)
        D0                 D0         A1

        ULONG CDJump (LONG, struct CDRequest *);@{b}

   FUNCTION@{ub}
        Springt innerhalb eines Tracks zu einer neuen Position. Dabei
        sowohl vorwärts als auch rückwärts gesprungen werden. Der Offset
        gibt dabei die Richtung an (Vorzeichen) und die Sprungweite.
        Ein Wert von 75 entspricht dabei einer Sekunde.@{b}

   INPUTS@{ub}
        offset        --        Sprungweite von der aktuellen Position, das
                        Vorzeichen bestimmt die Richtung
        request        --        "struct CDRequest *" des entsprechenden Drives@{b}

   RESULT@{ub}
        result        --        liefert im Fehlerfall einen von 0 verschiedenen
                        Wert, der dem Errorcode entspricht.@{b}

   EXAMPLE@{ub}
        /* .... */

        CDJump (-(10 * 75), mycd);        /* 10 Sekunden zurück springen */

        /* .... */@{b}

   BUGS@{ub}
        keine bekannt.

@ENDNODE
@NODE "CDLockDrive" "cdplay.library/CDLockDrive()"
@{b}

   NAME@{ub}
        CDLockDrive -- ermöglicht das Öffnen des CD-Rom´s zu sperren@{b}

   SYNOPSIS@{ub}
        result = CDLockDrive (mode, request);
        D0                      D0    A1

        ULONG CDLockDrive (ULONG, struct CDRequest *);@{b}

   FUNCTION@{ub}
        Ermöglicht es, den Auswurf von CDRom´s zu vermeiden. Mit der
        Funktion kann die Klappe des Laufwerks verriegelt werden
        bzw. eine solche Verriegelung wieder aufgehoben werden.@{b}

   INPUTS@{ub}
        mode        --        Einen von 0 verschiedenen Wert zum Verriegeln
                        oder 0, um das Laufwerk freizugeben.
        request        --        "struct CDRequest *" des entsprechenden Drives@{b}

   RESULT@{ub}
        result        --        liefert im Fehlerfall einen von 0 verschiedenen
                        Wert, der dem Errorcode entspricht.@{b}

   EXAMPLE@{ub}
        struct CDRequest *mycd;

        if (mycd = @{"CDOpenDrive" LINK "CDOpenDrive"} ("scsi.device", 2))
        {
                /* Laufwerk verriegeln */
                CDLockDrive (TRUE, mycd);

                @{"CDCloseDrive" LINK "CDCloseDrive"} (mycd);
        }@{b}

   NOTES@{ub}
        Nach einem Reset ist die Verrieglung bei einigen Laufwerken
        aufgehoben, bei anderen nicht. Ausprobieren!@{b}

   BUGS@{ub}
        keine bekannt.

@ENDNODE
@NODE "CDNext" "cdplay.library/CDNext()"
@{b}

   NAME@{ub}
        CDNext -- wählt den nächsten Track an@{b}

   SYNOPSIS@{ub}
        result = CDNext (request)
