        gibt, hat der Aufruf keine Wirkung.@{b}

   INPUTS@{ub}
        request        --        "struct CDRequest *" des entsprechenden Drives@{b}

   RESULT@{ub}
        result        --        liefert im Fehlerfall einen von 0 verschiedenen
                        Wert, der dem Errorcode entspricht.@{b}

   BUGS@{ub}
        keine bekannt.@{b}

   SEE ALSO@{ub}
        @{"cdplay.library/CDPrev()" LINK "CDPrev"}

@ENDNODE
@NODE "CDOpen" "cdplay.library/CDOpen()"
@{b}

   NAME@{ub}
        CDOpen -- öffnet die Schublade des CDRom Laufwerkes@{b}

   SYNOPSIS@{ub}
        result = CDOpen (request)
        D0                 A1

        ULONG CDOpen (struct CDRequest *);@{b}

   FUNCTION@{ub}
        Öffnet die Schublade des CDRom Laufwerkes.@{b}

   INPUTS@{ub}
        request        --        "struct CDRequest *" des entsprechenden Drives@{b}

   RESULT@{ub}
        result        --        liefert im Fehlerfall einen von 0 verschiedenen
                        Wert, der dem Errorcode entspricht.@{b}

   NOTES@{ub}
        Wird nicht von allen Laufwerken unterstützt@{b}

   BUGS@{ub}
        keine bekannt.@{b}

   SEE ALSO@{ub}
