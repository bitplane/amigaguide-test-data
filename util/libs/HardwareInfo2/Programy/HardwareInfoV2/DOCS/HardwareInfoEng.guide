@node "hiDriveOn" "hiDriveOn"

HardwareInfo.library/DriveOn		HardwareInfo.library/hiDriveOn

    NAME
	hiDriveOn -- Turn on drive (V2).

    SYNOPSIS
	hiDriveOn(drivenumber)
		  D0

	void  hiDriveOn( ULONG)

    NOTES
	Values for drivenumber:
	3 - DF0
	4 - DF1
	5 - DF2
	6 - DF3

@endnode

