@node "hiMC68010Check" "hiMC68010Check"

HardwareInfo.library/hiMC68010Check		HardwareInfo.library/hiMC68010Check

    NAME
	hiMC68010Check -- Checking do you have MC68010 or higher.

    SYNOPSIS
	cpu = hiMC68010Check()
	D0

	BOOL  hiMC68010Check()

    RESULT
	cpu = 1 - MC68010+ found
	cpu = 0 - MC68010+ not found or error

@endnode

