@node "hiSetAGA" "hiSetAGA"

HardwareInfo.library/hiSetAGA		HardwareInfo.library/hiSetAGA

    NAME
	hiSetAGA -- Turn on AGA boards (like SetPatch).

    SYNOPSIS
