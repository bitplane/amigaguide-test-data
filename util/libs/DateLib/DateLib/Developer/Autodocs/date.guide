@{b}   SYNOPSIS@{ub}
	day = date_JulianLastMonthDay(month,year);
	 d0			       d0    d1

	unsigned short date_JulianLastMonthDay(const unsigned short month,
	    const long year);

@{b}   FUNCTION@{ub}
	JulianLastMonthDay returns the number of the last day for a given
	month.

@{b}   INPUTS@{ub}
	month - The month from which you want to get the last day.
	year  - The year in which the month is.

@{b}   RESULT@{ub}
	day - The number of the last day the month uses, or 0 if you use
	    an incorrect month.

@{b}   EXAMPLE@{ub}
	...
	day = date_JulianLastMonthDay(1,1994); /* 31 */
