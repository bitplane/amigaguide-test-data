@Node "GetProgArgsA()" "progargs.library/GetProgArgsA"
                                                     22 Dec 1994    04:52:32
@{b}   NAME@{ub}
       GetProgArgsA -- get values from an argument set.
       GetProgArgs -- varargs stub for GetProgArgsA().

@{b}   SYNOPSIS@{ub}
       result = GetProgArgsA( progArgs, argTags )
       D0                     A0        A1

       @{"BOOL" Link "INCLUDE:exec/types.h/Main" 68} GetProgArgsA( struct @{"ProgArgs" Link "libraries/progargs.h/Main" 82} *, struct @{"TagItem" Link "INCLUDE:utility/tagitem.h/Main" 31} * )

       result = GetProgArgsA( progArgs, arg1Tag, ... )

       @{"BOOL" Link "INCLUDE:exec/types.h/Main" 68} GetProgArgsA( struct @{"ProgArgs" Link "libraries/progargs.h/Main" 82} *, @{"Tag" Link "INCLUDE:utility/tagitem.h/Main" 29}, ... )

@{b}   FUNCTION@{ub}
       Extracts the requested arguments from the given argument set.  The
       tag list should be a standard array of { TagValue, PutAddress } tag
       pairs, where TagValue is an argument ID being requested and
       PutAddress is the address of a ULONG in memory in which to place the
       value.  If an explicit value for the argument is not found in the
       argument list, the argument's default value (if any) is returned.

       If any of the requested arguments have no explicit or default value
       an result of FALSE will be returned; if all values are extracted
       okay, TRUE is returned.

@{b}   INPUTS@{ub}
       progArgs - ( struct @{"ProgArgs" Link "libraries/progargs.h/Main" 82} * ) Argument set to query.
       argTags  - ( struct @{"TagItem" Link "INCLUDE:utility/tagitem.h/Main" 31} * ) Arguments to retrieve.

@{b}   RESULT@{ub}
       result - ( @{"BOOL" Link "INCLUDE:exec/types.h/Main" 68} ) TRUE if all is okay; FALSE if any argument
                was not found.

@{b}   TAGS@{ub}


@{b}   EXAMPLE@{ub}


@{b}   NOTES@{ub}
       .

@{b}   BUGS@{ub}
       .

@{b}   SEE ALSO@{ub}
       @{"AllocProgArgsA()" Link "AllocProgArgsA()"}, @{"AddProgArgsA()" Link "AddProgArgsA()"}

@EndNode

