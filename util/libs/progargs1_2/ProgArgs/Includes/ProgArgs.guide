@Node "PA_NextArgEntry()" "progargs.library/PA_NextArgEntry"
                                                     22 Dec 1994    16:15:55
 NAME
       PA_NextArgEntry -- get next sequential @{"ArgEntry" Link "libraries/progargs.h/Main" 59} in an argument set.

@{b}   SYNOPSIS@{ub}
       nextEntry = PA_NextArgEntry( progArgs, curEntry )
       D0                           A0        A1

       struct @{"ArgEntry" Link "libraries/progargs.h/Main" 59} * PA_NextArgEntry( struct @{"ProgArgs" Link "libraries/progargs.h/Main" 82} *,
                                          struct @{"ArgEntry" Link "libraries/progargs.h/Main" 59} * )

@{b}   FUNCTION@{ub}
       Returns the @{"ArgEntry" Link "libraries/progargs.h/Main" 59} which is sequentially after the given one.  If
       the given @{"ArgEntry" Link "libraries/progargs.h/Main" 59} is NULL, the first entry in the argument set is
       returned.  If the current entry is the last in the argument set, a
       NULL is returned.  This function can be used to loop over all of the
       arguments defined in an argument set.

@{b}   INPUTS@{ub}
       progArgs - ( struct @{"ProgArgs" Link "libraries/progargs.h/Main" 82} * ) Argument set to look in.
       curEntry - ( struct @{"ArgEntry" Link "libraries/progargs.h/Main" 59} * ) Current entry in the set.

@{b}   RESULT@{ub}
       nextEntry - ( struct @{"ArgEntry" Link "libraries/progargs.h/Main" 59} * ) Entry sequentially after the
                   given current one.

@{b}   TAGS@{ub}


@{b}   EXAMPLE@{ub}

       /* Show all argument templates in an argument set /*

       void ShowArguments(struct @{"ProgArgs" Link "libraries/progargs.h/Main" 82} * pa)
       {
           struct ArgEntry* ae;

           ae = NULL;
           while( (ae=PA_NextArgEntry(pa,ae)) ) {

               printf("%s\n",ae->ae_Template);

           }
       }

@{b}   NOTES@{ub}
       .

@{b}   BUGS@{ub}
       .

@{b}   SEE ALSO@{ub}
       @{"AllocProgArgsA()" Link "AllocProgArgsA()"}, @{"PA_GetArgEntry()" Link "PA_GetArgEntry()"}

@EndNode

@Node "PA_RemTagArgsA()" "progargs.library/PA_RemTagArgsA"
                                                     11 Dec 1994    20:23:29
@{b}   NAME@{ub}
       PA_RemTagArgsA -- remove tags from an argument array.
       PA_RemTagArgs -- varargs stub for PA_RemTagArgsA().

@{b}   SYNOPSIS@{ub}
       result = PA_RemTagArgsA( base, args )
       D0                       A0    A1

       @{"BOOL" Link "INCLUDE:exec/types.h/Main" 68} PA_RemTagArgsA( struct @{"TagArgs" Link "INCLUDE:libraries/progargs.h/Main" 24} *, struct @{"TagItem" Link "INCLUDE:utility/tagitem.h/Main" 31} * )

