       @{"BOOL" Link "INCLUDE:exec/types.h/Main" 68} PA_RemTagArgsA( struct @{"TagArgs" Link "INCLUDE:libraries/progargs.h/Main" 24} *, @{"Tag" Link "INCLUDE:utility/tagitem.h/Main" 29}, ... )

@{b}   FUNCTION@{ub}
       Removes the given tag values from the argument array.  They will no
       longer exist in this argument array's tag list.

       The tag ti_Data fields of the argument array MUST contain the magic
       values REMARG_REMOVE or REMARG_IGNORE to control whether or not this
       argument will actually be removed; any other value is illegal.

@{b}   INPUTS@{ub}
       base - ( struct @{"TagArgs" Link "INCLUDE:libraries/progargs.h/Main" 24} * ) Argument array to modify.
       args - ( struct @{"TagItem" Link "INCLUDE:utility/tagitem.h/Main" 31} * ) Arguments to remove.

@{b}   RESULT@{ub}
       result - ( @{"BOOL" Link "INCLUDE:exec/types.h/Main" 68} ) TRUE if all is okay, else FALSE.

@{b}   TAGS@{ub}


@{b}   EXAMPLE@{ub}


@{b}   NOTES@{ub}
       .

@{b}   BUGS@{ub}
       .

@{b}   SEE ALSO@{ub}
       @{"PA_AddTagArgsA()" Link "PA_AddTagArgsA()"}, @{"PA_AllocTagArgsA()" Link "PA_AllocTagArgsA()"}

@EndNode

@Node "RemProgArgsA()" "progargs.library/RemProgArgsA"
                                                     11 Dec 1994    20:12:26
@{b}   NAME@{ub}
       RemProgArgsA -- remove values from an argument set.
       RemProgArgs -- varargs stub for RemProgArgsA().

@{b}   SYNOPSIS@{ub}
       result = RemProgArgsA( progArgs, argTags )
       D0                     A0        A1

       @{"BOOL" Link "INCLUDE:exec/types.h/Main" 68} RemProgArgsA( struct @{"ProgArgs" Link "libraries/progargs.h/Main" 82} *, struct @{"TagItem" Link "INCLUDE:utility/tagitem.h/Main" 31} * )

       result = RemProgArgsA( progArgs, arg1Tag, ... )

       @{"BOOL" Link "INCLUDE:exec/types.h/Main" 68} RemProgArgsA( struct @{"ProgArgs" Link "libraries/progargs.h/Main" 82} *, @{"Tag" Link "INCLUDE:utility/tagitem.h/Main" 29}, ... )

@{b}   FUNCTION@{ub}
       This allows a program to remove the individual values in an
       argument set.  Note that these are the values initially supplied as
       the entries to AllocProgArgsA(); this function does NOT allow a
       program to add completely new arguments.  The act of 'removing' a
       value simply means that the associated @{"ArgEntry" Link "libraries/progargs.h/Main" 59} no longer has a
       value; a search for it in the argument tag list will result in it
       not being found, and if the arguments are written out to disk, this
       one will not be supplied.  [Or will only be supplied as a comment
       field, if the argument has a description associated with it.]

       The tag ti_Data fields of the argument array MUST contain the magic
       values REMARG_REMOVE or REMARG_IGNORE to control whether or not this
       argument will actually be removed; any other value is illegal.

@{b}   INPUTS@{ub}
       progArgs - ( struct @{"ProgArgs" Link "libraries/progargs.h/Main" 82} * ) Argument set to modify.
       argTags  - ( struct @{"TagItem" Link "INCLUDE:utility/tagitem.h/Main" 31} * ) Arguments to remove.

@{b}   RESULT@{ub}
       result - ( @{"BOOL" Link "INCLUDE:exec/types.h/Main" 68} ) TRUE if all is okay; FALSE if there was a problem.

@{b}   TAGS@{ub}


@{b}   EXAMPLE@{ub}


@{b}   NOTES@{ub}
       .

@{b}   BUGS@{ub}
       .

@{b}   SEE ALSO@{ub}
       AllocProgArgs(), AddProgArgs()

@EndNode

