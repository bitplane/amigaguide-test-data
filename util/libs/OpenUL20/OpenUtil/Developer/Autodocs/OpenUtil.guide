@node oGetMouseA "OpenUtil.library / UserInterface / oGetMouseA()"

  @{b}NAME@{ub}
        oGetMouseA   -- Get current Mouse position and/or buttons state
        oGetMouse    -- varargs stub for oGetMouseA()

  @{b}SYNOPSIS@{ub}
        oGetMouseA (Tags)
                     A0

        oGetMouse  (FirstTag, ...)

        void oGetMouseA (struct TagItem *)

        void oGetMouse  (Tag, ...)

  @{b}FUNCTION@{ub}
        This function serves information about the current state of the (three)
        Mouse buttons and/or the current Mouse position.

  @{b}INPUTS@{ub}
        Tags
                - oGetMouse_X (ULONG *)

                  If you pass this tag with a pointer to a ULONG variable in
                  ti_Data, you'll receive the current Mouse x position there.

                - oGetMouse_Y (ULONG *)

                  Put a ULONG pointer in ti_Data, and you'll receive the current
                  Mouse y position there.

                - oGetMouse_Screen

                  Pass this Tag with a Screen pointer in ti_Data, and oGetMouse_X
                  and oGetMouse_Y (if passed) will receive the current Mouse
                  position in relation to the passed Screen, instead of absolute
                  coordinates in the visual display. Note that both x and y may
                  be negative if the Mouse is placed outside the Screen bounds.

                - oGetMouse_Window

                  Pass this Tag with a Window pointer in ti_Data, and oGetMouse_X
                  and oGetMouse_Y (if passed) will receive the current Mouse
                  position in relation to the passed Window, instead of absolute
                  coordinates in the visual display. Note that both x and y may
                  be negative if the Mouse is placed outside the Window bounds.

                  oGetMouse_Screen & oGetMouse_Window cannot be mixed with one
                  single call (additional Mouse position mode Tags are ignored).

                - oGetMouse_LMB

                  Put a ULONG pointer in ti_Data, which reveives BOOL:
                  TRUE if the left Mouse button is hold down, FALSE if released.

                - oGetMouse_RMB

                  Put a ULONG pointer in ti_Data, which reveives BOOL:
                  TRUE if the right Mouse button is hold down, FALSE if released.

                - oGetMouse_MMB

                  Put a ULONG pointer in ti_Data, which reveives BOOL:
                  TRUE if the middle Mouse button is hold down, FALSE if released.

  @{b}RESULT@{ub}
        void    - All passed Tags receive the requested information in ti_Data,
                  where double Tags are ignored, while oGetMouse_Screen and
                  oGetMouse_Window cannot be mixed because only one Mouse
                  position can be reported each call.

  @{b}EXAMPLE@{ub}

        C:

        ULONG  MouseX;
        ULONG  LeftMouseButton;

        struct Window * MyWindow; // which is already opened

        oGetMouse(oGetMouse_X,     &MouseX,
                  oGetMouse_Window, MyWindow,
                  oGetMouse_LMB,   &LeftMouseButton,
                  TAG_DONE);

        if (LeftMouseButton>
        {
          Printf("Left-Klick at X-pos. %ld",MouseX);
        }

  @{b}NOTES@{ub}
        This function is used for easy single Mouse information requests.
        If you want to track Mouse movements, using an IDCMP_MOUSEMOVE
        Window will be more accurate.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)
@endnode
@node oGetProtection "OpenUtil.library / File Operations / oGetProtection()"

  @{b}NAME@{ub}
        oGetProtection -- Get the protection bit mask of a file/directory.

  @{b}SYNOPSIS@{ub}
        oGetProtection (Name)
                         A0

        ULONG oGetProtection (STRPTR)

  @{b}FUNCTION@{ub}
        The pendant to SetProtection(); this function returns the current
        protection bit mask of a file or directory.

  @{b}INPUTS@{ub}
        Name         - Full AmigaDOS file name.

  @{b}RESULT@{ub}
        ProtBits     - The protection bit mask, or ~0 (equal to -1) on an
                       error. Since the bit mask may be equal to ~0 in the
                       future, you should always check IoErr() after a call
                       which will always return NULL on success.

  @{b}AUTHOR@{ub}
        David 'Strider/tRSi' Wettig (strider@trsi.de)

  @{b}SEE ALSO@{ub}
        @{"oFileSize()" link "oFileSize"}, @{"oGetProtection()" link "oGetProtection"}
@endnode
@node oGetRecord "OpenUtil.library / List Functions / oGetRecord()"

  @{b}NAME@{ub}
        oGetRecord -- Get a List Node of a given ordinal number.

  @{b}SYNOPSIS@{ub}
        oGetRecord (Base, Number)
                     A0     D0

        struct Node * oGetRecord (struct List *, ULONG)

  @{b}FUNCTION@{ub}
        This function returns the List Node found at the given position, starting
        at pos. 0.

  @{b}INPUTS@{ub}
        Base            - An Exec List (may be empty).

        Number          - The ordinal link position number of the needed Node.

  @{b}RESULT@{ub}
        Node            - The Node which is linked at position <Number>, or
                          NULL if the List is empty or contains less than
                          <Number> Nodes.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oGetRecordNumber() " link "oGetRecordNumber"}, @{" oSearchRecordA() " link "oSearchRecordA"}
@endnode
@node oGetRecordNumber "OpenUtil.library / List Functions / oGetRecordNumber()"

  @{b}NAME@{ub}
        oGetRecordNumber -- Get the ordinal number of a Node in an Exec List

  @{b}SYNOPSIS@{ub}
        oGetRecordNumber (Base, Node)
                           A0    A1

        long oGetRecordNumber (struct List *, struct Node *)

  @{b}FUNCTION@{ub}
        This function returns the ordinal Number (link position) of a Node
        linked to the passed List.

  @{b}INPUTS@{ub}
        Base            - An Exec List (may be empty).

        Node            - A List Node of which to get the position number.

  @{b}RESULT@{ub}
        Number          - Position number of the given Node, or -1 if the Node
                          wasn't found in the passed List.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oGetRecord() " link "oGetRecord"}, @{" oSearchRecordA() " link "oSearchRecordA"}
@endnode
@node oIsDoubleClick "OpenUtil.library / User Interface / oIsDoubleClick()"

  @{b}NAME@{ub}
        oIsDoubleClick  -- Check for Gadget double-click

  @{b}SYNOPSIS@{ub}
        oIsDoubleClick (ActualGadget, ActualIndex, LastGadget, LastIndex, LastSeconds, LastMicros)
                             D0            D1          A0          A1         A2           A3

        long oIsDoubleClick (struct Gadget *, ULONG, struct Gadget **, ULONG *, ULONG *, ULONG *)

  @{b}FUNCTION@{ub}
        This function is used to see if a Gadget was double-clicked. Beyond the
        intuition DoubleClick() function, this one checks if it was the same
        Gadget and updates all LastGadget and LastTime imformation.

  @{b}INPUTS@{ub}
        ActualGadget    - The Gadget actually clicked, which is found in the
                          current IntuiMessage->IAddress field.

        ActualIndex     - This is used for a special kind of Gadgets (like
                          ListView Gadgets), where it's not enough to know
                          which gadget was clicked the last time. Here you
                          can pass a numeric value, which is, for example,
                          the ordinal number received with the IntuiMessage
                          (IMsg->Code), used with ListView Gadgets. With
                          things like a Button-kind Gadget, an Index value
                          isn't needed, so just pass -1 here.

        LastGadget      - This is a *pointer* to a variable which is declared
                          as a Gadget pointer. LastGadget is updated by
                          oIsDoubleClick() with every call. See example below.

        LastIndex       - Points to a ULONG variable which is updated by
                          oIsDoubleClick(). It holds the last Index value.

        LastSeconds     - Points to a ULONG variable, filled by oIsDoubleClick()
                          each call in order to remember the last time a
                          Gadget was clicked.

        LastMicros      - Like LastSeconds, this one holds the last micro
                          seconds value.

  @{b}RESULT@{ub}
        BOOL            - TRUE, if it was a double-click.

  @{b}EXAMPLE@{ub}

        (Working on a ListView Gadget, else pass -1 for ActualIndex)

        C:
                struct Gadget * myLastGadget   =  0; /* initial values */
                ULONG           myLastIndex    = -1; /*                */
                ULONG           myLastSeconds  =  0; /*                */
                ULONG           myLastMicros   =  0; /*                */

                Result = IsDoubleClick ( (struct Gadget *) IntuiMessage->IAddress,
                                         IntuiMessage->Code,
                                         &myLastGadget,
                                         &myLastIndex,
                                         &myLastSeconds,
                                         &myLastMicros);

        Asm:
                myLastGadget:     dc.l     0
                myLastIndex:      dc.l    -1
                myLastSeconds:    dc.l     0
                myLastMicros:     dc.l     0

                move.l  IntuiMessage,a0
                move.l  IntuiMessage->im_IAddress(a0),d0 ; ActualGadget
                moveq   #0,d1
                move.w  IntuiMessage->im_Code(a0),d1  ; Actual Index
                lea     myLastGadget,a0               ; pointer to LastGadget
                lea     myLastIndex,a1                ; pointer to LastIndex
                lea     myLastSeconds,a2              ; pointer to LastSeconds
                lea     myLastMicros,a3               ; pointer to LastMicros
                jsr     _LVOoIsDoubleClick(a6)
                move.l  d0,Result

  @{b}NOTES@{ub}
        For correct working, initialize LastGadget, LastSeconds & LastMicros
        to NULL and LastIndex to -1 (see example above). As stated before,
        these four variables are updated by oIsDoubleClick.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)
@endnode
@node oIsNumStr "OpenUtil.library / String Functions / oIsNumStr()"

  @{b}NAME@{ub}
        oIsNumStr -- check if a string contains numeric digits only.

  @{b}SYNOPSIS@{ub}
        oIsNumStr (String)
                     A0

        long oIsNumStr (STRPTR)

  @{b}FUNCTION@{ub}
        Checks if the given string only contains chars from "0" to "9".

  @{b}INPUTS@{ub}
        String - the string to check

  @{b}RESULT@{ub}
        Result  - FALSE if the string contains any non-numeric digits.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oAtol() " link "oAtol"}, @{" oStrTo64() " link "oStrTo64"}
@endnode
@node oITextHeight "OpenUtil.library / User Interface / oITextHeight()"

  @{b}NAME@{ub}
        oITextHeight  -- get the overall pixel height of an IntuiText chain

  @{b}SYNOPSIS@{ub}
        oITextHeight (IText)
                       A0

        ULONG oITextHeight (struct IntuiText *)

  @{b}FUNCTION@{ub}
        This function returns the overall pixel height of an IntuiText chain.

  @{b}INPUTS@{ub}
        IText           - An initialized and ready-to-print IntuiText chain,
                          such as created using @{" oCreateITextChainA() " link "oCreateITextChainA"}.

  @{b}RESULT@{ub}
        Height          - Overall pixel height of the IntuiText.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oITextWidth() " link "oITextWidth"}, @{" oCreateITextChainA() " link "oCreateITextChainA"}
