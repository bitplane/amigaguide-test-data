@node oDeleteStatusBar "OpenUtil.library / User Interface / oDeleteStatusBar()"

  @{b}NAME@{ub}
        oDeleteStatusBar  -- Free a Status Bar created using @{"oCreateStatusBarA()" link "oCreateStatusBarA()"}

  @{b}SYNOPSIS@{ub}
        oDeleteStatusBar (StatusBar, EraseMode)
                             A0          D0

        void oDeleteStatusBar (struct oStatusBar *, long)

  @{b}FUNCTION@{ub}
        This function frees a Status Bar object created using @{"oCreateStatusBarA()" link "oCreateStatusBarA()"}.

  @{b}INPUTS@{ub}
