        MatchString - The match string.

  @{b}RESULT@{ub}
        String      - STRPTR Source as passed if Source begins with
                      MatchString, else NULL.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrBeg() " link "oStrBeg"}, @{" oStrEnd() " link "oStrEnd"}, @{" oStrStr() " link "oStrStr"}
@endnode
@node oStrCat "OpenUtil.library / String Functions / oStrCat()"

