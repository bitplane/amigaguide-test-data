@node oStrComp "OpenUtil.library / String Functions / oStrComp()"

  @{b}NAME@{ub}
        oStrComp      -- Compare two strings, non-case-sensitive

  @{b}SYNOPSIS@{ub}
        oStrComp (Source, Destination)
                    A0         A1

        STRPTR oStrComp (STRPTR, STRPTR)

  @{b}FUNCTION@{ub}
        This function compares two strings, non-case-sensitive.

  @{b}INPUTS@{ub}
        Source        - String 1

        Destination   - String 2

  @{b}RESULT@{ub}
        long          0 if both strings are equal,
                      1 if Source (String 1) is higher,
                     -1 if Source (String 1) is lower.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrCompCase() " link "oStrCompCase"}, @{" oStrNComp() " link "oStrNComp"}
@endnode
@node oStrCompCase "OpenUtil.library / String Functions / oStrCompCase()"

  @{b}NAME@{ub}
        oStrCompCase  -- Compare two strings, case-sensitive

  @{b}SYNOPSIS@{ub}
        oStrCompCase (Source, Destination)
                        A0         A1

        STRPTR oStrCompCase (STRPTR, STRPTR)

  @{b}FUNCTION@{ub}
        This function compares two strings, case-sensitive.

  @{b}INPUTS@{ub}
        Source        - String 1

        Destination   - String 2

  @{b}RESULT@{ub}
        long          0 if both strings are equal,
                      1 if Source (String 1) is higher,
                     -1 if Source (String 1) is lower.

  @{b}SEE ALSO@{ub}
        @{" oStrComp() " link "oStrComp"}, @{" oStrNComp() " link "oStrNComp"}

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)
@endnode
@node oStrCopy "OpenUtil.library / String Functions / oStrCopy()"

  @{b}NAME@{ub}
        oStrCopy      -- Duplicate a string

  @{b}SYNOPSIS@{ub}
        oStrCopy (Source, Destination)
                    A0         A1

        STRPTR oStrCopy (STRPTR, STRPTR)

  @{b}FUNCTION@{ub}
        This function copies a string to a given destination address. Note that
        ANSI-C strcpy() is slightly faster if compiled inline, and that the args
        are swapped.

  @{b}INPUTS@{ub}
        Source        - The string to duplicate

        Destination   - Destination address

  @{b}RESULT@{ub}
        Destination   - The Destination address, containing the copy.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrCat() " link "oStrCat"}
@endnode
@node oStrCut "OpenUtil.library / String Functions / oStrCut()"

  @{b}NAME@{ub}
        oStrCut -- cut a string at a search string position

  @{b}SYNOPSIS@{ub}
        oStrCut (String, MatchString, MaxRange)
                   A0        A1          D0

        STRPTR oStrCut (STRPTR, STRPTR, ULONG)

  @{b}FUNCTION@{ub}
        Cut a string at the first match with another (part-) match string.
        The part string is searched in the source string; if a match is found,
        the source string gets cut at that position. If nothing was found,
        nothing gets changed. This function is not case-sensitive.

  @{b}INPUTS@{ub}
        String          - The string to truncate

        MatchString     - The string part to search for.

        MaxRange        - the maximum search offset in the source String.

  @{b}RESULT@{ub}
        Result points to the (new) end position of the passed string, no
        matter if the MatchString was found or not. Result always points to
        the trailing NULL byte of the string.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrCutCase() " link "oStrCutCase"}, @{" oChrCut() " link "oChrCut"}
@endnode
@node oStrCutCase "OpenUtil.library / String Functions / oStrCutCase()"

  @{b}NAME@{ub}
        oStrCutCase -- cut a string at the first match of another match string

  @{b}SYNOPSIS@{ub}
        oStrCutCase (String, MatchString, MaxRange)
                       A0         A1         D0

        STRPTR oStrCutCase (STRPTR, STRPTR, ULONG)

  @{b}FUNCTION@{ub}
        Cut a string at the first match with another (part-) match string.
        The Cut string is searched in the source string; if a match is found,
        the source string gets cut at that position. If nothing was found,
        nothing gets changed. This function is case-sensitive.

  @{b}INPUTS@{ub}
        String          - The string to truncate.

        MatchString     - The string part to search for.

        MaxRange        - The maximum search offset in the source String.

  @{b}RESULT@{ub}
        Result points to the (new) end position of the passed string, no
        matter if the MatchString was found or not. Result always points to
        the trailing NULL byte of the string.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrCut() " link "oStrCut"}, @{" oChrCut() " link "oChrCut"}
@endnode
@node oStrEnd "OpenUtil.library / String Functions / oStrEnd()"

  @{b}NAME@{ub}
        oStrEnd -- compare a string with the end of another string

  @{b}SYNOPSIS@{ub}
        oStrEnd (Source, MatchString)
                   A0         A1

        STRPTR oStrEnd (STRPTR, STRPTR)

  @{b}FUNCTION@{ub}
        Check if the Source string ends with the MatchString. This function
        is not case-sensitive; @{"oStrEndCase()" link "oStrEndCase"} is the case-sensitive version.

  @{b}INPUTS@{ub}
        Source      - The source string which to check for MatchString at the end

        MatchString - The part string which to match within the Source string

  @{b}RESULT@{ub}
        String      - STRPTR to the Source string at the position where
                      MatchString was found, else NULL.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrEndCase() " link "oStrEndCase"}, @{" oStrBeg() " link "oStrBeg"}, @{" oStrStr() " link "oStrStr"}
@endnode
@node oStrEndCase "OpenUtil.library / String Functions / oStrEndCase()"

  @{b}NAME@{ub}
        oStrEndCase -- compare a string with the end of another string

  @{b}SYNOPSIS@{ub}
        oStrEndCase (Source, MatchString)
                       A0         A1

        STRPTR oStrEndCase (STRPTR, STRPTR)

  @{b}FUNCTION@{ub}
        Check if the Source string ends with the MatchString. This function
        is case-sensitive; @{"oStrEnd()" link "oStrEnd"} is the non-case-sensitive version.

  @{b}INPUTS@{ub}
        Source      - The source string which to check for MatchString at the end

        MatchString - The part string which to find in the Source string

  @{b}RESULT@{ub}
        String      - STRPTR to the Source string at the position where
                      MatchString was found, else NULL.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrEnd() " link "oStrEnd"}, @{" oStrBeg() " link "oStrBeg"}, @{" oStrStr() " link "oStrStr"}
@endnode
@node oStrLeft "OpenUtil.library / String Functions / oStrLeft()"

  @{b}NAME@{ub}
        oStrLeft     -- extract the left part of a string

  @{b}SYNOPSIS@{ub}
        oStrLeft (Source, Destination, MaxLen)
                    A0        A1         D0

        STRPTR oStrLeft (STRPTR, STRPTR, ULONG)

  @{b}FUNCTION@{ub}
        This function copies the left part of a string to a destination buffer.

  @{b}INPUTS@{ub}
        Source          - Source string where to extract from.

        Destination     - Destination (string) buffer where to copy to

        MaxLen          - Maximum number of chars to copy. Copying ends when
                          MaxLen is reached or the Source string ends.

  @{b}RESULT@{ub}
        Destination     - (STRPTR). The new Destination string.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrRight() " link "oStrRight"}, @{" oStrMid() " link "oStrMid"}
@endnode
@node oStrLen "OpenUtil.library / String Functions / oStrLen()"

  @{b}NAME@{ub}
        oStrLen      -- Return the length of a string

  @{b}SYNOPSIS@{ub}
        oStrLen (String)
                   A0

        ULONG oStrLen (STRPTR)

  @{b}FUNCTION@{ub}
        This function returns the length of a given string. Note that ANSI-C
        strlen() is slightly faster when compiled as inline function, of course.

  @{b}INPUTS@{ub}
        String        - The string to count

  @{b}RESULT@{ub}
        Length        - The string length in bytes.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)
@endnode
@node oStrMid "OpenUtil.library / String Functions / oStrMid()"

  @{b}NAME@{ub}
        oStrMid -- extract a sub string from a string

  @{b}SYNOPSIS@{ub}
        oStrMid (Source, Destination, StartPos, MaxChars)
                   A0         A1         D0        D1

        STRPTR oStrMid (STRPTR, STRPTR, ULONG, ULONG)

  @{b}FUNCTION@{ub}
        oStrMid() copies a part of the passed source string to the Destination.
        A maximum of MaxChars gets copied, or less if a null-byte was found.
        The destination string is always null-terminated.

        To extract a string's right part, set MaxChars to -1; the left part
        can be extracted by setting StartPos to NULL.

  @{b}INPUTS@{ub}
        Source        - The source string.

        Destination   - The destination string.

        StartPos      - Start position (Source offset) for copying.

        MaxChars      - Maximum number of chars to copy.

  @{b}RESULT@{ub}
        NewString     - The passed Destination string. If StartPos points beyond
                        the Source string, NewString will be valid, but empty.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrLeft() " link "oStrLeft"}, @{" oStrRight() " link "oStrRight"}
@endnode
@node oStrNComp "OpenUtil.library / String Functions / oStrNComp()"

  @{b}NAME@{ub}
        oStrNComp     -- Compare two strings, non-case-sensitive

  @{b}SYNOPSIS@{ub}
        oStrNComp (Source, Destination, MaxLen)
                     A0        A1         D0

        STRPTR oStrNComp (STRPTR, STRPTR, ULONG)

  @{b}FUNCTION@{ub}
        This function compares two strings, non-case-sensitive.

  @{b}INPUTS@{ub}
        Source        - a string

        Destination   - another string

        MaxLen        - Maximum compare length. If the first <MaxLen> chars
                        are equal, oStrNComp() returns NULL (equality).

  @{b}RESULT@{ub}
        long          0 if both strings are equal,
                      1 if Source (String 1) is higher,
                     -1 if Source (String 1) is lower.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrNCompCase() " link "oStrNCompCase"}, @{" oStrComp() " link "oStrComp"}
@endnode
@node oStrNCompCase "OpenUtil.library / String Functions / oStrNCompCase()"

  @{b}NAME@{ub}
        oStrNCompCase  -- Compare two strings, case-sensitive

  @{b}SYNOPSIS@{ub}
        oStrNCompCase (Source, Destination, MaxLen)
                         A0        A1         D0

        STRPTR oStrNCompCase (STRPTR, STRPTR, ULONG)

  @{b}FUNCTION@{ub}
        This function compares two strings, case-sensitive.

  @{b}INPUTS@{ub}
        Source        - a string 

        Destination   - another string

        MaxLen        - Maximum compare length. If the first <MaxLen> chars
                        are equal, oStrNCompCase() returns NULL (equality).

  @{b}RESULT@{ub}
        long          0 if both strings are equal,
                      1 if Source (String 1) is higher,
                     -1 if Source (String 1) is lower.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrNComp() " link "oStrNComp"}, @{" oStrComp() " link "oStrComp"}
@endnode
@node oStrRight "OpenUtil.library / String Functions / oStrRight()"

  @{b}NAME@{ub}
        oStrRight     -- extract the right part of a string

  @{b}SYNOPSIS@{ub}
        oStrRight (Source, Destination, MaxLen)
                     A0        A1         D0

        STRPTR oStrRight (STRPTR, STRPTR, ULONG)

  @{b}FUNCTION@{ub}
        This function copies the right part of a string to a destination buffer.

  @{b}INPUTS@{ub}
        Source          - Source string where to extract from.

        Destination     - Destination (string) buffer where to copy to

        MaxLen          - Maximum number of chars to copy. Copying ends when
                          MaxLen is reached or the Source string reaches it's
                          left end (as passed).

  @{b}RESULT@{ub}
        Destination     - (STRPTR). The new Destination string.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrLeft() " link "oStrLeft"}, @{" oStrMid() " link "oStrMid"}
@endnode
@node oStrStr "OpenUtil.library / String Functions / oStrStr()"

  @{b}NAME@{ub}
        oStrStr -- Find a string in another string


  @{b}SYNOPSIS@{ub}
        oStrStr (Source, MatchString)
                   A0         A1

        STRPTR oStrStr (STRPTR, STRPTR)

  @{b}FUNCTION@{ub}
        Find MatchString in the Source string. If a match is found, Result points
        to the first match inside the Source string. If no match was found, Result
        will be NULL. This function is not case-sensitive.

  @{b}INPUTS@{ub}
        Source      - The source string.

        Matchstring - The string which to search for.

  @{b}RESULT@{ub}
        NewString   - A pointer to the match position in the search string
                      or NULL if nothing was found.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrStrCase() " link "oStrStrCase"}, @{" oStrLeft() " link "oStrLeft"}, @{" oStrRight() " link "oStrRight"}, @{" oStrChr() " link "oStrChr"},
@endnode
@node oStrStrCase "OpenUtil.library / String Functions / oStrStrCase()"

  @{b}NAME@{ub}
        oStrStrCase -- Find a string in another string


  @{b}SYNOPSIS@{ub}
        oStrStrCase (Source, MatchString)
                       A0         A1

        STRPTR oStrStrCase (STRPTR, STRPTR)

  @{b}FUNCTION@{ub}
        Find a string in a string. If a match is found, Result points to the
        first match inside the string. If no match was found, Result will be
        NULL. This function is case-sensitive.

  @{b}INPUTS@{ub}
        Source      - The source string.

        Matchstring - The string which to search for.

  @{b}RESULT@{ub}
        NewString   - A pointer to the string position of the search string
                      or NULL if nothing was found.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrStr() " link "oStrStr"}, @{" oStrLeft() " link "oStrLeft"}, @{" oStrRight() " link "oStrRight"}, @{" oStrChr() " link "oStrChr"},
@endnode
@node oStrTo64 "OpenUtil.library / String Functions / oStrTo64()"

  @{b}NAME@{ub}
        oStrTo64 -- Convert a decimal string to a 64-Bit number

  @{b}SYNOPSIS@{ub}
        oStrTo64 (String, DestHi, DestLo)
                    A0      A1      A2

        long oStrTo64 (STRPTR, ULONG *, ULONG *)

  @{b}FUNCTION@{ub}
        Converts a decimal string to a 64-Bit (QUAD-WORD) value.

        Like dos.library/StrToLong(), leading TABs and Spaces get
        skipped; then, all numeric chars get converted until the
        string ends or any non-numeric char is detected.

  @{b}INPUTS@{ub}
        String  - The string to convert.

        DestHi  - A pointer to a ULONG which receives the upper 32 bits
                  of the destination value

        DestLo  - A pointer to a ULONG which receives the lower 32 bits
                  of the destination value.

  @{b}RESULT@{ub}
        long    - Number of decimal characters converted. If NULL, nothing
                  was converted, and DestHi & DestLo are set to NULL. Else,
                  DestHi & DestLo contain the converted value. A Result of
                  NULL indicates that no numeric chars were found or the
                  value is still too large for 64 bits.
  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oNum64ToStr() " link "oNum64ToStr"}
@endnode
@node oStrToLower "OpenUtil.library / String Functions / oStrToLower()"

  @{b}NAME@{ub}
        oStrToLower -- lower-case a string


  @{b}SYNOPSIS@{ub}
        oStrToLower (String, MaxLen)
                       A0      D0

        STRPTR oStrToLower (STRPTR, ULONG)

  @{b}FUNCTION@{ub}
        Lower-case a string. Result is the same string as passed.

  @{b}INPUTS@{ub}
        String  - The string to convert.

        MaxLen  - Maximum number of chars to convert. Conversion ends when
                  MaxLen is reached or the Source string ends.

  @{b}RESULT@{ub}
        String  - A pointer to the converted string (same as input).

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrToUpper() " link "oStrToUpper"}
@endnode
@node oStrToUpper "OpenUtil.library / String Functions / oStrToUpper()"

  @{b}NAME@{ub}
        oStrToUpper -- upper-case a string


  @{b}SYNOPSIS@{ub}
        oStrToUpper (String, MaxLen)
                       A0      D0

        STRPTR oStrToUpper (STRPTR, ULONG)

  @{b}FUNCTION@{ub}
        Upper-case a string. Result is the same string as passed.

  @{b}INPUTS@{ub}
        String  - The string to convert.

        MaxLen  - Maximum number of chars to convert. Conversion ends when
                  MaxLen is reached or the Source string ends.

  @{b}RESULT@{ub}
        String  - A pointer to the converted string (same as input).

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oStrToLower() " link "oStrToLower"}
@endnode
@node oSubU64 "OpenUtil.library / Math Functions / oSubU64()"

  @{b}NAME@{ub}
        oSubU64       -- perform a QuadWord (64-bit) subtraction

  @{b}SYNOPSIS@{ub}
        oSubU64 (SrcHi, SrcLo, DestHi, DestLo)
                   D0     D1     A0      A1

        long oSubU64 (ULONG, ULONG, ULONG *, ULONG *)

  @{b}FUNCTION@{ub}
        Subtracts a 64-bit value (SrcHi/SrcLo) from another (DestHi/DestLo).

  @{b}INPUTS@{ub}
        SrcHi           - The upper 32 bits of the 64-bit value to subtract.

        SrcLo           - The lower 32 bits of the 64-bit value to subtract.

        DestHi          - A pointer to the upper 32 bits (ULONG) of the second
                          (destination) value where to subtract the first number
                          from.

        DestLo          - A pointer to the lower 32 bits of the destination
                          value.

  @{b}RESULT@{ub}
        Underflow       - BOOL. TRUE signals an underflow, which happens when
                          Src is greater than Dest.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{"oAddU64()" link "oAddU64"}, @{" oMulU64L() " link "oMulU64L"}, @{" oDivU64L() " link "oDivU64L"}
@endnode
@node oSuggestWindowPosA "OpenUtil.library / User Interface / oSuggestWindowPosA()"

  @{b}NAME@{ub}
        oSuggestWindowPosA  -- Suggest x/y position for a Window
        oSuggestWindowPos   -- varargs stub for oSuggestWindowPosA()

  @{b}SYNOPSIS@{ub}
        oSuggestWindowPosA (Screen, WindowLeft, WindowTop, Width, Height, Tags)
                              A0        A1          A2       D0     D1     A3

        oSuggestWindowPos  (Screen, WindowLeft, WindowTop, Width, Height, FirstTag, ...)

        long oSuggestWindowPosA (struct Screen *, ULONG *, ULONG *, ULONG, ULONG, struct TagItem *)

        long oSuggestWindowPos  (struct Screen *, ULONG *, ULONG *, ULONG, ULONG, Tag, ...)

  @{b}FUNCTION@{ub}
        This function is mostly used with temporary or application-independent
        Windows, such as Requesters. oSuggestWindowPosA() suggests an x/y position
        for opening such Windows, in relation to a passed Screen.

  @{b}INPUTS@{ub}
        Screen          - The Screen where to open the Window. Must be a valid
                          Screen pointer.

        WindowLeft      - A pointer to a ULONG which receives the x-position.

        WindowTop       - A pointer to a ULONG which receives the y-position.

                          Let WindowLeft & WindowTop point to the ti_Data fields
                          of your WA_Left & WA_Top Tags and you're set.

        Width           - The overall width of the Window.

        Height          - The overall height of the Window.

        Tags            - Currently, there's only one Tag defined, but using
                          Tags here will keep future flexibility.

                        oSWP_MouseGadget

                          (struct Gadget *). This Tag awaits an already created
                          Gadget to use with the Window. This Gadget should be
                          your "default" user interaction Gadget. The Window
                          will then be placed with the passed Gadget appearing
                          under the Mouse Pointer, or as close as possible
                          without placing the Window outside the passed Screen.
                          If this Tag isn't used, the Window gets centered on
                          the passed Screen.

  @{b}RESULT@{ub}
        void            - WindowLeft and WindowTop get set with the suggested
                          Window position.

  @{b}EXAMPLE@{ub}

        C:

        // we have already opened a Screen (or locked the Default Public Screen),
        // created all Gadgets etc. and now we're going to open the Window.

        struct Screen * myScreen;
        struct Gadget * myDefaultGadget;
        struct Window * myWindow;

        // The Window position is stored directly in the Window's TagList:

        struct TagItem myWindowTags [] =
        {
          {WA_Left,     0},
          {WA_Top,      0},
          {WA_Width,  400},
          {WA_Height, 200},
          {TAG_DONE}
        };

        oSuggestWindowPos(myScreen,
                          &myWindowTags[0].ti_Data,   /* points to WA_Left.ti_Data */
                          &myWindowTags[1].ti_Data);  /* points to WA_Top.ti_Data */
                          myWindowTags[2].ti_Data,    /* Window width  */
                          myWindowTags[3].ti_Data,    /* Window height */
                          oSWP_MouseGadget, myDefaultGadget,
                          TAG_DONE);

        oOpenWindowTagList(0,myWindowTags);

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)
@endnode
@node oSwap16 "OpenUtil.library / Misc. Functions / oSwap16()"

  @{b}NAME@{ub}
        oSwap16 -- Swap the upper 16 bits with the lower 16 bits of a 32-bit value

  @{b}SYNOPSIS@{ub}
        oSwap16 (Value)
                   D0

        ULONG oSwap16 (ULONG)

  @{b}FUNCTION@{ub}
        This very simple thing does nothing more than swapping the upper word
        with the lower word of a 32-bit variable.

        May be useful when working with WORD pairs and if Assembler isn't
        available or wanted.

  @{b}INPUTS@{ub}
        Value           - Anything which has 32-bit size

  @{b}RESULT@{ub}
        NewValue        - The passed Value, swapped.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)
@endnode
@node oTextHeight "OpenUtil.library / String Functions / oTextHeight()"

  @{b}NAME@{ub}
        oTextHeight -- get the number of text lines in an ASCII string

  @{b}SYNOPSIS@{ub}
        oTextHeight (String)
                       A0

        ULONG oTextHeight (STRPTR)

  @{b}FUNCTION@{ub}
        This function counts the number of text lines in a given string.

  @{b}INPUTS@{ub}
        String          - the string where to count the text lines

  @{b}RESULT@{ub}
        NumLines        ULONG. Number of text lines in the passed String.
                        Note that the last char in the String gets skipped if
                        it's a LineFeed character, so the blank line at the
                        bottom doesn't count.
                        
  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oTextWidth() " link "oTextWidth"}
@endnode
@node oTextWidth "OpenUtil.library / String Functions / oTextWidth()"

  @{b}NAME@{ub}
        oTextWidth -- get the length of the longest text line in an ASCII string

  @{b}SYNOPSIS@{ub}
        oTextWidth (String)
                      A0

        ULONG oTextWidth (STRPTR)

  @{b}FUNCTION@{ub}
        This function counts the number of chars in the longest text line
        of a given string, which is the overall text width for that string.

  @{b}INPUTS@{ub}
        String          - the string where to get the width of

  @{b}RESULT@{ub}
        NumChars        ULONG. All but Line Feed characters count.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oTextHeight() " link "oTextHeight"}
@endnode
@node oUnlockWindow "OpenUtil.library / User Interface / oUnlockWindow()"

  @{b}NAME@{ub}
        oUnlockWindow      -- Re-enable user input in a locked Window

  @{b}SYNOPSIS@{ub}
        oUnlockWindow (WindowLock)
                           A0

        void oUnlockWindow (struct oWindowLock *)

  @{b}FUNCTION@{ub}
        This function unlocks a Window which was locked using @{"oLockWindow()" link "oLockWindow"};
        the oWindowLock gets freed back to memory.

  @{b}INPUTS@{ub}
        WindowLock      - An oWindowLock structure, as returned by @{"oLockWindow()" link "oLockWindow"}.

  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
