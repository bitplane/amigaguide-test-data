@node oDirEntryType "OpenUtil.library / File Operations / oDirEntryType()"

  @{b}NAME@{ub}
        oDirEntryType -- Get the fib_DirEntryType of a given file/dir name (V2)

  @{b}SYNOPSIS@{ub}
        oDirEntryType( Name )
                        A0

        long oDirEntryType (STRPTR)

  @{b}FUNCTION@{ub}
        oDirEntryType() can be used to get the 'fib_DirEntryType' element
        of the FileInfoBlock according to the passed file name.

        See Include:dos/dos.h for struct FileInfoBlock.
        See Include:dos/dosextens.h for fib_DirEntryType type defines
        which are beginning with 'ST_'.

  @{b}INPUTS@{ub}
        Name          - standard AmigaDOS file/path name.

  @{b}RESULT@{ub}
