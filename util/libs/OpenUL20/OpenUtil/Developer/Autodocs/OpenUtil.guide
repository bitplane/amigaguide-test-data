  @{b}AUTHOR@{ub}
        Oliver "Bloodrock/tRSi" Lange (bloodrock@bloody.in-berlin.de)

  @{b}SEE ALSO@{ub}
        @{" oCreateList() " link "oCreateList"}, @{" oClearList() " link "oClearList"}, @{" oCutList() " link "oCutList"}, @{" oRemExecHeader() " link "oRemExecHeader"}
