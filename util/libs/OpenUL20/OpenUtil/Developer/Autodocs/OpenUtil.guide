  @{b}NAME@{ub}
        oDeleteRndSeed -- Free an oRndSeed structure allocated with @{"oCreateRndSeed()" link "oCreateRndSeed"}

  @{b}SYNOPSIS@{ub}
        oDeleteRndSeed (RndSeed)
                           D0

        void oDeleteRndSeed (struct oRndSeed *)

  @{b}FUNCTION@{ub}
        This function frees an oRndSeed structure (used for drawing random numbers).

