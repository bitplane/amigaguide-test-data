                @{" Storia " link Storia }

                @{" Installazione di Tottogol2 " link Installazione }
                @{" Impostazione del sistema " link WI_label_0 }
                @{" Riduzioni " link Riduzioni}
                @{" Algoritmi " link Algoritmi }
                @{" Opzioni " link WI_label_3 }
                @{" Colonne elaborate " link WI_label_6 }
