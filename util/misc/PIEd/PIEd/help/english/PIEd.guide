@NODE PI "Product-Info fields"
@{LINDENT 3}
The following are the fields defined by the Product-Info Specification
v6 as designed by Fred Fish and Udo Schuermann (with some extra fields
used by pitool!).

@{" address      " link .address     } @{" aminet-dir   " link .aminet-dir  } @{" author       " link .author      } @{" construction " link .construction}
@{" comment      " link .comment     } @{" contents     " link .contents    } @{" date         " link .date        } @{" described-by " link .described-by}
@{" description  " link .description } @{" distribution " link .distribution} @{" docs         " link .docs        } @{" email        " link .email       }
@{" exectype     " link .exectype    } @{" fax          " link .fax         } @{" fullname     " link .fullname    } @{" installsize  " link .installsize }
@{" keywords     " link .keywords    } @{" locale       " link .locale      } @{" name         " link .name        } @{" phone        " link .phone       }
@{" price        " link .price       } @{" reference    " link .reference   } @{" requirements " link .requirements} @{" restrictions " link .restrictions}
@{" run          " link .run         } @{" short        " link .short       } @{" source       " link .source      } @{" stored-in    " link .stored-in   }
@{" submittal    " link .submittal   } @{" tested       " link .tested      } @{" type         " link .type        } @{" version      " link .version     }

Now three I have added:

@{" beschreibung " link .beschreibung} @{" release      " link .release     } @{" uploader     " link .uploader}

@ENDNODE

@NODE .address "Product-Info field: .address"
@{LINDENT 3}
@{fg shine}@{b}@{u}.address:@{uu}@{ub}@{fg text}
      @{fg fill}<<<OPTIONAL>>>@{fg text}
      @{b}PURPOSE:@{ub}      Describe a full postal address of the author, to
                    be used if it becomes necessary or desirable to
                    contact the author.  Do not specify the author's
                    name, as this is already in the @{"author" link .author} field.
      @{b}FORMAT:@{ub}       Multiple lines; formatting symbols n are not
                    required, as physical line breaks are equivalent.
      @{b}NOTES:@{ub}        SEE THE @{"author" link .author} FIELD FOR IMPORTANT INFORMATION
@ENDNODE

