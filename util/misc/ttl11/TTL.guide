@database "TTL.guide"

@node Main "TTL V1.0 Documentation"

	                           TTL v1.1

	           a small TTL circuit information utility

	                        @{" Description  " link Description }
	                        @{" Requirements " link Requirements }
	                        @{" Installation " link Installation }
	                        @{" Usage        " link Usage }
	                        @{" Bugs         " link Bugs }
