@node "MAIN" "MAJORDOME PREFERENCES"

        @{b}PREFERENCES@{ub}


            Cet éditeur permet de configurer et d'apporter vos propres modifications
            a Majordome. 

            Procédure de manipulation :

            1. A partir de la fenętre Outils:
                    Appuyez sur la touche F6 de votre clavier ou cliquez sur l'icône 
                    représentant cette fonction. 

            2. A partir du Menu:
                    Activez le menu "Projet/Préférences/Edite"

            3. A partir du WorkBench:
                    Double cliquez sur l'icône "Majordome_Prefs"

            L'éditeur et divisé et 4 parties (Onglets):


                 @{" Onglet Majordome " link "tabs_majordome" 0} : Pour regler les preferences de Majordome

                 @{" Onglet Detecteur " link "tabs_detecteur" 0} : Pour definir le type de detecteur connecter a Majordome

                 @{" Onglet Serie     " link "tabs_serie" 0} : Pour parametrer le dispositif serie

                 @{" Onglet Emulation " link "tabs_emulation" 0} : Pour parametrer l'émulation
      

@endnode

@node "tabs_majordome" "Onglet Majordome"

        @{b}ONGLET MAJORDOME@{ub}


            @{" Fenętre Prise active " link "prise_actif" 0} : Pour activer ou pas la Fenętre Prise au démarrage
            @{" Séquenceur actif     " link "seq_actif" 0} : Pour activer ou pas le Séquenceur au démarrage
            @{" Chronogramme actif   " link "chrono_actif" 0} : Pour activer ou pas le Chronogramme au démarrage
            @{" Journal d'activité   " link "log_actif" 0} : Pour activer ou pas le journal d'activité 

            @{" Iconification        " link "iconnification" 0} : Pour choisir le type d'iconnification 

            @{" Démarrage            " link "demarage" 0} : Pour sélectionner le fichier de démarrage
            @{" Images               " link "images" 0} : Pour choisir le look de Majordome
            @{" Player               " link "player" 0} : Pour choisir le player d'échantillon

            @{" Ecran                " link "ecran" 0} : Pour choisir comment s'ouvre l'écran de Majordome
            @{" Type d'écran         " link "type_ecran" 0} : Pour choisir l'écran de Majordome

@endnode

@node "tabs_detecteur" "Onglet Detecteur"

        @{b}ONGLET DETECTEUR@{ub}


            @{" Detecteur N°1        " link "detector1" 0} : Pour definir le type de detecteur
            @{" Detecteur N°2        " link "detector2" 0} : Pour definir le type de detecteur

@endnode

@node "tabs_serie" "Onglet Serie"

        @{b}ONGLET SERIE@{ub}


            @{" Dispositif           " link "device" 0} : Pour selectionner le dispositif serie
            @{" Unité                " link "unite" 0} : Pour choisir le numéro d'unité du dispositif serie
            @{" Vitesse en Baud      " link "vit_baud" 0} : Pour choisir la vitesse de transfert du dispositif serie

            @{" Bits/Car             " link "bits_char" 0} : Pour definir le nombre de bits de caractčres
            @{" Bits/stop            " link "bits_stop" 0} : pour definir le nombre de bits de stop
            @{" Parité               " link "parite" 0} : Pour definir le type de parité

            @{" Appareil             " link "appareil" 0} : pour choisir le type d'appareil (Modem/Minitel)

            @{" Initialisation       " link "modem_init" 0} : Pour entrer la chaine d'initialisation du Modem
            @{" Numérotation         " link "modem_numero" 0} : Pour entrer la chaine de numérotation du Modem
            @{" Deconnection         " link "modem_deconnection" 0} : Pour entrer la chaine de deconnection du Modem

@endnode

@node "tabs_emulation" "Onglet Emulation"

        @{b}ONGLET EMULATION@{ub}


            @{" Emulation            " link "emulation" 0} : Pour activer ou non l'émulaton ( commande ŕ distance)
            @{" Type d'emulation     " link "type_emulation" 0} : pour choisir le type d'emulation

            @{" Mot de passe         " link "modem_pass" 0} : Pour choisir le mot de passe du Minitel®/Modem
            @{" Message d'accueil    " link "mes_acceuil" 0} : Pour entrer la chaine d'accueil
            @{" Nbre de sonnerie     " link "nbre_sonnerie" 0} : Pour choisir le nombre de sonnerie avant le décrochage

@endnode

