@{" Clipb.Überw. (rA C) " link manage_clipboard_menu  } @{" Löschen        (rA L) " link manage_delete_menu      } @{" Lernliste Löschen        " link manage_del_lernlst_menu  } @{" Bildschirm  (rA B) " link manage_pscr_menu    }
