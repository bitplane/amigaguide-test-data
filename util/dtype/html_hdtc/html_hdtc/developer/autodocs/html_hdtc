@node "--datasheet--" "html.datatype/--datasheet--"

    @{b}NAME@{ub}
        html.datatype -- hypertext datatype for HTML documents

    @{b}SUPERCLASS@{ub}
        hypertext.datatype

    @{b}DESCRIPTION@{ub}
        This datatype is used to handle HTML documents. It uses all features
        the hypertext.datatype offers. But NOTE in the unregistered version of
        HTDS you can only use five HTML documents at one time.

    @{b}METHODS@{ub}
        @{"OM_NEW" link "OM_NEW"} -- create a html @{"Object" link "AG:SysInc/intuition/classusr.h/main" 19}.

        @{"OM_DISPOSE" link "OM_DISPOSE"} -- dispose the html @{"Object" link "AG:SysInc/intuition/classusr.h/main" 19}.

        @{"OM_SET" link "OM_SET"} -- passes the method to the superclass and performs a refresh
            if needed.

        @{"OM_UPDATE" link "OM_UPDATE"} -- passes the method to the superclass and performs a refresh
            if needed.

        @{"OM_NOTIFY" link "OM_NOTIFY"} -- snoops the HTDTA_ShowLink attribute to convert HTML path
            definitions to Amiga paths.

        @{"GM_LAYOUT" link "GM_LAYOUT"} -- passes the method to the superclass and performs a
            asynchron layout request if needed.

        @{"DTM_GOTO" link "DTM_GOTO"} -- converts HTML path definitions to Amiga path definitions and
            calls then the superclass for this method.

        @{"DTM_ASYNCLAYOUT" link "DTM_ASYNCLAYOUT"} -- do the asynchron layout method.

        @{"DTM_PROCLAYOUT" link "DTM_PROCLAYOUT"} -- layout method in a process context.

    @{b}ATTRIBUTES@{ub}
        None.

    @{b}NOTE@{ub}
        See html_hdtc.hguide for supported HTML tags and HTML tag attributes.

    @{b}SEE ALSO@{ub}
        hypertext.datatype, HTDS.hguide, html_hdtc.hguide


@endnode
@node "DTM_ASYNCLAYOUT" "html.datatype/DTM_ASYNCLAYOUT"

    @{b}NAME@{ub}
        DTM_ASYNCLAYOUT -- asynchronously layout the object

    @{b}FUNCTION@{ub}
        This method performs now really the layout of the object.

    @{b}INPUTS@{ub}
        None.

    @{b}RESULT@{ub}
        Total number of vertical units.

    @{b}SEE ALSO@{ub}
        @{"DTM_PROCLAYOUT" link "DTM_PROCLAYOUT"}, @{"GM_LAYOUT" link "GM_LAYOUT"}, @{"hypertext.datatype/GM_LAYOUT" link "GM_LAYOUT"},
        hypertext.datatype/HTDTM_LAYOUT


@endnode
@node "DTM_GOTO" "html.datatype/DTM_GOTO"

    @{b}NAME@{ub}
        DTM_GOTO -- load and display an other object

    @{b}FUNCTION@{ub}
        This method only converts HTML/Unix style file pathes to AmigaDOS
        style pathes. It converts the URL to be loaded into an AmigaDOS
        path and then calls the superclass with the converted path for
        this method.

    @{b}INPUTS@{ub}
        struct @{b}dtGoto@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *dtg_GInfo;
            @{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} dtg_NodeName;
            struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *dtg_AttrList;
        };

        dtg_NodeName -- name of the node to go to. This also can be a complete
            filename.
        dtg_AttrList -- list of attributes, which specifies the object to go to.

    @{b}RESULTS@{ub}
        None defined.

    @{b}SEE ALSO@{ub}
        hypertext.datatype/DTM_GOTO


@endnode
@node "DTM_PROCLAYOUT" "html.datatype/DTM_PROCLAYOUT"

    @{b}NAME@{ub}
        DTM_PROCLAYOUT -- performs a layout on a process context

    @{b}FUNCTION@{ub}
        This method performs a layout on a process context. Thus this method
        must only be invoked from a process! It first calls the superclass
        DTM_PROCLAYOUT method and then falls through the @{"DTM_ASYNCLAYOUT" link "DTM_ASYNCLAYOUT"}
        method.

    @{b}INPUTS@{ub}
        None.

    @{b}RESULT@{ub}
        None.

    @{b}EXAMPLE@{ub}
        ...
        case DTM_PROCLAYOUT:
           /* Tell everyone that we are busy doing things */
           NotifyAttrs(obj, ((struct @{"gpLayout" link "AG:SysInc/intuition/gadgetclass.h/main" 320} *) msg)->gpl_GInfo, @{"NULL" link "AG:SysInc/exec/types.h/main" 79},
                       @{"GA_ID" link "AG:SysInc/intuition/gadgetclass.h/main" 47},       ((struct @{"Gadget" link "AG:SysInc/intuition/intuition.h/main" 215} *) obj)->GadgetID,
                       @{"DTA_Busy" link "AG:SysInc/datatypes/datatypesclass.h/main" 101},    @{"TRUE" link "AG:SysInc/exec/types.h/main" 73},
                       @{"TAG_DONE" link "AG:SysInc/utility/tagitem.h/main" 39});

           /* Let the super-class partake and then fall through to our layout
              method */
           @{"DoSuperMethodA" link "amiga_lib/DoSuperMethodA()"} (cl, obj, msg);
        case @{"DTM_ASYNCLAYOUT" link "DTM_ASYNCLAYOUT"}:
           /* perform the layout now! */
           break;
        ...

    @{b}SEE ALSO@{ub}
        @{"datatypes.library/DoAsyncLayout()" link "datatypes/DoAsyncLayout()"}, @{"DTM_ASYNCLAYOUT" link "DTM_ASYNCLAYOUT"},
        @{"hypertext.datatype/GM_LAYOUT" link "GM_LAYOUT"}


@endnode
@node "GM_LAYOUT" "html.datatype/GM_LAYOUT"

    @{b}NAME@{ub}
        GM_LAYOUT -- starts layout of the HTML object

    @{b}FUNCTION@{ub}
        This method is directly passed to its superclass. If the superclass
        returns zero the object needs to be layouted, which is done
        asynchronously by calling the @{"DoAsyncLayout()" link "datatypes/DoAsyncLayout()"} function. If it returns
        non zero nothing has to be done.

    @{b}INPUTS@{ub}
        struct @{b}gpLayout@{ub}
        {
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
           struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *gpl_GInfo;
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} gpl_Initial;
        };

        gpl_Initial - First call of GM_LAYOUT for this object

    @{b}RESULT@{ub}
        0   - start the asynchronous layout
        !=0 - do nothing

    @{b}SEE ALSO@{ub}
        @{"DTM_PROCLAYOUT" link "DTM_PROCLAYOUT"}, @{"DTM_ASYNCLAYOUT" link "DTM_ASYNCLAYOUT"}, hypertext.datatype/GM_LAYOUT,
        @{"datatypes.library/DoAsyncLayout()" link "datatypes/DoAsyncLayout()"}, hypertext.datatype/HTDTM_LAYOUT


@endnode
@node "OM_DISPOSE" "html.datatype/OM_DISPOSE"

    @{b}NAME@{ub}
        OM_DISPOSE -- frees all allocated resources of a HTML object

    @{b}FUNCTION@{ub}
        This method frees all allocated resources of a HTML object.
        After this it calls the superclass OM_DISPOSE method.

    @{b}INPUTS@{ub}
        None.

    @{b}RESULT@{ub}
        None.

    @{b}SEE ALSO@{ub}
        hypertext.datatype/OM_DISPOSE, @{"datatypes.library/DisposeDTObject()" link "datatypes/DisposeDTObject()"},
        @{"OM_NEW" link "OM_NEW"}


@endnode
@node "OM_NEW" "html.datatype/OM_NEW"

    @{b}NAME@{ub}
        OM_NEW -- create a HTML object.

    @{b}FUNCTION@{ub}
        This method first calls the superclass OM_NEW method and if this
        returns a valid @{"Object" link "AG:SysInc/intuition/classusr.h/main" 19} pointer it sets some HTML specific values,
        like underlining links instead of making buttons for links.

    @{b}INPUTS@{ub}
        struct @{b}opSet@{ub} {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               MethodID;
            struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32}      *ops_AttrList;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25}   *ops_GInfo;
        };

        ops_AttrList -- initial attribute values
        ops_GInfo -- always @{"NULL" link "AG:SysInc/exec/types.h/main" 79} for OM_NEW

    @{b}RESULT@{ub}
        pointer to the newly created HTML object or @{"NULL" link "AG:SysInc/exec/types.h/main" 79} for a failure.
        If this method fails, a possible reason for failure is provided via
        the @{"IoErr()" link "dos/IoErr()"} function.

    @{b}SEE ALSO@{ub}
        hypertext.datatype/OM_NEW, @{"OM_DISPOSE" link "OM_DISPOSE"}, @{"OM_SET" link "OM_SET"}


@endnode
@node "OM_NOTIFY" "html.datatype/OM_NOTIFY"

    @{b}NAME@{ub}
        OM_NOTIFY -- notify attributes changes to the object

    @{b}FUNCTION@{ub}
        This method is used to convert all URL's to AmigaDOS style pathes,
        which are notified to the object using the @{"DTA_Title" link "AG:SysInc/datatypes/datatypesclass.h/main" 73} tag, if the
        HTDTA_ShowLink occurs in the opu_AttrList.

    @{b}INPUTS@{ub}
        struct @{b}opUpdate@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
            struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *opu_AttrList;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *opu_GInfo;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} opu_Flags;
        };

        opu_AttrList -- list of notification attributes
        opu_GInfo -- @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} structure
        opu_Flags -- flag @{"OPUF_INTERIM" link "AG:SysInc/intuition/classusr.h/main" 104} or zero

    @{b}RESULTS@{ub}
        superclass results

    @{b}SEE ALSO@{ub}
        hypertext.datatype/OM_NOTIFY, rootclass/OM_NOTIFY,
        @{"rootclass/OM_UPDATE" link "OM_UPDATE"}, @{"OM_UPDATE" link "OM_UPDATE"}


@endnode
@node "OM_SET" "html.datatype/OM_SET"

    @{b}NAME@{ub}
        OM_SET -- sets attributes of a HTML object

    @{b}FUNCTION@{ub}
        The OM_SET method is used to set attributes of a html.datatype
        object. This method is processed first and then passed to its
        superclass. If the result is non zero it calls the HTDTM_RENDER
        method, which invokes the @{"GM_RENDER" link "AG:SysInc/intuition/gadgetclass.h/main" 191} method on the separate hypertext
        process.

    @{b}INPUTS@{ub}
        struct @{b}opSet@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               MethodID;
            struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32}      *ops_AttrList;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25}   *ops_GInfo;
        };

        ops_AttrList - list of new attributes
        ops_GInfo - @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} structure

    @{b}RESULT@{ub}
        non zero if the HTML object needs rendering, zero if not.

    @{b}ATTRIBUTES@{ub}
        None.

    @{b}SEE ALSO@{ub}
        hypertext.datatype/OM_SET, @{"OM_UPDATE" link "OM_UPDATE"}, @{"OM_NEW" link "OM_NEW"},
        @{"datatypes.library/SetDTAttrsA()" link "datatypes/SetDTAttrsA()"}


@endnode
@node "OM_UPDATE" "html.datatype/OM_UPDATE"

    @{b}NAME@{ub}
        OM_UPDATE -- updates attributes of a HTML object.

    @{b}FUNCTION@{ub}
        The OM_UPDATE method is used to update attributes of a HTML object.
        This method is processed first and then passed to the superclass. This
        method falls directly through the @{"OM_SET" link "OM_SET"} method, thus all attributes
        of this method are also supported. The following ATTRIBUTES section
        lists all attributes, which are only supported by the the OM_UPDATE
        method. If the result is non zero it calls the HTDTM_RENDER method,
        which invokes the @{"GM_RENDER" link "AG:SysInc/intuition/gadgetclass.h/main" 191} method on the separate hypertext process.

    @{b}INPUTS@{ub}
        struct @{b}opUpdate@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               MethodID;
            struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32}      *opu_AttrList;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25}   *opu_GInfo;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               opu_Flags;
        };

        opu_AttrList -- list of new attributes
        opu_GInfo -- @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} structure
        opu_Flags -- flags indicating the status of this update method

    @{b}ATTRIBUTES@{ub}
        None.

    @{b}RESULT@{ub}
        Non zero if the object needs to be rendered. Zero if there has nothing
        changed, so that rendering isn't needed.

    @{b}SEE ALSO@{ub}
        hypertext.datatype/OM_UPDATE, @{"OM_SET" link "OM_SET"}, @{"rootclass/OM_NOTIFY" link "OM_NOTIFY"}


@endnode
