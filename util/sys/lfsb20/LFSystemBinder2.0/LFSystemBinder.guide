        @{"Info" link "MPInfo" 0}
        @{"Print" link "MPImp" 0}
        @{b}*******@{ub}
        @{"Quit" link "MPQuit" 0}

    - @{b}Edition@{ub}:
        @{"Mark All" link "MEMarkAll" 0}
        @{"Unmark All" link "MEUnMarkAll" 0}
        @{b}*******@{ub}
        @{"Toggle assign" link "METogAss" 0}

    - @{b}Options@{ub}:
        @{"Reverse" link "MOInv" 0}
