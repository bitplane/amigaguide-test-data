   @{" -a   " link A} @{" -A   " link ─} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
