@NODE F "sort v1.80 Documentation - Features - f"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-f[y]	specifies the first line of the working range.
	If this option is given, ALL actions are done ONLY in the range.
	To give also the last line is not compelling.
	If y is bigger than the number of lines of the internal file
	(all infiles together) an error-message appears and the
	program is cancelled.

@{" Contents " link MAIN} @{" << " link E} @{" Features " link FEATURES} @{" >> " link G}
@ENDNODE

