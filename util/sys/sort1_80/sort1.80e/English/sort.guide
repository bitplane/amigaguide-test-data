   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-g	actually the capitals and small letters are distinguished.
	by setting this switch, sorting is non-case sensitive.

	equivalent to the keyword NOCASE/S

@{" Contents " link MAIN} @{" << " link F} @{" Features " link FEATURES} @{" >> " link H}
@ENDNODE

@NODE H "sort v1.80 Documentation - Features - h"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-h[x,y]	this option removes a given number of lines at the beginning of
	a file. This is useful, if a number of files has to be joined
	and each file starts with a header, which should be in the sorted
	file only once.
	if x and/or y is not given, it will NOT be asked for, the value
	for it is assumed to be zero.
	x gives the number of lines to be ignored for the first file and
	y for ALL other files which are joined

@{" Contents " link MAIN} @{" << " link G} @{" Features " link FEATURES} @{" >> " link I}
@ENDNODE

@NODE I "sort v1.80 Documentation - Features - i|I"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-i[<filename | str]
	the given string is ignored for sorting, if it appears
	on the beginning of the sorting column. It's NOT removed!
	if spaces are in the string, it's advicable to give the -i
	option only in the command line and answer the request.
	For deleting the full line is used for comparision.

	if no string is given in the command line, it will be asked for, as
	before too.  Now a list of strings can be given, not only one.
	To finish, just give a return without string.

	if the first char is a '<' a filename is assumed after and the list
	of strings to ignore is read from the specified file.
	this is useful, if many strings are given and many files have to be
	sorted.
	the file is supposed to contain each string on a separate line
	without any blank lines, otherwise it aborts reading the file.

	if nothing is given after '<', it is ignored, and you have to give
	all strings by hand.

-I[<filename | str]
	same as -i[<filename | str]
	difference is that it is sorted in two passes.
	first the file is sorted without ignoring the strings, then all
	doubles are erased and after that the file is sorted ignoring
	the given strings.
	This is useful, because using the -i option does not guarantee
	to erase ALL doubles.
	Note that the file is sorted twice, so proceeding takes more time.

@{" Contents " link MAIN} @{" << " link H} @{" Features " link FEATURES} @{" >> " link J}
@ENDNODE

@NODE J "sort v1.80 Documentation - Features - j|J"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-j[x]	joins x files and sorts them; the resulting file is written
	to <outfile>.

-J[x]	joins x files without sorting; the resulting file is written
	to <outfile>.

@{" Contents " link MAIN} @{" << " link I} @{" Features " link FEATURES} @{" >> " link L}
@ENDNODE

@NODE L "sort v1.80 Documentation - Features - l"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-l[y]	specifies the last line of the work range.
	If this option is given, ALL actions are done ONLY in the range.
	To give also the first line is not compelling.
	If y is bigger than the number of lines of the internal file
	(all in-read files together) the last line of the file is
	automatically taken as last line of the range.

	if x or/and y is not given it will be asked for

@{" Contents " link MAIN} @{" << " link J} @{" Features " link FEATURES} @{" >> " link N}
@ENDNODE

@NODE N "sort v1.80 Documentation - Features - n|N"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-n	the file is not sorted, only blank lines are erased.

-N	the file is not sorted, only blank lines and identical lines
	which are side by side are erased.
	Using this option might be more useful if the file is sorted.
	Note that ending spaces and tabs of lines in the file/range
	are erased now.

@{" Contents " link MAIN} @{" << " link L} @{" Features " link FEATURES} @{" >> " link O}
@ENDNODE

@NODE O "sort v1.80 Documentation - Features - o"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-o	the sorted file will be written to a file with the same name as
	the (first) infile.

	                        CAUTION!!!
	             IF ONCE OVERWRITTEN THE ORIGINAL
	                FILE CANNOT BE RESTORED!!!

@{" Contents " link MAIN} @{" << " link N} @{" Features " link FEATURES} @{" >> " link P}
@ENDNODE

@NODE P "sort v1.80 Documentation - Features - p|P"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-p[str]	all lines, that not match the search pattern 'str' will be removed.

-P[str]	all lines, that match the search pattern 'str' will be removed

if  characters like " are given it is advisable to give this switch as the
last of the command line, following switches are not recognized after a ".
The  use  of  -p|P  and -q|Q is possible at the same time.  Then first the
lines  will be picked / throwed out according to the string given with the
-p|P  option,  and  AFTER sorting, the file will be divided into two files
according to the string given with the -q|Q switch.

@{" Contents " link MAIN} @{" << " link O} @{" Features " link FEATURES} @{" >> " link Q}
@ENDNODE

@NODE Q "sort v1.80 Documentation - Features - q|Q"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-q[str]	All lines which do not match the search pattern will be written to
	an extra file (<outfile>.ohne) and all lines, which match it to the
	specified outfile.

-Q[str]	All lines which do match the search pattern will be written to an
	extra file (<outfile>.mit) and all lines, which don't to the
	specified outfile.

if  characters like " are given it is advisable to give this switch as the
last of the command line, following switches are not recognized after a ".
The  use  of  -p|P  and -q|Q is possible at the same time.  Then first the
lines  will be picked / throwed out according to the string given with the
-p|P  option,  and  AFTER sorting, the file will be divided into two files
according to the string given with the -q|Q switch.

@{" Contents " link MAIN} @{" << " link P} @{" Features " link FEATURES} @{" >> " link R}
@ENDNODE

@NODE R "sort v1.80 Documentation - Features - r"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-r	the given infile is only written in reverse order of lines
	without any other actions. Other selected options don't have
	any influence.

@{" Contents " link MAIN} @{" << " link Q} @{" Features " link FEATURES} @{" >> " link S}
@ENDNODE

@NODE S "sort v1.80 Documentation - Features - s|S"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-s[c]	the character c will be removed from the file/range.

-S[cd]	with this option the char c will be replaced by char d in the
	file/range.

NOTE:	if characters like " are given it is advisable to give this switch
	as the very last of the command line.  The reason is that the
	following arguments are not recognized after a " by the programm.

@{" Contents " link MAIN} @{" << " link R} @{" Features " link FEATURES} @{" >> " link T}
@ENDNODE

@NODE T "sort v1.80 Documentation - Features - t"

   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-t	erase spaces and tabs which are at the end of a line.
	This is useful, if different files have lines with identical
	contents, just differing from each other by the ending space.
	This option is now automatically set with the -E and -N option.
	the option can be used separatly if the file is not being sorted.

@{" Contents " link MAIN} @{" << " link S} @{" Features " link FEATURES} @{" >> " link U}
@ENDNODE

