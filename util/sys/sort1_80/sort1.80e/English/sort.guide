   @{" -a   " link A} @{" -A   " link Ä} @{" -b|B " link B} @{" -c|C " link C} @{" -d   " link D} @{" -e|E " link E} @{" -f   " link F} @{" -g   " link G} @{" -h   " link H} @{" -i|I " link I}
   @{" -j|J " link J} @{" -l   " link L} @{" -n|N " link N} @{" -o   " link O} @{" -p|P " link P} @{" -q|Q " link Q} @{" -r   " link R} @{" -s|S " link S} @{" -t   " link T} @{" -u   " link U}
   @{" -v   " link V} @{" -w|W " link W} @{" -x   " link X} @{" -y|Y " link Y} @{" -z|Z " link Z}

-u	lines which are complete in another, are erased
	Beginning of comparision is alway the first column, only if you
	use the C[z,l] option, then the column z

	example:
	cassette
	many cassettes
	cassettes

	only the line 'cassette' is being erased

@{" Contents " link MAIN} @{" << " link T} @{" Features " link FEATURES} @{" >> " link V}
