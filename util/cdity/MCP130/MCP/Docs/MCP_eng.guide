 @{"G L O B A L" link "Features" 0}      @{"L I S T S" link "fet_listspage" 0}      @{"S C R E E N M A N A G E R" link "fet_promotor" 0}      @{"H O T K E Y S" link "fet_hotkeys" 0}


@{b}@{u}MCP Snap Documentation@{uu}@{ub}
@{b}Snap@{ub} was entirely written by @{"Sören Sonnenburg" link s_Author} 1995-97.

