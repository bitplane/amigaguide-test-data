@NODE 4.1 "Tipos de herramienta soportados"

 CX_POPKEY=<tecla(s) para navegar entre las pantallas>

 CX_CLOSEKEY=<tecla(s) para salir del programa>

 CX_CONFIGKEY=<tecla(s) para invocar la ventana de preferencias>

 CX_WINDOWKEY=<tecla(s) para navegar entre las ventanas>

 WBSCREEN=1 siempre sobre el Workbench
         =0 sobre la pantalla que se encuentra en primer plano

 PUBLIC=1   sólo pantallas públicas
@ENDNODE

