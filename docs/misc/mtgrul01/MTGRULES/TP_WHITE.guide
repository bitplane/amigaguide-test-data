@node ADVAN "Advance Scout"

@{b}Advance Scout@{ub}

Color   = White
Rarity  = TP(C)
Type    = Summon Soldier(1/1)
Cost    = 1W
Artist  = Heather Hudson

Text(TP): First strike
          <W>: Target creature gains first strike until end of turn.

Flavor Text: @{i}"The soldiers' path is worn smooth by the tread
              of many feet -- all in one direction, none returning."
              ---Oracle en-Vec@{ui}

 @{b}No Rulings@{ub}


@endnode
@node ANGEL "Angelic Protector"

@{b}Angelic Protector@{ub}

Color   = White
Rarity  = TP(U)
Type    = Summon Angel(2/2)
Cost    = 3W
Artist  = DiTerlizzi

Text(TP): Flying
          If Angelic Protector is the target of a spell or ability, it 
          gets +0/+3 until end of turn.

Flavor Text: @{i}"My familiy sheltered in her light, the dark was
               content to wait." ---Crovax@{ui}

 @{b}No Rulings@{ub}


@endnode
