@database SH_Artifact.guide
@author "Roger, Christian, Robert"
@$VER: MTG.guide 3.3 march.98
@node MAIN "Stronghold - Artifact Cards"
@{" " link MTG_CARD_LISTS.guide/CL_SH}
                          @{b}Stronghold - Artifact Cards@{ub}

            @{" Bullwhip                " link CLOUD}     @{" Ensnaring Bridge        " link CONTE}
            @{" Heartstone              " link DREAH}     @{" Horn of Greed           " link DREAP}
            @{" Hornet Cannon           " link EVACU}     @{" Jinxed Ring             " link GLIDI}
            @{" Mox Diamond             " link HAMME}     @{" Portcullis              " link HESIT}
            @{" Shifting Wall           " link INTRU}     @{" Sword of the Chosen     " link LEAP_}
            @{" Volrath's Laboratory    " link MANAL}     

@endnode
@node CLOUD "Bullwhip"

@{b}Bullwhip@{ub}

Color   = Artifact
Rarity  = SH(U)
Type    = Artifact
Cost    = 4
Artist  = Brom

Text(SH): <2T>: Bullwhip deals 1 damage to target creature. That creature
          attacks this turn if able.

Flavor Text: @{i}"Pain is a crude way to enforce obedience, but it
             is cheap and plentiful." -Volrath
@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node CONTE "Ensnaring Bridge"

@{b}Ensnaring Bridge@{ub}

Color   = Artifact
Rarity  = SH(R)
Type    = Artifact
Cost    = 3
Artist  = Pete Venters

Text(SH): Each creature with power greater than the number of cards in your
          hand cannot attack.

Flavor Text: @{i}"I expected a fight, but I didn't expect it from the
             building itself." -Gerrard
@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node DREAH "Heartstone"

@{b}Heartstone@{ub}

Color   = Artifact
Rarity  = SH(U)
Type    = Artifact
Cost    = 3
Artist  = John Matson

Text(SH): The cost of each creature ability requiring an activation cost is
          reduced by 1. This cannot reduce an ability's generic mana cost
          to less then 1.

Flavor Text: @{i}"Finding a true heartstone is even harder than finding
             a true heart." -Hanna
@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node DREAP "Horn of Greed"

@{b}Horn of Greed@{ub}

Color   = Artifact
Rarity  = SH(R)
Type    = Artifact
Cost    = 3
Artist  = Jeff Miracola

Text(SH): Whenever any player plays a land, that player draws a card.

Flavor Text: @{i}"Rath grows, and I am nourished." -Volrath@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node EVACU "Hornet Cannon"

@{b}Hornet Cannon@{ub}

Color   = Artifact
Rarity  = SH(U)
Type    = Instant
Cost    = 4
Artist  = Ron Spencer

Text(SH): <3T>: Put a Hornet token into play. Treat this token as a 1/1
          artifact creature with flying that is unaffected by summoning
          sickness. At end of turn, destroy the token.


 @{b}NO RULINGS@{ub}

@endnode
@node GLIDI "Jinxed Ring"

@{b}Jinxed Ring@{ub}

Color   = Artifact
Rarity  = SH(U)
Type    = Artifact
Cost    = 2
Artist  = DiTerlizzi

Text(SH): Whenever any card is put into your graveyard from play, Jinxed
          Ring deals 1 damage to you.
          Sacrifice a creature: Target opponent gains control of Jinxed
          Ring permanently.

 @{b}NO RULINGS@{ub}

@endnode
@node HAMME "Mox Diamond"

@{b}Mox Diamond@{ub}

Color   = Artifact
Rarity  = SH(R)
Type    = Artifact
Cost    = 0
Artist  = Dan Frazier

Text(SH): When Mox Diamond comes into play, choose and discard a land card
          or sacrifice Mox Diamond.
          <T>: Add one mana of any color to your mana pool. Play this ability
          as a mana source.


 @{b}NO RULINGS@{ub}

@endnode
@node HESIT "Portcullis"

@{b}Portcullis@{ub}

Color   = Artifact
Rarity  = SH(R)
Type    = Artifact
Cost    = 4
Artist  = Kev Walker

Text(SH): Whenever any creature comes into play, if there are two or more
          other creatures in play, set that creature aside. If Portcullis
          leaves play, put the creature into play under its owner's
          control.


 @{b}NO RULINGS@{ub}

@endnode
@node INTRU "Shifting Wall"

@{b}Shifting Wall@{ub}

Color   = Artifact
Rarity  = SH(U)
Type    = Artifact Creature (0/0)
Cost    = X
Artist  = Michael Sutfin

Text(SH): Shifting Wall counts as a Wall (Walls cannot attack.)
          Shifting Wall comes into play with X +1/+1 counters on it.

Flavor Text: @{i}"You'd almost think Volrath
             doesn't want me here." -Gerrard@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node LEAP_ "Sword of the Chosen"

@{b}Sword of the Chosen@{ub}

Color   = Artifact
Rarity  = SH(R)
Type    = Legendary Artifact
Cost    = 2
Artist  = Adam Rex

Text(SH): <T>: Target legend gets +2/+2 until end of turn.

Flavor Text: @{i}One shard of Selenia yet remained.@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node MANAL "Volrath's Laboratory"

@{b}Volrath's Laboratory@{ub}

Color   = Artifact
Rarity  = SH(R)
Type    = Artifact
Cost    = 5
Artist  = Brom

Text(SH): When you play Volrath's Laboratory, choose a color and creature
          type.
          <5T>: Put a token creature into play. Treat this token as a 2/2
          creature of the chosen color and creature type.


 @{b}NO RULINGS@{ub}

@endnode
