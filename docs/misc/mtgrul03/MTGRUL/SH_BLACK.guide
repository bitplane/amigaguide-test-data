@node BOTTE "Bottomless Pit"

@{b}Bottomless Pit@{ub}

Color   = Black
Rarity  = SH(U)
Type    = Enchantment
Cost    = 1BB
Artist  = Kev Walker

Text(SH): During each player's upkeep, that player discards a card
          at random.

Flavor Text: @{i}"I'm sure it came with the place. I don't think you build one
              on purpose." -Gerrard@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node BRUSH "Brush With Death"

@{b}Brush With Death@{ub}

Color   = Black
Rarity  = SH(C)
Type    = Sorcery
Cost    = 2B
Artist  = Stephen Daniele

Text(SH): Buyback 2BB (You may pay an additional 2BB when you playthis
          spell. If you do, put it into your hand instead of your graveyard
          as part of the spell's effect.)
          Target opponent loses 2 life. You gain 2 life.


 @{b}NO RULINGS@{ub}

@endnode
@node CANNI "Cannibalize"

@{b}Cannibalize@{ub}

Color   = Black
Rarity  = SH(C)
Type    = Sorcery
Cost    = 1B
Artist  = Robert Bliss

Text(SH): Choose two target creatures controlled by any one player. Remove
          one of those creatures from the game and put two +1/+1 counters
          on the other.

Flavor Text: @{i}"Mine."@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node CORRU "Corrupting Licid"

@{b}Corrupting Licid@{ub}

Color   = Black
Rarity  = SH(U)
Type    = Summon Licid (2/2)
Cost    = 2B
Artist  = Thomas M. Baxa

Text(SH): <BT>: Corrupting Licid loses this abillity and becomes a creature
          enchantment that reads "Enchanted creature cannot be blocked
          except by artifact creatures and black creatures" instead of a
          creature. Move Corrupting Licid onto target creature. You may pay
          B to end this effect.


 @{b}NO RULINGS@{ub}

@endnode
@node CROVA "Crovax the Cursed"

@{b}Crovax the Cursed@{ub}

Color   = Black
Rarity  = SH(R)
Type    = Summon Legend (0/0)
Cost    = 2BB
Artist  = Pete Venters

Text(SH): Crovax the Cursed counts as a Vampire.
          Crovax comes into play with four +1/+1 counters on it.
          During your upkeep, sacrifice a creature and put a +1/+1 counter
          Crovax, or remove a +1/+1 counter from Crovax.
          B: Crovax gains flying until end of turn.


 @{b}NO RULINGS@{ub}

@endnode
@node DAUTH "Dauthi Trapper"

@{b}Dauthi Trapper@{ub}

Color   = Black
Rarity  = SH(U)
Type    = Summon Minion (1/1)
Cost    = 2B
Artist  = Thomas M. Baxa

Text(SH): <T>: Target creature gains shadow until end of turn. (This
          creature can block or be blocked by only creatures with shadow.)

Flavor Text: @{i}Merfolk tell their young of Dandan, humans of Rag Man.
              Dal tell tales of the Dauthi, and they are far worse.@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node DEATH "Death Stroke"

@{b}Death Stroke@{ub}

Color   = Black
Rarity  = SH(C)
Type    = Sorcery
Cost    = BB
Artist  = Colin Mc Neil

Text(SH): Destroy target tapped creature.

Flavor Text: @{i}For a sharp second, Selenia froze, and Crovax's blade
              found home. As the angel shattered like glass, Crovax felt
              his mind collapse- the curse had been fulfilled.@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node DUNGE "Dungeon Shade"

@{b}Dungeon Shade@{ub}

Color   = Black
Rarity  = SH(C)
Type    = Summon Spirit (1/1)
Cost    = 3B
Artist  = Jason Alexander Behnke

Text(SH): Flying
          <B>: Dungeon Shade gets +1/+1 until end of turn.

Flavor Text: @{i}A sickness stirs in its eyes, a nightmare born
              in darkened wails.@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node FOULI "Foul Imp"

@{b}Foul Imp@{ub}

Color   = Black
Rarity  = SH(C)
Type    = Summon Imp (2/2)
Cost    = BB
Artist  = Jim Nelson

Text(SH): Flying
          When Foul Imp comes into play, lose 2 life.

Flavor Text: @{i}The imp, unaware of its own ordor, paused to catch its
              breath...and promptly died.@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node GRAVE "Grave Pact"

@{b}Grave Pact@{ub}

Color   = Black
Rarity  = SH(R)
Type    = Enchantment
Cost    = 1BBB
Artist  = Scott Kirschner

Text(SH): Whenever any creature you control is put into any graveyard, each
          other player sacrifices a creature.

Flavor Text: @{i}"The bonds of loyalty can tie one to the grave." -Crovax@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node LABRA "Lab Rats"

@{b}Lab Rats@{ub}

Color   = Black
Rarity  = SH(C)
Type    = Sorcery
Cost    = B
Artist  = DiTerlizzi

Text(SH): Buyback 4 (You may pay an additional 4 when you play this spell.
          If you do, put it into your hand instead of your graveyard as
          part of the spell's effect.)
          Put a Rat token into play. Treat this token as a 1/1 black
          creature.


 @{b}NO RULINGS@{ub}

@endnode
@node MEGRI "Megrim"

@{b}Megrim@{ub}

Color   = Black
Rarity  = SH(U)
Type    = Enchantment
Cost    = 2B
Artist  = Donato Giancola

Text(SH): Whenever any opponent discards a card, Megrim deals 2 damage to
          him or her.

Flavor Text: @{i}"You can run from your pain," explained Gerrard to Crovax,
              "but take it from experience: you will tire before it does."@{ui}

 @{b}NO RULINGS@{ub}

@endnode
