@node AWAKE "Awakening"

@{b}Awakening@{ub}

Color   = Green
Rarity  = SH(R)
Type    = Enchantment
Cost    = 2GG
Artist  = Dan Frazier

Text(SH): At the beginning of each player's upkeep, untap all creatures and
          lands.

Flavor Text: @{i}"There are times when destiny calls forth a people and
              demands an action. Now is the time. We are the people.
              This is our action. Charge!" -Eladamri, Lord of Leaves@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node BURGE "Burgeoning"

@{b}Burgeoning@{ub}

Color   = Green
Rarity  = SH(R)
Type    = Enchantment
Cost    = G
Artist  = Randy Gallegos

Text(SH): Whenever any opponent plays a land, you may choose a land card
          from your hand and put it into play.

Flavor Text: @{i}"The plants said, "We will fight the stone with root and
              stem and seed. We are patient. We will win."
              -Skyshroud myth of the forest @{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node CARDA "Cardassid"

@{b}Cardassid@{ub}

Color   = Green
Rarity  = SH(R)
Type    = Summon Beasts (5/4)
Cost    = 4GG
Artist  = Brom

Text(SH): Trample
          <1G>: Regenerate Carnassid.

Flavor Text: @{i}The hunter would never forget the time or place where he first
              met the carnassid, for they buried him there.

 @{b}NO RULINGS@{ub}

@endnode
@node CONST "Constant Mists"

@{b}Constant Mists@{ub}

Color   = Green
Rarity  = SH(U)
Type    = Instant
Cost    = 1G
Artist  = Dermot Power

Text(SH): Buyback - Sacrifice a land (You may sacrifice a land in addition
          to any other costs when you play this spell. If you do, put
          Constant Mists into your hand instead of your graveyard as part
          of the spell's effect.)
          Creatures deal no combat damage this turn.

Flavor Text: @{i}

 @{b}NO RULINGS@{ub}

@endnode
@node CROSS "Crossbow Ambush"

@{b}Crossbow Ambush@{ub}

Color   = Green
Rarity  = SH(C)
Type    = Instant
Cost    = G
Artist  = Kev Walker

Text(SH): All creatures you control can block creatures with flying until
          end of turn.

Flavor Text: @{i}There is no drake that flies faster than a crossbow bolt.
              -Vec saying
@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node ELVEN "Elven Rite"

@{b}Elven Rite@{ub}

Color   = Green
Rarity  = SH(U)
Type    = Sorcery
Cost    = 1G
Artist  = Jeff Miracola

Text(SH): Put two +1/+1 counters, distributed any way you choose, on any
          number of target creatures.

Flavor Text: @{i}As the bough stretches, so shall you grow. As the roots spread,
               so shall you thrive.@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node ENDAN "Endangered Armodon"

@{b}Endangered Armodon@{ub}

Color   = Green
Rarity  = SH(C)
Type    = Summon Elephant (4/5)
Cost    = 2GG
Artist  = Kev Walker

Text(SH): If you control any creature with toughness 2 or less, sacrifice
          Endangered Armodon.

Flavor Text: @{i}These are its last days. Its doom to be remembered only
              until the hunters hunger again.@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node HERMI "Hermit Druid"

@{b}Hermit Druid@{ub}

Color   = Green
Rarity  = SH(R)
Type    = Summon Druid (1/1)
Cost    = 1G
Artist  = Heather Hudson

Text(SH): <GT>: Reveal cards from the top of your library until you reveal
          a basic land card. Put that card into your hand and put all other
          revealed cards into your graveyard.

Flavor Text: @{i}Seeking the company of plants ensures that your wits will go to
              seed.@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node LOWLA "Lowland Basilisk"

@{b}Lowland Basilisk@{ub}

Color   = Green
Rarity  = SH(C)
Type    = Summon Basilisk (1/3)
Cost    = 2G
Artist  = Randy Gallegos

Text(SH): Whenever Lowland Basilisk damages any creature, destroy that
          creature at end of combat.

Flavor Text: @{i}Unlike their cousins, Rathi basilisks turn their victims
              into puddles of flowstone.@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node MULCH "Mulch"

@{b}Mulch@{ub}

Color   = Green
Rarity  = SH(C)
Type    = Sorcery
Cost    = 1G
Artist  = Rebecca Guay

Text(SH): Reveal the top four cards of your library to all players. Put any
          of those cards that are lands into your hand and the rest into
          your graveyard.

Flavor Text: @{i}Hope is the one crop that can grow in any climate.@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node OVERG "Overgrowth"

@{b}Overgrowth@{ub}

Color   = Green
Rarity  = SH(C)
Type    = Enchant Land
Cost    = 2G
Artist  = Rob Alexander

Text(SH): Whenever enchanted land is tapped for mana, it produces an
          additional GG.

Flavor Text: @{i}Life needs no encouragement.@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node PRIMA "Primal Rage"

@{b}Primal Rage@{ub}

Color   = Green
Rarity  = SH(U)
Type    = Enchantment
Cost    = 1G
Artist  = Brian Snoddy

Text(SH): All creatures you control gain trample.

Flavor Text: @{i}"Charge!" A great cry went out, and countless elves and Vec
              soldiers charged up the mountain. Their fury and passion hid the
              fact that they were horribly outnumbered.@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node PROVO "Provoke"

@{b}Provoke@{ub}

Color   = Green
Rarity  = SH(C)
Type    = Instant
Cost    = 1G
Artist  = Terese Nielsen

Text(SH): Untap target creature you do not control. That creature blocks
          this turn if able.
          Draw a card.

Flavor Text: @{i}Mirri did not have time to think, only to react.@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node SKYSA "Skyshroud Archer"

@{b}Skyshroud Archer@{ub}

Color   = Green
Rarity  = SH(C)
Type    = Summon Elf (1/1)
Cost    = G
Artist  = Jeff Miracola

Text(SH): <T>: Target creature with flying gets -1/-1 until end of turn.

Flavor Text: @{i}In Rath, arrows are guided not by virtue but by necessity.@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node SKYST "Skyshroud Troopers"

@{b}Skyshroud Troopers@{ub}

Color   = Green
Rarity  = SH(C)
Type    = Summon Elves (3/3)
Cost    = 3G
Artist  = DiTerlizzi

Text(SH): <T>: Add G to your mana pool. Play this ability as a mana source.

Flavor Text: @{i}"We were not made for war. Like flowstone, Volrath shaped
              us to it." -Eladamri, Lord of Leaves@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node SPIKB "Spike Breeder"

@{b}Spike Breeder@{ub}

Color   = Green
Rarity  = SH(R)
Type    = Summon Spike (0/0)
Cost    = 3G
Artist  = Adam Rex

Text(SH): Spike Breeder comes into play with three +1/+1 counters on it.
          <2>, Remove a +1/+1 counter from Spike Breeder: Put a +1/+1
          counter on target creature.
          <2>, Remove a +1/+1 counter from Spike Breeder: Put a Spike token
          into play. Treat this token as a 1/1 green creature.


 @{b}NO RULINGS@{ub}

@endnode
@node SPIKC "Spike Colony"

@{b}Spike Colony@{ub}

Color   = Green
Rarity  = SH(C)
Type    = Summon Spike (0/0)
Cost    = 4G
Artist  = Douglas Shuler

Text(SH): Spike Colony comes into play with four +1/+1 counters on it.
          <2>, Remove a +1/+1 counter from Spike Colony: Put a +1/+1 counter
          on target creature.


 @{b}NO RULINGS@{ub}

@endnode
@node SPIKF "Spike Feeder"

@{b}Spike Feeder@{ub}

Color   = Green
Rarity  = SH(U)
Type    = Summon Spike (0/0)
Cost    = 1GG
Artist  = Heather Hudson

Text(SH): Spike Feeder comes into play with two +1/+1 counters on it.
          <2>, Remove a +1/+1 counter from Spike Feeder: Put a +1/+1 counter
          on target creature.
          Remove a +1/+1 counter from Spike Feeder: Gain 2 life.


 @{b}NO RULINGS@{ub}

@endnode
