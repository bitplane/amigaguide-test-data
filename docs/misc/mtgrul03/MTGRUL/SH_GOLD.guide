                          @{b}Stronghold - Multicolored Cards@{ub}

            @{" Acidic Sliver           " link ACIDI}     @{" Crystalline Sliver      " link CRYST}
            @{" Hibernation Sliver      " link HIBER}     @{" Sliver Queen            " link SLIVE}
            @{" Spined Sliver           " link SPINE}     @{" Victual Sliver          " link VICTU}
                 

@endnode
@node ACIDI "Acidic Sliver"

@{b}Acidic Sliver@{ub}

Color   = Multi
Rarity  = SH(U)
Type    = Summon Sliver (2/2)
Cost    = BR
Artist  = Jeff Miracola

Text(SH): Each Sliver gains "2, Sacrifice this creature: This creature
          deals 2 damage to target creature of player."

Flavor Text: @{b}The first sliver burst against the cave wall, and others
             piled in behind to deepen the new tunnel.
@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node CRYST "Crystalline Sliver"

@{b}Crystalline Sliver@{ub}

Color   = Multi
Rarity  = SH(U)
Type    = Summon Sliver (2/2)
Cost    = WU
Artist  = L.A, Williams

Text(SH): Slivers cannot be the target of spells or abilities.

Flavor Text: @{b}Bred as living shields, these slivers have proven
             unruly-they know they cannot be caught.
@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node HIBER "Hibernation Sliver"

@{b}Hibernation Sliver@{ub}

Color   = Multi
Rarity  = SH(U)
Type    = Summon Sliver (2/2)
Cost    = UB
Artist  = Scott Kirschner

Text(SH): Each Sliver gains "Pay 2 life: Return this creature to owner's
          hand."

Flavor Text: Mogglings have been known to play ball with hibernating
             slivers, completly unaware of their true nature.

 @{b}NO RULINGS@{ub}

@endnode
@node SLIVE "Sliver Queen"

@{b}Sliver Queen@{ub}

Color   = Multi
Rarity  = SH(R)
Type    = Summon Legend (7/7)
Cost    = WUBRG
Artist  = Ron Spencer

Text(SH): Sliver Queen counts as a Sliver.
          <2>: Put a Sliver token into play. Treat this token as a 1/1
          colorless creature.

Flavor Text: @{b}Her children are ever part of her.@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node SPINE "Spined Sliver"

@{b}Spined Sliver@{ub}

Color   = Multi
Rarity  = SH(U)
Type    = Summon Sliver (2/2)
Cost    = RG
Artist  = Ron Spencer

Text(SH): If any Sliver is blocked it gets +1/+1 until end of turn for each
          creature blocking it.

Flavor Text: @{b}"Slivers are evil and slivers are sly;
             And if you get eaten, then no one will cry."
             -Mogg children's rhyme
@{ub}

 @{b}NO RULINGS@{ub}

@endnode
@node VICTU "Victual Sliver"

@{b}Victual Sliver@{ub}

Color   = Multi
Rarity  = SH(U)
Type    = Summon Sliver (2/2)
Cost    = GW
Artist  = Terese Nielsen

Text(SH): Each Sliver gains "2, Sacrifice this creature: Gain 4 life."

Flavor Text: @{b}"We are kinfolk," explained Karn to the sliver queen.
             "Just as you need your progeny to complete you, so do I
             need the pieces of the Legacy to make me whole."
@{ub}

 @{b}NO RULINGS@{ub}

@endnode
