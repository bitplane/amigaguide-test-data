@node "pe_main" "Wzonka-Lad Palette Editor 1.05"
@toc "main"

          @{b}In General@{ub}

          @{" L'editeur de palette     " link "pe_palette" 0}  @{" Caracteristiques             " link "pe_features" 0}
          @{" Compatibilite            " link "pe_compability" 0}  @{" Configuration Requise        " link "pe_requirements" 0}
          @{" Historique               " link "pe_history" 0}  @{" Utilisation                  " link "pe_usage" 0}

          @{b}Gadgets@{ub}

            @{b}.iff@{ub}

              - Load        -->   Charge les couleurs d'un fichier iff. Seules
                                  les 8 premieres couleurs sont prises en compte.

            @{b}.prefs@{ub}

              - Load        -->   Charge les couleurs d'un fichier .prefs de Wzonka-Lad.
              - Save        --->  Sauvegarde les couleurs vers un fichier .prefs Wzonka-Lad.

            @{b}.cfg@{ub}

              - Load        -->   Charge des couleurs d'un fichier VGB .cfg.
              - Save        --->  Sauvegarde les couleurs vers un fichier VGB .cfg. Notez que
                                  les tags -xc(0-3) sont utilises.

            @{b}Colours@{ub}

              - Obtain      -->   Obtient les coleurs de @{"Wzonka-Lad" link "wzonka" 0} l'Emulateur.
                                  @{"Wzonka-Lad" link "wzonka" 0} tournera en tache de fond ou le
                                  gadget sera grise. Pour avoir ce bouton active vous avez besoin
                                  de @{"Wzonka-Lad" link "wzonka" 0} version 0.90 ou mieux.

            @{b}Background and Sprite colours@{ub}

              - Interpolate -->   Calcule les deux couleurs entre la premiere et
                                  la derniere pour former un degrade de couleurs.
                                  
              - <           -->   Copie la couleur a gauche.
              - >           --->                 droite.

              - R           -->   Change les valeurs de rouge de la couleur.
              - G           --->                        vert               .
              - B           ---->                       Bleu               .

@endnode

