@{"Althos IV         " LINK 045d}
@{"Amber             " LINK 045e}
@{"Amerind           " LINK 045f}
@{"Anchor            " LINK 0460}
@{"Andor             " LINK 0461}
@{"Angel One         " LINK 0462}
@{"Antares           " LINK 0463}
@{"Antos IV          " LINK 0464}
