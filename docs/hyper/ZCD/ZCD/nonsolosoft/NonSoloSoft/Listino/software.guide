@node "mainactor" "MainActor Broadcast"
@toc "Main"

@{b}Name.............@{ub} Mainactor Broadcast
@{b}Editore..........@{ub} Village Tronic
@{b}Prezzo...........@{ub} Fare riferimento al @{"listino" link "listino.guide/software"}
@{b}Supporto.........@{ub} floppy
