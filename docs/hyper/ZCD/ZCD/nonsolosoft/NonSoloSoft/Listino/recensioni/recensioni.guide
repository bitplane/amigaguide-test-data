Legenda:

AC  = Amiga Computing (inglese)
AE  = @{"Amiga Energy" link "recensioni/C.MarroFilosa.guide/AmigaEnergy" 0} (inglese)
AF  = @{"Amiga Format" link "recensioni/C.MarroFilosa.guide/AmigaFormat" 0} (inglese)
AFL = Amiga Flame (Rivista inglese in formato Elettronico)
AI  = @{"THE AMIGA INFORMER" link "recensioni/C.MarroFilosa.guide/TheAmigaInformer" 0} (Rivista Americana solo su abbonamento)
AM  = Amiga Magazine
AMY = @{"Amy Resource" link "cdrom.guide/amyresource" 0} (Rivista HTML presente sul CD-ROM)
AOL = Amiga On Line (Rivista inglese in formato Elettronico)
AOLI= Amiga On Line Italia (Rivista italiana in formato Elettronico)
AP  = Amiga Plus (Tedesca)
AR  = Amiga Report (Rivista inglese in formato Elettronico)
AS  = Amiga Shopper
@{b}ASU = @{"Amiga Survivor" link "recensioni/C.MarroFilosa.guide/AmigaSurvivor" 0} (inglese)@{ub}
AUI = Amiga User International (inglese)
@{b}CLU = @{"CLUBBED" link "recensioni/C.MarroFilosa.guide/CLUBBED" 0} (inglese)@{ub}
CU  = @{"CU Amiga" link "recensioni/C.MarroFilosa.guide/CUAmiga" 0} (inglese)
EAR = @{"Enigma Amiga Run" link "recensioni/C.MarroFilosa.guide/EnigmaAmigaRun" 0}
K   = K
MC  = MC MicroComputer
TAM = The Amiga Monitor (Rivista inglese in formato Elettronico)
TAN = The Amiga Nutta (Rivista inglese in formato Elettronico)
TGM = The Games Machine


@{b}ATTENZIONE@{ub} In neretto sono evidenziati i nuovi programmi o aggiornamenti


