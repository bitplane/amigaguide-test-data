@node "HELP_BUTTONS" "AmigaGuideź Help: Dugmad"

@{b}CONTENTS@{ub} - Prikazuje sadrzaj dokumenta (ukoliko isti postoji).
@{b}INDEX@{ub}    - Prikazuje indeks dokumenta (ukoliko isti postoji).
@{b}HELP@{ub}     - Prikazuje pomoc za trenutni dokument.
           Ako ona ne postoji, prikazuje globalnu datoteku za pomoc.
@{b}RETRACE@{ub}  - Vraca se na prethodnu temu.
@{b}BROWSE @{ub}  - Lista teme po onom redosledu kako se one nalaze u datoteci.
@endnode

@node "HELP_MENUS" "AmigaGuideź Help: Meniji"

@{b}PROJECT@{ub}
-------
OPEN              - Otvara novi dokument.
SAVE AS           - Sprema trenutni dokument u datoteku po izboru.
PRINT             - Ispisuje trenutni dokument na stampac.
ABOUT             - Prikazuje osnovne informacije o trenutnom dokumentu.
QUIT              - Zatvara trenutni dokument i napusta program.

@{b}EDIT@{ub}
------
MARK              - obelezava deo dokumenta.
COPY              - Kopira obelezeni deo u clipboard.
                    Ukoliko nista nije obelezeno kopira celi dokument.
SELECT ALL        - Obelezava celokupni trenutni dokument.
CLEAR SELECTED    - Odbelezava prethodno obelezeni deo dokumenta.

@{b}WINDOW@{ub}
------
MINIMIZE          - Svodi prozor na najmanje moguce dimenzije.
NORMAL            - Dimenzionise prozor u skladu sa trenutnim dokumentom.
MAXIMIZE          - Svodi prozor na najvece moguce dimenzije.

@{b}PREFS@{ub}
---------
SAVE AS DEFAULTS  - Snima trenutnu velicinu i polozaj prozora.

@endnode

@node "HELP_KEYSTROKES" "AmigaGuideź Help: Tastatura"

@{b}HELP@{ub}      - Prikazuje ovaj dokument.
@{b}ESC@{ub}       - Zatvara aktivni prozor.
@{b}BACKSPACE@{ub} - Vraca se na prethodnu stranicu.
@{b}SPACE@{ub}     - Odlazi na sledecu stranicu.
@{b}>@{ub}         - Skace na kraj dokumenta.
@{b}<@{ub}         - Skace na pocetak dokumenta.

@endnode

@node "HELP_ARROWS" "AmigaGuideź Help: Kursorske strelice"

@{b}GORE@{ub}          - Jedna linija gore.
@{b}DOLE@{ub}          - Jedna linija dole.
@{b}SHIFT + GORE@{ub}  - Stranica gore.
@{b}SHIFT + DOLE@{ub}  - Stranica dole.
@{b}ALT + GORE@{ub}    - Skace na pocetak dokumenta.
@{b}ALT + DOLE@{ub}    - Skace na kraj dokumenta.
@{b}LEVO@{ub}          - Pomice dokument ulevo.
@{b}DESNO@{ub}         - Pomice dokument udesno.
@{b}SHIFT + LEVO@{ub}  - Pomice dokument ulevo za sirinu prozora.
@{b}SHIFT + DESNO@{ub} - Pomice dokument udesno za sirinu prozora.
@{b}ALT + LEVO@{ub}    - Skace na krajnji levi rub dokumenta.
@{b}ALT + DESNO@{ub}   - Skace na krajnji desni rub dokumenta.

@endnode

@node "HELP_MOUSE" "AmigaGuideź Help: Mis"

@{b}KLIK@{ub} iznad hipertekst oznake ce skociti na za to vezanu temu.

@endnode

