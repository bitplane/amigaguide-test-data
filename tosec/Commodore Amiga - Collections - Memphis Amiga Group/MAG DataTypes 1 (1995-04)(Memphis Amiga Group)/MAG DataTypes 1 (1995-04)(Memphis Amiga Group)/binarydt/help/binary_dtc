@node "binary.datatype" "binary.datatype/binary.datatype"

    @{b}NAME@{ub}
        binary.datatype -- data type for any binary file

    @{b}FUNCTION@{ub}
        The binary data type, a base-class of all binary data, is used to
        load any binary file and displays the contents of the file in hex
        format.

    @{b}PREFS@{ub}
        The data type tries to load the prefs file first from
        "PROGDIR:Prefs/binary.prefs","PROGDIR:binary.prefs" and then
        "ENV:DataTypes/binary.prefs" on each @{"OM_NEW" link "AG:SysInc/intuition/classusr.h/main" 63} method to set up the
        attributes !
        Up from version 39.10 it uses the @{"ReadArgs()" link "dos/ReadArgs()"} function to parse the
        prefs file. The template is :

        NOASCII/S,NOWRAP/S,NONE/S,@{"BYTE" link "AG:SysInc/exec/types.h/main" 43}/S,@{"WORD" link "AG:SysInc/exec/types.h/main" 39}/S,@{"LONG" link "AG:SysInc/exec/types.h/main" 36}/S,BPL=BYTESPERLINE/N/K

        NOASCII   - sets @{"BDTA_ShowASCII" link "datatypes/binaryclass.h/main" 53} to @{"FALSE" link "AG:SysInc/exec/types.h/main" 76}
        NOWRAP    - sets @{"BDTA_DisplayWrap" link "datatypes/binaryclass.h/main" 59} to @{"FALSE" link "AG:SysInc/exec/types.h/main" 76}
        NONE      - sets @{"BDTA_DisplayHex" link "datatypes/binaryclass.h/main" 48} to @{"BDTDH_NONE" link "datatypes/binaryclass.h/main" 66}
        @{"BYTE" link "AG:SysInc/exec/types.h/main" 43}      - sets @{"BDTA_DisplayHex" link "datatypes/binaryclass.h/main" 48} to @{"BDTDH_BYTE" link "datatypes/binaryclass.h/main" 67}
        @{"WORD" link "AG:SysInc/exec/types.h/main" 39}      - sets @{"BDTA_DisplayHex" link "datatypes/binaryclass.h/main" 48} to @{"BDTDH_WORD" link "datatypes/binaryclass.h/main" 68}
        @{"LONG" link "AG:SysInc/exec/types.h/main" 36}      - sets @{"BDTA_DisplayHex" link "datatypes/binaryclass.h/main" 48} to @{"BDTDH_LONG" link "datatypes/binaryclass.h/main" 69}
        BYTESPERLINE <bpl> or
        BPL <bpl> - sets @{"BDTA_BytesPerLine" link "datatypes/binaryclass.h/main" 43} to <bpl> bytes

        The options can be on several lines !

    @{b}METHODS@{ub}
        @{"OM_NEW" link "AG:SysInc/intuition/classusr.h/main" 63} -- Create a new text object from a binary file in hex mode.

        @{"OM_DISPOSE" link "AG:SysInc/intuition/classusr.h/main" 64} -- dispose a object

        @{"OM_GET" link "AG:SysInc/intuition/classusr.h/main" 66} -- get a attribute of the object

        @{"OM_SET" link "AG:SysInc/intuition/classusr.h/main" 65} -- set attributes of the object

        @{"OM_UPDATE" link "AG:SysInc/intuition/classusr.h/main" 70} -- update some attributes of the object

        @{"GM_LAYOUT" link "AG:SysInc/intuition/gadgetclass.h/main" 199} -- Method to layout the hex text

        @{"GM_RENDER" link "AG:SysInc/intuition/gadgetclass.h/main" 191} -- draw the object

        @{"DTM_WRITE" link "AG:SysInc/datatypes/datatypesclass.h/main" 285} -- @{"DTWM_RAW" link "AG:SysInc/datatypes/datatypesclass.h/main" 429} mode is supported

        @{"DTM_PRINT" link "AG:SysInc/datatypes/datatypesclass.h/main" 272} -- prints the hex text

    @{b}TAGS@{ub}
        BDTA_Buffer -- (@{"UBYTE" link "AG:SysInc/exec/types.h/main" 47} *) pointer to the buffer, which should be
            displayed.
            Applicability is (ISG).

        @{"BDTA_BufferLen" link "datatypes/binaryclass.h/main" 38} -- (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) length of the buffer supplied with
            BDTA_Buffer tag. This must be given if the buffer tag is
            specified.
            Applicability is (ISG).

        @{"BDTA_BytesPerLine" link "datatypes/binaryclass.h/main" 43} -- (@{"UWORD" link "AG:SysInc/exec/types.h/main" 40}) number of bytes per line.
            If @{"BDTA_DisplayHex" link "datatypes/binaryclass.h/main" 48} is @{"BDTDH_WORD" link "datatypes/binaryclass.h/main" 68} it must be a multiply of 2,
            if it is @{"BDTDH_LONG" link "datatypes/binaryclass.h/main" 69} it must be a multiply of 4 !
            Default is 32.
            Applicability is (ISGNU).

        @{"BDTA_DisplayHex" link "datatypes/binaryclass.h/main" 48} -- (@{"UWORD" link "AG:SysInc/exec/types.h/main" 40}) type of the display. The following types
            are supported : @{"BDTDH_NONE" link "datatypes/binaryclass.h/main" 66}  - displays no hex values
                            @{"BDTDH_BYTE" link "datatypes/binaryclass.h/main" 67}  - displays each byte in hex ( 8 bit)
                            @{"BDTDH_WORD" link "datatypes/binaryclass.h/main" 68}  - displays each word in hex (16 bit)
                            @{"BDTDH_LONG" link "datatypes/binaryclass.h/main" 69}  - displays each long in hex (32 bit)
            Default is @{"BDTDH_LONG" link "datatypes/binaryclass.h/main" 69}.
            Applicability is (ISGNU).

        @{"BDTA_ShowASCII" link "datatypes/binaryclass.h/main" 53} -- (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) display at the end of the line the
            appropriate ASCII string !
            Default is @{"TRUE" link "AG:SysInc/exec/types.h/main" 73}.
            Applicability is (ISGNU).

        @{"BDTA_DisplayWrap" link "datatypes/binaryclass.h/main" 59} -- (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) the @{"BDTA_BytesPerLine" link "datatypes/binaryclass.h/main" 43} are ignored and the
            byte number is retrieved from the object width !
            Default is @{"TRUE" link "AG:SysInc/exec/types.h/main" 73}.
            Applicability is (ISGNU).

    @{b}BUGS@{ub}
        At the moment proportional fonts can't be handled.

    @{b}SEE ALSO@{ub}
        datatypesclass (where ?)


@endnode
