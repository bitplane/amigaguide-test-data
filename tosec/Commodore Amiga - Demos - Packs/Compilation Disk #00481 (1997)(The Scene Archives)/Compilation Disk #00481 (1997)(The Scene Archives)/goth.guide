                  @{"GRYZOR/DPL-INTERVIEW BY THE LAST SWEDE!" LINK INTGRYZOR}

  @{FG FILL}@{B}׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳@{FG TEXT}@{UB}

                  @{"HIJACKER/CLS-INTERVIEW BY SLASH/CITRON." LINK INTHIJACK}

  @{B}׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳=׳X׳@{UB}
