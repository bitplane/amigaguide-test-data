@node "CanDo_charstobegofline" "Let {String}=CharsToBegOfLine"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {String}=CharsToBegOfLine

@{fg highlight}Description...@{fg text}

  The characters before the cursor on the current line, but not including
the character that the cursor is on.
  
  SEE ALSO: @{" CharsToEndOfLine " link "CanDo_CharsToEndOfLine"}.

@endnode

@node "CanDo_charstoendofline" "Let {String}=CharsToEndOfLine"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {String}=CharsToEndOfLine

@{fg highlight}Description...@{fg text}

  The characters after the cursor on the current line, but not including
the character that the cursor is on.
  
  SEE ALSO: @{" CharsToBegOfLine " link "CanDo_CharsToBegOfLine"}.

@endnode

@node "CanDo_clear" "Clear <flags>"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Clear <flags>

@{fg highlight}Description...@{fg text}

  If the flag is DOCUMENT, then this command will clear out the whole
document; if the flag is LINE, it will clear only the current line.
  
  SEE ALSO: @{" Delete " link "CanDo_Delete"}.

@endnode

@node "CanDo_delete" "Delete <flags> [,{Count}]"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Delete <flags> [,{Count}]

@{fg highlight}Description...@{fg text}

  This command will delete parts of your current document.  The flags
include CHARACTER, CHARACTERS, LINE, TOSTARTOFLINE and TOENDOFLINE.

@endnode

@node "CanDo_documentname" "Let {DocumentBufferName}=DocumentName"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {DocumentBufferName}=DocumentName

@{fg highlight}Description...@{fg text}

  This returns the buffer name of the current document.
  
  SEE ALSO: @{" WorkWithDocument " link "CanDo_WorkWithDocument"}.

@endnode

@node "CanDo_insertdocument" "InsertDocument {SourceDocumentName} [,{StartingLine} [,{LineCount}]]"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  InsertDocument {SourceDocumentName} [,{StartingLine} [,{LineCount}]]

@{fg highlight}Description...@{fg text}

  Inserts text from the specified document into the current document at the
current cursor position.  Optionally, a start line and the number of lines
to copy can be specified.
  
  SEE ALSO: @{" Type " link "CanDo_Type"}.

@endnode

@node "CanDo_FilterDocument" "FilterDocument {pattern}"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  FilterDocument {pattern}

@{fg highlight}Description...@{fg text}

  Each line in the current document will be tested against the provided DOS
pattern.  Those lines which do not fit the pattern will be deleted.
  
  SEE ALSO: @{" PatternMatch " link "CanDo_PatternMatch"}.

@endnode

@node "CanDo_lengthofline" "Let {Integer}=LengthOfLine"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {Integer}=LengthOfLine

@{fg highlight}Description...@{fg text}

  This returns the number of characters in the current document line.

@endnode

@node "CanDo_linesindocument" "Let {Integer}=LinesInDocument"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {Integer}=LinesInDocument

@{fg highlight}Description...@{fg text}

  This returns the number of lines in the current document.

@endnode

@node "CanDo_loaddocument" "LoadDocument {FilePath} [,{DocumentBufferName} [,<loadflags>]]"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  LoadDocument {FilePath} [,{DocumentBufferName} [,<loadflags>]]

@{fg highlight}Description...@{fg text}

  Preload a document, either FTXT or ASCII.  See the manual for a full
description of this command.
  
  SEE ALSO: @{" SaveDocument " link "CanDo_SaveDocument"}.

@endnode

@node "CanDo_makedocument" "MakeDocument {DocumentBufferName}"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  MakeDocument {DocumentBufferName}

@{fg highlight}Description...@{fg text}

  This command makes an empty document buffer with the name specified.
  
  SEE ALSO: @{" WorkWithDocument " link "CanDo_WorkWithDocument"}.

@endnode

@node "CanDo_movecursor" "MoveCursor <directionflags> [,{Count}]"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  MoveCursor <directionflags> [,{Count}]

@{fg highlight}Description...@{fg text}

  Moves the cursor, in the given direction, in the document.  The direction
flags are UP, DOWN, LEFT and RIGHT.  You may also specify the number of
times to move.
  
  SEE ALSO: @{" MoveCursorTo " link "CanDo_MoveCursorTo"}.

@endnode

@node "CanDo_movecursorto" "MoveCursorTo <flags> [,{Count}]"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  MoveCursorTo <flags> [,{Count}]

@{fg highlight}Description...@{fg text}

  Moves the cursor around in the document.  Flags include:  STARTOF and
ENDOF modifiers and DOCUMENT, LINE, NEXTWORD, THISWORD and PREVIOUSWORD
which specify the scope of the movement.  You may also specify the number
of times to move.

  SEE ALSO: @{" MoveCursor " link "CanDo_MoveCursor"}.

@endnode

@node "CanDo_newline" "NewLine"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  NewLine

@{fg highlight}Description...@{fg text}

  Has the same effect as moving to the end of the current line and hitting
the RETURN key.
  
  SEE ALSO: @{" SplitLine " link "CanDo_SplitLine"}.

@endnode

@node "CanDo_positiononline" "PositionOnLine {LineNumber}"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  PositionOnLine {LineNumber}

@{fg highlight}Description...@{fg text}

  Move the cursor to the specified line.
  
  SEE ALSO: @{" TheLineNumber " link "CanDo_TheLineNumber"}.

@endnode

@node "CanDo_replace" "Replace {SearchString}, {ReplaceString} [,<flags>]"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Replace {SearchString}, {ReplaceString} [,<flags>]

@{fg highlight}Description...@{fg text}

  Does a search and replace in the current document using the given
strings.  See the manual for a full description of this command.
  
  SEE ALSO: @{" SearchFor " link "CanDo_SearchFor"} and @{" SearchFound " link "CanDo_SearchFound"}.

@endnode

@node "CanDo_savedocument" "SaveDocument {DocumentBufferName} [,{FilePath} [,<flags>]]"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  SaveDocument {DocumentBufferName} [,{FilePath} [,<flags>]]

@{fg highlight}Description...@{fg text}

  Saves the specified document to either its default, original, filepath or
to the given filepath.  Optionally, you may specify the way to save the
document:  either FTXT or ASCII.
  
  SEE ALSO: @{" LoadDocument " link "CanDo_LoadDocument"}.

@endnode

@node "CanDo_searchfor" "SearchFor {SearchString} [,<flags>]"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  SearchFor {SearchString} [,<flags>]

@{fg highlight}Description...@{fg text}

  This command searches the current document for the specified string.  See
the manual for a full description of this command.
  
  SEE ALSO: @{" Replace " link "CanDo_Replace"} and @{" SearchFound " link "CanDo_SearchFound"}.

@endnode

@node "CanDo_searchfound" "Let {Logical}=SearchFound"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {Logical}=SearchFound

@{fg highlight}Description...@{fg text}

  This variable has many uses and is set by many commands and functions.
The document commands @{" SearchFor " link "CanDo_SearchFor"} and @{" Replace " link "CanDo_Replace"} will set this variable to
true if they succeed in finding their search strings.  Also, the database
system's functions @{" SearchArray " link "CanDo_SearchArray"}, @{" PreviousArrayIndex " link "CanDo_PreviousArrayIndex"}, @{" FirstArrayIndex " link "CanDo_FirstArrayIndex"}
and @{" LastArrayIndex " link "CanDo_LastArrayIndex"} will set the SearchFound variable if they succeed.

@endnode

@node "CanDo_setworddelimiters" "SetWordDelimiters {WordDelimiters}"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  SetWordDelimiters {WordDelimiters}

@{fg highlight}Description...@{fg text}

  This defines the current document's word delimiter character set.  This
may change the results of many document commands, functions and variables.
  
  SEE ALSO: @{" TheWordDelimiters " link "CanDo_TheWordDelimiters"} and @{" TheWord " link "CanDo_TheWord"}.

@endnode

@node "CanDo_sizeofdocument" "Let {Integer}=SizeOfDocument"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {Integer}=SizeOfDocument

@{fg highlight}Description...@{fg text}

  This returns the size in characters of the current document.

@endnode

@node "CanDo_sortdocument" "SortDocument <flags> [,{StartingColumn}]"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  SortDocument <flags> [,{StartingColumn}]

@{fg highlight}Description...@{fg text}

  This command sorts the current document.  See the manual for a full
description of this command.

@endnode

@node "CanDo_splitline" "SplitLine [{Count}]"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  SplitLine [{Count}]

@{fg highlight}Description...@{fg text}

  Has the same effect as a RETURN key in the current document.  You may
also specify the number of times to do this.
  
  SEE ALSO: @{" NewLine " link "CanDo_NewLine"}.

@endnode

@node "CanDo_textfromdocument" "Let {String}=TextFromDocument(DocumentName)"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {String}=TextFromDocument(DocumentName)

@{fg highlight}Description...@{fg text}

  This returns the contents of a document as a single, sometimes large,
text string.  See the manual for a full description of this function.

@endnode

@node "CanDo_thecharacter" "Let {String}=TheCharacter"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {String}=TheCharacter

@{fg highlight}Description...@{fg text}

  This returns the character that the document cursor is on.  If the cursor
is at the end of the document, a @{" Nothing " link "CanDo_Nothing"} is returned.

@endnode

@node "CanDo_thecolumnnumber" "Let {Integer}=TheColumnNumber"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {Integer}=TheColumnNumber

@{fg highlight}Description...@{fg text}

  This returns the current column number in the document that the cursor is
on.

@endnode

@node "CanDo_theline" "Let {String}=TheLine"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {String}=TheLine

@{fg highlight}Description...@{fg text}

  This returns the line that the document cursor is on.  If the cursor is
on an empty line then a @{" Nothing " link "CanDo_Nothing"} is returned.

@endnode

@node "CanDo_thelinenumber" "Let {Integer}=TheLineNumber"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {Integer}=TheLineNumber

@{fg highlight}Description...@{fg text}

  This returns the current line number in the document that the cursor is
on.

@endnode

@node "CanDo_theword" "Let {String}=TheWord"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {String}=TheWord

@{fg highlight}Description...@{fg text}

  This returns the word that the document cursor is on.  If the cursor is
on an empty line then a @{" Nothing " link "CanDo_Nothing"} is returned.  Remember that what this
variable returns depends on how @{" TheWordDelimiters " link "CanDo_TheWordDelimiters"} is set up.

@endnode

@node "CanDo_theworddelimiters" "Let {String}=TheWordDelimiters"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Let {String}=TheWordDelimiters

@{fg highlight}Description...@{fg text}

  This returns the current document's word delimiters character set.
  
  SEE ALSO: @{" SetWordDelimiters " link "CanDo_SetWordDelimiters"}.

@endnode

@node "CanDo_type" "Type {String} [,<flag>]"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  Type {String} [,<flag>]

@{fg highlight}Description...@{fg text}

  This command types the given string into the current document.  If the
NEWLINE flag is given, then a RETURN is typed at the end of the string.

@endnode

@node "CanDo_workwithdocument" "WorkWithDocument {DocumentBufferName}"
@toc "CanDo_Documents_Index"
@{fg highlight}Command...@{fg text}

  WorkWithDocument {DocumentBufferName}

@{fg highlight}Description...@{fg text}

  All subsequent document commands, functions and variables will use the
specified DocumentBufferName as their current document.
  
  SEE ALSO: @{" MakeDocument " link "CanDo_MakeDocument"}.

@endnode

