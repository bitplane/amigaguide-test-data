@toc "CanDo_LexiconMain"
@{fg highlight}Available Topics...@{fg text}

  Variable @{" =AnyChangedBuffers             " link "CanDo_AnyChangedBuffers"}
  Function @{" =BufferType()                  " link "CanDo_BufferType"}
  Command  @{" Flush                          " link "CanDo_Flush"}
  Command  @{" FlushAll                       " link "CanDo_FlushAll"}
  Command  @{" GetBufferInfo                  " link "CanDo_GetBufferInfo"}
  Command  @{" InsertBufferList               " link "CanDo_InsertBufferList"}
