@node "CanDo_ARexx_Index" "ARexx Commands, Functions and Variables"
@toc "CanDo_LexiconMain"
@{fg highlight}Available Topics...@{fg text}

  Variable @{" =CurrentListenTo               " link "CanDo_CurrentListenTo"}
  Variable @{" =CurrentSpeakTo                " link "CanDo_CurrentSpeakTo"}
  Command  @{" InsertMessagePortList          " link "CanDo_InsertMessagePortList"}
  Command  @{" ListenTo                       " link "CanDo_ListenTo"}
  Variable @{" =MessageErrorCode              " link "CanDo_MessageErrorCode"}
  Variable @{" =MessageReturned               " link "CanDo_MessageReturned"}
  Command  @{" ReplyARexxWith                 " link "CanDo_ReplyARexxWith"}
  Command  @{" SendMessage                    " link "CanDo_SendMessage"}
  Command  @{" SpeakTo                        " link "CanDo_SpeakTo"}
  Variable @{" =TheMessage                    " link "CanDo_TheMessage"}
@endnode

@node "CanDo_currentlistento" "Let {ARexxPortName}=CurrentListenTo"
@toc "CanDo_ARexx_Index"
@{fg highlight}Command...@{fg text}

  Let {ARexxPortName}=CurrentListenTo

@{fg highlight}Description...@{fg text}

  Returns the "PortName" of the most recent ListenTo.
  
  SEE ALSO: @{" ListenTo " link "CanDo_ListenTo"}

@endnode

@node "CanDo_currentspeakto" "Let {ArexxPortName}=CurrentSpeakTo"
@toc "CanDo_ARexx_Index"
@{fg highlight}Command...@{fg text}

  Let {ArexxPortName}=CurrentSpeakTo

@{fg highlight}Description...@{fg text}

  Returns the "PortName" of the most recent SpeakTo.
  
  SEE ALSO: @{" SpeakTo " link "CanDo_SpeakTo"}

@endnode

@node "CanDo_insertmessageportlist" "InsertMessagePortList"
@toc "CanDo_ARexx_Index"
@{fg highlight}Command...@{fg text}

  InsertMessagePortList

@{fg highlight}Description...@{fg text}

  Types the list of all Public Message Ports into the current document.
Caution:  not all ports listed are valid ARexx Ports.
  
  SEE ALSO: @{" SpeakTo " link "CanDo_SpeakTo"}

@endnode

@node "CanDo_listento" "ListenTo {ARexxPortName}"
@toc "CanDo_ARexx_Index"
@{fg highlight}Command...@{fg text}

  ListenTo {ARexxPortName}

@{fg highlight}Description...@{fg text}

  Specifies the name of the "PortName" for receiving messages.
  
  SEE ALSO: @{" SpeakTo " link "CanDo_SpeakTo"}, @{" CurrentListenTo " link "CanDo_CurrentListenTo"} and @{" InsertMessagePortList " link "CanDo_InsertMessagePortList"}

@endnode

@node "CanDo_messageerrorcode" "Let {ErrorCode}=MessageErrorCode"
@toc "CanDo_ARexx_Index"
@{fg highlight}Command...@{fg text}

  Let {ErrorCode}=MessageErrorCode

@{fg highlight}Description...@{fg text}

  The error code which was returned from the last @{" SendMessage " link "CanDo_SendMessage"} command
used.  If this was a call to another CanDo application, that application
replied with @{" ReplyARexxWith " link "CanDo_ReplyARexxWith"}.
  
  SEE ALSO: @{" MessageReturned " link "CanDo_MessageReturned"}.

@endnode

@node "CanDo_messagereturned" "Let {Message}=MessageReturned"
@toc "CanDo_ARexx_Index"
@{fg highlight}Command...@{fg text}

  Let {Message}=MessageReturned

@{fg highlight}Description...@{fg text}

  The message which was returned from the last @{" SendMessage " link "CanDo_SendMessage"} command used.
If this was a call to another CanDo application, that application replied
with @{" ReplyARexxWith " link "CanDo_ReplyARexxWith"}.
  
  SEE ALSO: @{" MessageErrorCode " link "CanDo_MessageErrorCode"}.

@endnode

@node "CanDo_replyarexxwith" "ReplyARexxWith <flags> [,{Message or ErrorCode}]"
@toc "CanDo_ARexx_Index"
@{fg highlight}Command...@{fg text}

  ReplyARexxWith <flags> [,{Message or ErrorCode}]

@{fg highlight}Description...@{fg text}

  This command is used to reply to ARexx messages sent to this CanDo
application.  This command can only be used by a script that is used by an
ARexx Object.
  
  Flag        @{" MessageErrorCode " link "CanDo_MessageErrorCode"}    @{" MessageReturned " link "CanDo_MessageReturned"}
  ----        -------------------    ------------------
  NOERROR             0                   nothing
  ERROR        5 or {ErrorCode}           nothing
  MESSAGE             0             nothing or {Message}

  SEE ALSO: @{" SendMessage " link "CanDo_SendMessage"}.

@endnode

@node "CanDo_sendmessage" "SendMessage {Message} [,<flags>]"
@toc "CanDo_ARexx_Index"
@{fg highlight}Command...@{fg text}

  SendMessage {Message} [,<flags>]

@{fg highlight}Description...@{fg text}

  Sends an ARexx message to the port specified by the @{" SpeakTo " link "CanDo_SpeakTo"} command.
If no flags are given, then the command will wait for a reply before
continuing.  The reply will be found in @{" MessageReturned " link "CanDo_MessageReturned"}.

  If NORESULTS is specified, then no message will be returned, but the
script will wait for a reply, to get the @{" MessageErrorCode " link "CanDo_MessageErrorCode"}.  If ASYNC is
used instead, the script will not wait for the reply.
  
  SEE ALSO: @{" ReplyARexxWith " link "CanDo_ReplyARexxWith"}.

@endnode

@node "CanDo_speakto" "SpeakTo {ARexxPortName}"
@toc "CanDo_ARexx_Index"
@{fg highlight}Command...@{fg text}

  SpeakTo {ARexxPortName}

@{fg highlight}Description...@{fg text}

  Tells CanDo the name of the ARexx port to send messages to.
  
  SEE ALSO: @{" ListenTo " link "CanDo_ListenTo"}, @{" CurrentSpeakTo " link "CanDo_CurrentSpeakTo"}, @{" SendMessage " link "CanDo_SendMessage"} and
            @{" InsertMessagePortList " link "CanDo_InsertMessagePortList"}
@endnode

@node "CanDo_themessage" "Let {string}=TheMessage"
@toc "CanDo_ARexx_Index"
@{fg highlight}Command...@{fg text}

  Let {string}=TheMessage

@{fg highlight}Description...@{fg text}

  This is the last message received by an ARexx Object.
  
  SEE ALSO: @{" ListenTo " link "CanDo_ListenTo"} and @{" ReplyARexxWith " link "CanDo_ReplyARexxWith"}.

@endnode

