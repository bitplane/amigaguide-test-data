@node "CanDo_areacopy" "AreaCopy {X}, {Y}, {Width}, {Height}, {DestX}, {DestY}"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  AreaCopy {X}, {Y}, {Width}, {Height}, {DestX}, {DestY}

@{fg highlight}Description...@{fg text}

  Copies an area of the window with the upper corner at {X},{Y}, and of the
given size {Width}, {Height}, to the location with an upper corner at
{DestX},{DestY}.
  
  SEE ALSO: @{" AreaScroll " link "CanDo_AreaScroll"}.

@endnode

@node "CanDo_areascroll" "AreaScroll {X}, {Y}, {Width}, {Height}, {DeltaX}, {DeltaY}"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  AreaScroll {X}, {Y}, {Width}, {Height}, {DeltaX}, {DeltaY}

@{fg highlight}Description...@{fg text}

  Scrolls an area of the window with the upper corner at {X},{X} and of the
given size {Width}, {Height} by the distance given in {DeltaX},{DeltaY}.
  
  SEE ALSO: @{" AreaCopy " link "CanDo_AreaCopy"}.

@endnode

@node "CanDo_clearclipregions" "ClearClipRegions"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  ClearClipRegions

@{fg highlight}Description...@{fg text}

  Removes any and all clip regions created by the @{" InstallClipRegion " link "CanDo_InstallClipRegion"}
command.  See the manual for a full description of this command.

@endnode

@node "CanDo_clipbrush" "ClipBrush {X}, {Y}, {Width}, {Height}, {BrushBufferName} [,<memflag>]"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  ClipBrush {X}, {Y}, {Width}, {Height}, {BrushBufferName} [,<memflag>]

@{fg highlight}Description...@{fg text}

  Grabs a portion of the current card's window and stores it as a brush for
future use.  See the manual for a full description of this command.
  
  SEE ALSO: @{" ShowBrush " link "CanDo_ShowBrush"}, @{" SaveBrush " link "CanDo_SaveBrush"} and @{" AreaCopy " link "CanDo_AreaCopy"}.

@endnode

@node "CanDo_clippicture" "ClipPicture {ImageBufferName} [,<memflag>]"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  ClipPicture {ImageBufferName} [,<memflag>]

@{fg highlight}Description...@{fg text}

  Grabs the current card's window and stores it as a picture for future
use.  See the manual for a full description of this command.
  
  SEE ALSO: @{" ShowPicture " link "CanDo_ShowPicture"} and @{" SavePicture " link "CanDo_SavePicture"}.

@endnode

@node "CanDo_cliptransparentcolor" "Let {Integer}=ClipTransparentColor"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  Let {Integer}=ClipTransparentColor

@{fg highlight}Description...@{fg text}

  This returns the current transparent color register for brush and picture
clipping.
  
  SEE ALSO: @{" ClipBrush " link "CanDo_ClipBrush"}, @{" ClipPicture " link "CanDo_ClipPicture"} and @{" SetClipTransparentColor " link "CanDo_SetClipTransparentColor"}.

@endnode

@node "CanDo_cyclecolors" "CycleColors {FromColorReg}, {ToColorReg} [,<directionflags>]"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  CycleColors {FromColorReg}, {ToColorReg} [,<directionflags>]

@{fg highlight}Description...@{fg text}

  Cycles the color registers in the current window's palette.  The range is
from the {FromColorReg} to the {ToColorReg}.  See the manual for a full
description of this command.

@endnode

@node "CanDo_drawborder" "DrawBorder {X}, {Y}, {Width}, {Height}, <borderflags> [,{Pen1} [,{Pen2}]]"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  DrawBorder {X}, {Y}, {Width}, {Height}, <borderflags> [,{Pen1} [,{Pen2}]]

@{fg highlight}Description...@{fg text}

Draws a border rectangle according to the specified border style.

  BorderFlags:

  BOX, OUTLINE, DOUBLEOUTLINE, EMBOSSED,
  HEAVYEMBOSSED, SHADOW, BEVEL, DOUBLEBEVEL,
  BUTTONOUT, BUTTONIN, CHECKNO, CHECKYES,
  ROLLO, UP, DOWN, RIGHT and LEFT.

@endnode

@node "CanDo_gettextdimensions" "GetTextDimensions {String}, <LengthVarName>, <HeightVarName> [,<BaselineVarName>]"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  GetTextDimensions {String}, <LengthVarName>, <HeightVarName> [,<BaselineVarName>]

@{fg highlight}Description...@{fg text}

  This command will fill in the given variables with the size of the string
given under the current font and style settings.
  
  SEE ALSO: @{" SetPrintFont " link "CanDo_SetPrintFont"} and @{" SetPrintStyle " link "CanDo_SetPrintStyle"}.

@endnode

@node "CanDo_installclipregion" "InstallClipRegion {X}, {Y}, {Width}, {Height} [,<methodflags>]"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  InstallClipRegion {X}, {Y}, {Width}, {Height} [,<methodflags>]

@{fg highlight}Description...@{fg text}

  Creates a ClipRegion at the given location.  See the manual for a full
description of this command.
  
  SEE ALSO: @{" ClearClipRegions " link "CanDo_ClearClipRegions"}.

@endnode

@node "CanDo_loadpalette" "LoadPalette {FilePath} [,{PaletteBufferName} [,<loadflags>]]"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  LoadPalette {FilePath} [,{PaletteBufferName} [,<loadflags>]]

@{fg highlight}Description...@{fg text}

  This will load only the palette part of a picture or brush.  The
resultant buffer can be used only by the @{" ShowPalette " link "CanDo_ShowPalette"} command.

@endnode

@node "CanDo_savebrush" "SaveBrush {BrushBufferName} [,{SaveFilePath}]"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  SaveBrush {BrushBufferName} [,{SaveFilePath}]

@{fg highlight}Description...@{fg text}

  Saves a brush buffer to a disk file.
  
  SEE ALSO: @{" SavePicture " link "CanDo_SavePicture"} and @{" LoadBrush " link "CanDo_LoadBrush"}.

@endnode

@node "CanDo_savepicture" "SavePicture {PictureBufferName} [,{SaveFilePath}]"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  SavePicture {PictureBufferName} [,{SaveFilePath}]

@{fg highlight}Description...@{fg text}

  Saves a picture buffer to a disk file.
  
  SEE ALSO: @{" SaveBrush " link "CanDo_SaveBrush"} and @{" LoadPicture " link "CanDo_LoadPicture"}.

@endnode

@node "CanDo_setareadrawmode" "SetAreaDrawMode <flags>"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  SetAreaDrawMode <flags>

@{fg highlight}Description...@{fg text}

  The AreaDrawMode affects only Area commands.  If set to the default of
NORMAL, areas are drawn in a solid color using @{" PenA " link "CanDo_PenA"}.  If set to
OUTLINE, the area is drawn with @{" PenA " link "CanDo_PenA"} and outlined with @{" PenO " link "CanDo_PenO"}.
  
  SEE ALSO: @{" SetPen " link "CanDo_SetPen"} and @{" SetDrawMode " link "CanDo_SetDrawMode"}.

@endnode

@node "CanDo_setcliptransparentcolor" "SetClipTransparentColor {ColorReg}"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  SetClipTransparentColor {ColorReg}

@{fg highlight}Description...@{fg text}

  Sets the background color used in a clipped brush.  This color will be
transparent if @{" Transparent " link "CanDo_Transparent"} is set ON when displayed by @{" ShowBrush " link "CanDo_ShowBrush"}.
  
  SEE ALSO: @{" ClipBrush " link "CanDo_ClipBrush"}.

@endnode

@node "CanDo_setdrawmode" "SetDrawMode <drawflags>"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  SetDrawMode <drawflags>

@{fg highlight}Description...@{fg text}

  This command changes @{" TheDrawMode " link "CanDo_TheDrawMode"}, which affects how pixels are drawn by
all drawing commands.
  
  SEE ALSO: @{" SetAreaDrawMode " link "CanDo_SetAreaDrawMode"} and @{" SetPen " link "CanDo_SetPen"}.

@endnode

@node "CanDo_showpalette" "ShowPalette {PaletteBufferName}"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  ShowPalette {PaletteBufferName}

@{fg highlight}Description...@{fg text}

  Changes the current card's window palette to the palette in the given
buffer.  The buffer may be a Picture, Brush, BrushAnim or Palette buffer.
  
  SEE ALSO: @{" SetRGB " link "CanDo_SetRGB"} and @{" LoadPalette " link "CanDo_LoadPalette"}.

@endnode

@node "CanDo_thedrawmode" "Let {string}=TheDrawMode"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  Let {string}=TheDrawMode

@{fg highlight}Description...@{fg text}

  This returns the current drawmode as a string.
  
  SEE ALSO: @{" SetDrawMode " link "CanDo_SetDrawMode"}.

@endnode

@node "CanDo_transparent" "Transparent {Logical}"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  Transparent {Logical}

@{fg highlight}Description...@{fg text}

  If this is false then brushes are shown with no transparent parts.  If it
is true then the brushes will have transparent parts; specifically,
whatever was transparent when clipped.
  
  SEE ALSO: @{" SetClipTransparentColor " link "CanDo_SetClipTransparentColor"} and @{" TransparentStatus " link "CanDo_TransparentStatus"}.

@endnode

@node "CanDo_transparentstatus" "Let {Logical}=TransparentStatus"
@toc "CanDo_Graphics Advanced_Index"
@{fg highlight}Command...@{fg text}

  Let {Logical}=TransparentStatus

@{fg highlight}Description...@{fg text}

  This returns the current status of the transparency mode.
  
  SEE ALSO: @{" Transparent " link "CanDo_Transparent"}.

@endnode

