@node "CanDo_areacircle" "AreaCircle {X}, {Y}, {Radius}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  AreaCircle {X}, {Y}, {Radius}

@{fg highlight}Description...@{fg text}

  Draw a filled Circle at position {X},{Y} with a radius of {Radius}.  The
area color will come from @{" PenA " link "CanDo_PenA"}, set with the @{" SetPen " link "CanDo_SetPen"} command.
  
  SEE ALSO: @{" DrawCircle " link "CanDo_DrawCircle"} and @{" AreaEllipse " link "CanDo_AreaEllipse"}.

@endnode

@node "CanDo_areaellipse" "AreaEllipse {X}, {Y}, {XRadius}, {YRadius}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  AreaEllipse {X}, {Y}, {XRadius}, {YRadius}

@{fg highlight}Description...@{fg text}

  Draw a filled ellipse with its center at {X},{Y}.  The {XRadius} is the
horizontal radius and {YRadius} is the vertical radius.  The area color
will come from @{" PenA " link "CanDo_PenA"}, set with the @{" SetPen " link "CanDo_SetPen"} command.
  
  SEE ALSO: @{" DrawEllipse " link "CanDo_DrawEllipse"} and @{" AreaCircle " link "CanDo_AreaCircle"}.

@endnode

@node "CanDo_areapolygon" "AreaPolygon {X1}, {Y1}, {X2}, {Y2}, {X3}, {Y3} [,up to six points]"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  AreaPolygon {X1}, {Y1}, {X2}, {Y2}, {X3}, {Y3} [,up to six points]

@{fg highlight}Description...@{fg text}

  This allows you to draw a filled polygon with 3 to 6 vertices.  The first
3 verticies are required, the other 3 are optional.  The area color will
come from @{" PenA " link "CanDo_PenA"}, set with the @{" SetPen " link "CanDo_SetPen"} command.
  
  SEE ALSO: @{" DrawPolygon " link "CanDo_DrawPolygon"}.

@endnode

@node "CanDo_arearectangle" "AreaRectangle {X}, {Y}, {Width}, {Height}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  AreaRectangle {X}, {Y}, {Width}, {Height}

@{fg highlight}Description...@{fg text}

  Draw a filled rectangle with upper-left corner at {X},{Y} and with the
given width of {Width} and height of {Height}.  The area color is @{" PenA " link "CanDo_PenA"},
set with @{" SetPen " link "CanDo_SetPen"} command.
  
  SEE ALSO: @{" DrawRectangle " link "CanDo_DrawRectangle"}.

@endnode

@node "CanDo_clearwindow" "ClearWindow [{ColorReg}]"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  ClearWindow [{ColorReg}]

@{fg highlight}Description...@{fg text}

  Clears the Window to its initial state.  If it is a picture window the
image will be redisplayed.  If it is not a picture window, then it will be
cleared to the window's background color or to the optional {ColorReg}.

@endnode

@node "CanDo_colorofpixel" "Let {ColorReg}=ColorOfPixel({X}, {Y})"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  Let {ColorReg}=ColorOfPixel({X}, {Y})

@{fg highlight}Description...@{fg text}

  This function returns an integer value of the color of the pixel at
position {X},{Y} in the current window.
  
  SEE ALSO: @{" DrawPixel " link "CanDo_DrawPixel"}.

@endnode

@node "CanDo_drawcircle" "DrawCircle {X}, {Y}, {Radius}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  DrawCircle {X}, {Y}, {Radius}

@{fg highlight}Description...@{fg text}

  Draw a hollow circle at position {X},{Y} with a radius of {Radius}.  The
draw color will come from @{" PenA " link "CanDo_PenA"}, set with the @{" SetPen " link "CanDo_SetPen"} command.
  
  SEE ALSO: @{" AreaCircle " link "CanDo_AreaCircle"} and @{" DrawEllipse " link "CanDo_DrawEllipse"}.

@endnode

@node "CanDo_drawellipse" "DrawEllipse {X}, {Y}, {XRadius}, {YRadius}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  DrawEllipse {X}, {Y}, {XRadius}, {YRadius}

@{fg highlight}Description...@{fg text}

  Draw a hollow ellipse with its center at {X},{Y}.  The {XRadius} is the
horizontal radius and {YRadius} is the vertical radius.  The draw color
will come from @{" PenA " link "CanDo_PenA"}, set with the @{" SetPen " link "CanDo_SetPen"} command.
  
  SEE ALSO: @{" AreaEllipse " link "CanDo_AreaEllipse"} and @{" DrawCircle " link "CanDo_DrawCircle"}.

@endnode

@node "CanDo_drawline" "DrawLine {X1}, {Y1}, {X2}, {Y2}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  DrawLine {X1}, {Y1}, {X2}, {Y2}

@{fg highlight}Description...@{fg text}

  Draw a line from {X1},{Y1} to {X2},{Y2}.
  
  SEE ALSO: @{" DrawTo " link "CanDo_DrawTo"} and @{" MovePen " link "CanDo_MovePen"}.

@endnode

@node "CanDo_drawpixel" "DrawPixel {X}, {Y}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  DrawPixel {X}, {Y}

@{fg highlight}Description...@{fg text}

  Draws a single pixel at {X},{Y}.  This pixel is drawn with the color in
@{" PenA " link "CanDo_PenA"}, which is set with the @{" SetPen " link "CanDo_SetPen"} command.
  
  SEE ALSO: @{" MovePen " link "CanDo_MovePen"} and @{" ColorOfPixel " link "CanDo_ColorOfPixel"}.

@endnode

@node "CanDo_drawpolygon" "DrawPolygon {X1}, {Y1}, {X2}, {Y2}, {X3}, {Y3} [,up to six points]"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  DrawPolygon {X1}, {Y1}, {X2}, {Y2}, {X3}, {Y3} [,up to six points]

@{fg highlight}Description...@{fg text}

  This allows you to draw a hollow polygon with 3 to 6 vertices.  The first
3 verticies are required, the other 3 are optional.  The draw color will
come from @{" PenA " link "CanDo_PenA"}, set with the @{" SetPen " link "CanDo_SetPen"} command.
  
  SEE ALSO: @{" AreaPolygon " link "CanDo_AreaPolygon"}.

@endnode

@node "CanDo_drawrectangle" "DrawRectangle {X}, {Y}, {Width}, {Height}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  DrawRectangle {X}, {Y}, {Width}, {Height}

@{fg highlight}Description...@{fg text}

  Draw a hollow rectangle with upper-left corner at {X},{Y} and with the
given width of {Width} and height of {Height}.  The draw color is @{" PenA " link "CanDo_PenA"},
set with the @{" SetPen " link "CanDo_SetPen"} command.
  
  SEE ALSO: @{" AreaRectangle " link "CanDo_AreaRectangle"}.

@endnode

@node "CanDo_drawto" "DrawTo {X}, {Y}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  DrawTo {X}, {Y}

@{fg highlight}Description...@{fg text}

  Draws a line from the current pen position to {X},{Y}.  The current pen
position then becomes {X},{Y}.
  
  SEE ALSO: @{" RayTo " link "CanDo_RayTo"}, @{" MovePen " link "CanDo_MovePen"} and @{" DrawLine " link "CanDo_DrawLine"}.

@endnode

@node "CanDo_filltoborder" "FillToBorder {X}, {Y}, {ColorReg}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  FillToBorder {X}, {Y}, {ColorReg}

@{fg highlight}Description...@{fg text}

  Fill a shape starting at {X},{Y} and all the area outlined by {ColorReg}.
It fills with @{" PenA " link "CanDo_PenA"}.
  
  SEE ALSO: @{" FloodFill " link "CanDo_FloodFill"} and @{" SetPen " link "CanDo_SetPen"}.

@endnode

@node "CanDo_floodfill" "FloodFill {X}, {Y}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  FloodFill {X}, {Y}

@{fg highlight}Description...@{fg text}

  Fill a solid shape starting at {X},{Y} with color @{" PenA " link "CanDo_PenA"}.  The shape is
determined by the color at {X},{Y}.
  
  SEE ALSO: @{" FillToBorder " link "CanDo_FillToBorder"} and @{" SetPen " link "CanDo_SetPen"}.

@endnode

@node "CanDo_getrgb" "GetRGB {ColorReg}, <RedVar>, <GreenVar>, <BlueVar>"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  GetRGB {ColorReg}, <RedVar>, <GreenVar>, <BlueVar>

@{fg highlight}Description...@{fg text}

  Assign the red, green, and blue components of color register {ColorReg}
to the three given variables.
  
  SEE ALSO: @{" SetRGB " link "CanDo_SetRGB"} and @{" SetPen " link "CanDo_SetPen"}.

@endnode

@node "CanDo_loadbrush" "LoadBrush {FilePath} [,{BrushBufferName} [,<loadflags>]]"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  LoadBrush {FilePath} [,{BrushBufferName} [,<loadflags>]]

@{fg highlight}Description...@{fg text}

  Preload a DeluxePaint style Brush.
  
  SEE ALSO: @{" ShowBrush " link "CanDo_ShowBrush"} and @{" SaveBrush " link "CanDo_SaveBrush"}.

@endnode

@node "CanDo_loadpicture" "LoadPicture {FilePath} [,{PictureBufferName} [,<loadflags>]]"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  LoadPicture {FilePath} [,{PictureBufferName} [,<loadflags>]]

@{fg highlight}Description...@{fg text}

  Preload a DeluxePaint style Picture.  See the manual for a full
description of this command.
  
  SEE ALSO: @{" ShowPicture " link "CanDo_ShowPicture"} and @{" SavePicture " link "CanDo_SavePicture"}.

@endnode

@node "CanDo_movepen" "MovePen {X}, {Y}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  MovePen {X}, {Y}

@{fg highlight}Description...@{fg text}

  Move the current pen position to {X},{Y} without drawing.
  
  SEE ALSO: @{" DrawTo " link "CanDo_DrawTo"} and @{" RayTo " link "CanDo_RayTo"}.

@endnode

@node "CanDo_pena" "Let {ColorReg}=PenA"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  Let {ColorReg}=PenA

@{fg highlight}Description...@{fg text}

  This returns the current color register associated with PenA.  This is
normally used as the drawing pen.
  
  SEE ALSO: @{" SetPen " link "CanDo_SetPen"}, @{" PenB " link "CanDo_PenB"} and @{" PenO " link "CanDo_PenO"}.

@endnode

@node "CanDo_penb" "Let {ColorReg}=PenB"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  Let {ColorReg}=PenB

@{fg highlight}Description...@{fg text}

  This returns the current color register associated with PenB.  This is
used as an extra color pen by some graphic operations.
  
  SEE ALSO: @{" SetPen " link "CanDo_SetPen"}, @{" PenA " link "CanDo_PenA"} and @{" PenO " link "CanDo_PenO"}.

@endnode

@node "CanDo_peno" "Let {ColorReg}=PenO"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  Let {ColorReg}=PenO

@{fg highlight}Description...@{fg text}

  This returns the current color register associated with PenO.  This is
used as the outline pen by some graphic operations.
  
  SEE ALSO: @{" SetPen " link "CanDo_SetPen"}, @{" SetAreaMode " link "CanDo_SetAreaMode"}, @{" PenA " link "CanDo_PenA"} and @{" PenB " link "CanDo_PenB"}.

@endnode

@node "CanDo_printtext" "PrintText {String}, {X}, {Y}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  PrintText {String}, {X}, {Y}

@{fg highlight}Description...@{fg text}

  Prints the {String} using the current pen colors, print style, and font
at {X},{Y}.
  
  SEE ALSO: @{" SetPrintStyle " link "CanDo_SetPrintStyle"}, @{" SetPrintFont " link "CanDo_SetPrintFont"} and @{" SetPen " link "CanDo_SetPen"}.

@endnode

@node "CanDo_rayto" "RayTo {X}, {Y}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  RayTo {X}, {Y}

@{fg highlight}Description...@{fg text}

  Draws a line from the current pen position to {X},{Y}, but unlike the
@{" DrawTo " link "CanDo_DrawTo"} command, this command leaves the pen position where it was.
  
  SEE ALSO: @{" MovePen " link "CanDo_MovePen"} and @{" DrawLine " link "CanDo_DrawLine"}.

@endnode

@node "CanDo_setpen" "SetPen {PenAColorReg} [,{PenBColorReg} [,{PenOColorReg}]]"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  SetPen {PenAColorReg} [,{PenBColorReg} [,{PenOColorReg}]]

@{fg highlight}Description...@{fg text}

  This command sets the color register to be used by each of the three pens.
@{" PenA " link "CanDo_PenA"} must be set, while @{" PenB " link "CanDo_PenB"} and @{" PenO " link "CanDo_PenO"} are optional.
  
  SEE ALSO: @{" SetDrawMode " link "CanDo_SetDrawMode"} and @{" SetRGB " link "CanDo_SetRGB"}.

@endnode

@node "CanDo_setprintfont" "SetPrintFont {FontName}, {PointSize}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  SetPrintFont {FontName}, {PointSize}

@{fg highlight}Description...@{fg text}

  Set the print font to the font with the given name, and request the given
point size.  Under 1.3, if the font does not have that point size, the next
smallest size will be used.
  
  SEE ALSO: @{" SetPrintStyle " link "CanDo_SetPrintStyle"} and @{" PrintText " link "CanDo_PrintText"}.

@endnode

@node "CanDo_setprintstyle" "SetPrintStyle <styleflags> [,{ExtraPen1} [,{ExtraPen2}]]"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  SetPrintStyle <styleflags> [,{ExtraPen1} [,{ExtraPen2}]]

@{fg highlight}Description...@{fg text}

  This command sets up the print style for the @{" PrintText " link "CanDo_PrintText"} command.  See
the manual for a full description of this command.
  
  SEE ALSO: @{" SetPrintFont " link "CanDo_SetPrintFont"}.

@endnode

@node "CanDo_setrgb" "SetRGB {ColorReg}, {RedValue}, {GreenValue}, {BlueValue}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  SetRGB {ColorReg}, {RedValue}, {GreenValue}, {BlueValue}

@{fg highlight}Description...@{fg text}

  Assigns to color register {ColorReg} the red, green and blue values
given.  These values range from 0 to 255.
  
  SEE ALSO: @{" GetRGB " link "CanDo_GetRGB"}.

@endnode

@node "CanDo_showbrush" "ShowBrush {BrushBufferName}, {X}, {Y} [,<paletteflags> [,{MinTermValue}]]"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  ShowBrush {BrushBufferName}, {X}, {Y} [,<paletteflags> [,{MinTermValue}]]

@{fg highlight}Description...@{fg text}

  Display the brush at the {X},{Y} coordinates.  If the brush is not loaded
then CanDo will try to autoload it.  See the manual for a full description
of this command.
  
  SEE ALSO: @{" LoadBrush " link "CanDo_LoadBrush"} and @{" Transparent " link "CanDo_Transparent"}.

@endnode

@node "CanDo_showpicture" "ShowPicture {PictureBufferName}"
@toc "CanDo_Graphics_Index"
@{fg highlight}Command...@{fg text}

  ShowPicture {PictureBufferName}

@{fg highlight}Description...@{fg text}

  This will show the specified picture buffer.  If the picture is not loaded
then CanDo will try to autoload it.  See the manual for a full description
of this command.
  
  SEE ALSO: @{" LoadPicture " link "CanDo_LoadPicture"} and @{" SavePicture " link "CanDo_SavePicture"}.

@endnode

