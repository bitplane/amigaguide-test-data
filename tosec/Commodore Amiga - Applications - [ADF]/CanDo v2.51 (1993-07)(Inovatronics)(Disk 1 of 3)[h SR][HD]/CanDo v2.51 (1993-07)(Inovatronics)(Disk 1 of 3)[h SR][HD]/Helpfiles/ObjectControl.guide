@node "CanDo_attachobject" "AttachObject {ObjectName} [,{Arg1} [,up to ten arguments]]"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  AttachObject {ObjectName} [,{Arg1} [,up to ten arguments]]

@{fg highlight}Description...@{fg text}

  This will attach an object that has been detached.  This will cause an
error if the object is already attached.
  
  SEE ALSO: @{" DetachObject " link "CanDo_DetachObject"}, @{" ReattachObject " link "CanDo_ReattachObject"} and @{" ObjectAttached " link "CanDo_ObjectAttached"}.

@endnode

@node "CanDo_detachobject" "DetachObject {ObjectName}"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  DetachObject {ObjectName}

@{fg highlight}Description...@{fg text}

  Detach an object from the card.  All objects can be detached, but the
imagery of graphic objects will not be erased.  See the manual for a full
description of this command.
  
  SEE ALSO: @{" ReAttachObject " link "CanDo_ReAttachObject"} and @{" ObjectAttached " link "CanDo_ObjectAttached"}.

@endnode

@node "CanDo_disableobject" "DisableObject {ObjectName}"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  DisableObject {ObjectName}

@{fg highlight}Description...@{fg text}

  This will ghost a graphic object until the object has been enabled.  This
only works on Buttons, Fields and Menus.
  
  SEE ALSO: @{" EnableObject " link "CanDo_EnableObject"}.

@endnode

@node "CanDo_enableobject" "EnableObject {ObjectName}"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  EnableObject {ObjectName}

@{fg highlight}Description...@{fg text}

  This will enable a graphic object that has been disabled.  This will do
nothing if the object was not disabled.
  
  SEE ALSO: @{" DisableObject " link "CanDo_DisableObject"}.

@endnode

@node "CanDo_fastfeedback" "FastFeedBack {Logical}"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  FastFeedBack {Logical}

@{fg highlight}Description...@{fg text}

  Enables or disables FastFeedBack on mouse movements for an Object's Drag
script.

@endnode

@node "CanDo_getpropposition" "GetPropPosition {ObjectName}, <HorizPosVarName> [,<VertPosVarName>]"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  GetPropPosition {ObjectName}, <HorizPosVarName> [,<VertPosVarName>]

@{fg highlight}Description...@{fg text}

  This will retrieve a proportional object's positional values.
  
  SEE ALSO: @{" SetPropPosition " link "CanDo_SetPropPosition"}, @{" GetPropRange " link "CanDo_GetPropRange"} and @{" GetPropVisibleRange " link "CanDo_GetPropVisibleRange"}.

@endnode

@node "CanDo_getproprange" "GetPropRange {ObjectName}, <LowHorizVarName>, <HighHorizVarName> [,<LowVertVarName>, <HighVertVarName>]"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  GetPropRange {ObjectName}, <LowHorizVarName>, <HighHorizVarName> [,<LowVertVarName>, <HighVertVarName>]

@{fg highlight}Description...@{fg text}

  This will retrieve a proportional object's upper and lower range limits.
  
  SEE ALSO: @{" SetPropRange " link "CanDo_SetPropRange"}, @{" GetPropPosition " link "CanDo_GetPropPosition"} and @{" GetPropVisibleRange " link "CanDo_GetPropVisibleRange"}.

@endnode

@node "CanDo_getpropvisiblerange" "GetPropVisibleRange {ObjectName}, <DisplayHorizVarName> [,<DisplayVertVarName>]"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  GetPropVisibleRange {ObjectName}, <DisplayHorizVarName> [,<DisplayVertVarName>]

@{fg highlight}Description...@{fg text}

  This will retrieve a proportional object's visible size.
  
  SEE ALSO: @{" SetPropVisibleRange " link "CanDo_SetPropVisibleRange"}, @{" GetPropRange " link "CanDo_GetPropRange"} and @{" GetPropPosition " link "CanDo_GetPropPosition"}.
@endnode

@node "CanDo_integerfrom" "Let {Integer}=IntegerFrom({ObjectName})"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  Let {Integer}=IntegerFrom({ObjectName})

@{fg highlight}Description...@{fg text}

  Returns the integer currently held in the Integer Field {ObjectName}.
  
  SEE ALSO: @{" TextFrom " link "CanDo_TextFrom"} and @{" SetInteger " link "CanDo_SetInteger"}.

@endnode

@node "CanDo_keypressed" "Let {String}=KeyPressed"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  Let {String}=KeyPressed

@{fg highlight}Description...@{fg text}

  This returns the key that was pressed when used with a KeyInput object
that is looking for ANY key.
  
  SEE ALSO: @{" QualifiersPressed " link "CanDo_QualifiersPressed"}.

@endnode

@node "CanDo_moveobject" "MoveObject {ObjectName},{X},{Y}"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  MoveObject {ObjectName},{X},{Y}

@{fg highlight}Description...@{fg text}

  Moves an object in the visible window to the coordinates {X},{Y}.

@endnode

@node "CanDo_objectattached" "Let {Logical}=ObjectAttached({ObjectName})"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  Let {Logical}=ObjectAttached({ObjectName})

@{fg highlight}Description...@{fg text}

  Returns @{" True " link "CanDo_True"} if the named object is currently attached.
  
  SEE ALSO: @{" DetachObject " link "CanDo_DetachObject"} and @{" ReattachObject " link "CanDo_ReattachObject"}.

@endnode

@node "CanDo_objectname" "Let {String}=ObjectName"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  Let {String}=ObjectName

@{fg highlight}Description...@{fg text}

  This returns the name of the currently running object.

@endnode

@node "CanDo_objectstate" "Let {Logical}=ObjectState({ObjectName})"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  Let {Logical}=ObjectState({ObjectName})

@{fg highlight}Description...@{fg text}

  This indicates whether the object is currently selected.  With menus, this
also indicates if the item's checkmark is checked.
  
  SEE ALSO: @{" SetObjectState " link "CanDo_SetObjectState"}.

@endnode

@node "CanDo_qualifierspressed" "Let {String}=QualifiersPressed"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  Let {String}=QualifiersPressed

@{fg highlight}Description...@{fg text}

  A string of words, one for each qualifier pressed in the last keyboard
input, or NONE if none.  Qualifiers include:  CONTROL, CAPSLOCK, RIGHTALT,
LEFTALT, RIGHTSHIFT, LEFTSHIFT, LEFTAMIGA, RIGHTAMIGA, LEFTMOUSE,
MIDDLEMOUSE, and RIGHTMOUSE.

@endnode

@node "CanDo_reattachobject" "ReattachObject {ObjectName} [,{Arg1} [,up to ten arguments]]"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  ReattachObject {ObjectName} [,{Arg1} [,up to ten arguments]]

@{fg highlight}Description...@{fg text}

  This will attach an object that has been detached.  This will do nothing
if the object is already attached.
  
  SEE ALSO: @{" DetachObject " link "CanDo_DetachObject"} and @{" ObjectAttached " link "CanDo_ObjectAttached"}.

@endnode

@node "CanDo_refreshobject" "RefreshObject {ObjectName} ;<- only works on document objects"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  RefreshObject {ObjectName} ;<- only works on document objects

@{fg highlight}Description...@{fg text}

  Update the display of a document composed of list objects.  While this
normally occurs at the end of each script, this command forces the update
to occur during the script.  THIS SHOULD ONLY BE USED WITH DOCUMENT
OBJECTS!

@endnode

@node "CanDo_setinteger" "SetInteger {ObjectName}, {Integer}"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  SetInteger {ObjectName}, {Integer}

@{fg highlight}Description...@{fg text}

  Sets the value displayed in the Integer Field indicated by {ObjectName}
to the given {Integer}.
  
  SEE ALSO: @{" SetText " link "CanDo_SetText"} and @{" IntegerFrom " link "CanDo_IntegerFrom"}.

@endnode

@node "CanDo_setobjectstate" "SetObjectState {ObjectName}, {Logical}"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  SetObjectState {ObjectName}, {Logical}

@{fg highlight}Description...@{fg text}

  Used to deselect or select an Object.  @{" True " link "CanDo_True"} will select the Object,
@{" False " link "CanDo_False"} will deselect the Object.  If the object is a "checkable" menu item
or checkmark toggle button, this will set or clear the check mark.
  
  SEE ALSO: @{" ObjectState " link "CanDo_ObjectState"}.

@endnode

@node "CanDo_setpropposition" "SetPropPosition {ObjectName}, {HorizPos} [,{VertPos}]"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  SetPropPosition {ObjectName}, {HorizPos} [,{VertPos}]

@{fg highlight}Description...@{fg text}

  This will set a proportional object's positional values.
  
  SEE ALSO: @{" GetPropPosition " link "CanDo_GetPropPosition"}, @{" SetPropRange " link "CanDo_SetPropRange"} and @{" SetPropVisibleRange " link "CanDo_SetPropVisibleRange"}.

@endnode

@node "CanDo_setproprange" "SetPropRange {ObjectName}, {LowHoriz}, {HighHoriz} [,{LowVert}, {HighVert}]"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  SetPropRange {ObjectName}, {LowHoriz}, {HighHoriz} [,{LowVert}, {HighVert}]

@{fg highlight}Description...@{fg text}

  This will set a proportional object's upper and lower range limits.
  
  SEE ALSO: @{" GetPropRange " link "CanDo_GetPropRange"}, @{" SetPropPosition " link "CanDo_SetPropPosition"} and @{" SetPropVisibleRange " link "CanDo_SetPropVisibleRange"}.

@endnode

@node "CanDo_setpropvisiblerange" "SetPropVisibleRange {ObjectName}, {DisplayHoriz} [,{DisplayVert}]"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  SetPropVisibleRange {ObjectName}, {DisplayHoriz} [,{DisplayVert}]

@{fg highlight}Description...@{fg text}

  This will set a proportional object's visible size.
  
  SEE ALSO: @{" GetPropVisibleRange " link "CanDo_GetPropVisibleRange"}, @{" SetPropRange " link "CanDo_SetPropRange"} and @{" SetPropPosition " link "CanDo_SetPropPosition"}.
@endnode

@node "CanDo_settext" "SetText {ObjectName},{String}"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  SetText {ObjectName},{String}

@{fg highlight}Description...@{fg text}

  Sets the string displayed in the text Field indicated by {ObjectName} to
the given {String}.
  
  SEE ALSO: @{" SetInteger " link "CanDo_SetInteger"} and @{" TextFrom " link "CanDo_TextFrom"}.

@endnode

@node "CanDo_textfrom" "Let {String}=TextFrom({ObjectName})"
@toc "CanDo_Object Control_Index"
@{fg highlight}Command...@{fg text}

  Let {String}=TextFrom({ObjectName})

@{fg highlight}Description...@{fg text}

  Returns the string currently held in the Text Field {ObjectName}.
  
  SEE ALSO: @{" IntegerFrom " link "CanDo_IntegerFrom"} and @{" SetText " link "CanDo_SetText"}.

@endnode

