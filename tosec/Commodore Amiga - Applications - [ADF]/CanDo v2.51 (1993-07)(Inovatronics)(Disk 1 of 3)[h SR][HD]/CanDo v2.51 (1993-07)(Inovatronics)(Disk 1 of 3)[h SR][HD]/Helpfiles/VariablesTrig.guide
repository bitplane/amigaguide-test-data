@node "CanDo_acos" "Let {Angle}=ACos({Value})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Angle}=ACos({Value})

@{fg highlight}Description...@{fg text}

  Returns the trigonometric arccosine angle of the {Value}.
  
  SEE ALSO: @{" Cos " link "CanDo_Cos"} and @{" CosH " link "CanDo_CosH"}.

@endnode

@node "CanDo_asin" "Let {Angle}=ASin({Value})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Angle}=ASin({Value})

@{fg highlight}Description...@{fg text}

  Returns the trigonometric arcsine angle of the {Value}.
  
  SEE ALSO: @{" Sin " link "CanDo_Sin"} and @{" SinH " link "CanDo_SinH"}.

@endnode

@node "CanDo_atan" "Let {Angle}=ATan({Value})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Angle}=ATan({Value})

@{fg highlight}Description...@{fg text}

  Returns the trigonometric arctangent angle of the given {Value}.
  
  SEE ALSO: @{" Tan " link "CanDo_Tan"} and @{" TanH " link "CanDo_TanH"}.

@endnode

@node "CanDo_cos" "Let {Value}=Cos({Angle})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Value}=Cos({Angle})

@{fg highlight}Description...@{fg text}

  Returns the trigonometric cosine of the given {Angle}.
  
  SEE ALSO: @{" ACos " link "CanDo_ACos"} and @{" CosH " link "CanDo_CosH"}.

@endnode

@node "CanDo_cosh" "Let {Value}=CosH({Value})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Value}=CosH({Value})

@{fg highlight}Description...@{fg text}

  Returns the hyperbolic cosine of the {Value}.
  
  SEE ALSO: @{" Cos " link "CanDo_Cos"} and @{" ACos " link "CanDo_ACos"}.

@endnode

@node "CanDo_degtorad" "Let {RadianAngle}=DegToRad({DegreeAngle})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {RadianAngle}=DegToRad({DegreeAngle})

@{fg highlight}Description...@{fg text}

  Converts from a {DegreeAngle} into a {RadianAngle}.
  
  SEE ALSO: @{" RadToDeg " link "CanDo_RadToDeg"} and @{" SetExpression " link "CanDo_SetExpression"}.

@endnode

@node "CanDo_exp" "Let {Value}=Exp({Value})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Value}=Exp({Value})

@{fg highlight}Description...@{fg text}

  Returns the result of raising e (which is 2.71828) to the power of
{Value}.  To obtain the value of E, simply use a One for the {Value}.

@endnode

@node "CanDo_log10" "Let {Value}=Log10({Value})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Value}=Log10({Value})

@{fg highlight}Description...@{fg text}

  Returns the Logarithm in base 10 of the {Value}.
  
  SEE ALSO: @{" LogE " link "CanDo_LogE"}.

@endnode

@node "CanDo_loge" "Let {Value}=LogE({Value})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Value}=LogE({Value})

@{fg highlight}Description...@{fg text}

  Returns the natural logarithm (base e) of the {Value}.
  
  SEE ALSO: @{" Log10 " link "CanDo_Log10"}.

@endnode

@node "CanDo_pi" "Let {Value}=PI"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Value}=PI

@{fg highlight}Description...@{fg text}

  Contains the value of pi, accurate to 14 decimal places.

@endnode

@node "CanDo_radtodeg" "Let {DegreeAngle}=RadToDeg({RadianAngle})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {DegreeAngle}=RadToDeg({RadianAngle})

@{fg highlight}Description...@{fg text}

  Converts from a {RadianAngle} into a {DegreeAngle}.
  
  SEE ALSO: @{" DegToRad " link "CanDo_DegToRad"} and @{" SetExpression " link "CanDo_SetExpression"}.

@endnode

@node "CanDo_setexpression" "SetExpression <flags>"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  SetExpression <flags>

@{fg highlight}Description...@{fg text}

  Sets the mode of interpreting numbers for trigonometric operations.
CanDo defaults to RADIANS.  See the manual for a full description of this
command.

  SEE ALSO: @{" DegToRad " link "CanDo_DegToRad"} and @{" RadToDeg " link "CanDo_RadToDeg"}.

@endnode

@node "CanDo_sin" "Let {Value}=Sin({Angle})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Value}=Sin({Angle})

@{fg highlight}Description...@{fg text}

  Returns the trigonometric sine of the given {Angle}.
  
  SEE ALSO: @{" ASin " link "CanDo_ASin"} and @{" SinH " link "CanDo_SinH"}.

@endnode

@node "CanDo_sinh" "Let {Value}=SinH({Value})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Value}=SinH({Value})

@{fg highlight}Description...@{fg text}

  Returns the hyperbolic sine of the {Value}.
  
  SEE ALSO: @{" Sin " link "CanDo_Sin"} and @{" ASin " link "CanDo_ASin"}.

@endnode

@node "CanDo_tan" "Let {Value}=Tan({Angle})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Value}=Tan({Angle})

@{fg highlight}Description...@{fg text}

  Returns the trigonometric tangent of the given {Angle}.
  
  SEE ALSO: @{" ATan " link "CanDo_ATan"} and @{" TanH " link "CanDo_TanH"}.

@endnode

@node "CanDo_tanh" "Let {Value}=TanH({Value})"
@toc "CanDo_Variables, Trig_Index"
@{fg highlight}Command...@{fg text}

  Let {Value}=TanH({Value})

@{fg highlight}Description...@{fg text}

  Returns the hyperbolic tangent of the {Value}.
  
  SEE ALSO: @{" Tan " link "CanDo_Tan"} and @{" ATan " link "CanDo_ATan"}.

@endnode

