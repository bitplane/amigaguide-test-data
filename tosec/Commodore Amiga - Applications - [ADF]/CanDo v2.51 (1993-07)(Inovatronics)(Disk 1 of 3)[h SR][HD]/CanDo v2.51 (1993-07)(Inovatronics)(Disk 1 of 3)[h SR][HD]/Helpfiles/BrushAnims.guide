@node "CanDo_BrushAnims_Index" "BrushAnims Commands, Functions and Variables"
@toc "CanDo_LexiconMain"
@{fg highlight}Available Topics...@{fg text}

  Variable @{" =AnimationStatus               " link "CanDo_AnimationStatus"}
  Command  @{" BrushAnims                     " link "CanDo_BrushAnims"}
  Function @{" =FrameOfAnimation()            " link "CanDo_FrameOfAnimation"}
  Command  @{" GetBrushAnimCoordinates        " link "CanDo_GetBrushAnimCoordinates"}
  Command  @{" LoadBrushAnim                  " link "CanDo_LoadBrushAnim"}
  Command  @{" MoveBrushAnim                  " link "CanDo_MoveBrushAnim"}
  Command  @{" MoveBrushAnimTo                " link "CanDo_MoveBrushAnimTo"}
  Command  @{" RemoveBrushAnim                " link "CanDo_RemoveBrushAnim"}
  Command  @{" ResetBrushAnimFrame            " link "CanDo_ResetBrushAnimFrame"}
  Command  @{" SetBrushAnimFlags              " link "CanDo_SetBrushAnimFlags"}
  Command  @{" ShowBrushAnim                  " link "CanDo_ShowBrushAnim"}
@endnode

@node "CanDo_animationstatus" "Let {Logical}=AnimationStatus"
@toc "CanDo_BrushAnims_Index"
@{fg highlight}Command...@{fg text}

  Let {Logical}=AnimationStatus

@{fg highlight}Description...@{fg text}

  This variable returns TRUE if BrushAnim animations are currently running,
or FALSE if they are not.
  
  SEE ALSO: @{" BrushAnims " link "CanDo_BrushAnims"}.

@endnode

@node "CanDo_brushanims" "BrushAnims {Logical}"
@toc "CanDo_BrushAnims_Index"
@{fg highlight}Command...@{fg text}

  BrushAnims {Logical}

@{fg highlight}Description...@{fg text}

  This command turns ON and OFF the entire BrushAnim animation system.  If
{Logical} is FALSE, then all animations stop; likewise, if it is TRUE, then
all animations start.
  
  SEE ALSO: @{" AnimationStatus " link "CanDo_AnimationStatus"}.

@endnode

@node "CanDo_frameofanimation" "Let {FrameNumber}=FrameOfAnimation({BAnimBufferName})"
@toc "CanDo_BrushAnims_Index"
@{fg highlight}Command...@{fg text}

  Let {FrameNumber}=FrameOfAnimation({BAnimBufferName})

@{fg highlight}Description...@{fg text}

  This will return the current frame number of the specified BrushAnim
buffer.  This should be the frame being displayed, but in certain cases that
may not be true.
  
  SEE ALSO: ASYNC flag in @{" SetBrushAnimFlags " link "CanDo_SetBrushAnimFlags"}.

@endnode

@node "CanDo_getbrushanimcoordinates" "GetBrushAnimCoordinates {BAnimBufferName}, <XVarName>, <YVarName>"
@toc "CanDo_BrushAnims_Index"
@{fg highlight}Command...@{fg text}

  GetBrushAnimCoordinates {BAnimBufferName}, <XVarName>, <YVarName>

@{fg highlight}Description...@{fg text}

  This will return the current coordinates of the specified BrushAnim
buffer.  This should indicate the location of the BrushAnim, but in certain
cases this may not be true.
  
  SEE ALSO: ASYNC flag in @{" SetBrushAnimFlags " link "CanDo_SetBrushAnimFlags"}.

@endnode

@node "CanDo_loadbrushanim" "LoadBrushAnim {FilePath} [,{BAnimBufferName} [,<loadflags>]]"
@toc "CanDo_BrushAnims_Index"
@{fg highlight}Command...@{fg text}

  LoadBrushAnim {FilePath} [,{BAnimBufferName} [,<loadflags>]]

@{fg highlight}Description...@{fg text}

  Preload a DeluxePaint style AnimBrush.  See the manual for a full
description of this command.
  
  SEE ALSO: @{" ShowBrushAnim " link "CanDo_ShowBrushAnim"}.

@endnode

@node "CanDo_movebrushanim" "MoveBrushAnim {BAnimBufferName},{XVel},{YVel}[,{XAccel},{YAccel}[,{Steps}[,<flag>]]]"
@toc "CanDo_BrushAnims_Index"
@{fg highlight}Command...@{fg text}

  MoveBrushAnim {BAnimBufferName},{XVel},{YVel}[,{XAccel},{YAccel}[,{Steps}[,<flag>]]]

@{fg highlight}Description...@{fg text}

  Move a brushanim in a specific direction.  See the manual for a full
description of this command.
  
  SEE ALSO: @{" MoveBrushAnimTo " link "CanDo_MoveBrushAnimTo"} and @{" SetBrushAnimFlags " link "CanDo_SetBrushAnimFlags"}.

@endnode

@node "CanDo_movebrushanimto" "MoveBrushAnimTo {BAnimBufferName}, {DestX}, {DestY} [,{Steps} [,<flag>]]"
@toc "CanDo_BrushAnims_Index"
@{fg highlight}Command...@{fg text}

  MoveBrushAnimTo {BAnimBufferName}, {DestX}, {DestY} [,{Steps} [,<flag>]]

@{fg highlight}Description...@{fg text}

  Move a brushanim to a specific location.  See the manual for a full
description of this command.
  
  SEE ALSO: @{" MoveBrushAnim " link "CanDo_MoveBrushAnim"} and @{" SetBrushAnimFlags " link "CanDo_SetBrushAnimFlags"}.

@endnode

@node "CanDo_removebrushanim" "RemoveBrushAnim {BAnimBufferName}"
@toc "CanDo_BrushAnims_Index"
@{fg highlight}Command...@{fg text}

  RemoveBrushAnim {BAnimBufferName}

@{fg highlight}Description...@{fg text}

  Removes the BrushAnim from the display but does not flush it from memory.
  
  SEE ALSO: @{" ShowBrushAnim " link "CanDo_ShowBrushAnim"}.

@endnode

@node "CanDo_resetbrushanimframe" "ResetBrushAnimFram {BAnimBufferName} [,{FrameNumber}]"
@toc "CanDo_BrushAnims_Index"
@{fg highlight}Command...@{fg text}

  ResetBrushAnimFram {BAnimBufferName} [,{FrameNumber}]

@{fg highlight}Description...@{fg text}

  Resets a BrushAnim back to frame one.  Optionally, a specific frame to
reset to.  You can then show the individual frame with the @{" ShowBrush " link "CanDo_ShowBrush"}
command.
  
  SEE ALSO: @{" ShowBrushAnim " link "CanDo_ShowBrushAnim"}.

@endnode

@node "CanDo_setbrushanimflags" "SetBrushAnimFlags {BufferName}, <flags> [,{TickSpeed}]"
@toc "CanDo_BrushAnims_Index"
@{fg highlight}Command...@{fg text}

  SetBrushAnimFlags {BufferName}, <flags> [,{PlayTicks}]

@{fg highlight}Parameters...@{fg text}

  BufferName  = The name of the BrushAnim Buffer
        Flags = Options available for BrushAnims
    PlayTicks = How many jiffies over which to play the entire animation.

@{fg highlight}Description...@{fg text}

  Defines how a BrushAnim is to be played and stored in memory.  The
flags allow you to select between the following options:
  
  ASYNC or SYNC
  NOMASK or USEMASK
  COMPRESS or DECOMPRESSED
  FORWARD, BACKWARD or PINGPONG
  LINEARMOTION or SEQUENCEMOTION 
  LEAVEIMAGE or RESTOREBACKGROUND

In each case, the first option is the default.

@endnode

@node "CanDo_showbrushanim" "ShowBrushAnim {BAnimBufferName}, {XCoor}, {YCoor} [,{NTimes}]"
@toc "CanDo_BrushAnims_Index"
@{fg highlight}Command...@{fg text}

  ShowBrushAnim {BAnimBufferName}, {XCoor}, {YCoor} [,{NTimes}]

@{fg highlight}Description...@{fg text}

  Adds a BrushAnim to the window at {XCoor} and {YCoor}.  Optionally, you
can specify how many times to play the BrushAnim through.
   
  SEE ALSO: @{" LoadBrushAnim " link "CanDo_LoadBrushAnim"} and @{" RemoveBrushAnim " link "CanDo_RemoveBrushAnim"}.

@endnode

