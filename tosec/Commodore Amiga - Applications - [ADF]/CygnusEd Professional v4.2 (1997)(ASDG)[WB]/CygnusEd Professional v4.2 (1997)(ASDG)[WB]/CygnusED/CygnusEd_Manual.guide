 @{" SCROLLBORDERRIGHT   37 " link SCROLLBORDERRIGHT}
 @{" SCROLLBORDERTOP     38 " link SCROLLBORDERTOP}
 @{" SCROLLJUMP          10 " link SCROLLJUMP}
