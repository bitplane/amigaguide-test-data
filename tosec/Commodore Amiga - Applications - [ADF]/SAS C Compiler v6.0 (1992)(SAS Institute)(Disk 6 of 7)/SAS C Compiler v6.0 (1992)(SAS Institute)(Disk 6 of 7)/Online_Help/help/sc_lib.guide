@Node "CharFuncs"
   @{" isalnum()  " Link "isalnum()"}   Check if character is alphanumeric
   @{" isalpha()  " Link "isalpha()"}   Check if character is alphabetic
   @{" isascii()  " Link "isascii()"}   Check if character is ASCII
   @{" iscntrl()  " Link "iscntrl()"}   Check if character is a control character
   @{" iscsym()   " Link "iscsym()"}   Check if character is a C symbol character
   @{" iscsymf()  " Link "iscsymf()"}   Check if character is a C symbol lead character
   @{" isdigit()  " Link "isdigit()"}   Check if character is a decimal digit (0-9)
   @{" isgraph()  " Link "isgraph()"}   Check if character is a graphic character
   @{" islower()  " Link "islower()"}   Check if character is lower case
   @{" isprint()  " Link "isprint()"}   Check if character is printable
   @{" ispunct()  " Link "ispunct()"}   Check if character is a punctuation character
   @{" isspace()  " Link "isspace()"}   Check if character is a space
   @{" isupper()  " Link "isupper()"}   Check if character is upper case
   @{" isxdigit() " Link "isxdigit()"}   Check if character is a hex character (0-9, A-F, a-f)
   @{" toascii()  " Link "toascii()"}   Convert character to ASCII
   @{" tolower()  " Link "tolower()"}   Convert character to lower case
   @{" toupper()  " Link "toupper()"}   Convert character to upper case
@EndNode

@Node "StringFuncs"
See also "Memory Manipulation Functions"
   @{" astcsma()  " Link "astcsma()"}   AmigaDOS string pattern match (anchored)
   @{" stcpm()    " Link "stcpm()"}   Unanchored pattern match
   @{" stcpma()   " Link "stcpma()"}   Anchored pattern match
   @{" stcsma()   " Link "stcsma()"}   @{" UNIX " Link "Glossary - UNIX"} string pattern match (anchored)
   @{" stccpy()   " Link "stccpy()"}   Copy one string to another
   @{" stpcpy()   " Link "stpcpy()"}   Copy one string to another
   @{" strcpy()   " Link "strcpy()"}   Copy one string to another
   @{" strncpy()  " Link "strncpy()"}   Copy string, length-limited
   @{" stcis()    " Link "stcis()"}   Measure span of characters in set
   @{" stcisn()   " Link "stcisn()"}   Measure span of characters not in set
   @{" strcspn()  " Link "strcspn()"}   Measure span of characters not in set
   @{" stclen()   " Link "stclen()"}   Measure length of a string
   @{" strlen()   " Link "strlen()"}   Measure length of a string
   @{" strspn()   " Link "strspn()"}   Measure span of characters in set
   @{" stpbrk()   " Link "stpbrk()"}   Find break character in string
   @{" stpchr()   " Link "stpchr()"}   Find character in string
   @{" strchr()   " Link "strchr()"}   Find character in string
   @{" stpchrn()  " Link "stpchrn()"}   Find character not in string
   @{" strrchr()  " Link "strrchr()"}   Find character not in string
   @{" strpbrk()  " Link "strpbrk()"}   Find break character in string
   @{" strcat()   " Link "strcat()"}   Concatenate strings
   @{" strncat()  " Link "strncat()"}   Concatenate strings, length-limited
   @{" strcmp()   " Link "strcmp()"}   Compare strings
   @{" strcmpi()  " Link "strcmpi()"}   Compare strings, case-insensitive
   @{" stricmp()  " Link "stricmp()"}   Compare strings, case-insensitive
   @{" strncmp()  " Link "strncmp()"}   Compare strings, length-limited
   @{" strnicmp() " Link "strnicmp()"}   Compare strings, case-insensitive, length-limited
   @{" strnset()  " Link "strnset()"}   Set string to value, length-limited
   @{" strset()   " Link "strset()"}   Set string to value
   @{" strtok()   " Link "strtok()"}   Get a token
   @{" stcarg()   " Link "stcarg()"}   Get an argument
   @{" stpsym()   " Link "stpsym()"}   Get next symbol from a string
   @{" stptok()   " Link "stptok()"}   Get next token from a string
   @{" stpblk()   " Link "stpblk()"}   Skip blanks
   @{" strbpl()   " Link "strbpl()"}   Build string pointer list
   @{" strdup()   " Link "strdup()"}   Duplicate a string
   @{" strins()   " Link "strins()"}   Insert a string
   @{" strrev()   " Link "strrev()"}   Reverse a character string
   @{" strmid()   " Link "strmid()"}   Return a substring from a string
   @{" strstr()   " Link "strstr()"}   Locate a sub-string inside of a string
@EndNode

@Node "ConvFuncs"
   @{" atof()      " Link "atof()"}   Convert ASCII to float
   @{" atoi()      " Link "atoi()"}   Convert ASCII to integer
   @{" atol()      " Link "atol()"}   Convert ASCII to long integer
   @{" stcd_i()    " Link "stcd_i()"}   Convert decimal string to integer
   @{" stcd_l()    " Link "stcd_l()"}   Convert decimal string to long integer
   @{" ecvt()      " Link "ecvt()"}   Convert double to string
