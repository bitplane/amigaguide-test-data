+-----------------------------------------------------------------------------+


@node ARexx.GETSTRING "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - GETSTRING

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.GREEN "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - GREEN


            Without any arguments, this reports the current Green
        setting. Otherwise, a value in the range of -50 to 50 may
        be assigned by specifying that value after this command.
        Any negative values must be delimited by quotation marks.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.IMAGE_TYPE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - IMAGE_TYPE


            This command reports the characteristics of the current
        image in memory, being one of the following:


            BITPLANE        There exists a rendered image in the
                            current buffer, however there exists
                            no raw 24 bitplane data or 8 bitplane
                            grayscale data.


            COLOR           Raw 24 bitplane color data is in the
                            current buffer, however no image has been
                            rendered.

            COLOR BITPLANE  There exists a rendered image in the
                            current buffer, along with raw 24 bitplane
                            color data.

            GRAY            Raw 8 bitplane grayscale data is in the
                            current buffer, however no image has been
                            rendered.

            GRAY BITPLANE   There exists a rendered image in the
                            current buffer, along with raw 8 bitplane
                            grayscale data.

            NONE            There exists no images loaded into AdPro's
                            buffers.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.INK_CORRECTION "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - INK_CORRECTION

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.LAST_LOADED_IMAGE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - LAST_LOADED_IMAGE


            This command reports the path and filename of the last
        image loaded into AdPro.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.LAST_SAVED_IMAGE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - LAST_SAVED_IMAGE


            This command reports the path and filename of the last
        image saved by AdPro.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.LFORMAT "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - LFORMAT


            This command reports the currently selected Loader to be
        used when loading in new images into AdPro. By specifying a
        Loader name, this command can also access other Loaders for
        other file formats.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.LOAD "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - LOAD

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.LOADER "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - LOADER

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.MAGENTA_CORRECTION "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - MAGENTA_CORRECTION

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.OBTAIN_ADPRO "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - OBTAIN_ADPRO


            This places an exclusive access lock on the AdPro message
        port, if possible. While other programs may be trying to use
        the port simultaneously, this command guarantees that no two
        scripts can access and confuse data transfers with the AdPro
        message port.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.OFORMAT "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - OFORMAT

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.OKAY1 "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - OKAY1


            This will display a message on the AdPro screen and will
        prompt for the user to press the OK gadget before AdPro
        continues any image manipulations.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.OKAY2 "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - OKAY2


            This will display a message on the AdPro screen and will
        prompt for the user to press the OK or CANCEL gadget before
        AdPro continues any image manipulations.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.OPERATE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - OPERATE

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.OPERATOR "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - OPERATOR

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.ORIENTATION "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - ORIENTATION


            This command reports the display orientation of the next
        image to be loaded. This may be either PORTRAIT or LANDSCAPE,
        depending on the settings.
            The orientation may also be set by specifying one of the
        two above keywords after the command.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PAUSE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PAUSE


            This command will pause for a specified amount of time,
        with every 50 units pausing for one second. To pause for
        more than one second, enter the number of seconds multiplied
        by 50. To pause for a fraction of a second, use each unit to
        specify one-fiftieth of a second.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PCONTRAST "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PCONTRAST

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PCT_SCALE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PCT_SCALE

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PGETWB "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PGETWB


            This command will copy the first four colors of the
        Workbench palette to the AdPro palette.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PIXEL_ASPECT "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PIXEL_ASPECT


            This command reports the aspect ratio used in the current
        image in AdPro's buffer.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PIXEL_RESOLUTION "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PIXEL_RESOLUTION


            This command reports the resolution used in the current
        image in AdPro's buffer.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PLOAD "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PLOAD


            This command will load the palette from an image file and
        use that palette from within AdPro. The palette may be copied
        from any IFF graphic file that contains a palette. Any image
        data from that file will be ignored.
            If no filename is specified, a file requester will open.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.POFFSET "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - POFFSET


            This command reports the offset of color register 0. The
        offset cannot be larger than the total number of colors
        available for the image format. The offset may be set by
        specifying the offset value following the command.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PPOKE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PPOKE

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PSAVE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PSAVE


            This command will save the palette to an IFF format file.
        If no filename is specified, a file requester will open.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PSORT "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PSORT


            This command reports the sorting method of the current
        palette, either 0 (ascending) or 1 (descending). The sort
        ordering may be set by specifying either a 0 (ascending)
        or a 1 (descending) after the command.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PSTATUS "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PSTATUS


            This command reports whether the current palette is
        LOCKED or UNLOCKED. The lock status may be changed for
        the palette by specifying one of the two keywords.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PTOTAL "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PTOTAL


            This command reports the number of base colors available
        in the current AdPro palette. This value may be 2, 4, 8, 16,
        32, 64, 128, or 256 colors, or it may be one of the special
        modes such as EHB, HAM, or HAM8. Since the special modes use
        a base palette, only a limited number of colors are available
        as compared to the actual image. EHB can support a 32 color
        palette, while HAM supports 16 color palettes and HAM8 supports
        64 color palettes.
            The type of palette desired may be selected by specifying
        one of the above color sizes or one of the above special display
        modes.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PUSED "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PUSED


            This command reports the number of colors used by AdPro.
        The number of colors can be set by specifying the desired
        value after the command.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.PWIDTH "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - PWIDTH


            This reports the type of palette to be used in image and
        data processing. The available types are NORMAL and ENHANCED.
        The palette type may also be changed by specifying that type
        after the command.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.RED "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - RED


            Without any arguments, this reports the current Red
        setting. Otherwise, a value in the range of -50 to 50 may
        be assigned by specifying that value after this command.
        Any negative values must be delimited by quotation marks.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.RELEASE_ADPRO "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - RELEASE_ADPRO


            This command alters the status of the read/write lock
        placed on the AdPro message port so that the current script
        is no longer the owner. This allows other scripts or the
        current script to open the AdPro message port and exchange
        information.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.RENDER_TYPE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - RENDER_TYPE


            This command reports the current type of image to be
        rendered, specified by the number of colors or by a special
        mode name. These can include 2, 4, 8, 16, 32, 128, and 256
        color modes (corresponding to images containg between 1 and
        8 bitplanes). Also, EHB, HAM, HAM8, and the customizable
        CUST mode may be used.

            To specify the image rendering type, the command can
        be followed by the number of colors (up to 256 as listed
        above) or byt the mode name (as above).

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.SAVE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - SAVE

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.SAVER "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - SAVER

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.SCREEN_TYPE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - SCREEN_TYPE

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.SEPARATE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - SEPARATE

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.SEPARATION_DEPTH "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - SEPARATION_DEPTH

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.SEPARATION_MAP "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - SEPARATION_MAP

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.SEPARATION_TYPE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - SEPARATION_TYPE

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.SERIAL_NUMBER "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - SERIAL_NUMBER


            This command returns the serial number assigned to the
        AdPro program currently addressed by ARexx.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.SFORMAT "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - SFORMAT

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.UCR "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - UCR

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.USE_SEPARATION_DEFAULTS "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - USE_SEPARATION_DEFAULTS

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.VERSION "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - VERSION


            This command returns the current version of the AdPro
        being addressed from ARexx.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.XSIZE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - XSIZE


            This command reports the width of the image in AdPro's
        current buffer.

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.YELLOW_CORRECTION "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - YELLOW_CORRECTION

@endnode
+-----------------------------------------------------------------------------+


@node ARexx.YSIZE "Art Department Professional"
@toc Software.AdPro.ARexx

   ARexx - YSIZE


            This command reports the height of the image in AdPro's
        current buffer.

@endnode
