      @{"           Menus            " LINK Menus }
      @{"          Windows           " LINK Windows }
      @{"        Main screen         " LINK MainScreen }
      @{"      Player commands       " LINK PlrCommands }
      @{"     Keyboard shortcuts     " LINK KeybShorts }


* Click any boxed text to see more information on that subject.

* Use the up and down arrow keys to reveal more of a topic.

+ For more detailed information on using this help file, press the "Help"
  key.
@ENDNODE



