@database "AORM.Glossary.guide"


@node Glossary "Glossary"
@$VER: 2.160
@toc AORM/Main
@prev AORM.Addresses/Addresses
@next AORM.Index/Index
@Index AORM.Index/Index

    Glossary

        @{"    "link Glossary.A} A     @{"    "link Glossary.H} H     @{"    "link Glossary.O} O     @{"    "link Glossary.V} V
        @{"    "link Glossary.B} B     @{"    "link Glossary.I} I     @{"    "link Glossary.P} P     @{"    "link Glossary.W} W
        @{"    "link Glossary.C} C     @{"    "link Glossary.J} J     @{"    "link Glossary.Q} Q     @{"    "link Glossary.X} X
        @{"    "link Glossary.D} D     @{"    "link Glossary.K} K     @{"    "link Glossary.R} R     @{"    "link Glossary.Y} Y
        @{"    "link Glossary.E} E     @{"    "link Glossary.L} L     @{"    "link Glossary.S} S     @{"    "link Glossary.Z} Z
        @{"    "link Glossary.F} F     @{"    "link Glossary.M} M     @{"    "link Glossary.T} T
        @{"    "link Glossary.G} G     @{"    "link Glossary.N} N     @{"    "link Glossary.U} U

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.A "Glossary - A"
@toc Glossary

        @{FG HIGHLIGHT}
        .backdrop @{FG TEXT}- This file contains the location of any file left out
            on the Workbench using the "Leave Out" menu item in the Icons
            menu. Each entry is listed by a colon followed by the path
            and filename.

        @{FG HIGHLIGHT}
        .fastdir @{FG TEXT}- This file contains information on which files are stored
            in the current directory and is used by some programs to read
            the directory faster.

                @{"     " link AORM.OS.AmigaDOS/Dir     } SYS:C/Dir
                @{"     " link AORM.OS.AmigaDOS/List    } SYS:C/List
                @{"     " link Glossary.D}@{FG HIGHLIGHT} Directory  @{FG TEXT}

        @{FG HIGHLIGHT}
        .info @{FG TEXT}- This file contains information such as an icon's graphical
            image (if appended to that file's names), or may be used to
            describe the current directory or device.

                @{"     " link AORM.OS.AmigaDOS/Dir     } SYS:C/Dir
                @{"     " link AORM.OS.AmigaDOS/List    } SYS:C/List
                @{"     " link Glossary.I}@{FG HIGHLIGHT} Icon@{FG TEXT}

        @{FG HIGHLIGHT}
        3D @{FG TEXT}- Any object that has a measurable depth, length and width.
            Technique used in computer graphics to display moving,
            life-like images on a monitor.

                @{"     " rxs "address command 'display.s 225 225 pictures/pic.cube.solid 3D_Object'"} ILBM: 3D Object

        @{FG HIGHLIGHT}
        68K @{FG TEXT}- The abbreviation for Motorola's 68000 series of central
            processing units. Includes processors such as the MC68000 and the
            MC68040. Also used to refer to the assembly language supported by
            these processors.

                @{"     " link Glossary.A} @{FG HIGHLIGHT}Assembly      @{FG TEXT}
                @{"     " link Glossary.C} @{FG HIGHLIGHT}CPU           @{FG TEXT}
                @{"     " link Glossary.L} @{FG HIGHLIGHT}Language      @{FG TEXT}
                @{"     " link Glossary.M} @{FG HIGHLIGHT}Motorola      @{FG TEXT}
                @{"     " link Glossary.P} @{FG HIGHLIGHT}Processor     @{FG TEXT}

        @{FG HIGHLIGHT}
        8SVX @{FG TEXT}- The Amiga's IFF audio sample storage format.

                @{"     " link Glossary.A} @{FG HIGHLIGHT}Audio    @{FG TEXT}
                @{"     " link Glossary.I} @{FG HIGHLIGHT}IFF      @{FG TEXT}
                @{"     " link Glossary.S} @{FG HIGHLIGHT}Sample   @{FG TEXT}

        @{FG HIGHLIGHT}
        AA @{FG TEXT}- Development name for the AGA chip set.

                @{"     " link Glossary.C} @{FG HIGHLIGHT}Chip Set      @{FG TEXT}

        @{FG HIGHLIGHT}
        AA+ @{FG TEXT}- Development name for the low-end chipset originally designed
            to replace the AGA chipset in future years. It is assumed that
            this chipset will not be produced at the current time and may
            never be developed.

        @{FG HIGHLIGHT}
        AAA @{FG TEXT}- Development named for the newest generation Advanced Amiga
            Architecture chipset, presumed to be released in the Amiga
            5000. Supports 4 custom chips, including 24 bit graphics and
            16 bit audio.

        @{FG HIGHLIGHT}
        Accelerator @{FG TEXT}- A hardware device that increases the speed at
            which a computer operates and decreases the time required
            for software to operate a given task.

                @{"     " link AORM.OS.AmigaDOS/CPU  } SYS:C/CPU

        @{FG HIGHLIGHT}
        Accumulator @{FG TEXT}- A CPU register that contains one of the two operands
            available for the current instruction.

                @{"     " link Glossary.C          } @{FG HIGHLIGHT}CPU@{FG TEXT}
                @{"     " link Glossary.I          } @{FG HIGHLIGHT}Instruction@{FG TEXT}
                @{"     " link Glossary.O          } @{FG HIGHLIGHT}Operand@{FG TEXT}

        @{FG HIGHLIGHT}
        Address @{FG TEXT}- A location in memory, signified by a serial number used
            to access that memory location.

                @{"     " link Glossary.M          } @{FG HIGHLIGHT}Memory@{FG TEXT}

        @{FG HIGHLIGHT}
        Address Bus @{FG TEXT}- The part of the system bus that is used to transfer an
            address location to main memory or input and output devices.

        @{FG HIGHLIGHT}
        Address Space @{FG TEXT}- The entire range of memory that may be accessed by the
            CPU and its supporting hardware.

        @{FG HIGHLIGHT}
        Advanced Graphics Architecture @{FG TEXT}- CBM's high end custom chip set, used
            in the A1200, A4000, A4000T, and CD32 systems.

                @{"     " link AORM.Index/Memory_Usage  } INDEX: Memory Usage
                @{"     " link AORM.Index/Screenmodes   } INDEX: Screenmodes

        @{FG HIGHLIGHT}
        AGA @{FG TEXT}- Advanced Graphics Architecture Chip Set, as found in
            the Amiga 1200, Amiga 4000, and CD32, supporting modes such as
            HAM8 and 8 bitplanes per screenmode. Released in 1992.

        @{FG HIGHLIGHT}
        Akiko @{FG TEXT}- An AGA chip, found in the CD32 console, designed to
            handle CIA functions as well as chunky pixel to planar
            graphics conversions. Useful in converting IBM games to
            comparable Amiga equivalents. Originally known as the Arizona
            chip.

                @{"     " link Glossary.C}@{FG HIGHLIGHT} Chunky Pixels    @{FG TEXT}
                @{"     " link Glossary.C}@{FG HIGHLIGHT} CIA Chips        @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Planar pixels    @{FG TEXT}

        @{FG HIGHLIGHT}
        Alert Object @{FG TEXT}- The module of the operating system that reports
             a GURU Meditation Error.

                @{"     " link Glossary.G}@{FG HIGHLIGHT} GURU Meditation Error@{FG TEXT}
                @{"     " link Glossary.O}@{FG HIGHLIGHT} Operating System     @{FG TEXT}

        @{FG HIGHLIGHT}
        Alpha Channel @{FG TEXT}- An image that contains information regarding how another
            image is to be composited on a third image. Most alpha channels use
            greyscale alpha images or techniques based on brightness. A portion
            of an alpha image with a higher value will permit a larger intensity
            of the composting image to be merged with the third image.

                @{"     " link Glossary.B}@{FG HIGHLIGHT} Brightness    @{FG TEXT}
                @{"     " link Glossary.Ç}@{FG HIGHLIGHT} Composite     @{FG TEXT}
                @{"     " link Glossary.I}@{FG HIGHLIGHT} Image         @{FG TEXT}
                @{"     " link Glossary.I}@{FG HIGHLIGHT} Intensity     @{FG TEXT}

        @{FG HIGHLIGHT}
        AMAL @{FG TEXT}- AMOS' animation scripting language.

                @{"     " link Glossary.A}@{FG HIGHLIGHT} AMOS          @{FG TEXT}
                @{"     " link Glossary.A}@{FG HIGHLIGHT} Animation     @{FG TEXT}
                @{"     " link Glossary.L}@{FG HIGHLIGHT} Language      @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Script        @{FG TEXT}

        @{FG HIGHLIGHT}
        Ambient Light @{FG TEXT}- Light which is cast upon all surfaces. In the
            natural world, ambient light is cast by the Sun. Since the
            Sun is such a large source of light, light rays are bounced
            off various surfaces, allowing surfaces to be lit which are
            not facing the Sun. Without ambient light, shadows would
            totally blacken out surfaces that they are cast upon.

        @{FG HIGHLIGHT}
        AmigaDOS @{FG TEXT}- The Amiga's disk based command set, accessible via
            the CLI or Shell. Supports resident and internal commands,
            command line history, output redirection, and parameter
            passing.

                @{"     " link AORM.Index/Template      } INDEX: AmigaDOS Template
                @{"     " link AORM.Index/errors        } INDEX: Error Messages
                @{"     " link AORM.OS.AmigaDOS/NewCLI  } SYS:C/NewCLI
                @{"     " link AORM.OS.AmigaDOS/NewShell} SYS:C/NewShell
                @{"     " link Glossary.C}@{FG HIGHLIGHT} CLI       @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Shell     @{FG TEXT}

        @{FG HIGHLIGHT}
        AmigaGuide @{FG TEXT}- Commodore's hypertext application, using a point
            and click interface to search through textual applications
            containing nodes which may be interlinked using gadgets.
            The Amiga Online Reference Manual uses the AmigaGuide reader.

                @{"     " link Glossary.G}@{FG HIGHLIGHT} Gadget        @{FG TEXT}
                @{"     " link Glossary.H}@{FG HIGHLIGHT} Hypertext     @{FG TEXT}
                @{"     " link Glossary.I}@{FG HIGHLIGHT} Interface     @{FG TEXT}
                @{"     " link Glossary.N}@{FG HIGHLIGHT} Node          @{FG TEXT}
                @{"     " link Glossary.R}@{FG HIGHLIGHT} Reader        @{FG TEXT}

        @{FG HIGHLIGHT}
        Amiga Guy @{FG TEXT}- The short lived cartoon character in many of CBM's
            magazine ads, appearing from mid-1992 to early 1993.

        @{FG HIGHLIGHT}
        Amiga Vision @{FG TEXT}- Commodore's multimedia presentation software,
            using a graphical icon based interface to arrange animations,
            video, images, audio, and music into arranged presentations
            and applications.

                @{"     " link Glossary.I}@{FG HIGHLIGHT} Icon          @{FG TEXT}
                @{"     " link Glossary.M}@{FG HIGHLIGHT} Multimedia    @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Presentation  @{FG TEXT}

        @{FG HIGHLIGHT}
        AMOS @{FG TEXT}- A software design package, similar to BASIC, using
            integrated construction editors, such as a sprite editor and 3D
            object editor, for creating distributable programs and games.

                @{"     " link Glossary.B} @{FG HIGHLIGHT}BASIC    @{FG TEXT}

        @{FG HIGHLIGHT}
        Amplitude @{FG TEXT}- The measure of the height of a waveform.

                @{"     " link Glossary.W          } @{FG HIGHLIGHT}Waveform@{FG TEXT}

        @{FG HIGHLIGHT}
        Amplitude Modulation @{FG TEXT}- Using one channel to modify the amplitude
            of another and produce special effects.

        @{FG HIGHLIGHT}
        Anamorphic Squeeze @{FG TEXT}- A type of elongated lens flare technique that
            causes lens flares to appear wider.

                @{"     " link Glossary.L          } @{FG HIGHLIGHT}Lens Flare@{FG TEXT}

        @{FG HIGHLIGHT}
        Anamorphic Streaks @{FG TEXT}- A type of elongated lens flare technique that
            causes lens flares to appear wider with blue streaks.

                @{"     " link Glossary.L          } @{FG HIGHLIGHT}Lens Flare@{FG TEXT}

        @{FG HIGHLIGHT}
        Animation @{FG TEXT}- A sequence of still pictures stored in one file designed
            to give the illusion of motion when displayed rapidly in a
            sequential order. Most animations are identified by the FORM
            ANIM, FLI, MPEG, or other similar specification. Animations are
            frequently played at 30 frames per second.

                @{"     " link Glossary.H          } @{FG HIGHLIGHT}HAM    @{FG TEXT}
                @{"     " link Glossary.I          } @{FG HIGHLIGHT}IFF    @{FG TEXT}
                @{"     " link Glossary.F          } @{FG HIGHLIGHT}Frame  @{FG TEXT}

        @{FG HIGHLIGHT}
        Antialiasing @{FG TEXT}- The process of smoothing a jagged line or curve
            by merging the colors gradually.

                @{"     " rxs "address command 'display.s 221 236 pictures/pic.antialias Antialias'"            } ILBM: Antialias
                @{"     " link Glossary.D          } @{FG HIGHLIGHT}Dithering @{FG TEXT}

        @{FG HIGHLIGHT}
        Append @{FG TEXT}- This write mode allows a file to have new information added
            to the end of the file without destroying any of the old data.

                @{"     " link Glossary.W          } @{FG HIGHLIGHT}Write    @{FG TEXT}

        @{FG HIGHLIGHT}
        AppleTalk @{FG TEXT}- A very slow networking system.

                @{"     " link Glossary.N          } @{FG HIGHLIGHT}Network  @{FG TEXT}

        @{FG HIGHLIGHT}
        Application @{FG TEXT}- A software program that is used directly by a user
            as opposed to a file that is accessed mainly by other software,
            such as a device driver.

                @{"     " link Glossary.P          } @{FG HIGHLIGHT}Program  @{FG TEXT}
                @{"     " link Glossary.S          } @{FG HIGHLIGHT}Software @{FG TEXT}
                @{"     " link Glossary.T          } @{FG HIGHLIGHT}Tool     @{FG TEXT}

        @{FG HIGHLIGHT}
        Aquarium @{FG TEXT}- A database for searching through Fred Fish Disks.

                @{"     " link Glossary.F          } @{FG HIGHLIGHT}Fred Fish Disks  @{FG TEXT}
                @{"     " link Glossary.K          } @{FG HIGHLIGHT}Kingfisher       @{FG TEXT}

        @{FG HIGHLIGHT}
        Archie @{FG TEXT}- A UNIX program designed to find files over the Internet.
            Files may be located on any machine in Archie's database,
            and will be reported whenever a match is found. Archie is
            not capable of retrieving files, yet is capable of directing
            the user to them.

                @{"     " link Glossary.D          } @{FG HIGHLIGHT}Database    @{FG TEXT}
                @{"     " link Glossary.F          } @{FG HIGHLIGHT}File        @{FG TEXT}
                @{"     " link Glossary.I          } @{FG HIGHLIGHT}Internet    @{FG TEXT}
                @{"     " link Glossary.U          } @{FG HIGHLIGHT}UNIX        @{FG TEXT}

        @{FG HIGHLIGHT}
        Archive @{FG TEXT}- A file that contains another file or group of files, often
            compressed. Archives are created with programs such as ARC,
            LHARC, LHA, or DMS.

                @{"     " link AORM.OS.AmigaDOS/Protect } SYS:C/Protect
                @{"     " link Glossary.F          } @{FG HIGHLIGHT}File        @{FG TEXT}

        @{FG HIGHLIGHT}
        Archiving @{FG TEXT}- Placing a file or group of files into another
            file, often reducing its size, for temporary storage.

                @{"     " link Glossary.F          } @{FG HIGHLIGHT}File          @{FG TEXT}
                @{"     " link Glossary.C          } @{FG HIGHLIGHT}Compression   @{FG TEXT}

        @{FG HIGHLIGHT}
        Arcnet @{FG TEXT}- Modified token-passing scheme, while sending messages,
            as a networking protocol.

                @{"     " link Glossary.N          } @{FG HIGHLIGHT}Networking    @{FG TEXT}
                @{"     " link Glossary.P          } @{FG HIGHLIGHT}Protocol      @{FG TEXT}

        @{FG HIGHLIGHT}
        ARexx @{FG TEXT}- A script based programming language for communication
            within programs, the CLI, or the Shell.

                @{"     " link AORM.FAQ.ARexx/FAQ.ARexx.1.01} What is ARexx

        @{FG HIGHLIGHT}
        Argument @{FG TEXT}- A variable or value that may be passed to a routine.
            Used in programming, AmigaDOS, ARexx, and data entry.

                @{"     " link AORM.Index/Template      } INDEX: AmigaDOS Template
                @{"     " link Glossary.T}@{FG HIGHLIGHT} Template      @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Parameter     @{FG TEXT}

        @{FG HIGHLIGHT}
        Arizona @{FG TEXT}- Development name for the Akiko chip in the CD32
            console.

                @{"     " link Glossary.C} @{FG HIGHLIGHT}Akiko     @{FG TEXT}
                @{"     " link Glossary.C} @{FG HIGHLIGHT}CD32      @{FG TEXT}
                @{"     " link Glossary.C} @{FG HIGHLIGHT}Chip      @{FG TEXT}
                @{"     " link Glossary.C} @{FG HIGHLIGHT}Console   @{FG TEXT}

        @{FG HIGHLIGHT}
        Array @{FG TEXT}- A data storage technique that stores similar data types
            in a sequential memory unit with random memory access.

                @{"     " link Glossary.D          } @{FG HIGHLIGHT}Data Structure        @{FG TEXT}
                @{"     " link Glossary.M          } @{FG HIGHLIGHT}Memory                @{FG TEXT}
                @{"     " link Glossary.R          } @{FG HIGHLIGHT}Random Memory Access  @{FG TEXT}

        @{FG HIGHLIGHT}
        ASCII @{FG TEXT}- American Standard Code for Information Interchange. The
            most commonly used code on microcomputers for storing numbers,
            alphanumeric characters, and control codes.

                @{"     " link Glossary.A           } @{FG HIGHLIGHT}Alphanumeric Characters  @{FG TEXT}
                @{"     " link Glossary.C           } @{FG HIGHLIGHT}Characters               @{FG TEXT}
                @{"     " link Glossary.C           } @{FG HIGHLIGHT}Control Codes            @{FG TEXT}
                @{"     " link Glossary.N           } @{FG HIGHLIGHT}Numbers                  @{FG TEXT}

        @{FG HIGHLIGHT}
        ASCII File @{FG TEXT}- A file containing characters described by the ASCII
            standard character set. No binary characters are included.

                @{"     " link AORM.OS.AmigaDOS/Type    } SYS:C/Type

        @{FG HIGHLIGHT}
        Aspect Ratio @{FG TEXT}- The ratio of pixels displayed onscreen for a
            monitor or screenmode, estimating the actual shape of the
            pixels. A screenmode of 640x400 pixels has an aspect ratio
            of 1.6:1, with 1.6 horizontal pixels for every vertical
            pixel. A screen with 1:1 aspect ratio has an equal number
            of pixels horizontally and vertically.

                @{"     " link Glossary.P           } @{FG HIGHLIGHT}Pixel                  @{FG TEXT}
                @{"     " link Glossary.R           } @{FG HIGHLIGHT}Resolution                  @{FG TEXT}
                @{"     " link Glossary.S           } @{FG HIGHLIGHT}Screen                  @{FG TEXT}


        @{FG HIGHLIGHT}
        Assembly Language @{FG TEXT}- A language dependent on the processor it is
            running under, capable of instructing the processor to perform
            the most simple instructions possible by a programming language.

                @{"     " link Glossary.I           } @{FG HIGHLIGHT}Instruction                  @{FG TEXT}
                @{"     " link Glossary.L           } @{FG HIGHLIGHT}Language                  @{FG TEXT}
                @{"     " link Glossary.P           } @{FG HIGHLIGHT}Processor                  @{FG TEXT}

        @{FG HIGHLIGHT}
        Assign @{FG TEXT}- A label given to a directory, volume, or device, used to
            access that directory or volume by the newly assigned name.

                @{"     " link AORM.OS.AmigaDOS/Assign  } SYS:C/Assign
                @{"     " link AORM.OS.AmigaDOS/Info    } SYS:C/Info
                @{"     " link AORM.OS.AmigaDOS/Path    } SYS:C/Path

        @{FG HIGHLIGHT}
        Assignment @{FG TEXT}- The process of defining a label for a variable or
            directory.

                @{"     " link AORM.OS.AmigaDOS/Assign} SYS:C/Assign
                @{"     " link AORM.OS.AmigaDOS/Info  } SYS:C/Info
                @{"     " link AORM.OS.AmigaDOS/Path  } SYS:C/Path

        @{FG HIGHLIGHT}
        Asynchronous @{FG TEXT}- A scheduling technique which causes an event to occur
            only when another event has caused it to occur or finished using
            a shared bus.

        @{FG HIGHLIGHT}
        Auto Reliable Mode @{FG TEXT}- Allows a modem to make the best possible
            connection.

        @{FG HIGHLIGHT}
        AVL Tree @{FG TEXT}- A balancing tree whose leaves are always at the same
            height in the tree or off balance by a height of only 1.

                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.AVL AVL'"} ILBM: AVL Tree

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.B "Glossary - B"
@toc Glossary

        @{FG HIGHLIGHT}
        B52 @{FG TEXT}- The working project name of the A500 in 1986.

        @{FG HIGHLIGHT}
        Backdrop @{FG TEXT}- A window placed on a screen such that it is always
            furthest in the back and cannot be repositioned.

        @{FG HIGHLIGHT}
        Background @{FG TEXT}- A full screen image placed such that all other images
            appear in front of it.

        @{FG HIGHLIGHT}
        Backspace @{FG TEXT}- A key of the keyboard used to delete the character
            directly to the left of the cursor. The BACKSPACE key is
            located above the RETURN key, and is denoted by an arrow
            pointing to the left.

                @{"     " link AORM.Index/Conversions} INDEX: ASCII Code


        Balanced Tree @{FG TEXT}- A tree that has the same height for every leaf
            of the tree, such as an AVL tree or a Splay tree. Balanced
            trees are often programmed to balance themselves as a new
            node is added or investigated. These trees are designed to
            decrease search times and increase performance.

                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.AVL AVL'"            } ILBM: AVL Tree
                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.balanced Balanced'"  } ILBM: Balanced Tree
                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.leaf Leaf'"          } ILBM: Leaf
                @{"     " link Glossary.A}@{FG HIGHLIGHT} AVL Tree      @{FG TEXT}
                @{"     " link Glossary.B}@{FG HIGHLIGHT} Balanced Tree @{FG TEXT}
                @{"     " link Glossary.L}@{FG HIGHLIGHT} Leaf          @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Search Time   @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Splay Tree    @{FG TEXT}
                @{"     " link Glossary.T}@{FG HIGHLIGHT} Tree          @{FG TEXT}

        @{FG HIGHLIGHT}
        Bang Path @{FG TEXT}- An email address that specifies every computer
            that an email message will travel through.

        @{FG HIGHLIGHT}
        BAUD @{FG TEXT}- The rate at which the serial port sends data, often
            through a modem.

        @{FG HIGHLIGHT}
        BBS @{FG TEXT}- Bulliten Board System, used by computers to run networks
            over telephones.

        @{FG HIGHLIGHT}
        Bell @{FG TEXT}- An audible tone produced when an error occurs. May also
            be produced by pressing CTRL-G in an input stream, if
            supported.

        @{FG HIGHLIGHT}
        Bevel @{FG TEXT}- A technique used in 3D object modeling which places a
            rounded off edge or a cut angle at the edges of a 3D object
            or font.

        @{FG HIGHLIGHT}
        Bezier Curve @{FG TEXT}- A curved line drawn using a desktop publishing
            program or a 3D modeling program, designed to draw curves using
            mathematical formulas.

        @{FG HIGHLIGHT}
        Binary @{FG TEXT}- A number system using only 0 and 1.

        @{FG HIGHLIGHT}
        Binary File @{FG TEXT}- A file that contains information that is not
            easily readable by humans.

        @{FG HIGHLIGHT}
        Binary Operation @{FG TEXT}- A function or mathematical operation performed
            on two variables.

        @{FG HIGHLIGHT}
        Binary Tree @{FG TEXT}- A tree whose nodes have either 0, 1, or 2 children.

                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.binary Binary'"      } ILBM: Binary Tree
                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.node Node'"          } ILBM: Node
                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.root Root'"          } ILBM: Root
                @{"     " link Glossary.C}@{FG HIGHLIGHT} Child         @{FG TEXT}
                @{"     " link Glossary.N}@{FG HIGHLIGHT} Node          @{FG TEXT}
                @{"     " link Glossary.R}@{FG HIGHLIGHT} Root          @{FG TEXT}

        @{FG HIGHLIGHT}
        BIT @{FG TEXT}- The smallest unit of measure of storage space for RAM, ROM,
            disk drives, or similar devices. A BIT contains either a 0
            or 1, denoting ON/OFF or TRUE/FALSE.

                @{"     " link AORM.Index/Conversion   } INDEX: Binary Conversions
                @{"     " link AORM.OS.AmigaDOS/List   } SYS:C/List
                @{"     " link AORM.OS.AmigaDOS/Protect} SYS:C/Protect

        @{FG HIGHLIGHT}
        BIX @{FG TEXT}- Byte Information Exchange, a pay computer network where
            Commodore's official Amiga support is.

        @{FG HIGHLIGHT}
        Block @{FG TEXT}- An area of space on a device.

                @{"     " link AORM.OS.AmigaDOS/Info   } SYS:C/Info

        @{FG HIGHLIGHT}
        Blur @{FG TEXT}- The process of altering an image to remove sharp edges
            by modifying its surrounding pixels. This causes the image
            to appear out of focus.

        @{FG HIGHLIGHT}
        BOB @{FG TEXT}- A blitter object, a small graphical area which can
            be moved around the screen. Any screen area that a
            BOB covers is stored in memory and preserved, such that
            whenever the BOB is moved the underlying screen area
            is restored. BOBs can be any size and any amount of
            colors.

        @{FG HIGHLIGHT}
        Boing! @{FG TEXT}- An Amiga demo designed to run on the A1000 in 1985.
            The Boing! ball is a red and white checkerboarded sphere
            that bounces around the screen and casts a shadow.

        @{FG HIGHLIGHT}
        Bones @{FG TEXT}- A technique used in 3D object modeling which places a
            skeleton within an object, such that certain parts of the
            object are repositioned when the bone is moved or rotated.

        @{FG HIGHLIGHT}
        Boolean Math @{FG TEXT}- The use of FALSE and TRUE in programming, with
            0 assigned to FALSE and 1 assigned to TRUE, usable in any
            operation with only two available outcomes.

        @{FG HIGHLIGHT}
        Boolean Modeling @{FG TEXT}- The ability to remove any intersecting pieces
            of two or more objects by cutting and pasting them with other
            objects or primitives.

        @{FG HIGHLIGHT}
        BOOPSI @{FG TEXT}- Basic Object Oriented Programming for Intuition.

        @{FG HIGHLIGHT}
        Boot Block @{FG TEXT}- The area of a disk that defines whether the disk
            is capable of loading itself automatically.

                @{"     " link AORM.Workbench/wb.format} Workbench Format Menu Item
                @{"     " link AORM.OS.AmigaDOS/Install} SYS:C/Install

        @{FG HIGHLIGHT}
        Boot Menu @{FG TEXT}- A list of devices which can be selected before
            booting the system.

        @{FG HIGHLIGHT}
        Bounding Box @{FG TEXT}- A temporary image drawn onscreen to reflect the
            area for which the application is operating on. On the
            Workbench, a ruber-band like bounding box is used to select
            icons. In desktop publishing, bounding boxes have handles
            which allow them to resize images. In 3D modeling, they are
            used to define areas of influence or to set maximum size
            parameters.

        @{FG HIGHLIGHT}
        Bounding Column @{FG TEXT}- A bounding box that extends infintely in
            one or more directions, as used by Lightwave.

        @{FG HIGHLIGHT}
        BPS @{FG TEXT}- BITS Per Second, the rate at which data is sent over
            the serial port or through a modem.

        @{FG HIGHLIGHT}
        Breadbox @{FG TEXT}- A magazine for Video Toaster enthusiasts, now known
            as Video Toaster User Magazine.

        @{FG HIGHLIGHT}
        Break @{FG TEXT}- A command or sequence sent to a program in an attempt to
            halt execution of a routine or program.

                @{"     " link AORM.OS.AmigaDOS/Break } SYS:C/Break
                @{"     " link AORM.OS.AmigaDOS/Status} SYS:C/Status

        @{FG HIGHLIGHT}
        Brightness @{FG TEXT}- A measure of the intensity of a color, with more
            vivid colors containing more brightness and duller colors
            containing less brightness.

        @{FG HIGHLIGHT}
        Broadcast Quality @{FG TEXT}- Any video that is capable of being displayed
            on television, using a given resolution and a large color
            palette.

        @{FG HIGHLIGHT}
        BRU @{FG TEXT}- AmigaDOS hard drive backup utility, written by Fred Fish.

        @{FG HIGHLIGHT}
        Brush @{FG TEXT}- An image clipped from a larger image, often by a painting
            program.

        @{FG HIGHLIGHT}
        Brush Warp @{FG TEXT}- The process of fitting an image into an area such
            that some data is distorted by tightening it it smaller
            areas and widening it in larger areas.

        @{FG HIGHLIGHT}
        Brush Wrap @{FG TEXT}- The process of placing an image on the surface of
            a three dimensional object such as a sphere or any complicated
            modeled object.

        @{FG HIGHLIGHT}
        Bubble Memory @{FG TEXT}- A type of random access storage chip using magnetic
            storage bits called "bubbles".

        @{FG HIGHLIGHT}
        Buffer @{FG TEXT}- An area of memory set aside to temporarily store
            incoming and outgoing data. This allows a fast input
            stream to keep up with a slow output stream.

                @{"     " link AORM.OS.AmigaDOS/AddBuffers} SYS:C/AddBuffers

        @{FG HIGHLIGHT}
        Bulliten Board System @{FG TEXT}- A computer network used over standard
            telephone lines, accessible with a modem and a terminal program.

        @{FG HIGHLIGHT}
        Bump Mapping @{FG TEXT}- A type of texture that creates a 3D surface rendered
            on a 2D surface.

        @{FG HIGHLIGHT}
        Bus @{FG TEXT}- The data transfer path shared among processors and input devices,
            such that only one member of the system may use the bus at any
            given time. A bus consists of lines such as the timing line, the
            signal request line, and the data lines.

        @{FG HIGHLIGHT}
        Busy @{FG TEXT}- A state in which a device or volume is storing or
            retrieving data and cannot be tampered with.

        @{FG HIGHLIGHT}
        Busy Pointer @{FG TEXT}- The sprite image used to represent when the
            main pointer cannot be used to control the graphical
            interface, icons, or gadgets.

        @{FG HIGHLIGHT}
        Byte @{FG TEXT}- A measure of storage space, equaling 8 BITs.

                @{"     " link AORM.Index/Measurements   } INDEX: Measurements

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.C "Glossary - C"
@toc Glossary

        @{FG HIGHLIGHT}
        Cache @{FG TEXT}- A buffer used to increase access rates to a device by storing
            frequently used information in a small fast RAM chip. Cache RAM
            is often very expensive, and therefor is used only in small
            quantities.

                @{"     " link AORM.OS.AmigaDOS/CPU} SYS:C/CPU

        @{FG HIGHLIGHT}
        CAD @{FG TEXT}- Computer Aided Drafting, software that is used to design
            and develop floorplans, models, and other hardware.

        @{FG HIGHLIGHT}
        Camera @{FG TEXT}- A software object that is used to determine where the
            animation stage will be viewed from.

        @{FG HIGHLIGHT}
        Carriage Return @{FG TEXT}- A command sent via the keyboard to signify the
            end of data.

                @{"     " link AORM.Index/Conversion 20} INDEX: ASCII Code

        @{FG HIGHLIGHT}
        CATS @{FG TEXT}- Commodore Amiga Technical Support, organized to provide
            programmer information to registered and certified Amiga
            developers.

        @{FG HIGHLIGHT}
        CD+G @{FG TEXT}- A compact disc with music and graphics.

                @{"     " link Glossary.C }@{FG HIGHLIGHT} Compact Disk    @{FG TEXT}

        @{FG HIGHLIGHT}
        CD32 @{FG TEXT}- Commodore's 32-BIT CDROM based game console, based
            on the Amiga AGA custom chip set. Also includes the
            Akiko custom chip, used to convert chunky graphic bitmaps
            to planar bitmaps. Contains various video outputs ports,
            allowing it to be used on most televisions or monitors.
            Plays audio compact disks and video games stored on
            compact disks.

                @{"     " link AORM.Hardware/CD32} CD32 Specifications

        @{FG HIGHLIGHT}
        CDI @{FG TEXT}- An unsupported and unexpandable CDROM system.

        @{FG HIGHLIGHT}
        CDROM @{FG TEXT}- A disk drive used to read compact disks, which may
            contain audio or computer software. Compact discs are
            capable of storing 640 megabytes of data or over 60 minutes
            of 16 BIT sampled audio.

        @{FG HIGHLIGHT}
        CDTV @{FG TEXT}- Commodore Dynamic Total Vision, a CDROM based stand
            alone multimedia player, based on the Amiga OCS custom
            chip set. Designed to function as an audio CD player as
            well as a computer.

                @{"     " link AORM.Hardware/CDTV} CDTV Specifications

        @{FG HIGHLIGHT}
        CDXL @{FG TEXT}- The CDTV's custom animation format, based on CDROM
            transfer speeds.

                @{"     " link Glossary.A }@{FG HIGHLIGHT} Animation    @{FG TEXT}

        @{FG HIGHLIGHT}
        Central Glow @{FG TEXT}- A form of lens flare used in 3D modeling and
            ray tracing that creates the effect of a light source's
            concentrated light energy radiating from the source of
            the light.

                @{"     " link Glossary.L }@{FG HIGHLIGHT} Lens Flare    @{FG TEXT}

        @{FG HIGHLIGHT}
        Central Processing Unit @{FG TEXT}- The computer chip that controls most of
            the functions ot be performed by the computer by fetching and
            executing assembly instructions.

                @{"     " link AORM.OS.AmigaDOS/CPU} SYS:C/CPU

        @{FG HIGHLIGHT}
        Channel @{FG TEXT}- A pathway used by the audio chip when outputting
            sound.

                @{"     " link Glossary.O }@{FG HIGHLIGHT} Output       @{FG TEXT}
                @{"     " link Glossary.P }@{FG HIGHLIGHT} Paula        @{FG TEXT}

        @{FG HIGHLIGHT}
        Character @{FG TEXT}- A computer representation of a letter of the alphabet,
            number, or other symbol found in handwritten writing. Each
            character requires a corresponding ASCII code in order to be
            understood and stored by the computer.

                @{"     " link AORM.Index/alternate_char} INDEX: Alternate Character Sets
                @{"     " link Glossary.A}@{FG HIGHLIGHT} ASCII       @{FG TEXT}

        @{FG HIGHLIGHT}
        Character Generator @{FG TEXT}- A software and hardware combination that
            is capable of placing text on a video screen.

        @{FG HIGHLIGHT}
        Chip Puller @{FG TEXT}- A hardware device used to ease the process of
            removing socketed chips from a motherboard.

                @{"     " link Glossary.S }@{FG HIGHLIGHT} Socketed Chip   @{FG TEXT}

        @{FG HIGHLIGHT}
        Chip RAM @{FG TEXT}- RAM accessible only by the custom chip set, used
            primarily for graphics and audio data. Comparable to
            "video RAM" found on other platforms, however Chip RAM
            is more flexible in that it allows the Amiga to run
            computer programs from Chip RAM.

                @{"     " link AORM.OS.AmigaDOS/Avail    } SYS:C/Avail
                @{"     " link Glossary.C }@{FG HIGHLIGHT} Custom Chip Set  @{FG TEXT}
                @{"     " link Glossary.R }@{FG HIGHLIGHT} RAM              @{FG TEXT}

        @{FG HIGHLIGHT}
        Character @{FG TEXT}- An image produced by pressing a particular key on
            the keyboard, such as a letter of the alphabet, a
            numeral, or a symbol. A lowercase letter is treated as
            a different character than an uppercase letter.

        @{FG HIGHLIGHT}
        Character Generator @{FG TEXT}- A device that creates text over a video
            display.

        @{FG HIGHLIGHT}
        ChromaFX @{FG TEXT}- The special video effects created using a Video Toaster.

        @{FG HIGHLIGHT}
        Chromakey @{FG TEXT}- A device that overlays graphics on top of video,
            such as weather map displays during news broadcasts.

                @{"     " link Glossary.G }@{FG HIGHLIGHT} Genlock    @{FG TEXT}
                @{"     " link Glossary.O }@{FG HIGHLIGHT} Overlay    @{FG TEXT}

        @{FG HIGHLIGHT}
        Class @{FG TEXT}- A general structure defined for datatypes.

                @{"     " link Glossary.D }@{FG HIGHLIGHT} Datatypes    @{FG TEXT}
                @{"     " link Glossary.S }@{FG HIGHLIGHT} Structure    @{FG TEXT}

        @{FG HIGHLIGHT}
        CLI @{FG TEXT}- AmigaDOS Command Line Interface for accessing DOS. May
            be used from the Workbench to enter AmigaDOS commands
            and AmigaDOS scripts. Also used to execute ARexx scripts,
            compilers, and most applications. Similar to the Shell.

                @{"     " link AORM.Index/Template      } INDEX: AmigaDOS Template
                @{"     " link AORM.OS.AmigaDOS/NewCLI  } SYS:C/NewCLI
                @{"     " link AORM.OS.AmigaDOS/NewShell} SYS:C/NewShell
                @{"     " link Glossary.D}@{FG HIGHLIGHT} DOS       @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Script    @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Shell     @{FG TEXT}

        @{FG HIGHLIGHT}
        Clip Art @{FG TEXT}- Computer graphics images sold commercially or available
            freely which are used in advertising and graphical layouts,
            mainly in desktop publishing.

                @{"     " link Glossary.I }@{FG HIGHLIGHT} Image    @{FG TEXT}

        @{FG HIGHLIGHT}
        Clipboard @{FG TEXT}- The device which allows data to be cut and pasted
            between various programs.

        @{FG HIGHLIGHT}
        Clipping @{FG TEXT}- The process of removing or altering data that is contained
            beyond a given threshold. Often used when displaying images that
            are larger than the screen such as 3D objects.

        @{FG HIGHLIGHT}
        Close Gadget @{FG TEXT}- A gadget that appears in the upper left hand screen
            of most windows that is used to close the window or possibly
            quit that program.

                @{"     " rxs "address command 'display.s 303 65 pictures/pic.gadget.close Close_Gadget'"} ILBM: Close Gadget
                @{"     " link Glossary.G}@{FG HIGHLIGHT} Gadget    @{FG TEXT}
                @{"     " link Glossary.W}@{FG HIGHLIGHT} Window    @{FG TEXT}

        @{FG HIGHLIGHT}
        Collision Detection @{FG TEXT}- The ability to detect if two objects have
            surfaces that are touching each other in some way.

        @{FG HIGHLIGHT}
        Color @{FG TEXT}- A value assigned to a pixel based upon a mixture of red,
            green, and blue. 24 bit color will allow red, green, or blue
            to range from 0 to 255. 12 bit color will allow red, green,
            or blue to range from 0 to 16. The red, green, and blue
            values are known as RGB.

                @{"     " link Glossary.B}@{FG HIGHLIGHT} BIT       @{FG TEXT}
                @{"     " link Glossary.B}@{FG HIGHLIGHT} Bitplane  @{FG TEXT}
                @{"     " link Glossary.R}@{FG HIGHLIGHT} RGB       @{FG TEXT}

        @{FG HIGHLIGHT}
        Color Cycling @{FG TEXT}- A shifting of color values between a range of
            colors such that each register switches to the color of the
            previous register.

        @{FG HIGHLIGHT}
        Command @{FG TEXT}- An executable file, often stored in the C: directory.
            Commands are often the set of files called AmigaDOS, used
            primarily from a Shell or CLI to manipulate files.

                @{"     " link AORM.Index/Template      } INDEX: AmigaDOS Template
                @{"     " link AORM.OS.AmigaDOS/Execute } SYS:C/Execute
                @{"     " link AORM.OS.AmigaDOS/Protect } SYS:C/Protect
                @{"     " link AORM.OS.AmigaDOS/Run     } SYS:C/Run
                @{"     " link Glossary.D}@{FG HIGHLIGHT} DOS       @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Shell     @{FG TEXT}

        @{FG HIGHLIGHT}
        Command Inhibition @{FG TEXT}- The process of halting a command execution
            and replacing its return values with a predifined test value.

        @{FG HIGHLIGHT}
        Command Line Interface @{FG TEXT}- The Amiga's console device, capable of
            parsing text and accessing the AmigaDOS command set.

                @{"     " link AORM.Index/Template      } INDEX: AmigaDOS Template
                @{"     " link AORM.Index/control_codes } INDEX: AmigaDOS Control Codes
                @{"     " link AORM.Index/escape_codes  } INDEX: Escape Codes
                @{"     " link AORM.OS.AmigaDOS/NewCLI  } SYS:C/NewCLI
                @{"     " link AORM.OS.AmigaDOS/NewShell} SYS:C/NewShell

        @{FG HIGHLIGHT}
        Comment @{FG TEXT}- A line or group of text within an application, source
            code, or information file, designed ot provide information
            as to the use of the program or routine.

        @{FG HIGHLIGHT}
        Commodity @{FG TEXT}- A type of  program accessed by the Commodities
            Exchange. Allows an interface for accessing programs
            running as background processes. Also ensures that
            special programs are not executed twice on the same
            system, in the event that they may conflict in some way.

                @{"     " link AORM.Index/Qualifiers} INDEX: AmigaDOS Qualifiers
                @{"     " link Glossary.B }@{FG HIGHLIGHT} Background Process   @{FG TEXT}
                @{"     " link Glossary.E }@{FG HIGHLIGHT} Exchange             @{FG TEXT}

        @{FG HIGHLIGHT}
        Compact Disk @{FG TEXT}- A 5.25" removable hard disk used to store music,
            clip art, fonts, and other large software packages. CD's are
            capable of storing 640 megabytes, yet are slower than most
            other disk devices.

        @{FG HIGHLIGHT}
        Compiler @{FG TEXT}- Program to create programs by reading source code
            text files and converting them into executable code.

                @{"     " link Glossary.E }@{FG HIGHLIGHT} Executable   @{FG TEXT}
                @{"     " link Glossary.S }@{FG HIGHLIGHT} Source Code  @{FG TEXT}
                @{"     " link Glossary.T }@{FG HIGHLIGHT} Text File    @{FG TEXT}

        @{FG HIGHLIGHT}
        Composite @{FG TEXT}- A method of tranferring video and audio data on the
            same cable, without requiring seperate lines for video and
            audio.

        @{FG HIGHLIGHT}
        Compression @{FG TEXT}- To reduce the size of a file by removing repetitive
            patterns and replacing them with a code.

        @{FG HIGHLIGHT}
        Compugraphic @{FG TEXT}- A type of scalable font used by Workbench 2.0 and
            Workbench 3.0. Also usable by programs that support Workbench
            based bitmap fonts, used scalable bitmaps generated in real
            time (dependent on the speed of the processor).

                @{"     " link Glossary.F }@{FG HIGHLIGHT} Font     @{FG TEXT}
                @{"     " link Glossary.S }@{FG HIGHLIGHT} Scalable @{FG TEXT}

        @{FG HIGHLIGHT}
        CompuServe @{FG TEXT}- A pay computer network.

        @{FG HIGHLIGHT}
        Computer Aided Drafting @{FG TEXT}- The use of computers to create models,
            plans, and manufacturable products.

        @{FG HIGHLIGHT}
        Computer Rate @{FG TEXT}- The rate at which a modem and a computer are
            connected.

        @{FG HIGHLIGHT}
        Conditional Statement @{FG TEXT}- A programming structure that performs an
            operation when a specific predefined condition or value is met.

                @{"     " link AORM.OS.AmigaDOS/If} SYS:C/If

        @{FG HIGHLIGHT}
        Connection Rate @{FG TEXT}- The rate that two modems connect over a phone
            line.

        @{FG HIGHLIGHT}
        Console Device @{FG TEXT}- An interface between Intuition and windows,
            using ASCII and ANSI text messages.

                @{"     " link AORM.OS.AmigaDOS/Assign  } SYS:C/Assign
                @{"     " link AORM.OS.AmigaDOS/NewCLI  } SYS:C/NewCLI
                @{"     " link AORM.OS.AmigaDOS/NewShell} SYS:C/NewShell

        @{FG HIGHLIGHT}
        Cooked Input @{FG TEXT}- Input data that has been modified in some way.

        @{FG HIGHLIGHT}
        Copy Protection @{FG TEXT}- The process of modifying software such that
            it can only be used by one customer.

        @{FG HIGHLIGHT}
        Copyright @{FG TEXT}- The ownership right for a software product by an
            individual, group, or business. Copyrights are considered
            to be credited to a software product upon creation, and
            copyright protection may be filed with the government.
            Copyrighted products are denoted by the word "Copyright",
            or the © symbol, followed by the year of creation and the
            owner of the copyright. The (C) symbol is not legally admissible
            as a copyright symbol.

                @{"     " link AORM.Index/Alternate_Char 20 } INDEX: © Symbol
                @{"     " link AORM.Index/Alternate_Char 28 } INDEX: ® Symbol

        @{FG HIGHLIGHT}
        CPU @{FG TEXT}- Central Processing Unit, the main chip in a computer.
            Used primarily to perform operations and run programs,
            or to run a given device. Also used to direct traffic
            and appropriate information to the required devices or
            support chips.

                @{"     " link AORM.OS.AmigaDOS/CPU} SYS:C/CPU

        @{FG HIGHLIGHT}
        CPU Slot @{FG TEXT}- An expansion slot designed to provide simple
            upgrades to the Central Processing Unit for faster
            computer operations.

        @{FG HIGHLIGHT}
        Crash @{FG TEXT}- A system failure that requires a reboot.

                @{"     " link Glossary.G }@{FG HIGHLIGHT} GURU Meditation Error    @{FG TEXT}

        @{FG HIGHLIGHT}
        Crosshair @{FG TEXT}- A type of pointer designed the focus the attention of
            the user on the center of the pointer, using either a vertical
            and horizontal line or an "X" shaped symbol.

        @{FG HIGHLIGHT}
        Cursor @{FG TEXT}- A symbol used to mark the location of activity. In text
            modes, the cursor may take the shape of a small rectangular
            block, an underscore, or a vertical bar. The cursor is
            often a blinking character.

                @{"     " link AORM.Index/Conversions} INDEX: ASCII Code

        @{FG HIGHLIGHT}
        Cycle @{FG TEXT}- One unit of a repetitive process.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.D "Glossary - D"
@toc Glossary

        @{FG HIGHLIGHT}
        Darken -

        @{FG HIGHLIGHT}
        Database @{FG TEXT}- A program used to store large amounts of organized
            data.

        @{FG HIGHLIGHT}
        Data @{FG TEXT}- Information as stored by the computer in a program,
            file, source code, or other format.

        @{FG HIGHLIGHT}
        Data Bus @{FG TEXT}- The portion of a bus that is used to transfer data to
            and from memory and the CPU or other I/O device.

        @{FG HIGHLIGHT}
        Data Compression @{FG TEXT}- Decreases the size of a file by replacing
            repetitive patterns with smaller codes.

        @{FG HIGHLIGHT}
        Data Structure @{FG TEXT}- An organized group os similar variables stored
            in one variable, capable of accessing its parts independently
            or as one unit.

        @{FG HIGHLIGHT}
        Data Type @{FG TEXT}- A file format structure for use with Multiview
            that allows any program to access various file formats.

        @{FG HIGHLIGHT}
        Datestamp @{FG TEXT}- The date and time assigned to a file when it was last
            created or modified.

                @{"     " link AORM.OS.AmigaDOS/List} SYS:C/List

        @{FG HIGHLIGHT}
        Datum @{FG TEXT}- One unit of information, as used by a computer.

        @{FG HIGHLIGHT}
        Daughterboard @{FG TEXT}- An expansion board that plugs into a main
            processor board.

        @{FG HIGHLIGHT}
        DCFS @{FG TEXT}- Directory Cached File System, allowing Workbench 3.0
            or greater systems to access directories or drawers
            faster than non-DCFS file systems.

                @{"     " link AORM.Workbench/wb.format} Workbench Format Menu Item

        @{FG HIGHLIGHT}
        Dead Key @{FG TEXT}- A key which does not create a character, but instead
            modifies the next character to be used. Often used to
            display accent symbols over vowels and consenants in foreign
            languages.

                @{"     " link AORM.Index/Alternate_Char 58} INDEX: Dead Keys

        @{FG HIGHLIGHT}
        DECnet @{FG TEXT}- Digital Equipment Corp's Ethernet networking.

        @{FG HIGHLIGHT}
        Decompression @{FG TEXT}- To make a file readable by returning it
            to its original form after decoding a file of codes.

        @{FG HIGHLIGHT}
        Degrader @{FG TEXT}- A program used to slow down faster computers
            in order to stay compatible with slower machines.

        @{FG HIGHLIGHT}
        Delete @{FG TEXT}- The process of removing a trace to a file in memory
            or on disk, or the process of removing data from an editor.
            Files that are deleted are merely marked as "out of service",
            and their storage area is flagged as usable to the system.
            Deleted files can be recovered only if that storage space
            has not been allocated to another file. Generally, when
            attempting to recover a file, it is important to cease
            writing or storing any further data onto the disk before
            attempting to recover the file. Writing to the disk may
            forever remove the file that has been deleted.

                @{"     " link AORM.Index/Conversions} INDEX: ASCII Code
                @{"     " link Glossary.R }@{FG HIGHLIGHT} Recover      @{FG TEXT}
                @{"     " link Glossary.U }@{FG HIGHLIGHT} Undelete     @{FG TEXT}

        @{FG HIGHLIGHT}
        Delimiter @{FG TEXT}- A symbol used ot define the end of a string or
            statement, often a single quote or double quote.

        @{FG HIGHLIGHT}
        DELPHI @{FG TEXT}- A pay computer network.

                @{"     " link Glossary.N }@{FG HIGHLIGHT} Network    @{FG TEXT}

        @{FG HIGHLIGHT}
        Depth Gadget @{FG TEXT}- A gadget which allows windows or screens to
            be arranged, located in the upper right corner of most
            windows or screens, such as found on the Workbench.
            Identified by two small square images, one overlapping
            the other. Workbench 1.x contains two depth gadgets,
            one for pushing to the back and one for pushing to the
            front. Workbench 2.x and 3.x provide a single depth
            gadget that pushes in either direction depending on the
            position of the window in relation to other windows.

                @{"     " rxs "address command 'display.s 303 65 pictures/pic.gadget.depth Depth_Gadget'"} ILBM: Depth Gadget
                @{"     " link Glossary.G }@{FG HIGHLIGHT} Gadget    @{FG TEXT}

        @{FG HIGHLIGHT}
        Depth of Field @{FG TEXT}- A 3D rendering technique that creates a more
            realistic view of a setting, causing objects at a given
            distance from the camera to appear out of focus, as they
            would appear in a real world situation.

                @{"     " link Glossary.R}@{FG HIGHLIGHT} Rendering    @{FG TEXT}

        @{FG HIGHLIGHT}
        Desktop Publishing @{FG TEXT}- The printing of manuscripts and
            publications using computers and software.

        @{FG HIGHLIGHT}
        Desktop Video @{FG TEXT}- The production of television capable video
            broadcasts using computers and software.

        @{FG HIGHLIGHT}
        DevCon @{FG TEXT}- The annual Amiga Developer Conference.

        @{FG HIGHLIGHT}
        Device @{FG TEXT}- A piece of hardware used as part of a computer and a
            software program that references that piece of hardware.

                @{"     " link AORM.OS.AmigaDOS/Assign} SYS:C/Assign
                @{"     " link AORM.OS.AmigaDOS/Info  } SYS:C/Info
                @{"     " link Glossary.H }@{FG HIGHLIGHT} Hardware    @{FG TEXT}

        @{FG HIGHLIGHT}
        DIG @{FG TEXT}- See Display Independent Graphics.

        @{FG HIGHLIGHT}
        DigiPaint3 @{FG TEXT}- NewTek's original HAM paint program, later developing
            into ToasterPaint.

        @{FG HIGHLIGHT}
        Digital @{FG TEXT}- Any system that stores data using numbers.

        @{FG HIGHLIGHT}
        Digital Signal Processor @{FG TEXT}- An integer based math coprocessor used
            for speech recognition, audio control, and serial port control.

        @{FG HIGHLIGHT}
        Digitizer @{FG TEXT}- A hardware device used to record video or audio into
            a computer file.

        @{FG HIGHLIGHT}
        Direct Access @{FG TEXT}- The process by which data is found by using only the
            location of the data as opposed to sequential searches through
            all data until a match is found.

        @{FG HIGHLIGHT}
        Direct Connection @{FG TEXT}- A modem connection without data compression,
            error correction, or flow control.

        @{FG HIGHLIGHT}
        Directional Light @{FG TEXT}- A light in a 3D scene that may be aimed at a
            particular point or object, rather than radiating in all
            directions.

                @{"     " link Glossary.S}@{FG HIGHLIGHT} Spot Light    @{FG TEXT}

        @{FG HIGHLIGHT}
        Direct Memory Access @{FG TEXT}- The ability for a device to access RAM without
            receiving permission from the CPU.

        @{FG HIGHLIGHT}
        Directory @{FG TEXT}- A location on a volume that contains a specific group of
            files, often related.

                @{"     " link Glossary.F}@{FG HIGHLIGHT} File    @{FG TEXT}
                @{"     " link AORM.OS.AmigaDOS/CD     } SYS:C/CD
                @{"     " link AORM.OS.AmigaDOS/Dir    } SYS:C/Dir
                @{"     " link AORM.OS.AmigaDOS/List   } SYS:C/List
                @{"     " link AORM.OS.AmigaDOS/MakeDir} SYS:C/MakeDir

        @{FG HIGHLIGHT}
        DirOpus @{FG TEXT}- A file manipulation program, such as the Workbench, using
            a text only interface. Uses one source directory and once
            destination directory for all operations.

                @{"     " link Glossary.W}@{FG HIGHLIGHT} Workbench    @{FG TEXT}

        @{FG HIGHLIGHT}
        Disabled Interrupt @{FG TEXT}- A condition by which the CPU ignores all interrupt
            requests of a given priority.

                @{"     " link Glossary.P }@{FG HIGHLIGHT} Priority    @{FG TEXT}

        @{FG HIGHLIGHT}
        Disc @{FG TEXT}- A circular storage device used to store information such as
            music, programs, pictures, and text. Often used in reference to
            compact discs or CDROMs. See also Disk.

                @{"     " link Glossary.C }@{FG HIGHLIGHT} Compact Disc     @{FG TEXT}
                @{"     " link Glossary.F }@{FG HIGHLIGHT} Format           @{FG TEXT}
                @{"     " link Glossary.M }@{FG HIGHLIGHT} Magnetic Media   @{FG TEXT}

        @{FG HIGHLIGHT}
        Disk @{FG TEXT}- A magnetic circular storage device used to store information
            such as music, programs, pictures, and text. An abbreviated term
            for "diskette". See also Diskette, Disc.

                @{"     " link AORM.Workbench/wb.format} Workbench Format Menu Item

        @{FG HIGHLIGHT}
        Disk Doctor @{FG TEXT}- A program used to repair bad disks.

                @{"     " link AORM.Workbench/wb.format} Workbench Format Menu Item

        @{FG HIGHLIGHT}
        Diskette @{FG TEXT}- A magnetic circular storage device used to store information
            such as music, programs, pictures, and text. See also Disk.

                @{"     " link AORM.Workbench/wb.format} Workbench Format Menu Item

        @{FG HIGHLIGHT}
        DiskSalv @{FG TEXT}- A better program used to repair bad disks.

                @{"     " link AORM.Workbench/wb.format} Workbench Format Menu Item

        @{FG HIGHLIGHT}
        Displacement Mapping @{FG TEXT}- A type of texture mapping that causes the
            surface of a 3D object to appear as though it has been physically
            modified, when rendered. The actual surface may appear to have
            bumps and ridges when rendered when in fact it may still be a
            flat surface.

                @{"     " link Glossary.B }@{FG HIGHLIGHT} Bump Mapping     @{FG TEXT}
                @{"     " link Glossary.M }@{FG HIGHLIGHT} Mapping          @{FG TEXT}
                @{"     " link Glossary.T }@{FG HIGHLIGHT} Texture Mapping  @{FG TEXT}

        @{FG HIGHLIGHT}
        Display Enhancer @{FG TEXT}- The A3000's built in deinterlacer hardware,
            or any external device designed to remove the flicker
            produced by interlaced video signals. The Amiga 3000
            performs this function using the Amber custom chip, while
            the AGA capable Amigas use a software display deinterlacing
            technique. Any hardware display enhancer contains a memory
            buffer which may contain a screen of maximum size and
            bitplanes.

        @{FG HIGHLIGHT}
        Display Independent Graphics @{FG TEXT}- The ability for the operating system
            to access any graphics board through a specific device driver.
            Similar to Retargettable graphics, as used by the EGS
            system included with various graphics boards.

                @{"     " link Glossary.E }@{FG HIGHLIGHT} EGS                      @{FG TEXT}
                @{"     " link Glossary.R }@{FG HIGHLIGHT} Retargettable Graphics   @{FG TEXT}

        @{FG HIGHLIGHT}
        Distant Light @{FG TEXT}- A light in a 3D scene that appears far from
            the camera or objects and is generally used to light
            the entire scene or large portions of it. Also commonly
            used for lens flare effects.

        @{FG HIGHLIGHT}
        Dithering @{FG TEXT}- Using various pixel densities to simulate more
            colors or shades of a given color. Often uses two or
            more colors in a given area whose colors are similar.
            Only used for graphical images that do not contain
            enough bitplanes to produce more colors. 24 bitplane
            images do not require or benefit from dithering.

        @{FG HIGHLIGHT}
        DMA @{FG TEXT}- Direct Memory Access from a hardware device to RAM,
            bypassing the CPU.

        @{FG HIGHLIGHT}
        DNET @{FG TEXT}- Matt Dillon's networking software, allowing multiple
            shells to open between various machines.

        @{FG HIGHLIGHT}
        Dock @{FG TEXT}- A window interface that uses icons to represent programs,
            in an ordered arrangement, for quick access.

        @{FG HIGHLIGHT}
        DOS @{FG TEXT}- Disk Operating System, allowing a large number of executable
            files to perform desired operations.

        @{FG HIGHLIGHT}
        Dot File @{FG TEXT}- A file whose filename is preceeded by a period, used on
            UNIX systems to represent hidden files.

        @{FG HIGHLIGHT}
        Dot Matrix Printer @{FG TEXT}- A printer that uses a small grid of
            contacts to print characters onto paper.

        @{FG HIGHLIGHT}
        Double Buffering @{FG TEXT}- The use of multiple buffers to store data,
            often for fast output without breaks in between the
            output data.

        @{FG HIGHLIGHT}
        Double Click @{FG TEXT}- The process of pressing a mouse button twice
            in a short period of time so that the computer recognizes
            that a particular action should be taken, such as
            executing a program from the Workbench.

                @{"     " link Glossary.M }@{FG HIGHLIGHT} Mouse    @{FG TEXT}

        @{FG HIGHLIGHT}
        Double Sided Polygon @{FG TEXT}- A polygon that may have both sides
            rendered and visible by the camera.

                @{"     " link Glossary.A }@{FG HIGHLIGHT} 3D                   @{FG TEXT}
                @{"     " link Glossary.P }@{FG HIGHLIGHT} Polygon              @{FG TEXT}
                @{"     " link Glossary.S }@{FG HIGHLIGHT} Single Sided Polygon @{FG TEXT}

        @{FG HIGHLIGHT}
        Drag @{FG TEXT}- The process of moving the mouse while a button is
            depressed, often to move a screen or a window, or to select
            a menu item.

                @{"     " link Glossary.M }@{FG HIGHLIGHT} Mouse    @{FG TEXT}

        @{FG HIGHLIGHT}
        Dragbar @{FG TEXT}- A gadget on a screen or window that allows it to be
            repositioned with the mouse.

                @{"     " rxs "address command 'display.s 303 65 pictures/pic.gadget.dragbar Dragbar_Gadget'"} ILBM: Dragbar Gadget
                @{"     " link Glossary.M }@{FG HIGHLIGHT} Mouse    @{FG TEXT}

        @{FG HIGHLIGHT}
        Driver @{FG TEXT}- A software file that defines how to use a hardware
            device such as a printer.

        @{FG HIGHLIGHT}
        DSP @{FG TEXT}- Digital Signal Processor, an integer based math
            coprocessor used for speech recognition, audio control,
            and serial port control.

        @{FG HIGHLIGHT}
        DTP @{FG TEXT}- Desk Top Publishing, used for creating printed media
            and publications.

        @{FG HIGHLIGHT}
        DTV @{FG TEXT}- Desk Top Video, used for producing broadcast quality
            graphics animations and images.

        @{FG HIGHLIGHT}
        Dynamic @{FG TEXT}- Any structure that allows infinite space arrangements,
            limited only by memory. Dynamic structures may also change
            size without reallocating the entire memory block.

        @{FG HIGHLIGHT}
        Dynamic RAM @{FG TEXT}- A type of RAM that uses capacitors to store data.
            This type of RAM must be powered on a cyclic basis in order
            to keep the data available in the capacitors.

        @{FG HIGHLIGHT}
        Dynamic RAM Disk @{FG TEXT}- Any storage device, such as RAM:, that allows
            information to be stored on a device with modifiable storage
            space and memory allocation.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.E "Glossary - E"
@toc Glossary

        @{FG HIGHLIGHT}
        ECS @{FG TEXT}- Enhanced Chip Set.

        @{FG HIGHLIGHT}
        Editor @{FG TEXT}- Program that allows modification of text files.

                @{"     " link AORM.OS.AmigaDOS/Ed  } SYS:C/Ed
                @{"     " link AORM.OS.AmigaDOS/Edit} SYS:C/Edit
                @{"     " link Glossary.T }@{FG HIGHLIGHT} Text    @{FG TEXT}

        @{FG HIGHLIGHT}
        Edge @{FG TEXT}- A segment of a line connecting between two points,
            as used in a 3D object or polygon. May be rendered
            soft or hard.

                @{"     " rxs "address command 'display.s 225 225 pictures/pic.cube.edge Edge'"} ILBM: Edge
                @{"     " link Glossary.H}@{FG HIGHLIGHT} Hard Edge    @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Soft Edge    @{FG TEXT}

        @{FG HIGHLIGHT}
        Edge Detection @{FG TEXT}- Process of finding where an image contains
            a sub-image, such as the shoulder of a human or the hood
            of a car.

        @{FG HIGHLIGHT}
        EGS @{FG TEXT}- Third party retargetable graphics system, like RTG.

        @{FG HIGHLIGHT}
        Email @{FG TEXT}- Text messages sent privately over a computer network.

        @{FG HIGHLIGHT}
        Emboss @{FG TEXT}- The process of altering an image to make it appear as
            though it had been carved into another surface, such as
            a monetary coin.

        @{FG HIGHLIGHT}
        Emulator @{FG TEXT}- A software or hardware combination that allows one
            computer to run software written for another computer.

        @{FG HIGHLIGHT}
        Enabled Interrupt @{FG TEXT}- The condition that allows the CPU to respond to
            or receive interrupts.

        @{FG HIGHLIGHT}
        Envelopes @{FG TEXT}- Time elapsed calculations of the characteristics of
            a scene and the objects in it, as used by Lightwave.

                @{"     " link Glossary.S}@{FG HIGHLIGHT} Scene    @{FG TEXT}

        @{FG HIGHLIGHT}
        Environmental Variable @{FG TEXT}- A variable that defines a given string
            that may be accessed locally or globally.

        @{FG HIGHLIGHT}
        Envoy @{FG TEXT}- The Amiga's networking software.

        @{FG HIGHLIGHT}
        Erasable Disk @{FG TEXT}- Any disk storage medium that may be reused by
            erasing the information, often magnetically. The process of
            removing the data from a disk is referred to as "formatting".

        @{FG HIGHLIGHT}
        Error Message @{FG TEXT}- A message used to alert the user of the cause
            of an error, such as reported by AmigaDOS, the Workbench,
            or as a GURU message. Often are classified by ID numbers.

                @{"     " link AORM.Index/errors} INDEX: Error Messages
                @{"     " link Glossary.A}@{FG HIGHLIGHT} Alert Object          @{FG TEXT}
                @{"     " link Glossary.G}@{FG HIGHLIGHT} GURU Meditation Error @{FG TEXT}

        @{FG HIGHLIGHT}
        Error Correction @{FG TEXT}- The process of verifying and insuring a data
            transmission.

        @{FG HIGHLIGHT}
        Essence @{FG TEXT}- A set of randomly generated algorithmic texture mappings
            available for 3D modeling and rendering packages.

                @{"     " link Glossary.A}@{FG HIGHLIGHT} Algorithm @{FG TEXT}
                @{"     " link Glossary.R}@{FG HIGHLIGHT} Random    @{FG TEXT}
                @{"     " link Glossary.T}@{FG HIGHLIGHT} Texture   @{FG TEXT}

        @{FG HIGHLIGHT}
        Ethernet @{FG TEXT}- DEC & UNIX hardware networking protocol.

        @{FG HIGHLIGHT}
        EuroDemo @{FG TEXT}- A program written primarily in Europe to demonstrate
            the capabilities of the animation and sound of the Amiga.

        @{FG HIGHLIGHT}
        EuroMagazine @{FG TEXT}- An Amiga magazine distributed in Europe, and often
            imported into the United States. These magazines reflect the
            stronger European entertainment market.

        @{FG HIGHLIGHT}
        Executable @{FG TEXT}- A self-booting file that performs a task.

                @{"     " link AORM.OS.AmigaDOS/Execute} SYS:C/Execute
                @{"     " link AORM.OS.AmigaDOS/Protect} SYS:C/Protect
                @{"     " link Glossary.F }@{FG HIGHLIGHT} File    @{FG TEXT}

        @{FG HIGHLIGHT}
        Execute Cycle @{FG TEXT}- The event of the clock cycle when the CPU
            performs the current operation.

                @{"     " link Glossary.C }@{FG HIGHLIGHT} Clock    @{FG TEXT}
                @{"     " link Glossary.C }@{FG HIGHLIGHT} CPU      @{FG TEXT}

        @{FG HIGHLIGHT}
        Exponential Notation @{FG TEXT}- The use of exponents based upon smaller
            numbers to store large values in smaller memory spaces.

        @{FG HIGHLIGHT}
        Export @{FG TEXT}- The process of saving a file or object in a format that
            is not in its natural format, performing any required
            operations needed to convert it into the desired format.

                @{"     " link Glossary.I}@{FG HIGHLIGHT} Import    @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Save      @{FG TEXT}

        @{FG HIGHLIGHT}
        Expression @{FG TEXT}- A mathematical equation readable by an interpreter
            or compiler.

        @{FG HIGHLIGHT}
        External @{FG TEXT}- A file that is located on a volume and not in memory.

        @{FG HIGHLIGHT}
        Extraction @{FG TEXT}- Removing a file from an archive, decompressing it
            if necessary.

        @{FG HIGHLIGHT}
        Extrude @{FG TEXT}- The process of converting a 2D or planar image into
            a 3D image by adding depth or height and placing an exact
            duplicate of the original on the opposite face of the
            extrusion, connecting the edges for each corresponding
            point.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.F "Glossary - F"
@toc Glossary

        @{FG HIGHLIGHT}
        Face @{FG TEXT}- A viewable surface of a 3D object, containing a fixed
            number of points, interconnected by edges, forming the
            perimeter of the face. Also known as a polygon.

                @{"     " rxs "address command 'display.s 225 225 pictures/pic.cube.face Face'"} ILBM: Face
                @{"     " link Glossary.E}@{FG HIGHLIGHT} Edge      @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Polygon   @{FG TEXT}
                @{"     " link Glossary.T}@{FG HIGHLIGHT} Triangle  @{FG TEXT}

        @{FG HIGHLIGHT}
        Fade @{FG TEXT}- The process of darkening an image until all color registers
            are set to 0, or to another destination register. One image
            may be faded to black, another solid color, or another image.

                @{"     " link Glossary.M }@{FG HIGHLIGHT} Morph    @{FG TEXT}

        @{FG HIGHLIGHT}
        Fast RAM @{FG TEXT}- RAM not accessible by the custom chip set, but from
            other devices and processors.

        @{FG HIGHLIGHT}
        FAQ @{FG TEXT}- Frequently Asked Questions list, providing questions and
            answers that are common among computer users.

        @{FG HIGHLIGHT}
        Fetch Cycle @{FG TEXT}- The event of the clock cycle when the CPU receives
            in memory the next instruction to be performed.

        @{FG HIGHLIGHT}
        FFS @{FG TEXT}- Fast File System disk file storage system.

                @{"     " link AORM.Workbench/wb.format  } Workbench Format Menu Item
                @{"     " link AORM.OS.AmigaDOS/Info     } SYS:C/Info
                @{"     " link Glossary.D }@{FG HIGHLIGHT} Directory Cached File System     @{FG TEXT}
                @{"     " link Glossary.D }@{FG HIGHLIGHT} Disk                             @{FG TEXT}
                @{"     " link Glossary.F }@{FG HIGHLIGHT} Format                           @{FG TEXT}
                @{"     " link Glossary.I }@{FG HIGHLIGHT} International File System        @{FG TEXT}
                @{"     " link Glossary.O }@{FG HIGHLIGHT} Old File System                  @{FG TEXT}
                @{"     " link Glossary.S }@{FG HIGHLIGHT} Storage                          @{FG TEXT}

        @{FG HIGHLIGHT}
        Field @{FG TEXT}- A portion of a frame as used by television standards.
            NTSC video displays 2 fields for every frame in a video
            broadcast, with each of the two fields interlaced to
            produce one frame of an animation or video recording.

                @{"     " link Glossary.F }@{FG HIGHLIGHT} Frame    @{FG TEXT}
                @{"     " link Glossary.N }@{FG HIGHLIGHT} NTSC     @{FG TEXT}
                @{"     " link Glossary.P }@{FG HIGHLIGHT} PAL      @{FG TEXT}
                @{"     " link Glossary.S }@{FG HIGHLIGHT} SECAM    @{FG TEXT}

        @{FG HIGHLIGHT}
        FIFO @{FG TEXT}- First In, First Out management technique, which ensures
            all the older data is used before the newer data.

        @{FG HIGHLIGHT}
        File @{FG TEXT}- A finite sequence of data stored on a volume.

        @{FG HIGHLIGHT}
        Fillit @{FG TEXT}- A bevel used to smooth the inner joint of two connecting
            surfaces.

        @{FG HIGHLIGHT}
        Filter @{FG TEXT}- A type of software driver that modifies or cleans data.

                1. An audio effect that removes tones from a certain
            pitch range.

                2. An imaging effect that applies a special algorithm on an
            image with the intention of providing a particular effect,
            such as antialiasing or blurring.

        @{FG HIGHLIGHT}
        Firmware @{FG TEXT}- CPU instructions or other information stored in ROM
            or other read only storage mediums.

        @{FG HIGHLIGHT}
        Flicker @{FG TEXT}- The effect an interlaced screen causes on some monitors
            while drawing screens.

        @{FG HIGHLIGHT}
        Float @{FG TEXT}- A number that uses fractions in decimal form.

        @{FG HIGHLIGHT}
        Floppy Disk @{FG TEXT}- Any disk that is made out of flexible disks,
            made out of materials such as kevlar.

        @{FG HIGHLIGHT}
        Floppy Drive @{FG TEXT}- Any hardware that accesses floppy disks.

                @{"     " link AORM.OS.AmigaDOS/Info} SYS:C/Info
                @{"     " link Glossary.D }@{FG HIGHLIGHT} Disk    @{FG TEXT}

        @{FG HIGHLIGHT}
        Floptical @{FG TEXT}- A removable storage disk capable of storing 20
            megabytes of data on one 3.5" disk.

        @{FG HIGHLIGHT}
        Flow Control @{FG TEXT}- The buffering system that is used when two modems
            connect at a different rate than either connects to a
            computer.

        @{FG HIGHLIGHT}
        Fog @{FG TEXT}- A type of rendering technique which causes the scene to
            appear within a cloud or mist. Also simulates the visibility
            of air, such that objects in the distance appear in differing
            color qualities than those near the camera or viewpoint.

        @{FG HIGHLIGHT}
        Font @{FG TEXT}- A type of style used to display text to the screen; a
            set particular set of characters all of the same type style.

        @{FG HIGHLIGHT}
        Format @{FG TEXT}- The layout of a storage device or data structure, or the
            process of creating a data structure on a medium. This can
            prepare a disk for storage by the operating system, known
            as @{FG HIGHLIGHT}formatting@{FG TEXT} the disk.

                @{"     " link AORM.Workbench/wb.format } Workbench Format Menu Item
                @{"     " link Glossary.D}@{FG HIGHLIGHT} Disk    @{FG TEXT}

        @{FG HIGHLIGHT}
        FPS @{FG TEXT}- Frames Per Second that an animation or video is displayed.

        @{FG HIGHLIGHT}
        FPU @{FG TEXT}- Floating Point Unit.

        @{FG HIGHLIGHT}
        Frame @{FG TEXT}- A unit of an animation or video sequence, compromising
            of one still picture, often interlaced by two fields. Used
            in television to produce moving images.

                @{"     " link Glossary.F}@{FG HIGHLIGHT} Field    @{FG TEXT}

        @{FG HIGHLIGHT}
        Frame Buffer @{FG TEXT}- An area of RAM used for digitizing images.

        @{FG HIGHLIGHT}
        Fred Fish Disks @{FG TEXT}- A collection of files contained in over 800
            disks and distributed freely by Fred Fish.

        @{FG HIGHLIGHT}
        Frequency @{FG TEXT}- The rate of cycles per second.

        @{FG HIGHLIGHT}
        Frequency Modulation @{FG TEXT}- Using on channel to modify the period of
            the waveform of another channel, to produce special effects.

        @{FG HIGHLIGHT}
        Fringing @{FG TEXT}- The side effect of using HAM modes that cause strange
            discolorations primarily along the edges of pictures.

        @{FG HIGHLIGHT}
        FTP @{FG TEXT}- File Transfer Protocol for UNIX.

        @{FG HIGHLIGHT}
        Function Key @{FG TEXT}- A key of the keyboard that is programmable and may
            serve many functions. Labelled as F1, F2, F3, ... F10.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.G "Glossary - G"
@toc Glossary

        @{FG HIGHLIGHT}
        Gadget @{FG TEXT}- An area of a window that accepts input from the keyboard
            or mouse.

        @{FG HIGHLIGHT}
        Gate @{FG TEXT}- A boolean circuit that results in a boolean value when given
            a boolean or binary operation.

        @{FG HIGHLIGHT}
        General Purpose Registers @{FG TEXT}- CPU registers used for a variety of
            functions, as opposed to specialized registers.

        @{FG HIGHLIGHT}
        GEnie @{FG TEXT}- A pay computer network.

        @{FG HIGHLIGHT}
        Genlock @{FG TEXT}- A device that superimposes video over graphics. Genlocks
            often use the background pen for the video overlay.

        @{FG HIGHLIGHT}
        GIGO @{FG TEXT}- Garbage In, Garbage Out, a software technique that describes
            a mishandled routine that is not performing correctly or that
            purposely returns inaccurate information.

        @{FG HIGHLIGHT}
        Global Variable @{FG TEXT}- A variable that is accesible in the current
            shell and in any other shells.

        @{FG HIGHLIGHT}
        Gradient @{FG TEXT}- A pattern using a range of colors or shades, providing
            a smooth dithered transition.

        @{FG HIGHLIGHT}
        Grid Snap @{FG TEXT}- The process of rounding off a value due to the inability
            of a mouse or other controller to maintain accuracy on highly
            detailed images or modelers. Causes the unit of editing an
            image or 3D object to work in predefined increments, allowing
            for more accurate work.

        @{FG HIGHLIGHT}
        Ground @{FG TEXT}- The surface of the Earth and the layers underneath.

                1. The process of allowing electricity to safely travel to
            an electrically stable object in order to avoid electrical
            faults.

                2.  The surface plane in a 3D world, often found beneath
            the camera when in an upright position. The area directly
            beneath the camera is known as the nadir, and the point at
            which the ground meets the sky is the horizon.

        @{FG HIGHLIGHT}
        GURU Meditation Error @{FG TEXT}- The Amiga's error output when the system has
            malfunctioned and requires rebooting.

                @{"     " link AORM.Index/guru.specific} INDEX: GURU Meditation Errors

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.H "Glossary - H"
@toc Glossary

        @{FG HIGHLIGHT}
        HAM6 @{FG TEXT}- 6 BIT Hold and Modify Mode, permitting
            4,096 colors to be displayable onscreen.

                @{"     " link Glossary.H}@{FG HIGHLIGHT} Hold and Modify Mode    @{FG TEXT}

        @{FG HIGHLIGHT}
        HAM8 @{FG TEXT}- 8 BIT Hold and Modify Mode, permitting
            262,144 colors to be displayable onscreen. Available
            currently on AGA machines only.

                @{"     " link Glossary.H}@{FG HIGHLIGHT} Hold and Modify Mode    @{FG TEXT}

        @{FG HIGHLIGHT}
        Handshake @{FG TEXT}- The process of two devices acknowledging and
            understanding each other; the initial contact of two
            hardware devices.

        @{FG HIGHLIGHT}
        Hard Disk @{FG TEXT}- A disk that is made out of a rigid, inflexible
            material.

        @{FG HIGHLIGHT}
        Hard Drive @{FG TEXT}- Any hardware device that uses disks that are not
            flexible or bendable.

        @{FG HIGHLIGHT}
        Hard Drive Installable @{FG TEXT}- Software that may be installed onto
            a hard drive or similar device.

        @{FG HIGHLIGHT}
        Hard Edge @{FG TEXT}- An edge that is rendered without special shading
            techniques, appearing sharp as opposed to rounded or
            smoothed.

                @{"     " link Glossary.S}@{FG HIGHLIGHT} Sharp Edge    @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Soft Edge     @{FG TEXT}

        @{FG HIGHLIGHT}
        Hard Link @{FG TEXT}- A hard link is a file that accesses another file on
            the same partition.

        @{FG HIGHLIGHT}
        Hardware @{FG TEXT}- Electronic computer devices.

                @{"     " link Glossary.S}@{FG HIGHLIGHT} Software      @{FG TEXT}

        @{FG HIGHLIGHT}
        Hash Function @{FG TEXT}- A function used to create a key value, thereby
            determining where to store the data given to the function.
            May involve extremely simply or very complicated functions.

                @{"     " link Glossary.F}@{FG HIGHLIGHT} Function  @{FG TEXT}
                @{"     " link Glossary.K}@{FG HIGHLIGHT} Key       @{FG TEXT}

        @{FG HIGHLIGHT}
        Hash Table @{FG TEXT}- An array which stores data based upon key values
            assigned to that data using a hash function. The sample
            pictures include some abbreviations for states in the United
            States, classifying them by various methods. Each column
            represents a different hash key based upon the same function.

                @{"     " rxs "address command 'display.s 648  92 pictures/pic.hash.alphabetized  Alphabetized'" } ILBM: Hashing by Alphabetizing
                @{"     " rxs "address command 'display.s 384 158 pictures/pic.hash.first_initial First_Initial'"} ILBM: Hashing by First Initial
                @{"     " rxs "address command 'display.s 215 180 pictures/pic.hash.region        Region'"       } ILBM: Hashing by Region
                @{"     " rxs "address command 'display.s 153 312 pictures/pic.hash.vowel         Vowels'"       } ILBM: Hashing by Vowels & Consenants
                @{"     " link Glossary.A}@{FG HIGHLIGHT} Array    @{FG TEXT}

        @{FG HIGHLIGHT}
        Hayes Command Set @{FG TEXT}- The set of commands which are used to control
            a Hayes compatible modem.

                @{"     " link AORM.Index/Hayes   } INDEX: Hayes Command Set
                @{"     " link AORM.Index/Hayes.S } INDEX: Hayes S Registers
                @{"     " link Glossary.M }@{FG HIGHLIGHT} Modem    @{FG TEXT}

        @{FG HIGHLIGHT}
        Hayes Compatible Modem @{FG TEXT}- A modem that supports the Hayes Command
            Set, made by various modem manufacturers. Although Hayes does
            manufacture modems, it is not necessary to use a Hayes brand
            modem in order to utilize the Hayes Command Set or the various
            terminal programs that support the Hayes Command Set.

        @{FG HIGHLIGHT}
        Hayes S Registers -

        @{FG HIGHLIGHT}
        HDTV @{FG TEXT}- A television standard that supports higher resolutions
            and better displays.

        @{FG HIGHLIGHT}
        Hedley @{FG TEXT}- A greyscale monitor display format.

        @{FG HIGHLIGHT}
        Hidden File @{FG TEXT}- A file that may not be listed depending on the program
            used to list it.

                @{"     " link AORM.OS.AmigaDOS/Protect} SYS:C/Protect

        @{FG HIGHLIGHT}
        Hidden Glossary - A glossary of words in AORM that is only readable
            by double clicking on the word Hidden, or by using a buggy
            version of AmigaGuide.

        Hidden Line -

                @{"     " rxs "address command 'display.s 225 225 pictures/pic.cube.hidden_line Hidden_Lines'"} ILBM: Hidden Lines

        @{FG HIGHLIGHT}
        Highlighted Text @{FG TEXT}- An area or block of text that has been
            selected by the user for some sort of activity, often
            to delete, copy, or replace the highlighted text. The
            highlighted text is displayed in reverse video and appears
            as though each character is displayed on a small rectangular
            box.

        @{FG HIGHLIGHT}
        Hold and Modify Mode @{FG TEXT}- A graphics mode that uses built in hardware
            compression and decompression to increase the number of
            displayable colors on the screen.

        @{FG HIGHLIGHT}
        Horizon -

        @{FG HIGHLIGHT}
        Host @{FG TEXT}- The program or process initiating the given operation.

        @{FG HIGHLIGHT}
        Hotkey -

        @{FG HIGHLIGHT}
        Hot Links @{FG TEXT}- A scripting macro language used for inter-program
            communication.

        @{FG HIGHLIGHT}
        HyperText @{FG TEXT}- The ability to scan or read text applications by
            searching for keywords.

        @{FG HIGHLIGHT}
        Hz @{FG TEXT}- Hertz, the rate at which a chip cycles per second.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.I "Glossary - I"
@toc Glossary


        @{FG HIGHLIGHT}I/O @{FG TEXT}- Input and output.


        @{FG HIGHLIGHT}Icon @{FG TEXT}- A picture on the Workbench that can be manipulated in
            order to manipulate a file that it represents.

                @{"     " rxs "address command 'display.s 143 86 pictures/pic.icon.drawer Drawer'"   } ILBM: Drawer Icon
                @{"     " rxs "address command 'display.s 143 86 pictures/pic.icon.floppy Disk'"     } ILBM: Floppy Disk Icon
                @{"     " rxs "address command 'display.s 143 86 pictures/pic.icon.partition Disk'"  } ILBM: Hard Disk Icon
                @{"     " rxs "address command 'display.s 143 86 pictures/pic.icon.prefs Prefs'"     } ILBM: Preference Drawer Icon
                @{"     " link AORM.Workbench/wb.icons} Workbench Icons Menu


        @{FG HIGHLIGHT}IDE @{FG TEXT}- A format for hard drive expansion buses.


        @{FG HIGHLIGHT}IFF @{FG TEXT}- Interchange File Format for storing pictures and sounds.


        @{FG HIGHLIGHT}Illuminate -


        @{FG HIGHLIGHT}Image -


        @{FG HIGHLIGHT}IML @{FG TEXT}- Imagine Mailing List, a discussion group of Impulse's 3D
            modeling software.


        @{FG HIGHLIGHT}Impact Printer @{FG TEXT}- A method of printing to paper that requires
            physical contact between the printer head and the paper.


        Import -


        @{FG HIGHLIGHT}InFix Notation @{FG TEXT}- The use of operators between two variables.


        @{FG HIGHLIGHT}Input @{FG TEXT}- Data given to hardware or software.


        @{FG HIGHLIGHT}Installer @{FG TEXT}- The Amiga's software installation program, designed to
            simplify and standardize the process of installing new software
            or updating old software.


        @{FG HIGHLIGHT}Installer Script @{FG TEXT}- A text file that is read by the Installer program,
            containing executable commands that may be interpreted and acted
            upon.


        @{FG HIGHLIGHT}Instruction @{FG TEXT}- A command readable by an interpreter or compiler.


        @{FG HIGHLIGHT}Instruction Set @{FG TEXT}- the complete list of commands supported by an
            interpreter or compiler.


        @{FG HIGHLIGHT}Instrument @{FG TEXT}- A digitized audio sample of a particular musical
            instrument or sound, designed to be played as a real musical
            instrument.


        @{FG HIGHLIGHT}Integer @{FG TEXT}- A number format that contains only whole numbers.


        @{FG HIGHLIGHT}Intensity -


        @{FG HIGHLIGHT}Interactivity @{FG TEXT}- A method of designing software that allows
            the user to decide what should occur.


        @{FG HIGHLIGHT}Interchange File Format @{FG TEXT}- A file format, called IFF, that allows
            various types of data to be stored in a standard way.

                @{"     " link AORM.OS.AmigaDOS/Type} SYS:C/Type


        @{FG HIGHLIGHT}Interlace @{FG TEXT}- A screen display mode that has double the verticle
            resolution.


        @{FG HIGHLIGHT}Internal @{FG TEXT}- A file stored in memory, accessible only through the
            Shell.

                @{"     " link AORM.OS.AmigaDOS/NewCLI  } SYS:C/NewCLI
                @{"     " link AORM.OS.AmigaDOS/NewShell} SYS:C/NewShell


        @{FG HIGHLIGHT}International File System -

                @{"     " link AORM.Workbench/wb.format} Workbench Format Menu Item


        @{FG HIGHLIGHT}Internet @{FG TEXT}- A large computer network encompassign various mainframe
            computers on college campuses, businesses, and government
            buildings around the world.


        @{FG HIGHLIGHT}Interpreter @{FG TEXT}- A program that executes commands from a text
            file. Used by scripting langauges, such as AmigaDOS.


        @{FG HIGHLIGHT}Interprocess Communication @{FG TEXT}- The ability to send data between
            applications currently residing in memory.


        @{FG HIGHLIGHT}Intuition @{FG TEXT}- Amiga's graphics environment.

                @{"     " link AORM.OS.AmigaDOS/Version} SYS:C/Version


        @{FG HIGHLIGHT}Inverse Kinematics @{FG TEXT}- The ability to influence pieces of an object
            by moving a connected piece.


        @{FG HIGHLIGHT}IRC @{FG TEXT}- Internet Relay Chat real-time chat line.


        @{FG HIGHLIGHT}ISDN @{FG TEXT}- Replaces analog telephone systems with digital systems.


        @{FG HIGHLIGHT}ISO 9660 @{FG TEXT}- A popular CD ROM standard format.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.J "Glossary - J"
@toc Glossary


        @{FG HIGHLIGHT}JOVE @{FG TEXT}- Jonathan's Own Version of EMACS.


        @{FG HIGHLIGHT}Joystick @{FG TEXT}- A handheld device that allows the user to direct
            activity using a small directional keypad or stick
            controller.


        @{FG HIGHLIGHT}JPEG @{FG TEXT}- A lossy 24 BIT compression format for pictures. Pictures
            converted to JPEG format will suffer some reduction in quality,
            although this often will not be noticed by the human eye.


        @{FG HIGHLIGHT}Jumper @{FG TEXT}- A hardware connection which is adjustable by the user,
            often by moving a small pin on a motherboard or expansion
            card.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.K "Glossary - K"
@toc Glossary

        @{FG HIGHLIGHT}
        Keyboard @{FG TEXT}- The hardware device of a computer used to enter text
            into the computer by a typist. Includes keys containing the
            letters of the alphabet, numbers, function keys, cursor keys,
            control keys, and a numeric keypad. Some keyboards are
            integrated while others are detached and connected via a cord.

                @{"     " link AORM.Index/Alternate_Char 58} INDEX: Dead Keys
                @{"     " rxs "address command 'display.s 228 90 pictures/pic.keyboard.alphabet Alphanumeric'"   } ILBM: Alphanumeric Keys
                @{"     " rxs "address command 'display.s 228 90 pictures/pic.keyboard.CTRL CTRL'"               } ILBM: CTRL Key
                @{"     " rxs "address command 'display.s 228 90 pictures/pic.keyboard.Cursor Cursor'"           } ILBM: Cursor Keys
                @{"     " rxs "address command 'display.s 228 90 pictures/pic.keyboard.ESC ESC'"                 } ILBM: ESC Key
                @{"     " rxs "address command 'display.s 228 90 pictures/pic.keyboard.Function Function'"       } ILBM: Function Keys
                @{"     " rxs "address command 'display.s 228 90 pictures/pic.keyboard.HELP HELP'"               } ILBM: HELP Key
                @{"     " rxs "address command 'display.s 228 90 pictures/pic.keyboard.1 Keyboard'"              } ILBM: Keyboard
                @{"     " rxs "address command 'display.s 228 90 pictures/pic.keyboard.Numeric_Keypad Numeric_Keypad'" } ILBM: Numeric Keypad Keys
                @{"     " rxs "address command 'display.s 228 90 pictures/pic.keyboard.RETURN RETURN'"           } ILBM: RETURN Key
                @{"     " rxs "address command 'display.s 228 90 pictures/pic.keyboard.RIGHT_AMIGA RIGHT_AMIGA'" } ILBM: RIGHT AMIGA Key
                @{"     " rxs "address command 'display.s 228 90 pictures/pic.keyboard.SPACE SPACE'"             } ILBM: SPACE Key
                @{"     " link AORM.OS.AmigaDOS/SetKeyboard} SYS:C/SetKeyboard
                @{"     " link Glossary.F   }@{FG HIGHLIGHT} Keymap             @{FG TEXT}

        @{FG HIGHLIGHT}
        Keyboard Garage @{FG TEXT}- An area under the A1000 that provides room to
            store the keyboard.

        @{FG HIGHLIGHT}
        Keyboard Shortcut @{FG TEXT}- A sequence of keypresses that cause another
            more complicated action to occur in a program or on the
            Workbench. These may be single keypresses or combinations using
            keys such as CTRL, LEFT-AMIGA, or SHIFT. Many are user definable,
            while others are denoted in menus using a special symbol followed
            by the corresponding key. Menu keyboard shortcuts are accessed
            by pressing the RIGHT-AMIGA key and the denoted key simultaneously.

                @{"     " link Glossary.H }@{FG HIGHLIGHT} Hotkey       @{FG TEXT}
                @{"     " link Glossary.M }@{FG HIGHLIGHT} Macro        @{FG TEXT}

        @{FG HIGHLIGHT}
        Key Frame @{FG TEXT}- A frame of an animation where a key event occurs, such as
            the beginning of a new motion or morph. Key frames are defined by
            the animator using numeric values to denote positions of objects
            or their relative speeds, while non-key frames are calculated
            automatically using animation or similar software.

                @{"     " link Glossary.F }@{FG HIGHLIGHT} Frame        @{FG TEXT}
                @{"     " link Glossary.A }@{FG HIGHLIGHT} Animation    @{FG TEXT}

        @{FG HIGHLIGHT}
        Keymap @{FG TEXT}- A file that contains information regarding the layout of
            keys on a keyboard, including special alternate character sets
            and dead keys used in foreign languages.

                @{"     " link AORM.Index/alternate_char} INDEX: Alternate Character Sets
                @{"     " link Glossary.C }@{FG HIGHLIGHT} Character    @{FG TEXT}
                @{"     " link Glossary.I }@{FG HIGHLIGHT} Input        @{FG TEXT}

        @{FG HIGHLIGHT}
        Kickstart @{FG TEXT}- The Amiga's operating system, stored mostly in ROM,
            consisting of Exec, Intuition, shared libraries, and the Amiga's
            other custom software routines.

                @{"     " link AORM.Index/Kickstart      } INDEX: Kickstart Revisions
                @{"     " link AORM.OS.AmigaDOS/SetPatch } SYS:C/SetPatch
                @{"     " link AORM.OS.AmigaDOS/Version  } SYS:C/Version
                @{"     " link Glossary.L }@{FG HIGHLIGHT} Library              @{FG TEXT}
                @{"     " link Glossary.O }@{FG HIGHLIGHT} Operating System     @{FG TEXT}
                @{"     " link Glossary.R }@{FG HIGHLIGHT} ROM                  @{FG TEXT}

        @{FG HIGHLIGHT}
        Kilobyte @{FG TEXT}- A measure of storage space, equaling 1024 bytes.

                @{"     " link Glossary.B }@{FG HIGHLIGHT} Byte         @{FG TEXT}
                @{"     " link Glossary.S }@{FG HIGHLIGHT} Storage      @{FG TEXT}

        @{FG HIGHLIGHT}
        KingFisher @{FG TEXT}- A database for searching through Fred Fish disk
            libraries, containing a cross reference table of all current
            files and the disks they are located on. Includes software
            which allows new Fred Fish disk announcements to be included
            in the KingFisher cross reference system.

                @{"     " link Glossary.D }@{FG HIGHLIGHT} Database         @{FG TEXT}
                @{"     " link Glossary.F }@{FG HIGHLIGHT} Fred Fish Disk   @{FG TEXT}
                @{"     " link Glossary.P }@{FG HIGHLIGHT} Public Domain    @{FG TEXT}

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.L "Glossary - L"
@toc Glossary


        @{FG HIGHLIGHT}Label @{FG TEXT}- A word or number used to define the beginning of a routine
            within a program's source code.

                @{"     " link Glossary.P}@{FG HIGHLIGHT} Program       @{FG TEXT}
                @{"     " link Glossary.R}@{FG HIGHLIGHT} Routine       @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Source Code   @{FG TEXT}


        @{FG HIGHLIGHT}LAN @{FG TEXT}- Local Area Network; a group of personal computers networked
            together.

                @{"     " link Glossary.N}@{FG HIGHLIGHT} Network      @{FG TEXT}


        @{FG HIGHLIGHT}Landscape Generator @{FG TEXT}- A software program that creates scenic
            landscapes, often for use with 3D modeling.

                @{"     " link Glossary.M}@{FG HIGHLIGHT} Modeling      @{FG TEXT}


        @{FG HIGHLIGHT}Language @{FG TEXT}- A set of commands and functions used by a compiler
            or interpreter to perform a specific set of operations.

                @{"     " link Glossary.C}@{FG HIGHLIGHT} Command       @{FG TEXT}
                @{"     " link Glossary.C}@{FG HIGHLIGHT} Compiler      @{FG TEXT}
                @{"     " link Glossary.F}@{FG HIGHLIGHT} Function      @{FG TEXT}
                @{"     " link Glossary.I}@{FG HIGHLIGHT} Interpreter   @{FG TEXT}
                @{"     " link Glossary.O}@{FG HIGHLIGHT} Operation     @{FG TEXT}


        @{FG HIGHLIGHT}Laser Printer @{FG TEXT}- A device that prints text or graphics to paper
            using light beams, much like a photocopier or FAX machine.

                @{"     " link Glossary.F}@{FG HIGHLIGHT} FAX       @{FG TEXT}
                @{"     " link Glossary.G}@{FG HIGHLIGHT} Graphics  @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Printer   @{FG TEXT}
                @{"     " link Glossary.T}@{FG HIGHLIGHT} Text      @{FG TEXT}

        @{FG HIGHLIGHT}
        Lathe -

        @{FG HIGHLIGHT}
        Layer -

        @{FG HIGHLIGHT}Lee Stranagan @{FG TEXT}- A famous author and tutor for the Video Toaster.


        @{FG HIGHLIGHT}Lens -

                @{"     " link Glossary.C}@{FG HIGHLIGHT} Camera      @{FG TEXT}


        @{FG HIGHLIGHT}Lens Flare @{FG TEXT}- A technique used in 3D animation which causes a
            light source to appear on a lens in order to simulate the
            effect of a real light source affecting a real video camera.

                @{"     " link Glossary.A}@{FG HIGHLIGHT} Anamorphic Squeeze    @{FG TEXT}
                @{"     " link Glossary.A}@{FG HIGHLIGHT} Anamorphic Streaks    @{FG TEXT}
                @{"     " link Glossary.C}@{FG HIGHLIGHT} Camera                @{FG TEXT}
                @{"     " link Glossary.L}@{FG HIGHLIGHT} Lens Reflections      @{FG TEXT}
                @{"     " link Glossary.O}@{FG HIGHLIGHT} Outer Glow            @{FG TEXT}


        @{FG HIGHLIGHT}Lens Reflections @{FG TEXT}- Light reflections that appear in video recorded
            using complex lens combinations, causing multiple reflections
            to appear for any given light source.

                @{"     " link Glossary.C}@{FG HIGHLIGHT} Camera      @{FG TEXT}


        @{FG HIGHLIGHT}Letterbox -


        @{FG HIGHLIGHT}Library @{FG TEXT}- A collection of compiled routines that can be accessed
            by more than one application.

                @{"     " link AORM.OS.AmigaDOS/Avail} SYS:C/Avail


        @{FG HIGHLIGHT}Light -


        @{FG HIGHLIGHT}Light Pen @{FG TEXT}- An electronic pen used to draw directly on the
            monitor's screen by placing the tip of the light pen on
            the glass surface of the monitor.

                @{"     " link Glossary.M}@{FG HIGHLIGHT} Monitor      @{FG TEXT}

        @{FG HIGHLIGHT}
        Light Sourcing -

                @{"     " rxs "address command 'display.s 225 225 pictures/pic.cube.6 Light_Sourcing'"} ILBM: Light Sourcing


        @{FG HIGHLIGHT}Lightwave @{FG TEXT}- NewTek's 3D animation stage editor, for use with the
            Video Toaster.

                @{"     " link Glossary.A}@{FG HIGHLIGHT} Animation         @{FG TEXT}
                @{"     " link Glossary.V}@{FG HIGHLIGHT} Video Toaster     @{FG TEXT}


        @{FG HIGHLIGHT}Line Feed @{FG TEXT}- A command sent to a device to advance the current
            position to the next line of output.

                @{"     " link Glossary.D}@{FG HIGHLIGHT} Device      @{FG TEXT}
                @{"     " link Glossary.O}@{FG HIGHLIGHT} Output      @{FG TEXT}


        @{FG HIGHLIGHT}Load @{FG TEXT}- The process of bringing a file from disk into the memory of
            the computer. Files stored on disk are retained when the computer
            is turned off, while files loaded in memory are not retained
            when the computer is turned off. Loading a file from disk does
            not change the file on disk.


        @{FG HIGHLIGHT}Local Variable @{FG TEXT}- A variable that is only accesible in the current
            shell or in any shells spawned from that shell.


        @{FG HIGHLIGHT}Locale @{FG TEXT}- The Amiga's multilingual environment.


        @{FG HIGHLIGHT}Locked File @{FG TEXT}- A file that is currently being used by another program.


        @{FG HIGHLIGHT}Locked Device @{FG TEXT}- A device that cannot be written to.

                @{"     " link AORM.OS.AmigaDOS/Info} SYS:C/Info
                @{"     " link AORM.OS.AmigaDOS/Lock} SYS:C/Lock


        @{FG HIGHLIGHT}Logical Operations @{FG TEXT}- the use of AND, NOT, OR, and XOR in functions
            or mathematical equations.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.M "Glossary - M"
@toc Glossary


        @{FG HIGHLIGHT}Macro @{FG TEXT}- A user defined or user created sequence of events that
            can be stored and reused by an application or program.


        @{FG HIGHLIGHT}Maps -


        @{FG HIGHLIGHT}Mapping -


        @{FG HIGHLIGHT}MED @{FG TEXT}- A public domain music editor by Teijo Kennen.


        @{FG HIGHLIGHT}Megabyte @{FG TEXT}- A measure of storage space, equaling 1024 kilobytes.

                @{"     " link AORM.OS.AmigaDOS/Avail   } SYS:C/Avail
                @{"     " link AORM.OS.AmigaDOS/Info    } SYS:C/Info
                @{"     " link Glossary.K}@{FG HIGHLIGHT} Kilobyte    @{FG TEXT}


        @{FG HIGHLIGHT}Memory @{FG TEXT}- The area where data is stored temporarily in order to
            work with programs and any software.

                @{"     " link AORM.OS.AmigaDOS/Avail} SYS:C/Avail


        @{FG HIGHLIGHT}Menu @{FG TEXT}- A list of commands accessible by the menu button of the
            mouse, displayed in upper most bar of a screen.


        @{FG HIGHLIGHT}Menu Button @{FG TEXT}- The right mouse button, used to display a window's
            menu.


        @{FG HIGHLIGHT}Message Port @{FG TEXT}- An accessible location of an application designed
            to send and receive messages, such as with ARexx.


        @{FG HIGHLIGHT}MicroPace @{FG TEXT}- A large distributor of Amiga hardware and software
            products.


        @{FG HIGHLIGHT}MIDI @{FG TEXT}- A music and audio based expansion bus.


        @{FG HIGHLIGHT}MMU @{FG TEXT}- Memory Management Unit.


        @{FG HIGHLIGHT}MNP @{FG TEXT}- Error correction protocols.


        @{FG HIGHLIGHT}Modem @{FG TEXT}- A hardware device used to send data between computers,
            often over telephone lines.


        @{FG HIGHLIGHT}Modeler @{FG TEXT}- NewTek's 3D object modeling software, for use with the
            Video Toaster.


        @{FG HIGHLIGHT}Modeler 3D @{FG TEXT}- One of NewTek's earliest software packages, a 3D
            object modeler for Amiga computers.


        @{FG HIGHLIGHT}Module @{FG TEXT}- A musical score designed to be played with a module
            player.


        @{FG HIGHLIGHT}Monaural @{FG TEXT}- An audio output format that allows only one channel of
            output, consisting of all available outputs combined.


        @{FG HIGHLIGHT}Monochrome @{FG TEXT}- A video mode allowing only two colors.


        @{FG HIGHLIGHT}More @{FG TEXT}- A text reader used to display text to the Shell or CLI,
            pausing at each page.


        @{FG HIGHLIGHT}Morph @{FG TEXT}- A transition of one image or object into another.


        @{FG HIGHLIGHT}Motherboard @{FG TEXT}- The computer hardware that contains the chips and
            expansion required to operate a computer.


        @{FG HIGHLIGHT}Motion Blur @{FG TEXT}- Process of blurring an image to give it the
            appearance of motion.


        @{FG HIGHLIGHT}Motion Graph -


        @{FG HIGHLIGHT}Motion Path -


        @{FG HIGHLIGHT}Mouse @{FG TEXT}- A handheld device used to control the sprite cursor on
            the screen, by placing imaginary screen coordinates on a
            tabletop surface.


        @{FG HIGHLIGHT}Mouse Pointer -


        @{FG HIGHLIGHT}MPEG @{FG TEXT}- A video and animation compression format.


        @{FG HIGHLIGHT}MS-DOS @{FG TEXT}- An outdated operating system.


        @{FG HIGHLIGHT}MUI @{FG TEXT}- Magic User Interface.


        @{FG HIGHLIGHT}Multimedia @{FG TEXT}- The combination of different output formats, such
            as text, graphics, and audio, into a single presentation.


        @{FG HIGHLIGHT}Multiscan @{FG TEXT}- A type of monitor capable of syncing to a wide range
            of frequencies.


        @{FG HIGHLIGHT}Multi Serial Board @{FG TEXT}- A hardware board that contains one or more
            serial ports that may be used to connect to multiple computers.


        @{FG HIGHLIGHT}Multisync @{FG TEXT}- A type of monitor capable of syncing to a wide range
            of frequencies.


        @{FG HIGHLIGHT}Multiview @{FG TEXT}- A Workbench tool designed to operate on various file types,
            such as to display an image or animation, or hear an audio sample
            or musical score.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.N "Glossary - N"
@toc Glossary


        @{FG HIGHLIGHT}NAB @{FG TEXT}- National Association of Broadcasters.


        @{FG HIGHLIGHT}Nadir @{FG TEXT}- The area of a surface plane directly beneath the camera in
            a 3D world.


        @{FG HIGHLIGHT}National Association of Broadcasters @{FG TEXT}- A group of video specialists
            devoted to video production and the application of video
            technology.


        @{FG HIGHLIGHT}NewTek @{FG TEXT}- A video hardware and software company based in Topeka,
            Kansas.


        @{FG HIGHLIGHT}NFS @{FG TEXT}- UNIX Network File System.


        @{FG HIGHLIGHT}NLQ @{FG TEXT}- Near Letter Quality, the best capable printed output from a
            given printer.


        @{FG HIGHLIGHT}Node -


        @{FG HIGHLIGHT}NoiseTracker @{FG TEXT}- A format for music compositions.


        @{FG HIGHLIGHT}Normal Connection @{FG TEXT}- A modem connection that allows flow control
            but no error correction or data compression.


        @{FG HIGHLIGHT}Novell @{FG TEXT}- IBM networking protocol.


        @{FG HIGHLIGHT}NTSC @{FG TEXT}- A North American television broadcast standard, also used
            in parts of Latin America and Japan.


        @{FG HIGHLIGHT}NULL Modem @{FG TEXT}- A cable or adapter that allows two computers to connect
            using standard serial ports and terminal software. Some lines
            from the serial ports are crossed.


        @{FG HIGHLIGHT}Numeric Keypad @{FG TEXT}- The area to the right of most keyboards, designed
            to simplify numerical data entry.


        @{FG HIGHLIGHT}NURBS -


        @{FG HIGHLIGHT}NuTech @{FG TEXT}- A company that has reverse engineered the Apple Macintosh
            ROM chips, and has created a Macintosh compatible motherboard.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.O "Glossary - O"
@toc Glossary


        @{FG HIGHLIGHT}Object @{FG TEXT}- A software creation that combines various graphical images
            into one image. A three dimensional computer representation of
            a physical thing.


        @{FG HIGHLIGHT}OCS @{FG TEXT}- Original Chip Set.


        @{FG HIGHLIGHT}OFS @{FG TEXT}- Old File System.

                @{"     " link AORM.Workbench/wb.format} Workbench Format Menu Item


        @{FG HIGHLIGHT}Omnidirectional Light -


        @{FG HIGHLIGHT}Operators @{FG TEXT}- Symbols used in a programming language to perform
            specific mathematical operations.


        @{FG HIGHLIGHT}Optical Character Recognition @{FG TEXT}- The process of understanding
            handwritten or typed characters, on a printed page,
            using computer software.


        @{FG HIGHLIGHT}Optical Mouse @{FG TEXT}- A mouse that uses beams of light to detect
            movement. This requires no moving parts and has more
            reliable and stable motion.


        @{FG HIGHLIGHT}Order of Operations @{FG TEXT}- The method used to interpret an expression,
            often assigning priorities to given instructions or symbols.


        @{FG HIGHLIGHT}OS @{FG TEXT}- Operating System, the set of commands in the computer.


        @{FG HIGHLIGHT}Outer Glow -

                @{"     " link Glossary.L}@{FG HIGHLIGHT} Lens Flare    @{FG TEXT}


        @{FG HIGHLIGHT}Outline Font @{FG TEXT}- A font that is scalable without losing data. In
            most cases, increasing the size of an outline font will
            increase the detail.


        @{FG HIGHLIGHT}Output @{FG TEXT}- Data received by hardware or software.


        @{FG HIGHLIGHT}Oversampling @{FG TEXT}- The technique by which data is read multiple times, in
            order to use the average of the data or that which appears more
            often. Repetitive oversampling leads to more reliable results.


        @{FG HIGHLIGHT}Overscan @{FG TEXT}- The area surrounding the visible screen that is unused
            or available using the Overscan preference program.


        @{FG HIGHLIGHT}Overwrite @{FG TEXT}- The process of destroying an old file by saving a new
            file on top of the old file, of the same name.

                @{"     " link AORM.OS.AmigaDOS/Protect} SYS:C/Protect

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.P "Glossary - P"
@toc Glossary


        @{FG HIGHLIGHT}PAL @{FG TEXT}- A primarily European television broadcast standard, also
            used in New Zealand and Australia.


        @{FG HIGHLIGHT}Palette @{FG TEXT}- The selection of colors made available to a screen.


        @{FG HIGHLIGHT}Parallel Port @{FG TEXT}- An external port used for printers, networking,
            scanners, and other hardware devices.


        @{FG HIGHLIGHT}Parameter @{FG TEXT}- A small message or option sent to a program.

                @{"     " link AORM.Index/Template} INDEX: AmigaDOS Template


        @{FG HIGHLIGHT}Parameter Passing @{FG TEXT}- The process of sending messages to a file from
            the Shell or CLI.

                @{"     " link AORM.Index/Template} INDEX: AmigaDOS Template


        @{FG HIGHLIGHT}Parent @{FG TEXT}- The directory which contains the current directory.

                @{"     " link AORM.OS.AmigaDOS/CD} SYS:C/CD


        @{FG HIGHLIGHT}Parsing @{FG TEXT}- The process of extracting a substring from a parent string.


        @{FG HIGHLIGHT}Particle Animation @{FG TEXT}- 3D animation technique that determines how
            objects behave in a given environment, allowing for gravity,
            friction, wind, magnetism, and acceleration.


        @{FG HIGHLIGHT}Particle Blur -


        @{FG HIGHLIGHT}Partition @{FG TEXT}- A finite area on a device.

                @{"     " link AORM.OS.AmigaDOS/Info} SYS:C/Info


        @{FG HIGHLIGHT}Pass Through @{FG TEXT}- A hardware interface which is duplicated on an
            expansion device such that multiple devices may be used on
            a single expansion slot.


        @{FG HIGHLIGHT}Path @{FG TEXT}- A list of directories that is searched whenever a command is
            entered at the Shell or CLI.

                @{"     " link AORM.OS.AmigaDOS/Assign} SYS:C/Assign
                @{"     " link AORM.OS.AmigaDOS/Path  } SYS:C/Path


        @{FG HIGHLIGHT}Pattern Matching @{FG TEXT}- The process of recognizing multiple files using
            common features of the filenames.

                @{"     " link AORM.Index/Pattern} INDEX: AmigaDOS Pattern Matching


        @{FG HIGHLIGHT}Paula @{FG TEXT}- The Amiga's audio, serial, and floppy control chip.


        @{FG HIGHLIGHT}PCMCIA @{FG TEXT}- An expansion bus using small credit-card like memory
            storage units.


        @{FG HIGHLIGHT}PD Software @{FG TEXT}- Public Doman freely distributable software.


        @{FG HIGHLIGHT}Pen @{FG TEXT}- A color from the palette capable of drawing graphics on the
            screen.


        @{FG HIGHLIGHT}Period @{FG TEXT}- The elapsed time between sound samples.


        @{FG HIGHLIGHT}Personal Video Production @{FG TEXT}- A term used to describe desktop
            video, when made in reference to the Video Toaster, due to
            the large number of amateurs and professionals using the
            Video Toaster.


        @{FG HIGHLIGHT}Perspective @{FG TEXT}- The technique or method used to display a three
            dimensional image in a two dimensional way, using vanishing
            points and horizons.


        @{FG HIGHLIGHT}PhonePak -


        @{FG HIGHLIGHT}Photo CD @{FG TEXT}- A file format which stores 24 BIT pictures on CD ROM,
            developed from consumer photo cameras.


        @{FG HIGHLIGHT}PIN1 @{FG TEXT}- The first pin on a drive cable that matches with the
            red colored pin of the interface ribbon.


        @{FG HIGHLIGHT}PIP @{FG TEXT}- Picture In Picture video display which superimposes a live
            video image over another live video image.


        @{FG HIGHLIGHT}Pipe @{FG TEXT}- A programming structure which allows one program to direct
            output to another program.


        @{FG HIGHLIGHT}Pixel @{FG TEXT}- The Picture Element, a small colored dot used to create
            any image.

                @{"     " link AORM.Index/Aspect} INDEX: Pixel Aspect Ratios


        @{FG HIGHLIGHT}Pixel Aspect Ratio @{FG TEXT}- See Aspect Ratio.

        @{FG HIGHLIGHT}
        Planar View -

        @{FG HIGHLIGHT}PLink @{FG TEXT}- American PeopleLink, a pay computer network, no longer in
            service.


        @{FG HIGHLIGHT}Plotter @{FG TEXT}- A hardware device, much like a printer, that draws
            images using felt pens of various sizes and colors.


        @{FG HIGHLIGHT}Point -

                @{"     " rxs "address command 'display.s 225 225 pictures/pic.cube.point Point'"} ILBM: Point


        @{FG HIGHLIGHT}Point Light -


        @{FG HIGHLIGHT}Polygon -

                @{"     " rxs "address command 'display.s 225 225 pictures/pic.cube.polygon Polygon'"} ILBM: Polygon


        @{FG HIGHLIGHT}Port @{FG TEXT}- An accessible location of an application designed to send
            and receive messages, such as with ARexx.

                @{"     " link AORM.OS.AmigaDOS/Mount} SYS:C/Mount


        @{FG HIGHLIGHT}Portal @{FG TEXT}- A computer network for files and messages. Monthly fee
             required. May also include an hourly fee for most subscribers.


        @{FG HIGHLIGHT}PostFix Notation @{FG TEXT}- The use of operators following a variable or
            group of variables.


        @{FG HIGHLIGHT}PostScript @{FG TEXT}- A popular printing format for desk top publishing
            software.


        @{FG HIGHLIGHT}PostScript Font @{FG TEXT}- A scalable font usable with Lightwave 3.0 to
            create 3D font objects.


        @{FG HIGHLIGHT}Power Down @{FG TEXT}- The process of turning off a computer.


        @{FG HIGHLIGHT}Power Up @{FG TEXT}- The process of turning on a computer. Also the name
            of CBM's promotional upgrades.


        @{FG HIGHLIGHT}Precision @{FG TEXT}- The amount of information stored in a numeric value,
            with more precise numbers containing more decimal positions.


        @{FG HIGHLIGHT}Prefix Notation @{FG TEXT}- The use of operators preceeding a variable or
            group of variables.

        @{FG HIGHLIGHT}
        Preview Window -

        @{FG HIGHLIGHT}Primitive @{FG TEXT}- A simple 3D geometric figure.


        @{FG HIGHLIGHT}Printer @{FG TEXT}- A hardware device that outputs a file to paper.


        @{FG HIGHLIGHT}Priority @{FG TEXT}- A value assigned to a task to determine how frequently
            it may have access to the CPU or devices.

                @{"     " link AORM.OS.AmigaDOS/ChangeTaskPri} SYS:C/ChangeTaskPri


        @{FG HIGHLIGHT}Procedural Maps -


        @{FG HIGHLIGHT}Process @{FG TEXT}- A software program or element being used by the system.


        @{FG HIGHLIGHT}Program @{FG TEXT}- A binary file used to perform a specific operation on
            a computer system. Also referred to as applications, tools,
            utilities, scripts, or commands.


        @{FG HIGHLIGHT}Programming Language @{FG TEXT}- A set of commands and functions used by a
            compiler or interpreter to perform a specific set of operations.


        @{FG HIGHLIGHT}Progress Indicator @{FG TEXT}- A bar graph used to show the proportion
            of time remaining to complete an operation.


        @{FG HIGHLIGHT}Projection Maps -


        @{FG HIGHLIGHT}Proportional Text @{FG TEXT}- Any characters that are not of fixed width,
            such that smaller and thinner characters require less space
            than wider and larger characters. Generally these characters
            have a fixed height but a dynamic width.


        @{FG HIGHLIGHT}Protection BIT @{FG TEXT}- A toggle used to define specific characteristics
            of a file.

                @{"     " link AORM.OS.AmigaDOS/Delete } SYS:C/Delete
                @{"     " link AORM.OS.AmigaDOS/Execute} SYS:C/Execute
                @{"     " link AORM.OS.AmigaDOS/List   } SYS:C/List
                @{"     " link AORM.OS.AmigaDOS/Protect} SYS:C/Protect


        @{FG HIGHLIGHT}Pure file -

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.Q "Glossary - Q"
@toc Glossary

        @{FG HIGHLIGHT}
        Qualifier -

                @{"     " link AORM.Index/Qualifiers} INDEX: AmigaDOS Qualifiers

        @{FG HIGHLIGHT}
        Quickshade -

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.R "Glossary - R"
@toc Glossary


        @{FG HIGHLIGHT}RAD @{FG TEXT}- A fixed size RAM disk that survives a warm reboot.

                @{"     " link AORM.OS.AmigaDOS/Info } SYS:C/Info
                @{"     " link AORM.OS.AmigaDOS/Mount} SYS:C/Mount

        @{FG HIGHLIGHT}
        Rail -


        @{FG HIGHLIGHT}RAM @{FG TEXT}- Random Access Memory. Temporary data storage area of
            computer chips.

                @{"     " link AORM.OS.AmigaDOS/Avail} SYS:C/Avail


        @{FG HIGHLIGHT}Raw Input @{FG TEXT}- Input data that is provided unmodified to a task.


        @{FG HIGHLIGHT}Ray -


        @{FG HIGHLIGHT}Raytrace @{FG TEXT}- A rendering technique which follow the pathway of light
            beams in order to determine the color shading of a given pixel
            on a given surface. This technique is capable of determining
            the refraction and reflection of light through given surfaces.


        @{FG HIGHLIGHT}Realistic Mode -


        @{FG HIGHLIGHT}Recoverable RAM Disk @{FG TEXT}- Any device, such as RAD: or VD0:, that
            allows data to be maintained and reused after reseting the
            computer.


        @{FG HIGHLIGHT}Recursion @{FG TEXT}- A type of loop structure that uses the original
            routine to determine an answer from a base case. The routine
            determines its answer from a generating function calculated
            against the base case. If no base case is defined, the
            routine will loop infinitely. See also Recursion.


        @{FG HIGHLIGHT}Redirection @{FG TEXT}- The method of directing output to a device or file.
            May be invoked from a CLI or Shell using the > or < symbol.
            The > symbol directs output to a given filename, while the
            < directs input from a given file.


        @{FG HIGHLIGHT}Reentrant File @{FG TEXT}- A file or program that may be executed or used by
            two different tasks simultaneously.


        @{FG HIGHLIGHT}Reference Grid -


        @{FG HIGHLIGHT}Reflection -


        @{FG HIGHLIGHT}Refraction @{FG TEXT}- Process of bending an image or light when viewed through
            another refractive object. Often used in ray tracing programs
            and image manipulation software.


        @{FG HIGHLIGHT}Rename @{FG TEXT}- The process of changing the name of a file to another name,
            often similar to the original name. The file contents are not
            modified in any way, yet the file will be listed as another name.

                @{"     " link AORM.OS.AmigaDOS/Rename} SYS:C/Rename


        @{FG HIGHLIGHT}Render @{FG TEXT}- The process of creating an image from a scene of 3D objects.


        @{FG HIGHLIGHT}Requester -

                @{"     " link AORM.Index/control_codes} INDEX: AmigaDOS Control Codes


        @{FG HIGHLIGHT}Resident -


        @{FG HIGHLIGHT}Resolution @{FG TEXT}- The measure of the number of pixels used in a screen,
            often measured in a horizontal and a vertical number, such as
            640x400 or 400x600.


        @{FG HIGHLIGHT}Resource Tracking @{FG TEXT}- The ability to monitor how the filing system,
            memory, and messages are being used and freed by an application.


        @{FG HIGHLIGHT}RexxMast @{FG TEXT}- The ARexx server, used to provide interprocess
            communications.


        @{FG HIGHLIGHT}RGB @{FG TEXT}- Red, Green, and Blue color data, used ot define the color of
            a light source or palette color. All colors are defined by a
            combination of Red, Green, and Blue colors. A list of colors
            and their RGB values may be found in the Index.

                @{"     " link AORM.Index/color_table   } INDEX: Color Table


        @{FG HIGHLIGHT}Rigid Disk Block @{FG TEXT}- A feature of 2.x and 3.0 Amigas which allows
            information about a hard disk to be stored on that hard disk
            as opposed to a mountlist.

                @{"     " link AORM.Workbench/wb.format} Workbench Format Menu Item


        @{FG HIGHLIGHT}Ripper @{FG TEXT}- A program that is capable of scanning memory for musical
            or graphical data.


        @{FG HIGHLIGHT}Ripple -


        @{FG HIGHLIGHT}RKM @{FG TEXT}- ROM Kernal Manual, the documentation for the Amiga
            operating system and hardware.


        @{FG HIGHLIGHT}RMA Number @{FG TEXT}- A number assigned to a customer and a product in the
            event it is returned for repair or replacement.


        @{FG HIGHLIGHT}ROM @{FG TEXT}- Read Only Memory. Permanent data storage area of computer
            chips.


        @{FG HIGHLIGHT}Root @{FG TEXT}- A directory that has no parent, being the first node of the
            tree structure.

                @{"     " link AORM.OS.AmigaDOS/CD} SYS:C/CD


        @{FG HIGHLIGHT}Roundit @{FG TEXT}- A type of bevel that smooths the outer edge of two
            intersecting surfaces.


        @{FG HIGHLIGHT}Row -


        @{FG HIGHLIGHT}RTG @{FG TEXT}- Retargetable Graphics, allowing any graphics board to
            have direct support by the operating system.


        @{FG HIGHLIGHT}Run Time Library @{FG TEXT}- A library of routines that is only used
            while an application requests it, and may be shared
            among other applications.

                @{"     " link AORM.OS.AmigaDOS/Avail} SYS:C/Avail

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.S "Glossary - S"
@toc Glossary


        @{FG HIGHLIGHT}
        Sample @{FG TEXT}- A data file recording of an audio sound.

        @{FG HIGHLIGHT}
        Sampler @{FG TEXT}- A hardware device for digitizing audio.

        @{FG HIGHLIGHT}
        Saturation -

        @{FG HIGHLIGHT}
        Scanline @{FG TEXT}- A rendering technique designed to quickly determine the
            color of a given pixel on a surface without inspecting or
            employing the characteristics of light refraction or reflection.

        @{FG HIGHLIGHT}
        Scene @{FG TEXT}- A collection of 3D objects in a stage and their predefined
            motions.

        @{FG HIGHLIGHT}
        Screen @{FG TEXT}- A rectangular display area with an independent palette
            and an independent resolution.

        @{FG HIGHLIGHT}
        Script @{FG TEXT}- List of commands in a text file, such as for AmigaDOS,
            which can be executed in order.

                @{"     " link AORM.OS.AmigaDOS/Execute} SYS:C/Execute
                @{"     " link AORM.OS.AmigaDOS/Protect} SYS:C/Protect

        @{FG HIGHLIGHT}
        Scroll Bar @{FG TEXT}- A gadget used to move data linearly.

        @{FG HIGHLIGHT}
        SCSI @{FG TEXT}- A format for hard drive expansion buses.

                @{"     " link AORM.Workbench/wb.format} Workbench Format Menu Item

        @{FG HIGHLIGHT}
        SCSI II @{FG TEXT}- A new format for improved hard drive performance.

                @{"     " link AORM.Workbench/wb.format} Workbench Format Menu Item

        @{FG HIGHLIGHT}
        Search Key -

        @{FG HIGHLIGHT}
        Search Time -

        @{FG HIGHLIGHT}
        SECAM @{FG TEXT}- A primarily European television broadcast standard.

        @{FG HIGHLIGHT}
        Segment -

        @{FG HIGHLIGHT}
        Seek Time -

        @{FG HIGHLIGHT}
        Select Button @{FG TEXT}- The left mouse button, used to select a gadget
            or icon. This is often used in conjunction with the term
            "@{FG HIGHLIGHT}double-click@{FG TEXT}" or "@{FG HIGHLIGHT}single-click@{FG TEXT}".

        @{FG HIGHLIGHT}
        Serial Port @{FG TEXT}- An external port used for modems, printers, and
            networking. Located at the rear of all Amiga models and
            via a special keyboard/serial port on the CD32. Most serial
            port compatible hardware and software is compatible on
            all systems. Some systems such as the Amiga 1000 may have
            reverse gender ports or different power lines. Hardware
            should only be used on the Amiga 1000 with investigation
            as to whether the product is safe to use.

                @{"     " link Glossary.M} @{FG HIGHLIGHT}Modem         @{FG TEXT}
                @{"     " link Glossary.N} @{FG HIGHLIGHT}Networking    @{FG TEXT}
                @{"     " link Glossary.P} @{FG HIGHLIGHT}Port          @{FG TEXT}
                @{"     " link Glossary.P} @{FG HIGHLIGHT}Printer       @{FG TEXT}

        @{FG HIGHLIGHT}
        Shadow @{FG TEXT}- The area which is not lit from a particular light source,
            due to an object in the path of radiated light.

        @{FG HIGHLIGHT}
        Shared Library @{FG TEXT}- A set of routines that may be accessed by many
            executable programs simultaneously.

                @{"     " link AORM.OS.AmigaDOS/Avail} SYS:C/Avail

        @{FG HIGHLIGHT}
        Shareware @{FG TEXT}- Software provided freely yet the author maintains
            all distribution rights.

        @{FG HIGHLIGHT}
        Sharp Edge @{FG TEXT}- An edge that is rendered as a sharp angle as
            opposed to being rounded or shaded. Also known as a
            @{FG HIGHLIGHT}hard edge@{FG TEXT}.

                @{"     " link Glossary.E}@{FG HIGHLIGHT} Edge      @{FG TEXT}
                @{"     " link Glossary.H}@{FG HIGHLIGHT} Hard Edge @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Soft Edge @{FG TEXT}

        @{FG HIGHLIGHT}
        Shell @{FG TEXT}- Enhanced CLI for accessing DOS commands.

                @{"     " link AORM.Index/Template          } INDEX: AmigaDOS Template
                @{"     " link AORM.Index/control_codes     } INDEX: AmigaDOS Control Codes
                @{"     " link AORM.Index/escape_codes      } INDEX: Escape Codes
                @{"     " link AORM.OS.AmigaDOS/NewCLI      } SYS:C/NewCLI
                @{"     " link AORM.OS.AmigaDOS/NewShell    } SYS:C/NewShell

        @{FG HIGHLIGHT}
        Shell-Startup @{FG TEXT}- A script used in starting a new Shell or CLI.

                @{"     " link AORM.OS.AmigaDOS/NewCLI      } SYS:C/NewCLI
                @{"     " link AORM.OS.AmigaDOS/NewShell    } SYS:C/NewShell

        @{FG HIGHLIGHT}
        Shielding @{FG TEXT}- Metal plating used to protect computer components
            from heat or other interference.

        @{FG HIGHLIGHT}
        Sidecar @{FG TEXT}- An expansion method using an internal edge connector
            for external hardware, such as the IBM emulator for the A1000.

        @{FG HIGHLIGHT}
        SIGGRAPH @{FG TEXT}- An annual computer graphics convention.

        @{FG HIGHLIGHT}
        Signature Case @{FG TEXT}- One of the first Amiga 1000s shipped,
            containing the signatures of the various people involved
            with developing the Amiga.

        @{FG HIGHLIGHT}
        SIMM @{FG TEXT}- Single Inline Memory Module used to store multiple chips
            on one small daughterboard.

        @{FG HIGHLIGHT}
        Single Frame Controller @{FG TEXT}- A device used to accurately record video
            animation images to a video tape recorder, such that frames may
            be individually placed or overwritten.

        @{FG HIGHLIGHT}
        Single Sided Polygon @{FG TEXT}- A polygon whose features are only rendered
            on one side of the polygon. Single sided polygons must face
            the camera in order to be rendered.

                @{"     " link Glossary.D}@{FG HIGHLIGHT} Double Sided Polygon  @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Polygon               @{FG TEXT}

        @{FG HIGHLIGHT}
        Skeleton @{FG TEXT}- The internal structure of a 3D object, allowing for
            control of moving parts such as bones or attached objects.

        @{FG HIGHLIGHT}
        Skeletonal Control @{FG TEXT}- The ability to define a group of objects by
            linking them at movanle joints.

        @{FG HIGHLIGHT}
        Sky @{FG TEXT}- The area in a 3D scene above the ground and above all
            objects, meeting with the surface plane or ground at the
            horizon.

        @{FG HIGHLIGHT}
        Slider @{FG TEXT}- A gadget used to move data linearly.

        @{FG HIGHLIGHT}
        SLIP  @{FG TEXT}- Serial Line Internet Protocol.

        @{FG HIGHLIGHT}
        Slow-Fast RAM @{FG TEXT}- Fast RAM added to the second 512k of an Amiga 500
            via the Trapdoor expansion bus.

        @{FG HIGHLIGHT}
        Smoothing @{FG TEXT}- The process of shading an edge to provide a rounded
            edge as opposed to a sharp edge.

        @{FG HIGHLIGHT}
        Smoothing Angle @{FG TEXT}- The threshold angle at which an edge is no longer
            smoothed, shaded, or soft edged.

        @{FG HIGHLIGHT}
        Socketed Chip @{FG TEXT}- A chip that is placed on the motherboard by
            inserting it into a small holder, which allows the chip
            to be removed easily.

        @{FG HIGHLIGHT}
        Soft Edge @{FG TEXT}- An edge that is rendered as a round edge, such as with
            phong shading.

                @{"     " link Glossary.P}@{FG HIGHLIGHT} Phong Shading @{FG TEXT}

        @{FG HIGHLIGHT}
        Soft Link @{FG TEXT}- A soft link is a file that accesses another file on a
            different partition.

                @{"     " link Glossary.H}@{FG HIGHLIGHT} Hard Link     @{FG TEXT}

        @{FG HIGHLIGHT}
        Software @{FG TEXT}- Information stored and altered on various media.

                @{"     " link Glossary.M}@{FG HIGHLIGHT} Media         @{FG TEXT}

        @{FG HIGHLIGHT}
        Software Clock @{FG TEXT}- The time keeping routines used in memory that
            are not maintained when the computer is powered down.

        @{FG HIGHLIGHT}
        Solid @{FG TEXT}- A type of rendering, similar to wireframe, yet with all
            hidden lines removed. Creates more realistic 3D drawings
            as opposed to wireframe stick drawings.

                @{"     " rxs "address command 'display.s 225 225 pictures/pic.cube.hidden_line Hidden_Lines'"} ILBM: Hidden Lines
                @{"     " rxs "address command 'display.s 225 225 pictures/pic.cube.solid Solid'"             } ILBM: Solid
                @{"     " link Glossary.H} @{FG HIGHLIGHT}Hidden Lines      @{FG TEXT}
                @{"     " link Glossary.W} @{FG HIGHLIGHT}Wireframe         @{FG TEXT}

        @{FG HIGHLIGHT}
        Sound Blaster @{FG TEXT}- A hardware device that allows sound to be output
            on an IBM PC compatible computer.

        @{FG HIGHLIGHT}
        SoundTracker @{FG TEXT}- A format for music compositions.

        @{FG HIGHLIGHT}
        Specular @{FG TEXT}- A visual highlight on an object caused by reflected
            light. May be the color of the light source or the surface
            color of the object in combination with the light source.

        @{FG HIGHLIGHT}
        Sphere @{FG TEXT}- A 3D object comprised of polygons such that it
            approximates the shape of a sphere. A true sphere may
            be generated algorithmically or by using infinite surface
            polygons.

        @{FG HIGHLIGHT}
        Spike Protector @{FG TEXT}- A device that attempts to protect electrical
            devices from bursts of electricity in the electrical
            system.

        @{FG HIGHLIGHT}
        Splay Tree @{FG TEXT}- A type of balanced tree that becomes more efficient
            by rotating nodes towards the root of the tree. Seek times
            are increased since frequently used nodes are stored closer
            to the root of the tree.

        @{FG HIGHLIGHT}
        Spline @{FG TEXT}- A curved line drawn using a desktop publishing program
            or a 3D modeling program, designed to draw curves using
            mathematical formulas.

        @{FG HIGHLIGHT}
        Spline Controls -

        @{FG HIGHLIGHT}
        Spot Light @{FG TEXT}- A light source used at close range in a scene
            designed to radiate on a small portion of the scene or
            an individual object, with a conical lighting area.

        @{FG HIGHLIGHT}
        Spreadsheet @{FG TEXT}- A program used to calculate large amounts of
            numbers.

        @{FG HIGHLIGHT}
        Sprite @{FG TEXT}- A graphics object that moves freely between screens
            and appears on top of all normal screen graphics.

        @{FG HIGHLIGHT}
        Stage @{FG TEXT}- An area used to contain 3D objects, of which no object is
            intended to leaved the stage.

        @{FG HIGHLIGHT}
        Startup-Sequence @{FG TEXT}- A script used in booting the computer.

                @{"     " link AORM.OS.AmigaDOS/Execute} SYS:C/Execute
                @{"     " link AORM.OS.AmigaDOS/Protect} SYS:C/Protect

        @{FG HIGHLIGHT}
        Stereo @{FG TEXT}- The use of two channels, a Right and a Left, to output
            sound, simulating multiple sound sources.

        @{FG HIGHLIGHT}
        Story Board @{FG TEXT}- A type of presentation that explains a given movie
            scene using short clips or still images, without actually
            recording the scene.

        @{FG HIGHLIGHT}
        String @{FG TEXT}- A finite sequence of characters.

        @{FG HIGHLIGHT}
        String Delimiter @{FG TEXT}- A quotation mark used to signify the
            beginning or end of a sequence of characters, often
            either a single quote (@{FG HIGHLIGHT}'@{FG TEXT}) or a double quote (@{FG HIGHLIGHT}"@{FG TEXT}).

        @{FG HIGHLIGHT}
        Structure @{FG TEXT}- A user-defined data storage technique, grouping
            common variables into one programmable unit in memory
            which may be treated as a singular variable.

                @{"     " link Glossary.V}@{FG HIGHLIGHT} Variable      @{FG TEXT}

        @{FG HIGHLIGHT}
        Stub @{FG TEXT}- A routine used in debugging or programming that returns
            a test value without performing any operations.

        @{FG HIGHLIGHT}
        Subsystem ID @{FG TEXT}- A value that represents a particular area of the
            system, used in identifying where an error occurred.

        @{FG HIGHLIGHT}
        Surface @{FG TEXT}- A two dimensional area of an object.

        @{FG HIGHLIGHT}
        Surface Color -

        @{FG HIGHLIGHT}
        Surface Mounted Chip  @{FG TEXT}- A computer chip that is soldered to a
            motherboard and cannot be removed easily.

        @{FG HIGHLIGHT}
        Surge Protector @{FG TEXT}- A device that attempts to protect electrical
            devices from bursts of electricity in the electrical
            system.

        @{FG HIGHLIGHT}
        Switcher @{FG TEXT}- NewTek's video production control software, for use
            with the Toaster and peripherals.

        @{FG HIGHLIGHT}
        Syntax @{FG TEXT}- The proper use of a language in programming or command
            usage.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.T "Glossary - T"
@toc Glossary

        @{FG HIGHLIGHT}
        Tablet @{FG TEXT}- A tabletop hardware device that allows a user to draw
            to the screen by pressing a pen to the sensitive tablet
            surface.

        @{FG HIGHLIGHT}
        Task @{FG TEXT}- A software program or element being used by the system.

        @{FG HIGHLIGHT}
        Task Held Error @{FG TEXT}- An error that freezes a task yet allows
            other programs to continue running.

        @{FG HIGHLIGHT}
        Task Priority @{FG TEXT}- A value given to a task or process that
            determines how often it should have access to the CPU
            or its hardware and software.

                @{"     " link AORM.OS.AmigaDOS/ChangeTaskPri} SYS:C/ChangeTaskPri

        @{FG HIGHLIGHT}
        TBC @{FG TEXT}- Time Base Corrector, used to synchronize video inputs.

        @{FG HIGHLIGHT}
        TCP/IP @{FG TEXT}- Transmission Control Protocol/Internet Protocol for
            ethernet, primarily on  UNIX machines.

        @{FG HIGHLIGHT}
        Telnet @{FG TEXT}- A program which allows on UNIX host to log into another.

        @{FG HIGHLIGHT}
        Template @{FG TEXT}- A list of parameters and argumenst that may be passed
            to a command or function.

                @{"     " link AORM.Index/Template} INDEX: AmigaDOS Template

        @{FG HIGHLIGHT}
        Temporary File @{FG TEXT}- A file that is created and destroyed by a program,
            for the purpose of creating another file.

        @{FG HIGHLIGHT}
        Term @{FG TEXT}- A program that access remote computer systems over the
            serial port or a networking device.

        @{FG HIGHLIGHT}
        Terminal @{FG TEXT}- A program that access remote computer systems over the
            serial port or a networking device.

        @{FG HIGHLIGHT}
        TeX @{FG TEXT}- An Amiga word processing and graphics printing package.

        @{FG HIGHLIGHT}
        Text @{FG TEXT}- Written words, numbers, or characters stored in a computer
            file. May also refer to files which use 7 bit ASCII encoding
            as opposed to binary files which support 8 bit ASCII encoding.

        @{FG HIGHLIGHT}
        Text Editor @{FG TEXT}- A small program used to edit ASCII files or text
            files. Similar to a Word Processor.

        @{FG HIGHLIGHT}
        Text File @{FG TEXT}- A file that is easily readable by humans.

        @{FG HIGHLIGHT}
        Text Modes @{FG TEXT}- A display format where each character displayed has
            the same height and same width, such that all characters
            are displayed in straight columns and rows. These displays
            are much faster than proportional text modes.

        @{FG HIGHLIGHT}
        Texture @{FG TEXT}- An image placed on an object to give the appearance of
            a specific type of material.

        @{FG HIGHLIGHT}
        Texture Mapping @{FG TEXT}- The process of placing images or algorithms
            onto a 3D object.

        @{FG HIGHLIGHT}
        Throughput @{FG TEXT}- The amount of data transferred.

        @{FG HIGHLIGHT}
        Time Base Corrector @{FG TEXT}- A device used to stabilize a video signal.

        @{FG HIGHLIGHT}
        Timestamp @{FG TEXT}- The date and time assigned to a file when it was last
            created or modified.

        @{FG HIGHLIGHT}
        Toaster @{FG TEXT}- See Video Toaster.

                @{"     " link Glossary.V}@{FG HIGHLIGHT} Video Toaster         @{FG TEXT}

        @{FG HIGHLIGHT}
        ToasterCG @{FG TEXT}- NewTek's character generator software for use with
            the Video Toaster.

                @{"     " link Glossary.C}@{FG HIGHLIGHT} Character Generator   @{FG TEXT}
                @{"     " link Glossary.V}@{FG HIGHLIGHT} Video Toaster         @{FG TEXT}

        @{FG HIGHLIGHT}
        Toaster Cozzy @{FG TEXT}- An external device used to contain a Video
            Toaster card for use with an Amiga 3000.

                @{"     " link Glossary.V}@{FG HIGHLIGHT} Video Toaster @{FG TEXT}

        @{FG HIGHLIGHT}
        Toaster Font @{FG TEXT}- A font used with the Video Toaster Character
            Generator.

                @{"     " link Glossary.F}@{FG HIGHLIGHT} Font          @{FG TEXT}
                @{"     " link Glossary.V}@{FG HIGHLIGHT} Video Toaster @{FG TEXT}

        @{FG HIGHLIGHT}
        ToasterLink @{FG TEXT}- A software and hardware combination that allows
            Macintosh computers to share images and data with a Toaster
            equipped Amiga through the serial port.

                @{"     " link Glossary.S}@{FG HIGHLIGHT} Serial Port   @{FG TEXT}
                @{"     " link Glossary.V}@{FG HIGHLIGHT} Video Toaster @{FG TEXT}

        @{FG HIGHLIGHT}
        ToasterPaint @{FG TEXT}- NewTek's HAM6 painting software for use with the
            Video Toaster, formerly known as DigiPaint III.

                @{"     " link Glossary.H}@{FG HIGHLIGHT} HAM6          @{FG TEXT}
                @{"     " link Glossary.V}@{FG HIGHLIGHT} Video Toaster @{FG TEXT}

        @{FG HIGHLIGHT}
        Token @{FG TEXT}- A word or symbol in a computer language, meant to be
            understood by an interpreter or compiler.

                @{"     " link Glossary.P}@{FG HIGHLIGHT} Compiler      @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Interpreter   @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Language      @{FG TEXT}
                @{"     " link Glossary.W}@{FG HIGHLIGHT} Word          @{FG TEXT}

        @{FG HIGHLIGHT}
        Toner Cartridge @{FG TEXT}- An ink cartridge used by a laser printer
            to print text or graphics onto a piece of paper.

                @{"     " link Glossary.P}@{FG HIGHLIGHT} Graphics      @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Laser Printer @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Print         @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Text          @{FG TEXT}

        @{FG HIGHLIGHT}
        Tool @{FG TEXT}- A software program or utility, capable of being operated
            from the Workbench, often using data files called Projects.

                @{"     " link Glossary.P}@{FG HIGHLIGHT} Project  @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Program  @{FG TEXT}
                @{"     " link Glossary.U}@{FG HIGHLIGHT} Utility  @{FG TEXT}

        @{FG HIGHLIGHT}
        Tool Type @{FG TEXT}- A parameter passed to a program or file through the
            Workbench via the program or file's icon. Parameters may
            include associated data files, applications, or preferences.

                @{"     " link Glossary.I}@{FG HIGHLIGHT} Icon          @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Parameter     @{FG TEXT}

        @{FG HIGHLIGHT}
        Touch @{FG TEXT}- The process of modifying the timestamp of a file, most
            often to the current date and time.

        @{FG HIGHLIGHT}
        Touch Sensitive Screen @{FG TEXT}- A monitor and software combination that
            allows the user to touch an image displayed in the screen,
            often a gadget.

        @{FG HIGHLIGHT}
        Trace Mode @{FG TEXT}- A debugging mode that allows a programmer to view
            the values of variables and the line numbers that an interpreter
            is reading.

        @{FG HIGHLIGHT}
        Track @{FG TEXT}- An area of a device, in sequence, used to store data.

        @{FG HIGHLIGHT}
        Trackball @{FG TEXT}- An input device which allows the user to control
            onscreen images and interfaces, such as commonly done
            with a mouse. Using a rotating sphere, the user rolls
            his hand or fingers to direct a pointer onscreen. These
            devices are often used when desk space is limited.

                @{"     " link Glossary.I}@{FG HIGHLIGHT} Input Device  @{FG TEXT}
                @{"     " link Glossary.I}@{FG HIGHLIGHT} Interface     @{FG TEXT}
                @{"     " link Glossary.M}@{FG HIGHLIGHT} Mouse         @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Pointer       @{FG TEXT}

        @{FG HIGHLIGHT}
        Tracker @{FG TEXT}- A program used to write music modules, such as
            SoundTracker, ProTracker, or NoiseTracker. SoundTracker
            is widely known as the first popular Amiga music tracker,
            and has since migrated to the IBM and Macintosh world.

        @{FG HIGHLIGHT}
        Transparency @{FG TEXT}- The ability for light to pass through an object,
            and the amount of light that passes through it, causing
            objects or images behind the transparent portions to be
            visible in some amount, defined using parameters.

        @{FG HIGHLIGHT}
        Trapdoor @{FG TEXT}- Internal expansion bus on the A500, A600, and A1200
            allowing cards to be added beneath the keyboard without
            opening the computer's case.

        @{FG HIGHLIGHT}
        Tree @{FG TEXT}- The method for which directories are stored, with the
            entire set of files contained in one branching system of
            directories. A tree starts at the root, with any number
            of child nodes that it may lead two. Each child may also
            have its own children, similar to a family tree, allowing
            nodes to be referred to each other in much the same way.

                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.AVL AVL'"            } ILBM: AVL Tree
                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.balanced Balanced'"  } ILBM: Balanced Tree
                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.binary Binary'"      } ILBM: Binary Tree
                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.leaf Leaf'"          } ILBM: Leaf
                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.node Node'"          } ILBM: Node
                @{"     " rxs "address command 'display.s 161 105 pictures/pic.tree.root Root'"          } ILBM: Root
                @{"     " link Glossary.A}@{FG HIGHLIGHT} AVL Tree      @{FG TEXT}
                @{"     " link Glossary.B}@{FG HIGHLIGHT} Balanced Tree @{FG TEXT}
                @{"     " link Glossary.B}@{FG HIGHLIGHT} Binary Tree   @{FG TEXT}
                @{"     " link Glossary.L}@{FG HIGHLIGHT} Leaf          @{FG TEXT}
                @{"     " link Glossary.N}@{FG HIGHLIGHT} Node          @{FG TEXT}
                @{"     " link Glossary.R}@{FG HIGHLIGHT} Root          @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Splay Tree    @{FG TEXT}


        Triangle @{FG TEXT}- A polygon with only three edges and three points,
            used by some modeling programs. Used most effectively on
            surfaces that are not planar and bend through space.

                @{"     " rxs "address command 'display.s 225 225 pictures/pic.cube.triangle Triangle'"} ILBM: Triangle
                @{"     " link Glossary.E}@{FG HIGHLIGHT} Edge         @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Planar       @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Polygon      @{FG TEXT}

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.U "Glossary - U"
@toc Glossary

        @{FG HIGHLIGHT}
        Unary Operation @{FG TEXT}- A function or mathematical operation performed
            on one variable, such as a negation of a number or the
            square root.

                @{"     " link Glossary.V}@{FG HIGHLIGHT} Variable      @{FG TEXT}

        @{FG HIGHLIGHT}
        Undelete @{FG TEXT}- The process of restoring a lost file, if possible.
            Performed by scanning the directory list for file links
            in the event that they are intact. If a portion of the
            data is overwritten, the file cannot be completely
            restored.

                @{"     " link AORM.OS.AmigaDOS/Delete} SYS:C/Delete

        @{FG HIGHLIGHT}
        Underscan @{FG TEXT}- Any screen mode that has a border surrounding it
            and does not utilize the full width and height of the
            screen. Most computer displays use underscan modes, while
            television, video, and full screen images generally use
            overscan modes.

                @{"     " link Glossary.O}@{FG HIGHLIGHT} Overscan      @{FG TEXT}
                @{"     " link Glossary.V}@{FG HIGHLIGHT} Video         @{FG TEXT}

        @{FG HIGHLIGHT}
        Underscore @{FG TEXT}- The character used to define a space, by printing
            a character. The underscore is produced by pressing the
            SHIFT "-" keys. Example: These_words_are_connected.

        @{FG HIGHLIGHT}
        Unit of Measure @{FG TEXT}- A value used for measuring images and objects
            in programs such as desktop publishers and 3D modeling.
            Includes traditional units such as inches or centimeters
            along with computer specific units such as pixels or world
            coordinates.

                @{"     " link Glossary.P}@{FG HIGHLIGHT} Pixel          @{FG TEXT}

        @{FG HIGHLIGHT}
        USENET @{FG TEXT}- Internet networking system.

        @{FG HIGHLIGHT}
        User Group @{FG TEXT}- A group of computer enthusiasts sharing common
            interests and techniques for better using computer systems,
            or to learn more about the system.

        @{FG HIGHLIGHT}
        User Startup-Sequence @{FG TEXT}- A script that is used in booting the computer,
            designed to be easily modifiable by the user, without the risk
            of interfering with the normal booting process.

        @{FG HIGHLIGHT}
        UUCP @{FG TEXT}- UNIX communication protocol for transferring email,
            news, and files.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.V "Glossary - V"
@toc Glossary

        @{FG HIGHLIGHT}
        Vector @{FG TEXT}- A line in three dimensional space which is used in
            defining the direction a surface is facing, or the direction
            an object is travelling.

        @{FG HIGHLIGHT}
        Vector Graphics @{FG TEXT}- Three dimensional graphics, mostly compromised
            of lines, used in games and 3D modeling.

        @{FG HIGHLIGHT}
        Version String @{FG TEXT}- A string of characters that provides information
            about a file, such as the version, revision, and date of
            creation. The version string may be accessed using the AmigaDOS
            Version command.

                @{"     " link AORM.OS.AmigaDOS/Version} SYS:C/Version

        @{FG HIGHLIGHT}
        Vibrato @{FG TEXT}- An audio effect that causes a sound to vibrate.

        @{FG HIGHLIGHT}
        Video @{FG TEXT}- A visually displayed sequence of images, and the processes
            involved with producing and displaying such images.

        @{FG HIGHLIGHT}
        Video CD @{FG TEXT}- A video compression format designed to store over an
            hour of video and audio on a compact disk, playable on home
            computer systems and CD consoles.

        @{FG HIGHLIGHT}
        Video RAM @{FG TEXT}- Any RAM used specifically for graphics or video,
            such as used on IBM compatibles or graphics boards.

        @{FG HIGHLIGHT}
        Video Slot @{FG TEXT}- An expansion slot that permits access to video
            devices and Zorro slots simultaneously.

        @{FG HIGHLIGHT}
        Video Toaster @{FG TEXT}- An Amiga hardware device used in video
            production.

        @{FG HIGHLIGHT}
        Video Toaster User @{FG TEXT}- A magazine devoted to Video Toaster
            enthusiasts.

        @{FG HIGHLIGHT}
        Video Wall @{FG TEXT}- A large monitor or grid of monitors, often several
            feet wide, used to display images.

        @{FG HIGHLIGHT}
        Virtual Reality @{FG TEXT}- The use of computers to create three dimensional
            spaces which users can interact with.

        @{FG HIGHLIGHT}
        VRAM @{FG TEXT}- A type of RAM chip, not to be confused with Video RAM,
            used in high performance systems.

        @{FG HIGHLIGHT}
        Voice @{FG TEXT}- Access to an audio channel for audio output.

        @{FG HIGHLIGHT}
        Volume @{FG TEXT}- A name or ID associated with a hardware storage device,
            such as a hard drive.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.W "Glossary - W"
@toc Glossary

        @{FG HIGHLIGHT}
        Wait State -


        @{FG HIGHLIGHT}
        Warm Reboot @{FG TEXT}- To reset the computer without turning the power off,
            using the CTRL-LAMIGA-RAMIGA key sequence.

                @{"     " link Glossary.C }@{FG HIGHLIGHT} Cold Reboot      @{FG TEXT}
                @{"     " link Glossary.R }@{FG HIGHLIGHT} Reboot           @{FG TEXT}
                @{"     " link Glossary.R }@{FG HIGHLIGHT} Reset            @{FG TEXT}

        @{FG HIGHLIGHT}
        Wave Writer @{FG TEXT}- A software package that positions 3D text for use
            with Lightwave.

                @{"     " link Glossary.A }@{FG HIGHLIGHT} 3D           @{FG TEXT}
                @{"     " link Glossary.L }@{FG HIGHLIGHT} Lightwave    @{FG TEXT}
                @{"     " link Glossary.T }@{FG HIGHLIGHT} Text         @{FG TEXT}

        @{FG HIGHLIGHT}
        WBStartup @{FG TEXT}- The Workbench Startup drawer contains files which are
            executed whenever the Workbench is loaded.

                @{"     " link Glossary.D }@{FG HIGHLIGHT} Drawer       @{FG TEXT}
                @{"     " link Glossary.L }@{FG HIGHLIGHT} LoadWB       @{FG TEXT}
                @{"     " link Glossary.W }@{FG HIGHLIGHT} Workbench    @{FG TEXT}

        @{FG HIGHLIGHT}
        West Chester @{FG TEXT}- Commodore's headquarters in the United States,
            located in West Chester, Pennsylvania.

        @{FG HIGHLIGHT}
        Wildcard @{FG TEXT}- A pattern that represents any string of text.

                @{"     " link AORM.Index/Pattern        } INDEX: AmigaDOS Pattern Matching
                @{"     " link Glossary.P }@{FG HIGHLIGHT} Pattern Matching     @{FG TEXT}
                @{"     " link Glossary.S }@{FG HIGHLIGHT} String               @{FG TEXT}

        @{FG HIGHLIGHT}
        Window @{FG TEXT}- A portion of a screen defined by a rectangular border,
            often draggable with the mouse. May also be positioned behind
            or in front of other windows, and may be closed. Contains a
            border, gadgets, and a raster area. Must be opened on an
            existing screen and use colors that are avilable from the
            screen's palette.

                @{"     " link AORM.Workbench/wb.window  } Workbench Window Menu
                @{"     " link Glossary.D }@{FG HIGHLIGHT} Drawer       @{FG TEXT}
                @{"     " link Glossary.S }@{FG HIGHLIGHT} Screen       @{FG TEXT}
                @{"     " link Glossary.W }@{FG HIGHLIGHT} Workbench    @{FG TEXT}

        @{FG HIGHLIGHT}
        Wipe @{FG TEXT}- A technique used to clear and image from a display, or to
            redraw a new image. Often used in conjunction with a second
            image to be drawn in its place. May also be used with video.

        @{FG HIGHLIGHT}
        Wireframe @{FG TEXT}- A method of drawing a 3D image by drawing only the
            edges of the correspoding 3D object. All edges are shown,
            including those hidden by faces or polygons.

        @{FG HIGHLIGHT}
        Word Processor @{FG TEXT}- A software program that is used to display
            and print texts. Used for simple text layouts.

        @{FG HIGHLIGHT}
        Workbench @{FG TEXT}- The Amiga's graphic oriented file manipulation
            program. The graphical user interface allows windows and
            menus to be onscreen along with icons and shells. Also
            refers to the standard Amiga system software boot disk
            which includes the Amiga's preference software, AmigaDOS,
            and utilities.

                @{"     " link AORM.Workbench/Workbench         } Workbench
                @{"     " link AORM.Workbench/Workbench.menus   } Workbench Menus
                @{"     " link Glossary.D }@{FG HIGHLIGHT       } Drawer       @{FG TEXT}
                @{"     " link Glossary.G }@{FG HIGHLIGHT       } GUI          @{FG TEXT}
                @{"     " link Glossary.L }@{FG HIGHLIGHT       } LoadWB       @{FG TEXT}
                @{"     " link Glossary.M }@{FG HIGHLIGHT       } Menu         @{FG TEXT}
                @{"     " link Glossary.W }@{FG HIGHLIGHT       } Window       @{FG TEXT}
                @{"     " link Glossary.W }@{FG HIGHLIGHT       } WBStartup    @{FG TEXT}

        @{FG HIGHLIGHT}
        World Coordinates @{FG TEXT}- The coordinate system representing an entire
            scene and all the objects within that scene, irregardless of
            the dimensions of the actual objects themselves that are
            present within the scene.

        @{FG HIGHLIGHT}
        Write Protect @{FG TEXT}- A mode for which a storage device or file cannot
            have data written to or deleted from it. Some devices have
            software protection while others have hardware protection.
            Software write protection can often be turned on or off using
            software, while hardware write protection generally requires
            a hardware setting. Some devices, such as CD-ROMs, are only
            currently available with write protection.

                @{"     " link AORM.OS.AmigaDOS/Protect } SYS:C/Protect
                @{"     " link AORM.Workbench/wb.format } Workbench Format Menu Item
                @{"     " link Glossary.D}@{FG HIGHLIGHT} Delete    @{FG TEXT}
                @{"     " link Glossary.F}@{FG HIGHLIGHT} File      @{FG TEXT}
                @{"     " link Glossary.W}@{FG HIGHLIGHT} Write     @{FG TEXT}

        @{FG HIGHLIGHT}
        WYSIWYG @{FG TEXT}- What You See Is What You Get, a display format that
            matches paper printed output as close as possible. These
            displays are slower than Text Modes.

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.X "Glossary - X"
@toc Glossary

        @{FG HIGHLIGHT}
        X11 @{FG TEXT}- A UNIX based graphics environment, supporting XWindows.

                @{"     " link Glossary.G }@{FG HIGHLIGHT} GUI              @{FG TEXT}
                @{"     " link Glossary.U }@{FG HIGHLIGHT} UNIX             @{FG TEXT}
                @{"     " link Glossary.W }@{FG HIGHLIGHT} Window           @{FG TEXT}
                @{"     " link Glossary.X }@{FG HIGHLIGHT} XWindow          @{FG TEXT}

        @{FG HIGHLIGHT}
        XModem @{FG TEXT}- A file transfer protocol used over the serial port by
            terminal programs.

                @{"     " link Glossary.F }@{FG HIGHLIGHT} File             @{FG TEXT}
                @{"     " link Glossary.F }@{FG HIGHLIGHT} File Transfer    @{FG TEXT}
                @{"     " link Glossary.M }@{FG HIGHLIGHT} Modem            @{FG TEXT}
                @{"     " link Glossary.P }@{FG HIGHLIGHT} Protocol         @{FG TEXT}
                @{"     " link Glossary.S }@{FG HIGHLIGHT} Serial           @{FG TEXT}
                @{"     " link Glossary.Y }@{FG HIGHLIGHT} YModem           @{FG TEXT}
                @{"     " link Glossary.Z }@{FG HIGHLIGHT} ZModem           @{FG TEXT}

        @{FG HIGHLIGHT}
        XPR @{FG TEXT}- Transfer Protocol libraries that allow file transfers over
            the serial port. Allows any XPR compatible terminal program to
            use the same XPR libraries and protocols that are not supported
            inherently by non-XPR terminal programs.

                @{"     " link Glossary.L}@{FG HIGHLIGHT} Library          @{FG TEXT}
                @{"     " link Glossary.M}@{FG HIGHLIGHT} Modem            @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Shared Library   @{FG TEXT}

        @{FG HIGHLIGHT}
        XWindows @{FG TEXT}- A GUI for UNIX based computers, featuring pop-up
            menus, shells, and windows.

                @{"     " link Glossary.G}@{FG HIGHLIGHT} GUI              @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Shell            @{FG TEXT}
                @{"     " link Glossary.U}@{FG HIGHLIGHT} UNIX             @{FG TEXT}
                @{"     " link Glossary.W}@{FG HIGHLIGHT} Window           @{FG TEXT}

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.Y "Glossary - Y"
@toc Glossary

        @{FG HIGHLIGHT}
        YModem @{FG TEXT}- A file transfer protocol used over the serial port by
            terminal programs. Supports error correction.

                @{"     " link Glossary.F}@{FG HIGHLIGHT} File             @{FG TEXT}
                @{"     " link Glossary.F}@{FG HIGHLIGHT} File Transfer    @{FG TEXT}
                @{"     " link Glossary.M}@{FG HIGHLIGHT} Modem            @{FG TEXT}
                @{"     " link Glossary.P}@{FG HIGHLIGHT} Protocol         @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} Serial           @{FG TEXT}
                @{"     " link Glossary.Y}@{FG HIGHLIGHT} XModem           @{FG TEXT}
                @{"     " link Glossary.Z}@{FG HIGHLIGHT} ZModem           @{FG TEXT}

@endnode
+-----------------------------------------------------------------------------+


@node Glossary.Z "Glossary - Z"
@toc Glossary

        @{FG HIGHLIGHT}
        Zenith @{FG TEXT}- The area of the sky directly above the camera in a 3D world.
            This area is part of the sky not adjoining the horizon.

        @{FG HIGHLIGHT}
        ZIP @{FG TEXT}- A type of RAM chip used in the A3000 and some other
            computers and RAM expansion cards.

                @{"     " link Glossary.C}@{FG HIGHLIGHT} Chip     @{FG TEXT}
                @{"     " link Glossary.M}@{FG HIGHLIGHT} Memory   @{FG TEXT}
                @{"     " link Glossary.R}@{FG HIGHLIGHT} RAM      @{FG TEXT}
                @{"     " link Glossary.S}@{FG HIGHLIGHT} SIMM     @{FG TEXT}

        @{FG HIGHLIGHT}
        Zip Gadget @{FG TEXT}- A window gadget designed to alter the size of the
            window, often toggling between a small size and a large size.
            Also referred to as a Zoom gadget.

                @{"     " rxs "address command 'display.s 303 65 pictures/pic.gadget.zoom Zip_Gadget'"} ILBM: Zip Gadget

        @{FG HIGHLIGHT}
        ZModem @{FG TEXT}- A file transfer protocol used over the serial port by
            terminal programs. Supports resumable transmission, error
            correction, and automatic receive recognition.

                @{"     " link Glossary.F }@{FG HIGHLIGHT} File             @{FG TEXT}
                @{"     " link Glossary.F }@{FG HIGHLIGHT} File Transfer    @{FG TEXT}
                @{"     " link Glossary.M }@{FG HIGHLIGHT} Modem            @{FG TEXT}
                @{"     " link Glossary.P }@{FG HIGHLIGHT} Protocol         @{FG TEXT}
                @{"     " link Glossary.S }@{FG HIGHLIGHT} Serial           @{FG TEXT}
                @{"     " link Glossary.Z }@{FG HIGHLIGHT} XModem           @{FG TEXT}
                @{"     " link Glossary.Y }@{FG HIGHLIGHT} YModem           @{FG TEXT}

        @{FG HIGHLIGHT}
        Zoom @{FG TEXT}- The process of enlarging the viewable area of an image or
            object without altering the actual image or object. Enlarged
            images are "Zoomed In" while reduced images are "Zoomed Out".

        @{FG HIGHLIGHT}
        Zoom Gadget @{FG TEXT}- A window gadget designed to alter the size of the
            window, often toggling between a small size and a large size.
            Also referred to as a Zip gadget.

                @{"     " rxs "address command 'display.s 303 65 pictures/pic.gadget.zoom Zoom_Gadget'"} ILBM: Zoom Gadget

        @{FG HIGHLIGHT}
        Zorro Slot @{FG TEXT}- An expansion slot in 16 BIT or 32 BIT wide data
            paths for adding hardware to a computer. Used to support
            products such as modems, RAM expansion, hard drive
            controllers, and emulators. In most models, adding a card
            to this type of slot requires the removal of the case of
            the computer. Internal Zorro slots also feature the ability
            to use external peripherals via custom external expansion
            ports with removable dust covers.

                @{"     " link Glossary.B }@{FG HIGHLIGHT} Bus          @{FG TEXT}
                @{"     " link Glossary.C }@{FG HIGHLIGHT} CPU Slot     @{FG TEXT}
                @{"     " link Glossary.E }@{FG HIGHLIGHT} Expansion    @{FG TEXT}
                @{"     " link Glossary.V }@{FG HIGHLIGHT} Video Slot   @{FG TEXT}

@endnode
+-----------------------------------------------------------------------------+

@node Hidden "Glossary - Hidden"
@toc Glossary

    Hidden Glossary

        @{FG HIGHLIGHT}
        Cigase @{FG TEXT}- One of the first Amiga 1000's to be produced.

        @{FG HIGHLIGHT}
        Commodorian Economics @{FG TEXT}- An economics system that focuses on
            selling products only to those who already have one.

        @{FG HIGHLIGHT}
        Crip @{FG TEXT}- A computer that will not boot.

        @{FG HIGHLIGHT}
        De'in @{FG TEXT}- To decompile someone. See also "Diss'in".

        @{FG HIGHLIGHT}
        Hard @{FG TEXT}- Any peripheral that is faster and better than its
            predecessors. See also "Heavy".

        @{FG HIGHLIGHT}
        Harsh One's Gig @{FG TEXT}- To save pointless files, such as music modules
            and GIFs, onto a large hard disk.

        @{FG HIGHLIGHT}
        Max Out @{FG TEXT}- The process of using an item to its full potential,
            or in processors, to clock the chips at twice its rated
            specifications.

        @{FG HIGHLIGHT}
        Megabarrett @{FG TEXT}- A unit of measurement that rates how much misleading
            and false information is contained in a statement.

        @{FG HIGHLIGHT}
        Motorollan' @{FG TEXT}- A 50mHz 68030 or 68040 equipped Amiga.

        @{FG HIGHLIGHT}
        Pirate @{FG TEXT}- Hopefully not you!

        @{FG HIGHLIGHT}
        Pregnant Mouse @{FG TEXT}- An Amiga mouse that appears slightly bulged,
            as opposed to the older Beer Belly mouse from earlier
            machines.

        @{FG HIGHLIGHT}
        Regressed Half Brite @{FG TEXT}- A graphics mode found only in early
            Amiga 1000's.

        @{FG HIGHLIGHT}
        Reveng @{FG TEXT}- The process of reverse engineering someone else's work.

        @{FG HIGHLIGHT}
        Righteous @{FG TEXT}- Any keyboard shortcut that uses the Right Amiga
            key as a qualifier.

        @{FG HIGHLIGHT}
        SX @{FG TEXT}- Sucks.

        @{FG HIGHLIGHT}
        Three Finger Salute @{FG TEXT}- The process of resetting an Amiga using the
            CTRL-Amiga-Amiga keyboard sequence.

        @{FG HIGHLIGHT}
        Viral Floppy @{FG TEXT}- A bootable disk that has been infected.

        @{FG HIGHLIGHT}
        Virtual @{FG TEXT}- Anything that brings a state of awe to a person. See
            also "Awesome" or "Totally Radical".

@endnode
+-----------------------------------------------------------------------------+
