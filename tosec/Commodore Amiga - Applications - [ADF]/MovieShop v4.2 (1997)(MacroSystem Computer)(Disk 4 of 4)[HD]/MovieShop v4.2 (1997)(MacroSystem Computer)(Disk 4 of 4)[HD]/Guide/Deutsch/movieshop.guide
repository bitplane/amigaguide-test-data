@ENDNODE

@NODE OPENWINDOW_MACROS "Menü: Fenster/Makros..."
  Öffnen des @{" Makros " LINK MACROS}-Fensters.

  ARexx:	Siehe @{" ToolBox... " LINK OPENWINDOW_TOOLBOX}
@ENDNODE

@NODE OPENWINDOW_TOOLBOX "Menü: Fenster/ToolBox..."
@NEXT WINDOWSMENU
  Öffnen des @{" ToolBox " LINK TOOLBOX}-Fensters.

  ARexx:	OPENWINDOW
  Schablone:	SCENECONTROL/S,SCENES/S,SAMPLECONTROL/S,
		SOUNDS=SAMPLES/S,TIMELINECONTROL/S,TIMELINES=TIMELINELIST/S,
		TIMELINE/S,LOCATOR/S,INDEX/S,BLOCK=EDIT/S,
		CLIP/S,EFFECTS/S,COLORKEYING/S,STATUS/S,
		AUDIOCUT/S,AUDIOMIX/S,AUDIOLEVEL/S,PREVIEW/S,
		TIMELINEPOS=TIMELINEINFO/S,DISPLAYINFO/S,STATISTIC/S,
		MACROS/S,TOOLBOX/S,COMMAND/S,PROJECTOPTS/S,
		VIDEOOPTS/S,AUDIOOPTS/S,EXPORTOPTS=IMPORTOPTS/S,
		TIMELINEOPTS/S,YUVOPTS/S,TOOLBOXOPTS/S,
		MISCOPTS/S,ADVOPTS/S,WINDOWS/S,TITLE/K,
		BUFFEROPTS=HARDWAREOPTS/S,VIDEOEXPORTOPTS=AUDIOEXPORTOPTS/S,
		PRIORITIES=INPUT/S
@ENDNODE

