  ARexx:	Siehe @{" ToolBox... " LINK OPENWINDOW_TOOLBOX}
@ENDNODE

@NODE OPENWINDOW_EDIT "Menü: Fenster/Szenen»Bearbeiten..."
  Öffnen des @{" Bearbeiten " LINK EDIT}-Fensters.

  ARexx:	Siehe @{" ToolBox... " LINK OPENWINDOW_TOOLBOX}
@ENDNODE

@NODE OPENWINDOW_CLIP "Menü: Fenster/Szenen»Zwischenablage..."
