     @{" Rum Distillery       " LINK BUILDING28} @{" Shipyard              " LINK building8} @{" Rum Factory          " LINK BUILDING29}
     @{" Town Hall            " LINK BUILDING9} @{" Capitol               " LINK building30} @{" Town Hall (EMPTY)    " link BUILDING10}
     @{" Capitol Expansion    " LINK BUILDING31} @{" Colonial Assembly     " LINK BUILDING11} @{" Fur Trader's House   " link BUILDING32}
