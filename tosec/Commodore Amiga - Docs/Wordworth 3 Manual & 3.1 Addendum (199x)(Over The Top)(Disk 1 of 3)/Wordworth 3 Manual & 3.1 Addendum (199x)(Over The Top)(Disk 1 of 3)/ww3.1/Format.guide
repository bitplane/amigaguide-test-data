@Node Main "Formatting Text"
@ToC "Ww3.guide/Main"
 @{B}CONTENTS@{UB}

 This section gives help on how to format your
 document so that it appears the way that you
 want.

  @{" Formatting Text Characters " Link "Format.guide/CharFormat"}
    - @{" Different Text Styles " Link "Format.guide/CharStyles"}

  @{" Formatting The Document " Link "Format.guide/DocFormat"}

  @{" Formatting Paragraphs " Link "Format.guide/ParaFormat"}
    - @{" Adjusting Margins " Link "Format.guide/Margins"}
    - @{" Aligning And Justifying Text " Link "Format.guide/Justify"}
    - @{" Changing Line Spacing " Link "Format.guide/LineSpacing"}
    - @{" Hyphenating Text " Link "Format.guide/Hyphenation"}
    - @{" Indenting Lines And Paragraphs " Link "Format.guide/Indenting"}
    - @{" Keeping Lines Together Over Pages " Link "Format.guide/ParasTogether"}
