@{"DoWarn"         link RX_DoWarn}         (NO ARGS)

@{fg highlight}- E -@{fg text}
@{"EditWindow"     link RX_EditWindow}     (NO ARGS)

@{fg highlight}- G -@{fg text}
@{"GetActive"      link RX_GetActive}      (NO ARGS)
@{"GetEntries"     link RX_GetEntries}     (NO ARGS)
@{"GetField"       link RX_GetField}       ENTRY/N/K,NUMBER/N
@{"GetNextAlarm"   link RX_GetNextAlarm}   (NOARGS)

@{fg highlight}- L -@{fg text}
@{"LastSaved"      link RX_LastSaved}      (NO ARGS)
@{"Log"            link RX_Log}            STATE/N,TOGGLE/S
@{"LogMessage"     link RX_LogMessage}     SPACER/S,POPUP/S,MESSAGE/F

@{fg highlight}- M -@{fg text}
