@{"ClearList"      link RX_ClearList}      (NO ARGS)
@{"ClearLog"       link RX_ClearLog}       (NO ARGS)
@{"Clock"          link RX_Clock}          STATE/N,TOGGLE/S
@{"ClockFont"      link RX_ClockFont}      FONTNAME/A,SIZE/N/A
@{"ClockFormat"    link RX_ClockFormat}    FORMAT
@{"ClockPubScreen" link RX_ClockPubScreen} NAME/A
@{"ClockXY"        link RX_ClockXY}        X/N/K,Y/N/K,RESET/S

