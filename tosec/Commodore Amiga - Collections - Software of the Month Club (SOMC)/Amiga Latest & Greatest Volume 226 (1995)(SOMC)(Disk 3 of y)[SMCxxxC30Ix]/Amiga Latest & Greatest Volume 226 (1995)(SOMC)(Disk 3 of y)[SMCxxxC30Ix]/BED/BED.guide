  @{" SetChar         " LINK "SetChar" 0} - Set the char under the cursor
  @{" SetCurrentDir   " LINK "SetCurrentDir" 0} - Set the current directory
  @{" SetDisplayLock  " LINK "SetDisplayLock" 0} - Set the lock on the display of the current file
  @{" SetFilePath     " LINK "SetFilePath" 0} - Set the path of the curret document
  @{" SetInputLock    " LINK "SetInputLock" 0} - Set the lock on the input in the current document
  @{" SetPrefs        " LINK "SetPrefs" 0} - Set the specified preference
  @{" SetPriority     " LINK "SetPriority" 0} - Set the task priority of BED
  @{" SetQuoteMode    " LINK "SetQuoteMode" 0} - Set the quote mode
