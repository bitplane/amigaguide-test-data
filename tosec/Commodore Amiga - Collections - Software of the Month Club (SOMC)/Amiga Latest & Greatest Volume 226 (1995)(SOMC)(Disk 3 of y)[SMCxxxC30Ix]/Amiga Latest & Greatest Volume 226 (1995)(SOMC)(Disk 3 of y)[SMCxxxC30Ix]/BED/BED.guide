@NODE "Prefs_Reference" "Preferences Reference"

  @{title "Preferences Reference"}

  This is the list of the preferences supported by Blacks Editor 1.0
  which can be used in any preference file, and can be modified with
  the command SetPrefs <pref_name> <value>.

    @{" Alphabetical order " LINK "Prefs_Alphabetical" 0}

    @{" Functional groupings " LINK "Prefs_Functional" 0}

@ENDNODE

