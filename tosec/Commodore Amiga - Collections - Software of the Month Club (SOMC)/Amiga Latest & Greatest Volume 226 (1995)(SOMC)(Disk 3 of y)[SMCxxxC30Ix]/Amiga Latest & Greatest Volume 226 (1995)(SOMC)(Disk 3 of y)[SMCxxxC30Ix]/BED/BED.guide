  @{" OpenDoc         " LINK "OpenDoc" 0} - Open a new document
  @{" OpenFile        " LINK "OpenFile" 0} - Load the specified file in the current document
  @{" OpenMacro       " LINK "OpenMacro" 0} - Load the specified macro
