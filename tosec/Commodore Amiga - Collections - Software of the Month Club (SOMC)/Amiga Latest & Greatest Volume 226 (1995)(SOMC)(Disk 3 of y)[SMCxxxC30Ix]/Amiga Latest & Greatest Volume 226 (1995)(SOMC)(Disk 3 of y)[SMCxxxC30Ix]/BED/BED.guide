  @{" RequestBool     " LINK "RequestBool" 0} - Open a bool requester
  @{" RequestChoice   " LINK "RequestChoice" 0} - Open a requester with multiple choices
  @{" RequestFile     " LINK "RequestFile" 0} - Open a file requester
  @{" RequestFont     " LINK "RequestFont" 0} - Open a font requester
