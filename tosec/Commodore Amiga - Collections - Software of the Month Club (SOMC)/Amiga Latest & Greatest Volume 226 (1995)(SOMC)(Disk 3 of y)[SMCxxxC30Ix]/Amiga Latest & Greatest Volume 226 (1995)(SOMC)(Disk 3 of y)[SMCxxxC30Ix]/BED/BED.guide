  @{" OpenRequester   " LINK "OpenRequester" 0} - Open the specified requester
  @{" PasteClip       " LINK "PasteClip" 0} - Paste the clipboard in the current document
  @{" PlayMacro       " LINK "PlayMacro" 0} - Play the recorded macro
  @{" PrintClip       " LINK "PrintClip" 0} - Print the contents of the clipboard
  @{" PrintFile       " LINK "PrintFile" 0} - Print the current document
