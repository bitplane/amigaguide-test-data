@NODE "QuickReference" "Quick Reference for Blacks Editor"

  @{title "Quick reference for Blacks Editor"}

  IMPORTANT !!! These three keyboard sequences are always valid:
  --------------------------------------------------------------

  [Ctrl]-[Shift]-[Alt]-F1   Restore the built-in default definitions (menus, keys, etc...)
  [Ctrl]-[Shift]-[Alt]-F2   Restore the built-in default preferences
  [Ctrl]-[Shift]-[Alt]-F3   Remake the screen


  Standard keybard sequences:
  ---------------------------

  [Return]               Insert a line
  [Enter]                Insert a line with indent
  [Backspace]            Delete the previous character
  [Del]                  Delete the current character
  [Tab]                  Insert a tab
  [Esc]
  [Help]                 This help

  [CursorUp]             Move the cursor up by one line
  [CursorDown]           Move the cursor down by one line
  [CursorRight]          Move the cursor right by one character
  [CursorLeft]           Move the cursor left by one character

  [F1]                   Open a new document
  [F2]                   Open a new file in the current document
  [F3]                   Find matching bracket
  [F4]                   Open the Command Shell
  [F5]                   Open a DOS Shell
  [F6]                   Move the cursor to the start of previous paragraph
  [F7]                   Move the cursor to the start of next paragraph
  [F8]                   Indent the selected block
  [F9]                   Save the current file if modified
  [F10]                  Activate the next document and bring it to front


  [Shift]-[Return]       Insert a line without breaking the current line
  [Shift]-[Enter]        Insert a line with indent without breaking the current line
  [Shift]-[BackSpace]    Delete to the start of the current word
  [Shift]-[Del]          Delete to the end of the current word
  [Shift]-[Tab]          Move to the previous tab stop on the current line
  [Shift]-[Esc]
  [Shift]-[Help]         Display the General Blacks Editor Help

  [Shift]-[CursorUp]     Move the cursor up by one screenful
  [Shift]-[CursorDown]   Move the cursor down by one screenful
  [Shift]-[CursorRight]  Move to the start of the next word
  [Shift]-[CursorLeft]   Move to the start of the previous word

  [Shift]-[F1]           Display the General Blacks Editor Help
  [Shift]-[F2]           Open a new file in a new document
  [Shift]-[F3]           Undo the current line
  [Shift]-[F4]           Restore the window default position
  [Shift]-[F5]           Iconify / Deiconify the current document window
  [Shift]-[F6]           Format the current paragraph
  [Shift]-[F7]           Justify current paragraph
  [Shift]-[F8]           Unindent the selected block
  [Shift]-[F9]           Save the current file with a different name
  [Shift]-[F10]          Activate the previous document and bring it to front


  [Alt]-[Return]         Insert a line with indent without breaking the current line
  [Alt]-[Enter]          Insert a line without breaking the current line
  [Alt]-[BackSpace]      Delete to the start of the current line
  [Alt]-[Del]            Delete to the end of the current line
  [Alt]-[Tab]            Move to the previous tab stop on the current line
  [Alt]-[Esc]            Close the current document
  [Alt]-[Help]

  [Alt]-[CursorUp]       Move the cursor to the start of the document
  [Alt]-[CursorDown]     Move the cursor to the end of the document
  [Alt]-[CursorRight]    Move the cursor to the end of the line
  [Alt]-[CursorLeft]     Move the cursor to the start of the line

  [Alt]-[F1]             Move to the position indicated by bookmark 1
  [Alt]-[F2]             Move to the position indicated by bookmark 2
  [Alt]-[F3]             Move to the position indicated by bookmark 3
  [Alt]-[F4]             Move to the position indicated by bookmark 4
  [Alt]-[F5]             Move to the position indicated by bookmark 5
  [Alt]-[F6]             Move to the position indicated by bookmark 6
  [Alt]-[F7]             Move to the position indicated by bookmark 7
  [Alt]-[F8]             Move to the position indicated by bookmark 8
  [Alt]-[F9]             Move to the position indicated by bookmark 9
  [Alt]-[F10]            Move to the position indicated by bookmark 10


  [Ctrl]-[Return]        Insert a line with indent
  [Ctrl]-[Enter]         Insert a line
  [Ctrl]-[Backspace]     Delete the current line
  [Ctrl]-[Del]           Delete the current line
  [Ctrl]-[Tab]           Move to the next tab stop on the current line
  [Ctrl]-[Esc]           Quit BED
  [Ctrl]-[Help]

  [Ctrl]-[CursorUp]      Scroll the current document up
  [Ctrl]-[CursorDown]    Scroll the current document down
  [Ctrl]-[CursorRight]   Shift the current line or block right
  [Ctrl]-[CursorLeft]    Shift the current line or block left

  [Ctrl]-[F1]            Set bookmark 1 to the current cursor position
  [Ctrl]-[F2]            Set bookmark 2 to the current cursor position
  [Ctrl]-[F3]            Set bookmark 3 to the current cursor position
  [Ctrl]-[F4]            Set bookmark 4 to the current cursor position
  [Ctrl]-[F5]            Set bookmark 5 to the current cursor position
  [Ctrl]-[F6]            Set bookmark 6 to the current cursor position
  [Ctrl]-[F7]            Set bookmark 7 to the current cursor position
  [Ctrl]-[F8]            Set bookmark 8 to the current cursor position
  [Ctrl]-[F9]            Set bookmark 9 to the current cursor position
  [Ctrl]-[F10]           Set bookmark 10 to the current cursor position

  [Ctrl]-R               Toggle read-only mode
  [Ctrl]-T               Toggle expand tabs mode
  [Ctrl]-I               Toggle auto-indent mode
  [Ctrl]-F               Toggle free form mode
  [Ctrl]-O               Toggle overstrike mode
  [Ctrl]-W               Toggle word wrap mode
  [Ctrl]-J               Toggle jump scroll mode
  [Ctrl]-B               Toggle backup mode
  [Ctrl]-K               Toggle IBM keypad mode

  [Ctrl]-Q               Quote character, next character entered is taken as is

  [Ctrl]-1               Change the text color
  [Ctrl]-2               Change the background color
  [Ctrl]-3               Change the text color of selected text
  [Ctrl]-4               Change the background color of selected text

  [Alt]-[Ctrl]-[CursorLeft]  Move the cursor to the start of the word
  [Alt]-[Ctrl]-[CursorRight] Move the cursor to the end of the word
  [Alt]-[Ctrl]-[Del]         Delete to the start of the word
  [Alt]-[Ctrl]-[Backspace]   Delete to the end of the word

  [Home]          Move the cursor to the start of the document
  [End]           Move the cursor to the end of the document
  [PgUp]          Scroll the document up by one page
  [PgDn]          Scroll the document down by one page
  [Ins]           Toggle overstrike mode
  [Del]           Delete the current charcater
  [Cursorup]      Scroll the document up by one line
  [CursorDown]    Scroll the document down by one line
  [CursorLeft]    Move the cursor left by one character
  [CursorRight]   Move the cursor right by one character
  [ScrL]          Toggle read-only mode
  [PrtSc]         Print the current file


  Standard mouse sequences:
  -------------------------

  Holding down the left button and pushing the mouse off the bottom or top
  edges of the window scrolls the display.

  Double-clicking the left button marks the start of a selection block.

  Holding down the middle button and cliking the right button marks the start
  of a selection block


  Status Area Information
  -----------------------

  The letters in the status area have the following meaning:


  M/m  Document modified since last save? (M=Yes, m=No)
  R/r  Read Only (R=On, r=Off)
  T/t  Expand Tabs (T=On, t=Off)
  I/i  Auto-Indent (I=On, i=Off)
  F/f  Free Form (F=On, f=Off)
  O/o  Overstrike (O=On, o=Off)
  W/w  Word Wrap (W=On, w=Off)
  J/j  Jump Scroll (J=On, j=Off)
  B/b  Create Backups (B=On, b=Off)
  K/k  IBM Keyboard (K=On, k=Off)

@ENDNODE

@NODE "Commands_Reference" "Commands Reference"

  @{title "Commands Reference"}

  Blacks Editor 1.0 supports 150 ARexx commands.

  You can use these commands to write your own definition file, to
  modify an existing one, or to write ARexx Macros.

  The global commands are the only who can be sent to the general
  ARexx port called BED. The others can only be sent to the specific
  ARexx port of some document.

  The commands are listed according different criteria:

    @{" Alphabetical order " LINK "Commands_Alphabetical" 0}

    @{" Functional groupings " LINK "Commands_Functional" 0}

    @{" Global commands " LINK "Commands_Global" 0}

@ENDNODE

@NODE "Commands_Alphabetical" "Alphabetical List of Commands"
@toc "Commands_Reference"

  @{title "Alphabetical List of Commands"}

  @{" About           " LINK "About" 0} - Bring up the About requester
  @{" ActivateLastDoc " LINK "ActivateLastDoc" 0} - Activates and bring to front the last document
  @{" ActivateNextDoc " LINK "ActivateNextDoc" 0} - Activates and bring to front the next document
  @{" ActivatePrevDoc " LINK "ActivatePrevDoc" 0} - Activates and grong to front the previous document
  @{" ActivateWindow  " LINK "ActivateWindow" 0} - Activates the window of the current document
  @{" BackSpace       " LINK "BackSpace" 0} - Delete the character before the cursor
  @{" BeepScreen      " LINK "BeepScreen" 0} - Flashes the screen
  @{" Center          " LINK "Center" 0} - Center the current paragraph
  @{" CenterView      " LINK "CenterView" 0} - Center vertically the current line
  @{" ClearBookMark   " LINK "ClearBookMark" 0} - Clear the specified bookmark
  @{" ClearFile       " LINK "ClearFile" 0} - Clears the current file
  @{" CloseDoc        " LINK "CloseDoc" 0} - Closes the current document
  @{" ControlWindow   " LINK "ControlWindow" 0} - Toggle between open and close document window
  @{" Conv2Lower      " LINK "Conv2Lower" 0} - Convert the character to lower case
  @{" Conv2Spaces     " LINK "Conv2Spaces" 0} - Convert the tabs to spaces
  @{" Conv2Tabs       " LINK "Conv2Tabs" 0} - Convert the spaces to tabs
  @{" Conv2Upper      " LINK "Conv2Upper" 0} - Convert the character to upper case
  @{" CopyBlk         " LINK "CopyBlk" 0} - Copy the selected block to the clipboard
  @{" CutBlk          " LINK "CutBlk" 0} - Copy the selected block to the clipboard and erase it
  @{" Delete          " LINK "Delete" 0} - Delete the character under the cursor character
  @{" DeleteBlk       " LINK "DeleteBlk" 0} - Erase the selected block
  @{" DeleteEOL       " LINK "DeleteEOL" 0} - Delete from the cursor to the end of the line
  @{" DeleteEOF       " LINK "DeleteEOF" 0} - Delete from the cursor to the end of the file
  @{" DeleteEOW       " LINK "DeleteEOW" 0} - Delete from the cursor to the end of the word
  @{" DeleteLine      " LINK "DeleteLine" 0} - Delete the current line
  @{" DeleteSOL       " LINK "DeleteSOL" 0} - Delete from the cursor to the start of the line
  @{" DeleteSOF       " LINK "DeleteSOF" 0} - Delete from the cursor to the start of the file
  @{" DeleteSOW       " LINK "DeleteSOW" 0} - Delete from the cursor to the start of the word
  @{" DeleteWord      " LINK "DeleteWord" 0} - Delete the word under the cursor
  @{" EncryptBlk      " LINK "EncryptBlk" 0} - Encrypt the selected block
  @{" EndMacro        " LINK "EndMacro" 0} - Stops the recording of a macro
  @{" ExecARexxMacro  " LINK "ExecARexxMacro" 0} - Execute am ARexx script
  @{" ExecARexxString " LINK "ExecARexxString" 0} - Execute an ARexx string
  @{" ExecDosScript   " LINK "ExecDosScript" 0} - Execute a DOS script
  @{" ExecTool        " LINK "ExecTool" 0} - Execute syncronously a Tool
  @{" Exist           " LINK "Exist" 0} - Check if a the specified command is supported by BED
  @{" ExistsFile      " LINK "ExistsFile" 0} - Check if a file exists
  @{" Find            " LINK "Find" 0} - Search in the current document for the specified string
  @{" FindChange      " LINK "FindChange" 0} - Search in the current document for the specified string and replace it with another
  @{" FormatParagraph " LINK "FormatParagraph" 0} - Format the current paragraph
  @{" GetBlk          " LINK "GetBlk" 0} - Return the text in the selected block
  @{" GetBlkDims      " LINK "GetBlkDims" 0} - Return info about the selected block
  @{" GetBlkInfo      " LINK "GetBlkInfo" 0} - Return info about the selected block
  @{" GetChar         " LINK "GetChar" 0} - Return the current character
  @{" GetCurrentDir   " LINK "GetCurrentDir" 0} - Return the name of the current dir
  @{" GetCursorPos    " LINK "GetCursorPos" 0} - Return info about the current position of the cursor
  @{" GetDocuments    " LINK "GetDocuments" 0} - Return the names of the documents and their ARexx port name
  @{" GetErrorInfo    " LINK "GetErrorInfo" 0} - Return the string of the specified error code
  @{" GetFileInfo     " LINK "GetFileInfo" 0} - Return info about the current document
  @{" GetFilePath     " LINK "GetFilePath" 0} - Return the path and/or filename of the current document
  @{" GetLastDoc      " LINK "GetLastDoc" 0} - Return the ARexx port name of the last edited document
  @{" GetLine         " LINK "GetLine" 0} - Return the text of the current line
  @{" GetLockInfo     " LINK "GetLockInfo" 0} - Return info about the locks
  @{" GetMacroInfo    " LINK "GetMacroInfo" 0} - Return info about the current macro recorded
  @{" GetPort         " LINK "GetPort" 0} - Return the ARexx port name of a document
  @{" GetPrefs        " LINK "GetPrefs" 0} - Return the value of the specified preference
  @{" GetPriority     " LINK "GetPriority" 0} - Return the task priority of BED
  @{" GetScreenInfo   " LINK "GetScreenInfo" 0} - Return info about the screen
  @{" GetTemplate     " LINK "GetTemplate" 0} - Return the template of the specified command
  @{" GetVersion      " LINK "GetVersion" 0} - Return the version string of BED
  @{" GetViewInfo     " LINK "GetViewInfo" 0} - Return info about the current view
  @{" GetWindowInfo   " LINK "GetWindowInfo" 0} - Return info about the current document window
  @{" GetWindowSpec   " LINK "GetWindowSpec" 0} - Return the specification of the current document window
  @{" GetWord         " LINK "GetWord" 0} - Return the word under the cursor
  @{" Help            " LINK "Help" 0} - Display an AmigaGuide document with an help about the specified topic
  @{" IconifyWindow   " LINK "IconifyWindow" 0} - Iconify/uniconify the current document window
  @{" Illegal         " LINK "Illegal" 0} - Produces an error
  @{" Insert          " LINK "Insert" 0} - Insert the specified string in the document
  @{" InsertTab       " LINK "InsertTab" 0} - Insert a tab in the text
  @{" InsertFile      " LINK "InsertFile" 0} - Insert a file in the document
  @{" InsertLine      " LINK "InsertLine" 0} - Insert a new line in the document
  @{" Justify         " LINK "Justify" 0} - Justify the current paragraph
  @{" LeftJustify     " LINK "LeftJustify" 0} - Left justify the current paragraph
  @{" MarkBlk         " LINK "MarkBlk" 0} - Mark the start of the selection block
  @{" Move            " LINK "Move" 0} - Move the cursor to the specified line and/or column
  @{" MoveBookMark    " LINK "MoveBookMark" 0} - Move the cursor to the specified bookmark
  @{" MoveDown        " LINK "MoveDown" 0} - Move the cursor down one or more lines line
  @{" MoveDownScr     " LINK "MoveDownScr" 0} - Move the cursor down one page
  @{" MoveEOF         " LINK "MoveEOF" 0} - Move the cursor to the end of the document
  @{" MoveEOL         " LINK "MoveEOL" 0} - Move the cursor to the end of the current line
  @{" MoveEOW         " LINK "MoveEOW" 0} - Move the cursor to the end of the word
  @{" MoveLeft        " LINK "MoveLeft" 0} - Move the cursor left one or more characters
  @{" MoveMatchBkt    " LINK "MoveMatchBkt" 0} - Move the cursor on the matching bracket
  @{" MoveNextTabStop " LINK "MoveNextTabStop" 0} - Move the cursor to the next tab stop position
  @{" MoveNextWord    " LINK "MoveNextWord" 0} - Move the cursor to the start of the next word
  @{" MovePrevTabStop " LINK "MovePrevTabStop" 0} - Move the cursor to the previous tab stop
  @{" MovePrevWord    " LINK "MovePrevWord" 0} - Move the cursor to the start of the previous word
  @{" MoveRight       " LINK "MoveRight" 0} - Move the cursor right one or more characters
  @{" MoveSizeWindow  " LINK "MoveSizeWindow" 0} - Change the dimensions and position of the current document window
  @{" MoveSOF         " LINK "MoveSOF" 0} - Move the cursor to the start of the file
  @{" MoveSOL         " LINK "MoveSOL" 0} - Move the cursor to the start of the current line
  @{" MoveSOW         " LINK "MoveSOW" 0} - Move the cursor to the start of the current word
  @{" MoveUp          " LINK "MoveUp" 0} - Move the cursor up one or more lines
  @{" MoveUpScr       " LINK "MoveUpScr" 0} - Move the cursor up one page
  @{" MoveWindow      " LINK "MoveWindow" 0} - Change the position of the current document window
  @{" NewShell        " LINK "NewShell" 0} - Opens a new shell
  @{" Nop             " LINK "Nop" 0} - Absolutely nothing
