@node Codes

    @{b}@{u}Übersicht aller Steuer-Codes@{ub}@{uu}@{par}

@{b}Hoch:@{ub}@{par}
  @{b}Syntax:@{ub} <Obj1>^<Obj2>@{par}
  @{b}Funktion:@{ub} Stellt <Obj2> abhängig von der Größe von <Obj1> hoch, um
z.B. eine Potenz darzustellen.@{par}
  @{b}Eingabe:@{ub} <Obj1> - Basis@{par}
           <Obj2> - Exponent@{par}

@{b}Tief:@{ub}@{par}
  @{b}Syntax:@{ub}<Obj1>_<Obj2>@{par}
  @{b}Funktion:@{ub} Stellt <Obj2> abhängig von der Größe von <Obj1> tief, um
z.B. einen Index darzustellen.@{par}
  @{b}Eingabe:@{ub} <Obj1> - Basis@{par}
           <Obj2> - Index@{par}

@{b}Hoch und Tief:@{ub}@{par}
  @{b}Syntax:@{ub} <Obj1>^_<Obj2><Obj3>@{par}
  @{b}Funktion:@{ub} Stellt <Obj2> abhängig von der Größe von <Obj1> hoch und
<Obj3> tief.@{par}
  @{b}Eingabe:@{ub} <Obj1> - Basis@{par}
           <Obj2> - Exponent@{par}
           <Obj3> - Index@{par}

@{b}Oben:@{ub}@{par}
  @{b}Syntax:@{ub} <Obj>\\up<Obj2>@{par}
  @{b}Funktion:@{ub} Positioniert <Obj2> oberhalb von <Obj1>.@{par}
  @{b}Eingabe:@{ub} <Obj1> - Grundobjekt@{par}
           <Obj2> - oberes Objekt@{par}
 
  @{b}Beispiel:@{ub} @{par}
               -1@{par}
  F\\up[-1] ->  F (Umkehrfunktion)@{par}

@{b}Unten:@{ub}@{par}
  @{b}Syntax:@{ub} <Obj1>\\dn<Obj2>@{par}
  @{b}Funktion:@{ub} Positioniert <Obj2> unterhalb von <Obj1>.@{par}
  @{b}Eingabe:@{ub} <Obj1> - Grundobjekt@{par}
           <Obj2> - unteres Objekt@{par}
  @{b}Beispiel:@{ub}@{par}
                      lim@{par}
  [lim]\\dn[n->0] ->  n->0@{par}

@{b}Oben und Unten:@{ub}@{par}
  @{b}Syntax:@{ub} <Obj1>\\ud<Obj2><Obj3>@{par}
  @{b}Funktion:@{ub} Positioniert <Obj2> oberhalb, <Obj3> unterhalb von <Obj1>.@{par}
  @{b}Eingabe:@{ub} <Obj1> - Grundobjekt@{par}
           <Obj2> - oberes Objekt@{par}
           <Obj3> - unteres Objekt@{par}

@{b}Klammern:@{ub}@{par}

  @{b}Syntax:@{ub}@{par}
    Eingabe      Ausgabe@{par}
    ( <Obj1>    -> ( <Obj1>@{par}
    { <Obj1>    -> { <Obj1>@{par}
    \\l[ <Obj1> -> [ <Obj1>@{par}
    \\l] <Obj1> -> ] <Obj1>@{par}
    \\l| <Obj1> -> | <Obj1>@{par}
    <Obj1> )    -> <Obj1> )@{par}
    <Obj1> }    -> <Obj1> }@{par}
    <Obj1> \\r] -> <Obj1> ]@{par}
    <Obj1> \\r[ -> <Obj1> [@{par}
    <Obj1> \\r| -> <Obj1> |@{par}
  Außerdem gibt es spitze Klammern, die nur über die @{"Auswahl-gadgets" link Select} anwählbar sind:@{par}
    < <Obj1> -> < <Obj1>@{par}
    <Obj1> > -> <Obj1> >@{par}

  @{b}Funktion:@{ub} Skaliert die Klammer in Abhängigkeit von der Größe von <Obj1>@{par}
  @{b}Eingabe:@{ub} <Obj1> - Größe der Klammer@{par}

  @{b}Beispiel:@{ub}@{par}
                  / 1  |@{par}
  ([1/2x]\\r| ->  |  -x |@{par}
                  \\ 2  |@{par}

@{b}Bruch:@{ub}@{par}
  @{b}Syntax:@{ub} <Obj1>/<Obj2>@{par}
  @{b}Funktion:@{ub} Erzeugt einen Bruch.@{par}
  @{b}Eingabe:@{ub} <Obj1> - Zähler@{par}
           <Obj2> - Nenner@{par}

@{b}Quadratwurzel:@{ub}@{par}
  @{b}Syntax:@{ub} \\sqrt<Obj1>@{par}
  @{b}Funktion:@{ub} Erzeugt eine Quadraturzel@{par}
  @{b}Eingabe:@{ub} <Obj1> - Radikand@{par}

@{b}Wurzel:@{ub}@{par}
  @{b}Syntax:@{ub} \\rt<Obj1><Obj2>@{par}
  @{b}Funktion:@{ub} Erzeugt eine Wurzel@{par}
  @{b}Eingabe:@{ub} <Obj1> - Wurzelexponent@{par}
           <Obj2> - Radikand@{par}


@{b}Matrix:@{ub}@{par}
  @{b}Syntax:@{ub} \\mx<m><n><Obj1><Obj2>...<Objm*n>@{par}
  @{b}Funktion:@{ub} Erzeugt eine (m,n)-Matrix@{par}
  @{b}Eingabe:@{ub} <m> - einstellige Anzahl der Zeilen (m=1..9)@{par}
           <n> - einstellige Anzahl der Spalten (n=1..9)@{par}
           <Obj1>,<Obj2>,...,<Objm*n> - Felder der Matrix (Zeile für Zeile@{par}
  @{b}Beispiel:@{ub}@{par}

  ([\\mx321[1/2]4[2,3][\\sqrt2]0]) @{par}

@{code}
       /   1 \\
      / 1  -  \\
      |    2  |
  --> |       |
      | 4 2,3 |
      \\  _    /
       \\Y2 0 /

@{body}

@{b}Unterstreichen:@{ub}@{par}
  @{b}Syntax:@{ub} \\ul<Obj1>@{par}
  @{b}Funktion:@{ub} Zeichnet einen Unterstrich@{par}
  @{b}Eingabe:@{ub} <Obj1> - zu unterstreichendes Object@{par}

@{b}überstreichen:@{ub}@{par}
  @{b}Syntax:@{ub} \\ol<Obj1>@{par}
  @{b}Funktion:@{ub} Zeichnet eine Linie über dem Objekt@{par}
  @{b}Eingabe:@{ub} <Obj1> - zu überstreichendes Object@{par}
  @{b}Beispiel:@{ub}@{par}
@{code}
               --
  \\ol[PQ]  ->  PQ
@{body}


Da die Zeichen '^','_','\\' und '/' als Steuer-Codes verwendet werden, kann
man sie nur durch voranstellen eines Backslashes ('\\') als normale Zeichen
verwenden.@{par}
Also:@{par}
  \\^ -> ^@{par}
  \\_ -> _@{par}
  \\\\ -> \\@{par}
  \\/ -> /

@endnode

