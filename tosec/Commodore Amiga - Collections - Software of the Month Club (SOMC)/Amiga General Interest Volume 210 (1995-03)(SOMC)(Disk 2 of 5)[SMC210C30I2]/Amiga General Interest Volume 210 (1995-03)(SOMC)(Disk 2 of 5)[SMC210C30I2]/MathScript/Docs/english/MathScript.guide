@node Codes

    @{b}@{u}Overview of all control codes@{ub}@{uu}@{par}


@{b}Up:@{ub}@{par}
  @{b}syntax:@{ub} <Obj1>^<Obj2>@{par}
  @{b}function:@{ub} Moves <Obj2> dependent on the size of <Obj1> up for
example in order to show it as an exponent of a power.@{par}
  @{b}input:@{ub} <Obj1> - base@{par}
           <Obj2> - exponent

@{b}Down:@{ub}@{par}
  @{b}syntax:@{ub}<Obj1>_<Obj2>@{par}
  @{b}function:@{ub} Moves <Obj2> dependent on the size of <Obj1> down for
example in order to show an subscript.@{par}
  @{b}input:@{ub} <Obj1> - base@{par}
           <Obj2> - subscript

@{b}Up and down:@{ub}@{par}
  @{b}syntax:@{ub} <Obj1>^_<Obj2><Obj3>@{par}
  @{b}function:@{ub} Moves <Obj2> dependent on the size of <Obj1> up and
<Obj3> down.@{par}
  @{b}input:@{ub} <Obj1> - base@{par}
           <Obj2> - exponent@{par}
           <Obj3> - subscript@{par}

@{b}Above:@{ub}@{par}
  @{b}syntax:@{ub} <Obj>\\up<Obj2>@{par}
  @{b}function:@{ub} Moves <Obj2> above <Obj1>.@{par}
  @{b}input:@{ub} <Obj1> - base object@{par}
           <Obj2> - higher object@{par}
 
@{b}Example:@{ub} @{par}
               -1@{par}
  F\\up[-1] ->  F (inverse function)@{par}

@{b}Under:@{ub}@{par}
  @{b}syntax:@{ub} <Obj1>\\dn<Obj2>@{par}
  @{b}function:@{ub} Moves <Obj2> under <Obj1>.@{par}
  @{b}input:@{ub} <Obj1> - base object@{par}
           <Obj2> - lower object@{par}
  @{b}Example:@{ub}@{par}
                      lim@{par}
  [lim]\\dn[n->0] ->  n->0@{par}

@{b}Above and under:@{ub}@{par}
  @{b}syntax:@{ub} <Obj1>\\ud<Obj2><Obj3>@{par}
  @{b}function:@{ub} Moves <Obj2> above and <Obj3> under <Obj1>.@{par}
  @{b}input:@{ub} <Obj1> - base object@{par}
           <Obj2> - higher object@{par}
           <Obj3> - lower object@{par}

@{b}Brackets:@{ub}@{par}

  @{b}syntax:@{ub}@{par}
    input      output@{par}
    (<Obj1>   -> (<Obj1>@{par}
    {<Obj1>   -> {<Obj1>@{par}
    \\l[<Obj1> -> [<Obj1>@{par}
    \\l]<Obj1> -> ]<Obj1>@{par}
    \\l|<Obj1> -> |<Obj1>@{par}
    <Obj1>)   -> <Obj1>)@{par}
    <Obj1>}   -> <Obj1>}@{par}
    <Obj1>\\r] -> <Obj1>]@{par}
    <Obj1>\\r[ -> <Obj1>[@{par}
    <Obj1>\\r| -> <Obj1>|@{par}
  Moreover there are special pointed brackets which are only available
through the @{"selection gadgets" link Select}:@{par}
    <<Obj1> -> <<Obj1>@{par}
    <Obj1>> -> <Obj1>>@{par}

  @{b}function:@{ub} Scales the brackets dependent on the size of <Obj1>@{par}
  @{b}input:@{ub} <Obj1> - specifies the size of the brackets@{par}

  @{b}Example:@{ub}@{par}
                  / 1  |@{par}
  ([1/2x]\\r| ->  |  -x |@{par}
                  \\ 2  |@{par}


@{b}Fraction:@{ub}@{par}
  @{b}syntax:@{ub} <Obj1>/<Obj2>@{par}
  @{b}function:@{ub} Creates a fraction.@{par}
  @{b}input:@{ub} <Obj1> - nominator@{par}
           <Obj2> - denominator@{par}

@{b}Square root:@{ub}@{par}
  @{b}syntax:@{ub} \\sqrt<Obj1>@{par}
  @{b}function:@{ub} Creates a square root.@{par}
  @{b}input:@{ub} <Obj1> @{par}

@{b}Root:@{ub}@{par}
  @{b}syntax:@{ub} \\rt<Obj1><Obj2>@{par}
  @{b}function:@{ub} Creates a root.@{par}
  @{b}input:@{ub} <Obj1> - root exponent@{par}
           <Obj2> @{par}


@{b}Matrix:@{ub}@{par}
  @{b}syntax:@{ub} \\mx<m><n><Obj1><Obj2>...<Objm*n>@{par}
  @{b}function:@{ub} Creates a (m,n)-matrix.@{par}
  @{b}input:@{ub} <m> - one-digit number of rows (m=1..9)@{par}
           <n> - one-digit number of columns (n=1..9)@{par}
           <Obj1>,<Obj2>,...,<Objm*n> - Elements of the matrix (row by row)@{par}
  @{b}example:@{ub}@{par}

  ([\\mx321[1/2]4[2,3][\\sqrt2]0]) @{par}

@{code}
       /   1 \\
      / 1  -  \\
      |    2  |
      |       |
      | 4 2,3 |
      \\  _    /
       \\Y2 0 /

@{body}

@{b}Underline:@{ub}@{par}
  @{b}syntax:@{ub} \\ul<Obj1>@{par}
  @{b}function:@{ub} Underline the object.@{par}
  @{b}input:@{ub} <Obj1> - underlined object.@{par}

@{b}Overline:@{ub}@{par}
  @{b}syntax:@{ub} \\ol<Obj1>@{par}
  @{b}function:@{ub} Overline the object.@{par}
  @{b}input:@{ub} <Obj1> - overlined object.@{par}
  @{b}example:@{ub}@{par}
@{code}
               --
  \\ol[PQ]  ->  PQ
@{body}


Because the characters  '^','_' ,'\\' and '/' are used as control codes you
can use them as normal characters by writing a single backslash ('\\') in
front of them.@{par}
Thus:@{par}
  \\^ -> ^@{par}
  \\_ -> _@{par}
  \\\\ -> \\@{par}
  \\/ -> /

@endnode

