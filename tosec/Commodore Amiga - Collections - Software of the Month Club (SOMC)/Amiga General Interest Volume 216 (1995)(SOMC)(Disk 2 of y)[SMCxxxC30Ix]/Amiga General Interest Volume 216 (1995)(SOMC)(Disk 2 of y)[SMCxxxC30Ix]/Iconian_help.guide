@NODE "Gadget.000.00D" "Icon X Position Text Entry Gadget"
@KEYWORDS "Changing the position of a saved icon."
Gadget:	@{b}Icon X Position Text Entry@{ub}
Gadget:	@{b}Icon Y Position Text Entry@{ub}

@{b}Function@{ub}
  Alters the saved viewing position of an icon.

@{b}Notes@{ub}
  A very large negative number will appear if the @{"Free Icon Position?" link "Gadget.000.00F"} gadget is checked upon loading an icon.
@ENDNODE

@NODE "Gadget.000.00E" "Icon Y Position Text Entry"
SEE:	@{"Icon X Position Text Entry" link "Gadget.000.00D"}
@ENDNODE

@NODE "Gadget.000.010" "Free Icon Position Checkbox"
@KEYWORDS "Changing the freedom of a saved icon."
Gadget:	@{b}Free Icon Position Checkbox@{ub}

@{b}Function@{ub}
  When checked, the icon will be saved similar to Workbench's "Unsnapshot" menu.
@ENDNODE

