@REM----------------------------------------------------------------------
@NODE "Edit->Paste" "Edit->Paste"
@TOC "Edit"
@KEYWORDS "Pasting an image from the clipboard."
Menu:	@{b}Edit@{ub}
Item:	@{b}Paste@{ub}

@{b}Function@{ub}
  Loads any image residing in the clipboard.  The image will be loaded using the current datatype settings.

@{b}See Also@{ub}
  @{"Copy" link "Edit->Copy"}
  @{"Cut" link "Edit->Cut"}
@ENDNODE
@NODE "Edit->Copy" "Edit->Copy"
@TOC "Edit"
@KEYWORDS "Copying an image to the clipboard."
Menu:	@{b}Edit@{ub}
Item:	@{b}Copy@{ub}

@{b}Function@{ub}
  Saves the current image to the clipboard.

@{b}See Also@{ub}
  @{"Paste" link "Edit->Paste"}
  @{"Cut" link "Edit->Cut"}
@ENDNODE
@NODE "Edit->Cut" "Edit->Cut"
@TOC "Edit"
@KEYWORDS "Cutting an image to the clipboard."
Menu:	@{b}Edit@{ub}
Item:	@{b}Cut@{ub}

@{b}Function@{ub}
  Save the current image to the clipboard.  If successful, the image will be cleared.

@{b}Notes@{ub}
  This operation is undoable.

@{b}See Also@{ub}
  @{"Paste" link "Edit->Paste"}
  @{"Copy" link "Edit->Copy"}
@ENDNODE
@NODE "Edit->Erase" "Edit->Erase"
@TOC "Edit"
@KEYWORDS "Clearing the current image."
Menu:	@{b}Edit@{ub}
Item:	@{b}Erase@{ub}

@{b}Function@{ub}
  Simply erases the current image.

@ENDNODE
@NODE "Edit->Exchange" "Edit->Exchange"
@TOC "Edit"
@KEYWORDS "Swapping the normal and highlight images"
Menu:	@{b}Edit@{ub}
Item:	@{b}Exchange@{ub}

@{b}Function@{ub}
  Swaps the normal and selected images.

@{b}Notes@{ub}
  This operation is undoable, but you will need to select undo for both images.
@ENDNODE

@NODE "Edit->Paste from Other" "Edit->Paste from Other"
@TOC "Edit"
@KEYWORDS "Copying one image to the other."
Menu:	@{b}Edit@{ub}
Item:	@{b}Paste from Other@{ub}

@{b}Function@{ub}
  Copies the other image to the current image.

@{b}Notes@{ub}
  This menu item is reversed from the standard IconEdit.
@ENDNODE
@REM----------------------------------------------------------------------
@NODE "Edit->Goto Oldest" "Edit->Goto Oldest"
@TOC "Edit"
@KEYWORDS "Undoing all."
Menu:	@{b}Edit@{ub}
Item:	@{b}Undo Buffers@{ub}
 Sub:	@{b}Goto Oldest@{ub}

@{b}Function@{ub}
@ENDNODE
