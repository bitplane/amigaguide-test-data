@ENDNODE

@NODE "Gadget.000.00A" "Redo Gadget"
@KEYWORDS "Redo using the redo gadget."
Gadget:	@{b}Redo Boolean@{ub}

@{b}Function@{ub}
  Moves back one spot in the current project's redo list, if available.

@{b}Keyboard Equivalent@{ub}
  Shift U
@ENDNODE

