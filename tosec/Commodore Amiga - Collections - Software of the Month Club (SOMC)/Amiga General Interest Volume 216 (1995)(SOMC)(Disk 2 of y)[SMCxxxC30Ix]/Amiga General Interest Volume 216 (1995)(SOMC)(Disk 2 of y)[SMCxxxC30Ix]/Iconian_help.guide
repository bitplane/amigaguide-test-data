	Cursor Down
  Shift Cursor Up
  Shift Cursor Down
@ENDNODE

@NODE "Gadget.000.005" "Magnification Level"
@KEYWORDS "Changing the magnification level."
Gadget:	@{b}Magnification Level Slider@{ub}

@{b}Function@{ub}
