@node f_findfirst "F_FindFirst" 

@{b}@{u}F_FindFirst@{ub}@{uu}


@{b}Name: @{ub}  F_FindFirst -- Search for a pattern  

@{b}Synopsis: @{ub}  F_FindFirst Field,Blur/K,Pattern/F
   Result = @{i}Number_of_Record@{ui}  

@{b}Function: @{ub}  Searches for the first matching with the pattern, which has 
   been either set with @{"F_SetSearchPat" link F_SetSearchPat} or using the arguments. If rc is 
   equal zero, Result is equal to the number of the found record. This 
   may be accessed using @{"F_GotoRec" link F_GotoRec}. If nothing is found, 5 is returned.  

@{b}Inputs: @{ub}  Field - ID of the Field to search
   Blur - Factor for blurred search. Specifying activates it. 
   Pattern - Standard search pattern. 
   If you don`t specify Field or Pattern, the values will be used, which 
   have been previously used in the search requester or have been set by 
   F_SetSearchPat and F_SetSearchField.  

@{b}Results: @{ub}  rc = 0: result = Number of matching record.  rc = 5: nothing 
   found or no pattern.   

@{b}Example: @{ub}  

/* Find-Example.rexx */
options results
address FIASCO

count = 0

F_FindFirst "Test" "?#?"   /* search for the first record in
                            * which the field with the ID Test
                            * is not empty */

do while rc = 0            /* Continue searching until
                            * nothing is found */

   F_GotoRec Result        /* activate the found record */

   count = count + 1

   F_FindNext "Test" "?#?" /* search for next */

end

/* All records done */


   
 

@{b}See also: @{ub}   

@endnode 
@node f_findnext "F_FindNext" 

@{b}@{u}F_FindNext@{ub}@{uu}


@{b}Name: @{ub}  F_FindNext -- Search for a pattern.  

@{b}Synopsis: @{ub}  F_FindNext Field,Blur/K,Pattern/F
   Result = @{i}Number_of_next_Record@{ui}  

@{b}Function: @{ub}  Searches for the next matching with the pattern, which has 
   been either set with @{"F_SetSearchPat" Link F_SetSearchPat} or using the arguments. 	If it 
   succeeds ( rc = 0), Result contains the number of the found record. 
   The record may be activated using @{"F_GotoRec" Link F_GotoRec}.  

@{b}Note: @{ub}  The active Record is not searched by F_FindNext and F_FindPrev. 
   If you want to write a program, which searches all records, you have 
   to call at first @{"F_FindFirst" Link F_FindFirst} and then F_FindNext.  

@{b}Inputs: @{ub}  Field - ID of the Field to search
   Blur - Factor for blurred search. Specifying activates it. 
   Pattern - Standard search pattern. 
   If you don`t specify Field or Pattern, the values will be used, which 
   have been previously used in the search requester or have been set by 
   F_SetSearchPat and F_SetSearchField.  

@{b}Results: @{ub}  If rc = 0, result = recordnumber of next matching.
   If rc = 5, nothing found or no pattern  

@{b}Example: @{ub}  see @{"F_FindFirst" link F_FindFirst}  

@{b}See also: @{ub}   

@endnode 
@node f_findprev "F_FindPrev" 

@{b}@{u}F_FindPrev@{ub}@{uu}


@{b}Name: @{ub}  F_FindPrev -- Search for a pattern backwards.  

@{b}Synopsis: @{ub}  F_FindPrev Field,Blur/K,Pattern/F
   Result = @{i}Number_of_prev_Record@{ui}  

@{b}Function: @{ub}  Searches for the previous matching with the pattern, which 
   has been either set with @{"F_SetSearchPat" Link F_SetSearchPat} or using the arguments. 	If 
   it succeeds ( rc = 0), Result contains the number of the found record. 
   This may be activated using @{"F_GotoRec" Link F_GotoRec}. 

@{b}Inputs: @{ub}  Field - ID of the Field to search
   Blur - Factor for blurred search. Specifying activates it. 
   Pattern - Standard search pattern. 
   If you don`t specify Field or Pattern, the values will be used, which 
   have been previously used in the search requester or have been set by 
   F_SetSearchPat and F_SetSearchField.  

@{b}Results: @{ub}  if rc = 0, result contains the recordnumber of previous 
   matching if rc = 5, nothing found or no pattern  

@{b}Note: @{ub}  F_FindPrev is not very handy in ARexx scripts. You should use 
   combinations of @{"F_FindFirst" Link F_FindFirst} and @{"F_FindNext" link F_FindNext} instead.  

@{b}See also: @{ub}   

@endnode 
@node f_findreq "F_FindReq" 

@{b}@{u}F_FindReq@{ub}@{uu}


@{b}Name: @{ub}  F_FindReq -- open the search requester  

@{b}Synopsis: @{ub}  F_FindReq  

@{b}Function: @{ub}  Opens the @{"search requester" Link RqFind}. This command does exactly the 
   same a @{"Compare/Find" Link MnFind}. The command may be only called in @{"record mode" link RecordMode}.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}See also: @{ub}   

@endnode 


@node f_getfieldattributes "F_GetFieldAttributes" 

@{b}@{u}F_GetFieldAttributes@{ub}@{uu}


@{b}Name: @{ub}  F_GetFieldAttributes -- Read the attributes of a field  

@{b}Synopsis: @{ub}  F_GetFieldAttributes Field/A,X/S,Y/S,W=Width/S,H=Height/S,
   Rexx/S,Type/S,ListX/S,ListW/S,MaxChars/S,InitCont/S,OwnInit/S,
   Labels/K/N,Commands/S,Stack/S
   rc = @{i}Success @{ui}
   Result = @{i}Attribute_Value @{ui}  

@{b}Function: @{ub}  Reads one attribute of the specified field. The value of the 
   attribute is returned in Result. Not every fieldtype supports all 
   attributes, if a type does not support a particular attribute, rc will 
   be not equal 0. You may only specify one attribute while calling this 
   command. For convenience, this command may be called both in record 
   mode and in mask mode.  This command may be also called in virtual 
   state. 

@{b}Input: @{ub}  Field - ID of a field. Always required. 
   X - I want to know the top edge of field in cursors 
   Y - Left edge of field in cursors 
   W - Width of field in cursors 
   H - Height of field in cursors 
   Rexx - Name of ARexx script assigned to field 
   Type - Type of field (e.g. string, integer, etc.) 
   ListX - Left edge of field in list, -1 if field is hidden 
   ListW - Width of field in list, -1 if field is hidden 
   MaxChars - MaxChars attribute 
   InitCont - InitCont attribute. One of own, old, key OwnInit - Own 
   initial content 
   Labels - Returns the label of the specified number
   Command - Command attribute of field
   Stack - Stack attribute of field
    

@{b}Results: @{ub}  rc - zero, if successful. 
   Result - contains requested attribute, if rc = 0  

@{b}See also: @{ub}  Field documentation 

@endnode 


@node f_getfieldcont "F_GetFieldCont" 

@{b}@{u}F_GetFieldCont@{ub}@{uu}


@{b}Name: @{ub}  F_GetFieldCont -- Read the content of a field  

@{b}Synopsis: @{ub}  F_GetFieldCont Field/A
   rc = Success
   result = Content
    

@{b}Function: @{ub}  Reads the content of the specified Field in the active record 
   and returns it in result.  May be only called in record mode.  This 
   command may be also called in virtual state. 

@{b}Inputs: @{ub}  FieldId - Id of Field  

@{b}Results: @{ub}  rc = 0 - everything Ok, result will be the content 
   rc = 5 - no record active 
   rc = 10 - arg missing, or unknown ID. 
    result - is equal to the current content of the field, if rc = 0.
   The format:
   String - the string itself.
   Integer - the number itself.
   Float - the fp number.
   Slider - the value of the slider.
   Cycle - the number of the active label.
   Date - the date in the format DD.MM.[YY]YY.
   Time - the time in the format HH:MM:SS.
   Extern - the string itself.
   Datatyp.- the string itself.
   

@{b}See also: @{ub}   

@endnode 
@node f_getprojfullname "F_GetProjFullName" 

@{b}@{u}F_GetProjFullName@{ub}@{uu}


@{b}Name: @{ub}  F_GetProjFullName -- get the name of the current project  

@{b}Synopsis: @{ub}  F_GetProjFullName
   Result = @{i}Name@{ui}  

@{b}Function: @{ub}  Returns the filename of the current project incl. path.  

@{b}Note: @{ub}  The path is relative to the current directory of Fiasco.  

@{b}Inputs: @{ub}   

@{b}Results: @{ub}  Name - Name of project incl. path.  

@{b}See also: @{ub}  @{"F_GetProjName" link F_GetProjName}  

@endnode 
@node f_getprojname "F_GetProjName" 

@{b}@{u}F_GetProjName@{ub}@{uu}


@{b}Name: @{ub}  F_GetProjName -- read the filename of the current project  

@{b}Synopsis: @{ub}  F_GetProjName
   Result = @{i}Filename@{ui}  

@{b}Function: @{ub}  Returns the filename of the current project without path. 
   This value may be used for @{"F_SelectProj" Link F_SelectProj}.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  Result - Filename of the current project without path. A file 
   must not necessarily exist. This is possible, if the name has been 
   changed using Options and the project has not been saved.  

@{b}See also: @{ub}  @{"F_GetProjFullName" link F_GetProjFullName}  

@endnode 


@node f_getrecnum "F_GetRecNum" 

@{b}@{u}F_GetRecNum@{ub}@{uu}


@{b}Name: @{ub}  F_GetRecNum -- Get the number of the current record.  

@{b}Synopsis: @{ub}  F_GetRecNum
   Result = @{i}Number_of_record@{ui}  

@{b}Function: @{ub}  Returns the number of the active record in result. May be 
   used to save the initial status of the project and to restore it at 
   the end using @{"F_GotoRec" Link F_GotoRec}.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  Result = Number of the record. Note that filters and other 
   operations may change the record numbers.  

@{b}See also: @{ub}   

@endnode 


@node f_gotofirstrec "F_GotoFirstRec" 

@{b}@{u}F_GotoFirstRec@{ub}@{uu}


@{b}Name: @{ub}  F_GotoFirstRec -- activate the first record  

@{b}Synopsis: @{ub}  F_GotoFirstRec  

@{b}Function: @{ub}  activates the first record. If the current project does not 
   contain any records, nothing will happen.  Equivalent with @{"Record/First" Link MnFirstRecord}
   . May be only called in @{"record mode" link recordMode}.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}See also: @{ub}   

@endnode 


@node f_gotonextrec "F_GotoNextRec" 

@{b}@{u}F_GotoNextRec@{ub}@{uu}


@{b}Name: @{ub}  F_GotoNextRec -- activate the next record  

@{b}Synopsis: @{ub}  F_GotoNextRec  

@{b}Function: @{ub}  Activates the record after the active one. If the active 
   record is the last record or the current project contains no records, 
   nothing will happen.  Equivalent with @{"Record/Next" Link MnNext}. May be only called 
   in @{"record mode" link recordMode}.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}See also: @{ub}   

@endnode 


@node f_gotolastrec "F_GotoLastRec" 

@{b}@{u}F_GotoLastRec@{ub}@{uu}


@{b}Name: @{ub}  F_GotoLastRec -- activate the last record  

@{b}Synopsis: @{ub}  F_GotoLastRec  

@{b}Function: @{ub}  Activates the last record. If the current project does not 
   contain any records, nothing will happen.  Equivalent with @{"Record/Last" Link MnLastRecord}
   . May be only called in @{"record mode" link recordMode}.  

@{b}Inputs: @{ub}   

@{b}Results: @{ub}   

@{b}See also: @{ub}   

@endnode 


@node f_gotoprevrec "F_GotoPrevRec" 

@{b}@{u}F_GotoPrevRec@{ub}@{uu}


@{b}Name: @{ub}  F_GotoPrevRec -- activate the previous record.  

@{b}Synopsis: @{ub}  F_GotoPrevRec  

@{b}Function: @{ub}  Activates the record, which precedes the active record. If 
   the active record is the first record, nothing will happen.  
   Equivalent with @{"Record/Previous" Link MnPrevious}. May be only called in @{"record mode" link recordMode}.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}See also: @{ub}   

@endnode 


@node f_gotorec "F_GotoRec" 

@{b}@{u}F_GotoRec@{ub}@{uu}


@{b}Name: @{ub}  F_GotoRec -- activate a record.  

@{b}Synopsis: @{ub}  F_GotoRec Record/A/N  

@{b}Function: @{ub}  Activate the record, whose number has been given as arg. If 
   the number was invalid, do nothing.  

@{b}Inputs: @{ub}  RecordNumber - The number of the record. Please note, that 
   sorting, adding or removing records or filters may change the record 
   numbers.  

@{b}Results: @{ub}   

@{b}See also: @{ub}   

@endnode 
@node f_gotorecreq "F_GotoRecReq" 

@{b}@{u}F_GotoRecReq@{ub}@{uu}


@{b}Name: @{ub}  F_GotoRecReq -- open the @{"Goto-Requester" Link RqGoto}  

@{b}Synopsis: @{ub}  F_GotoRecReq  

@{b}Function: @{ub}  Does exactly the same as @{"Records/Goto" Link MnGoto}. May be only called in 
   @{"record mode" link RecordMode}.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}See also: @{ub}  @{"F_GotoRec" link F_GotoRec} @{"Record/Goto" link MnGoto} 

@endnode 
@node f_import "F_Import" 

@{b}@{u}F_Import@{ub}@{uu}


@{b}Name: @{ub}  F_Import -- Import data 

@{b}Synopsis: @{ub}  F_Import File/A,RecStart/K,RecEnd/K,RecSep/K,FieldStart/K,
   FieldEnd/K,FieldSep/K,SkipLines/k,StartLine/N/K,FirstRecIDs/S,
   AppendFields/S
   rc = @{i}Success@{ui} 

@{b}Function: @{ub}  Calls the import function of Fiasco. The specified file will 
   be imported into the current project using the specified parameters. 
   For more information on import and export see section  
   @{"Import and Export" link XPort}.    You may also use the escape sequences of Fiasco. 
   If you do not specify a parameter, it will be empty. 

@{b}Inputs: @{ub}  File - Name of File
   RecStart,RecEnd,RecSep,FieldStart,FieldEnd,FieldSep - the structuring 
   characters
   SkipLines - Comment introducer 
   StartLine - Length of initial comment 
   FirstRecIDs - First Record contains IDs 
   AppendFields - Append new fields 
   

@{b}Results: @{ub}  rc = 0, if everything went well 

@{b}Notes: @{ub}  The option Overwrite old project of the import requester is not 
   directly supported. You have to emulate it using @{"F_ClearProject" Link f_clearproject}.  

@{b}See also: @{ub}  @{"F_Export" link f_export}, Chapter Import and Export 

@endnode 
@node f_ismarked "F_IsMarked" 

@{b}@{u}F_IsMarked@{ub}@{uu}


@{b}Name: @{ub}  F_IsMarked -- Is the record marked? 

@{b}Synopsis: @{ub}  F_IsMarked Record/N 
   rc = @{i}IsMarked@{ui} 

@{b}Function: @{ub}  Looks, whether the current or the specified record is marked. 
   If it is not marked, 5 is returned.  This command may be also called 
   in virtual state. 

@{b}Inputs: @{ub}  Record - Number of record, if not specified, current record is 
   used. 

@{b}Results: @{ub}  rc = 0: Record marked, = 5: Record not marked, > 5: other 
   error 

@{b}See also: @{ub} 

@endnode 


@node f_isvirgin "F_IsVirgin" 

@{b}@{u}F_IsVirgin@{ub}@{uu}


@{b}Name: @{ub}  F_IsVirgin -- Is the project unchanged?  

@{b}Synopsis: @{ub}  F_IsVirgin
   rc = @{i}Is_Virgin@{ui}  

@{b}Function: @{ub}  Tests, whether the current project has been changed since the 
   last saving. If it has been changed, Quit, Erase, Load and so on, will 
   put an requester.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  rc = 0 - Unchanged
   rc = 5 - Changed  

@{b}See also: @{ub}  @{"F_MakeVirgin" link F_MakeVirgin}  

@endnode 


@node f_loaddtobject "F_LoadDTObject" 

@{b}@{u}F_LoadDTObject@{ub}@{uu}


@{b}Name: @{ub}  F_LoadDTObject -- Load the contents of a datatypes field 

@{b}Synopsis: @{ub}  F_LoadDTObject Field/A 

@{b}Function: @{ub}  Loads the contents of a datatypes field, which was 
   "deferred". 

@{b}Inputs: @{ub}  Field - ID of datatypes field 

@{b}Results: @{ub}  The contents are loaded 

@{b}See also: @{ub} 

@endnode 
@node f_locate "F_Locate" 

@{b}@{u}F_Locate@{ub}@{uu}


@{b}Name: @{ub}  F_Locate -- Locate the Cursor  

@{b}Synopsis: @{ub}  F_Locate X/A/N,Y/A/N  

@{b}Function: @{ub}  Sets the cursor at the given position. At this place the next 
   mask operation will happen. May be only called in mask mode.  

@{b}Inputs: @{ub}  X - X-Coordinate
   Y - Y-Coordinate  

@{b}Results: @{ub}   

@{b}Bugs: @{ub}  Currently not particularly useful, because there are no direct 
   commands for manipulating the mask.  

@{b}See also: @{ub}   

@endnode 


@node f_lockgui "F_LockGUI" 

@{b}@{u}F_LockGUI@{ub}@{uu}


@{b}Name: @{ub}  F_LockGUI -- Make the GUI not accessible by the user. 

@{b}Synopsis: @{ub}  F_LockGUI 

@{b}Function: @{ub}  Locks the GUI of Fiasco. The pointer will appear as a "wait 
   clock". After locking the GUI, the ARexx script can run, without the 
   danger of being influenced by the user. Before the script ends, 
   @{"F_UnlockGUI" link f_unlockgui} must be called in order to give the control back to the 
   user. F_LockGUI and F_UnlockGUI may be nested. 

@{b}Inputs: @{ub}  none 

@{b}Results: @{ub}  none 

@{b}Note: @{ub}  Make sure, that your scripts unlock the GUI in every case before 
   exiting. Use signal commands to catch errors or breaks. For example: 
   
   /* test.rexx */
   
   address FIASCO
   options results

   signal on syntax
   signal on halt
   
   F_LockGUI        /* Lock the GUI */

   /* your code */

   F_UnlockGUI      /* Unlock the GUI */

   exit             /* And finish */

   Syntax:             
   Halt:

   F_UnlockGUI
   exit


   
 However, if a script leaves Fiasco locked, you may the following 
   script, which is also available in the file ARexx/UnlockGUI.rexx:
   
     /*
      * Fiasco will complain once, 
      * if ARexx-Debug is activated
      */

     address FIASCO

     do forever

         F_UnlockGUI

         if rc ~= 0 then break

     end

   


@{b}See also: @{ub}  @{"F_UnlockGUI" link f_unlockgui} 

@endnode 
@node f_makevirgin "F_MakeVirgin" 

@{b}@{u}F_MakeVirgin@{ub}@{uu}


@{b}Name: @{ub}  F_MakeVirgin -- Say Fiasco, that the current project is unchanged  

@{b}Synopsis: @{ub}  F_MakeVirgin  

@{b}Function: @{ub}  Pretends, that the current project is unchanged. This 
   prevents certain procedures (Erase, Load, Quit,...) to put up a 
   requester.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  A project, that thinks, it has not been changed since the last 
   saving.  

@{b}Note: @{ub}  The ARexx commands of Fiasco 1.1 provide direct arguments to 
   suppress these warnings. Because of that, this function has no real 
   meaning. It is recommended not to use this command, in order not to 
   confuse the user.  

@{b}See also: @{ub}  @{"F_IsVirgin" link F_IsVirgin}  

@endnode 


@node f_markallrecords "F_MarkAllRecords" 

@{b}@{u}F_MarkAllRecords@{ub}@{uu}


@{b}Name: @{ub}  F_MarkAllRecords -- Mark all Records  

@{b}Synopsis: @{ub}  F_MarkAllRecords  

@{b}Function: @{ub}  Marks all records in the current project. They will be 
   displayed highlighted in the list. Does exactly the same as 
   @{"Records/Mark All" Link mnmarkallrecords}.  

@{b}Inputs: @{ub}   

@{b}Results: @{ub}   

@{b}See also: @{ub}  @{"F_UnmarkAllRecords" link F_UnmarkAllRecords} @{"F_MarkRecord" link F_MarkRecord}  

@endnode 


@node f_markmatch "F_MarkMatch" 

@{b}@{u}F_MarkMatch@{ub}@{uu}


@{b}Name: @{ub}  F_MarkMatch -- Mark records, which match with a pattern  

@{b}Synopsis: @{ub}  F_MarkMatch Field/A, Blur/K, Pattern/F/A  

@{b}Function: @{ub}  Marks all records, which match with the given pattern in the 
   given field. Operates similar to the filter. F_MarkMatch clears the 
   marks of the records, which don`t match.  

@{b}Inputs: @{ub}  Field -- The ID of the field, which will be examined
   Blur -- Takes the blurfactor of the comparison. Specify only, if you 
   want to do blurred search.
   Pattern -- The pattern to search for.  

@{b}Results: @{ub}   

@{b}See also: @{ub}  @{"F_MarkRecord" link F_MarkRecord} @{"F_ToggleAllMarks" link F_ToggleAllMarks}  

@endnode 
@node f_markrecord "F_MarkRecord" 

@{b}@{u}F_MarkRecord@{ub}@{uu}


@{b}Name: @{ub}  F_MarkRecord -- Mark a record  

@{b}Synopsis: @{ub}  F_MarkRecord Record/N  

@{b}Function: @{ub}  Marks a record in the current project. It will be displayed 
   highlighted in the list.  This command may be also called in virtual 
   state. 

@{b}Inputs: @{ub}  Record/N -- Optional, if given the record specified by it`s 
   number will be marked. Otherwise, the current record will be marked.  

@{b}Results: @{ub}   

@{b}See also: @{ub}  @{"F_UnmarkRecord" link F_UnmarkRecord} @{"F_MarkAllRecords" link F_MarkAllRecords}  

@endnode 


@node f_newproject "F_NewProject" 

@{b}@{u}F_NewProject@{ub}@{uu}


@{b}Name: @{ub}  F_NewProject -- Open a new project window  

@{b}Synopsis: @{ub}  F_NewProject  

@{b}Function: @{ub}  Opens a new project. A new window is opened and activated. It 
   is then entirely empty. Does exactly the same as @{"Project/New" Link MnNew}.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}Bugs: @{ub}  Should claim on error.  

@{b}See also: @{ub}   

@endnode 


@node f_openlist "F_OpenList" 

@{b}@{u}F_OpenList@{ub}@{uu}


@{b}Name: @{ub}  F_OpenList -- Open the @{"list window" link list}  

@{b}Synopsis: @{ub}  F_OpenList  

@{b}Function: @{ub}  This command is equal to activating the menuitem @{"Control/List" Link MnListWindow}
   .  

@{b}Inputs: @{ub}   

@{b}Results: @{ub}   

@{b}See also: @{ub}  Control/List @{"F_CloseList" link F_CloseList}  

@endnode 


@node f_openproject "F_OpenProject" 

@{b}@{u}F_OpenProject@{ub}@{uu}


@{b}Name: @{ub}  F_OpenProject -- Load a project  

@{b}Synopsis: @{ub}  F_OpenProject File/A
   rc = @{i}Success@{ui}  

@{b}Function: @{ub}  Tries to read a fiasco project into the current project 
   window. The data, which are currently in the window will be freed 
   @{i}without any request@{ui}.  

@{b}Inputs: @{ub}  Name - Filename of the project  

@{b}Results: @{ub}  rc = 0, if everything went Ok,
   = 10, if argument is missing or file cannot be loaded.  

@{b}See also: @{ub}  @{"F_OpenProjectReq" link F_OpenProjectReq}  

@endnode 
@node f_openprojectreq "F_OpenProjectReq" 

@{b}@{u}F_OpenProjectReq@{ub}@{uu}


@{b}Name: @{ub}  F_OpenProjectReq -- Open the "Open Project" ASL requester  

@{b}Synopsis: @{ub}  F_OpenProjectReq  

@{b}Function: @{ub}  Does exactly the same as @{"Project/Open" Link MnOpen}. I`m too lazy to write 
   this here again. :-)  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}Note: @{ub}  The user may have canceled the request  

@{b}See also: @{ub}  @{"F_OpenProject" link F_OpenProject} @{"Project/Open" link MnOpen}  

@endnode 
@node f_openservicewin "F_OpenServiceWin" 

@{b}@{u}F_OpenServiceWin@{ub}@{uu}


@{b}Name: @{ub}  F_OpenServiceWin -- Open the service window  

@{b}Synopsis: @{ub}  F_OpenServiceWin  

@{b}Function: @{ub}  Opens the @{"service window" Link ServiceWin}, if it is not already open.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}See also: @{ub}  @{"F_CloseServiceWin" link F_CloseServiceWin }  

@endnode 


@node f_optionsreq "F_OptionsReq" 

@{b}@{u}F_OptionsReq@{ub}@{uu}


@{b}Name: @{ub}  F_OptionsReq -- Open the @{"options requester" Link RqOptions} for the current 
   project  

@{b}Synopsis: @{ub}  F_OptionsReq  

@{b}Function: @{ub}  Does exactly the same as @{"Project/Options" link MnOptions}  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}See also: @{ub}   

@endnode 


@node f_progress "F_Progress" 

@{b}@{u}F_Progress@{ub}@{uu}


@{b}Name: @{ub}  F_Progress -- give the user a sense of the duration of a 
   operation  

@{b}Synopsis: @{ub}  F_Progress Done/A/N, Max/A/N  

@{b}Function: @{ub}  Displays a nice progress bar in the service window, as known 
   of Sort or Open Project. You should reset the status gadget with 
   @{"F_ResetStatus" Link F_ResetStatus} when the operation has completed.  

@{b}Inputs: @{ub}  Done -- the number of data items currently processed. 
   Max -- the number of all data items.  

@{b}Results: @{ub}   

@{b}See also: @{ub}  @{"F_SetStatus" link F_SetStatus}  

@endnode 


@node f_quit "F_Quit" 

@{b}@{u}F_Quit@{ub}@{uu}


@{b}Name: @{ub}  F_Quit -- close the current project  

@{b}Synopsis: @{ub}  F_Quit Force/S  

@{b}Function: @{ub}  Closes the current project. If you do not specify Force, this 
   command does exactly the same as @{"Project/Quit" Link MnQuit}. That means, it is 
   possible, that a requester opens, which asks you whether you want to 
   save the current project before proceeding or cancel.  To prevent 
   this, specify the Force parameter. This will suppress all warnings. To 
   find out, wheter the project is not saved, you may use @{"F_IsVirgin" Link F_IsVirgin}.  

@{b}Inputs: @{ub}  Force -- suppress all warnings.  

@{b}Results: @{ub}  none  

@{b}Notes: @{ub}  If the current project is closed, another project will be 
   activated, or, if there is no other project, Fiasco will be shut down. 
   An ARexx script should not rely on the order, in which the next 
   project will be activated.  

@{b}See also: @{ub}   

@endnode 


@node f_remallrecords "F_RemAllRecords" 

@{b}@{u}F_RemAllRecords@{ub}@{uu}


@{b}Name: @{ub}  F_RemAllRecords -- Delete all records of project 

@{b}Synopsis: @{ub}  F_RemAllRecords Force/S 

@{b}Function: @{ub}  Removes all records of the current project. If you do not 
   specify the Force parameter, this command does exactly the same as 
   Record/Remove all. That means, that a requester may show up, which 
   will ask you, whether you really want to remove all records. To 
   prevent this behavior, specify Force.  This command may only be called 
   in record mode. 

@{b}Inputs: @{ub}  Force - suppress all warnings 

@{b}Results: @{ub}  A project without any records. 

@{b}See also: @{ub} 

@endnode 


@node f_remrecord "F_RemRecord" 

@{b}@{u}F_RemRecord@{ub}@{uu}


@{b}Name: @{ub}  F_RemRecord -- Delete the active record  

@{b}Synopsis: @{ub}  F_RemRecord Force/S  

@{b}Function: @{ub}  Removes the active record and activates the next. If you do 
   not specify the Force parameter, this command does exactly the same as 
   Record/Remove. That means, that a requester may show up, which will 
   ask you, whether you really want to remove this record. To prevent 
   this behavior, specify Force.  This function may only be called in 
   record mode.  

@{b}Inputs: @{ub}  Force -- suppress all warnings.  

@{b}Results: @{ub}  none  

@{b}See also: @{ub}  @{"F_AddRecord" link F_AddRecord}, @{"Record/Remove Record" link MnRemoveRecord}  

@endnode 


@node f_requestchoice "F_RequestChoice" 

@{b}@{u}F_RequestChoice@{ub}@{uu}


@{b}Name: @{ub}  F_RequestChoice -- request a choice 

@{b}Synopsis: @{ub}  F_RequestChoice Body/A,Gadgets/A,Title/K
   result = @{i}Selection@{ui} 

@{b}Function: @{ub}  Creates an intuition easy-requester with the specified 
   parameters. Works very similar to the CLI command Requestchoice. The 
   differences: Slightly different parameters, puts the requester up on 
   Fiasco's screen.  This command may be also called in virtual state. 

@{b}Inputs: @{ub}  Body - Main text of requester.
   Gadgets - Gadgets at the bottom of requester. Each choice must be 
   separated by a |.
   Title - Title of requester. 

@{b}Results: @{ub}  result - Number of selected gadget, 0 for the rightmost one. 

@{b}See also: @{ub} 

@endnode 


@node f_requestfile "F_RequestFile" 

@{b}@{u}F_RequestFile@{ub}@{uu}


@{b}Name: @{ub}  F_RequestFile -- request a file 

@{b}Synopsis: @{ub}  F_RequestFile File,Pattern/K,Title/K,Savemode/S,Drawersonly/S,
   Noicons/S 
   rc = @{i}Success@{ui}
   result = @{i}SelectedFile@{ui} 

@{b}Function: @{ub}  Puts up an ASL file requester. Works very similar to the CLI 
   command Requestfile. The differences: Slightly different parameters, 
   puts the requester up on Fiasco's screen.  This command may be also 
   called in virtual state. 

@{b}Inputs: @{ub}  File - Initial File including path for the requester
   Pattern - Initial Pattern
   Title - Title for the requester
   Savemode - Activates savemode: Black background, no selection via 
   doubleclick
   Drawersonly - Displays only Drawers 
   Noicons - Filters Icons 
   

@{b}Results: @{ub}  rc = 0, if user selected a file, otherwise user canceled.
   result = selected file, if rc = 0 

@{b}See also: @{ub} 

@endnode 


@node f_resetstatus "F_ResetStatus" 

@{b}@{u}F_ResetStatus@{ub}@{uu}


@{b}Name: @{ub}  F_ResetStatus -- restores the normal informations in the status 
   gadget  

@{b}Synopsis: @{ub}  F_ResetStatus  

@{b}Function: @{ub}  Sets the status gadget of the service window to the normal 
   contents. This is RecNum / AllRecs in the Record Mode or X / Y in the 
   mask mode. You should use this call to reset the status informations 
   set with @{"F_SetStatus" Link F_SetStatus}.  

@{b}Inputs: @{ub}   

@{b}Results: @{ub}   

@{b}See also: @{ub}   

@endnode 


@node f_saveproject "F_SaveProject" 

@{b}@{u}F_SaveProject@{ub}@{uu}


@{b}Name: @{ub}  F_SaveProject -- Save the current project  

@{b}Synopsis: @{ub}  F_SaveProject  

@{b}Function: @{ub}  Save the current project under the old name on disk. Does 
   exactly the same as @{"Project/Save" Link MnSave}.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}Bugs: @{ub}  Does not inform the script about errors.  

@{b}See also: @{ub}  @{"F_SaveProjectReq" link F_SaveProjectReq}  

@endnode 
@node f_saveprojectreq "F_SaveProjectReq" 

@{b}@{u}F_SaveProjectReq@{ub}@{uu}


@{b}Name: @{ub}  F_SaveProjectReq -- Open filereq and save project under new name  

@{b}Synopsis: @{ub}  F_SaveProjectReq  

@{b}Function: @{ub}  Does exactly the same as @{"Project/Save As..." Link MnSaveAs}.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}Note: @{ub}  The user may have canceled the request  

@{b}See also: @{ub}  @{"F_SaveProject" link F_SaveProject}  

@endnode 


@node f_savesettings "F_SaveSettings" 

@{b}@{u}F_SaveSettings@{ub}@{uu}


@{b}Name: @{ub}  F_SaveSettings -- Save the current program settings.  

@{b}Synopsis: @{ub}  F_SaveSettings  

@{b}Function: @{ub}  Does exactly the same as @{"Settings/Save Settings" Link MnSaveSettings}.  

@{b}Inputs: @{ub}  none  

@{b}Results: @{ub}  none  

@{b}See also: @{ub}  Settings/Save Settings  

@endnode 


@node f_selectproj "F_SelectProj" 

@{b}@{u}F_SelectProj@{ub}@{uu}


@{b}Name: @{ub}  F_SelectProj -- activate an already load project  

@{b}Synopsis: @{ub}  F_SelectProj Name/A
   rc = @{i}Success@{ui}  

@{b}Function: @{ub}  Activates a project, which stays already in memory. The 
   filename without path is used to identify the project. This may be the 
   name, which has been obtained using @{"F_GetProjName" Link F_GetProjName}. All following 
   commands refer to the new project.   

@{b}Inputs: @{ub}  Name - Name of project without path.  

@{b}Results: @{ub}  rc = 5, if project is already active. 
   = 10, if argument is missing, or there is no such project.  

@{b}See also: @{ub}  @{"F_GetProjName" link F_GetProjName}  

@endnode 


@node f_setfieldcont "F_SetFieldCont" 

@{b}@{u}F_SetFieldCont@{ub}@{uu}


@{b}Name: @{ub}  F_SetFieldCont -- Change the content of a field.  

@{b}Synopsis: @{ub}  F_SetFieldCont Field/A,Cont/A/F
   rc = @{i}Success@{ui}  

@{b}Function: @{ub}  Sets the content of the specified field in the active record 
   to the specified content.  May be only called in @{"record mode" link RecordMode}. This 
   command may be also called in virtual state. 

@{b}Inputs: @{ub}  Field - Identificationname of the field 
   Cont - New content of the Field. This arg takes the whole input 
   inclusive spaces. The Interpretation of this arg depends on the 
   fieldtype: 
   String - is copied directly 
   Integer - Numbers are read directly, other things are 0 
   Float - dto. 
   Boolean - 1 or TRUE = selected, 0 or FALSE = not selected 
   Slider - Number is read. Bad numbers will be adjusted. 
   Cycle - Number or name of label is taken. 
   Date - Date in Format DD.MM.[YY]YY is taken. 
   Time - Time in Format HH:MM:SS is taken. 
   Extern - is copied directly 
   Datat. - is copied directly 

@{b}Results: @{ub}  rc = 0 - no error 
   rc = 5 - no record is active 
   rc = 10 - missing arg or bad FieldId  

@{b}See also: @{ub}   

@endnode 


@node f_setmode "F_SetMode" 

@{b}@{u}F_SetMode@{ub}@{uu}


@{b}Name: @{ub}  F_SetMode -- Select the editing mode  

@{b}Synopsis: @{ub}  F_SetMode Mask/S, Records/S
   rc = @{i}Success@{ui}  

@{b}Function: @{ub}  Activates the specified mode for the current project.  

@{b}Inputs: @{ub}  Mask - activates @{"mask mode" link MaskMode}.
   Records - activates @{"record mode" link RecordMode}.
   Mask and Records are mutually exclusive.  

@{b}Results: @{ub}  rc = 0 - no error 
   = 5 - the project was already in the specified mode 
   = 10 - missing or bad arg  

@{b}See also: @{ub}   

@endnode 
@node f_setsearchfield "F_SetSearchField" 

@{b}@{u}F_SetSearchField@{ub}@{uu}


@{b}Name: @{ub}  F_SetSearchField -- Set the field to search  

@{b}Synopsis: @{ub}  F_SetSearchField Field/A
   rc = @{i}Success@{ui}  

@{b}Function: @{ub}  Sets the field, which will be searched by @{"F_FindFirst" link F_FindFirst} and 
   @{"F_FindNext" link F_FindNext}.  

@{b}Inputs: @{ub}  Field - The Id of the field, which shall be searched.  

@{b}Results: @{ub}  returns 10 in rc, if the argument is missing or the id is 
   unknown. otherwise 0 is returned.  

@{b}Notes: @{ub}  You don`t need this function for simple searching, because 
   Fiasco 1.1 allows passing these parameters directly with the search 
   functions.  

@{b}See also: @{ub}  @{"F_SetSearchPat" link F_SetSearchPat}  

@endnode 


@node f_setsearchpat "F_SetSearchPat" 

@{b}@{u}F_SetSearchPat@{ub}@{uu}


@{b}Name: @{ub}  F_SetSearchPat -- Set the pattern to search for  

@{b}Synopsis: @{ub}  F_SetSearchPat Pattern/A/F
   rc = @{i}Success@{ui}  

@{b}Function: @{ub}  Sets the searchpattern for the active project. If you also 
   have specified a search field using @{"F_SetSearchField" link F_SetSearchField}, you may search 
   for matching entries using @{"F_FindFirst" link F_FindFirst} and @{"F_FindNext" link F_FindNext}. The value 
   will be also used in the search requester.  

@{b}Inputs: @{ub}  searchpattern - a string to search for  

@{b}Results: @{ub}  rc = 0 - everything ok. 
   rc = 10 - no argument 
   rc = 20 - systemfailure (no memory, etc.) 
    

@{b}Notes: @{ub}  You don`t need this function for simple searching, because 
   Fiasco 1.1 allows passing these parameters directly with the search 
   functions.  

@{b}See also: @{ub}   

@endnode 


@node f_setstatus "F_SetStatus" 

@{b}@{u}F_SetStatus@{ub}@{uu}


@{b}Name: @{ub}  F_SetStatus -- display a status string to the user  

@{b}Synopsis: @{ub}  F_SetStatus String/A  

@{b}Function: @{ub}  Displays the given string in the status gadget of the 
   @{"service window" Link ServiceWin}. If the service window is not open, nothing will be 
   done.  

@{b}Inputs: @{ub}  String -- the string to be displayed  

@{b}Results: @{ub}   

@{b}See also: @{ub}  @{"F_ResetStatus" link F_ResetStatus}  

@endnode 


@node f_sort "F_Sort" 

@{b}@{u}F_Sort@{ub}@{uu}


@{b}Name: @{ub}  F_Sort -- Sort the records of the current project  

@{b}Synopsis: @{ub}  F_Sort Field/A,Descending/S  

@{b}Function: @{ub}  Sorts the records of the current project according to the 
   alphabetical or equivalent priority of the contents of a specified 
   field.  

@{b}Inputs: @{ub}  Field -- The ID of a field to sort after
   Descending -- Specify this, if you want the sorting to be backwards.  

@{b}Results: @{ub}   

@{b}See also: @{ub}  @{"F_SortReq" link F_SortReq}, @{"Compare/Sort" link MnSort}  

@endnode 
@node f_sortreq "F_SortReq" 

@{b}@{u}F_SortReq@{ub}@{uu}


@{b}Name: @{ub}  F_SortReq -- Open the sort requester  

@{b}Synopsis: @{ub}  F_SortReq  

@{b}Function: @{ub}  Does exactly the same as @{"Compare/Sort" Link MnSort}. May be only called in 
   record mode.  

@{b}Inputs: @{ub}   

@{b}Results: @{ub}   

@{b}See also: @{ub}  Compare/Sort...  

@endnode 


@node f_toggleallmarks "F_ToggleAllMarks" 

@{b}@{u}F_ToggleAllMarks@{ub}@{uu}


@{b}Name: @{ub}  F_ToggleAllMarks -- toggle the marks of all records.  

@{b}Synopsis: @{ub}  F_ToggleAllMarks  

@{b}Function: @{ub}  Clears the marks on records, which were marked and sets the 
   marks on previously unmarked records. Does exactly the same as 
   @{"Records/Toggle All Marks" Link mntoggleallmarks}.  

@{b}Inputs: @{ub}   

@{b}Results: @{ub}   

@{b}See also: @{ub}  @{"F_MarkRecord" link F_MarkRecord}  

@endnode 


@node f_unlockgui "F_UnlockGUI" 

@{b}@{u}F_UnlockGUI@{ub}@{uu}


@{b}Name: @{ub}  F_UnlockGUI -- Unlock the GUI of Fiasco 

@{b}Synopsis: @{ub}  F_UnlockGUI
   rc = @{i}Success@{ui} 

@{b}Function: @{ub}  Unlock the GUI, which has been previously locked using 
   @{"F_LockGUI" Link F_lockgui}. The user has again access to Fiasco. F_LockGUI and 
   F_UnlockGUI may be nested. 

@{b}Inputs: @{ub}  none 

@{b}Results: @{ub}  rc not equal 0, if no lock was present. 

@{b}See also:  @{ub}  @{"F_LockGUI" link f_lockgui} 

