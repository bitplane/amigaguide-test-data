	GUI  = @{" GFXUSERINTERFACE " LINK Option_GFXUSERINTERFACE}/S,
	API  = @{" APPICON          " LINK Option_APPICON}/S,
	L    = @{" LOOP             " LINK Option_LOOP}/S,
	D    = @{" DEFAULTS         " LINK Option_DEFAULTS}/S, ND   = @{" NODEFAULTS       " LINK Option_DEFAULTS}/S,
	S    = @{" SCREEN           " LINK Option_SCREEN}/S, NS   = @{" NOSCREEN         " LINK Option_SCREEN}/S,
	V    = @{" VISIBLE          " LINK Option_VISIBLE}/S, NV   = @{" INVISIBLE        " LINK Option_VISIBLE}/S,
	C    = @{" CACHE            " LINK Option_CACHE}/S, NC   = @{" NOCACHE          " LINK Option_CACHE}/S,
	IC   = @{" INSTCACHE        " LINK Option_INSTCACHE}/S, NIC  = @{" NOINSTCACHE      " LINK Option_INSTCACHE}/S,
	DC   = @{" DATACACHE        " LINK Option_DATACACHE}/S, NDC  = @{" NODATACACHE      " LINK Option_DATACACHE}/S,
	B    = @{" BURST            " LINK Option_BURST}/S, NB   = @{" NOBURST          " LINK Option_BURST}/S,
	IB   = @{" INSTBURST        " LINK Option_INSTBURST}/S, NIB  = @{" NOINSTBURST      " LINK Option_INSTBURST}/S,
	DB   = @{" DATABURST        " LINK Option_DATABURST}/S, NDB  = @{" NODATABURST      " LINK Option_DATABURST}/S,
	CB   = @{" COPYBACK         " LINK Option_COPYBACK}/S, NCB  = @{" NOCOPYBACK       " LINK Option_COPYBACK}/S,
	EC   = @{" EXTERNALCACHE    " LINK Option_EXTERNALCACHE}/S, NEC  = @{" NOEXTERNALCACHE  " LINK Option_EXTERNALCACHE}/S,
	VBR  = @{" VBRTOFAST        " LINK Option_VBR}/S, NVBR = @{" VBRTO0           " LINK Option_VBR}/S,
	APN  = @{" APPEND           " LINK Option_APPEND}/S, NAPN = @{" NOAPPEND         " LINK Option_APPEND}/S,
