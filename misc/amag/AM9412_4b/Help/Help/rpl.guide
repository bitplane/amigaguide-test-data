WORD

  C_COORDSYS

TEMPLATE

  Vorigin
  Vx
  Vy
  Vz
  bR bG bB bA
  sName
  iAttr
  TagList
  C_COORDSYS aObject

@EndNode


@Node "C_CUBE"

WORD

  C_CUBE

TEMPLATE

  Vvertex0
  Vvertex1
  Vvertex2
  Vdvect
  bR bG bB bA
  sName
  iAttr
  TagList
  C_CUBE aObject

EXAMPLE

  ( create a cube animated by )
  ( a RPL method MethodWord   )
  2.00    3.01    0.00   ( first vertex )
  3.01    3.01    0.00   ( second vertex )
  2.00    2.00    0.00   ( third vertex )
  0.00    0.00    1.00   ( dvect )
  255 255 255 0  ( RGBA )
  "cube"     ( name )
  0          ( attr )
  "CEND"
  "RPL" "SMTH"
  "MethodWord" "SRPL" ( See MTH_CREATE example )
  C_CUBE DROP

@EndNode


@Node "C_CUTCONE"

WORD

  C_CUTCONE

TEMPLATE

  Vcentre
  Va
  Vb
  Vaxis
  Vp1
  Vm1
  Vn1
  Vp2
  Vm2
  Vn2
  [fStAngle fEnAngle]
  iR iB iG iA
  sName
  iAttr
  TagList
  C_CUTCONE aObject

EXAMPLE

  ( create a sectored cut-cone )
  ( surface )
 -2.51   -0.50    2.50   ( center )
  0.50    0.00    0.00   ( a )
  0.00    0.50    0.00   ( b )
  0.00    0.00   -1.50   ( axis )
  ( first bounding plane )
 -2.51   -0.50    1.00   ( p1 )
  0.00    1.00    0.00   ( m1 )
  1.00    0.00    0.00   ( n1 )
  ( second bounding plane )
 -2.51   -0.50    2.00   ( p2 )
  0.00    1.00    0.00   ( m2 )
  1.00    0.00    0.00   ( n2 )
  0.00    4.71   ( angles )
  255 255 255 0  ( RGBA )
  "cutcone"      ( name )
  lOF_SECTOR     ( attr: sector )
  "CEND"
  C_CUTCONE DROP

@EndNode


@Node "C_CUTPOLYMID"

WORD

