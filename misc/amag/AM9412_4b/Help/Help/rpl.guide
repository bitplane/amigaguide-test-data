@Node "C_CONE"

WORD

  C_CONE

TEMPLATE

  Vapex
  Va
  Vb
  Vaxis
  Vp
  Vm
  Vn
  [fStAngle fEnAngle]
  iR iB iG iA
  sName
  iAttr
  TagList
  C_CONE aObject

EXAMPLE

  ( surface )
  1.50    1.50    2.00   ( center )
  0.50    0.00    0.00   ( a )
  0.00    0.50    0.00   ( b )
  0.00    0.00   -1.00   ( c )
  ( bounding plane )
  1.50    1.50    1.00   ( p )
  0.00    0.50    0.00   ( m )
  0.50    0.00    0.00   ( n )
  255 255 255 0  ( RGBA )
  "cone"         ( name )
  0              ( attr )
  "CEND"         ( tags )
  C_CONE DROP

@EndNode


