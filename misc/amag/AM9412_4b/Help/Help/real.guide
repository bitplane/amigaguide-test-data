        e       - kinetic energy
        t, u, v - current time
        fx, fy, fz - birth day
        l       - boolean value for deletion/creation
@EndNode

@Node "PROCESSOR"

PROCESSOR

    SYNTAX

              Level
             /    \
        Targets  Level(M)


    VARIABLES

