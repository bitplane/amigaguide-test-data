                  #868 offsets in Hunk #0
               hunk_end (o: $2236C,#140140 t: $3F2,#1010)
          
               hunk_bss (o: $22370,#140144 t: $3EB,#1003)
                 Size: $4, #4 (MEMF_FAST)
               hunk_end (o: $22378,#140152 t: $3F2,#1010)


