 -------------------------
     @{" ADDRESS             " LINK "ADDRESS"} - [ [<název portu> [<pęíkazový výraz>]] | [[VALUE] Výraz] ]
     @{" ARG                 " LINK "ARG"} - <@{" îablona " LINK Îablony}>

@{B}@{FG HighLight} B@{UB}@{FG Text}
 -------------------------
     @{" BREAK               " LINK "BREAK"}  

