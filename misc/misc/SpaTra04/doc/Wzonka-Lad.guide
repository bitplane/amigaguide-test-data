@node "mappers" "Tipos de cartuchos soportados"
@toc "main"

  Lista de tipos de cartuchos existentes:

          0 - Sµlo ROM                12 - ROM+MBC3+RAM
          1 - ROM+MBC1                13 - ROM+MBC3+RAM+BAT
          2 - ROM+MBC1+RAM            19 - ROM+MBC5
          3 - ROM+MBC1+RAM+BAT        1A - ROM+MBC5+RAM
          5 - ROM+MBC                 1B - ROM+MBC5+RAM+BAT
          6 - ROM+MBC2+BAT            1C x ROM+MBC5+RUMBLE
          8 - ROM+RAM                 1D x ROM+MBC5+RUMBLE+SRAM
          9 - ROM+RAM+BAT             1E x ROM+MBC5+RUMBLE+SRAM+BAT
          B * ROM+MMM01               1F * CÃmara de bolsillo
          C * ROM+MMM01+SRAM          FD * Bandai TAMA5
          D * ROM+MMM01+SRAM+BAT      FE * Hudson HuC-3
          F * ROM+MBC3+TEMP+BAT       FF x Hudson HuC-1
         10 * ROM+MBC3+TEMP+RAM+BAT
         11 - ROM+MBC3

               * =  No soportados por Wzonka-Lad (aºn)
               x =  Soporte parcial (mÃs o menos)
             BAT =  Memoria de RAM estÃtica mantenida con baterÚa
            TEMP =  Temporizador (@{i}TIMER@{ui})
@endnode
