   NOMBRE
      PM_AlterState -- Simula la (de-)selección de
                       la marca de verificación de un ítem
                       (disponible a partir de la versión 5).

   Continuará...
   (algún día, porque por ahora no creo que necesite esta función)
@endnode
------------------------------------------------------------------------------
@node macros "Ejemplos de macros"

 struct PopupMenu *menu;

 @{b}/* Creando un menú con macros... */@{ub}

 menu = PMMenu("Título del menú"),
        End;

 @{b}/* Creando un menú como el anterior, pero con ítems... */@{ub}

 menu = PMMenu("Título del menú"),
               PMItem("Item del texto"),
                          @{b}/* Etiquetas de atributos para el ítem */@{ub}
               End,
               PMItem("Ítem de texto (2)"),
                          @{b}/* Etiquetas de atributos para el ítem */@{ub}
               End,
        End;

 @{b}/* Creando un submenú para un ítem... */@{ub}

 menu = PMMenu("Título del menú"),
               PMItem("Ítem con submenú"),
                      PMSimpleSub,
                                   @{b}/* Aquí irían los ítems... */@{ub}
                      End,
               End,
        End;

 @{b}/* Creando una lista de IDentificadores excluyentes para PM_Exclude */@{ub}
 @{b}/* Pudiendo realizarse de esta primera forma... */@{ub}

        PM_Exclude,
                PMExl   ExID(1),
                        ExID(2),
        End,

 @{b}/* O pudiendo realizarse de esta segunda forma... */@{ub}

        PM_Exclude, PM_ExLst(1, 2, 3, 0), End,
@endnode
