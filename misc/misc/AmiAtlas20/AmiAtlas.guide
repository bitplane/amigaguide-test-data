@node MENU_EXTRAS "Extras-Menu"
   @{b}Extras-Menu@{ub}

      @{"  Extras->Kartendetails      " link MENU_EXTRAS_DETAILS}    @{"  Extras->Workbench              " link MENU_EXTRAS_WORKBENCH}
      @{"  Extras->Geschwindigkeiten  " link MENU_EXTRAS_SPEED}    @{"  Extras->Bildschirmmodus        " link MENU_EXTRAS_SCREEN}
      @{"  Extras->Zeichensätze       " link MENU_EXTRAS_FONTS}    @{"  Extras->Karte neu zeichnen     " link MENU_EXTRAS_REDRAW}
      @{"  Extras->Farben             " link MENU_EXTRAS_COLORS}    @{"  Extras->Ikonifizieren          " link MENU_EXTRAS_ICONIFY}
      @{"  Extras->Verschiedenes      " link MENU_EXTRAS_MISC}    @{"  Extras->Einstellung speichern  " link MENU_EXTRAS_SAVE_CONFIG}


   Im Extras-Menu stehen alle Möglichkeiten der freien Konfiguration
   von 'AmiAtlas Pro' zur Verfügung. Sämtliche Einstellungen werden in
