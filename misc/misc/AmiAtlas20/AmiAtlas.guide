      @{"  Suchen->Bundesland    " link MENU_SEARCH_STATE}    @{"  Suchen->Position merken  " link MENU_SEARCH_MEM_POS}
      @{"  Suchen->Kennzeichen   " link MENU_SEARCH_CARID}    @{"  Suchen->Alte Position    " link MENU_SEARCH_OLD_POS}


