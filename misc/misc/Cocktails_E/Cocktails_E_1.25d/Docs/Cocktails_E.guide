@TOC "Sommaire"

@{b}VI  Technical notes.@{ub}


	1) @{"On program" LINK "Sur le programme"}
	2) @{"On cocktails" LINK "Sur les cocktails"}

		       |
		       |->  @{"Recipes preparation" LINK "Sur les cocktails"9}
