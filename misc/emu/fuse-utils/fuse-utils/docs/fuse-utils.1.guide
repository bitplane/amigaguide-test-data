@{i}audio2tape@{ui}(1), @{i}createhdf@{ui}(1), @{i}fuse@{ui}(1), @{i}libspectrum@{ui}(3), @{i}listbasic@{ui}(1), @{i}raw2hdf@{ui}(1), @{i}rzxcheck@{ui}(1), @{i}rzxdump@{ui}(1), @{i}rzxtool@{ui}(1), @{i}scl2trd@{ui}(1), @{i}snap2tzx@{ui}(1), @{i}snapconv@{ui}(1), @{i}tape2wav@{ui}(1), @{i}tapeconv@{ui}(1), @{i}tzxlist@{ui}(1), @{i}xspect@{ui}(1), @{i}xzx@{ui}(1) The comp.sys.sinclair Spectrum FAQ, at 
