@database snap2tzx
@master "snap2tzx.1"
@remark "manual page source format generated by PolyglotMan v3.2 available at http://polyglotman.sourceforge.net/"
@wordwrap
@tab 8
   
@node sect0 "Name"
snap2tzx - Convert ZX Spectrum snapshot to .tzx tape images    
@endnode

@node sect1 "Synopsis"
 @{b}snap2tzx@{ub} [-1 @{i}string@{ui}]@{i}@{ui} [-2 @{i}string@{ui}]@{i}@{ui} [-b @{i}colour@{ui}]@{i}@{ui} [-g @{i}string@{ui}]@{i}@{ui} [-l @{i}string@{ui}]@{i}@{ui} [-o @{i}filename@{ui}]@{i}@{ui} [-r] [-s @{i}speed@{ui}]@{i}@{ui} [-v] [-$ @{i}filename@{ui}]@{i}@{ui} @{i}snapshot@{ui}     


@endnode

@node sect2 "Description"
snap2tzx converts a ZX Spectrum snapshot into a .tzx tape image.    
@endnode

@node sect3 "Options"


· -1 @{i}string@{ui} @{lindent 3}
causes @{i}string@{ui} (which has a maximum of 32 characters) to be shown while loading. @{lindent 0}

· -2 @{i}string@{ui} @{lindent 3}
causes @{i}string@{ui} (maximum 32 characters) to also be shown while loading. @{lindent 0}

· -b @{i}colour@{ui} @{lindent 3}
specifies the border colour while loading. @{lindent 0}

· -g @{i}string@{ui} @{lindent 3}
causes @{i}string@{ui} (maximum 32 characters) to be used as the game name while loading. @{lindent 0}

· -l @{i}string@{ui} @{lindent 3}
causes @{i}string@{ui} (maximum 8 characters) to be used as the BASIC filename in the loader. @{lindent 0}

· -o @{i}filename@{ui} @{lindent 3}
causes the output to be sent to @{i}filename@{ui}. @{lindent 0}

· -r @{lindent 3}
causes the final line of attribute data in the loading screen to be bright. @{lindent 0}

· -s @{i}speed@{ui} @{lindent 3}
specifies the speed of the loader; available values for @{i}speed@{ui} are 0 (1500 bps), 1 (2250 bps), 2 (3000 bps) and 3 (6000 bps). @{lindent 0}

· -v @{lindent 3}
specifies verbose output. @{lindent 0}

· -$ @{i}filename@{ui} @{lindent 3}
specifies that the ZX Spectrum screen stored in @{i}filename@{ui} should be used as the loading screen. @{lindent 0}

· @{i}snapshot@{ui} @{lindent 3}
specifies the snapshot (in a format supported by @{i}libspectrum@{ui}(3)) to be converted. @{lindent 0}

In any @{i}string@{ui} parameter, the tilde (~) will be converted into a copyright symbol.    


@endnode

@node sect4 "Bugs"
None known.    
@endnode

@node sect5 "See Also"
@{i}fuse@{ui}(1), @{i}fuse-utils@{ui}(1), @{i}libspectrum@{ui}(3), @{i}listbasic@{ui}(1), @{i}snapconv@{ui}(1) The comp.sys.sinclair Spectrum FAQ, at 
@{i}http://www.worldofspectrum.org/faq/index.html@{ui}.    


@endnode

@node sect6 "Author"
Philip Kendall (philip-fuse@shadowmagic.org.uk). Tomaz Kac wrote @{i}z802tzx@{ui} (@{i}ftp://ftp.worldofspectrum.org/pub/sinclair/tools/unix/z802tzx-1.2.tar.gz@{ui}), on which  @{i}snap2tzx@{ui} is very heavily based. 

Martijn van der Heide wrote the turbo-loading code, originally for @{i}Taper @{ui}(@{i}http://www.worldofspectrum.org/taper.html@{ui}). 


@endnode
