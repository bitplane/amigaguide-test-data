@database scl2trd
@master "scl2trd.1"
@remark "manual page source format generated by PolyglotMan v3.2 available at http://polyglotman.sourceforge.net/"
@wordwrap
@tab 8
   
@node sect0 "Name"
scl2trd - Convert .scl disk images to .trd.    
@endnode

@node sect1 "Synopsis"
 @{b}scl2trd@{ub} @{i}sclfile@{ui} "trdfile"     


@endnode

@node sect2 "Description"
scl2trd converts a .scl disk file to a 80 track, double sided (640 KB) .trd disk file.    
@endnode

@node sect3 "Options"


· @{i}sclfile@{ui} @{lindent 3}
specifies a .scl file whose contents are to be converted. @{lindent 0}

· @{i}trdfile@{ui} @{lindent 3}
specifies a .trd file to create.    @{lindent 0}


@endnode

@node sect4 "Bugs"
None known.    
@endnode

@node sect5 "See Also"
@{i}fuse@{ui}(1), @{i}fuse-utils@{ui}(1) The comp.sys.sinclair Spectrum FAQ, at 
@{i}http://www.worldofspectrum.org/faq/index.html@{ui}.    


@endnode

@node sect6 "Author"
Philip Kendall (philip-fuse@shadowmagic.org.uk). Dmitry Sanarin's conversion routines from his Glukalka emulator are used. 


@endnode
