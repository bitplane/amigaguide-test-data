@database rzxdump
@master "rzxdump.1"
@remark "manual page source format generated by PolyglotMan v3.2 available at http://polyglotman.sourceforge.net/"
@wordwrap
@tab 8
   
@node sect0 "Name"
rzxdump - List contents of Sinclair ZX Spectrum input recording files    
@endnode

@node sect1 "Synopsis"
 @{b}rzxdump@{ub} @{i}rzxfile@{ui}...     


@endnode

@node sect2 "Description"
rzxdump outputs a description of the contents of RZX input recording files.    
@endnode

@node sect3 "Options"


· @{i}rzxfile@{ui} @{lindent 3}
specifies an input recording file whose contents are to be listed.    @{lindent 0}


@endnode

@node sect4 "Bugs"
The contents of compressed blocks are not displayed with in a useful fashion.    
@endnode

@node sect5 "See Also"
@{i}fuse@{ui}(1), @{i}fuse-utils@{ui}(1), @{i}rzxcheck@{ui}(1), @{i}rzxtool@{ui}(1) The comp.sys.sinclair Spectrum FAQ, at 
@{i}http://www.worldofspectrum.org/faq/index.html@{ui}.    


@endnode

@node sect6 "Author"
Philip Kendall (philip-fuse@shadowmagic.org.uk). 
@endnode
