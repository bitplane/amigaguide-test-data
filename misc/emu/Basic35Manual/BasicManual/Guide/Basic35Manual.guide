         08      -                           @{"61      FILE NOT OPEN           " link "61_FILE_NOT_OPEN" 0}
         09      -                           @{"52      FILE TOO LARGE          " link "52_FILE_TOO_LARGE" 0}
         10      -                           @{"64      FILE TYPE MISMATCH      " link "64_FILE_TYPE_MISMATCH" 0}
         11      -                           @{"67      ILLEGAL SYSTEM T OR S   " link "67_ILLEGAL_SYSTEM_T_OR_S" 0}
         12      -                           @{"66      ILLEGAL TRACK AND SECTOR" link "66_ILLEGAL_TRACK_AND_SECTOR" 0}
         13      -                           @{"65      NO BLOCK                " link "65_NO_BLOCK" 0}
         14      -                           @{"70      NO CHANNEL              " link "70_NO_CHANNEL" 0}
         15      -                           @{"51      OVERFLOW IN RECORD      " link "51_OVERFLOW_IN_RECORD" 0}
         16      -                           @{"20      READ ERROR              " link "20_READ_ERROR" 0}
