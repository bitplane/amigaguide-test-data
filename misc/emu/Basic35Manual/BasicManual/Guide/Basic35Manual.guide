         #A     784              784               466.2
          H     798              798               493.9
         --------------------------------------------------------
          C     810              810               523.3
         #C     822              822               554.4
          D     834              834               587.4
         #D     844              844               622.3
          E     854              854               659.3
          F     864              864               698.5
         #F     873              873               740.0
          G     881              881               784.0
