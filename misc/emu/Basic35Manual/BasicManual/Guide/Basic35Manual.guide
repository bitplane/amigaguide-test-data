 DESCRIPTION
     The program on tape or disk does not match the program in memory.
@endnode

@node "29_LOAD" "29_LOAD"
 basic_error/29_LOAD                                         basic_error/29_LOAD
 
 NUMBER
     29

 MESSAGE
     LOAD

 DESCRIPTION
     There was a problem loading. Try again.
@endnode

@node "30_BREAK" "30_BREAK"
 basic_error/30_BREAK                                       basic_error/30_BREAK
 
 NUMBER
     30

 MESSAGE
     BREAK

