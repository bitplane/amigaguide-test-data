@DATABASE "Zombies"
@NODE "MAIN" "SPECCY POKES - Z - Zombies"
@TOC "MAIN"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/z/ZOMBIES.SNA|N > T:NIL"} ... retro:games/spectrum/z/ZOMBIES.SNA
@{"RUN GAME            " rxs "zxamrun()"}

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - Z@{uu}


                                  @{B}@{U}Zombies@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives Pl1" RXS "ADDRESS COMMAND ZXAMPoke(29553,0)"}      29553,0
@{"Infinite Lives Pl2" RXS "ADDRESS COMMAND ZXAMPoke(29565,0)"}      29565,0
@{"Lives Pl1 & 2 = x " RXS "ADDRESS COMMAND ZXAMPoke(30146,255)"}      30146,x (x= 1-255). Click to set to 255
@endnode
