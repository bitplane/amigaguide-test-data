                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - C@{uu}


                                  @{u}@{b}Cop Out@{uu}@{ub}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(35370,0)"}          35370,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(32817,254) zxampoke(35390,254)"}          32817,x:35390,x:Lives = x (x= 1-254). Click to set to 254


