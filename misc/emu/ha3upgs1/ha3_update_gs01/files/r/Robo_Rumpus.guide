@DATABASE "Robo_Rumpus"
@NODE "MAIN" "SPECCY POKES - R - Robo Rumpus"
@{"LOAD FROM SPECCY SENSATIONS 2" system "rx rexx:zxam_run.rexx speccy2:games/r/RUMPUS.SNA|N > T:NIL"} ... speccy2:games/R/RUMPUS.SNA
@{"LOAD FROM RETRO GOLD         " system "rx rexx:zxam_run.rexx retro:games/spectrum/r/RUMPUS.SNA|N > T:NIL"} ... retro:games/spectrum/r/RUMPUS.SNA
@{"RUN GAME                     " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - R@{uu}


                                @{B}@{U}Robo Rumpus@{UB}@{UU}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(50950,0)"}          50950,0
@endnode
