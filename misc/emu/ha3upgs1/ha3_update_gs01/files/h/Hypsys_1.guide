@DATABASE "Hypsys_Part_1"
@NODE "MAIN" "SPECCY POKES - H - Hypsys Part 1"
@{"LOAD FROM SPECCY SENSATIONS 2" system "rx rexx:zxam_run.rexx speccy2:games/h/hypsys/hypsys1.SNA|N > T:NIL"} ... speccy2:games/h/hypsys/HYPSYS1.sna
@{"RUN GAME                     " rxs "zxamrun()"}
@TOC "MAIN"


                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - G@{uu}


                               @{U}@{B}Hypsys Part 1@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}

            
@{"Infinite Energy    " RXS "ADDRESS COMMAND ZXAMPoke(54199,0)"}     54199,0
@{"Infinite Ammo      " RXS "ADDRESS COMMAND ZXAMPoke(54260,182)"}     54260,182
@{"Immune To Big Ships" RXS "ADDRESS COMMAND ZXAMPoke(54108,201)"}     54108,201
@endnode
