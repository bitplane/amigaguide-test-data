@DATABASE "A_Team"
@NODE "MAIN" "SPECCY POKES - A - A Team (The)"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/a/a_team2.SNA|N > T:NIL"} ... retro:games/spectrum/a/A_TEAM2.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"


                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - A@{uu}


                               @{u}@{b}A Team (The)@{uu}@{ub}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}

            
@{"Infinite Energy" RXS "ADDRESS COMMAND ZXAMPoke(26419,42)"}         26419,42
@{"Infinite Ammo  " RXS "ADDRESS COMMAND ZXAMPoke(26379,0)"}         26379,0
@{"Infinite Clips " RXS "ADDRESS COMMAND ZXAMPoke(26391,0)"}         26391,0
@{"Infinite Bombs " RXS "ADDRESS COMMAND ZXAMPoke(26318,0)"}         26318,0
@{"Only 1 Enemy   " RXS "ADDRESS COMMAND ZXAMPoke(26337,98)"}         26337,98
@{"Only 1 Jeep    " RXS "ADDRESS COMMAND ZXAMPoke(26359,175)"}         26359,175
@{"Enemy = x      " RXS "ADDRESS COMMAND ZXAMPoke(24882,10)"}         24882,x (x= 1-255). Click to set to 10
@{"Clips = x      " RXS "ADDRESS COMMAND ZXAMPoke(24913,255)"}         24913,x (x= 1-255). Click to set to 255
@{"Jeeps = x      " RXS "ADDRESS COMMAND ZXAMPoke(24887,2)"}         24887,x (x= 1-255). Click to set to 2
@{"Bombs = x      " RXS "ADDRESS COMMAND ZXAMPoke(24923,255)"}         24923,x (x= 1-255). Click to set to 255
@{"Ammo  = x      " RXS "ADDRESS COMMAND ZXAMPoke(24918,255) zxampoke(26396,255) zxampoke(26449,255)"}         24918,x:26396,x:26449,x (x= 1-255). Click to set to 255
@endnode
