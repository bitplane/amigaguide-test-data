@DATABASE "Nifty_Lifty"
@NODE "MAIN" "SPECCY POKES - N - Nifty Lifty"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/n/NIFLIFT.SNA|N > T:NIL"} ... retro:games/spectrum/N/NIFLIFT.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - N@{uu}


                                @{U}@{B}Nifty Lifty@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(43526,0) zxampoke(50526,0)"}          43526,0:50526,0
@{"Infinite Time " RXS "ADDRESS COMMAND ZXAMPoke(42877,0)"}          42877,0
@endnode
