@DATABASE "Gonzalezzzzz_Part_1"
@NODE "MAIN" "SPECCY POKES - G - Gonzalezzzz Part 1"
@{"LOAD FROM SPECCY SENSATIONS 2" system "rx rexx:zxam_run.rexx speccy2:games/g/gonzza/gonzza1.SNA|N > T:NIL"} ... speccy2:games/g/gonzza/GONZZA1.sna
@{"RUN GAME                     " rxs "zxamrun()"}
@TOC "MAIN"


                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - G@{uu}


                            @{U}@{B}Gonzalezzzz Part 1@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}

            
@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(32382,0)"}          32382,0
@{"Infinite Time " RXS "ADDRESS COMMAND ZXAMPoke(37693,0)"}          37693,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(31890,128)"}          31890,x (x= 1-128). Click to set to 128
@endnode
