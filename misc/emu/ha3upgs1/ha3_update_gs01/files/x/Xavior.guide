@DATABASE "Xavior"
@NODE "MAIN" "SPECCY POKES - X - Xavior"
@TOC "MAIN"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/x/XAVIOR.SNA|N > T:NIL"} ... retro:games/spectrum/x/XAVIOR.SNA
@{"RUN GAME            " rxs "zxamrun()"}

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - X@{uu}


                                  @{B}@{U}Xavior@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(62481,0)"}          62481,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(62931,255)"}          62931,x (x= 1-255). Click to set to 255
@endnode
