@DATABASE "Barmy_Burgers"
@NODE "MAIN" "SPECCY POKES - B - Barmy Burgers"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/b/barmy_bu.SNA|N > t:NIL"} ... retro:games/spectrum/b/BARMY_BU.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"


                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - B@{uu}


                               @{u}@{b}Barmy Burgers@{uu}@{ub}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}

            
@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(58654,0)"}          58654,0
@{"Infinite Spray" RXS "ADDRESS COMMAND ZXAMPoke(56543,0)"}          56543,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(43721,255)"}          43721,x (x= 1-255). Click to set to 255
@endnode
