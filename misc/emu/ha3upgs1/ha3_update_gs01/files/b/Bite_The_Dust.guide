@DATABASE "Bite_The_Dust"
@NODE "MAIN" "SPECCY POKES - B - Bite_The_Dust"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/b/bite.SNA|N > T:NIL"} ... retro:games/spectrum/b/BITE.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"


                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - B@{uu}


                               @{b}@{u}Bite The Dust@{uu}@{ub}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}

            
@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(35934,0)"}          35934,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(39257,255)"}          39257,x (x= 1-255). Click to set to 255
@endnode
