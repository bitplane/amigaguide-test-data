@DATABASE "Future Bike Sim"
@NODE "MAIN" "SPECCY POKES - F - Future Bike Sim"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - F
                   ====================================

                              Future Bike Sim
                              ===============


DESCRIPTION              POKE
===========              ====

@{"Immunity       " RXS "ADDRESS COMMAND ZXAMPoke(43472,255)"}         43472,255
@{"Infinite Lives " RXS "ADDRESS COMMAND ZXAMPoke(38528,182)"}         38528,182
@{"Infinite Smarts" RXS "ADDRESS COMMAND ZXAMPoke(37986,0)"}         37986,0
@{"Radar Activated" RXS "ADDRESS COMMAND ZXAMPoke(43548,255)"}         43548,255
@{"Lives = x      " RXS "ADDRESS COMMAND ZXAMPOKE(23908,255) zxampoke(23975,255)"}         23908,x:23975,x (x= 1-255)
@{"Smarts = x     " RXS "ADDRESS COMMAND ZXAMPOKE(23909,255) zxampoke(23980,255)"}         23909,x:23980,x (x= 1-255)


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).


                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode
