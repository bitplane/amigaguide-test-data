@DATABASE "Flying Shark"
@NODE "MAIN" "SPECCY POKES - F - Flying Shark"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - F
                   ====================================

                               Flying Shark
                               ============


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives " RXS "ADDRESS COMMAND ZXAMPoke(54462,201)"}         54462,201
@{"Infinite Smarts" RXS "ADDRESS COMMAND ZXAMPoke(54379,3)"}         54379,3
@{"No Enemies     " RXS "ADDRESS COMMAND ZXAMPoke(51631,201)"}         51631,201
@{"Everything dies" RXS "ADDRESS COMMAND ZXAMPoke(48082,201)"}         48082,201
@{"Immunity       " RXS "ADDRESS COMMAND ZXAMPoke(48114,0) ZXAMPoke(48115,1)"}         48114,0:48115,0
@{"Lives = x      " RXS "ADDRESS COMMAND ZXAMPoke(42464,255)"}         42464,x (x= 1-255)
@{"Bombs = x      " RXS "ADDRESS COMMAND ZXAMPoke(42490,255)"}         42490,x (x= 1-255)

                         I haven't tested this one as the game crashes
                         on the emulator. Handy that!
                                                        Rastan
@endnode
