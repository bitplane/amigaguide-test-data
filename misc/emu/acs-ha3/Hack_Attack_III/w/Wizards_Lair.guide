@DATABASE "Wizard's Lair"
@NODE "MAIN" "SPECCY POKES - W - Wizard's Lair"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - W
                   ====================================

                               Wizard's Lair
                               =============



DESCRIPTION              POKE
===========              ====

@{"Lives = x       " RXS "ADDRESS COMMAND ZXAMPoke(25522,255)"}        25522,x (x= 1-255)
@{"Infinite Weapons" RXS "ADDRESS COMMAND ZXAMPoke(51419,0)"}        51419,0
@{"Maximum Objects " RXS "ADDRESS COMMAND ZXAMPoke(25516,255) ZXAMPoke(25517,255) ZXAMPoke(25518,255)"}        25516,255:25517,255:25518,255
@{"More Energy     " RXS "ADDRESS COMMAND ZXAMPoke(47753,0)"}        47753,0
@{"Infinite Energy " RXS "ADDRESS COMMAND ZXAMPoke(52056,0)"}        52056,0
@{"Infinite Lives  " RXS "ADDRESS COMMAND ZXAMPoke(47968,0)"}        47968,0
@{"Infinite Keys   " RXS "ADDRESS COMMAND ZXAMPoke(52081,0)"}        52081,0

                         This POKE seems to be working OK, even though the
                         only version I have is called "MAGIC CASTLE", and
                         is in Spanish(?)

                         Rastan.
@endnode
