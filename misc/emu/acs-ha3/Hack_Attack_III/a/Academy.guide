@DATABASE "Academy"
@NODE "MAIN" "SPECCY POKES - A - Academy"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - A
                   ====================================

                                  Academy
                                  =======


DESCRIPTION              POKE
===========              ====

@{"No Weight Limit    " RXS "ADDRESS COMMAND ZXAMPoke(31378,255) ZXAMPoke(31386,255)"}     31378,255:31386,255
@{"Load Any Level     " RXS "ADDRESS COMMAND ZXAMPoke(32924,33)"}     32924,33
@{"Infinite Deflector " RXS "ADDRESS COMMAND ZXAMPoke(50584,201)"}     50584,201
@{"Infinite Fuel      " RXS "ADDRESS COMMAND ZXAMPoke(44556,0)"}     44556,0
@{"Delay Bombs        " RXS "ADDRESS COMMAND ZXAMPoke(44831,0)"}     44831,0
@{"Infinite Missiles  " RXS "ADDRESS COMMAND ZXAMPoke(44716,0)"}     44716,0
@{"Infinite Flares    " RXS "ADDRESS COMMAND ZXAMPoke(44752,0)"}     44752,0
@{"Infinite Ammunition" RXS "ADDRESS COMMAND ZXAMPoke(44794,0)"}     44794,0
@{"Cost = x           " RXS "ADDRESS COMMAND ZXAMPoke(26497,1)"}     26497,x (x= 1-100)
@{"Wieght = x         " RXS "ADDRESS COMMAND ZXAMPoke(24496,255)"}     24496,x (x= 1-255)
@{"Missiles = x       " RXS "ADDRESS COMMAND ZXAMPoke(47754,255)"}     47754,x (x= 1-255)
@{"Ammo = x           " RXS "ADDRESS COMMAND ZXAMPoke(47755,255)"}     47755,x (x= 1-255)
@{"Flares = x         " RXS "ADDRESS COMMAND ZXAMPoke(47756,255)"}     47756,x (x= 1-255)
@{"Bombs = x          " RXS "ADDRESS COMMAND ZXAMPoke(47757,255)"}     47757,x (x= 1-255)


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

@endnode
