@DATABASE "Hawk Storm"
@NODE "MAIN" "SPECCY POKES - H - Hawk Storm"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - H
                   ====================================

                                Hawk Storm
                                ==========


DESCRIPTION              POKE
===========              ====

@{"Infinite Ammo    " RXS "ADDRESS COMMAND ZXAMPOKE(34869,0)"}       34869,0
@{"Infinite Bombs   " RXS "ADDRESS COMMAND ZXAMPOKE(32197,0)"}       32197,0
@{"Infinite Stryders" RXS "ADDRESS COMMAND ZXAMPOKE(37668,0)"}       37668,0
@{"Infinite Shields " RXS "ADDRESS COMMAND ZXAMPOKE(41901,0)"}       41901,0
@{"Immunity         " RXS "ADDRESS COMMAND ZXAMPOKE(32163,0) zxampoke(35306,0) zxampoke(36604,0) zxampoke(37804,0)"}       32163,0:35306,0:36604,0:37804,0
@{"Barrier Hits = x " RXS "ADDRESS COMMAND ZXAMPOKE(33380,1)"}       33380,x (x= 1-255)
@{"Gun Hits = x     " RXS "ADDRESS COMMAND ZXAMPOKE(33385,1)"}       33385,x (x= 1-255)


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

                         The "Barrier Hits" and "Gun Hits" POKEs
                         set how many times you have to shoot them
                         to destroy them.


                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode
