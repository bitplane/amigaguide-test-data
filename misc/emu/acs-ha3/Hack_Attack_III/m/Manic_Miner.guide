@DATABASE "Manic Miner"
@NODE "MAIN" "SPECCY POKES - M - Manic Miner"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - M
                   ====================================

                                Manic Miner
                                ===========



DESCRIPTION              POKE
===========              ====

@{"Infinite Lives " RXS "ADDRESS COMMAND ZXAMPoke(35136,0)"}         35136,0
@{"Infinite Oxygen" RXS "ADDRESS COMMAND ZXAMPoke(34798,0) ZXAMPoke(34799,0) ZXAMPoke(34800,0)"}         34798,0:34799,0:34800,0
@{"No Collision   " RXS "ADDRESS COMMAND ZXAMPoke(36106,0)"}         36106,0
@{"No Horiz. Nasty" RXS "ADDRESS COMMAND ZXAMPoke(36160,0)"}         36160,0
@{"Mystery POKE?  " RXS "ADDRESS COMMAND ZXAMPoke(35160,0)"}         35160,0
@{"Alter Enemies  " RXS "ADDRESS COMMAND ZXAMPoke(36150,0)"}         36150,0


                         @{"CLICK HERE TO DISABLE 'NO COLLISION' POKE" RXS "ADDRESS COMMAND ZXAMPoke(36106,107)"}

                         The "No Collision" POKE is a bit dodgy. Not only
                         does some of the screen flash if you do hit a
                         nasty, but if you fall from a distance, you end
                         up stuck beneath the floor with no way to escape!
                         If you do get stuck, just press ESCAPE and click
                         the above button. RUN the game again, and you
                         will die as normal. Then you can re-activate the
                         POKE again if needed.

                         Rastan.
@endnode
