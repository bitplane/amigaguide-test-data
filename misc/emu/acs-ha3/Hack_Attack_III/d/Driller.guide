@DATABASE "Driller"
@NODE "MAIN" "SPECCY POKES - D - Driller"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - D
                   ====================================

                                  Driller
                                  =======


DESCRIPTION              POKE
===========              ====

@{"Infinite Energy " RXS "ADDRESS COMMAND ZXAMPoke(48246,0)"}        48246,0
@{"Infinite Shields" RXS "ADDRESS COMMAND ZXAMPoke(49425,0) ZXAMPoke(49022,0)"}        49425,0:49022,0
@{"Infinite Time   " RXS "ADDRESS COMMAND ZXAMPoke(47882,195)"}        47882,195

                         This POKE only seems to work in certain areas of
                         the game. In other parts, you lose energy and shields
                         as usual.
                                     Rastan
@endnode
