@DATABASE "Double Dragon II"
@NODE "MAIN" "SPECCY POKES - D - Double Dragon II"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - D
                   ====================================

                             Double Dragon II
                             ================


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives Pl 1" RXS "ADDRESS COMMAND ZXAMPoke(29014,0)"}     29014,0
@{"Infinite Lives Pl 2" RXS "ADDRESS COMMAND ZXAMPoke(29033,0)"}     29033,0
@{"Lives = x Pl 1 & 2 " rxs "ADDRESS COMMAND ZXAMPoke(24890,255)"}     24890,x (x= 1-255)


                         This is one of my POKEs - Enjoy!

                         Rastan.
@endnode
