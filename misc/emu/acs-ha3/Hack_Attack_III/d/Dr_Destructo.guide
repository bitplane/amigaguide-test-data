@DATABASE "Dr. Destructo"
@NODE "MAIN" "SPECCY POKES - D - Dr. Destructo"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - D
                   ====================================

                               Dr. Destructo
                               =============


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(39136,0)"}          39136,0
@{"Immunity      " RXS "ADDRESS COMMAND ZXAMPoke(39119,0)"}          39119,0
@{"Infinite Days " RXS "ADDRESS COMMAND ZXAMPoke(42517,0)"}          42517,0
@{"Lives pl1 = x " RXS "ADDRESS COMMAND ZXAMPoke(41763,255)"}          41763,x (x= 1-255)
@{"Lives pl2 = x " RXS "ADDRESS COMMAND ZXAMPoke(34837,255)"}          34837,x (x= 1-255)


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).


                         I haven't tested this one as I don't have the
                         game :(
                                  Rastan
@endnode
