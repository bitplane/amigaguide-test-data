@DATABASE "The A Team"
@NODE "MAIN" "SPECCY POKES - T - The A Team"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - T
                   ====================================

                                The A Team
                                ==========



DESCRIPTION              POKE
===========              ====

@{"Infinite Energy" RXS "ADDRESS COMMAND ZXAMPoke(26419,42)"}         26419,42
@{"Infinite Ammo  " RXS "ADDRESS COMMAND ZXAMPoke(26379,0)"}         26379,0
@{"Infinite Clips " RXS "ADDRESS COMMAND ZXAMPoke(26391,42)"}         26391,0
@{"Infinite Bombs " RXS "ADDRESS COMMAND ZXAMPoke(26318,0)"}         26318,0
@{"Enemy = x      " RXS "ADDRESS COMMAND ZXAMPoke(24882,1)"}         24882,x (x= 1-255)
@{"Jeeps = x      " RXS "ADDRESS COMMAND ZXAMPoke(24887,1)"}         24887,x (x= 1-255)
@{"Clips = x      " RXS "ADDRESS COMMAND ZXAMPoke(24913,255)"}         24913,x (x= 1-255)
@{"Bombs = x      " RXS "ADDRESS COMMAND ZXAMPoke(24923,128)"}         24923,x (x= 1-128)
@{"Ammo = x       " RXS "ADDRESS COMMAND ZXAMPoke(24918,255) zxampoke(26396,255) zxampoke(26449,255)"}         24918,x:26396,x:26449,x (x= 1-255)
@{"Only 1 Enemy   " RXS "ADDRESS COMMAND ZXAMPoke(26337,98)"}         26337,98
@{"Only 1 Jeep    " RXS "ADDRESS COMMAND ZXAMPoke(26359,175)"}         26359,175


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).


                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode
