@DATABASE "Tai-Chi Tortoise"
@NODE "MAIN" "SPECCY POKES - T - Tai-Chi Tortoise"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - T
                   ====================================

                             Tai-Chi Tortoise
                             ================



DESCRIPTION              POKE
===========              ====

@{"Infinite Lives " RXS "ADDRESS COMMAND ZXAMPoke(65121,0)"}         65121,0
@{"Infinite Energy" RXS "ADDRESS COMMAND ZXAMPoke(56867,201)"}         56867,201
@{"Object #1 = x  " RXS "ADDRESS COMMAND ZXAMPoke(53113,0)"}         53113,x (x= 0-27)
@{"Object #2 = x  " RXS "ADDRESS COMMAND ZXAMPoke(53118,0)"}         53118,x (x= 0-27)
@{"Object #3 = x  " RXS "ADDRESS COMMAND ZXAMPoke(53123,0)"}         53123,x (x= 0-27)


OBJECTS
=======

 0 = card                10 = bottle               20 = coil
 1 = card                11 = pick axe             21 = bucket
 2 = card                12 = hammer               22 = rope
 3 = fire extinguisher   13 = space                23 = rate
 4 = ??                  14 = arrow                24 = ice
 5 = battery             15 = fire power           25 = clock
 6 = heart               16 = circle               26 = stool
 7 = handle              17 = key part             27 = drill
 8 = boot                18 = key part
 9 = component           19 = key part

                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

                         Rastan.
@endnode
