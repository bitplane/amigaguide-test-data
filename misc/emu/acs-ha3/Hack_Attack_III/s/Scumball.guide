@DATABASE "Scumball"
@NODE "MAIN" "SPECCY POKES - S - Scumball"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - S
                   ====================================

                                 Scumball
                                 ========



DESCRIPTION              POKE
===========              ====

@{"Lives = x      " RXS "ADDRESS COMMAND ZXAMPoke(49098,255)"}         49098,x (x= 1-255)
@{"Grenades = x   " RXS "ADDRESS COMMAND ZXAMPoke(49093,255)"}         49093,x (x= 1-255)
@{"Infinite Lives " RXS "ADDRESS COMMAND ZXAMPoke(65036,0)"}         65036,0
@{"Infinite Energy" RXS "ADDRESS COMMAND ZXAMPoke(52928,0)"}         52928,0
@{"Infinite Spares" RXS "ADDRESS COMMAND ZXAMPoke(52801,0)"}         52801,0
@{"Infinite Lasers" RXS "ADDRESS COMMAND ZXAMPoke(52866,0)"}         52866,0


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

                         I haven't tested this one as I don't have the
                         game (or at least not a WORKING version on
                         Speccy Sensations 2!)

                         Rastan
@endnode
