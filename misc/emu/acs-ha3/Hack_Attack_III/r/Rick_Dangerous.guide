@DATABASE "Rick Dangerous"
@NODE "MAIN" "SPECCY POKES - R - Rick Dangerous"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - R
                   ====================================

                              Rick Dangerous
                              ==============



DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(58356,0)"}          58356,0
@{"Infinite Ammo " RXS "ADDRESS COMMAND ZXAMPoke(64075,0)"}          65075,0
@{"Infinite Bombs" RXS "ADDRESS COMMAND ZXAMPoke(64166,0)"}          64166,0
@{"Ammo = x      " RXS "ADDRESS COMMAND ZXAMPoke(58300,255)"}          58300,x (x= 1-255)
@{"Bombs = x     " rxs "address command zxampoke(44012,255)"}          44012,x (x= 1-255)
@{"Lives = x     " rxs "address command zxampoke(58104,255)"}          58104,x (x= 1-255)


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).


                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode
