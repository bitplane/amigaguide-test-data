@DATABASE "Pro Powerboat Sim"
@NODE "MAIN" "SPECCY POKES - P - Pro Powerboat Sim"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - P
                   ====================================

                             Pro Powerboat Sim
                             =================



DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" rxs "address command zxampoke(37780,0)"}          37780,0
@{"Infinite Mines" rxs "address command zxampoke(38421,0)"}          38421,0
@{"Lives Pl1 = x " rxs "address command zxampoke(39387,255)"}          39387,x (x= 1-255)
@{"Lives Pl2 = x " rxs "address command zxampoke(39375,255)"}          39375,x (x= 1-255)
@{"Mines Pl1 = x " rxs "address command zxampoke(39393,255)"}          39393,x (x= 1-255)
@{"Mines Pl2 = x " rxs "address command zxampoke(39380,255)"}          39380,x (x= 1-255)


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

                         The "Infinite Lives" POKE works for both
                         players.


                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode
