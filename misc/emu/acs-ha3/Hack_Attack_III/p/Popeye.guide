@DATABASE "Popeye"
@NODE "MAIN" "SPECCY POKES - P - Popeye"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - P
                   ====================================

                                  Popeye
                                  ======



DESCRIPTION              POKE
===========              ====

@{"Infinite Time   " rxs "address command zxampoke(26242,0)"}        26242,0
@{"Infinite Spinach" RXS "ADDRESS COMMAND ZXAMPoke(30057,195)"}        30057,195
@{"Hearts = x      " RXS "ADDRESS COMMAND ZXAMPoke(26095,1)"}        26095,x (x= 1-24)


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

@endnode
