@DATABASE "Bear Bovver"
@NODE "MAIN" "SPECCY POKES - B - Bear Bovver"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - B
                   ====================================

                                Bear Bovver
                                ===========


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(39192,0)"}          39192,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(49236,255)"}          49236,x (x= 1-255)
@{"Bombs = x     " RXS "ADDRESS COMMAND ZXAMPoke(49231,255)"}          49231,x (x= 1-255)
@{"Infinite Bombs" RXS "ADDRESS COMMAND ZXAMPoke(39134,0)"}          39134,0


                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode
