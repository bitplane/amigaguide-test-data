@DATABASE "Ball Crazy"
@NODE "MAIN" "SPECCY POKES - B - Ball Crazy"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - B
                   ====================================

                                Ball Crazy
                                ==========


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(28489,201)"}          28489,201
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(28086,255)"}          28086,x (x= 1-255)
@{"Immunity      " RXS "ADDRESS COMMAND ZXAMPoke(32995,00)"}          32995,0
@{"Infinite Ammo " RXS "ADDRESS COMMAND ZXAMPoke(31085,0)"}          31085,0


                         "Infinite Ammo" is one of my POKEs. Enjoy!

                         Rastan.
@endnode
