@DATABASE "Operation Gunship"
@NODE "MAIN" "SPECCY POKES - O - Operation Gunship"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - O
                   ====================================

                             Operation Gunship
                             =================



DESCRIPTION              POKE
===========              ====

@{"Infinite Fuel   " RXS "ADDRESS COMMAND ZXAMPoke(53926,0)"}        53926,0
@{"Infinite Bullets" RXS "ADDRESS COMMAND ZXAMPoke(55976,0)"}        55976,0
@{"Infinite Rockets" RXS "ADDRESS COMMAND ZXAMPoke(56304,0)"}        56304,0
@{"Infinite Armour " RXS "ADDRESS COMMAND ZXAMPoke(53977,201)"}        53977,201
@{"Men To Save = x " RXS "ADDRESS COMMAND ZXAMPoke(53377,1)"}        53377,x (x= 1-8)



                         Make sure you don't put any more than 8 men
                         to save, as the game only puts the 8 in
                         set locations, and you'll never finish!


                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode
