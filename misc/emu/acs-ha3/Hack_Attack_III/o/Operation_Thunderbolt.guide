@{"Ammo P2 = x     " RXS "ADDRESS COMMAND ZXAMPoke(37939,255)"}        37939,x (x= 1-255)
@{"Energy P2 = x   " RXS "ADDRESS COMMAND ZXAMPoke(37951,255)"}        37951,x (x= 1-255)
