@DATABASE "Into The Eagle's Nest"
@NODE "MAIN" "SPECCY POKES - I - Into The Eagle's Nest"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - I
                   ====================================

                           Into The Eagle's Nest
                           =====================



DESCRIPTION              POKE
===========              ====

@{"Infinite Ammo" RXS "ADDRESS COMMAND ZXAMPoke(36640,0) ZXAMPoke(36641,0)"}           36641,0
@{"Infinite Keys" RXS "ADDESS COMMAND ZXAMPoke(40512,0) ZXAMPoke(40513,0)"}           40513,0
@{"No Injury    " RXS "ADDRESS COMMAND ZXAMPoke(41136,0) ZXAMPoke(41137,0)"}           41137,0

                         Note the "No Injury" POKE does not help if you shoot
                         explosives!
                                     Rastan.
@endnode
