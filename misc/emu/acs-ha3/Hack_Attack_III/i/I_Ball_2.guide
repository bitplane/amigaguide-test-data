@DATABASE "I, Ball 2"
@NODE "MAIN" "SPECCY POKES - I - I, Ball 2"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - I
                   ====================================

                                 I, Ball 2
                                 =========


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives     " RXS "ADDRESS COMMAND ZXAMPoke(45392,0)"}     45392,0
@{"Infinite Time      " RXS "ADDRESS COMMAND ZXAMPoke(38009,0)"}     38009,0
@{"Infinite Ammo      " RXS "ADDRESS COMMAND ZXAMPoke(39919,0) ZXAMPoke(43714,0)"}     39919,0:43714,0
@{"No Enemies         " RXS "ADDRESS COMMAND ZXAMPoke(36664,201) ZXAMPoke(39674,201)"}     36664,201:39674,201
@{"Immunity           " RXS "ADDRESS COMMAND ZXAMPoke(43612,33) ZXAMPoke(43619,33)"}     43612,33:43619,33
@{"Timed Blocks Vanish" RXS "ADDRESS COMMAND ZXAMPoke(35327,33) ZXAMPoke(35338,33)"}     35327,33:35338,33
@{"Key Not Needed     " RXS "ADDRESS COMMAND ZXAMPoke(45601,33)"}     45601,33
@{"Rapid Fire         " RXS "ADDRESS COMMAND ZXAMPoke(65343,15)"}     65343,15
@{"Lives = x          " RXS "ADDRESS COMMAND ZXAMPoke(43384,255)"}     43384,x (x= 1-255)
@{"Bombs = x          " RXS "ADDRESS COMMAND ZXAMPoke(43366,250)"}     43366,x (x= 1-250)
@{"Fireballs = x      " RXS "ADDRESS COMMAND ZXAMPoke(43394,255)"}     43394,x (x= 1-250)
@{"Level = x          " RXS "ADDRESS COMMAND ZXAMPoke(43410,0)"}     43410,x (x= 0-48)
@{"Bullets = x        " RXS "ADDRESS COMMAND ZXAMPoke(65343,5)"}     65343,x (x= 1-5)

                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

                         Using all of these at once will COMPLETELY ruin
                         the game!

                         Rastan.
@endnode
