 @{" Visualizzazione su schede EGS                   " link "GraEGS" }
 @{" Visualizzazione su schede CyberGraphX/Picasso96 " link "GraCyber96" }
 @{" Visualizzazione su schede Graffity              " link "GraGraffity" }
 @{" Visualizzazione su schede Picasso               " link "GraPicasso" }
 @{" Visualizzazione su schede Merlin                " link "GraMerlin" }
 @{" Visualizzazione su schede Retina Z3             " link "GraRetinaZ3" }
 @{" Visualizzazione su una finestra nel Workbench   " link "GraWindow" }

 @{" Come usare i modi grafici video                 " link "GraVideo" }

