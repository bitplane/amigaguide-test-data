  @{" Clr ABoot        " link "Command Clr ABoot"}  @{" Open...          " link "Command Open..."}  @{" Set Screen...    " link "Command Set Screen..."}
  @{" Clr Dir          " link "Command Clr Dir"}  @{" Output File      " link "Command Output File"}  @{" TX Close         " link "Command TX Close"}
  @{" Clr Files        " link "Command Clr Files"}  @{" Output Prt       " link "Command Output Prt"}  @{" TX Close All     " link "Command TX Close All"}
