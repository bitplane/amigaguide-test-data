            @{" Panic Button Window " link "Prefs Defaults - Panic Button Window"} defaults preference
            @{" Cancel              " link "Panic Window - Cancel"} panic window button
            @{" Suspend             " link "Panic Window - Suspend"} panic window button

@endnode

