  @{" Copy As          " link "Command Copy As"}  @{" Reset All        " link "Command Reset All"}  @{" TX ScrollDown    " link "Command TX ScrollDown"}
  @{" Copy/Format      " link "Command Copy-Format"}  @{" Save As...       " link "Command Save As..."}  @{" TX ScrollUp      " link "Command TX ScrollUp"}
