| @{"@   Name   " link "Pattern Match - Cycle"} @{"                               " link "Pattern Match - String"} @{"@    In   " link "Pattern Match - In Out"} @{"@ Activate " link "Pattern Match - Activate"}  |
| @{"@   Name   " link "Pattern Match - Cycle"} @{"                               " link "Pattern Match - String"} @{"@    In   " link "Pattern Match - In Out"} @{"@ Activate " link "Pattern Match - Activate"}  |
| @{"@   Name   " link "Pattern Match - Cycle"} @{"                               " link "Pattern Match - String"} @{"@    In   " link "Pattern Match - In Out"} @{"@ Activate " link "Pattern Match - Activate"}  |
| @{"@   Name   " link "Pattern Match - Cycle"} @{"                               " link "Pattern Match - String"} @{"@    In   " link "Pattern Match - In Out"} @{"@ Activate " link "Pattern Match - Activate"}  |
