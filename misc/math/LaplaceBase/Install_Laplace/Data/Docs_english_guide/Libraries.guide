@TOC "Manual.guide/Main"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual ------------------------------------------------- Libraries -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "Main" "Libraries"
@{U}10) Libraries@{UU}

   Laplace offers the ability to process external files. These files are plain
ASCII files and may be edited  with every texteditor. They will be  processed,
just as if you  entered the contents  in a window. The  results won't be  dis-
played, so this is only useful for constant and function definitions.  Library
files have a trailing @{B}.lh@{UB} and  are located in the @{B}Data/Include@{UB} directory.  Use
the @{"include()" LINK "Functions.guide/FKT-INCLUDE"} command to gain access to a library.
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT} include("linalg.lh");

   If you want a library to be available on startup, add a line  @{B}include("@{B}lib-@{UB}@{UB}
@{B}@{B}name.lh@{UB}");@{UB} to the  file @{B}Data/Include/init.lh@{UB}. This  way you can  load all  re-
quired libraries with the single command @{B}include("init.lh");@{UB}.

@{"linalg.lh" LINK "LibLinAlg"}:
   @{" * " LINK "FKT-ADDCOLS"} addcols()            @{" * " LINK "FKT-ADDROWS"} addrows()            @{" * " LINK "FKT-ANGLE"} angle()
   @{" * " LINK "FKT-MULTCOL"} multcol()            @{" * " LINK "FKT-MULTROW"} multrow()            @{" * " LINK "FKT-SWAPCOLS"} swapcols()
   @{" * " LINK "FKT-SWAPROWS"} swaprows()           @{" * " LINK "FKT-UMATRIX"} umatrix()

@{"analysis.lh" LINK "LibAnalysis"}:
   @{" * " LINK "FKT-RANDOMCPOLY"} randomcpoly()        @{" * " LINK "FKT-RANDOMPOLY"} randompoly()         @{" * " LINK "FKT-RANDOMQPOLY"} randomqpoly()
   @{" * " LINK "FKT-RANDOMRPOLY"} randomrpoly()

@{"statistics.lh" LINK "LibStatistics"}:
   @{" * " LINK "FKT-AVERAGE"} average()            @{" * " LINK "FKT-ERROR"} error()              @{" * " LINK "FKT-SIGMA"} sigma()

@{"physic.lh" LINK "LibPhysic"}:

@{"math.lh" LINK "LibMath"}:


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
