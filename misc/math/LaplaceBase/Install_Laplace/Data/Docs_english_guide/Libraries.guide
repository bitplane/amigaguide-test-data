@REM KEY 0 0 "LibLinAlg" "swaprows()"
@{U}swaprows()@{UU}

@{B}sypnosis:@{UB}
   @{B}swaprows(@{I}M @{UI}, @{I}r1 @{UI}, @{I}r2 @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}M @{UI}: matrix
   @{I}r1, r2 @{UI}: integer between @{I}1 @{UI} and @{I}rows  M @{UI}

@{B}result:@{UB}
   matrix

   Return the matrix @{I}M @{UI}, except that rows @{I}r1 @{UI} and @{I}r2 @{UI} are swapped.


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
