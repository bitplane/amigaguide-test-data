@REM KEY 0 0 "LibLinAlg" "multcol()"
@{U}multcol()@{UU}

@{B}sypnosis:@{UB}
   @{B}multcol(@{I}M @{UI}, @{I}c @{UI}, @{I}x @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}M @{UI}: matrix
   @{I}c @{UI}: integer between @{I}1 @{UI} and @{I}cols  M @{UI}
   @{I}x @{UI}: number

@{B}result:@{UB}
   matrix

   Returns the matrix @{I}M @{UI}, except that column @{I}c @{UI} is multiplied by @{I}x @{UI}.


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
