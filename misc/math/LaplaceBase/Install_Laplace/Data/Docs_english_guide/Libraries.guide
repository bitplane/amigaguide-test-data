@{U}10.2) analysis.lh@{UU}

   @{" * " LINK "FKT-RANDOMCPOLY"} randomcpoly()        @{" * " LINK "FKT-RANDOMPOLY"} randompoly()         @{" * " LINK "FKT-RANDOMQPOLY"} randomqpoly()
   @{" * " LINK "FKT-RANDOMRPOLY"} randomrpoly()


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-RANDOMCPOLY"
@TITLE "randomcpoly()"
@NEXT "FKT-RANDOMPOLY"
@TOC "LibAnalysis"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual --------------------------------------------- randomcpoly() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibAnalysis" "randomcpoly()"
@{U}randomcpoly()@{UU}

@{B}sypnosis:@{UB}
   @{B}randomcpoly(@{I}n @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}n @{UI}: positive integer

@{B}result:@{UB}
   number

   This creates a polynom in  @{I}x @{UI} of @{I}n @{UI}-th  degree with random complex coeffi-
cients @{I}a_i @{UI}, with @{I}-1<=re a_i<=1 @{UI} and @{I}-1<=im a_i<=1 @{UI}.
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT} f(x) = randomcpoly(2)
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT}    => @{I}0.5-0.3i+(0.3+0.5i)*x-(0.7-0.4i)*x^2@{UI}


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-RANDOMPOLY"
@TITLE "randompoly()"
@NEXT "FKT-RANDOMQPOLY"
@PREV "FKT-RANDOMCPOLY"
@TOC "LibAnalysis"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual ---------------------------------------------- randompoly() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibAnalysis" "randompoly()"
@{U}randompoly()@{UU}

@{B}sypnosis:@{UB}
   @{B}randompoly(@{I}n @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}n @{UI}: positive integer

@{B}result:@{UB}
   number

   This creates a polynom in  @{I}x @{UI} of @{I}n @{UI}-th  degree with random integer coeffi-
cients @{I}a_i @{UI}, with @{I}-10<=a_i<=10 @{UI}.
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT} f(x) = randompoly(2)
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT}    => @{I}5+3*x-7*x^2@{UI}


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-RANDOMQPOLY"
@TITLE "randomqpoly()"
@NEXT "FKT-RANDOMRPOLY"
@PREV "FKT-RANDOMPOLY"
@TOC "LibAnalysis"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual --------------------------------------------- randomqpoly() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibAnalysis" "randomqpoly()"
@{U}randomqpoly()@{UU}

@{B}sypnosis:@{UB}
   @{B}randomqpoly(@{I}n @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}n @{UI}: positive integer

@{B}result:@{UB}
   number

   This creates a polynom in @{I}x @{UI} of  @{I}n @{UI}-th degree with random rational coeffi-
cients @{I}a_i / b_i @{UI}, with @{I}-10<=a_i<=10 @{UI} and @{I}1<=b_i<=10 @{UI}.
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT} f(x) = randomqpoly(2)
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT}    => @{I}3/7+5/8*x-1/3*x^2@{UI}


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-RANDOMRPOLY"
@TITLE "randomrpoly()"
@PREV "FKT-RANDOMQPOLY"
@TOC "LibAnalysis"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual --------------------------------------------- randomrpoly() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibAnalysis" "randomrpoly()"
@{U}randomrpoly()@{UU}

@{B}sypnosis:@{UB}
   @{B}randomrpoly(@{I}n @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}n @{UI}: positive integer

@{B}result:@{UB}
   number

   This creates a polynom in @{I}x @{UI} of @{I}n @{UI}-th degree with random real coefficients
@{I}a_i @{UI}, with @{I}-1<=a_i<=1 @{UI}
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT} f(x) = randomrpoly(2)
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT}    => @{I}0.5+0.3*x-0.7*x^2@{UI}


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
