@NODE "FKT-ADDCOLS"
@TITLE "addcols()"
@NEXT "FKT-ADDROWS"
@TOC "LibLinAlg"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual ------------------------------------------------- addcols() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibLinAlg" "addcols()"
@{U}addcols()@{UU}

@{B}sypnosis:@{UB}
   @{B}addcols(@{I}M @{UI}, @{I}c1 @{UI}, @{I}c2 @{UI}, @{I}x @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}M @{UI}: matrix
   @{I}c1, c2 @{UI}: integer between @{I}1 @{UI} and @{I}cols  M @{UI}
   @{I}x @{UI}: number

@{B}result:@{UB}
   matrix

   Returns the matrix @{I}M @{UI}, except that column @{I}c1 @{UI} is replaced by

                        @{I}(column c1) + x * (column c2) @{UI}


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-ADDROWS"
@TITLE "addrows()"
@NEXT "FKT-ANGLE"
@PREV "FKT-ADDCOLS"
@TOC "LibLinAlg"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual ------------------------------------------------- addrows() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibLinAlg" "addrows()"
@{U}addrows()@{UU}

@{B}sypnosis:@{UB}
   @{B}addrows(@{I}M @{UI}, @{I}r1 @{UI}, @{I}r2 @{UI}, @{I}x @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}M @{UI}: matrix
   @{I}r1, r2 @{UI}: integer between @{I}1 @{UI} and @{I}rows  M @{UI}
   @{I}x @{UI}: number

@{B}result:@{UB}
   matrix

   Returns the matrix @{I}M @{UI}, except that row @{I}r1 @{UI} is replaced by

                           @{I}(row r1) + x * (row r2) @{UI}


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-ANGLE"
@TITLE "angle()"
@NEXT "FKT-MULTCOL"
@PREV "FKT-ADDROWS"
@TOC "LibLinAlg"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual --------------------------------------------------- angle() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibLinAlg" "angle()"
@{U}angle()@{UU}

@{B}sypnosis:@{UB}
   @{B}angle(@{I}a @{UI}, @{I}b @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}a,b @{UI}: vector

@{B}result:@{UB}
   number

   Calculate the angle, enclosed by the vectors @{I}a @{UI} and @{I}b @{UI}:

                  @{I}angle  x = arccos acot b / abs(a)*abs(b) @{UI}


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
