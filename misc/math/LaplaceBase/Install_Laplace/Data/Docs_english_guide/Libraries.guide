@REM KEY 0 0 "LibLinAlg" "swapcols()"
@{U}swapcols()@{UU}

@{B}sypnosis:@{UB}
   @{B}swapcols(@{I}M @{UI}, @{I}c1 @{UI}, @{I}c2 @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}M @{UI}: matrix
   @{I}c1, c2 @{UI}: integer between @{I}1 @{UI} and @{I}cols  M @{UI}

@{B}result:@{UB}
   matrix

   Return the matrix @{I}M @{UI}, except that columns @{I}c1 @{UI} and @{I}c2 @{UI} are swapped.


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
