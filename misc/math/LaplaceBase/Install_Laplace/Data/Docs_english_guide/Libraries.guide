@REM KEY 0 0 "Libraries" "statistics.lh"
@{U}10.3) statistics.lh@{UU}

   @{" * " LINK "FKT-AVERAGE"} average()            @{" * " LINK "FKT-ERROR"} error()              @{" * " LINK "FKT-SIGMA"} sigma()


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-AVERAGE"
@TITLE "average()"
@NEXT "FKT-ERROR"
@TOC "LibStatistics"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual ------------------------------------------------- average() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibStatistics" "average()"
@{U}average()@{UU}

@{B}sypnosis:@{UB}
   @{B}average(@{I}A @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}A @{UI}: array of numbers

@{B}result:@{UB}
   number

   Returns the arithmetic average of the array's contents.

             @{I}average  A = 1 / n *sum  x_i, A = {x_1, x_2,...x_n} @{UI}


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-ERROR"
@TITLE "error()"
@NEXT "FKT-SIGMA"
@PREV "FKT-AVERAGE"
@TOC "LibStatistics"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual --------------------------------------------------- error() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibStatistics" "error()"
@{U}error()@{UU}

@{B}sypnosis:@{UB}
   @{B}error(@{I}A @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}A @{UI}: array of numbers

@{B}result:@{UB}
   number

   Calculate the statistical error of the array's contents, which is

                    @{I}error  A = sigma  A / sqrt(count  A) @{UI}


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-SIGMA"
@TITLE "sigma()"
@PREV "FKT-ERROR"
@TOC "LibStatistics"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual --------------------------------------------------- sigma() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibStatistics" "sigma()"
@{U}sigma()@{UU}

@{B}sypnosis:@{UB}
   @{B}sigma(@{I}A @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}A @{UI}: array of numbers

@{B}result:@{UB}
   number

   Calculate the standard variation of the array's contents, which is  defined
as

   @{I}sigma  A = sqrt(sum ((x - y)^2) / (count  A - 1)), @{UI}with@{I} y = average  A @{UI}


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ © by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
