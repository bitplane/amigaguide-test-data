   @{" * " LINK "FKT-RANDOMCPOLY"} randomcpoly()        @{" * " LINK "FKT-RANDOMPOLY"} randompoly()         @{" * " LINK "FKT-RANDOMQPOLY"} randomqpoly()
   @{" * " LINK "FKT-RANDOMRPOLY"} randomrpoly()


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-RANDOMCPOLY"
@TITLE "randomcpoly()"
@NEXT "FKT-RANDOMPOLY"
@TOC "LibAnalysis"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace --------------------------------------- randomcpoly() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibAnalysis" "randomcpoly()"
@{U}randomcpoly()@{UU}

@{B}sypnosis:@{UB}
   @{B}randomcpoly(@{I}n @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}n @{UI}: positive Ganzzahl

@{B}result:@{UB}
   Zahl

   Erzeugt ein Polynom in @{I}x @{UI} @{I}n @{UI}-ten Grade mit zufälligen komplexen Koeffizien-
ten @{I}a_i @{UI}, mit @{I}-1<=re a_i<=1 @{UI} und @{I}-1<=im a_i<=1 @{UI}.
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT} f(x) = randomcpoly(2)
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT}    => @{I}0.5-0.3i+(0.3+0.5i)*x-(0.7-0.4i)*x^2@{UI}


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-RANDOMPOLY"
@TITLE "randompoly()"
@NEXT "FKT-RANDOMQPOLY"
@PREV "FKT-RANDOMCPOLY"
@TOC "LibAnalysis"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace ---------------------------------------- randompoly() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibAnalysis" "randompoly()"
@{U}randompoly()@{UU}

@{B}sypnosis:@{UB}
   @{B}randompoly(@{I}n @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}n @{UI}: positive Ganzzahl

@{B}result:@{UB}
   Zahl

   Erzeugt ein Polynom in @{I}x @{UI} @{I}n @{UI}-ten Grade mit zufälligen ganzen  Koeffizienten
@{I}a_i @{UI}, mit @{I}-10<=a_i<=10 @{UI}.
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT} f(x) = randompoly(2)
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT}    => @{I}5+3*x-7*x^2@{UI}


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-RANDOMQPOLY"
@TITLE "randomqpoly()"
@NEXT "FKT-RANDOMRPOLY"
@PREV "FKT-RANDOMPOLY"
@TOC "LibAnalysis"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace --------------------------------------- randomqpoly() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibAnalysis" "randomqpoly()"
@{U}randomqpoly()@{UU}

@{B}sypnosis:@{UB}
   @{B}randomqpoly(@{I}n @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}n @{UI}: positive Ganzzahl

@{B}result:@{UB}
   Zahl

   Erzeugt ein Polynom  in @{I}x  @{UI} @{I}n @{UI}-ten  Grade mit  zufälligen rationalen  Koef-
fizienten @{I}a_i / b_i @{UI}, mit @{I}-10<=a_i<=10 @{UI} und @{I}1<=b_i<=10 @{UI}.
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT} f(x) = randomqpoly(2)
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT}    => @{I}3/7+5/8*x-1/3*x^2@{UI}


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-RANDOMRPOLY"
@TITLE "randomrpoly()"
@PREV "FKT-RANDOMQPOLY"
@TOC "LibAnalysis"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace --------------------------------------- randomrpoly() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibAnalysis" "randomrpoly()"
@{U}randomrpoly()@{UU}

@{B}sypnosis:@{UB}
   @{B}randomrpoly(@{I}n @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}n @{UI}: positive Ganzzahl

@{B}result:@{UB}
   Zahl

   Erzeugt ein Polynom in @{I}x @{UI} @{I}n @{UI}-ten Grade mit zufälligen reellen Koeffizienten
@{I}a_i @{UI}, mit @{I}-1<=a_i<=1 @{UI}.
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT} f(x) = randomrpoly(2)
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT}    => @{I}0.5+0.3*x-0.7*x^2@{UI}


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "LibStatistics"
@TITLE "statistics.lh"
@NEXT "LibPhysic"
@PREV "LibAnalysis"
@TOC "Libraries"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace --------------------------------------- statistics.lh -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "Libraries" "statistics.lh"
@{U}10.3) statistics.lh@{UU}

   @{" * " LINK "FKT-AVERAGE"} average()            @{" * " LINK "FKT-ERROR"} error()              @{" * " LINK "FKT-SIGMA"} sigma()


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-AVERAGE"
@TITLE "average()"
@NEXT "FKT-ERROR"
@TOC "LibStatistics"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace ------------------------------------------- average() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibStatistics" "average()"
@{U}average()@{UU}

@{B}sypnosis:@{UB}
   @{B}average(@{I}A @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}A @{UI}: Array von Zahlen

@{B}result:@{UB}
   Zahl

   Liefert das arithmetische Mittel der Elemente des Array.

             @{I}average  A = 1 / n *sum  x_i, A = {x_1, x_2,...x_n} @{UI}


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-ERROR"
@TITLE "error()"
@NEXT "FKT-SIGMA"
@PREV "FKT-AVERAGE"
@TOC "LibStatistics"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace --------------------------------------------- error() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibStatistics" "error()"
@{U}error()@{UU}

@{B}sypnosis:@{UB}
   @{B}error(@{I}A @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}A @{UI}: Array von Zahlen

@{B}result:@{UB}
   Zahl

   Berechnet den statistischen Fehler der Elemente des Arrays, der  folgender-
maßen definiert ist:

                    @{I}error  A = sigma  A / sqrt(count  A) @{UI}


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-SIGMA"
@TITLE "sigma()"
@PREV "FKT-ERROR"
@TOC "LibStatistics"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace --------------------------------------------- sigma() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibStatistics" "sigma()"
@{U}sigma()@{UU}

@{B}sypnosis:@{UB}
   @{B}sigma(@{I}A @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}A @{UI}: Array von Zahlen

@{B}result:@{UB}
   Zahl

   Berechnet die Standardabweichung  der Elemente des  Arrays, die  folgender-
maßen definiert ist:

   @{I}sigma  A = sqrt(sum ((x - y)^2) / (count  A - 1)), @{UI}with@{I} y = average  A @{UI}


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
