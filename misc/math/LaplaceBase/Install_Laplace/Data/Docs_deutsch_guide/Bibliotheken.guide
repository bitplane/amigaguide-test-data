@NODE "FKT-ADDCOLS"
@TITLE "addcols()"
@NEXT "FKT-ADDROWS"
@TOC "LibLinAlg"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace ------------------------------------------- addcols() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibLinAlg" "addcols()"
@{U}addcols()@{UU}

@{B}sypnosis:@{UB}
   @{B}addcols(@{I}M @{UI}, @{I}c1 @{UI}, @{I}c2 @{UI}, @{I}x @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}M @{UI}: Matrix
   @{I}c1, c2 @{UI}: Ganzzahl zwischen @{I}1 @{UI} und @{I}cols  M @{UI}
   @{I}x @{UI}: Zahl

@{B}result:@{UB}
   Matrix

   Liefert eine Kopie der Matrix @{I}M @{UI} zurück, außer daß die Spalte @{I}c1 @{UI} durch

                        @{I}(Spalte c1) + x * (Spalte c2) @{UI}

   ersetzt wurde.


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-ADDROWS"
@TITLE "addrows()"
@NEXT "FKT-ANGLE"
@PREV "FKT-ADDCOLS"
@TOC "LibLinAlg"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace ------------------------------------------- addrows() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibLinAlg" "addrows()"
@{U}addrows()@{UU}

@{B}sypnosis:@{UB}
   @{B}addrows(@{I}M @{UI}, @{I}r1 @{UI}, @{I}r2 @{UI}, @{I}x @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}M @{UI}: Matrix
   @{I}r1, r2 @{UI}: Ganzzahl zwischen @{I}1 @{UI} und @{I}rows  M @{UI}
   @{I}x @{UI}: Zahl

@{B}result:@{UB}
   Matrix

   Liefert eine Kopie der Matrix @{I}M @{UI} zurück, außer daß die Zeile @{I}r1 @{UI} durch

                         @{I}(Zeile r1) + x * (Zeile r2) @{UI}

   ersetzt wurde.


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-ANGLE"
@TITLE "angle()"
@NEXT "FKT-MULTCOL"
@PREV "FKT-ADDROWS"
@TOC "LibLinAlg"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace --------------------------------------------- angle() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "LibLinAlg" "angle()"
@{U}angle()@{UU}

@{B}sypnosis:@{UB}
   @{B}angle(@{I}a @{UI}, @{I}b @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}a,b @{UI}: Vektor

@{B}result:@{UB}
   Zahl

   Berechnet den Winkel, der von den beiden Vektoren @{I}a @{UI} und @{I}b @{UI} eingeschlossen
wird:

                  @{I}angle  x = arccos acot b / abs(a)*abs(b) @{UI}


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
