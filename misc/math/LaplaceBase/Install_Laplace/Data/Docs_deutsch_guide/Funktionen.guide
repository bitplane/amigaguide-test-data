@PREV "FKT-EXP"
@TOC "Functions"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace ----------------------------------------------- fak() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "Functions" "fak()"
@{U}fak()@{UU}

@{B}sypnosis:@{UB}
   @{B}fak(@{I}x @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}x @{UI}: Ganzzahl

@{B}result:@{UB}
   Zahl

   Liefert @{I}x! @{UI} (Fakultät) zurück. Für @{I}x <=0 @{UI} wird @{I}0 @{UI} zurückgegeben. Die Ober-
grenze ist zur Zeit bei @{I}170! @{UI},  da Laplace intern mit 64 Bit Fließkommazahlen
arbeitet.


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-FLOOR"
@TITLE "floor()"
