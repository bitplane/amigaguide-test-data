@TITLE "acos()"
@NEXT "FKT-ACOSH"
@PREV "FKT-ABS"
@TOC "Functions"
@{FG SHINE}@{BG SHADOW}@{B}- Anleitung zu Laplace ---------------------------------------------- acos() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "Functions" "acos()"
@{U}acos()@{UU}

@{B}sypnosis:@{UB}
   @{B}acos(@{I}x @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}x @{UI}: Zahl

@{B}result:@{UB}
   Zahl

   Liefert den Arcus Cosinus von @{I}x @{UI}. Dies ist identisch mit @{I}arccos  x @{UI}.


@{FG SHINE}@{BG SHADOW}@{B}----------------------------------------------------------------- © bei P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
