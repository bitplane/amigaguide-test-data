           times faster.
@endnode

@node "appl" "Application examples"


  APPLICATION EXAMPLES
  
                  Example I:   @{"Linear Regression." link "regres" 0}
                  Example II:  @{"Bode Plots." link "bode" 0}
                  Example III: @{"Root Locus." link "rlocus" 0}
                  Example IV:  @{"Nyquist diagram." link "nyquist" 0}
                  Example V:   @{"Taylor series." link "taylor" 0}
