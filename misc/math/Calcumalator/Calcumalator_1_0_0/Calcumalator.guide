@database "Calcumalator.guide"
@node MAIN "Calcumalator Documentation"
@{b}@{fg fill}Calcumalator@{fg text}@{ub}
A Simple calculator designed to look decent on AmigaOS 2.04+. Tested
successfully on AmigaOS 4.1.

@{"Introduction" link "INTRO"}
@{"Requirements" link "REQUIREMENTS"}
@{"Features" link "FEATURES"}

@{"Installation" link "INSTALL"}
