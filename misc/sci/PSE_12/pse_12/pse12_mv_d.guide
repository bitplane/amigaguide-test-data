@NODE "H"  "Wasserstoff"
@{b}Name des Elementes :@{ub} Wasserstoff
@{b}Lateinischer Name  :@{ub} Hydrogenium
@{b}Englischer Name    :@{ub} Hydrogen
@{b}Französischer Name :@{ub} Hydrogčne

@{b}Symbol              :@{ub} H
@{b}Ordnungszahl        :@{ub} 1
@{b}Isotopen            :@{ub} @{" Übersicht " link ISOTOP_H}
@{b}Zustand bei 25°C    :@{ub} gasförmig, Nichtmetall
@{b}Häufigkeit [p.p.m.] :@{ub} 1520
@{b}Entdeckt von        :@{ub} Cavendish (1766)

@{b}Elektronenkonfiguration :@{ub} 1s^1
@{b}Oxidationszustände      :@{ub} -1, +1

@{b}Relative Atommasse           :@{ub} 1.0079
@{b}Elektronegativität           :@{ub} 2.20 (Pauling)
@{b}Atomradius (in pm)           :@{ub} 78
@{b}Ionisierungsenergie (kJ/mol) :@{ub} 1312.0

@{b}Dichte (in kg/m^3)       :@{ub} 0.08988
@{b}Schmelztemperatur (in K) :@{ub} 14.01
@{b}Siedetemperatur   (in K) :@{ub} 20.28
@prev LR
@ENDNODE
