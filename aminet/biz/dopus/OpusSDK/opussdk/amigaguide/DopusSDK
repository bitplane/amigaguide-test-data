		     D0

	@{"Att_List" LINK "dopus/lists.h/File" 10} *Att_NewList(ULONG);@{b}

    FUNCTION@{ub}
	Creates a new @{"Att_List" LINK "dopus/lists.h/File" 10} structure, which you use in conjunction with
	Att_Nodes. These functions provide a convenient way of dynamically
	allocating members of lists and performing searches and sorts on them.@{b}

    INPUTS@{ub}
