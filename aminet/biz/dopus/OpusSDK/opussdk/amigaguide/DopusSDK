			A0

	void FreeObjectList(@{"ObjectList" LINK "dopus/layout.h/File" 184} *);@{b}

    FUNCTION@{ub}
	This routine frees the supplied list of objects. If there are any
	gadgets in the list, they are automatically removed from the window
