@NODE "BuildMenuStrip" "BuildMenuStrip()"
@{b}

    NAME@{ub}
	BuildMenuStrip - build a MenuStrip easily@{b}

    SYNOPSIS@{ub}
	BuildMenuStrip(menus, locale)
