@NODE "ReplyAppMessage" "ReplyAppMessage()"
@{b}

    NAME@{ub}
	ReplyAppMessage - reply to an AppMessage@{b}

    SYNOPSIS@{ub}
	ReplyAppMessage(msg)
			 A0

	void ReplyAppMessage(@{"DOpusAppMessage" LINK "dopus/appicon.h/File" 68} *);@{b}

    FUNCTION@{ub}
	This function is the best way to reply to a @{"DOpusAppMessage" LINK "dopus/appicon.h/File" 68}. Its
	operation is quite straightforward - if the message has a reply
	port set, it calls ReplyMsg() as normal. Otherwise, it calls
	@{"FreeAppMessage" LINK "FreeAppMessage"}. This allows messages to be sent with no reply
	needed. Directory Opus will never send an AppMessage without a
	reply port, but you might want to use this routine among your
	own processes.@{b}

    INPUTS@{ub}
	msg - message to reply to@{b}

    RESULT@{ub}
	The message is replied or freed.@{b}

    SEE ALSO@{ub}
	@{"FreeAppMessage()" LINK "FreeAppMessage"}

@ENDNODE
@NODE "SetAppIconMenuState" "SetAppIconMenuState()"
@{b}

    NAME@{ub}
	SetAppIconMenuState - change the state of an icon popup menu@{b}

    SYNOPSIS@{ub}
	SetAppIconMenuState(icon, item, state)
			     A0    D0     D1

	long SetAppIconMenuState(APTR, long, long);@{b}

    FUNCTION@{ub}
	This allows you to set the state of a toggle-select menu item in
	the icon popup menu of AppIcons. These menu items would have been
	added with the @{"DAE_ToggleMenu" LINK "dopus/appicon.h/File" 19} and @{"DAE_ToggleMenuSel" LINK "dopus/appicon.h/File" 20} tags.@{b}

    INPUTS@{ub}
	icon - icon to act on, as returned by AddAppIcon()
	item - number of item to change (in the order they were added)
	state - new state for the item (TRUE=selected)@{b}

    RESULT@{ub}
	Returns the old selection state of the item.@{b}

    NOTES@{ub}
	This routine uses 0 as a base ID for the menu items, even if you
	specified a new base with @{"DAE_MenuBase" LINK "dopus/appicon.h/File" 23}.@{b}

    SEE ALSO@{ub}
	@{"ChangeAppIcon()" LINK "ChangeAppIcon"}, workbench.library/AddAppIcon

@ENDNODE
@NODE "SetWBArg" "SetWBArg()"
@{b}

    NAME@{ub}
	SetWBArg - fill out a WBArg entry in a @{"DOpusAppMessage" LINK "dopus/appicon.h/File" 68}@{b}

    SYNOPSIS@{ub}
	SetWBArg(msg, item, lock, name, memory)
		  A0   D0    D1    A1     A2

	BOOL SetWBArg(@{"DOpusAppMessage" LINK "dopus/appicon.h/File" 68} *, short, BPTR, char *, APTR);@{b}

    FUNCTION@{ub}
	This routine makes it easy to initialise the WBArg structures
	in an AppMessage (or a @{"DOpusAppMessage" LINK "dopus/appicon.h/File" 68}).@{b}

    INPUTS@{ub}
	msg - AppMessage to initialise
	item - item to initialise (starting at 0)
	lock - lock on parent directory
	name - name of file
	memory - memory handle or NULL@{b}

    RESULT@{ub}
	The specified WBArg in the AppMessage is initialised with the
	lock and name specified. This routine returns TRUE if it was
	successful.@{b}

