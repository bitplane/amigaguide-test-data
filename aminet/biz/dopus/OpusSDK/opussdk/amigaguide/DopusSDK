@NODE "AllocTimer" "AllocTimer()"
@{b}

    NAME@{ub}
	AllocTimer - allocate a timer handle@{b}

    SYNOPSIS@{ub}
	AllocTimer(unit, port)
		    D0    A0

	@{"TimerHandle" LINK "dopus/timer.h/File" 10} *AllocTimer(ULONG, struct MsgPort *);@{b}

    FUNCTION@{ub}
	This function allocates a timer handle to enable easy use of the
	timer.device. You can supply a message port for it to use,
	or have it create one for you. If you do not supply a message port,
	the "port" field of the returned @{"TimerHandle" LINK "dopus/timer.h/File" 10} structure contains
	the address of the port that was created for you.@{b}

    INPUTS@{ub}
	unit - the timer.device unit you wish to use (eg UNIT_VBLANK)
	port - message port to use (or NULL to have one created)@{b}

    RESULT@{ub}
	Returns a @{"TimerHandle" LINK "dopus/timer.h/File" 10} to use with the other functions.@{b}

    SEE ALSO@{ub}
	@{"FreeTimer()" LINK "FreeTimer"}, @{"StartTimer()" LINK "StartTimer"}

@ENDNODE
@NODE "CheckTimer" "CheckTimer()"
@{b}

    NAME@{ub}
	CheckTimer - see if a timer request has completed@{b}

    SYNOPSIS@{ub}
	CheckTimer(handle)
		     A0

	BOOL CheckTimer(@{"TimerHandle" LINK "dopus/timer.h/File" 10} *);@{b}

    FUNCTION@{ub}
	This function allows you to discover if a timer request you have
	started has completed.@{b}

    INPUTS@{ub}
	handle - timer handle@{b}

    RESULT@{ub}
	Returns TRUE if the request is complete, or FALSE if it has not
	completed or is invalid.@{b}

    SEE ALSO@{ub}
	@{"StartTimer()" LINK "StartTimer"}, @{"StopTimer()" LINK "StopTimer"}

@ENDNODE
@NODE "FreeTimer" "FreeTimer()"
@{b}

    NAME@{ub}
	FreeTimer - free a timer handle@{b}

    SYNOPSIS@{ub}
	FreeTimer(handle)
		    A0

	void FreeTimer(@{"TimerHandle" LINK "dopus/timer.h/File" 10} *);@{b}

    FUNCTION@{ub}
	This function frees a timer handle created with @{"AllocTimer()" LINK "AllocTimer"}. Any
	outstanding request is aborted automatically. If you supplied your
	own message port to the @{"AllocTimer()" LINK "AllocTimer"} function, you are responsible
	for deleting the port yourself.@{b}

    INPUTS@{ub}
	handle - timer handle@{b}

    SEE ALSO@{ub}
	@{"AllocTimer()" LINK "AllocTimer"}

@ENDNODE
@NODE "GetTimerBase" "GetTimerBase()"
@{b}

    NAME@{ub}
	GetTimerBase - get a pointer to the timer.device library base@{b}

    SYNOPSIS@{ub}
	GetTimerBase()

	struct Library *GetTimerBase(void);@{b}

    FUNCTION@{ub}
	This function returns a pointer to the library base of the
	timer.device. The library base pointer is needed if you want to call
	any of the library functions of the timer.device. This routine saves
	you having to open the timer.device to get this base pointer.@{b}

