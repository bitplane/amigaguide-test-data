@NODE "AddObjectList" "AddObjectList()"
@{b}

    NAME@{ub}
	AddObjectList - add a list of objects to a window@{b}

    SYNOPSIS@{ub}
	AddObjectList(window, objects)
			A0       A1

	@{"ObjectList" LINK "dopus/layout.h/File" 184} *AddObjectList(struct Window *, @{"ObjectDef" LINK "dopus/layout.h/File" 74} *);@{b}

