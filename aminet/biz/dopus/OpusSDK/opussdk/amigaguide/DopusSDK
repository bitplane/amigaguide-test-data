	this pointer.

@ENDNODE
@NODE "StartTimer" "StartTimer()"
@{b}

    NAME@{ub}
	StartTimer - send a timer request@{b}

    SYNOPSIS@{ub}
	StartTimer(handle, seconds, micros)
		     A0       D0      D1

	void StartTimer(@{"TimerHandle" LINK "dopus/timer.h/File" 10} *, ULONG, ULONG);@{b}

    FUNCTION@{ub}
	This function starts a timer request for a given period of time.
	Your code should wait on "handle->port" for a signal indicating a
	completed request. You can call @{"CheckTimer()" LINK "CheckTimer"} at any time to see if
	the request has been completed.@{b}

    INPUTS@{ub}
	handle - timer handle
	seconds - number of seconds for the request
	micros - number of microseconds (0-999999)@{b}

    NOTES@{ub}
	You can call this routine with a request already pending; the first
	request will automatically be aborted.@{b}

    SEE ALSO@{ub}
	@{"AllocTimer()" LINK "AllocTimer"}, @{"StopTimer()" LINK "StopTimer"}, @{"CheckTimer()" LINK "CheckTimer"}

@ENDNODE
@NODE "StopTimer" "StopTimer()"
@{b}

    NAME@{ub}
	StopTimer - stop a timer request in progress@{b}

    SYNOPSIS@{ub}
	StopTimer(handle)
		    A0

	void StopTimer(@{"TimerHandle" LINK "dopus/timer.h/File" 10} *);@{b}

    FUNCTION@{ub}
	This function aborts a timer request that was previously started
	with @{"StartTimer()" LINK "StartTimer"}. If the request has already completed, this
	function simply does the cleanup.@{b}

    INPUTS@{ub}
	handle - timer handle@{b}

    SEE ALSO@{ub}
	@{"AllocTimer()" LINK "AllocTimer"}, @{"StartTimer()" LINK "StartTimer"}, @{"CheckTimer()" LINK "CheckTimer"}

@ENDNODE
@NODE "TimerActive" "TimerActive()"
@{b}

    NAME@{ub}
	TimerActive - check if a timer request is pending@{b}

    SYNOPSIS@{ub}
	TimerActive(handle)
		      A0

	BOOL TimerActive(@{"TimerHandle" LINK "dopus/timer.h/File" 10} *);@{b}

    FUNCTION@{ub}
	If you lose track of (or can't be bothered keeping track of)
	whether or not you have a pending timer request, this function
	allows you to find out.

	This function is actually not really necessary. All the timer
	functions are robust enough to cope with multiple requests
	(a @{"StartTimer()" LINK "StartTimer"} with an already-pending request), or a @{"StopTimer()" LINK "StopTimer"}
	when a request is already complete (or was never sent), or any of
	the other "error" conditions that the timer.device is usually
	sensitive to.@{b}

    INPUTS@{ub}
	handle - timer handle@{b}

    RESULT@{ub}
	Returns TRUE if there is a request pending.@{b}

    SEE ALSO@{ub}
	@{"AllocTimer()" LINK "AllocTimer"}

@ENDNODE
