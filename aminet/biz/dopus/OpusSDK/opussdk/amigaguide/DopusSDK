@NODE "FindAppWindow" "FindAppWindow()"
@{b}

    NAME@{ub}
	FindAppWindow - test to see if a window is an AppWindow@{b}

    SYNOPSIS@{ub}
	FindAppWindow(window)
			A0

	APTR FindAppWindow(struct Window *);@{b}

    FUNCTION@{ub}
	This routine allows you to discover whether a Window is in fact
	an AppWindow.@{b}

    INPUTS@{ub}
