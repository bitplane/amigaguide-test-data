    NOTES@{ub}
	This routine is useful in allowing you to find an item to set the state
	of the @{"POPUPF_CHECKED" LINK "dopus/popup.h/File" 21} and @{"POPUPF_DISABLED" LINK "dopus/popup.h/File" 23} flags.@{b}

    SEE ALSO@{ub}
	@{"DoPopUpMenu()" LINK "DoPopUpMenu"}

