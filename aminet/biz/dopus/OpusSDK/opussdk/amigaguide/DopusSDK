@NODE "DoPopUpMenu" "DoPopUpMenu()"
@{b}

    NAME@{ub}
	DoPopUpMenu - display a popup menu@{b}

    SYNOPSIS@{ub}
	DoPopUpMenu(window, menu, itemptr, button)
		      A0     A1      A2      D0

	USHORT DoPopUpMenu(struct Window *, @{"PopUpMenu" LINK "dopus/popup.h/File" 35} *, @{"PopUpItem" LINK "dopus/popup.h/File" 11} **, USHORT);@{b}

    FUNCTION@{ub}
	This routine displays a popup menu. The @{"PopUpMenu" LINK "dopus/popup.h/File" 35} structure must be
	initialised as follows:

	    item_list - a list of the menu items

	    locale    - a pointer to an initialised DOpusLocale structure

	    flags     - menu flags. Currently supported flags are:

			    @{"POPUPMF_HELP" LINK "dopus/popup.h/File" 43}    - menu supports help via the user
					      pressing the help key

			    @{"POPUPMF_REFRESH" LINK "dopus/popup.h/File" 44} - the callback function supplied
					      should be used to refresh the
					      parent window

			    @{"POPUPMF_ABOVE" LINK "dopus/popup.h/File" 45}   - the popup menu should open
					      above the parent window, instead
					      of over the current mouse
					      position

	    callback  - pointer to your refresh callback function, or NULL

	The callback function is a function that you define to handle the
	situation when the parent window needs to be refreshed. If the parent
	window is simplerefresh, you should provide this function. The function
	has the following prototype:

	    void __asm refresh_callback(    register __d0 ULONG type,
					    register __a0 struct Window *window,
					    register __a1 ULONG userdata )

	The routine will be called whenever the parent window needs to be
	refreshed. 'type' is the IDCMP message type; usually
	IDCMP_REFRESHWINDOW. 'window' is a pointer to the parent window, and
	'userdata' is the userdata field of the @{"PopUpMenu" LINK "dopus/popup.h/File" 35} structure.

	The 'item_list' parameter is a MinList containing the items of the
	popup menu. Each node on this list is a @{"PopUpItem" LINK "dopus/popup.h/File" 11} structure, which is
	defined as follows :

	    item_name - pointer to item name

	    id	- item ID

	    flags     - item flags. Currently supported flags are:

			    @{"POPUPF_LOCALE" LINK "dopus/popup.h/File" 19}   - signifies that 'item_name' is
					      not a pointer to a string, but
					      is a locale ID representing a
					      string in the supplied locale.

			    @{"POPUPF_CHECKIT" LINK "dopus/popup.h/File" 20}  - item can be checked, much like
					      CHECKIT in Intuition menus

			    @{"POPUPF_CHECKED" LINK "dopus/popup.h/File" 21}  - item starts out checked, much
					      like CHECKED in Intuition menus

			    @{"POPUPF_SUB" LINK "dopus/popup.h/File" 22}      - item has sub-items

			    @{"POPUPF_DISABLED" LINK "dopus/popup.h/File" 23} - item is disabled

	    data      - unless @{"POPUPF_SUB" LINK "dopus/popup.h/File" 22} is set, this is a userdata field
			that can be set to anything. If @{"POPUPF_SUB" LINK "dopus/popup.h/File" 22} is set, this
			field must point to an initialised MinList containing
			the @{"PopUpItem" LINK "dopus/popup.h/File" 11} structures for the sub-menu. You can
			have up to four levels of sub-menus.

	Set 'item_name' to the special value @{"POPUP_BARLABEL" LINK "dopus/popup.h/File" 25} to produce a
	separator bar in the menu.@{b}

    INPUTS@{ub}
	window  - Parent window to open menu over
	menu    - @{"PopUpMenu" LINK "dopus/popup.h/File" 35} to open
	itemptr - Pointer to location to receive a pointer to the selected
		  item
	button  - The code of the mouse button pressed to generate this menu.
		  This is used to control which mouse button release will
		  remove the menu (eg, if you pass SELECTDOWN for the 'button'
		  value, the menu will be removed on a SELECTUP event)@{b}

    RESULT@{ub}
	Returns -1 if no item was selected. If an item was selected,
	the item ID is returned, and the address of the @{"PopUpItem" LINK "dopus/popup.h/File" 11} structure
	is stored in 'itemptr'. If the user pressed the help key over an item
	and the @{"POPUPMF_HELP" LINK "dopus/popup.h/File" 43} flag is set, the @{"POPUP_HELPFLAG" LINK "dopus/popup.h/File" 27} flag will be
	set in the returned item ID.@{b}

    SEE ALSO@{ub}
	@{"GetPopUpItem()" LINK "GetPopUpItem"}

@ENDNODE
@NODE "GetPopUpItem" "GetPopUpItem()"
@{b}

    NAME@{ub}
	GetPopUpItem - find a @{"PopUpItem" LINK "dopus/popup.h/File" 11} by ID@{b}

    SYNOPSIS@{ub}
	GetPopUpItem(menu, id)
		      A0   D0

	@{"PopUpItem" LINK "dopus/popup.h/File" 11} *GetPopUpItem(@{"PopUpMenu" LINK "dopus/popup.h/File" 35} *, USHORT);@{b}

