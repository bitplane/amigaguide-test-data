@NODE Funktionen "FWCalcTab: Tabellen-Funktionen"
@TOC Funktionen
@{FG SHINE}
     _____________________________________________________________________
@{FG TEXT}
     @{B}Folgende Funktionen stehen zur Auswahl:

        =(Zelle@{B}
                  +   Addition
                  -   Subtraktion
                  %   ganzzahlige Division
                  //  Rest
                  /   reele Division
                  *   Multiplikation
                  **  Potenzierung
                  ()  Klammerrechnungen@{B}
            Zelle)
@{B}
        =SUMME@{UB}(Zelle:Zelle) o.          (der Syntax wegen)
        =(Zelle:Zelle)                  Summe aus @{" Zirkelbezug " link Zirkel}@{B}

        =MITTELWERT@{UB}(Zelle;Zelle ... ),  vorher DURCHSCHNITT !!!@{B}
        =MITTELWERT@{UB}(Zelle:Zelle)        Mittelwert aus Zirkelbezug@{B}

        =MAX@{UB}(Zelle;Zelle...)            Maximum aus den angegebenen Zellen@{B}
        =MAX@{UB}(Zelle:Zelle)               Maximum aus Zirkelbezug@{B}

        =MIN@{UB}(Zelle;Zelle...)            Minimum aus den angegebenen Zellen@{B}
        =MIN@{UB}(Zelle:Zelle)               Minimum aus Zirkelbezug@{B}

        =DATE@{UB}                           Aktuelles Datum@{B}
        =TIME@{UB}                           Aktuelle Uhrzeit
     _____________________________________________________________________
@{FG SHINE}     _____________________________________________________________________
@{FG TEXT}
     @{B}Das Eingabeformat:@{UB}

            z.B. in D5: =(A1+B2+C3/10) eintragen,

        wobei Groß- und Kleinschreibung sowie Leerzeichen, egal sind.
     _____________________________________________________________________


@PREV Funktionen
@NEXT Funktionen
@ENDNODE
@NODE Zirkel "FWCalcTab: Zirkelbezug"
@PREV Zirkel
@TOC Zirkel
@{FG SHINE}
     _____________________________________________________________________
@{FG TEXT}
     @{B}Zirkelbezug:@{UB}

        Für alle die wenig mit Tabellenkalkulationen zu tun haben:

        Wenn ich z.B. einen Zirkelbezug A1:B3 eingebe, werden die Zellen
        A1, A2, A3, B1, B2 und B3 in die Rechnung miteinbezogen.
     _____________________________________________________________________


@NEXT Zirkel
@ENDNODE
@NODE ResBold "FWCalcTab: Prefs: ResBold"
@PREV Prefs
@TOC prefs
@{FG SHINE}
     _____________________________________________________________________
@{FG TEXT}
     @{B}1 = ResBold EIN
     0 = ResBold AUS

     eingestellt ist 1 @{UB}

       Die Ergebnisse werden on Bold ausgegeben.
     _____________________________________________________________________


@ENDNODE
@NODE ResNegMarg "FWCalcTab: Prefs: ResNegMark"
@TOC prefs
@{FG SHINE}
     _____________________________________________________________________
@{FG TEXT}
     @{B}1 = ResNegMark EIN
     0 = ResNegMark AUS

     eingestellt ist 1 @{UB}

       Negative Ergebnisse werden in ROT ausgegeben.
     _____________________________________________________________________

     Die Farbe wird in der Catalog-Datei eingestellt, da die Farb-Angaben
     von der Final-Writer-Sprachversion abhängig sind


@ENDNODE
