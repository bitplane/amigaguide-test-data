     _____________________________________________________________________

     @{B}Muß in Anführungszeichen stehen!@{UB}


@ENDNODE
@NODE Helpguide "FWCalcTab: Prefs: HelpGuide"
@TOC prefs
@{FG SHINE}
     _____________________________________________________________________
@{FG TEXT}
