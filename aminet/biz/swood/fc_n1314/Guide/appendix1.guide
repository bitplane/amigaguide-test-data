@node func_ABOVE "Formula Function: ABOVE..."
@{fg highlight}ABOVE@{fg text}
Value or address of cell above the current cell.

@{b}Format:@{ub}
ABOVE

@{b}Input:@{ub}
None

@{b}Output:@{ub}
cell:
  address or value of cell above current cell

@{b}Example:@{ub}
=above+1    = cell above + 1
=row(above) = row number of cell above

@{b}See Also:@{ub}
@{"BELOW" link func_BELOW }, @{"LEFT" link func_LEFT }, @{"RIGHT" link func_RIGHT }
@endnode


@node func_ABS "Formula Function: ABS..."
@{fg highlight}ABS@{fg text}
Absolute Value of a number.

@{b}Format:@{ub}
ABS(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
number:	absolute value of x

@{b}Example:@{ub}
abs(-1) = 1
abs(1) = 1
@endnode

@node func_ACOS "Formula Function: ACOS..."
@{fg highlight}ACOS@{fg text}
Arc cosine of a number.

@{b}Format:@{ub}
ACOS(x)

@{b}Input:@{ub}
number: x   (limits: -1.0 to 1.0)

@{b}Output:@{ub}
number: arc cosine of x
ERROR:	if input exceed limits

@{b}Example:@{ub}
acos(0.2) = 1.36943
@endnode

@node func_ACOSH "Formula Function: ACOSH..."
@{fg highlight}ACOSH@{fg text}
Inverse hyperbolic cosine of a number.

@{b}Format:@{ub}
ACOSH(x)

@{b}Input:@{ub}
number: x

@{b}Output:@{ub}
number: inverse hyperbolic cosine of x

@{b}Example:@{ub}
acosh(12) = 3.167313
@endnode

@node func_ACOTH "Formula Function: ACOTH..."
@{fg highlight}ACOTH@{fg text}
Inverse hyperbolic cotangent of x.

@{b}Format:@{ub}
ACOSH(x)

@{b}Input:@{ub}
number: x

@{b}Output:@{ub}
number: inverse hyperbolic cotangent of x

@{b}Example:@{ub}
acoth(12) = 0.083527042
@endnode

@node func_ALPHA "Formula Function: ALPHA..."
@{fg highlight}ALPHA@{fg text}
Least Squares Method Function - Alpha Value.

@{b}Format:@{ub}
ALPHA(range)

@{b}Input:@{ub}
range:
  Two-column range, with a minimum of 2 rows.  The first
  column must contain the X values (independant variable),
  and the second column must contain the Y values
  (dependant variable)

@{b}Output:@{ub}
number:	'a' value for the formula  y=a+bx

@{b}Example:@{ub}
alpha(a1:b10)

@{b}See Also:@{ub}
@{"BETA" link func_BETA }, @{"CORR" link func_CORR }, @{"COVAR" link func_COVAR }
@endnode

@node func_ASIN "Formula Function: ASIN..."
@{fg highlight}ASIN@{fg text}
Arc sine of a number.

@{b}Format:@{ub}
ASIN(x)

@{b}Input:@{ub}
number: x   (limits: -1.0 to 1.0)

@{b}Output:@{ub}
number: arc sine of x
ERROR:	if input exceed limits

@{b}Example:@{ub}
asin(0.2) = 0.201357921
@endnode

@node func_ASINH "Formula Function: ASINH..."
@{fg highlight}ASINH@{fg text}
Inverse hyperbolic sine of a number.

@{b}Format:@{ub}
ASINH(x)

@{b}Input:@{ub}
number: x

@{b}Output:@{ub}
number: inverse hyperbolic sine of x

@{b}Example:@{ub}
asinh(12) = 3.179785438
@endnode

@node func_ATAN "Formula Function: ATAN..."
@{fg highlight}ATAN@{fg text}
Arc tangent of a number.

@{b}Format:@{ub}
ATAN(x)

@{b}Input:@{ub}
number: x

@{b}Output:@{ub}
number: Arc tangent of x

@{b}Example:@{ub}
atan(12) = 1.487655095
@endnode

@node func_ATAN2 "Formula Function: ATAN2..."
@{fg highlight}ATAN2@{fg text}
Arc tangent of two numbers.

@{b}Format:@{ub}
ATAN2(x,y)

@{b}Input:@{ub}
number:	x
number: y

@{b}Output:@{ub}
number:	Arc tangent of x/y in the range -pi to +pi
ERROR:	If inputs x and y are both zero

@{b}Example:@{ub}
atan2(1,2) = 0.463647609
@endnode

@node func_ATANH "Formula Function: ATANH..."
@{fg highlight}ATANH@{fg text}
Inverse hyperbolic tangent of a number.

@{b}Format:@{ub}
ATANH(x)

@{b}Input:@{ub}
number:	x	(limits: x^2 <= 1.0)

@{b}Output:@{ub}
number:	inverse hyperbolic tangent of x
ERROR:	if x exceeds limits

@{b}Example:@{ub}
atanh(0.2) = 0.202732554
@endnode

@node func_AVG "Formula Function: AVG..."
@{fg highlight}AVG@{fg text}
Average of one or more numeric values.

@{b}Format:@{ub}
AVG(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells that contain numeric values
 - ranges (only cells with numeric contents in the range are used)

Null arguments, e.g. =avg(10,,5), are accepted, but are only
used to increase the 'count'.  The above formula will produce
5 (15/3) not 7.5 (15/2).

@{b}Output:@{ub}
number:
  Average value of all arguments provided.  This is defined
  as the sum of all numeric values in the arguments provided
  divided by the 'count' of arguments provided.

  'count' is the number of numeric arguments, plus number
  of cells arguments, plus number of cells with contents
  in range arguments.

@{b}Example:@{ub}
avg(a1:b10,12,100,a1/23))
avg(100,a1,b10:c20,cos(12))

@{b}See Also:@{ub}
@{"COUNT" link func_COUNT }, @{"SUM" link func_SUM }, @{"CAVG" link func_CAVG }, @{"FAVG" link func_FAVG d}
@endnode

@node func_BELOW "Formula Function: BELOW..."
@{fg highlight}BELOW@{fg text}
Value or address of cell below the current cell.

@{b}Format:@{ub}
BELOW

@{b}Input:@{ub}
None

@{b}Output:@{ub}
cell:
  address or value of cell above below cell

@{b}Example:@{ub}
=below+1    = cell below + 1
=row(below) = row number of cell below

@{b}See Also:@{ub}
@{"ABOVE" link func_ABOVE }, @{"LEFT" link func_LEFT }, @{"RIGHT" link func_RIGHT }
@endnode

@node func_BETA "Formula Function: BETA..."
@{fg highlight}BETA@{fg text}
Least Squares Method Function - Beta Value.

@{b}Format:@{ub}
BETA(range)

@{b}Input:@{ub}
range:
  Two-column range, with a minimum of 2 rows.  The first
  column must contain the X values (independant variable),
  and the second column must contain the Y values
  (dependant variable).

@{b}Output:@{ub}
number:	'b' value for the formula  y=a+bx

@{b}Example:@{ub}
beta(a1:b10)

@{b}See Also:@{ub}
@{"ALPHA" link func_ALPHA }, @{"CORR" link func_CORR }, @{"COVAR" link func_COVAR }
@endnode

@node func_BIN "Formula Function: BIN..."
@{fg highlight}BIN@{fg text}
Convert a number to a binary string.

@{b}Format:@{ub}
BIN(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
string:	binary string equivalent of x

@{b}Example:@{ub}
bin(12) = "1100"

@{b}See Also:@{ub}
@{"BINTO" link func_BINTO }
@endnode

@node func_BINTO "Formula Function: BINTO..."
@{fg highlight}BINTO@{fg text}
Convert a binary string to a number.

@{b}Format:@{ub}
BINTO(str)

@{b}Input:@{ub}
string:	str (consisting of 1's and 0's)

@{b}Output:@{ub}
number:	value of binary number in str

@{b}Example:@{ub}
binto("1100") = 12

@{b}See Also:@{ub}
@{"BIN" link func_BIN }
@endnode

@node func_CASE "Formula Function: CASE..."
@{fg highlight}CASE@{fg text}
Select an entry from a list.

@{b}Format:@{ub}
CASE(x,v1,v2,v3,....,vn)

@{b}Input:@{ub}
number:	
  x 	(limits: x >= 1)
entry:	
  one or more numbers and/or strings
  v1, v2, v3, ... vn

@{b}Output:@{ub}
number:
  returns v1 if x = 1, v2 if x = 2, v3 if x = 3, etc.
ERROR:
  if x < 1 or x > number of values

CASE() will also return a cell or range address if used as a
cell or range argument to another function.

@{b}Example:@{ub}
case(2,11,22,33,44) = 22
case(1,11,22,33,44) = 11
case(3,"one","two","three","four") = "three"

@{b}See Also:@{ub}
@{"PICK" link func_PICK }, @{"CHOOSE" link func_CHOOSE }
@endnode

@node func_CAVG "Formula Function: CAVG..."
@{fg highlight}CAVG@{fg text}
Average of multiple numbers conditionally selected.

@{b}Format:@{ub}
CAVG(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is tested for every
  cell in 'arguments' below, and if the expression is
  true (non-zero) then the cell is considered as a
  valid argument, otherwise the cell is ignored.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  average value of all numeric cells for which
  expression was true.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

=cavg(here>5,a1:a10)

This will give you the average of all cells in the range a1:a10
which have a value higher than 5.

=cavg((here>=5)&(here<=10),a1:a10)

This will give you the average of cells in the range a1:a10
which have a value between 5 and 10.

@{b}See Also:@{ub}
@{"AVG" link func_AVG }, @{"CCOUNT" link func_CCOUNT }, @{"CSUM" link func_CSUM }, @{"FAVG" link func_FAVG }
@endnode

@node func_CCOUNT "Formula Function: CCOUNT..."
@{fg highlight}CCOUNT@{fg text}
Count number of cells within a range that meet specific criteria.

@{b}Format:@{ub}
CCOUNT(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is tested for every
  cell in 'arguments' below, and if the expression is
  true (non-zero) then the cell is considered as a
  valid argument, otherwise the cell is ignored.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  number of valid numeric cells for which expression
  was true.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

=ccount(here>5,a1:a10)

This will give you the number of cells in the range a1:a10
which have a value higher than 5.

=ccount((here>=5)&(here<=10),a1:a10)

This will give you the number of cells in the range a1:a10
which have a value between 5 and 10.

@{b}See Also:@{ub}
@{"COUNT" link func_COUNT }, @{"CAVG" link func_CAVG }, @{"CSUM" link func_CSUM }
@endnode

@node func_CELL "Formula Function: CELL..."
@{fg highlight}CELL@{fg text}
Get value of a specific cell in current sheet or another sheet.

@{b}Format:@{ub}
CELL(column,row)
CELL(sheet,column,row)

@{b}Input:@{ub}
sheet:	[optional] sheet number from 1 to 254
column:	column number, from 0 to 18277
row:	row number, from 1 to 65000

@{b}Output:@{ub}
contents of the cell defined by arguments column and row in
the current sheet, or in another sheet (if 'sheet' is used).

@{b}Example:@{ub}
cell(0,1) = value of cell a1 in the current sheet
cell(2,0,1) = value of cell a1 in sheet B

@{b}Notes:@{ub}
CELL() is a LIVE function.  It is evaluated at every recalc.

CELL() does not guarantee the returned value is totally correct
if Minimal Recalc is used.  It is guaranteed to return the
correct value only if Full Recalc is used.

The INDEX() function is generally much safer.

@{b}See Also:@{ub}
@{"INDEX" link func_INDEX }
@endnode

@node func_CFIRST "Formula Function: CFIRST..."
@{fg highlight}CFIRST@{fg text}
Get first cell within a range that meets specific criteria.

@{b}Format:@{ub}
CFIRST(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is tested for every
  cell in 'arguments' below, and if the expression is
  true (non-zero) then the cell is considered as a
  valid argument, otherwise the cell is ignored.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number or string:
  value of the first cell for which expression was true.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

=cfirst(here>5,a1:a10)

This will give you the first cell in the range a1:a10 that has
a value higher than 5.

=cfirst((here>=5)&(here<=10),a1:a10)

This will give you the value of the first cell in the range
a1:a10 that has a value between 5 and 10.

@{b}See Also:@{ub}
@{"FIRST" link func_FIRST }, @{"CLAST" link func_CLAST }, @{"CPICK" link func_CPICK }
@endnode

@node func_CHAR "Formula Function: CHAR..."
@{fg highlight}CHAR@{fg text}
Get ASCII character.

@{b}Format:@{ub}
CHAR(x)

@{b}Input:@{ub}
number: x	(x between 0 and 255)

@{b}Output:@{ub}
string:	single character string representing ASCII value of x.

@{b}Example:@{ub}
char(75) = "K"

@{b}See Also:@{ub}
@{"CODE" link func_CODE }
@endnode

@node func_CHOOSE "Formula Function: CHOOSE..."
@{fg highlight}CHOOSE@{fg text}
Select an entry from a list.

@{b}Format:@{ub}
CHOOSE(x,v1,v2,v3,....,vn)

@{b}Input:@{ub}
number:
  x 	(limits: x >= 1)
entry:	
  one or more numbers and/or strings
  v1, v2, v3, ... vn

@{b}Output:@{ub}
number:	returns v1 if x = 1, v2 if x = 2, v3 if x = 3, etc.
ERROR:	if x < 1 or x > number of values

CHOOSE() will also return a cell or range address if used as a
cell or range argument to another function.

@{b}Example:@{ub}
choose(2,11,22,33,44) = 22
choose(1,11,22,33,44) = 11
choose(3,"one","two","three","four") = "three"

@{b}See Also:@{ub}
@{"PICK" link func_PICK }, @{"CASE" link func_CASE }
@endnode

@node func_CLAST "Formula Function: CLAST..."
@{fg highlight}CLAST@{fg text}
Get last cell within a range that meets specific criteria.

@{b}Format:@{ub}
CLAST(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is tested for every
  cell in 'arguments' below, and if the expression is
  true (non-zero) then the cell is considered as a
  valid argument, otherwise the cell is ignored.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number or string:
  value of the last cell for which expression was true.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

=clast(here>5,a1:a10)

This will give you the last cell in the range a1:a10 that has
a value higher than 5.

=clast((here>=5)&(here<=10),a1:a10)

This will give you the value of the last cell in the range
a1:a10 that has a value between 5 and 10.

@{b}See Also:@{ub}
@{"LAST" link func_LAST }, @{"CFIRST" link func_CFIRST }, @{"CPICK" link func_CPICK }
@endnode

@node func_CLEAN "Formula Function: CLEAN..."
@{fg highlight}CLEAN@{fg text}
Clean a string from any non-printable characters.

@{b}Format:@{ub}
CLEAN(str)

@{b}Input:@{ub}
string:	str

@{b}Output:@{ub}
string:	
  identical to 'str' except that any non-printable
  characters are removed.  Non-printable characters are
  defined as ASCII characters 0 to 31 and 128 to 159.
@endnode

@node func_CMAX "Formula Function: CMAX..."
@{fg highlight}CMAX@{fg text}
Highest value of multiple numbers conditionally selected.

@{b}Format:@{ub}
CMAX(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is tested for every
  cell in 'arguments' below, and if the expression is
  true (non-zero) then the cell is considered as a
  valid argument, otherwise the cell is ignored.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  highest value of all numeric cells for which
  expression was true.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

=cmax(here<5,a1:a10)

This will give you the highest value of all cells in the range
a1:a10 which have a value lower than 5.

=cmax((here>=5)&(here<=10),a1:a10)

This will give you the highest value of cells in the range
a1:a10 which have a value between 5 and 10.

@{b}See Also:@{ub}
@{"MAX" link func_MAX }, @{"CMIN" link func_CMIN }
@endnode

@node func_CMIN "Formula Function: CMIN..."
@{fg highlight}CMIN@{fg text}
Lowest value of multiple numbers conditionally selected.

@{b}Format:@{ub}
CMIN(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is tested for every
  cell in 'arguments' below, and if the expression is
  true (non-zero) then the cell is considered as a
  valid argument, otherwise the cell is ignored.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  lowest value of all numeric cells for which expression
  was true.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

=cmin(here>5,a1:a10)

This will give you the lowest value of all cells in the range
a1:a10 which have a value higher than 5.

=cmin((here>=5)&(here<=10),a1:a10)

This will give you the lowest value of cells in the range
a1:a10 which have a value between 5 and 10.

@{b}See Also:@{ub}
@{"MIN" link func_MIN }, @{"CMAX" link func_CMAX }
@endnode

@node func_CODE "Formula Function: CODE..."
@{fg highlight}CODE@{fg text}
Get ASCII code of a character.

@{b}Format:@{ub}
CODE(str)

@{b}Input:@{ub}
string:	str (only first character in str is used)

@{b}Output:@{ub}
number:	ASCII value of first character in str

@{b}Example:@{ub}
code("t") = 116

@{b}See Also:@{ub}
@{"CHAR" link func_CHAR }
@endnode

@node func_COL "Formula Function: COL..."
@{fg highlight}COL@{fg text}
Get column number of a cell or range.

@{b}Format:@{ub}
COL()
COL(cell)
COL(range)
COL(range,cell)

@{b}Input:@{ub}
cell:	[optional] a cell name
range:	[optional] a range name

@{b}Output:@{ub}
Depends on arguments provided:

COL()
returns the column number of the current cell.

COL(cell)
returns the column number of the provided cell.

COL(range)
returns the column number of the top left cell in the provided range.

COL(range,cell)
returns the column offset of 'cell' in 'range', or ERROR if
'cell' is outside 'range'.

@{b}Example:@{ub}
col() = column number of current cell
col(c1) = 3 (column C)
col(c1:d1) = 3 (column C)
col(c1:e10,d1) = 1 (offset of column D to column C)

@{b}See Also:@{ub}
@{"COLS" link func_COLS }, @{"ROW" link func_ROW }
@endnode

@node func_COLOR "Formula Function: COLOR..."
@{fg highlight}COLOR@{fg text}
Get the Graph Color number.

@{b}Format:@{ub}
COLOR(str)

@{b}Input:@{ub}
string:
  str (string matching the name of a Graph Color)

@{b}Output:@{ub}
number:
  number of color in graph colors list, or 0 if it was
  not found.

@{b}Example:@{ub}
color("yellow") = 12 (number of color 'yellow')

color(if(a1>=0,"yellow","light red"))
  this will return the value of 'yellow' (12) if a1>=0,
  otherwise it will return the value of 'light red' (2).

@{b}See Also:@{ub}
@{"PATTERN" link func_PATTERN }, @{"SYMBOL" link func_SYMBOL }
@endnode

@node func_COLS "Formula Function: COLS..."
@{fg highlight}COLS@{fg text}
Get the number of columns in a range.

@{b}Format:@{ub}
COLS(range)

@{b}Input:@{ub}
range:	a range name

@{b}Output:@{ub}
number:	number of columns in range

@{b}Example:@{ub}
cols(a1:c1)	= 3

@{b}See Also:@{ub}
@{"ROWS" link func_ROWS }, @{"SHEETS" link func_SHEETS }
@endnode

@node func_COMB "Formula Function: COMB..."
@{fg highlight}COMB@{fg text}
Calculate the Combination possibilities of a selection of
distinct items from a group.

@{b}Format:@{ub}
COMB(n,r)

@{b}Input:@{ub}
number:	n
number: r

@{b}Output:@{ub}
number: 
  the Combination value (as used in Probability and
  Statistics)	which is usually defined as  nCr = nPr/r!
  (where nPr = n!/(n-r)!)

@{b}Example:@{ub}
If you have a group of five people: A, B, C, D and E and
wanted to select only three of them.  There would be
comb(5,3) = 12 possible selections:
ABC ABD ABE ACD ACE ADE BCD BCE BDE and CDE

@{b}Note:@{ub}
Rearranging items within an Combination does not give a
different combination, thus ABC and ACB are the same
combination.

@{b}See Also:@{ub}
@{"PERM" link func_PERM }
@endnode

@node func_CORR "Formula Function: CORR..."
@{fg highlight}CORR@{fg text}
Least Squares Method Function - Correlation Co-effecient.

@{b}Format:@{ub}
CORR(range)

@{b}Input:@{ub}
range:
  Two-column range, with a minimum of 2 rows.  The first
  column must contain the X values (independant variable),
  and the second column must contain the Y values
  (dependant variable)

@{b}Output:@{ub}
number:
  Correlation Co-effecient using the Least Squares Method
  between the dependant and independant variables.

@{b}Example:@{ub}
corr(a1:b10)

@{b}See Also:@{ub}
@{"ALPHA" link func_ALPHA }, @{"BETA" link func_BETA }, @{"COVAR" link func_COVAR }
@endnode

@node func_COS "Formula Function: COS..."
@{fg highlight}COS@{fg text}
Cosine of a number.

@{b}Format:@{ub}
COS(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
number: cosine of x

@{b}Example:@{ub}
cos(12) = 0.843853959
@endnode

@node func_COSH "Formula Function: COSH..."
@{fg highlight}COSH@{fg text}
Hyperbolic cosine of a number.

@{b}Format:@{ub}
COSH(x)

@{b}Input:@{ub}
number:	x	(limit: x <= 709.778)

@{b}Output:@{ub}
number:	hyperbolic cosine of x
ERROR:	if x exceeds limits

@{b}Example:@{ub}
cosh(12) = 81377.3957
@endnode

@node func_COTAN "Formula Function: COTAN..."
@{fg highlight}COTAN@{fg text}
Cotangent of a number.

@{b}Format:@{ub}
COTAN(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
number: cotangent of x

@{b}Example:@{ub}
cotan(12) = -1.572673406
@endnode

@node func_COTH "Formula Function: COTH..."
@{fg highlight}COTH@{fg text}
Hyperbolic cotangent of a number.

@{b}Format:@{ub}
COTH(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
number: hyperbolic cotangent of x

@{b}Example:@{ub}
coth(1) = 1.313035285
@endnode

@node func_COUNT "Formula Function: COUNT..."
@{fg highlight}COUNT@{fg text}
Count of one or more numeric values.

@{b}Format:@{ub}
COUNT(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells that contain numeric values
 - ranges (only cells with numeric contents in the range are used)

Null arguments, e.g. =count(10,,5), are accepted, but are only
used to increase the 'count'.  The above formula will produce
a count of 3, not 2.

@{b}Output:@{ub}
number:
  Number of valid numeric arguments provided.  This is
  defined as the number of numeric arguments, plus number
  of cells arguments, plus number of cells with contents
  in range arguments.

@{b}Example:@{ub}
count(a1:b10,12,100)
count(100,a1,b10:c20)

@{b}See Also:@{ub}
@{"AVG" link func_AVG }, @{"SUM" link func_SUM }, @{"CCOUNT" link func_CCOUNT }, @{"FCOUNT" link func_FCOUNT }
@endnode

@node func_COVAR "Formula Function: COVAR..."
@{fg highlight}COVAR@{fg text}
Least Squares Method Function - Co-variance.

@{b}Format:@{ub}
COVAR(range)

@{b}Input:@{ub}
range:
  Two-column range, with a minimum of 2 rows.  The first
  column must contain the X values (independant variable),
  and the second column must contain the Y values
  (dependant variable)

@{b}Output:@{ub}
number:
  Covariance using the Least Squares Method between the
  dependant and independant variables.

@{b}Example:@{ub}
covar(a1:b10)

@{b}See Also:@{ub}
@{"ALPHA" link func_ALPHA }, @{"BETA" link func_BETA }, @{"CORR" link func_CORR }
@endnode

@node func_CPICK "Formula Function: CPICK..."
@{fg highlight}CPICK@{fg text}
Get a specific cell within a range that meets specific criteria.

@{b}Format:@{ub}
CPICK(offset,expression,multiple range arguments)

@{b}Input:@{ub}
number:
  offset, a positive or negative integer number.
  It is used to define which cell to select from
  the cells for which expression is true.

  If offset is positive, it picks cells from the
  start of the ranges defined.  If it is negative,
  it picks cells from the end of the ranges defined.

    3	use the 3rd argument
    2	use the 2nd argument
    1	use the 1st argument
    0	use the last argument
   -1	use the argument before last
   -2	use the 2nd argument before last
   -3	use the 3rd argument before last

expression:
  a formula expression.  This is tested for every
  cell in 'arguments' below, and if the expression is
  true (non-zero) then the cell is considered as a
  valid argument, otherwise the cell is ignored.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number or string:
  value of the selected cell for which expression was
  true.  If no cell was found, 0 is returned.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

=cpick(3,here>5,a1:a10)

This will give you the value of the third cell in the range
a1:a10 which has a value higher than 5.

=cpick(-2,(here>=5)&(here<=10),a1:a10)

This will give you the value of the 2nd to last cell in the
range a1:a10 which has a value between 5 and 10.

@{b}See Also:@{ub}
@{"PICK" link func_PICK }, @{"CFIRST" link func_CFIRST }, @{"CLAST" link func_CLAST }
@endnode

@node func_CSUM "Formula Function: CSUM..."
@{fg highlight}CSUM@{fg text}
Sum of multiple numbers conditionally selected.

@{b}Format:@{ub}
CSUM(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is tested for every
  cell in 'arguments' below, and if the expression is
  true (non-zero) then the cell is considered as a
  valid argument, otherwise the cell is ignored.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  sum of all numeric cells for which expression was true.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

=csum(here>5,a1:a10)

This will give you the sum of all cells in the range a1:a10
which have a value higher than 5.

=csum((here>=5)&(here<=10),a1:a10)

This will give you the sum of cells in the range a1:a10
which have a value between 5 and 10.

@{b}See Also:@{ub}
@{"SUM" link func_SUM }, @{"CAVG" link func_CAVG }, @{"CCOUNT" link func_CCOUNT }, @{"FSUM" link func_FSUM }
@endnode

@node func_DATE "Formula Function: DATE..."
@{fg highlight}DATE@{fg text}
Calculate the serial date number for a specific year, month and
day.

@{b}Format:@{ub}
DATE(year,month,day)

@{b}Input:@{ub}
number:	year (from 0 to 2100)
number: month (from 1 to 12)
number: day (from 1 to 31)

@{b}Output:@{ub}
date:
  serial date number for the day, month and year selected.

@{b}Example:@{ub}
date(1994,2,1) = 5875, which is the serial date number for
1-feb-1994.

@{b}See Also:@{ub}
@{"YEAR" link func_YEAR }, @{"MONTH" link func_MONTH }, @{"DAY" link func_DAY }, @{"TODAY" link func_TODAY }, @{"DATESTR" link func_DATESTR }, @{"DATEVALUE" link func_DATEVALUE }
@endnode

@node func_DATESTR "Formula Function: DATESTR..."
@{fg highlight}DATESTR@{fg text}
Convert a date number to a string using a specific format.

@{b}Format:@{ub}
DATESTR(str,date)

@{b}Input:@{ub}
string:	str (string containing a date format specification)
date:	date (serial date number)

@{b}Output:@{ub}
string:
  a string describing the date provided in the format
  provided.

@{b}Example:@{ub}
datestr("dd Mmm yyyy",TODAY) would return "01 Feb 1994"

@{b}See Also:@{ub}
@{"DATE" link func_DATE }, @{"DATEVALUE" link func_DATEVALUE }
@endnode

@node func_DATEVALUE "Formula Function: DATEVALUE..."
@{fg highlight}DATEVALUE@{fg text}
Convert date string to a date serial number.

@{b}Format:@{ub}
DATEVALUE(date string)

@{b}Input:@{ub}
string:	date string
  The date string should look like a date, i.e. day
  number, month name (3 characters at least) and year
  number.  Indirect date specifications are also
  accepted,  e.g. "next monday".  See Appendix 6 for
  details on date strings.

@{b}Output:@{ub}
date:	date serial number
ERROR:	if date string was not valid

@{b}Example:@{ub}
datevalue("1 feb 1994") =  5875, which is the serial date
number for 1-feb-1994.

Indirect date specification:

datevalue("next monday")
datevalue("second monday in jan 94")
datevalue("friday")
datevalue("next monday")
datevalue("last monday")
datevalue("second last monday")
datevalue("today")
datevalue("first monday in jan 94")
datevalue("last monday in feb")
datevalue("first tuesday next month")
datevalue("last tuesday this month")
datevalue("third friday last month")
datevalue("first day next year")

@{b}See Also:@{ub}
@{"DATESTR" link func_DATESTR }, @{"DATE" link func_DATE }
@endnode

@node func_DAVG "Formula Function: DAVG..."
@{fg highlight}DAVG@{fg text}
Average value of a selected field in a @{"database" link "FinalCalc:guide/part7.guide/Main"}.

@{b}Format:@{ub}
DAVG(offset)
DAVG(database input range, offset)
DAVG(offset, database criteria range)
DAVG(database input range, offset, database criteria range)

@{b}Input:@{ub}
range: [optional]
  Database input range.  If this is not defined, the default Data Input Range
  for the current sheet is used.

number:
  offset, selects the field (column) to use from the database input range.

range: [optional]
  Database critiera range.  If this is not defined, the default Data Criteria
  Range for the current sheet is used.

@{b}Output:@{ub}
number:
  average value of all entries in the selected field
  (column) in the database entries that match the
  database Search Criteria.
ERROR:
  if the database input or criteria ranges are not defined.

@{b}See Also:@{ub}
@{"DCOUNT" link func_DCOUNT }, @{"DSUM" link func_DSUM }, @{"DMIN" link func_DMIN }, @{"DMAX" link func_DMAX }, @{"DVAR" link func_DVAR }, @{"DSUM" link func_DSUM }
@endnode

@node func_DAY "Formula Function: DAY..."
@{fg highlight}DAY@{fg text}
Get day number from a serial date number.

@{b}Format:@{ub}
DAY(date)

@{b}Input:@{ub}
date:	serial date number

@{b}Output:@{ub}
number:
  from 1 to 31, the day number from the provided serial
  date number

@{b}Example:@{ub}
day(today) = 12  (if today was the 12th of the month)

@{b}See Also:@{ub}
@{"DATE" link func_DATE }, @{"MONTH" link func_MONTH }, @{"YEAR" link func_YEAR }, @{"TODAY" link func_TODAY }, @{"DATESTR" link func_DATESTR }, @{"DATEVALUE" link func_DATEVALUE }
@endnode

@node func_DAYS "Formula Function: DAYS..."
@{fg highlight}DAYS@{fg text}
Get the number of days in the month specified.

@{b}Format:@{ub}
DAYS(year,month)

@{b}Input:@{ub}
number:	year
number:	month

@{b}Output:@{ub}
number:
  number of days in the month and year specified.
  This takes into consideration leap years.

@{b}Example:@{ub}
days(1994,1) = 31 (days in the month of Jan 1994)

To get the number of days in the current month:
days(year(today),month(today))

@{b}See Also:@{ub}
@{"DATE" link func_DATE }, @{"DAY" link func_DAY }, @{"MONTH" link func_MONTH }, @{"YEAR" link func_YEAR }
@endnode

@node func_DCOUNT "Formula Function: DCOUNT..."
@{fg highlight}DCOUNT@{fg text}
Number of entries that match the search criteria in a selected
field in a @{"database" link "FinalCalc:guide/part7.guide/Main"}.

@{b}Format:@{ub}
DCOUNT(offset)
DCOUNT(database input range, offset)
DCOUNT(offset, database criteria range)
DCOUNT(database input range, offset, database criteria range)

@{b}Input:@{ub}
range: [optional]
  Database input range.  If this is not defined, the default Data Input Range
  for the current sheet is used.

number:
  offset, selects the field (column) to use from the database input range.

range: [optional]
  Database critiera range.  If this is not defined, the default Data Criteria
  Range for the current sheet is used.

@{b}Output:@{ub}
number:
  number of entries in the selected field (column) in the
  database entries that match the database Search
  Criteria.
ERROR:
  if the database input or criteria ranges are not defined.

@{b}See Also:@{ub}
@{"DSUM" link func_DSUM }, @{"DMIN" link func_DMIN }, @{"DMAX" link func_DMAX }, @{"DAVG" link func_DAVG }
@endnode

@node func_DEC "Formula Function: DEC..."
@{fg highlight}DEC@{fg text}
Convert decimal number to a string.

@{b}Format:@{ub}
DEC(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
string:	a string with the decimal value of x

@{b}Example:@{ub}
dec(123) = "123"

@{b}See Also:@{ub}
@{"STRING" link func_STRING }, @{"VALUE" link func_VALUE }, @{"HEX" link func_HEX }, @{"BIN" link func_BIN }
@endnode

@node func_DEGREES "Formula Function: DEGREES..."
@{fg highlight}DEGREES@{fg text}
Convert a number from radians to degrees.

@{b}Format:@{ub}
DEGREES(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
number:	value of x radians in degrees

@{b}Example:@{ub}
degrees(12) = 114.592

@{b}See Also:@{ub}
@{"RADIANS" link func_RADIANS }
@endnode

@node func_DMAX "Formula Function: DMAX..."
@{fg highlight}DMAX@{fg text}
Highest value of a selected field in a @{"database" link "FinalCalc:guide/part7.guide/Main"}.

@{b}Format:@{ub}
DMAX(offset)
DMAX(database input range, offset)
DMAX(offset, database criteria range)
DMAX(database input range, offset, database criteria range)

@{b}Input:@{ub}
range: [optional]
  Database input range.  If this is not defined, the default Data Input Range
  for the current sheet is used.

number:
  offset, selects the field (column) to use from the database input range.

range: [optional]
  Database critiera range.  If this is not defined, the default Data Criteria
  Range for the current sheet is used.

@{b}Output:@{ub}
number:
  highest value of all entries in the selected field
  (column) in the database entries that match the
  database Search Criteria.
ERROR:
  if the database input or criteria ranges are not defined.

@{b}See Also:@{ub}
@{"DCOUNT" link func_DCOUNT }, @{"DMIN" link func_DMIN }, @{"DAVG" link func_DAVG }, @{"DVAR" link func_DVAR }, @{"DSUM" link func_DSUM }
@endnode

@node func_DMIN "Formula Function: DMIN..."
@{fg highlight}DMIN@{fg text}
Lowest value of a selected field in a @{"database" link "FinalCalc:guide/part7.guide/Main"}.

@{b}Format:@{ub}
DMIN(offset)
DMAX(database input range, offset)
DMAX(offset, database criteria range)
DMAX(database input range, offset, database criteria range)

@{b}Input:@{ub}
range: [optional]
  Database input range.  If this is not defined, the default Data Input Range
  for the current sheet is used.

number:
  offset, selects the field (column) to use from the database input range.

range: [optional]
  Database critiera range.  If this is not defined, the default Data Criteria
  Range for the current sheet is used.


@{b}Output:@{ub}
number:
  lowest value of all entries in the selected field
  (column) in the database entries that match the
  database Search Criteria.
ERROR:
  if the database input or criteria ranges are not defined.

@{b}See Also:@{ub}
@{"DCOUNT" link func_DCOUNT }, @{"DMAX" link func_DMAX }, @{"DAVG" link func_DAVG }, @{"DVAR" link func_DVAR }, @{"DSUM" link func_DSUM }
@endnode

@node func_DSTD "Formula Function: DSTD..."
@{fg highlight}DSTD@{fg text}
Standard deviation of a selected field in a @{"database" link "FinalCalc:guide/part7.guide/Main"}.

@{b}Format:@{ub}
DSTD(offset)
DSTD(database input range, offset)
DSTD(offset, database criteria range)
DSTD(database input range, offset, database criteria range)

@{b}Input:@{ub}
range: [optional]
  Database input range.  If this is not defined, the default Data Input Range
  for the current sheet is used.

number:
  offset, selects the field (column) to use from the database input range.

range: [optional]
  Database critiera range.  If this is not defined, the default Data Criteria
  Range for the current sheet is used.


@{b}Output:@{ub}
number:
  standard deviation of all entries in the selected field
  (column) in the database entries that match the database
  Search Criteria.
ERROR:
  if the database input or criteria ranges are not defined.

@{b}See Also:@{ub}
@{"DCOUNT" link func_DCOUNT }, @{"DMAX" link func_DMAX }, @{"DMIN" link func_DMIN }, @{"DAVG" link func_DAVG }, @{"DVAR" link func_DVAR }
@endnode

@node func_DSUM "Formula Function: DSUM..."
@{fg highlight}DSUM@{fg text}
Sum of a selected field in a @{"database" link "FinalCalc:guide/part7.guide/Main"}.

@{b}Format:@{ub}
DSUM(offset)
DSUM(database input range, offset)
DSUM(offset, database criteria range)
DSUM(database input range, offset, database criteria range)

@{b}Input:@{ub}
range: [optional]
  Database input range.  If this is not defined, the default Data Input Range
  for the current sheet is used.

number:
  offset, selects the field (column) to use from the database input range.

range: [optional]
  Database critiera range.  If this is not defined, the default Data Criteria
  Range for the current sheet is used.


@{b}Output:@{ub}
number:
  sum of all entries in the selected field (column) in
  the database entries that match the database Search
  Criteria.
ERROR:
  if the database input or criteria ranges are not defined.

@{b}See Also:@{ub}
@{"DCOUNT" link func_DCOUNT }, @{"DMAX" link func_DMAX }, @{"DMIN" link func_DMIN }, @{"DAVG" link func_DAVG }, @{"DVAR" link func_DVAR }
@endnode

@node func_DVAR "Formula Function: DVAR..."
@{fg highlight}DVAR@{fg text}
Variance of a selected field in a @{"database" link "FinalCalc:guide/part7.guide/Main"}.

@{b}Format:@{ub}
DVAR(offset)
DVAR(database input range, offset)
DVAR(offset, database criteria range)
DVAR(database input range, offset, database criteria range)

@{b}Input:@{ub}
range: [optional]
  Database input range.  If this is not defined, the default Data Input Range
  for the current sheet is used.

number:
  offset, selects the field (column) to use from the database input range.

range: [optional]
  Database critiera range.  If this is not defined, the default Data Criteria
  Range for the current sheet is used.


@{b}Output:@{ub}
number:
  variance of all entries in the selected field (column) in
  the database entries that match the database Search
  Criteria.
ERROR:
  if the database input or criteria ranges are not defined.

@{b}See Also:@{ub}
@{"DCOUNT" link func_DCOUNT }, @{"DMAX" link func_DMAX }, @{"DMIN" link func_DMIN }, @{"DAVG" link func_DAVG }, @{"DSUM" link func_DSUM }, @{"DSTD" link func_DSTD }
@endnode

@node func_ERROR "Formula Function: ERROR..."
@{fg highlight}ERROR@{fg text}
Set ERROR condition in a formula.

@{b}Format:@{ub}
ERROR

@{b}Input:@{ub}
None

@{b}Output:@{ub}
ERROR:	set result to ERROR

@{b}Example:@{ub}
if(a1<10,a1,ERROR)  this will return the value of a1 if a1
is less than 10, or ERROR if it isn't.

@{b}See Also:@{ub}
@{"IF" link func_IF }, @{"ISERR" link func_ISERR }, @{"IZERR" link func_IZERR }
@endnode

@node func_EVALUATE "Formula Function: EVALUATE..."
@{fg highlight}EVALUATE@{fg text}
Evaluate a string as a formula.

@{b}Format:@{ub}
EVALUATE(expression)

@{b}Input:@{ub}
string:	
  expression: any valid formula or math expression
  You can use any cell or range reference within
  the expression.

@{b}Output:@{ub}
result:
  number or string depending on result of evaluated
  expression
ERROR:
  if expression was not valid

@{b}Example:@{ub}
evaluate("1+2+(12^7)")

@{b}Note:@{ub}
EVALUATE() is a live function, it is evaluated at every	recalc.

@{b}See Also:@{ub}
@{"VALUE" link func_VALUE }
@endnode

@node func_EXACT "Formula Function: EXACT..."
@{fg highlight}EXACT@{fg text}
Compare two strings (case-sensitive).

@{b}Format:@{ub}
EXACT(str1,str2)

@{b}Input:@{ub}
string:	str1
string:	str2

@{b}Output:@{ub}
TRUE:
  if str1 and str2 are identical
FALSE:
  if str1 and str2 are not identical

@{b}Example:@{ub}
EXACT() does a case-sensitive comparison, unlike the normal
string comparison using the '=' sign.

"test"="Test"			returns TRUE
exact("test","Test")	returns FALSE
@endnode

@node func_EXP "Formula Function: EXP..."
@{fg highlight}EXP@{fg text}
Value of e (2.718281828) to the power x.

@{b}Format:@{ub}
EXP(x)

@{b}Input:@{ub}
number:	x	(limits: x between -708.396 and 709.778)

@{b}Output:@{ub}
number:	value of e (2.718281828) to the power x
ERROR:	if x exceeds limits

@{b}Example:@{ub}
exp(12) = 162754.791
@endnode

@node func_FACT "Formula Function: FACT..."
@{fg highlight}FACT@{fg text}
Calculate Factorial of a number.

@{b}Format:@{ub}
FACT(x)

@{b}Input:@{ub}
number:	
  x	(limits: x >= 0.0)
  any fraction is removed before x is used, i.e.
  fact(2.1) = fact(2)

@{b}Output:@{ub}
number:	
  factorial of x
1:		
  if x = 0
ERROR:	
  if x < 0

@{b}Example:@{ub}
fact(3)		equals 1 x 2 x 3, i.e. 6
fact(4)		equals 1 x 2 x 3 x 4, i.e. 24
fact(12)	equals 1 x 2 x 3 x ... x 12, i.e. 479001600
@endnode

@node func_FALSE "Formula Function: FALSE..."
@{fg highlight}FALSE@{fg text}
Constant: value of FALSE (zero).

@{b}Format:@{ub}
FALSE

@{b}Input:@{ub}
None

@{b}Output:@{ub}
FALSE:	(zero)

@{b}Example:@{ub}
if(a1<12,TRUE,FALSE)

@{b}See Also:@{ub}
@{"TRUE" link func_TRUE }
@endnode

@node func_FAVG "Formula Function: FAVG..."
@{fg highlight}FAVG@{fg text}
Average of applying an expression to one or more arguments.

@{b}Format:@{ub}
FAVG(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is evaluated for every
  cell in 'arguments' below, and the result is used
  as the argument in the calculations.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  average value of the results of evaluating the
  expression for all numeric cells in the arguments
  provided.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

favg(here*2,a1:a10)

This will give you the average of all cells in the range a1:a10
multiplied by 2.

favg(cos(here),a1:a10)

This will give you the average of cosines of the cells in the
range a1:a10.

@{b}See Also:@{ub}
@{"AVG" link func_AVG }, @{"CAVG" link func_CAVG }, @{"FCOUNT" link func_FCOUNT }, @{"FSUM" link func_FSUM }
@endnode

@node func_FCOUNT "Formula Function: FCOUNT..."
@{fg highlight}FCOUNT@{fg text}
Number of numeric cells in one or more ranges.

@{b}Format:@{ub}
FAVG(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  ignored by FCOUNT()
arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  average value of the results of evaluating the
  expression for all numeric cells in the arguments
  provided.

@{b}Note:@{ub}
This is a dummy function.  It works exactly the same as
COUNT().  'expression' is ignored.  It is only provided as a
way to easily debug the FAVG(), FSUM(), FMAX(), FMIN(), etc.
functions.  It is often useful to quickly change FSUM() to
FCOUNT() to see how many entries are affecting it.

@{b}See Also:@{ub}
@{"FAVG" link func_FAVG }, @{"FSUM" link func_FSUM }, @{"FSUM" link func_FSUM }, @{"COUNT" link func_COUNT }
@endnode

@node func_FFIRST "Formula Function: FFIRST..."
@{fg highlight}FFIRST@{fg text}
Result of applying an expression to the first cell in one or
more arguments.

@{b}Format:@{ub}
FFIRST(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is evaluated for every
  cell in 'arguments' below, and the result is used
  as the argument in the calculations.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  result of evaluating the expression for the first
  valid cell in the arguments provided.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

ffirst(here*2,a1:a10)

This will give you the value of the first valid cell in the
range a1:a10 multiplied by 2.

ffirst(cos(here),a1:a10)

This will give you the cosine of the first valid cell in the
range a1:a10.

@{b}See Also:@{ub}
@{"FLAST" link func_FLAST }, @{"FPICK" link func_FPICK }, @{"FIRST" link func_FIRST }, @{"CFIRST" link func_CFIRST }
@endnode

@node func_FIELD "Formula Function: FIELD..."
@{fg highlight}FIELD@{fg text}
Value of current field being evaluated in the current database.

@{b}Format:@{ub}
FIELD

@{b}Input:@{ub}
None

@{b}Output:@{ub}
Value of current field being evaulated.  Used in Database
operations only.

@{b}Example:@{ub}
See the @{"database" link "FinalCalc:guide/part7.guide/Main"} section for a detailed description.
@endnode

@node func_FIND "Formula Function: FIND..."
@{fg highlight}FIND@{fg text}
Find a string in another string.

@{b}Format:@{ub}
FIND(str1,str2,n)

@{b}Input:@{ub}
string:	str1
string:	str2
number:	n

@{b}Output:@{ub}
number:
  starting position of first occurance of 'str2' in
  'str1' starting from the n'th character
ERROR:
  if str2 was not found in str1

@{b}Example:@{ub}
find("this is a test","test",0) returns 10
@endnode


@node func_FIRST "Formula Function: FIRST..."
@{fg highlight}FIRST@{fg text}
Get first valid entry from multiple numeric or string arguments.

@{b}Format:@{ub}
FIRST(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells 
 - ranges

@{b}Output:@{ub}
number or string:	value of first valid entry from arguments

@{b}Example:@{ub}
first(a1:b10) returns the value of the first cell in the range
a1:b10 that contains a valid value

@{b}See Also:@{ub}
@{"LAST" link func_LAST }, @{"PICK" link func_PICK }, @{"FFIRST" link func_FFIRST }, @{"CFIRST" link func_CFIRST }
@endnode

@node func_FLAST "Formula Function: FLAST..."
@{fg highlight}FLAST@{fg text}
Result of applying an expression to the last cell in one or
more arguments.

@{b}Format:@{ub}
FLAST(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is evaluated for every
  cell in 'arguments' below, and the result is used
  as the argument in the calculations.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  result of evaluating the expression for the last
  valid cell in the arguments provided.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

flast(here*2,a1:a10)

This will give you the value of the last valid cell in the
range a1:a10 multiplied by 2.

flast(cos(here),a1:a10)

This will give you the cosine of the last valid cell in the
range a1:a10.

@{b}See Also:@{ub}
@{"FFIRST" link func_FFIRST }, @{"FPICK" link func_FPICK }, @{"LAST" link func_LAST }, @{"CLAST" link func_CLAST }
@endnode

@node func_FMAX "Formula Function: FMAX..."
@{fg highlight}FMAX@{fg text}
Largest result of applying an expression to the first cell in
one or more arguments.

@{b}Format:@{ub}
FMAX(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is evaluated for every
  cell in 'arguments' below, and the result is used
  as the argument in the calculations.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  largest result of evaluating the expression to all
  valid cells in the arguments provided.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

fmax(here*2,a1:a10)

This will give you the value of the highest cell value in the
range a1:a10 multiplied by 2.

fmax(cos(here),a1:a10)

This will give you the highest cosine value of all cells in the
range a1:a10.

@{b}See Also:@{ub}
@{"FMIN" link func_FMIN }, @{"MAX" link func_MAX }, @{"CMAX" link func_CMAX }
@endnode

@node func_FMIN "Formula Function: FMIN..."
@{fg highlight}FMIN@{fg text}
Lowest result of applying an expression to the first cell in
one or more arguments.

@{b}Format:@{ub}
FMIN(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is evaluated for every
  cell in 'arguments' below, and the result is used
  as the argument in the calculations.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  lowest result of evaluating the expression to all
  valid cells in the arguments provided.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

fmin(here*2,a1:a10)

This will give you the value of the lowest cell value in the
range a1:a10 multiplied by 2.

fmin(cos(here),a1:a10)

This will give you the lowest cosine value of all cells in the
range a1:a10.

@{b}See Also:@{ub}
@{"FMAX" link func_FMAX }, @{"MIN" link func_MIN }, @{"CMIN" link func_CMIN }
@endnode

@node func_FPICK "Formula Function: FPICK..."
@{fg highlight}FPICK@{fg text}
Result of applying an expression to the a specific cell in one
or more arguments.

@{b}Format:@{ub}
FPICK(offset,expression,multiple range arguments)

@{b}Input:@{ub}
number:	
  offset, a positive or negative integer number.
  It is used to define which cell to select from
  the cells for which expression is true.

  If offset is positive, it picks cells from the
  start of the ranges defined.  If it is negative,
  it picks cells from the end of the ranges defined.

    3	use the 3rd argument
    2	use the 2nd argument
    1	use the 1st argument
    0	use the last argument
   -1	use the argument before last
   -2	use the 2nd argument before last
   -3	use the 3rd argument before last

expression:
  a formula expression.  This is evaluated for every
  cell in 'arguments' below, and the result is used
  as the argument in the calculations.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  result of evaluating the expression for the
  selected cell in the arguments provided.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

fpick(2,here*2,a1:a10)

This will give you the value of the second valid cell in the
range a1:a10 multiplied by 2.

flast(-3,cos(here),a1:a10)

This will give you the cosine of the third last valid cell in
the range a1:a10.

@{b}See Also:@{ub}
@{"FFIRST" link func_FFIRST }, @{"FLAST" link func_FLAST }, @{"PICK" link func_PICK }, @{"CPICK" link func_CPICK }
@endnode

@node func_FRAC "Formula Function: FRAC..."
@{fg highlight}FRAC@{fg text}
Get fractional part of a number.

@{b}Format:@{ub}
FRAC(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
number:	fractional part of x

@{b}Example:@{ub}
frac(1.45) = 0.45

@{b}See Also:@{ub}
@{"INT" link func_INT }
@endnode

@node func_FSIGN "Formula Function: FSIGN..."
@{fg highlight}FSIGN@{fg text}
Get Significance of F Value given two degrees of freedom.
(used for @{"Multivariate Regression Analysis" link "FinalCalc:guide/part4.guide/part4.4"})

@{b}Format:@{ub}
FSIGN(f value,degrees of freedom 1,degrees of freedom 2)

@{b}Input:@{ub}
number:	f value
number:	degrees of freedom 1
number:	degrees of freedom 2

@{b}Output:@{ub}
number:	
  Significance of F value given the provided degrees of
  freedom.

@{b}See Also:@{ub}
@{"REGRES" link func_REGRES }, @{"TSIGN" link func_TSIGN }
@endnode

@node func_FSUM "Formula Function: FSUM..."
@{fg highlight}FSUM@{fg text}
Sum of applying an expression to one or more arguments.

@{b}Format:@{ub}
FSUM(expression,multiple range arguments)

@{b}Input:@{ub}
expression:
  a formula expression.  This is evaluated for every
  cell in 'arguments' below, and the result is used
  as the argument in the calculations.

arguments:
  one or more data ranges

@{b}Output:@{ub}
number:
  sum of the results of evaluating the expression for
  all numeric cells in the arguments provided.

@{b}Example:@{ub}
You can use the HERE keyword to mean the current cell being
evaluated.  For example:

fsum(here*2,a1:a10)

This will give you the sum of all cells in the range a1:a10
multiplied by 2.

fsum(cos(here),a1:a10)

This will give you the sum of cosines of the cells in the
range a1:a10.

@{b}See Also:@{ub}
@{"SUM" link func_SUM }, @{"CSUM" link func_CSUM }, @{"FAVG" link func_FAVG }, @{"FCOUNT" link func_FCOUNT }
@endnode

@node func_FV "Formula Function: FV..."
@{fg highlight}FV@{fg text}
Calculates the Future Value of an amount.

@{b}Format:@{ub}
FV(amount,interest rate,number of periods)

@{b}Input:@{ub}
number:	amount
number:	interest rate
number:	periods

@{b}Output:@{ub}
number:
  Future Value of a future amount with a specific
  number of periods and a specific interest rate using
  compound interest.

@{b}Example:@{ub}
An amount of $10,000 today, would be worth $23,965.58 in 15
years at an	interest rate of 6%.  (with interest compounded
yearly)

fv(10000,6%,15) = 23965.58

If interest is compounded monthly, then divide the interest
rate by 12, and multiply the periods by 12.

@{b}See Also:@{ub}
@{"FVA" link func_FVA }, @{"PV" link func_PV }, @{"TERM" link func_TERM }, @{"RATE" link func_RATE }
@endnode

@node func_FVA "Formula Function: FVA..."
@{fg highlight}FVA@{fg text}
Calculates the Future Value of a stream of fixed payments.

@{b}Format:@{ub}
FVA(annuity amount,interest rate,number of periods)

@{b}Input:@{ub}
number:	annuity amount
number:	interest rate
number:	periods

@{b}Output:@{ub}
number:
  Future Value of a stream of fixed payments over a
  number of periods presuming a specific interest rate
  using compound interest.

@{b}Example:@{ub}
An annuity of $1,000 a month over 15 years at an interest rate
of 6% is worth $290,818.71 after 15 years.

pva(1000,6%/12,15*12) = 290818.71

@{b}See Also:@{ub}
@{"FVA" link func_FVA }, @{"PV" link func_PV }, @{"TERMA" link func_TERMA }, @{"RATEA" link func_RATEA }
@endnode

@node func_GAMMA "Formula Function: GAMMA..."
@{fg highlight}GAMMA@{fg text}
Calculate Gamma value of a number.

@{b}Format:@{ub}
GAMMA(x)

@{b}Input:@{ub}
number:
  x	(limits: x >= 0.0)

@{b}Output:@{ub}
number:
  Gamma value of x
  This is defined as the product of multiplying all
  numbers from 1 to x-1.
1:
  if x = 0
ERROR:
  if x < 0

@{b}Example:@{ub}
gamma(6) = 1 x 2 x 3 x 4 x 5 = 120
@endnode

@node func_GETCOLOR "Formula Function: GETCOLOR..."
@{fg highlight}GETCOLOR@{fg text}
Get color of a cell.

@{b}Format:@{ub}
GETCOLOR(cell)

@{b}Input:@{ub}
cell:	cell name

@{b}Output:@{ub}
number:
  value that defines cell style:
  	-1	cell not allocated
  	 0	default
  	 1	white
  	 2	red
  	 3	green
  	 4	blue
  	 5	orange
  	 6	pink
  	 7	cyan
  	 8	yellow

@{b}Example:@{ub}
getcolor(a1) = 2 (if the color of cell a1 is red)

@{b}Note:@{ub}
Since changes to cell color do not invoke a recalc, you
will need to issue a recalc command if you manually change
a cell's color.
@endnode

@node func_GETSTYLE "Formula Function: GETSTYLE..."
@{fg highlight}GETSTYLE@{fg text}
Get style of a cell.

@{b}Format:@{ub}
GETSTYLE(cell)

@{b}Input:@{ub}
cell:	cell name

@{b}Output:@{ub}
number:
  value that defines cell style:
  	-1	cell not allocated
  	 0	normal
  	 1	bold
  	 2	italic
  	 4	undeline
  	 8	reverse
  	16	shaded

  Combined styles are added together:
  	bold+italic  = 1+2  = 3

@{b}Example:@{ub}
getstyle(a1) = 1 (if the cell a1 is set to bold)

@{b}Note:@{ub}
Since changes to cell style do not invoke a recalc, you
will need to issue a recalc command if you manually change
a cell's style.
@endnode

@node func_HERE "Formula Function: HERE..."
@{fg highlight}HERE@{fg text}
Address/value of current cell.

@{b}Format:@{ub}
HERE
HERE(column offset,row offset)
HERE(sheet offset,column offset,row offset)

@{b}Input:@{ub}
number:	[optional] sheet offset
number:	[optional] column offset
number:	[optional] row offset

@{b}Output:@{ub}
contents of the current cell in the current sheet, plus the
sheet, column and row offsets provided.

@{b}Example:@{ub}
here = value of current cell
here(1,0) = value of next cell to right
here(0,1) = value of cell below current one
row(here) = row number of current cell

@{b}Note:@{ub}
Although this is a useful function, it bypasses the minimal
recalc mechanism, so extensive use of it might make it
necessary to use Full Recalc.
@endnode

@node func_HEX "Formula Function: HEX..."
@{fg highlight}HEX@{fg text}
Convert a number to a hexadecimal string.

@{b}Format:@{ub}
HEX(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
string:	hexadecimal string equivalent of x

@{b}Example:@{ub}
hex(1234) = "4d2"

@{b}See Also:@{ub}
@{"HEXTO" link func_HEXTO }
@endnode

@node func_HEXTO "Formula Function: HEXTO..."
@{fg highlight}HEXTO@{fg text}
Convert a hexadecimal string to a number.

@{b}Format:@{ub}
HEXTO(str)

@{b}Input:@{ub}
string:
  str (string with a hexadecimal number)

@{b}Output:@{ub}
number:	
  decimal value of hexadecimal number in str
0:
  if str does not look like a hexadecimal number

@{b}Example:@{ub}
hexto("4d2") = 1234

@{b}See Also:@{ub}
@{"HEX" link func_HEX }
@endnode

@node func_HLOOK "Formula Function: HLOOK..."
@{fg highlight}HLOOK@{fg text}
Look up a value from a table with a row offset.

@{b}Format:@{ub}
HLOOK(value to be looked up,range,row offset)

@{b}Input:@{ub}
number:
  value to be looked up
range:
  range
number:
  row offset (limits:	offset >= 0)

@{b}Output:@{ub}
number:
  the table defined by 'range' is searched horizontally
  for the largest value that is not greater than the
  look-up value, then the row offset is used to look up
  another value vertically from the table, which is
  returned.

ERROR:
  if offset is negative or value not found in table

HLOOK() will also return a cell or range address if used as a
cell or range argument to another function.

@{b}See Also:@{ub}
@{"VLOOK" link func_VLOOK }
@endnode

@node func_HOUR "Formula Function: HOUR..."
@{fg highlight}HOUR@{fg text}
Extract hour number from a serial time number.

@{b}Format:@{ub}
HOUR(time)

@{b}Input:@{ub}
time:
  a serial time number

@{b}Output:@{ub}
number:
  the hour number (0 to 23) in the serial time number

@{b}Example:@{ub}
hour(now) = 13 (if the time is 1 p.m.)

@{b}See Also:@{ub}
@{"TIME" link func_TIME }, @{"MINUTE" link func_MINUTE }, @{"SECOND" link func_SECOND }, @{"NOW" link func_NOW }
@endnode

@node func_IF "Formula Function: IF..."
@{fg highlight}IF@{fg text}
Return one of two arguments based on value of an expression.

@{b}Format:@{ub}
IF(expression,value if expression true,
  value if expression false)

@{b}Input:@{ub}
expression:
  any valid formula expression
argument:
  number, string, cell or range address
argument:
  number, string, cell or range address

@{b}Output:@{ub}
if expression is true (non-zero), 'value if expression true'
is returned, otherwise 'value if expression value' is returned

IF() will also return a cell or range address if used as a
cell or range argument to another function.

@{b}Examples:@{ub}
=if(a1>12,100,500)

This will return 100 if a1 is bigger than 12, otherwise it will
return 500.

=if(a1<1000,a1,1000)

This will return the value of a1 if a1 is less than 1000,
otherwise it will return 1000.

=sum(if(a1>1,a1:a10,b1:b10))

This will return the sum of a1:a10 if a1 > 1, otherwise it
will return the sum of b1:b10
@endnode

@node func_INDEX "Formula Function: INDEX..."
@{fg highlight}INDEX@{fg text}
Get value of a cell indexed within a range.

@{b}Format:@{ub}
INDEX(range,column offset,row offset)
INDEX(range,sheet offset,column offset,row offset)

@{b}Input:@{ub}
range:
  range
number:
  sheet offset
number:
  column offset
number:
  row offset

@{b}Output:@{ub}
value:
  value of a cell within the provided range indexed by
  the selected sheet, column and row offsets
ERROR:
  if any offset is outside provided range

@{b}Example:@{ub}
index(a1:c10,0,0) = value of cell a1
index(a1:c10,1,0) = value of cell b1
index(a1:c10,0,1) = value of cell a2

@{b}See Also:@{ub}
@{"CELL" link func_CELL }
@endnode

@node func_INF "Formula Function: INF..."
@{fg highlight}INF@{fg text}
Constant: Infinity

@{b}Format:@{ub}
INF

@{b}Input:@{ub}
None

@{b}Output:@{ub}
number:	Infinity

@{b}See Also:@{ub}
@{"NINF" link func_NINF }
@endnode

@node func_INT "Formula Function: INT..."
@{fg highlight}INT@{fg text}
Get integer part of a number.

@{b}Format:@{ub}
INT(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
number:	integer part of x

@{b}Example:@{ub}
int(1.45) = 1
int(2.91) = 2

@{b}See Also:@{ub}
@{"FRAC" link func_FRAC }
@endnode

@node func_IRR "Formula Function: IRR..."
@{fg highlight}IRR@{fg text}
Calculate Internal Rate of Return on a series of cash flows.

@{b}Format:@{ub}
IRR(range of cash flows,guess)

@{b}Input:@{ub}
range:
  cash flows
number:
  guess:  a number between 0 and 1 that represents a guess
  at the possible IRR.

@{b}Output:@{ub}
number:
  the discount rate that would cause the net present
  value of a string of cash flows over a number of
  periods (defined by the number of cells in the range)
  to be equal to zero.

@{b}Example:@{ub}
To calculate the Internal Rate of Return of a string of cash
flows in the range a1:c10 at a guess rate of 6%:

irr(a1:c10,6%)

@{b}Note:@{ub}
IRR() is an iterative function.  It will attempt to find the
solution by successive approximation.  IRR() will make a
maximum of 100 attempts to arrive at a figure that is within
0.000001 accuracy.

@{b}See Also:@{ub}
@{"NPV" link func_NPV }, @{"PV" link func_PV }, @{"FV" link func_FV }
@endnode

@node func_ISERR "Formula Function: ISERR..."
@{fg highlight}ISERR@{fg text}
Test expression for ERROR condition.

@{b}Format:@{ub}
ISERR(expression)

@{b}Input:@{ub}
expression:	any valid formula expression

@{b}Output:@{ub}
TRUE:
  if expression evaluated caused an ERROR
FALSE:
  if expression evaluated did not cause an ERROR

@{b}Example:@{ub}
if(iserr(a1),0,a1)

This returns 0 if a1 is an ERROR, otherwise returns the value
of a1.

@{b}Note:@{ub}
During evaluation of the expression in ISERR(), normal ERROR
checking and flagging is ignored.  This allows you to safely
trap ERROR conditions.

@{b}See Also:@{ub}
@{"ERROR" link func_ERROR }, @{"IZERR" link func_IZERR }, @{"IF" link func_IF }
@endnode

@node func_ISINF "Formula Function: ISINF..."
@{fg highlight}ISINF@{fg text}
Test expression for infinity.

@{b}Format:@{ub}
ISINF(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
TRUE:
  if x equals positive or negative infinity
FALSE:
  if x doesn't equal positive or negative infinity

@{b}Example:@{ub}
if(isinf(a1),0,a1)

This returns 0 if a1 equal infinity, otherwise returns the
value of a1.

@{b}See Also:@{ub}
@{"IF" link func_IF }
@endnode

@node func_ISNUM "Formula Function: ISNUM..."
@{fg highlight}ISNUM@{fg text}
Test for a number.

@{b}Format:@{ub}
ISNUM(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
TRUE:
  if x is a number or empty
FALSE:
  if x is a string

@{b}Example:@{ub}
if(isnum(a1),a1,0)

This returns 0 if a1 is not a number, otherwise returns the
value of a1.

@{b}See Also:@{ub}
@{"IF" link func_IF }, @{"ISSTR" link func_ISSTR }
@endnode

@node func_ISRANGE "Formula Function: ISRANGE..."
@{fg highlight}ISRANGE@{fg text}
Test for a range.

@{b}Format:@{ub}
ISRANGE(range)

@{b}Input:@{ub}
range:	range

@{b}Output:@{ub}
TRUE:
  if 'range' is a valid range
FALSE:
  if 'range' is no a valid range

@{b}Example:@{ub}
IF(isrange(test),sum(test),0)

@{b}See Also:@{ub}
@{"IF" link func_IF }
@endnode

@node func_ISSTR "Formula Function: ISSTR..."
@{fg highlight}ISSTR@{fg text}
Test for a string.

@{b}Format:@{ub}
ISSTR(str)

@{b}Input:@{ub}
string:	str

@{b}Output:@{ub}
TRUE:
  if str is a string
FALSE:
  if str is not a string

@{b}Example:@{ub}
if(isstr(a1),a1,"default")

This returns "default" if a1 is not a string, otherwise returns
the value of a1.

@{b}See Also:@{ub}
@{"IF" link func_IF }, @{"ISNUM" link func_ISNUM }
@endnode

@node func_IZERR "Formula Function: IZERR..."
@{fg highlight}IZERR@{fg text}
Test expression for ERROR and Infinity conditions.

@{b}Format:@{ub}
IZERR(expression)

@{b}Input:@{ub}
expression:
  any valid formula expression

@{b}Output:@{ub}
TRUE:
  if expression evaluated caused an ERROR, or was
  a negative or positive infinity

FALSE:
  if expression evaluated did not cause an ERROR and
  is not a negative or positive infinity

@{b}Example:@{ub}
if(izerr(a1),0,a1)

This returns 0 if a1 is an ERROR or infinity, otherwise returns
the value of a1.

@{b}Note:@{ub}
IZERR is provided for compatibility reasons with imported .WKS
sheets.  When importing .WKS sheets, ISERR() is automatically
converted to IZERR().

FinalCalc supports Infinity and will not cause an ERROR.
IZERR() is the only case when it is considered to be an ERROR.

During evaluation of the expression in IZERR(), normal ERROR
checking and flagging is ignored.  This allows you to safely
trap ERROR conditions.

@{b}See Also:@{ub}
@{"ERROR" link func_ERROR }, @{"ISERR" link func_ISERR }, @{"IF" link func_IF }
@endnode

@node func_KEEP "Formula Function: KEEP..."
@{fg highlight}KEEP@{fg text}
Remove all characters from a string except for specific
characters.

@{b}Format:@{ub}
KEEP(str,template)

@{b}Input:@{ub}
string:	str
string:	template

@{b}Output:@{ub}
string:
  'str' with all characters that are not in 'template'
  removed.

@{b}Example:@{ub}
keep("this is a test","tis") = "tisistst"

@{b}See Also:@{ub}
@{"REMOVE" link func_REMOVE }
@endnode

@node func_LAST "Formula Function: LAST..."
@{fg highlight}LAST@{fg text}
Get last valid entry from multiple numeric or string arguments.

@{b}Format:@{ub}
LAST(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells
 - ranges

@{b}Output:@{ub}
number or string:
  value of last valid entry from arguments

@{b}Example:@{ub}
last(a1:b10) returns the value of the last cell in the range
a1:b10 that contains a valid value

@{b}See Also:@{ub}
@{"FIRST" link func_FIRST }, @{"PICK" link func_PICK }, @{"FLAST" link func_FLAST }, @{"CLAST" link func_CLAST }
@endnode

@node func_LEFT "Formula Function: LEFT..."
@{fg highlight}LEFT@{fg text}
Get part of the left side of a string.

@{b}Format:@{ub}
LEFT(str,n)

@{b}Input:@{ub}
string:
  str
number:
  n

@{b}Output:@{ub}
string:
  the leftmost n characters from 'str'

@{b}Example:@{ub}
left("this is a test",4) = "this"


@{fg highlight}LEFT@{fg text}
Value or address of cell to the left of the current cell.

@{b}Format:@{ub}
LEFT

@{b}Input:@{ub}
None

@{b}Output:@{ub}
cell:
  address or value of cell left of current cell

@{b}Example:@{ub}
=left+1    = cell to the left + 1
=col(left) = column number of cell to the left


@{b}See Also:@{ub}
@{"RIGHT" link func_RIGHT }, @{"ABOVE" link func_ABOVE }, @{"BELOW" link func_BELOW }, @{"MID" link func_MID }, @{"LEN" link func_LEN }
@endnode

@node func_LEN "Formula Function: LEN..."
@{fg highlight}LEN@{fg text}
Get the length of a string.

@{b}Format:@{ub}
LEN(str)

@{b}Input:@{ub}
string:
  str

@{b}Output:@{ub}
number:
  number of characters in 'str'.

@{b}Example:@{ub}
len("this is a test") = 14
@endnode

@node func_LIMIT "Formula Function: LIMIT..."
@{fg highlight}LIMIT@{fg text}
Test a value against limits.

@{b}Format:@{ub}
LIMIT(x,a,b,value if x<a,value if a<=x<=b,value if b<x)

@{b}Input:@{ub}
number:	x
number:	a
number:	b
number:	value if x<a
number:	value if a<=x<=b
number:	value if b<x

@{b}Output:@{ub}
number:	
  returns one of three values depending on x, a, and b.
  a must be smaller than b, and they define the limits
  that value x is compared to.  If x is smaller than the
  limit, then value 1 (value if x<a) is returned.  If x
  is within a and b, then value 2 (value if a<=x<=b) is
  returned.   Else if x is larger than the limit, then
  value 3 (value if b<x) is returned.

ERROR:
  if a > b
@endnode

@node func_LOG "Formula Function: LOG..."
@{fg highlight}LOG@{fg text}
Logarithm of a number to base 10.

@{b}Format:@{ub}
LOG(x)

@{b}Input:@{ub}
number:	
  x	(limit: x <= 0.0)

@{b}Output:@{ub}
number:
  logarithm of x to base 10
ERRROR:
  if x exceeds limits

@{b}Example:@{ub}
log(12) = 1.079181246

@{b}See Also:@{ub}
@{"LOGN" link func_LOGN }
@endnode

@node func_LOGN "Formula Function: LOGN..."
@{fg highlight}LOGN@{fg text}
Natural (base e) logarithm of a number.

@{b}Format:@{ub}
LOGN(x)

@{b}Input:@{ub}
number:
  x	(limit: x <= 0.0)

@{b}Output:@{ub}
number:
  natural logarithm of x (base e)
ERRROR:
  if x exceeds limits

@{b}Example:@{ub}
logn(12) = 2.48490665

@{b}See Also:@{ub}
@{"LOG" link func_LOG }
@endnode

@node func_LOWER "Formula Function: LOWER..."
@{fg highlight}LOWER@{fg text}
Convert a string to all lowercase characters.

@{b}Format:@{ub}
LOWER(str)

@{b}Input:@{ub}
string:
  str

@{b}Output:@{ub}
string:
  lower-case version of str

@{b}Example:@{ub}
=lower("TEST") = "test"

@{b}See Also:@{ub}
@{"UPPER" link func_UPPER }, @{"PROPER" link func_PROPER }
@endnode

@node func_MAX "Formula Function: MAX..."
@{fg highlight}MAX@{fg text}
Highest value of one or more numeric values.

@{b}Format:@{ub}
MAX(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells that contain numeric values
 - ranges (only cells with numeric contents in the range are used)

@{b}Output:@{ub}
number:
  Highest numeric value of all arguments provided, or
  zero if no arguments were found.

@{b}Example:@{ub}
max(a1:b10,12,100,a1/23))
max(100,a1,b10:c20,cos(12))

@{b}See Also:@{ub}
@{"MIN" link func_MIN }, @{"CMAX" link func_CMAX }, @{"FMAX" link func_FMAX }
@endnode

@node func_MID "Formula Function: MID..."
@{fg highlight}MID@{fg text}
Get part of a string.

@{b}Format:@{ub}
MID(str,start,length)

@{b}Input:@{ub}
string:
  str
number:
  start
number:
  length

@{b}Output:@{ub}
string:	
  'length' (or less) characters from 'str' starting at
  position 'start'.

@{b}Example:@{ub}
mid("this is a test",5,4) = "is a"

@{b}See Also:@{ub}
@{"LEFT" link func_LEFT }, @{"RIGHT" link func_RIGHT }, @{"LEN" link func_LEN }
@endnode

@node func_MIN "Formula Function: MIN..."
@{fg highlight}MIN@{fg text}
Lowest value of one or more numeric values.

@{b}Format:@{ub}
MIN(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells that contain numeric values
 - ranges (only cells with numeric contents in the range are used)

@{b}Output:@{ub}
number:
  Lowest numeric value of all arguments provided, or
  zero if no arguments were found.

@{b}Example:@{ub}
min(a1:b10,12,100,a1/23))
min(100,a1,b10:c20,cos(12))

@{b}See Also:@{ub}
@{"MAX" link func_MAX }, @{"CMIN" link func_CMIN }, @{"FMIN" link func_FMIN }
@endnode

@node func_MINUTE "Formula Function: MINUTE..."
@{fg highlight}MINUTE@{fg text}
Extract minute number from a serial time number.

@{b}Format:@{ub}
MINUTE(time)

@{b}Input:@{ub}
time:
  a serial time number

@{b}Output:@{ub}
number:
  the minute number (0 to 59) in the serial time number

@{b}Example:@{ub}
minute(now) = 12 (if the time is 10:12)

@{b}See Also:@{ub}
@{"TIME" link func_TIME }, @{"HOUR" link func_HOUR }, @{"SECOND" link func_SECOND }, @{"NOW" link func_NOW }
@endnode

@node func_MOD "Formula Function: MOD..."
@{fg highlight}MOD@{fg text}
Get remainder of a division.

@{b}Format:@{ub}
MOD(x,y)

@{b}Input:@{ub}
number:	x
number:	y

@{b}Output:@{ub}
number:
  value of x modulo y (same as x%y).  This is the
  remainder after dividing x over y.

@{b}Example:@{ub}
mod(15,6) = 3 (remainder of 15/6)
@endnode

@node func_MONTH "Formula Function: MONTH..."
@{fg highlight}MONTH@{fg text}
Get month number from a serial date number.

@{b}Format:@{ub}
MONTH(date)

@{b}Input:@{ub}
date:
  serial date number

@{b}Output:@{ub}
number:
  from 1 to 12, the month number from the provided serial
  date number

@{b}Example:@{ub}
day(today) = 2  (if the current month was February)

@{b}See Also:@{ub}
@{"DATE" link func_DATE }, @{"DAY" link func_DAY }, @{"YEAR" link func_YEAR }, @{"TODAY" link func_TODAY }, @{"DATESTR" link func_DATESTR }, @{"DATEVALUE" link func_DATEVALUE }
@endnode

@node func_MONTHS "Formula Function: MONTHS..."
@{fg highlight}MONTHS@{fg text}
Get number of months in a date.

@{b}Format:@{ub}
MONTHS(date)

@{b}Input:@{ub}
date:
  serial date number

@{b}Output:@{ub}
number:
  the number of months in the date number provided.

@{b}Example:@{ub}
MONTHS() is useful for comparisons with month counts:

months(date1)-months(date2)  returns the number of months
between date1 and date2.
@endnode

@node func_NAMESTR "Formula Function: NAMESTR..."
@{fg highlight}NAMESTR@{fg text}
Convert cell or range definition to a string.

@{b}Format:@{ub}
NAMESTR(cell/range)

@{b}Input:@{ub}
cell or range definition

@{b}Output:@{ub}
string:
  cell or range name string

@{b}Example:@{ub}
namestr(a1)
  returns  A1

namestr(a1:b10)
  returns  A1:B10

namestr(cell(0,1))
  returns  A1

namestr(a_a1)
  returns  A_A1

@{b}See Also:@{ub}
@{"CELL" link func_CELL }, @{"RANGE" link func_RANGE }
@endnode

@node func_NINF "Formula Function: NINF..."
@{fg highlight}NINF@{fg text}
Constant: Negative infinity.

@{b}Format:@{ub}
NINF

@{b}Input:@{ub}
None

@{b}Output:@{ub}
number:	Negative Infinity

@{b}See Also:@{ub}
@{"INF" link func_INF }
@endnode

@node func_NOT "Formula Function: NOT..."
@{fg highlight}NOT@{fg text}
Logical Not.

@{b}Format:@{ub}
NOT(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
FALSE:
  if x is TRUE (non-zero)
TRUE:
  if x is FALSE (zero)

@{b}Example:@{ub}
if(not(a1),"non-zero","zero")
is the same as:
if(a1,"zero","non-zero")
@endnode

@node func_NOW "Formula Function: NOW..."
@{fg highlight}NOW@{fg text}
Returns the current date and time value.

@{b}Format:@{ub}
NOW

@{b}Input:@{ub}
None

@{b}Output:@{ub}
the current date/time serial number.  The time/date serial
number is defined as the number of days since 1-Jan-1978.  The
integer value is the number of days, and the fraction is the
time.

@{b}Example:@{ub}
if the date is 1-Feb-1994 and the time is 12:00 noon, NOW will
return 5875.5, where 5875 is the number of days since
1-Jan-1978 and .5 is half a day, thus 12:00 noon.

@{b}Note:@{ub}
NOW is a live function, it is always evaluated at every
recalc.  If you only need the date number and not the time
number, use the TODAY function instead.

@{b}See Also:@{ub}
@{"TODAY" link func_TODAY }, @{"TIME" link func_TIME }, @{"HOUR" link func_HOUR }, @{"MINUTE" link func_MINUTE }, @{"SECOND" link func_SECOND }, @{"TIMESTR" link func_TIMESTR }, @{"TIMEVALUE" link func_TIMEVALUE }
@endnode

@node func_NPV "Formula Function: NPV..."
@{fg highlight}NPV@{fg text}
Calculate the Net Present Value of a string of cash flows.

@{b}Format:@{ub}
NPV(range of cash flows,discount rate)

@{b}Input:@{ub}
range:
  cash flows
number:
  discount rate

@{b}Output:@{ub}
number:
  the net present value of a string of cash flows over
  a number of periods (defined by the number of cells in
  the range) given the discount rate.

@{b}Example:@{ub}
To calculate the net present value of a string of cash flows
in the range a1:c10 at a discount rate of 6%:

npv(a1:c10,6%)

@{b}See Also:@{ub}
@{"IRR" link func_IRR }, @{"PV" link func_PV }, @{"FV" link func_FV }
@endnode

@node func_NUM "Formula Function: NUM..."
@{fg highlight}NUM@{fg text}
Get a number.

@{b}Format:@{ub}
NUM(x)

@{b}Input:@{ub}
number:
  x

@{b}Output:@{ub}
number:
  if x a number, x is returned
0:
  if x is not a number

@{b}Example:@{ub}
num(12) = 12
num("test") = 0
num(a1) = value of a1 if a1 is number, or 0 if a1 contains a
  string.

@{b}Note:@{ub}
NUM is used where you want to make sure that a number is
provided to another function and not a string.

@{b}See Also:@{ub}
@{"ISNUM" link func_ISNUM }, @{"STR" link func_STR }
@endnode

@node func_OCT "Formula Function: OCT..."
@{fg highlight}OCT@{fg text}
Convert a number to an octal string.

@{b}Format:@{ub}
OCT(x)

@{b}Input:@{ub}
number:
  x

@{b}Output:@{ub}
string:
  octal string equivalent of x

@{b}Example:@{ub}
oct(123) = "173"

@{b}See Also:@{ub}
@{"OCTTO" link func_OCTTO }
@endnode

@node func_OCTTO "Formula Function: OCTTO..."
@{fg highlight}OCTTO@{fg text}
Convert an octal string to a number.

@{b}Format:@{ub}
OCTTO(str)

@{b}Input:@{ub}
string:
  str

@{b}Output:@{ub}
number:
  value of octal string in str

@{b}Example:@{ub}
octto("173") = 123

@{b}See Also:@{ub}
@{"OCT" link func_OCT }
@endnode

@node func_PATTERN "Formula Function: PATTERN..."
@{fg highlight}PATTERN@{fg text}
Get the Graph Pattern number.

@{b}Format:@{ub}
PATTERN(str)

@{b}Input:@{ub}
string:
  str (string matching the name of a Graph Pattern)

@{b}Output:@{ub}
number:
  number of pattern in graph patterns list, or 0 if it
  was not found.

@{b}Example:@{ub}
pattern("checkered") = 7 (number of pattern 'checkered')

@{b}See Also:@{ub}
@{"COLOR" link func_COLOR }, @{"SYMBOL" link func_SYMBOL }
@endnode

@node func_PATH "Formula Function: PATH..."
@{fg highlight}PATH@{fg text}
Get the full path name of a file, directory, or current project.

@{b}Format:@{ub}
PATH()
PATH(directory)
PATH(filename)

@{b}Input:@{ub}
string:
  directory (name of a valid directory)
string:
  filename (name of a valid file)

@{b}Output:@{ub}
string:
  if a directory or file name was provided, returns the
  full path name to that directory or file, otherwise
  returns the full path name to the current project file.
  (If the current project does not have a file name yet,
  "Untitled" is returned)

@{b}Example:@{ub}
path("C:list") = "Workench:c/list".
path() = "Work:FinalCalc/projects/demo.sheet"
@endnode

@node func_PERM "Formula Function: PERM..."
@{fg highlight}PERM@{fg text}
Calculate the Permutation possibilities of a selection of
distinct items from a group.

@{b}Format:@{ub}
PERM(n,r)

@{b}Input:@{ub}
number:	n
number:	r

@{b}Output:@{ub}
number:
  Permutation value of two numbers, n and r.  (as used in
  Probability and Statistics)	which is usually defined as
  nPr = n!/(n-r)!

@{b}Example:@{ub}
If you have a group of four people (A, B, C, D) and two jobs
to give out to only two of the four people,	how many possible
permutations of Person/Job are possible?

perm(4,2) = 12

Specifically: AB, AC, AD, BA, BC, BD, CA, CB, CD, DA, DB, DC
(AB here means A gets Job 1 and B gets Job 2)

@{b}See Also:@{ub}
@{"COMB" link func_COMB }
@endnode

@node func_PI "Formula Function: PI..."
@{fg highlight}PI@{fg text}
Constant: PI value.

@{b}Format:@{ub}
PI

@{b}Input:@{ub}
None

@{b}Output:@{ub}
number:	PI = 3.141592654
@endnode

@node func_PICK "Formula Function: PICK..."
@{fg highlight}PICK@{fg text}
Get a specific entry from one or more numeric or string
arguments.

@{b}Format:@{ub}
PICK(offset,multiple cell/range/expression arguments)

@{b}Input:@{ub}
number:
  offset, a positive or negative integer number.
  It is used to define which entry to select from
  the arguments provided.

  If offset is positive, it picks entries from the
  start of the arguments provided.  If it is negative,
  it picks entries from the end of the arguments
  provided.

  	 3	use the 3rd entry
  	 2	use the 2nd entry
  	 1	use the 1st entry
  	 0	use the last entry
  	-1	use the entry before last
  	-2	use the 2nd entry before last
  	-3	use the 3rd entry before last

One or more of:
 - numbers
 - cells 
 - ranges

@{b}Output:@{ub}
number or string:	value of first valid entry from arguments

@{b}Example:@{ub}
  =pick(3,a1:a10)

  This will give you the value of the third cell in the range
  a1:a10, which is a3.

  =pick(-2,a1:a10)

  This will give you the value of the 2nd to last cell in the
  range a1:a10 which is a9.

@{b}See Also:@{ub}
@{"LAST" link func_LAST }, @{"FIRST" link func_FIRST }, @{"CPICK" link func_CPICK }, @{"FPICK" link func_FPICK }
@endnode

@node func_PMT "Formula Function: PMT..."
@{fg highlight}PMT@{fg text}
Calculate loan repayment amount.

@{b}Format:@{ub}
PMT(principal,interest,term of loan)

@{b}Input:@{ub}
number:	principal amount of loan
number:	interest rate
number:	term of loan

@{b}Output:@{ub}
number:
  appropriate repayment amount for a loan given the
  principal, interest rate and term using compound interest

@{b}Example:@{ub}
To calculate the yearly loan repayment amount for a loan of
$10,000, at a yearly interest rate of 12% for 15 years:

pmt(10000,12%,15) = $1468.24 per year

If the repayments were monthly, you should divided the yearly
interest rate by 12 and multiply the term by 12:

pmt(10000,12%/12,15*12) = $120.01 per month

Note the use of the % sign to indicate a percentage.  You can
use a normal number instead:  0.12 = 12%

@{b}See Also:@{ub}
@{"PVA" link func_PVA }, @{"FVA" link func_FVA }
@endnode

@node func_PROD "Formula Function: PROD..."
@{fg highlight}PROD@{fg text}
Product of multiplying of one or more numeric values.

@{b}Format:@{ub}
PROD(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells that contain numeric values
 - ranges (only cells with numeric contents in the range are used)

@{b}Output:@{ub}
number:
  Product of multiplying the numeric values of all
  arguments provided.

@{b}Example:@{ub}
prod(a1:b10,12,100,a1/23))
prod(100,a1,b10:c20,cos(12))
@endnode

@node func_PROPER "Formula Function: PROPER..."
@{fg highlight}PROPER@{fg text}
Convert a string to proper case.

@{b}Format:@{ub}
PROPER(str)

@{b}Input:@{ub}
string:
  str

@{b}Output:@{ub}
string:
  str with first character in every word in uppercase
  and the rest in lowercase

@{b}Example:@{ub}
proper("this is a test.") = "This Is A Test"

@{b}See Also:@{ub}
@{"LOWER" link func_LOWER }, @{"UPPER" link func_UPPER }
@endnode

@node func_PV "Formula Function: PV..."
@{fg highlight}PV@{fg text}
Calculates the Present Value of an amount.

@{b}Format:@{ub}
PV(future amount,interest rate,number of periods)

@{b}Input:@{ub}
number:	future amount
number:	interest rate
number:	periods

@{b}Output:@{ub}
number:
  Present Value of a future amount with a specific
  number of periods and a specific interest rate using
  compound interest.

@{b}Example:@{ub}
An amount of $10,000 in 15 years at an interest rate of 6% is
worth $4172.65 today.  (with interest compounded yearly)

pv(10000,6%,15) = 4172.65

@{b}See Also:@{ub}
@{"FV" link func_FV }, @{"PVA" link func_PVA }, @{"TERM" link func_TERM }, @{"RATE" link func_RATE }
@endnode

@node func_PVA "Formula Function: PVA..."
@{fg highlight}PVA@{fg text}
Calculates the Present Value of a stream of fixed payments.

@{b}Format:@{ub}
PVA(annuity amount,interest rate,number of periods)

@{b}Input:@{ub}
number:	annuity amount
number:	interest rate
number:	periods

@{b}Output:@{ub}
number:
  Present Value of a stream of fixed payments over a
  number of periods presuming a specific interest rate
  using compound interest.

@{b}Example:@{ub}
An annuity of $1,000 a month over 15 years at an interest rate
of 6% is worth  $118,503.51 today.

pva(1000,6%/12,15*12) = 118503.51

@{b}See Also:@{ub}
@{"FVA" link func_FVA }, @{"PV" link func_PV }, @{"TERMA" link func_TERMA }, @{"RATEA" link func_RATEA }
@endnode

@node func_RADIANS "Formula Function: RADIANS..."
@{fg highlight}RADIANS@{fg text}
Convert a number from degrees to radians.

@{b}Format:@{ub}
RADIANS(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
number:	value of x degrees in radians

@{b}Example:@{ub}
degrees(114.592) = 12

@{b}See Also:@{ub}
@{"DEGREES" link func_DEGREES }
@endnode

@node func_RAND "Formula Function: RAND..."
@{fg highlight}RAND@{fg text}
Get a random number.

@{b}Format:@{ub}
RAND

@{b}Input:@{ub}
None

@{b}Output:@{ub}
number:	a random number between 0.0 and 1.0

@{b}Example:@{ub}
rand*15 = a random number between 0.0 and 15.0
@endnode

@node func_RANGE "Formula Function: RANGE..."
@{fg highlight}RANGE@{fg text}
Construct a range reference.

@{b}Format:@{ub}
RANGE(col1,row1,col2,row2)
RANGE(sheet1,col1,row1,sheet2,col2,row)

@{b}Input:@{ub}
sheet:
  [optional] sheet1
column:
  col1
row:
  row1
sheet:
  [optional] sheet2
column:
  col2
row:
  row2

@{b}Output:@{ub}
range:
  a range that is constructed from the start and end
  sheets, columns and rows defined.

@{b}Example:@{ub}
sum(range(0,1,3,10)) = sum(a1:d10)

@{b}Note:@{ub}
RANGE() can only be used with a function expecting a range

@{b}See Also:@{ub}
@{"RINDEX" link func_RINDEX }, @{"CELL" link func_CELL }
@endnode

@node func_REGRES "Formula Function: REGRES..."
@{fg highlight}REGRES@{fg text}
Perform Multivariate Regression Analysis.

Multivariate Regression Analysis analyzes a dependant variable
compared to a set of independant variables to find out the
relationship between them.

To use this REGRES() you need the following data:

1.	A set of observations from the dependant variable.  These
	should be set up as a single column of data in the sheet.

2.	One or more sets of observations from the independant
	variables.  These should be set up as one or more columns
	of data in the sheet.

See the @{"Multivariate Regression Analysis" link "FinalCalc:guide/part4.guide/part4.4"} section for more
details.

@{b}Format:@{ub}
REGRES(indepenant variables range,dependant variable range,
  item,offset)

@{b}Input:@{ub}
range:
  independant variables range
range:
  dependant variable range

string:
  'item' controls what analysis is performed on the data
  ranges.  This must be one of the following:

  	R
  		Get Multiple R
  	R2
  		Get Multiple R˛
  	FV
  		Get F Value
  	FS
  		Get F Significance
  	MEAN
  		Get Y Mean
  	ERROR_I
  		Get Standard Error of Intercept
  	TEST_I
  		Get Test for Hypothesis: I = 0
  	SIG_I
  		Get Signifance of TEST_I
  	REG_SUM_SQUARES
  		Get Sum of Squares of Regression
  	RES_SUM_SQUARES
  		Get Sum of Squares of Residual
  	TOT_SUM_SQUARES
  		Get Total Sum of Squares
  	REG_FREEDOM
  		Get Degrees of Freedom of Regression
  	RES_FREEDOM
  		Get Degrees of Freedom of Residual
  	TOT_FREEDOM
  		Get Total Degrees of Freedom
  	REG_MEAN
  		Get Mean Square of Regression
  	RES_MEAN
  		Get Mean Square of Residual
  	RES_ERROR
  		Get Standard Error of Estimate
  	EST_I
  		Get Estimated Intercept

  	The following items require 'offset' to be defined:

  	EST_Y
  		Get Estimated Yn
  	EST_X
  		Get Estimated Xn value
  	ERROR_X
  		Get Standard Error for Xn
  	TEST_X
  		Get Test for Hypothesis: Xn = 0
  	SIG_X
  		Get Significance of TEST_X for Xn

number:
  [optional] offset
  Define the entry from a list to select.  This only
  applies to some items (as described above.)

  If 'offset' is outside the available data, zero is returned.

  If offset is not defined for an item that requires it, offset defaults to 0.

@{b}Output:@{ub}
number:
  required item, according to 'item' and 'offset' above.
ERROR:
  in the following cases:
  - The Dependant Variable Range contains one data column
  - The number of rows in Dependant and Independant Variables
    don't match."
  - Insufficient number of data points
  - Unknown item name."

@{b}Example:@{ub}
regres(a1:c10,d1:d10,"r2")		Get Multiple R˛
regres(a1:c10,d1:d10,"est_x",1)	Get Estimated X1

@{b}See Also:@{ub}
@{"FSIGN" link func_FSIGN }, @{"TSIGN" link func_TSIGN }
@endnode

@node func_RATE "Formula Function: RATE..."
@{fg highlight}RATE@{fg text}
Calculate the interest rate of an investment.

@{b}Format:@{ub}
RATE(future value,present value,periods)

@{b}Input:@{ub}
number:	future value
number:	present value
number:	periods

@{b}Output:@{ub}
number:
  the interest rate of an investment, given its present
  and future values and the number of periods using
  compound interest

@{b}Example:@{ub}
An amount of $10,000 today, would need an interest rate of
7.60% to be worth $30,000 in 15 years.  (with interest
compounded yearly)

rate(30000,10000,15) = 7.60%

If interest is compounded monthly, then divide the interest
rate by 12, and multiply the periods by 12.

@{b}See Also:@{ub}
@{"TERM" link func_TERM }, @{"FV" link func_FV }, @{"PV" link func_PV }
@endnode

@node func_RATEA "Formula Function: RATEA..."
@{fg highlight}RATEA@{fg text}
Calculate the interest rate on an annuity, given its future
value, present value and number of periods.

@{b}Format:@{ub}
RATEA(annuity,future value,periods)

@{b}Input:@{ub}
number:	annuity
number:	future value
number:	periods

@{b}Output:@{ub}
number:
  the interest rate of a stream of fixed payments, given
  the future value of the annuity and future values and
  the number of periods using compound interest

@{b}See Also:@{ub}
@{"TERMA" link func_TERMA }, @{"FVA" link func_FVA }, @{"PVA" link func_PVA }
@endnode

@node func_REMOVE "Formula Function: REMOVE..."
@{fg highlight}REMOVE@{fg text}
Remove specific characters from a string.

@{b}Format:@{ub}
REMOVE(str,template)

@{b}Input:@{ub}
string:	str
string:	template

@{b}Output:@{ub}
string:
  'str' with all characters that are in 'template' removed.

@{b}Example:@{ub}
remove("abcde 12345","cd34") = "abe 125"

@{b}See Also:@{ub}
@{"KEEP" link func_KEEP }
@endnode

@node func_REPEAT "Formula Function: REPEAT..."
@{fg highlight}REPEAT@{fg text}
Repeat a string multiple times.

@{b}Format:@{ub}
REPEAT(str,n)

@{b}Input:@{ub}
string:
  str
number:
  n

@{b}Output:@{ub}
string:
  'str' repeated n time, to a maximum of 2047 characters.

@{b}Example:@{ub}
repeat("test ",3) = "test test test "
@endnode

@node func_REPLACE "Formula Function: REPLACE..."
@{fg highlight}REPLACE@{fg text}
Replace a sub-string with another.

@{b}Format:@{ub}
REPLACE(str1,x,y,str2)

@{b}Input:@{ub}
string:
  str1
number:
  x
number:
  y
string:
  str2

@{b}Output:@{ub}
string:
  y characters from 'str1' are deleted starting at
  position x and 'str2' is inserted in their place

@{b}Example:@{ub}
replace("nice test",5,4,"TEST") = "NICE TEST"
@endnode

@node func_REVERSE "Formula Function: REVERSE..."
@{fg highlight}REVERSE@{fg text}
Reverse a string.

@{b}Format:@{ub}
REVERSE(str)

@{b}Input:@{ub}
string:	str

@{b}Output:@{ub}
string:	reversed string

@{b}Example:@{ub}
=lower("a test") = "tset a"
@endnode

@node func_RIGHT "Formula Function: RIGHT..."
@{fg highlight}RIGHT@{fg text}
Get part of the right side of a string.

@{b}Format:@{ub}
RIGHT(str,n)

@{b}Input:@{ub}
string:
  str
number:
  n

@{b}Output:@{ub}
string:
  the rightmost n characters from 'str'

@{b}Example:@{ub}
right("this is a test",6) = "a test"


@{fg highlight}RIGHT@{fg text}
Value or address of cell to the right of the current cell.

@{b}Format:@{ub}
RIGHT

@{b}Input:@{ub}
None

@{b}Output:@{ub}
cell:
  address or value of cell right of current cell

@{b}Example:@{ub}
=right+1    = cell to the right + 1
=col(right) = column number of cell to the right


@{b}See Also:@{ub}
@{"LEFT" link func_LEFT }, @{"ABOVE" link func_ABOVE }, @{"BELOW" link func_BELOW }, @{"MID" link func_MID }, @{"LEN" link func_LEN }
@endnode

@node func_RINDEX "Formula Function: RINDEX..."
@{fg highlight}RINDEX@{fg text}
Define a sub-range from a larger range.

@{b}Format:@{ub}
RINDEX(base range,start column offset,start row offset,
  end column offset,end row offset)

RINDEX(base range,start sheet offset,start column offset,
  start row offset,end sheet offset,end column offset,
  end row offset)

@{b}Input:@{ub}
range:	base range
number:	[optional] start sheet offset
number:	start column offset
number:	start row offset
number:	[optional] end sheet offset
number:	end column offset
number:	end row offset

@{b}Output:@{ub}
range:
  a range built from offsets within the base range
ERROR:
  if offsets are outside the base range

@{b}Example:@{ub}
rindex(C10:F100,0,0,0,0) = C10:C10
rindex(C10:F100,0,0,1,0) = C10:D10
rindex(C10:F100,1,0,3,0) = D10:F10
rindex(C10:F100,0,1,0,5) = C11:C15

@{b}Note:@{ub}
There are major benefits of using RINDEX() over RANGE():

  1.	Safety:
  	RINDEX() performs bounds checking for you and alerts you
  	with ERROR if you have built a range that is outside the
  	base range.  RANGE() has no safety net.

  2.	Speed:
  	Formulas with RANGE() are live, i.e. calculated every time
  	even if they haven't changed.  Formulas with RINDEX() are
  	only calculated when a cell in the base range changes.
  	This can make a big difference in speed in large sheets.

@{b}See Also:@{ub}
@{"INDEX" link func_INDEX }, @{"RANGE" link func_RANGE }
@endnode

@node func_ROMAN "Formula Function: ROMAN..."
@{fg highlight}ROMAN@{fg text}
Convert a number to a Roman Numerals string.

@{b}Format:@{ub}
ROMAN(x)

@{b}Input:@{ub}
number:
  x  (from 1 to 100,000)

@{b}Output:@{ub}
string:
  Roman Numerals string equivalent of x.

@{b}Example:@{ub}
roman(1993) = "MCMXCIII"
@endnode

@node func_ROUND "Formula Function: ROUND..."
@{fg highlight}ROUND@{fg text}
Round a number.

@{b}Format:@{ub}
ROUND(x,y)

@{b}Input:@{ub}
number:	x
number:	y

@{b}Output:@{ub}
number:	x rounded down to y digits

@{b}Example:@{ub}
round(1234.56789,4)     1234.5679
round(1234.56789,3)     1234.5680
round(1234.56789,2)     1234.5700
round(1234.56789,1)     1234.6000
round(1234.56789,0)     1235.0000
round(1234.56789,-1)    1230.0000
round(1234.56789,-2)    1200.0000
round(1234.56789,-3)    1000.0000
@endnode

@node func_ROW "Formula Function: ROW..."
@{fg highlight}ROW@{fg text}
Get row number of a cell or range.

@{b}Format:@{ub}
ROW()
ROW(cell)
ROW(range)
ROW(range,cell)

@{b}Input:@{ub}
cell:
  [optional] a cell name
range:
  [optional] a range name

@{b}Output:@{ub}
Depends on arguments provided:

ROW()
returns the row number of the current cell.

ROW(cell)
returns the row number of the provided cell.

ROW(range)
returns the row number of the top left cell in the provided
range.

ROW(range,cell)
returns the row offset of 'cell' in 'range', or ERROR if
'cell' is outside 'range'.

@{b}Example:@{ub}
row() = row number of current cell
row(c1) = 1
row(c2:d3) = 2
row(c1:e10,d3) = 2 (offset of row 3 to row 1)

@{b}See Also:@{ub}
@{"ROWS" link func_ROWS }, @{"COL" link func_COL }
@endnode

@node func_ROWS "Formula Function: ROWS..."
@{fg highlight}ROWS@{fg text}
Get number of rows in a range.

@{b}Format:@{ub}
ROWS(range)

@{b}Input:@{ub}
range:
  range

@{b}Output:@{ub}
number:
  number of rows in 'range'

@{b}Example:@{ub}
rows(a1:a10) = 10

@{b}See Also:@{ub}
@{"COLS" link func_COLS }, @{"SHEETS" link func_SHEETS }
@endnode

@node func_SECOND "Formula Function: SECOND..."
@{fg highlight}SECOND@{fg text}
Extract second number from a serial time number.

@{b}Format:@{ub}
SECOND(time)

@{b}Input:@{ub}
time:
  a serial time number

@{b}Output:@{ub}
number:
  the second number (0 to 59) in the serial time number

@{b}Example:@{ub}
second(now) = 23 (if the time is 10:12:23)

@{b}See Also:@{ub}
@{"TIME" link func_TIME }, @{"HOUR" link func_HOUR }, @{"MINUTE" link func_MINUTE }, @{"NOW" link func_NOW }
@endnode

@node func_SETCOLOR "Formula Function: SETCOLOR..."
@{fg highlight}SETCOLOR@{fg text}
Set a cell or range to a color number.

@{b}Format:@{ub}
SETCOLOR(cell/range,color)

@{b}Input:@{ub}
cell/range:
  cell or range specification

number:
  color number:
  	 0  default
  	 1  white
  	 2  red
  	 3  green
  	 4  blue
  	 5  orange
  	 6  pink
  	 7  cyan
  	 8  yellow

@{b}Output:@{ub}
None

@{b}Example:@{ub}
This function does NOT return any result, only zero.  So it	can
be safely added to the end of any formula:

=A1+SETCOLOR(HERE,IF(A1<0,2,1))
This sets the current cell to the value of A1, and its color to
white.  If the number is less than 0, it sets the color to red.

@{b}Note:@{ub}
This function may actually allocate new cells!  Use it with
caution.

@{b}See Also:@{ub}
@{"GETCOLOR" link func_GETCOLOR }, @{"SETSTYLE" link func_SETSTYLE }
@endnode

@node func_SETSTYLE "Formula Function: SETSTYLE..."
@{fg highlight}SETSTYLE@{fg text}
Set a cell or range to a specific style.

@{b}Format:@{ub}
SETSTYLE(cell/range,color)

@{b}Input:@{ub}
cell/range:
  cell or range specification

number:
  style number:
  	 0  normal
  	 1  bold
  	 2  italic
  	 4  undeline
  	 8  reverse
  	16  shaded

  	Combined styles are added together:
  	bold+italic  = 1+2  = 3

@{b}Output:@{ub}
None

@{b}Example:@{ub}
This function does NOT return any result, only zero.  So it	can
be safely added to the end of any formula:

=A1+SETSTYLE(HERE,IF(A1<0,9,1))
This sets the current cell to the value of A1, and its style to
bold.  If the number is less than 0, it sets the style to
bold-reverse.

@{b}Note:@{ub}
This function may actually allocate new cells!  Use it with
caution.

@{b}See Also:@{ub}
@{"GETSTYLE" link func_GETSTYLE }, @{"SETCOLOR" link func_SETCOLOR }
@endnode

@node func_SHEET "Formula Function: SHEET..."
@{fg highlight}SHEET@{fg text}
Get sheet number of a cell or range.

@{b}Format:@{ub}
SHEET()
SHEET(cell)
SHEET(range)
SHEET(range,cell)

@{b}Input:@{ub}
cell:
  [optional] a cell name
range:
  [optional] a range name

@{b}Output:@{ub}
Depends on arguments provided:

SHEET()
returns the sheet number of the current cell.

SHEET(cell)
returns the sheet number of the provided cell.

SHEET(range)
returns the sheet number of the top left cell in the provided
range.

SHEET(range,cell)
returns the sheet offset of 'cell' in 'range', or ERROR if
'cell' is outside 'range'.

@{b}Example:@{ub}
sheet() = sheet number of current cell
sheet(c_c1) = 3 (sheet C)
sheet(c_c1:e_d1) = 3 (sheet C)
sheet(a_c1:z_e10,b_d1) = 1 (offset of sheet B to sheet A)

@{b}See Also:@{ub}
@{"SHEETS" link func_SHEETS }, @{"COL" link func_COL }, @{"ROW" link func_ROW }
@endnode

@node func_SHEETS "Formula Function: SHEETS..."
@{fg highlight}SHEETS@{fg text}
Get the number of sheets in a range.

@{b}Format:@{ub}
SHEETS(range)

@{b}Input:@{ub}
range:
  a range name

@{b}Output:@{ub}
number:
  number of sheets in range

@{b}Example:@{ub}
cols(a_a1:c_z10) = 3

@{b}See Also:@{ub}
@{"ROWS" link func_ROWS }, @{"COLS" link func_COLS }
@endnode

@node func_SIGN "Formula Function: SIGN..."
@{fg highlight}SIGN@{fg text}
Test number for positive, negative or zero.

@{b}Format:@{ub}
SIGN(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
1:	if x > 0
0:	if x = 0
-1:	if x < 0

@{b}Example:@{ub}
if(sign(a1)=-1,"negative","positive")
@endnode

@node func_SIN "Formula Function: SIN..."
@{fg highlight}SIN@{fg text}
Sine of a number.

@{b}Format:@{ub}
SIN(x)

@{b}Input:@{ub}
number:
  x	(limit: x < 6.7465e+9)

@{b}Output:@{ub}
number:
  sine of x
ERROR:
  if x exceeds limits

@{b}Example:@{ub}
sin(12) = -0.536572918
@endnode

@node func_SINH "Formula Function: SINH..."
@{fg highlight}SINH@{fg text}
Hyperbolic sine of a number.

@{b}Format:@{ub}
SINH(x)

@{b}Input:@{ub}
number:
  x	(limit: x <= 709.778)

@{b}Output:@{ub}
number:
  hyperbolic sine of x
ERROR:
  if x exceeds limits

@{b}Example:@{ub}
sinh(12) = 81377.395
@endnode

@node func_SLN "Formula Function: SLN..."
@{fg highlight}SLN@{fg text}
Calculate the yearly straight-line depreciation amount of a
fixed asset.

@{b}Format:@{ub}
SLN(cost,salvage value,life)

@{b}Input:@{ub}
number:	cost
number:	salvage value
number:	life (in years)

@{b}Output:@{ub}
number:
  the yearly straight-line depreciation amount of a fixed
  asset taking into consideration its salvage value at
  the end of its life.  This is defined as:

  	SLN = (cost - salvage value)/life

@{b}Example:@{ub}
If an asset is worth $50,000, and is expected to last 7 years
and to be worth $10,000 at the end of its lifetime, the yearly
depreciation amount should be $5,714.28.

sln(50000,10000,7) = 5714.28

@{b}See Also:@{ub}
@{"SYD" link func_SYD }
@endnode

@node func_SQRT "Formula Function: SQRT..."
@{fg highlight}SQRT@{fg text}
Square root of a number.

@{b}Format:@{ub}
SQRT(x)

@{b}Input:@{ub}
number:
  x	(limits: x >= 0.0)

@{b}Output:@{ub}
number:
  square root of x

@{b}Example:@{ub}
sqrt(4)	= 2
@endnode

@node func_STD "Formula Function: STD..."
@{fg highlight}STD@{fg text}
Standard deviation of one or more numeric values.

@{b}Format:@{ub}
STD(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells that contain numeric values
 - ranges (only cells with numeric contents in the range are used)

@{b}Output:@{ub}
number:
  Standard deviation of all arguments provided.

@{b}Example:@{ub}
std(a1:b10,12,100,a1/23))
std(100,a1,b10:c20,cos(12))

@{b}See Also:@{ub}
@{"COUNT" link func_COUNT }, @{"AVG" link func_AVG }, @{"SUM" link func_SUM }, @{"STDS" link func_STDS }
@endnode

@node func_STDS "Formula Function: STDS..."
@{fg highlight}STDS@{fg text}
Standard deviation of a sample population of one or more
numeric values.

@{b}Format:@{ub}
STDS(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells that contain numeric values
 - ranges (only cells with numeric contents in the range are used)

@{b}Output:@{ub}
number:
  Standard deviation of a sample population of all
  arguments provided.

@{b}Example:@{ub}
stds(a1:b10,12,100,a1/23))
stds(100,a1,b10:c20,cos(12))

@{b}See Also:@{ub}
@{"COUNT" link func_COUNT }, @{"AVG" link func_AVG }, @{"SUM" link func_SUM }, @{"STD" link func_STD }
@endnode

@node func_STR "Formula Function: STR..."
@{fg highlight}STR@{fg text}
Get a string.

@{b}Format:@{ub}
STR(str)

@{b}Input:@{ub}
string:	str

@{b}Output:@{ub}
string:
  if str is a string, str is returned, otherwise a null
  string ("") is returned.

@{b}Example:@{ub}
len(str(a1))  This makes sure that LEN() always gets a string
argument.  Without STR(), if a1 was a number, LEN() would cause
an ERROR.

@{b}Note:@{ub}
STR is used where you want to make sure that a string is
provided to another function and not a number.

@{b}See Also:@{ub}
@{"NUM" link func_NUM }
@endnode

@node func_STRING "Formula Function: STRING..."
@{fg highlight}STRING@{fg text}
Convert a number to a string with fixed number of decimals.

@{b}Format:@{ub}
STRING(x,n)

@{b}Input:@{ub}
number:	x    number to convert
number: n    number of decimals places

@{b}Output:@{ub}
string:	a string with the value of x

@{b}Example:@{ub}
string(12.345,2) = "12.34"
string(12.345,5) = "12.34500"

@{b}See Also:@{ub}
@{"DEC" link func_DEC }, @{"VALUE" link func_VALUE }
@endnode


@node func_SUM "Formula Function: SUM..."
@{fg highlight}SUM@{fg text}
Sum of one or more numeric values.

@{b}Format:@{ub}
SUM(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells that contain numeric values
 - ranges (only cells with numeric contents in the range are used)

@{b}Output:@{ub}
number:
  Sum of all arguments provided.

@{b}Example:@{ub}
sum(a1:b10,12,100,a1/23))
sum(100,a1,b10:c20,cos(12))

@{b}See Also:@{ub}
@{"COUNT" link func_COUNT }, @{"AVG" link func_AVG }, @{"CSUM" link func_CSUM }, @{"FSUM" link func_FSUM }
@endnode

@node func_SYD "Formula Function: SYD..."
@{fg highlight}SYD@{fg text}
Calculate the yearly depreciation amount of a fixed asset for a
number of periods using the sum-of-the-years'-digits method.

@{b}Format:@{ub}
SYD(cost,salvage value,life,period)

@{b}Input:@{ub}
number:	cost
number:	salvage value
number:	life (in years)
number:	period (in years)

@{b}Output:@{ub}
number:
  the depreciation amount for the selected period of a
  fixed asset for a number of periods, taking into
  consideration its salvage value at the end of its life,
  using the sum-of-the-years'-digits method.  This method
  has an accelerated deprecation in the early years of an
  asset's life.

@{b}See Also:@{ub}
@{"SLN" link func_SLN }
@endnode

@node func_SYMBOL "Formula Function: SYMBOL..."
@{fg highlight}SYMBOL@{fg text}
Get the Graph Symbol number.

@{b}Format:@{ub}
SYMBOL(str)

@{b}Input:@{ub}
string:
  str (string matching the name of a Graph Symbol)

@{b}Output:@{ub}
number:
  number of symbol in graph symbols list, or 0 if it
  was not found.

@{b}Example:@{ub}
pattern("square") = 4 (number of pattern 'square')

@{b}See Also:@{ub}
@{"COLOR" link func_COLOR }, @{"PATTERN" link func_PATTERN }
@endnode

@node func_TAN "Formula Function: TAN..."
@{fg highlight}TAN@{fg text}
Tangent of a number.

@{b}Format:@{ub}
TAN(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
number:	tangent of x

@{b}Example:@{ub}
tan(12) = -0.636

@{b}See Also:@{ub}
@{"SIN" link func_SIN }, @{"COS" link func_COS }, @{"TANH" link func_TANH }, @{"ATAN" link func_ATAN }, @{"ATAN2" link func_ATAN2 }
@endnode

@node func_TANH "Formula Function: TANH..."
@{fg highlight}TANH@{fg text}
Hyperbolic tangent of a number.

@{b}Format:@{ub}
TANH(x)

@{b}Input:@{ub}
number:	x

@{b}Output:@{ub}
number:	hyperbolic tangent of x

@{b}Example:@{ub}
tanh(1) = 0.762

@{b}See Also:@{ub}
@{"SIN" link func_SIN }, @{"COS" link func_COS }, @{"TAN" link func_TAN }, @{"ATAN" link func_ATAN }, @{"ATAN2" link func_ATAN2 }
@endnode

@node func_TERM "Formula Function: TERM..."
@{fg highlight}TERM@{fg text}
Calculate the number of periods required to reach a certain
future value.

@{b}Format:@{ub}
TERM(interest rate,future value,present value)

@{b}Input:@{ub}
number:	rate of interest
number:	future value
number:	present value

@{b}Output:@{ub}
number:
  number of periods required to reach the specified future
  value, given the interest rate and the present value.

@{b}Example:@{ub}
An amount of $10,000 today, would need 14.275 periods at an
interest rate of 8% to be worth $30,000 in 15 years.  (with
interest compounded yearly)

term(8%,30000,10000) = 14.275

If interest is compounded monthly, then divide the interest
rate by 12, and multiply the periods by 12.

@{b}See Also:@{ub}
@{"FV" link func_FV }, @{"PV" link func_PV }, @{"RATE" link func_RATE }
@endnode

@node func_TERMA "Formula Function: TERMA..."
@{fg highlight}TERMA@{fg text}
Calculate the number of periods required to reach a certain
future value for a stream of fixed payments.

@{b}Format:@{ub}
TERMA(annuity,interest rate,future value)

@{b}Input:@{ub}
number:	annuity
number:	interest rate
number:	future value

@{b}Output:@{ub}
number:
  number of periods required to reach the specified
  future value for a stream of fixed payments at a
  specific rate of interest

@{b}Example:@{ub}
A stream of payments of $1000 each would need 28.55 periods
to be worth $100,000 presuming an interest rate of 8%.
(with interest compounded yearly)

terma(1000,8%,100000) = 28.55

If interest is compounded monthly, then divide the interest
rate by 12, and multiply the periods by 12.

@{b}See Also:@{ub}
@{"FVA" link func_FVA }, @{"PVA" link func_PVA }, @{"RATEA" link func_RATEA }
@endnode

@node func_THERE "Formula Function: THERE..."
@{fg highlight}THERE@{fg text}
Cell address of cursor.

@{b}Format:@{ub}
THERE

@{b}Input:@{ub}
None

@{b}Output:@{ub}
cell:
  address of cell where the cursor is currently pointing

@{b}Example:@{ub}
col(there) = column where the cursor currently is

@{b}See Also:@{ub}
@{"HERE" link func_HERE }
@endnode

@node func_TIME "Formula Function: TIME..."
@{fg highlight}TIME@{fg text}
Calculate a serial time number from time components.

@{b}Format:@{ub}
TIME(hour,minute,second)

@{b}Input:@{ub}
number:	hour (0 to 23)
number:	minute (0 to 59)
number:	second (0 to 59)

@{b}Output:@{ub}
time:
  serial time number calculated from hour, minute and
  second arguments

@{b}Example:@{ub}
time(12,0,0) = 0.5

@{b}See Also:@{ub}
@{"TIMESTR" link func_TIMESTR }, @{"TIMEVALUE" link func_TIMEVALUE }, @{"HOUR" link func_HOUR }, @{"MINUTE" link func_MINUTE }, @{"SECOND" link func_SECOND }, @{"NOW" link func_NOW }
@endnode

@node func_TIMESTR "Formula Function: TIMESTR..."
@{fg highlight}TIMESTR@{fg text}
Convert a time number to a string using a custom format.

@{b}Format:@{ub}
TIMESTR(str,time)

@{b}Input:@{ub}
string:
  str
time:
  time

@{b}Output:@{ub}
string:
  convert time to a string using the string format
  provided in 'str'

@{b}Example:@{ub}
timestr("h:mm aa",NOW) = "12:10 am"

@{b}See Also:@{ub}
@{"TIME" link func_TIME }, @{"TIMEVALUE" link func_TIMEVALUE }, @{"HOUR" link func_HOUR }, @{"MINUTE" link func_MINUTE }, @{"SECOND" link func_SECOND }, @{"NOW" link func_NOW }
@endnode

@node func_TIMEVALUE "Formula Function: TIMEVALUE..."
@{fg highlight}TIMEVALUE@{fg text}
Convert a string from text to a time number.

@{b}Format:@{ub}
TIMEVALUE(str)

@{b}Input:@{ub}
string:	str

@{b}Output:@{ub}
time:
  the time number in 'str'.  This	must contain a string
  that looks like a time number, e.g. "12:00" or "12:10:00".

ERROR:	if str doesn't look like a time number

@{b}Example:@{ub}
timevalue("12:00") = 0.5

@{b}See Also:@{ub}
@{"TIME" link func_TIME }, @{"TIMESTR" link func_TIMESTR }, @{"HOUR" link func_HOUR }, @{"MINUTE" link func_MINUTE }, @{"SECOND" link func_SECOND }, @{"NOW" link func_NOW }
@endnode

@node func_TODAY "Formula Function: TODAY..."
@{fg highlight}TODAY@{fg text}
Current system date.

@{b}Format:@{ub}
TODAY

@{b}Input:@{ub}
None

@{b}Output:@{ub}
date:
  serial date number for the current date.  The date
  serial number is defined as the number of days since
  1-Jan-1978.

@{b}Example:@{ub}
if the date is 1-Feb-1994, TODAY will return 5875, where 5875
is the number of days since 1-Jan-1978.

@{b}Note:@{ub}
TODAY is not a live function, it is only evaluated:
  a.	if the cell has changed.
  b.	if the current system date has changed since the last
  	recalc.
  c.	when the project is first loaded.

@{b}See Also:@{ub}
@{"NOW" link func_NOW }, @{"DATE" link func_DATE }, @{"YEAR" link func_YEAR }, @{"MONTH" link func_MONTH }, @{"DAY" link func_DAY }
@endnode

@node func_TRANSLATE "Formula Function: TRANSLATE..."
@{fg highlight}TRANSLATE@{fg text}
Convert characters in a string.

@{b}Format:@{ub}
TRANSLATE(str,template1,template2)

@{b}Input:@{ub}
string:	str
string:	template1
string:	template2

@{b}Output:@{ub}
string:
  'str' is copied as is except for any character that is
  found in 'template1' is replaced with the corresponding
  character from 'template2'.

@{b}Example:@{ub}
translate("this is a test","th","TH") = "THis is a TesT"
translate("this is a test","th","12") = "12is is a 1es1"
@endnode

@node func_TRIM "Formula Function: TRIM..."
@{fg highlight}TRIM@{fg text}
Clean multiple spaces from a string.

@{b}Format:@{ub}
TRIM(str)

@{b}Input:@{ub}
string:	str

@{b}Output:@{ub}
string:
  contents of str except that multiple spaces are converted
  into a single space.  Trailing spaces are also removed.

@{b}Example:@{ub}
trim("this    is   a    test   ") = "this is a test"
@endnode

@node func_TRUE "Formula Function: TRUE..."
@{fg highlight}TRUE@{fg text}
Constant: value of TRUE (1).

@{b}Format:@{ub}
TRUE

@{b}Input:@{ub}
None

@{b}Output:@{ub}
TRUE (1)

@{b}See Also:@{ub}
@{"FALSE" link func_FALSE }
@endnode

@node func_TSIGN "Formula Function: TSIGN..."
@{fg highlight}TSIGN@{fg text}
Get Significance of T Value given the degrees of freedom.
(used for @{"Multivariate Regression Analysis" link "FinalCalc:guide/part4.guide/part4.4"})

@{b}Format:@{ub}
TSIGN(f value,degrees of freedom)

@{b}Input:@{ub}
number:	t value
number:	degrees of freedom

@{b}Output:@{ub}
number:
  Significance of T value given the provided degrees of
  freedom.

@{b}See Also:@{ub}
@{"REGRES" link func_REGRES }, @{"FSIGN" link func_FSIGN }
@endnode

@node func_UPPER "Formula Function: UPPER..."
@{fg highlight}UPPER@{fg text}
Convert a string to uppercase characters.

@{b}Format:@{ub}
UPPER(str)

@{b}Input:@{ub}
string:	str

@{b}Output:@{ub}
string:	converts str to all uppercase characters

@{b}Example:@{ub}
upper("test") = "TEST"

@{b}See Also:@{ub}
@{"LOWER" link func_LOWER }, @{"PROPER" link func_PROPER }
@endnode

@node func_VALUE "Formula Function: VALUE..."
@{fg highlight}VALUE@{fg text}
Convert a string to a number.

@{b}Format:@{ub}
VALUE(expression)

@{b}Input:@{ub}
string:
  expression, any valid formula or math expression

@{b}Output:@{ub}
result:
  number or string depending on result of evaluated
  expression
ERROR:
  if expression was not valid

@{b}Example:@{ub}
evaluate("sin(12)") = sine of 12

@{b}Note:@{ub}
You can use cell and range names in 'expression' but it is not
recommended since VALUE() is not a live function.  If you need
to use cell or range names, use the EVALUATE() function
instead.

@{b}See Also:@{ub}
@{"EVALUATE" link func_EVALUATE }, @{"STRING" link func_STRING }, @{"DEC" link func_DEC }
@endnode

@node func_VAR "Formula Function: VAR..."
@{fg highlight}VAR@{fg text}
Variance of one or more numeric values.

@{b}Format:@{ub}
VAR(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells that contain numeric values
 - ranges (only cells with numeric contents in the range are used)

@{b}Output:@{ub}
number:
  Variance of all arguments provided

@{b}Example:@{ub}
var(a1:b10,12,100,a1/23))
var(100,a1,b10:c20,cos(12))

@{b}See Also:@{ub}
@{"VARS" link func_VARS }, @{"SUM" link func_SUM }, @{"COUNT" link func_COUNT }, @{"AVG" link func_AVG }
@endnode

@node func_VARS "Formula Function: VARS..."
@{fg highlight}VARS@{fg text}
Variance of a sample population of one or more numeric values.

@{b}Format:@{ub}
VARS(multiple range/cell/expression arguments)

@{b}Input:@{ub}
One or more of:
 - numbers
 - cells that contain numeric values
 - ranges (only cells with numeric contents in the range are used)

@{b}Output:@{ub}
number:
  Variance of a sample population of all arguments provided

@{b}Example:@{ub}
vars(a1:b10,12,100,a1/23))
vars(100,a1,b10:c20,cos(12))

@{b}See Also:@{ub}
@{"VAR" link func_VAR }, @{"SUM" link func_SUM }, @{"COUNT" link func_COUNT }, @{"AVG" link func_AVG }
@endnode

@node func_VLOOK "Formula Function: VLOOK..."
@{fg highlight}VLOOK@{fg text}
Look up a value from a table with a column offset.

@{b}Format:@{ub}
VLOOK(value to be looked up,range,column offset)

@{b}Input:@{ub}
number:
  value to be looked up
range:
  range
number:
  column offset (limits:	offset >= 0)

@{b}Output:@{ub}
number:
  the table defined by 'range' is searched vertically
  for the largest value that is not greater than the
  look-up value, then the column offset is used to look
  up another value horizontally from the table, which is
  returned.

ERROR:
  if offset is negative or value not found in table

VLOOK() will also return a cell or range address if used as a
cell or range argument to another function.

@{b}See Also:@{ub}
@{"HLOOK" link func_HLOOK }
@endnode

@node func_WINDCHILL "Formula Function: WINDCHILL..."
@{fg highlight}WINDCHILL@{fg text}
Calculate the wind chill temperature.

@{b}Format:@{ub}
WINDCHILL(temperature,wind speed)

@{b}Input:@{ub}
number:
  temperature (in degrees Celcius)
number:
  wind speed (in kilometers per hour)

@{b}Output:@{ub}
number:
  wind chill factor (in degress Celcius) for the
  temperature and wind speed specified

@{b}Example:@{ub}
If the current temperature is 11 degress Celcius and the wind
speed is 20 kilometers per hour, the wind chill temperature is
4.83 degress Celcius

windchill(11,20) = 4.83
@endnode

@node func_WORD "Formula Function: WORD..."
@{fg highlight}WORD@{fg text}
Get a specific word from a string.

@{b}Format:@{ub}
WORD(str,n)

@{b}Input:@{ub}
string:
  str
number:
  n

@{b}Output:@{ub}
string:
  the n'th word from 'str'.  If n is more than the number
  of words in 'str', a null string ("") is returned.

@{b}Example:@{ub}
word("this is a test",2) = "is"

@{b}Note:@{ub}
A word is defined as a group of alphanumeric characters
separated from another 'word' by one or more non-alphanumeric
characters.

@{b}See Also:@{ub}
@{"WORDS" link func_WORDS }
@endnode

@node func_WORDS "Formula Function: WORDS..."
@{fg highlight}WORDS@{fg text}
Get the number of words in a string.

@{b}Format:@{ub}
WORDS(str)

@{b}Input:@{ub}
string:
  str

@{b}Output:@{ub}
number:
  the number of words in string 'str'

@{b}Example:@{ub}
words("this is a test") = 4

@{b}Note:@{ub}
A word is defined as a group of alphanumeric characters
separated from another 'word' by one or more non-alphanumeric
characters.

@{b}See Also:@{ub}
@{"WORD" link func_WORD }
@endnode

@node func_YEAR "Formula Function: YEAR..."
@{fg highlight}YEAR@{fg text}
Get year number from a serial date number.

@{b}Format:@{ub}
YEAR(date)

@{b}Input:@{ub}
date:
  serial date number

@{b}Output:@{ub}
number:
  the year number from the provided serial date number

@{b}Example:@{ub}
day(today) = 1994  (if the current year was 1994)

@{b}See Also:@{ub}
@{"DATE" link func_DATE }, @{"DAY" link func_DAY }, @{"MONTH" link func_MONTH }, @{"TODAY" link func_TODAY }, @{"DATESTR" link func_DATESTR }, @{"DATEVALUE" link func_DATEVALUE }
@endnode

