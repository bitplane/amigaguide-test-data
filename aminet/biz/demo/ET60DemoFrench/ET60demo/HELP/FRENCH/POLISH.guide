 @{b}ImiesÓůw.@{ub}

 @{"†ImiesÓůw†przysÓůwkowy†(participe†prťsent)††††††††††††††††††††††††††" link "1450" 0}
 @{"†ImiesÓůw†przymiotnikowy†(participe†passť)††††††††††††††††††††††††††" link "1455" 0}
