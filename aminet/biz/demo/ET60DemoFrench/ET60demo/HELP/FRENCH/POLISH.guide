@node "1090" "Rodzajnik Űci‚gniŽty"

 @{b}Rodzajnik Űci‚gniŽty.@{ub}

 Zobacz takŻe: @{"†Rodzajnik†okreŰlony††††" link "1060" 0}
               @{"†Rodzajnik†nieokreŰlony†" link "1070" 0}
               @{"†Rodzajnik†cz‚stkowy††††" link "1080" 0}
               @{"†Opuszczenie†rodzajnika†" link "1100" 0}

            l.poj.       l.mn.
 r. mŽski   @{b}au, du       aux, des@{ub}
 r. ŻeÔski  @{b}„ la, de la  aux, des@{ub}

Rodzajnik ten powstaje z poÓ‚czenia rodzajnika okreŰlonego z przyimkami "„" i "de":
 „ + le   = au,
 „ + les  = aux
 de + le  = du,
 de + les = des

 @{b}Je parle du film.@{ub}
 MůwiŽ o filmie.
@endnode

@node "1100" "Opuszczenie rodzajnika"

