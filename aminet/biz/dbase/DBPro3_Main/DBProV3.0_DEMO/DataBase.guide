@NODE DATUM "Datumformate"
@{b}M÷glichkeiten f³r den Standardeintrag beim Feldtyp "Datum"@{ub}


       @{u}Platzhalter  Bedeutung                     @{uu}
       %d           Tag als zweistellige Zahl
       %m           Monat als zweistellige Zahl
       %t           Monat als Text
       %y           Jahr als zweistellige Zahl
       %Y           Jahr als vierstellige Zahl
       %H           Stunde als zweistellige Zahl
       %M           Minute als zweistellige Zahl
       %S           Sekunde als zweistellige Zahl
       %%           Das Zeichen "%" selbst


@{i}Bespiele:@{ui} %d.%m.%Y
          %d. %t '%y
          Gl³ckshausen, den %d/%m/%y
          Am %d.%m um %H:%M

@ENDNODE
