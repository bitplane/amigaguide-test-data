@node "2 Routine · Get_FONT.PREFS" "Routine · Get_FONT.PREFS"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get_FONT.PREFS
 
Local READFILE="ENV:sys/font.prefs",X=0,SizeVar="",FontVar=""
If EXISTS(READFILE)=TRUE
	IfError
		Let SysDefText="topaz",SysDefTextSize=8
	Else
		If FileSize(READFILE)>""
			GetFileInfo READFILE,FILECNT
			SetFileBufferSize Limit(1,1024,Integer(FILECNT%1024))
			OpenFile READFILE,"WORKFILE",READONLY ,OLDFILE 
			FileReadChars "WORKFILE",X,223
			FileReadChars "WORKFILE",SizeVar,1,HEX 
			FileReadChars "WORKFILE",X,2
			FileReadChars "WORKFILE",FontVar,30
			Let SysDefTextSize=HexToInteger(SizeVar)
			Let SysDefText=GetWord(FontVar,1,".")
			Close "WORKFILE"
		Else
			Let SysDefText="topaz",SysDefTextSize=8
		EndIf
	EndIf
Else
	Let SysDefText="topaz",SysDefTextSize=8
EndIf
GetFontInfo SCREEN ,ScreenText,ScreenTextSize
Let GOS=ScreenTextSize+3
@endnode
 
@node "3 Routine · Get_PUBSCREEN.PREFS" "Routine · Get_PUBSCREEN.PREFS"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get_PUBSCREEN.PREFS
 
Loop CNT,1,10
	If NOT PUBSCREENEXISTS("A2K_PubScreen."||CNT)
		ExitLoop
	EndIf
EndLoop
Let PROG.PUBSCRTITLE="A2K_PubScreen."||CNT
@endnode
 
@node "4 Routine · Set_PROG.VARS" "Routine · Set_PROG.VARS"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Set_PROG.VARS
 
Let PROG.SCRTITLE=DECKNAME|||"Version 1.0"|||"(14-Dec-00)"|||" "|||"Public Screen"||":"|||Char(34)||PROG.PUBSCRTITLE||Char(34)
Let PROG.SCRTITLE=PROG.SCRTITLE|||" "|||GetWord(THEDATE,2,"/")||"-"||GetWord(THEDATE,1,"/")||"-"||GetWord(THEDATE,3,"/")
@endnode
 
@node "5 Routine · Get Date" "Routine · Get Date"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get Date
 
Let Day=GetWord(TheDate,2,"/")
Let Month=GetWord(TheDate,1,"/")
Let Year=GetWord(TheDate,3,"/")
@endnode
 
@node "6 Routine · MakeName" "Routine · MakeName"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} MakeName
 
If Name<>""
	If Number<>0
		Let NameKey=CharsToHex(Name||Char(10)||Number||Char(10)||HexToChars("545247"))
		SaveVariable NameKey,"S:A2K.key"
		Do "KeyFile"
		SaveVariable ©2000,"S:A2K.key"
		Do "KeyFile"
		Let PROG.PUBSCRTITLE="A2K_PubScreen."||CNT
		If EXISTS("A2K:A2K.Prefs")
			AttachObject "Main"
			DetachObject "Welcome"
		Else
			OpenWindow "A2KSubDeck","PrefsWindow"
		EndIf
	EndIf
EndIf
@endnode
 
@node "7 Routine · KeyFile" "Routine · KeyFile"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} KeyFile
 
Let ©1994=HexToChars("533A41324B2E6B6579")
If EXISTS(©1994)
	Let FCnt=1
	If FILETYPE(©1994)=HexToChars("43445652")
		IfError
		Else
			Let ©1995=LoadVariable(©1994)
			Let ©1996=HexToChars(©1995)
			Let ©1997=NumberOfChars(©1996),©1998=0,©1999="",©1990=""
			Loop
				Let ©1998=©1998+1
				Let ©1999=Char(Absolute(ASCII(Getchars(©1996,©1998,1))-255))
				Let ©2000=©2000||CharsToHex(©1999)
				Let ©1990=©1990||©1999
			Until ©1998=©1997
			Let ®2001=GetWord(©1990,1,Char(10)),®2002=GetWord(©1990,2,Char(10)),®2003=GetWord(©1990,3,Char(10))
		EndIf
	EndIf
EndIf
@endnode
 
@node "8 Routine · Quit" "Routine · Quit"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Quit
 
If Exists("Ram:A2KData")
	Dos "C:Delete Ram:A2KData All"
EndIf
Dos "C:Delete Ram:A2K.Prefs"
Dos "C:Delete Ram:A2K.Tax"
Dos "C:Assign A2K: "
Quit
@endnode
 
@node "9 Routine · Set Prefs" "Routine · Set Prefs"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Set Prefs
 
Let A2KPrefs.Date=DefDate
Let A2KPrefs.Note=DefNote
Let A2KPrefs.DistDir=DefDistDir
Let A2KPrefs.DataDir=DefDataDir
Let A2KPrefs.OrdDir=DefOrdDir
Let A2KPrefs.CustDir=DefCustDir
Let A2KPrefs.PenA=DefPenA
Let A2KPrefs.PenB=DefPenB
Let A2KPrefs.PenC=DefPenC
Let A2KPrefs.BGPic=DefBGPic
Let A2KPrefs.TBGPic=DefTBGPic
Let A2KPrefs.DBGPic=DefDBGPic
Let A2KPrefs.OBGPic=DefOBGPic
Let A2KPrefs.CBGPic=DefCBGPic
Let A2KPrefs.PBGPic=DefPBGPic
Let A2KPrefs.PalDir=DefPalDir
Let A2KPrefs.Palette=DefPalBuf
Let A2KPrefs.DefPrefsWinX=DefPrefsWinX
Let A2KPrefs.DefPrefsWiny=DefPrefsWinY
Let A2KPrefs.DefTaxWinX=DefTaxWinX
Let A2KPrefs.DefTaxWiny=DefTaxWiny
Let A2KPrefs.DefListWinX=DefListWinX
Let A2KPrefs.DefListWiny=DefListWiny
Let A2KPrefs.DefStockWinX=DefStockWinX
Let A2KPrefs.DefStockWiny=DefStockWiny
@endnode
 
@node "10 Routine · Set Def" "Routine · Set Def"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Set Def
 
Let DefDate=A2KPrefs.Date
Let DefNote=A2KPrefs.Note
Let DefDistDir=A2KPrefs.DistDir
Let DefDataDir=A2KPrefs.DataDir
Let DefOrdDir=A2KPrefs.OrdDir
Let DefCustDir=A2KPrefs.CustDir
Let DefBGPic=A2KPrefs.BGPic
Let DefTBGPic=A2KPrefs.TBGPic
Let DefDBGPic=A2KPrefs.DBGPic
Let DefOBGPic=A2KPrefs.OBGPic
Let DefCBGPic=A2KPrefs.CBGPic
Let DefPBGPic=A2KPrefs.PBGPic
Let DefPenA=A2KPrefs.PenA
Let DefPenB=A2KPrefs.PenB
Let DefPenC=A2KPrefs.PenC
Let DefPalBuf=A2KPrefs.Palette
Let DefPalDir=A2KPrefs.PalDir
Let DefPrefsWinX=A2KPrefs.DefPrefsWinX
Let DefPrefsWinY=A2KPrefs.DefPrefsWinY
Let DefTaxWinX=A2KPrefs.DefTaxWinX
Let DefTaxWinY=A2KPrefs.DefTaxWinY
Let DefListWinX=A2KPrefs.DefListWinX
Let DefListWiny=A2KPrefs.DefListWiny
Let DefStockWinX=A2KPrefs.DefStockWinX
Let DefStockWiny=A2KPrefs.DefStockWiny
@endnode
 
@node "11 Routine · Make Def" "Routine · Make Def"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Make Def
 
Let N=0,DefNote="$",DefDate="DMY"
Do "Make Ram Dir"
Do "Make Sys Dir"
Let DefDistDir="A2K:A2KData/DistData",DefDataDir="A2K:A2KData/StockData"
Let DefOrdDir="A2K:A2KData/OrderData",DefCustDir="A2K:A2KData/CustData"
Let DefPenA=1,DefPenB=2,DefPenC=3
If Exists("A2K:BGPics/Default.bg")
	Let DefBGPic="A2K:BGPics/Default.bg"
	Let DefTBGPic="A2K:BGPics/Default.bg"
	Let DefDBGPic="A2K:BGPics/Default.bg"
	Let DefOBGPic="A2K:BGPics/Default.bg"
	Let DefCBGPic="A2K:BGPics/Default.bg"
	Let DefPBGPic="A2K:BGPics/Default.bg"
Else
	Let DefBGPic=""
	Let DefTBGPic=""
	Let DefDBGPic=""
	Let DefOBGPic=""
	Let DefCBGPic=""
	Let DefPBGPic=""
EndIf
If Exists("A2K:Palette")
	Let DefPalBuf="Palette",DefPalDir="A2K:Palette"
	LoadPalette "Palette",DefPalBuf,ASNEEDED 
Else
	ClipBrush 10,20,40,40,"PaletteBrush"
	SaveBrush "PaletteBrush","A2K:Palette"
	Let DefPalBuf="Palette",DefPalDir="A2K:Palette"
	LoadPalette "Palette",DefPalBuf,ASNEEDED 
EndIf
Let DefPrefsWinX=0
Let DefPrefsWiny=0
Let DefTaxWinX=0
Let DefTaxWiny=0
Let DefListWinX=0
Let DefListWiny=0
Let DefStockWinX=0
Let DefStockWiny=0
@endnode
 
@node "12 Routine · Make Ram Dir" "Routine · Make Ram Dir"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Make Ram Dir
 
If Not Exists("Ram:A2KData")
	Dos "C:MakeDir Ram:A2KData"
EndIf
If Not Exists("Ram:A2KData/DistData")
	Dos "C:MakeDir Ram:A2KData/DistData"
EndIf
If Not Exists("Ram:A2KData/StockData")
	Dos "C:MakeDir Ram:A2KData/StockData"
EndIf
If Not Exists("Ram:A2KData/OrderData")
	Dos "C:MakeDir Ram:A2KData/OrderData"
EndIf
If Not Exists("Ram:A2KData/CustData")
	Dos "C:MakeDir Ram:A2KData/CustData"
EndIf
If Not Exists("Ram:A2KData/PrintData")
	Dos "C:MakeDir Ram:A2KData/PrintData"
EndIf
@endnode
 
@node "13 Routine · Make Sys Dir" "Routine · Make Sys Dir"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Make Sys Dir
 
If Not Exists("A2K:A2KData")
	Dos "C:MakeDir A2K:A2KData"
EndIf
If Not Exists("A2K:A2KData/DistData")
	Dos "C:MakeDir A2K:A2KData/DistData"
ElseIf Exists("A2K:A2KData/DistData/Dist.Data")
	Dos "C:Copy A2K:A2KData/StockData/Dist.Data Ram:A2KData/DistData"
EndIf
If Not Exists("A2K:A2KData/StockData")
	Dos "C:MakeDir A2K:A2KData/StockData"
ElseIf Exists("A2K:A2KData/StockData/Stock.Data")
	Dos "C:Copy A2K:A2KData/StockData/Stock.Data Ram:A2KData/StockData"
EndIf
If Not Exists("A2K:A2KData/OrderData")
	Dos "C:MakeDir A2K:A2KData/OrderData"
ElseIf Exists("A2K:A2KData/OrderData/Order.Data")
	Dos "C:Copy A2K:A2KData/OrederData/Order.Data Ram:A2KData/OrderData"
EndIf
If Not Exists("A2K:A2KData/CustData")
	Dos "C:MakeDir A2K:A2KData/CustData"
ElseIf Exists("A2K:A2KData/CustData/Cust.Data")
	Dos "C:Copy A2K:A2KData/CustData/Cust.Data Ram:A2KData/CustData"
EndIf
If Exists("A2K:A2KData/A2K.tax")
	Dos "C:Copy A2K:A2KData/A2K.tax Ram:A2KData"
EndIf
@endnode
 
@node "14 Routine · FileType ErrorCheck" "Routine · FileType ErrorCheck"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} FileType ErrorCheck
 
Let ER="You Have A Problem",ERD="This Means that You are using the wrong type of Data file."
Let TempFileName=FileName
If MATCH(FILETYPE(TempFileName),"CDVR")
	Let TempFile=LoadVariable(TempFileName)
EndIf
If MATCH(FILETYPE(TempFileName),"Picture","Brush")
	LoadPalette TempFileName,"DefPalBuf",ASNEEDED 
EndIf
If MATCH(FILETYPE(TempFileName),"Unknown")
	Let ET=Errortext
	If ET="Invalid variable name"
		DisposeAll
		Do "Make Def"
		Do "Set Prefs"
		SaveVariable A2KPrefs,"Ram:A2K.prefs"
	Else
		Let AFR=AskForResponse(ER||Char(10)||ET,"Error...")
	EndIf
EndIf
@endnode
 
@node "15 Routine · ShowBrush" "Routine · ShowBrush"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} ShowBrush
 
Let WBL=WindowBorderLeft
Let WBT=WindowBorderTop
Let WW=WindowWidth
Let WBR=WindowBorderRight
Let WH=WindowHeight
Let WBB=WindowBorderBottom
ClearWindow
ShowBrushEfx Arg1,WBL,WBT,"Tile",0.000,WW-WBR-WBL,WH-WBT-WBB
IfError
EndIf
@endnode
 
@node "16 Routine · Click" "Routine · Click"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Click
 
SetDrawMode JAM1 
SetPen 5
AreaRectangle Arg1,Arg2,Arg3,Arg4
DrawBorder Arg1,Arg2,Arg3,Arg4,BEVEL ,1,2
SetPrintFont "topaz",8
SetPrintStyle PLAIN ,1,2
SetPen 2,1
PrintText Arg5,Arg1+18-Arg6,Arg2+3
@endnode
 
@node "17 Routine · Get Fields" "Routine · Get Fields"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get Fields
 
Let FieldNames[1]=Arg1
Let FieldNames[2]=Arg2
Let FieldNames[3]=Arg3
Let FieldNames[4]=Arg4
Let FieldNames[5]=Arg5
Let FieldNames[6]=Arg6
Let FieldNames[7]=Arg7
Let FieldNames[8]=Arg8
Let FieldNames[9]=Arg9
Let FieldNames[10]=Arg10
@endnode
 
@node "18 Routine · Format Fields" "Routine · Format Fields"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Format Fields
 
Let M=Max(9999)
Let Arg2=FormatValue(TextFrom(Arg1),"###0.00")
If Arg2>M
	Let Arg2=0
EndIf
SetText Arg1,FormatValue(Arg2,"###0.00")
@endnode
 
@node "19 Routine · Format $" "Routine · Format $"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Format $
 
If CURRFIELD<>1 & CURRFIELD<>2 & CURRFIELD<>3 & CURRFIELD<>6
	While ObjectState(Arg1)
		Let M=Arg2
		Let N=0
		Let Arg3=TextFrom(Arg4)
		Let Arg3=Arg3||Arg5||FormatValue(N,"####0.05")
		Let FInfo=Arg3
		If Arg3|||Arg6|||M
			Let Arg3=Arg7
			SetText Arg4,FormatValue(Arg3,"####0.00")
		Else
			Delay 0,0,10
			SetText Arg4,FormatValue(Arg3,"####0.00")
		EndIf
	EndLoop
EndIf
@endnode
 
@node "20 Routine · Draw" "Routine · Draw"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Draw
 
Let WBL=WindowBorderLeft
Let WBT=WindowBorderTop
Let WW=WindowWidth
Let WBR=WindowBorderRight
Let WH=WindowHeight
Let WBB=WindowBorderBottom
DrawBorder WindowX+WBL,WindowY,WindowWidth-WBR-WBL,WindowHeight-WindowY,BEVEL ,2,1
DrawBorder WindowX+WBL,WindowY,WindowWidth-WBR-WBL,70,BEVEL ,2,1
DrawBorder WindowX+WBL,WindowY+GOS+58,WindowWidth-WBR-WBL,WindowHeight-WindowY,BEVEL ,2,1
@endnode
 
@node "21 Routine · Set Field" "Routine · Set Field"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Set Field
 
If Arg1=""
	Let CurrField=CurrField+1
Else
	Let CurrField=Arg1
EndIf
If CurrField>LastArrayIndex(FieldNames)
	Let CurrField=1
EndIf
SetObjectState FieldNames[CurrField],On
@endnode
 
@node "22 Routine · Tax" "Routine · Tax"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Tax
 
If Exists("Ram:A2K.Tax")
	Let A2KTax=LoadVariable("Ram:A2K.Tax")
	Let Tax=A2KTax.Tax
	Let GST=A2KTax.GST
	Let PST=A2KTax.PST
	Let VAT1=A2KTax.VAT1
	Let VAT2=A2KTax.VAT2
	If Tax<>""
		Let T="Yes"
	ElseIf GST<>""
		Let T="Yes"
	ElseIf PST<>""
		Let T="Yes"
	ElseIf VAT1<>""
		Let T="Yes"
	ElseIf VAT2<>""
		Let T="Yes"
	EndIf
EndIf
@endnode
 
@node "23 Routine · Search NextOrder" "Routine · Search NextOrder"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Search NextOrder
 
WorkWithDocument "Order List"
Local NewOrderIndex
SetSearchArrayFlags NOCASE SUBSTRING 
Let NewOrderIndex=SearchArray(OrderDataBase,SearchText,"."||SearchField,OrderIndex+1)
If Not SearchFound
	Let NewOrderIndex=SearchArray(OrderDataBase,SearchText,"."||SearchField)
	If Not SearchFound
		If SizeOfDocument<>0
			MoveCursorTo STARTOF DOCUMENT 
			SplitLine
			MoveCursor UP 
			Let OrderIndex=1
			InsertArrayEntry OrderDataBase,OrderIndex
			Let OrderDataBase[OrderIndex]=GetDBObjects
		EndIf
	EndIf
EndIf
If SearchFound
	Do "Get OrderEntry",NewOrderIndex
EndIf
@endnode
 
@node "24 Routine · Draw Order" "Routine · Draw Order"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Draw Order
 
Let APen=DefPenA,BPen=DefPenB,CPen=DefPenC
SetDrawMode JAM2 
SetPen APen,5
PrintText "Qty",128,470
PrintText "Profit =",163,470
PrintText "Total(s)",246,470
PrintText "P.V. =",377,470
PrintText "B.V. =",449,470
PrintText "Dist =",553,470
PrintText "Cost =",617,470
PrintText "Tax Payable :",27,495
PrintText "Customer Tax:",27,515
@endnode
 
@node "25 Routine · Tax Amounts" "Routine · Tax Amounts"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Tax Amounts
 
Let TaxDist=0
Let TaxCust=0
Let ATX=TextFrom(".Tax")
Let Qty=IntegerFrom(".Qty")
Do "Format Fields",".Dist",Dist
Do "Format Fields",".Cust",Cust
If ATX="Tax"
	Let TaxDist=(Qty*Dist)+(Dist/100*Tax)
	Let TaxCust=(Qty*Cust)+(Cust/100*Tax)
ElseIf ATX="GST"
	Let TaxDist=(Qty*Dist)+(Dist/100*GST)
	Let TaxCust=(Qty*Cust)+(Cust/100*GST)
ElseIf ATX="PST"
	Let TaxDist=(Qty*Dist)+(Dist/100*PST)
	Let TaxCust=(Qty*Cust)+(Cust/100*PST)
ElseIf ATX="VAT1"
	Let TaxDist=(Qty*Dist)+(Dist/100*VAT1)
	Let TaxCust=(Qty*Cust)+(Cust/100*VAT1)
ElseIf ATX="VAT2"
	Let TaxDist=(Qty*Dist)+(Dist/100*VAT1)
	Let TaxCust=(Qty*Cust)+(Cust/100*VAT1)
ElseIf ATX<>""
	Let ATX=FormatValue(TextFrom(".Tax"),"####")
	Let TaxDist=(Qty*Dist)+(Dist/100*ATX)
	Let TaxCust=(Qty*Cust)+(Cust/100*ATX)
ElseIf ATX=""
	Let TaxDist=Dist
	Let TaxCust=Cust
EndIf
SetText ".Dist",TaxDist
SetText ".Cust",TaxCust
Do "Format Fields",".Dist",TaxDist
Do "Format Fields",".Cust",TaxCust
@endnode
 
@node "26 Routine · Get OrderEntry" "Routine · Get OrderEntry"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get OrderEntry
 
SetPrintFont "topaz",8
SetDrawMode JAM2 
SetPen BPen,5
SetPrintStyle PLAIN ,BPen,3
Let OrderIndex=Arg1
SetDBObjects OrderDataBase[OrderIndex]
PrintText RightJustify(OrderIndex,4),570,114
PrintText RightJustify(NumberOfArrayEntries(OrderDataBase),4),380,114
SetPen APen,5
PrintText "Ordering Info...                ",20,114
PrintText "There Are :",293,114
PrintText "Items",420,114
PrintText "Index No.",500,114
WorkWithDocument "Order List"
PositionOnLine Arg1
@endnode
 
@node "27 Routine · Load StockDataFile" "Routine · Load StockDataFile"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load StockDataFile
 
WorkWithDocument "Stock List"
Clear DOCUMENT 
If Sort="Yes"
	SortArray StockDataBase,INTEGER ,".VS"
EndIf
Let StockIndex=FirstArrayIndex(StockDataBase)
While SearchFound
	Type LeftJustify(StockDataBase[StockIndex].VS,12)
	Type "  "
	Type RightJustify(StockDataBase[StockIndex].Qty,2)
	Type "  "
	Type LeftJustify(StockDataBase[StockIndex].Des,22)
	Type "   "
	Type RightJustify(FormatValue(StockDataBase[StockIndex].PV,"###0.00"),7)
	Type "  "
	Type RightJustify(FormatValue(StockDataBase[StockIndex].BV,"###0.00"),7)
	Type " "
	If T="Yes"
		Type LeftJustify(FormatValue(StockDataBase[StockIndex].Tax,"###%"),4)
	Else
		Type LeftJustify(FormatValue(StockDataBase[StockIndex].Tax,"###%"),4)
	EndIf
	Type " "
	Type RightJustify(FormatValue(StockDataBase[StockIndex].Dist,DefNote||"###0.00"),7)
	Type " "
	Type RightJustify(FormatValue(StockDataBase[StockIndex].Cust,DefNote||"###0.00"),7)
	NewLine
	Let StockIndex=NextArrayIndex(StockDataBase,StockIndex)
EndLoop
Delete CHARACTER ,-1
If StockIndex=1
	MoveCursorTo STARTOF DOCUMENT 
EndIf
@endnode
 
@node "28 Routine · Get VS" "Routine · Get VS"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get VS
 
If Exists("Ram:A2KData/StockData/Stock.Data")
	Let StockDataBase=LoadVariable("Ram:A2KData/StockData/Stock.Data")
EndIf
If Arg1<>""
	Let VS=Arg1
Else
	Let VS=TextFrom(".VS")
EndIf
If VS<>""
	Local NewStockIndex
	SetSearchArrayFlags NOCASE SUBSTRING 
	Let NewStockIndex=SearchArray(StockDataBase,VS,".VS",StockIndex+1)
	If Not SearchFound
		Let NewStockIndex=SearchArray(StockDataBase,VS,".VS")
	EndIf
	If SearchFound
		Let StockIndex=NewStockIndex
	EndIf
	Let PV=FormatValue(StockDataBase[StockIndex].PV,"###0.00")
	Let BV=FormatValue(StockDataBase[StockIndex].BV,"###0.00")
	Let Dist=FormatValue(StockDataBase[StockIndex].Dist,"###0.00")
	Let Cust=FormatValue(StockDataBase[StockIndex].Cust,"###0.00")
Else
	Let Dist=0
	Let Cust=0
EndIf
@endnode
 
@node "29 Routine · Calc Tax" "Routine · Calc Tax"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Calc Tax
 
Let Qty=IntegerFrom(".Qty")
If ATX="Tax"
	Let TotalTaxDistT=TotalTaxDistT+(Qty*Dist/100*Val)
	Let TotalTaxCustT=TotalTaxCustT+(Qty*Cust/100*Val)
ElseIf ATX="GST"
	Let TotalTaxDistG=TotalTaxDistG+(Qty*Dist/100*Val)
	Let TotalTaxCustG=TotalTaxCustG+(Qty*Cust/100*Val)
ElseIf ATX="PST"
	Let TotalTaxDistP=TotalTaxDistP+(Qty*Dist/100*Val)
	Let TotalTaxCustP=TotalTaxCustP+(Qty*Cust/100*Val)
ElseIf ATX="VAT1"
	Let TotalTaxDistV1=TotalTaxDistV1+(Qty*Dist/100*Val)
	Let TotalTaxCustV1=TotalTaxCustV1+(Qty*Cust/100*Val)
ElseIf ATX="VAT2"
	Let TotalTaxDistV2=TotalTaxDistV2+(Qty*Dist/100*Val)
	Let TotalTaxCustV2=TotalTaxCustV2+(Qty*Cust/100*Val)
ElseIf ATX<>""
	Let ATX=FormatValue(TextFrom(".Tax"),"####")
	Let TotalTaxDist=TotalTaxDist+(Qty*Dist/100*ATX)
	Let TotalTaxCust=TotalTaxCust+(Qty*Cust/100*ATX)
ElseIf ATX=""
	Let TotalTaxDist=TotalTaxDist+(Qty*Dist/100*Val)
	Let TotalTaxCust=TotalTaxCust+(Qty*Cust/100*Val)
EndIf
@endnode
 
@node "30 Routine · Print Calc Totals" "Routine · Print Calc Totals"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Print Calc Totals
 
Do "Draw Cust"
Local Px
Let Px=135
PrintText "                                                                    ",Px,415
PrintText "                                                                    ",Px,435
If TotalTaxCustT<>0
	SetPen APen,5
	PrintText "TAX=",Px,435
	SetPen CPen,5
	PrintText RightJustify(FormatValue(TotalTaxCustT,DefNote||"###0.00"),7),Px+35,435
	Let Px=Px+95
EndIf
If TotalTaxCustG<>0
	SetPen APen,5
	PrintText "GST=",Px,435
	SetPen CPen,5
	PrintText RightJustify(FormatValue(TotalTaxCustG,DefNote||"###0.00"),7),Px+35,435
	Let Px=Px+95
EndIf
If TotalTaxCustP<>0
	SetPen APen,5
	PrintText "PST=",Px,435
	SetPen CPen,5
	PrintText RightJustify(FormatValue(TotalTaxCustP,DefNote||"###0.00"),7),Px+35,435
	Let Px=Px+95
EndIf
If TotalTaxCustV1<>0
	SetPen APen,5
	PrintText "VAT1=",Px,435
	SetPen CPen,5
	PrintText RightJustify(FormatValue(TotalTaxCustV1,DefNote||"###0.00"),7),Px+40,435
	Let Px=Px+95
EndIf
If TotalTaxCustV2<>0
	SetPen APen,5
	PrintText "VAT2=",Px+5,435
	SetPen CPen,5
	PrintText RightJustify(FormatValue(TotalTaxCustV2,DefNote||"###0.00"),7),Px+45,435
EndIf
@endnode
 
@node "31 Routine · Print Totals" "Routine · Print Totals"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Print Totals
 
Do "Draw Cust"
SetDrawMode JAM2 
SetPrintFont "topaz",8
SetPen BPen,5
PrintText RightJustify(TotalQty,2),130,405
PrintText RightJustify(FormatValue(TotalCust,DefNote||"###0.00"),7),617,405
@endnode
 
@node "32 Routine · PrintTax" "Routine · PrintTax"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} PrintTax
 
Let Day=GetWord(TheDate,2,"/")
Let Month=GetWord(TheDate,1,"/")
Let Year=GetWord(TheDate,3,"/")
WorkWithDocument "Ram:A2KData/OrderData/Order.Doc"
Clear DOCUMENT 
Type " ",NEWLINE 
Type "VS            Qty Description                 P.V.     B.V. Tax     Dist    Cost"
MoveCursorTo ENDOF DOCUMENT 
NewLine
Type "ŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻ",NEWLINE 
InsertDocument "Order List"
MoveCursorTo ENDOF DOCUMENT 
NewLine
Type "ŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻ",NEWLINE 
Type "        Total Qty Total Profit  Total(s)      P.V.     B.V.         Dist    Cost",NEWLINE 
Type "              "
Type RightJustify(TotalQty,2)
Type "       "
Type RightJustify(FormatValue(TotalProfit,"###0.00"),7)
Type "             "
Type RightJustify(FormatValue(TotalPV,"###0.00"),7)
Type "  "
Type RightJustify(FormatValue(TotalBV,"###0.00"),7)
Type "      "
Type RightJustify(FormatValue(TotalDist,DefNote||"###0.00"),7)
Type " "
Type RightJustify(FormatValue(TotalCust,DefNote||"###0.00"),7),NEWLINE 
NewLine
SaveDocument "Ram:A2KData/OrderData/Order.Doc"
Do "Type Calc Totals"
@endnode
 
@node "33 Routine · Type Calc Totals" "Routine · Type Calc Totals"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Type Calc Totals
 
If ATX="Tax"
	Type "Tax Payable : Tax="
	Type RightJustify(FormatValue(TotalTaxDistT,DefNote||"###0.00"),7)
	NewLine
	Type "Customer Tax: Tax="
	Type RightJustify(FormatValue(TotalTaxCustT,DefNote||"###0.00"),7)
EndIf
If ATX="GST"
	Type "Tax Payable : GST="
	Type RightJustify(FormatValue(TotalTaxDistG,DefNote||"###0.00"),7)
	NewLine
	Type "Customer Tax: GST="
	Type RightJustify(FormatValue(TotalTaxCustG,DefNote||"###0.00"),7)
EndIf
If ATX="PST"
	Type "    Tax Payable : PST="
	Type RightJustify(FormatValue(TotalTaxDistP,DefNote||"###0.00"),7)
	NewLine
	Type "    Customer Tax: PST="
	Type RightJustify(FormatValue(TotalTaxCustP,DefNote||"###0.00"),7)
EndIf
If ATX="VAT1"
	Type "Tax Payable : VAT1="
	Type RightJustify(FormatValue(TotalTaxDistV1,DefNote||"###0.00"),7)
	NewLine
	Type "Customer Tax: VAT1="
	Type RightJustify(FormatValue(TotalTaxCustV1,DefNote||"###0.00"),7)
EndIf
If ATX="VAT2"
	Type "    Tax Payable : VAT2="
	Type RightJustify(FormatValue(TotalTaxDistV2,DefNote||"###0.00"),7)
	NewLine
	Type "    Customer Tax: VAT2="
	Type RightJustify(FormatValue(TotalTaxCustV2,DefNote||"###0.00"),7)
EndIf
If ATX<>""
	Type "Tax Payable : Tax="
	Type RightJustify(FormatValue(TotalTaxDistT,DefNote||"###0.00"),7)
	NewLine
	Type "Customer Tax: Tax="
	Type RightJustify(FormatValue(TotalTaxCustT,DefNote||"###0.00"),7)
EndIf
If ATX=""
	Type "Tax Payable : Tax="
	Type RightJustify(FormatValue(TotalTaxDistT,DefNote||"###0.00"),7)
	NewLine
	Type "Tax="
	Type RightJustify(FormatValue(TotalTaxCustT,DefNote||"###0.00"),7)
EndIf
@endnode
 
