@node "164 AfterAttachment · " "AfterAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AfterAttachment@{fg text}@{ub} 
 
Let Base="Stock"
Do "Set Def"
Let APen=DefPenA
Let BPen=DefPenB
Let CPen=DefPenC
Do "Tax"
FastFeedBack On
Dispose Work
Let Sort="Yes"
ReattachObject "Fields"
Do "Get Fields",".VS",".Qty",".Des",".PV",".BV",".Tax",".Dist",".Cust"
If Exists("Ram:A2KData/StockData/Stock.Data")
	Let StockDataBase=LoadVariable("Ram:A2KData/StockData/Stock.Data")
	Do "Load StockDataFile"
ElseIf Exists(DefDataDir||"/Stock.Data")
	Let StockDataBase=LoadVariable(DefDataDir||"/Stock.Data")
	Do "Load StockDataFile"
	SaveVariable StockDataBase,"Ram:A2KData/StockData/Stock.Data"
ElseIf Not Exists(DefDataDir||"/Stock.Data")
	SetFileRequestMode REGULARMODE ,REJECTICONS PATTERNFIELD 
	SetFileRequestPattern "#?.Data"
	Let FileName=AskForFileName(DefDataDir||"/.Data","Select File To Load...")
	If FileOf(FileName)<>""
		Let StockDataBase=LoadVariable(FileName)
		IfError
			Let StockDataBase[StockIndex]=GetDBObjects
		EndIf
		Do "Load StockDataFile"
		SaveVariable StockDataBase,"Ram:A2KData/StockData/Stock.Data"
	Else
		Let StockIndex=1
		Let StockDataBase[StockIndex]=GetDBObjects
		Do "Load StockDataFile"
		SaveVariable StockDataBase,"Ram:A2KData/StockData/Stock.Data"
	EndIf
EndIf
Do "Get Date"
Do "Get StockEntry",1
Do "Set Field",1
@endnode
 
