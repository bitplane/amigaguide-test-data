	@{fg highlight}Image@{fg text} "CanDo:Decks/A2K/A2K.br/Load.br"
	@{fg highlight}Highlight@{fg text} OUTLINE 
@{b}EndScript@{ub}
@{b}OnClick@{ub}
	Do "Click",MX,55,60,14,"Load",4
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	ReattachObject "B_Load"
	SetFileRequestMode REGULARMODE ,REJECTICONS PATTERNFIELD 
	SetFileRequestPattern "#?.Data"
	Let FileName=AskForFileName(DefDataDir||"/.Data","Select File To Load...")
	If Base="Stock"
		Do "Load Stock"
	ElseIf Base="Order"
		Do "Load Order"
	ElseIf Base="Cust"
		Do "Load Cust"
	EndIf
	Do "Get Date"
	Do "Set Field",1
@{b}EndScript@{ub}
@endnode
 
