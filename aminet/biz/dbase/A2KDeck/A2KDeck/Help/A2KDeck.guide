@node "71 Routine · Get NextCust" "Routine · Get NextCust"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get NextCust
 
Let CustEntry=GetDBObjects
If CustEntry<>CustDataBase[CustIndex]
	Do "EnterCust"
EndIf
Let CustIndex=NextArrayIndex(CustDataBase,CustIndex)
If Not SearchFound
	Let CustIndex=FirstArrayIndex(CustDataBase)
EndIf
Do "Get CustEntry",CustIndex
@endnode
 
@node "72 Routine · Tax CustAmounts" "Routine · Tax CustAmounts"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Tax CustAmounts
 
Let TaxCust=0
Let ATX=TextFrom(".Tax")
Let Qty=IntegerFrom(".Qty")
Do "Format Fields",".Cust",Cust
If ATX="Tax"
	Let TaxCust=(Qty*Cust)+(Cust/100*Tax)
ElseIf ATX="GST"
	Let TaxCust=(Qty*Cust)+(Cust/100*GST)
ElseIf ATX="PST"
	Let TaxCust=(Qty*Cust)+(Cust/100*PST)
ElseIf ATX="VAT1"
	Let TaxCust=(Qty*Cust)+(Cust/100*VAT1)
ElseIf ATX="VAT2"
	Let TaxCust=(Qty*Cust)+(Cust/100*VAT1)
ElseIf ATX<>""
	Let ATX=FormatValue(TextFrom(".Tax"),"####")
	Let TaxCust=(Qty*Cust)+(Cust/100*ATX)
ElseIf ATX=""
	Let TaxCust=Cust
EndIf
SetText ".Cust",TaxCust
Do "Format Fields",".Cust",TaxCust
@endnode
 
@node "73 Routine · Store CustEntry" "Routine · Store CustEntry"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Store CustEntry
 
WorkWithDocument "Cust List"
Let Work=GetDBObjects
If Work<>CustDataBase[CustIndex]
	Do "Delete CustEntry",CustIndex
	Let CustIndex=TheLineNumber
	InsertArrayEntry CustDataBase,CustIndex
	Let CustDataBase[CustIndex]=Work
EndIf
Do "Load CustDataFile"
@endnode
 
