@node "81 Routine · Load Name" "Routine · Load Name"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load Name
 
If Exists("Ram:A2KData/CustData/CustName.Data")
	Let CustName=LoadVariable("Ram:A2KData/CustData/CustName.Data")
	Do "Set Name"
ElseIf Exists(DefCustDir||"/CustName.Data")
	Let CustName=LoadVariable(DefCustDir||"/CustName.Data")
	SaveVariable CustName,"Ram:A2KData/CustData/CustName.Data"
	Do "Set Name"
ElseIf Not Exists(DefCustDir||"/CustName.Data")
	Do "Get Date"
	If Exists("Ram:A2KData/DistData/Dist.Data")
		Let DistDataBase=LoadVariable("Ram:A2KData/DistData/Dist.Data")
	ElseIf Exists("A2K:A2KData/DistData/Dist.Data")
		Let DistDataBase=LoadVariable("A2K:A2KData/DistData/Dist.Data")
	EndIf
	Let CustName.Name=DistDataBase.Name
	SaveVariable CustName,"Ram:A2KData/CustData/CustName.Data"
	Do "Set Name"
EndIf
@endnode
 
@node "82 Routine · Load Cust" "Routine · Load Cust"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load Cust
 
If FileOf(FileName)<>""
	Let CustDataBase=LoadVariable(FileName)
	Do "Load CustDataFile"
	SaveVariable CustDataBase,"Ram:A2KData/CustData/Cust.Data"
Else
	Let CustIndex=1
	Let CustDataBase[CustIndex]=GetDBObjects
	Do "Load CustDataFile"
	SaveVariable CustDataBase,"Ram:A2KData/CustData/Cust.Data"
EndIf
Do "Get CustEntry",1
@endnode
 
