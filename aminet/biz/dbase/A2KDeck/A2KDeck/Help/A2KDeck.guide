@node "93 Window · DistWindow" "Window · DistWindow"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Window@{fg text}@{ub} DistWindow
 
@{b}NoAttach@{ub}
@{b}Definition@{ub}
	Origin 170,170
	Title "Distributor Screen..."
	Size 315,220
	DefaultColors 1,0,4
	WindowFlags ACTIVATE TOFRONT BLOCK 
	VisualEffects NONE ,NONE 
@{b}EndScript@{ub}
@{b}BeforeAttachment@{ub}
	Do "Make Ram Dir"
	Do "KeyFile"
@{b}EndScript@{ub}
@{b}AfterAttachment@{ub}
	Let A2KPrefs=LoadVariable("A2K:A2K.prefs")
	Do "Set Def"
	Let APen=DefPenA
	Let BPen=DefPenB
	Let CPen=DefPenC
	If DefBGPic<>""
		Do "ShowBrush",DefTBGPic
	EndIf
	AttachObject "DistObjects"
@{b}EndScript@{ub}
@{b}Resource "DistObjects"@{ub}
	NoAttach
	AfterAttachment
		Do "Get Fields",".Name",".Number",".Add1",".Add2",".Sub",".State",".PostCode",".Email",".UseID",".Phn"
		Let FieldNames[11]=".Vox",FieldNames[12]=".Mob"
		If Exists("Ram:A2KData/DistData/Dist.Data")
			Let DistDataBase=LoadVariable("Ram:A2KData/DistData/Dist.Data")
			SetDBObjects DistDataBase
		ElseIf Exists(DefDistDir||"/Dist.Data")
			Let DistDataBase=LoadVariable(DefDistDir||"/Dist.Data")
			SetDBObjects DistDataBase
			Let Name=TextFrom(".Name")
			If Name<>""
				SaveVariable DistDataBase,"Ram:A2KData/DistData/Dist.Data"
				SaveVariable DistDataBase,"Ram:A2KData/DistData/"||Name||".Data"
			EndIf
		ElseIf Not Exists(DefDistDir||"/Dist.Data")
			SetDBObjects Nothing
		EndIf
		Do "Click",234,186,68,14,"Save"
		ReattachObject "B_Save"
		SetObjectState ".Name",On
		SetText ".Name",®2001
	EndScript
	TextField ".Name"
		Definition
			InitialText ""
			Origin 12,30
			Size 208,12
			Border INVERT BEVEL 
			Label "Your Name",ABOVELEFT 
			MaxFieldLength 25
			Font "topaz",8
			TextColors 1,5
			AltTextColors 1,5
		EndScript
		OnClick
			Let CurrField=1
			Let OldName=TextFrom(".Name")
		EndScript
		OnRelease
			Let Name=TextFrom(".Name")
			If Name<>®2001
				SetObjectState ".Name",On
			Else
				Do "Get Number"
			EndIf
		EndScript
@endnode
 
