@node "58 Routine · Print OrderCalc Totals" "Routine · Print OrderCalc Totals"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Print OrderCalc Totals
 
Do "Draw Order"
Local Px
Let Px=135
PrintText "                                                                    ",Px,495
PrintText "                                                                    ",Px,515
If TotalTaxDistT<>0
	SetPen APen,5
	PrintText "TAX=",Px,495
	PrintText "TAX=",Px,515
	SetPen CPen,5
	PrintText RightJustify(FormatValue(TotalTaxDistT,DefNote||"###0.00"),7),Px+35,495
	PrintText RightJustify(FormatValue(TotalTaxCustT,DefNote||"###0.00"),7),Px+35,515
	Let Px=Px+95
EndIf
If TotalTaxDistG<>0
	SetPen APen,5
	PrintText "GST=",Px,495
	PrintText "GST=",Px,515
	SetPen CPen,5
	PrintText RightJustify(FormatValue(TotalTaxDistG,DefNote||"###0.00"),7),Px+35,495
	PrintText RightJustify(FormatValue(TotalTaxCustG,DefNote||"###0.00"),7),Px+35,515
	Let Px=Px+95
EndIf
If TotalTaxDistP<>0
	SetPen APen,5
	PrintText "PST=",Px,495
	PrintText "PST=",Px,515
	SetPen CPen,5
	PrintText RightJustify(FormatValue(TotalTaxDistP,DefNote||"###0.00"),7),Px+35,495
	PrintText RightJustify(FormatValue(TotalTaxCustP,DefNote||"###0.00"),7),Px+35,515
	Let Px=Px+95
EndIf
If TotalTaxDistV1<>0
	SetPen APen,5
	PrintText "VAT1=",Px,495
	PrintText "VAT1=",Px,515
	SetPen CPen,5
	PrintText RightJustify(FormatValue(TotalTaxDistV1,DefNote||"###0.00"),7),Px+40,495
	PrintText RightJustify(FormatValue(TotalTaxCustV1,DefNote||"###0.00"),7),Px+40,515
	Let Px=Px+95
EndIf
If TotalTaxDistV2<>0
	SetPen APen,5
	PrintText "VAT2=",Px+5,495
	PrintText "VAT2=",Px+5,515
	SetPen CPen,5
	PrintText RightJustify(FormatValue(TotalTaxDistV2,DefNote||"###0.00"),7),Px+45,495
	PrintText RightJustify(FormatValue(TotalTaxCustV2,DefNote||"###0.00"),7),Px+45,515
EndIf
@endnode
 
@node "59 Routine · Calc OrderTax" "Routine · Calc OrderTax"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Calc OrderTax
 
Let Qty=IntegerFrom(".Qty")
If ATX="Tax"
	Let TotalTaxDistT=TotalTaxDistT+(Qty*Dist/100*Val)
	Let TotalTaxCustT=TotalTaxCustT+(Qty*Cust/100*Val)
ElseIf ATX="GST"
	Let TotalTaxDistG=TotalTaxDistG+(Qty*Dist/100*Val)
	Let TotalTaxCustG=TotalTaxCustG+(Qty*Cust/100*Val)
ElseIf ATX="PST"
	Let TotalTaxDistP=TotalTaxDistP+(Qty*Dist/100*Val)
	Let TotalTaxCustP=TotalTaxCustP+(Qty*Cust/100*Val)
ElseIf ATX="VAT1"
	Let TotalTaxDistV1=TotalTaxDistV1+(Qty*Dist/100*Val)
	Let TotalTaxCustV1=TotalTaxCustV1+(Qty*Cust/100*Val)
ElseIf ATX="VAT2"
	Let TotalTaxDistV2=TotalTaxDistV2+(Qty*Dist/100*Val)
	Let TotalTaxCustV2=TotalTaxCustV2+(Qty*Cust/100*Val)
ElseIf ATX<>""
	Let ATX=FormatValue(TextFrom(".Tax"),"####")
	Let TotalTaxDist=TotalTaxDist+(Qty*Dist/100*ATX)
	Let TotalTaxCust=TotalTaxCust+(Qty*Cust/100*ATX)
ElseIf ATX=""
	Let TotalTaxDist=TotalTaxDist+(Qty*Dist/100*Val)
	Let TotalTaxCust=TotalTaxCust+(Qty*Cust/100*Val)
EndIf
@endnode
 
@node "60 Routine · Do SearchOrder" "Routine · Do SearchOrder"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Do SearchOrder
 
If Arg1
	SetText ".VS",Arg5.VS
	SetText ".Des",Arg5.Des
	SetText ".PV",Arg5.PV
	SetText ".BV",Arg5.BV
	SetText ".Tax",Arg5.Tax
	Let Dist=Arg5.Dist
	Let Cust=Arg5.Cust
	Do "Tax Amounts"
	Let StockIndex=Arg4
	Let SearchText=TextFrom(".VS")
	Let SearchField="VS"
	Do "Search NextOrder"
	Do "EnterOrder"
	Do "Search NextOrder"
EndIf
@endnode
 
@node "61 Routine · Get CustEntry" "Routine · Get CustEntry"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get CustEntry
 
SetPrintFont "topaz",8
SetDrawMode JAM2 
SetPen BPen,5
SetPrintStyle PLAIN ,BPen,3
Let CustIndex=Arg1
SetDBObjects CustDataBase[CustIndex]
PrintText RightJustify(CustIndex,4),570,114
PrintText RightJustify(NumberOfArrayEntries(CustDataBase),4),380,114
SetPen APen,5
PrintText "Customer Order Info...",20,114
PrintText "There Are :",293,114
PrintText "Items",420,114
PrintText "Index No.",500,114
WorkWithDocument "Cust List"
PositionOnLine Arg1
@endnode
 
@node "62 Routine · Load CustDataFile" "Routine · Load CustDataFile"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load CustDataFile
 
Let TotalQty=0,TotalCust=0,TotalTaxCust=0,TotalTaxCustT=0,TotalTaxCustG=0
Let TotalTaxCustP=0,TotalTaxCustV1=0,TotalTaxCustV2=0
WorkWithDocument "Cust List"
Clear DOCUMENT 
If Sort="Yes"
	SortArray CustDataBase,INTEGER ,".VS"
EndIf
Let CustIndex=FirstArrayIndex(CustDataBase)
While SearchFound
	Type LeftJustify(CustDataBase[CustIndex].VS,12)
	Type "  "
	Type RightJustify(CustDataBase[CustIndex].Qty,2)
	Type "  "
	Type LeftJustify(CustDataBase[CustIndex].Des,22)
	Type "                    "
	If T="Yes"
		Let ATX=CustDataBase[CustIndex].Tax
		Do "Get VS",CustDataBase[CustIndex].VS
		Let Val=FormatValue(CustDataBase[CustIndex].Tax,"####")
		Type LeftJustify(FormatValue(CustDataBase[CustIndex].Tax,"###%"),4)
	Else
		Type LeftJustify(FormatValue(CustDataBase[CustIndex].Tax,"###%"),4)
	EndIf
	Type "         "
	Type RightJustify(FormatValue(CustDataBase[CustIndex].Cust,DefNote||"###0.00"),7)
	Let TotalQty=TotalQty+CustDataBase[CustIndex].Qty
	Let TotalCust=TotalCust+CustDataBase[CustIndex].Cust
	Do "Calc Tax"
	NewLine
	Let CustIndex=NextArrayIndex(CustDataBase,CustIndex)
EndLoop
Delete CHARACTER ,-1
If CustIndex=1
	MoveCursorTo STARTOF DOCUMENT 
EndIf
Do "Print Calc Totals"
Do "Print Totals"
@endnode
 
@node "63 Routine · EnterCust" "Routine · EnterCust"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} EnterCust
 
WorkWithDocument "Cust List"
Let AS=GetDBObjects
Do "Store CustEntry"
Let Find=SearchArray(CustDataBase,AS)
Do "Get CustEntry",Find
Do "Set Field",CurrField
@endnode
 
@node "64 Routine · Delete CustEntry" "Routine · Delete CustEntry"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Delete CustEntry
 
DeleteArrayEntry CustDataBase,Arg1
PositionOnLine Arg1
If TheLineNumber=LinesInDocument
	Clear LINE 
	Delete CHARACTER ,-1
	Let CustIndex=0
Else
	Delete LINE 
EndIf
Do "Load CustDataFile"
PositionOnLine Arg1
@endnode
 
@node "65 Routine · Load SubDeck" "Routine · Load SubDeck"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load SubDeck
 
If Not Exists("A2K:A2KSubDeck")
	Let Response=AskForResponse("The Prefs Function for this program"||char(10)||"         has not been found."||char(10)||"          Continue anyway?","!!!WARNING!!!","Okay|Quit")
	If (Response=1)
		Let Response=AskforResponse("Some features of this program may"||char(10)||"        not work properly."||char(10)||"         Continue anyway?","!!!2nd WARNING!!!","Okay|Quit")
		If (Response=2)
			Do "Quit"
		EndIf
	ElseIf (Response=2)
		Do "Quit"
	EndIf
EndIf
LoadSubDeck "A2K:A2KSubDeck","A2KSubDeck"
IfError
EndIf
@endnode
 
@node "66 Routine · Do Search Names" "Routine · Do Search Names"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Do Search Names
 
If Arg1
	SetText "Name",Arg5.Name
	SetText "Add1",Arg5.Add1
	SetText "Add2",Arg5.Add2
	SetText "Phn",Arg5.Phn
	SetText "Mob",Arg5.Mob
EndIf
