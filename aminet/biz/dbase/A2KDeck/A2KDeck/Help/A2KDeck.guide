@node "67 Routine · Do Search" "Routine · Do Search"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Do Search
 
If Arg1
	SetText ".VS",Arg5.VS
	SetText ".Des",Arg5.Des
	SetText ".Tax",Arg5.Tax
	Let Cust=Arg5.Cust
	Do "Tax CustAmounts"
	Let StockIndex=Arg4
	Let SearchText=TextFrom(".VS")
	Let SearchField="VS"
	Do "Search Next"
	Do "EnterCust"
	Do "Search Next"
EndIf
@endnode
 
