Do "Draw Order"
SetDrawMode JAM2 
SetPrintFont "topaz",8
SetPen BPen,5
PrintText RightJustify(TotalQty,2),130,482
PrintText RightJustify(FormatValue(TotalPV,"###0.00"),7),377,482
PrintText RightJustify(FormatValue(TotalBV,"###0.00"),7),449,482
PrintText RightJustify(FormatValue(TotalDist,DefNote||"###0.00"),7),553,482
PrintText RightJustify(FormatValue(TotalCust,DefNote||"###0.00"),7),617,482
PrintText RightJustify(FormatValue(TotalProfit,DefNote||"###0.00"),7),170,482
