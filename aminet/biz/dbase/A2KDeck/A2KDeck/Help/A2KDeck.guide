@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get Name
 
Let Name=TextFrom(".Name")
If Name=""
	Do "Set Field",1
ElseIf Name<>®2001
	SetObjectState ".Name",On
EndIf
@endnode
 
@node "86 Routine · About" "Routine · About"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} About
 
MakeDocument "TEMP"
WorkWithDocument "TEMP"
Clear DOCUMENT 
Type "    A2K 2000",NEWLINE 
Type "  Amway Deck V9.3",NEWLINE 
Type "Created With CanDo V3.8",NEWLINE 
Type "        and",NEWLINE 
Type "     Created by",NEWLINE 
Type "   Thomas R. Grant",NEWLINE 
Local ©=AskForResponse(TextFromDocument("TEMP"))
@endnode
 
@node "87 BeforeAttachment · " "BeforeAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}BeforeAttachment@{fg text}@{ub} 
 
SetAutoFileRequester FALSE
Do "Get_FONT.PREFS"
Do "Get_PUBSCREEN.PREFS"
Do "Set_PROG.VARS"
Dos "C:Assign A2K: """||(TheCurrentDirectory)||""""
Do "Make Ram Dir"
@endnode
 
@node "88 AfterAttachment · " "AfterAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AfterAttachment@{fg text}@{ub} 
 
SetAutoFileRequester FALSE
If Not Exists("Ram:A2K.Tax")
	If Exists("A2K:A2K.Tax")
		Dos "C:Copy A2K:A2K.Tax Ram:"
	EndIf
EndIf
Let ©1994=HexToChars("533A41324B2E6B6579")
If EXISTS(©1994)
	Do "KeyFile"
	If ®2003<>HexToChars("545247")
		Do "Load SubDeck"
		AttachObject "Welcome"
		Let PROG.PUBSCRTITLE="WORKBENCH"
		StopScript
	ElseIf Exists("A2K:A2K.Prefs")
		Dos "C:Copy A2K:A2K.Prefs Ram:"
		Let PROG.PUBSCRTITLE="A2K_PubScreen."||CNT
		Do "Load SubDeck"
		AttachObject "Main"
	ElseIf Not Exists("A2K:A2K.Prefs")
		Let PROG.PUBSCRTITLE="WORKBENCH"
		Do "Load SubDeck"
		OpenWindow "A2KSubDeck","PrefsWindow"
		IfError
		EndIf
	EndIf
Else
	Do "Load SubDeck"
	AttachObject "Welcome"
EndIf
@endnode
 
