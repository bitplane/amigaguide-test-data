@node "84 Routine · Get Number" "Routine · Get Number"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get Number
 
Let Name=TextFrom(".Name")
Let Number=IntegerFrom(".Number")
If Number=0
	If Name<>""
		Do "Set Field",2
		Do "Get Name"
	Else
		Do "Get Name"
	EndIf
ElseIf Number<>®2002
	SetObjectState ".Number",On
Else
	SetObjectState ".Add1",On
EndIf
@endnode
 
