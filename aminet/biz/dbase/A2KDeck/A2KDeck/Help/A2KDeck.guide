@node "107 BeforeAttachment · " "BeforeAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}BeforeAttachment@{fg text}@{ub} 
 
If EXISTS("A2K:A2K.Prefs")
	Let A2KPrefs=LoadVariable("A2K:A2K.Prefs")
EndIf
Do "Set Def"
Let APen=DefPenA
Let BPen=DefPenB
Let CPen=DefPenC
@endnode
 
@node "108 AfterAttachment · " "AfterAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AfterAttachment@{fg text}@{ub} 
 
SetAutoFileRequester FALSE
SetSystemRequesterTo WINDOW 
FastFeedBack On
AttachObject "MainObjetcs"
AttachObject "DataBase"
Let Base="Stock"
If Not Exists(DefDistDir||"/Dist.Data")
	AttachObject "DistWindow"
EndIf
@endnode
 
