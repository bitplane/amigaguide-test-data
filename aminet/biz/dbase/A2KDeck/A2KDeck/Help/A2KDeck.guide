@node "90 Window · Welcome" "Window · Welcome"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Window@{fg text}@{ub} Welcome
 
@{b}NoAttach@{ub}
@{b}Definition@{ub}
	Origin 160,140
	Size 330,200
	DefaultColors 1,0,3
	WindowFlags ACTIVATE TOFRONT WORKBENCH BLOCK 
	VisualEffects NONE ,NONE 
@{b}EndScript@{ub}
@{b}AfterAttachment@{ub}
	Let PROG.PUBSCRTITLE="WORKBENCH"
	SetAutoFileRequester FALSE
	SetSystemRequesterTo WINDOW 
	FastFeedBack ON
	SetPrintStyle PLAIN ,2,1
	SetDrawMode JAM1 
	SetPen 2,3
	If EXISTS("Fonts:Times/36")
		SetPrintFont "Times",36
		PrintText "Welcome",81,19
		PrintText "to",130,45
		PrintText "A2K",106,80
	Else
		SetPrintFont "topaz",8
		PrintText "Welcome to A2K",81,50
	EndIf
	SetPrintFont "topaz",8
	SetPen 1,3
	SetDrawMode JAM2 
	PrintText "...and your name is?",70,115
	PrintText "...and your IBO number?",70,150
	SetObjectState ".F_Name",On
@{b}EndScript@{ub}
@{b}TextField ".F_Name"@{ub}
	Definition
		InitialText ""
		Origin 50,128
		Size 208,12
		Border INVERT BEVEL 
		MaxFieldLength 25
		Font "topaz",8
		TextColors 1,4
		AltTextColors 1,4
	EndScript
	OnRelease
		Let YName=TextFrom(".F_Name")
		If YName=""
			SetObjectState ".F_Name",On
		EndIf
		If YName<>OldName
			SetInteger ".F_Number",0
			SetObjectState ".F_Number",On
		Else
			SetObjectState ".F_Number",On
		EndIf
	EndScript
	OnClick
		Let CurrField=1,OldName=TextFrom(".F_Name")
	EndScript
@endnode
 
@node "91 IntegerField · .F_Number" "IntegerField · .F_Number"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}IntegerField@{fg text}@{ub} .F_Number
 
@{b}Definition@{ub}
	@{fg highlight}Limits@{fg text} 0,9999999
	@{fg highlight}InitialInteger@{fg text} 0
	@{fg highlight}Origin@{fg text} 125,164
	@{fg highlight}Size@{fg text} 64,12
	@{fg highlight}Border@{fg text} INVERT BEVEL 
	@{fg highlight}MaxFieldLength@{fg text} 7
	@{fg highlight}Font@{fg text} "topaz",8
	@{fg highlight}TextColors@{fg text} 1,4
	@{fg highlight}AltTextColors@{fg text} 1,4
@{b}EndScript@{ub}
@{b}OnClick@{ub}
	Let CurrField=2
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	Let Number=IntegerFrom(".F_Number"),Name=TextFrom(".F_Name")
	If Name=""
		SetObjectState ".F_Name",On
	ElseIf Number=0
		SetObjectState ".F_Number",On
	ElseIf Number<>0
		Do "MakeName"
	EndIf
@{b}EndScript@{ub}
@endnode
 
