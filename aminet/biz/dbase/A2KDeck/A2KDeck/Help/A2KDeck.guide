@node "105 AreaButton · B_Save" "AreaButton · B_Save"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AreaButton@{fg text}@{ub} B_Save
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} 234,186
	@{fg highlight}Border@{fg text} BEVEL 
	@{fg highlight}Text@{fg text} "Save"
	@{fg highlight}Font@{fg text} "topaz",8
	@{fg highlight}Highlight@{fg text} NONE 
	@{fg highlight}Size@{fg text} 68,14
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	ReattachObject "B_Save"
	Do "Get Number"
	If Name<>""
		If Number<>0
			Let DistDataBase=GetDBObjects
			SaveVariable DistDataBase,"Ram:A2KData/DistData/Dist.Data"
			SaveVariable DistDataBase,"Ram:A2KData/DistData/"||Name||".Data"
			SaveVariable DistDataBase,DefDistDir||"/Dist.Data"
			SaveVariable DistDataBase,DefDistDir||"/"||Name||".Data"
			SetObjectState "MainWindow",On
			DetachObject "DistWindow"
		EndIf
	EndIf
@{b}EndScript@{ub}
@{b}OnClick@{ub}
	Do "Click",234,186,68,14,"Save"
@{b}EndScript@{ub}
@endnode
 
