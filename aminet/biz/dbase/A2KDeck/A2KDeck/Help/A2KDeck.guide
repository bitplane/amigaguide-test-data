@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Set OrderTax Field
 
If Arg1
	Let TaxAmount=Arg2
	Let TaxField=Arg3
	Do "Get VS"
	SetText ".Tax",TaxField
	Do "Tax"
	Do "Tax Amounts"
	Let OrderDataBase[OrderIndex]=GetDBObjects
	Let SearchText=TextFrom(".VS")
	Let SearchField="VS"
	Do "Search NextOrder"
	Do "EnterOrder"
	Do "Search NextOrder"
EndIf
Do "Set Field",1
@endnode
 
