@node "145 AreaButton · B_+" "AreaButton · B_+"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AreaButton@{fg text}@{ub} B_+
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} 78,87
	@{fg highlight}Border@{fg text} BEVEL 
	@{fg highlight}Text@{fg text} " + "
	@{fg highlight}Font@{fg text} "topaz",8
	@{fg highlight}Highlight@{fg text} NONE 
	@{fg highlight}Size@{fg text} 28,14
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	ReattachObject "B_+"
	If Base="Order"
		Do "Get VS"
		Do "Tax"
		;Do "Tax Amounts"
		Let OrderDataBase[OrderIndex]=GetDBObjects
		Let SearchText=TextFrom(".VS")
		Let SearchField="VS"
		Do "Search NextOrder"
		Do "EnterOrder"
		Do "Search NextOrder"
	EndIf
	If Base="Cust"
		Do "Get VS"
		Do "Tax"
		;Do "Tax Amounts"
		Let CustDataBase[CustIndex]=GetDBObjects
		Let SearchText=TextFrom(".VS")
		Let SearchField="VS"
		Do "Search Next"
		Do "EnterCust"
		Do "Search Next"
	EndIf
	Do "Set Field",CURRFIELD
@{b}EndScript@{ub}
@{b}OnClick@{ub}
	Do "Click",78,87,28,14,"+",8
	If Base="Stock"
		Do "Format $","B_+",Max(99999),FN,FIELDNAMES[CURRFIELD],"+",">",0
	ElseIf Base="Order"
		If CurrField<>2
			Do "Format $","B_+",Max(99999),FN,FIELDNAMES[CURRFIELD],"+",">",0
		Else
			Do "Get VS"
			While ObjectState("B_+")
				Let Qty=IntegerFrom(".Qty")
				Let Qty=Qty+1
				If Qty>99
					Let Qty=1
				EndIf
				Let PV=FormatValue(Qty*StockDataBase[StockIndex].PV,"###0.00")
				Let BV=FormatValue(Qty*StockDataBase[StockIndex].BV,"###0.00")
				Let Dist=FormatValue(Qty*StockDataBase[StockIndex].Dist,"###0.00")
				Let Cust=FormatValue(Qty*StockDataBase[StockIndex].Cust,"###0.00")
				Delay 0,0,10
				SetInteger ".Qty",Qty
				SetText ".PV",PV
				SetText ".BV",BV
				SetText ".Dist",Dist
				SetText ".Cust",Cust
			EndLoop
		EndIf
	ElseIf Base="Cust"
		If CurrField<>2
			Do "Format $","B_+",Max(99999),FN,FIELDNAMES[CURRFIELD],"+",">",0
		Else
			Do "Get VS"
			While ObjectState("B_+")
				Let Qty=IntegerFrom(".Qty")
				Let Qty=Qty+1
				If Qty>99
					Let Qty=1
				EndIf
				Let Cust=FormatValue(Qty*StockDataBase[StockIndex].Cust,"###0.00")
				Delay 0,0,10
				SetInteger ".Qty",Qty
				SetText ".Cust",Cust
			EndLoop
		EndIf
	EndIf
@{b}EndScript@{ub}
@endnode
 
@node "146 AreaButton · B_-" "AreaButton · B_-"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AreaButton@{fg text}@{ub} B_-
 
@{b}Definition@{ub}
	@{fg highlight}Origin@{fg text} 108,87
	@{fg highlight}Border@{fg text} BEVEL 
	@{fg highlight}Text@{fg text} " - "
	@{fg highlight}Font@{fg text} "topaz",8
	@{fg highlight}Highlight@{fg text} NONE 
	@{fg highlight}Size@{fg text} 28,14
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	ReattachObject "B_-"
	DoObjectScript "B_+",ONRELEASE 
	Do "Set Field",4
@{b}EndScript@{ub}
@{b}OnClick@{ub}
	Do "Click",108,87,28,14,"-",8
	If Base="Stock"
		Do "Format $","B_-",Min(0),FN,FIELDNAMES[CURRFIELD],"-","<",9999
	ElseIf Base="Order"
		If CurrField=2
			Do "Get VS"
			While ObjectState("B_-")
				Let Qty=IntegerFrom(".Qty")
				Let Qty=Qty-1
				If Qty=0
					Let Qty=99
				EndIf
				Let PV=FormatValue(Qty*StockDataBase[StockIndex].PV,"###0.00")
				Let BV=FormatValue(Qty*StockDataBase[StockIndex].BV,"###0.00")
				Let Dist=FormatValue(Qty*StockDataBase[StockIndex].Dist,"###0.00")
				Let Cust=FormatValue(Qty*StockDataBase[StockIndex].Cust,"###0.00")
				Delay 0,0,10
				SetInteger ".Qty",Qty
				SetText ".PV",PV
				SetText ".BV",BV
				SetText ".Dist",Dist
				SetText ".Cust",Cust
			EndLoop
		Else
			Do "Format $","B_-",Min(0),FN,FIELDNAMES[CURRFIELD],"-","<",9999
		EndIf
	ElseIf Base="Cust"
		If CurrField=2
			Do "Get VS"
			While ObjectState("B_-")
				Let Qty=IntegerFrom(".Qty")
				Let Qty=Qty-1
				If Qty=0
					Let Qty=99
				EndIf
				Let Cust=FormatValue(Qty*StockDataBase[StockIndex].Cust,"###0.00")
				Delay 0,0,10
				SetInteger ".Qty",Qty
				SetText ".Cust",Cust
			EndLoop
		Else
			Do "Format $","B_-",Min(0),FN,FIELDNAMES[CURRFIELD],"-","<",9999
		EndIf
	EndIf
@{b}EndScript@{ub}
@endnode
 
