@node "174 AfterAttachment · " "AfterAttachment · "
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}AfterAttachment@{fg text}@{ub} 
 
Do "Tax"
Do "Click",14,387,682,66;B_InfoA
Do "Draw Cust"
FastFeedBack On
Dispose Work
Let Sort="Yes"
Let Base="Cust"
ReattachObject "Fields"
DisableObject ".PV"
DisableObject ".BV"
DisableObject ".Dist"
Do "Get Fields",".VS",".Qty",".Des",".Tax",".Cust","Name","Add1","Add2","Phn","Mob"
Let FieldNames[11]="OrdDate"
Let FieldNames[12]="DelDate"
If Exists("Ram:A2KData/CustData/Cust.Data")
	Let CustDataBase=LoadVariable("Ram:A2KData/CustData/Cust.Data")
	Do "Load CustDataFile"
ElseIf Exists(DefCustDir||"/Cust.Data")
	Let CustDataBase=LoadVariable(DefCustDir||"/Cust.Data")
	Do "Load CustDataFile"
	SaveVariable CustDataBase,"Ram:A2KData/CustData/Cust.Data"
ElseIf Not Exists(DefCustDir||"/Cust.Data")
	If Exists("Ram:A2KData/OrderData/Order.Data")
		Let CustDataBase=LoadVariable("Ram:A2KData/OrderData/Order.Data")
		Do "Load CustDataFile"
		SaveVariable CustDataBase,"Ram:A2KData/CustData/Cust.Data"
	Else
		SetFileRequestMode REGULARMODE ,REJECTICONS PATTERNFIELD 
		SetFileRequestPattern "#?.Data"
		Let FileName=AskForFileName(DefCustDir||"/.Data","Select File To Load...")
		If FileOf(FileName)<>""
			Let CustDataBase=LoadVariable(FileName)
			Do "Load CustDataFile"
			SaveVariable CustDataBase,"Ram:A2KData/CustData/Cust.Data"
		Else
			Let CustIndex=1
			Let CustDataBase[CustIndex]=GetDBObjects
			Do "Load CustDataFile"
			SaveVariable CustDataBase,"Ram:A2KData/CustData/Cust.Data"
		EndIf
	EndIf
EndIf
Do "Load Name"
Do "Get Date"
Do "Get CustEntry",1
Do "Set Field",1
@endnode
 
