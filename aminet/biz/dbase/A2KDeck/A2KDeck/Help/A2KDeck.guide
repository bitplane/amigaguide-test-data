@node "50 Routine · Set Tax Field" "Routine · Set Tax Field"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Set Tax Field
 
If Arg1
	Let TaxAmount=Arg2
	Let TaxField=Arg3
	Do "Get VS"
	SetText ".Tax",TaxField
	Do "Tax"
	Do "Tax CustAmounts"
	Let CustDataBase[CustIndex]=GetDBObjects
	Let SearchText=TextFrom(".VS")
	Let SearchField="VS"
	Do "Search Next"
	Do "EnterCust"
	Do "Search Next"
EndIf
Do "Set Field",1
@endnode
 
@node "51 Routine · Load OrderDataFile" "Routine · Load OrderDataFile"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Load OrderDataFile
 
Let TotalPV=0,TotalBV=0,TotalQty=0,TotalDist=0,TotalCust=0,TotalProfit=0,TotalTaxDist=0,TotalTaxCust=0
Let TotalTaxDistT=0,TotalTaxCustT=0,TotalTaxDistG=0,TotalTaxCustG=0,TotalTaxDistP=0,TotalTaxCustP=0
Let TotalTaxDistV1=0,TotalTaxCustV1=0,TotalTaxDistV2=0,TotalTaxCustV2=0
WorkWithDocument "Order List"
Clear DOCUMENT 
If Sort="Yes"
	SortArray OrderDataBase,INTEGER ,".VS"
EndIf
Let OrderIndex=FirstArrayIndex(OrderDataBase)
While SearchFound
	Type LeftJustify(OrderDataBase[OrderIndex].VS,12)
	Type "  "
	Type RightJustify(OrderDataBase[OrderIndex].Qty,2)
	Type "  "
	Type LeftJustify(OrderDataBase[OrderIndex].Des,22)
	Type "   "
	Type RightJustify(FormatValue(OrderDataBase[OrderIndex].PV,"###0.00"),7)
	Type "  "
	Type RightJustify(FormatValue(OrderDataBase[OrderIndex].BV,"###0.00"),7)
	Type " "
	If T="Yes"
		Let ATX=OrderDataBase[OrderIndex].Tax
		Do "Get VS",OrderDataBase[OrderIndex].VS
		Let Val=FormatValue(OrderDataBase[OrderIndex].Tax,"####")
		Type LeftJustify(FormatValue(OrderDataBase[OrderIndex].Tax,"###%"),4)
	Else
		Type LeftJustify(FormatValue(OrderDataBase[OrderIndex].Tax,"###%"),4)
	EndIf
	Type " "
	Type RightJustify(FormatValue(OrderDataBase[OrderIndex].Dist,DefNote||"###0.00"),7)
	Type " "
	Type RightJustify(FormatValue(OrderDataBase[OrderIndex].Cust,DefNote||"###0.00"),7)
	Let TotalPV=TotalPV+OrderDataBase[OrderIndex].PV,TotalBV=TotalBV+OrderDataBase[OrderIndex].BV
	Let TotalQty=TotalQty+OrderDataBase[OrderIndex].Qty,TotalDist=TotalDist+OrderDataBase[OrderIndex].Dist
	Let TotalCust=TotalCust+OrderDataBase[OrderIndex].Cust,TotalProfit=TotalCust-TotalDist
	Do "Calc OrderTax"
	NewLine
	Let OrderIndex=NextArrayIndex(OrderDataBase,OrderIndex)
EndLoop
Delete CHARACTER ,-1
If OrderIndex=1
	MoveCursorTo STARTOF DOCUMENT 
EndIf
Do "Print OrderCalc Totals"
Do "Print OrderTotals"
@endnode
 
@node "52 Routine · PrintCust" "Routine · PrintCust"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} PrintCust
 
If T="Yes"
	Do "PrintTax"
Else
	Let Day=GetWord(TheDate,2,"/")
	Let Month=GetWord(TheDate,1,"/")
	Let Year=GetWord(TheDate,3,"/")
	WorkWithDocument "Ram:A2K/OrderData/Order.Doc"
	Clear DOCUMENT 
	Type " ",NEWLINE 
	Type "VS     Qty    Description              P.V.      B.V.      Dist      Cost"
	MoveCursorTo ENDOF DOCUMENT 
	NewLine
	Type "ŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻ",NEWLINE 
	InsertDocument "Order List"
	MoveCursorTo ENDOF DOCUMENT 
	NewLine
	Type "ŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻ",NEWLINE 
	Type " Total Qty   Total Profit  Total(s)    P.V.      B.V.      Dist      Cost",NEWLINE 
	Type "      "
	Type RightJustify(TotalQty,3)
	Type "        "
	Type RightJustify(FormatValue(TotalProfit,Note||"####0.00"),8)
	Type "          "
	Type RightJustify(FormatValue(TotalPV,Note||"####0.00"),8)
	Type "  "
	Type RightJustify(FormatValue(TotalBV,Note||"####0.00"),8)
	Type "  "
	Type RightJustify(FormatValue(TotalDist,Note||"####0.00"),8)
	Type "  "
	Type RightJustify(FormatValue(TotalCust,Note||"####0.00"),8),NEWLINE 
EndIf
SaveDocument "Ram:A2KData/OrderData/Order.Doc"
SaveDocument "Ram:A2KData/OrderData/Order.Doc","Ram:A2KData/PrintData/Order.Doc"
Dos "C:Join Ram:A2KData/PrintData/Dist.Doc Ram:A2KData/PrintData/Order.Doc as Ram:A2KData/PrintData/Print.Doc"
Dos "C:Copy Ram:A2KData/PrintData/Print.Doc to Ram:A2KData/OrderData/Temp.Doc"
If DefDate="MDY"
	Dos "C:Rename Ram:A2KData/OrderData/Temp.Doc Ram:A2KData/OrderData/Ordering-["||Month||"-"||Day||"-"||Year||"].Doc"
Else
	Dos "C:Rename Ram:A2KData/OrderData/Temp.Doc Ram:A2KData/OrderData/Ordering-["||Day||"-"||Month||"-"||Year||"].Doc"
EndIf
Dos "C:Delete Ram:A2KCustData/OrderData/Temp.Doc"
Dos "C:Copy Ram:A2KCustData/OrderData "||DefOrdDir||" All"
@endnode
 
@node "53 Routine · New Order" "Routine · New Order"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} New Order
 
SetDBObjects Nothing
WorkWithDocument "Order List"
Clear DOCUMENT 
Dispose OrderDataBase
Let OrderDataBase[OrderIndex]=GetDBObjects
Do "Load OrderDataFile"
Do "Get OrderEntry",1
Do "Set Field",1
@endnode
 
@node "54 Routine · New Stock" "Routine · New Stock"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} New Stock
 
Do "Store StockEntry"
WorkWithDocument "Stock List"
SetDBObjects Nothing
SetText ".Des","Empty"
MoveCursorTo STARTOF DOCUMENT 
SearchFor "Empty"
If Not SearchFound
	Let NewEntry=GetDBObjects
	If NewEntry<>StockDataBase[StockIndex]
		If SizeOfDocument<>0
			WorkWithDocument "Stock List"
			MoveCursorTo STARTOF DOCUMENT 
			SplitLine
			MoveCursor UP 
			Let StockIndex=1
			InsertArrayEntry StockDataBase,StockIndex
		EndIf
	EndIf
	Let StockDataBase[StockIndex]=GetDBObjects
	Do "Load StockDataFile"
	MoveCursorTo STARTOF DOCUMENT 
	SearchFor "Empty"
	Do "Get StockEntry",TheLineNumber
ElseIf SearchFound
	Do "Get StockEntry",TheLineNumber
EndIf
@endnode
 
@node "55 Routine · Move" "Routine · Move"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Move
 
MoveObject "B_OverDate",0,-100
MoveObject "B_Date",0,-100
MoveObject "B_OverCalc",0,-100
MoveObject "B_Calc",0,-100
MoveObject "B_OverExpen",0,-100
MoveObject "B_Expen",0,-100
MoveObject "B_OverHelp",0,-100
MoveObject "B_Help",0,-100
Let MX=153-PropX*60,My=55
If MX=93
	Let N=1,Cnt=10
	MoveObject "B_OverLoad",Mx-1,My-41
	Do "Click",MX,55,60,14,"Load",4
	MoveObject "B_Load",Mx,My
ElseIf MX=33
	Let Mx=31,N=1,Cnt=11
	MoveObject "B_OverLoad",0,-100
	MoveObject "B_Load",0,-100
ElseIf MX=-27
	Let Mx=-31,N=2,Cnt=12
	MoveObject "B_OverLoad",0,-100
	MoveObject "B_Load",0,-100
	MoveObject "B_OverSave",0,-100
	MoveObject "B_Save",0,-100
ElseIf MX=-87
	Let Mx=-93,N=3,Cnt=13
	MoveObject "B_OverLoad",0,-100
	MoveObject "B_Load",0,-100
	MoveObject "B_OverSave",0,-100
	MoveObject "B_Save",0,-100
	MoveObject "B_OverDelete",0,-100
	MoveObject "B_Delete",0,-100
ElseIf MX=-147
	Let Mx=-155,N=4,Cnt=14
	MoveObject "B_OverLoad",0,-100
	MoveObject "B_Load",0,-100
	MoveObject "B_OverSave",0,-100
	MoveObject "B_Save",0,-100
	MoveObject "B_OverDelete",0,-100
	MoveObject "B_Delete",0,-100
	MoveObject "B_OverNew",0,-100
	MoveObject "B_New",0,-100
EndIf
Loop
	Let OBT[1]="Save",Tm[1]=4,OBT[2]="Delete",Tm[2]=12,OBT[3]="New",Tm[3]=0,OBT[4]="Search",Tm[4]=12
	Let OBT[5]="Prefs",Tm[5]=8,OBT[6]="People",Tm[6]=12,OBT[7]="Tapes",Tm[7]=8,OBT[8]="Books",Tm[8]=8
	Let OBT[9]="Print",Tm[9]=8,OBT[10]="Date",Tm[10]=4,OBT[11]="Expen",Tm[11]=8,OBT[12]="Calc",Tm[12]=4
	Let OBT[13]="Help",Tm[13]=4
	MoveObject "B_Over"||OBT[N],MX+(62*N)-1,My-41
	Do "Click",MX+(62*N),55,60,14,OBT[N],Tm[N]
	MoveObject "B_"||OBT[N],MX+(62*N),My
	Let N=N+1
Until N=Cnt
@endnode
 
@node "56 Routine · Reattach" "Routine · Reattach"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Reattach
 
Do "Click",14,87,30,14,"<",7
Do "Click",46,87,30,14,">",7
Do "Click",78,87,28,14,"+",8
Do "Click",108,87,28,14,"-",8
Do "Click",138,87,44,14,"Clr",8
Do "Click",226,87,30,14,"Tax",15
Do "Click",318,87,124,14,"DataBase",-12
Do "Click",444,87,124,14,"Ordering Form",8
Do "Click",570,87,124,14,"Customer Reciet",16
Do "Click",14,111,680,14 ;"InfoBar"
ReattachObject "B_Previous"
ReattachObject "B_Next"
ReattachObject "B_+"
ReattachObject "B_-"
ReattachObject "B_Clr"
ReattachObject "B_Tax"
ReattachObject "B_InfoBar"
ReattachObject "B_DataBase"
ReattachObject "B_Order"
ReattachObject "B_Customer"
@endnode
 
