@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Do Set Date
 
If Arg1
	If CURRFIELD=11
		SetText "OrdDate",Arg2
	ElseIf CURRFIELD=12
		SetText "DelDate",Arg2
	Else
		SetText "OrdDate",Arg2
	EndIf
EndIf
