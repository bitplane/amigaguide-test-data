@node "161 TextField · .Cust" "TextField · .Cust"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}TextField@{fg text}@{ub} .Cust
 
@{b}Definition@{ub}
	@{fg highlight}InitialText@{fg text} ""
	@{fg highlight}Origin@{fg text} 598,131
	@{fg highlight}Size@{fg text} 64,12
	@{fg highlight}Border@{fg text} INVERT BEVEL 
	@{fg highlight}Justification@{fg text} RIGHT 
	@{fg highlight}MaxFieldLength@{fg text} 7
	@{fg highlight}Font@{fg text} "topaz",8
	@{fg highlight}TextColors@{fg text} 1,5
	@{fg highlight}AltTextColors@{fg text} 1,5
@{b}EndScript@{ub}
@{b}OnClick@{ub}
	Let CurrField=8
@{b}EndScript@{ub}
@{b}OnRelease@{ub}
	Do "Format Fields",".Cust",Cust
	Let Entry=GetDBObjects
	If Base="Stock"
		If Entry<>StockDataBase[StockIndex]
			Do "EnterStock"
		EndIf
	ElseIf Base="Order"
		If Entry<>OrderDataBase[OrderIndex]
			Do "EnterOrder"
		EndIf
	ElseIf Base="Cust"
		If Entry<>CustDataBase[CustIndex]
			Do "EnterCust"
		EndIf
	EndIf
	Do "Set Field",1
@{b}EndScript@{ub}
@endnode
 
