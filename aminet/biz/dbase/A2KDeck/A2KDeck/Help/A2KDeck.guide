@node "69 Routine · Get PrevOrder" "Routine · Get PrevOrder"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get PrevOrder
 
Let OrderEntry=GetDBObjects
If OrderEntry<>OrderDataBase[OrderIndex]
	Do "EnterOrder"
EndIf
Let OrderIndex=PreviousArrayIndex(OrderDataBase,OrderIndex)
If Not SearchFound
	Let OrderIndex=LastArrayIndex(OrderDataBase)
EndIf
Do "Get OrderEntry",OrderIndex
@endnode
 
@node "70 Routine · Get PrevCust" "Routine · Get PrevCust"
 
@{pari -4}@{lindent 8}@{b}@{fg highlight}Routine@{fg text}@{ub} Get PrevCust
 
Let CustEntry=GetDBObjects
If CustEntry<>CustDataBase[CustIndex]
	Do "EnterCust"
EndIf
Let CustIndex=PreviousArrayIndex(CustDataBase,CustIndex)
If Not SearchFound
	Let CustIndex=LastArrayIndex(CustDataBase)
EndIf
Do "Get CustEntry",CustIndex
