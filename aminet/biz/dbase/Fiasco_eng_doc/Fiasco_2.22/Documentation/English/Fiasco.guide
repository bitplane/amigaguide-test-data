@node rxsetsearchfield "SetSearchField" 
@toc ARexxFuncInd

@{b}@{u}SetSearchField@{ub}@{uu}


@{b}Name:@{ub} @{b}SetSearchField@{ub} - Add a field to a search info 

@{b}Synopsis:@{ub} @{b}SetSearchField SearchInfo/K/A,FieldID/K/A,Blur/K/N,Pattern/K/A/F@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Adds a field and the pattern to a search info in field mode. 
   The specified field @{i}must@{ui} match the pattern in order to have the search 
   info match a record. 

@{b}Arguments:@{ub} @{b}SearchInfo@{ub} - Name of the search info to be modified. 
   @{b}FieldID@{ub} - ID of the field to be searched. 
   @{b}Blur@{ub} - Blur factor. When not specified, blurred search will be turned off.
   @{b}Pattern@{ub} - Pattern for the field.
   

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 
@node rxsetstatus "SetStatus" 
