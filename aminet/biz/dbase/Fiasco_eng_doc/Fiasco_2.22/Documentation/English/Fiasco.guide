@{b}Settings@{ub}

@{"ReadSettings" link rxreadsettings} @{"SaveSettings" link rxsavesettings} 


@{b}Miscellaneous@{ub}

 @{"Fault" link rxfault}
 @{"FlushRecords" link rxflushrecords}

 

@endnode 
@node rxactivatedbwindow "ActivateDBWindow" 
@toc ARexxFuncInd

@{b}@{u}ActivateDBWindow@{ub}@{uu}


@{b}Name:@{ub} @{b}ActivateDBWindow@{ub} -- Activate a database's window (8) 

@{b}Synopsis:@{ub} @{b}ActivateDBWindow Project/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Activates the mask window of the specified database.  The 
   user's input focus will change to this window. This has no effect on 
   the working of the calling ARexx script.  If the database is hidden, 
   this command does nothing.  

@{b}Arguments:@{ub} @{b}Project@{ub} - Name of database to be activated. 

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 


@node rxactivatefield "ActivateField" 
@toc ARexxFuncInd

@{b}@{u}ActivateField@{ub}@{uu}


@{b}Name:@{ub} @{b}ActivateField@{ub} - Activate a field in the mask. 

@{b}Synopsis:@{ub} @{b}ActivateField FieldID/A@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Activates the field with the specified ID in the mask. Only 
   fields, which appear as a string or longint gadget may be activated. 
   If project or window is not active, the field cannot be activated.  
   This command may be only called in record mode. 

@{b}Arguments:@{ub} @{b}FieldID@{ub} - ID of the field to be activated. 

@{b}Results:@{ub} @{b}RC@{ub} - Zero if the field has been activated. 


@endnode 


@node rxactiveindex "ActiveIndex" 
@toc ARexxFuncInd

@{b}@{u}ActiveIndex@{ub}@{uu}


@{b}Name:@{ub} @{b}ActiveIndex@{ub} -- Control the active index 

@{b}Synopsis:@{ub} @{b}ActiveIndex Index/K,Next/S,Prev/S,NoHistory/S,Force/S,Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui}
   @{b}Result@{ub} = @{i}Active Index@{ui} 

@{b}Function:@{ub} This command controls the active index. You may specify an 
   index by name or activate the @{b}next@{ub} or @{b}prev@{ub}ious index in the 
   @{"index history" Link indexhistory}. The name of the newly activated index will be returned. 
   If you do not specify any of @{b}Index@{ub}, @{b}Next@{ub} or @{b}Prev@{ub}, only the name of the 
   active index will be returned. 

@{b}Arguments:@{ub} @{b}Index@{ub} - Activate specified index.
   @{b}Next@{ub} - Activate next index in history.
   @{b}Prev@{ub} - Activate previous index in history.
   @{b}NoHistory@{ub} - Do not track this change in the index history.
   @{b}Force@{ub} - Suppress all warnings. 

@{b}Results:@{ub} @{b}RC@{ub} - Success. @{b}Result@{ub} - Name of the now active index. 


@endnode 
@node rxactiverecord "ActiveRecord" 
@toc ARexxFuncInd

@{b}@{u}ActiveRecord@{ub}@{uu}


@{b}Name:@{ub} @{b}ActiveRecord@{ub} -- Control the active record 

@{b}Synopsis:@{ub} @{b}ActiveRecord Record/K/N,First/S,Last/S,Next/S,Prev/S,Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 
   @{b}Result@{ub} = @{i}New active record@{ui} 

@{b}Function:@{ub} With @{b}ActiveRecord@{ub} you may control the active record in the 
   addressed database. You may activate a record specified by record 
   number, the @{b}first@{ub}, the @{b}last@{ub} or the @{b}next@{ub} or the @{b}prev@{ub}ious record 
   relative to the currently active record. The number of the new active 
   record will be returned. If you do not specify any of the five first 
   arguments, only the number of the active record will be returned and 
   the position won't be changed.  This command may be only called in 
   record mode. 

@{b}Arguments:@{ub} @{b}Record@{ub} - Activate specified record. 
   @{b}First@{ub} - Activate first record. 
   @{b}Last@{ub} - Activate last record. 
   @{b}Next@{ub} - Activate the record after the currently active one.
   @{b}Prev@{ub} - Activate the record before the currently active one.
   

@{b}Results:@{ub} @{b}RC@{ub} - Success
   @{b}Result@{ub} - Number of now active record. 


@endnode 


@node rxaddlvfieldentry "AddLVFieldEntry" 
@toc ARexxFuncInd

@{b}@{u}AddLVFieldEntry@{ub}@{uu}


@{b}Name:@{ub} @{b}AddLVFieldEntry@{ub} - Add an entry to a listview field 

@{b}Synopsis:@{ub} @{b}AddLVFieldEntry FieldID/A,Record/K/N,ListEntry/K/N@{ub} 
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Adds a new entry after the specified entries of the specified 
   listview field. If no entry is specified, the entry will be added as 
   the last entry. It will contain the @{b}Initial Content@{ub} set in the field 
   requester. To change the content, use @{b}@{"SetField" link rxsetfield}@{ub}.  This command may be 
   only called in record mode. 

@{b}Arguments:@{ub} @{b}FieldID@{ub} - ID of listview field 
   @{b}Record@{ub} - Number of record to be changed 
   @{b}ListEntry@{ub} - Number of entry after which the entry will be added. 
   Counting from 1. 0 for adding an entry at the top of the list. 

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 


@node rxaddrecord "AddRecord" 
@toc ARexxFuncInd

@{b}@{u}AddRecord@{ub}@{uu}


@{b}Name:@{ub} @{b}AddRecord@{ub} - Add a new record to a database 

@{b}Synopsis:@{ub} @{b}AddRecord Record/K/N,Inactive/S,Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui}
   @{b}Result@{ub} = @{i}Record Position@{ui} 

@{b}Function:@{ub} Creates a new record and adds it to the addressed database. The 
   record will contain the initial values.  This command may be only 
   called in record mode. 

@{b}Arguments:@{ub} @{b}Record@{ub} - Record after which the new record will be inserted 
   into the database. Please note that Fiasco may choose another position 
   for the record. This may be for instance with automatic sorting the 
   case. If not specified, the record will be inserted after the active 
   one. 
   @{b}Inactive@{ub} - Record will not be activated. 
   

@{b}Results:@{ub} @{b}RC@{ub} - Success 
   @{b}Result@{ub} - The real position of the new record. 


@endnode 


@node rxcalculateformula "CalculateFormula" 
@toc ARexxFuncInd

@{b}@{u}CalculateFormula@{ub}@{uu}


@{b}Name:@{ub} @{b}CalculateFormula@{ub} - Calculates a formula. 

@{b}Synopsis:@{ub} @{b}CalculateFormula Formula/A,Record/K/N,Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui}
   @{b}Result@{ub} = @{i}Result of calculation@{ui} 

@{b}Function:@{ub} Calculates a formula and returns the result. If fields are 
   referenced in the formula, the field values of the current or the 
   specified record in the addressed database will be used.  This command 
   may be only called in record mode. 

@{b}Arguments:@{ub} @{b}Formula@{ub} - Formula to be calculated.
   @{b}Record@{ub} - Record to be used as current one for calculation. 

@{b}Results:@{ub} @{b}RC@{ub} - Success.
   @{b}Result@{ub} - Result of calculation. 


@endnode 


@node rxclear "Clear" 
@toc ARexxFuncInd

@{b}@{u}Clear@{ub}@{uu}


@{b}Name:@{ub} @{b}Clear@{ub} -- Clear a project 

@{b}Synopsis:@{ub} @{b}Clear Force/S@{ub} 
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Deletes all data in the addressed project. It will be in a 
   state much like after a @{b}New@{ub}.  If you do not specify @{b}Force@{ub}, this 
   command does exactly the same as @{b}@{"Project/Erase" Link MnErase}@{ub}. That means, it is 
   possible, that a requester opens, which asks you whether you want to 
   save the current project before proceeding or cancel.  To prevent 
   this, specify the @{b}Force@{ub} parameter. This will suppress all warnings. 

@{b}Arguments:@{ub} @{b}Force@{ub} - Suppress all warnings. 

@{b}Results:@{ub} @{b}RC@{ub} - Not equal zero, if user cancelled warning requester. 


@endnode 


@node rxclonerecord "CloneRecord" 
@toc ARexxFuncInd

@{b}@{u}CloneRecord@{ub}@{uu}


@{b}Name:@{ub} @{b}CloneRecord@{ub} -- copy a record 

@{b}Synopsis:@{ub} @{b}CloneRecord Record/K/N,To/K/N@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Creates an exact copy of the active or specified record and 
   inserts it at the specified position in the active index. May also 
   affect other indices.  This command may be only called in record mode. 

@{b}Arguments:@{ub} @{b}Record@{ub} - Number of record to be cloned.
   @{b}To@{ub} - Number of record after which the new record will be 
   inserted. 

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 


@node rxclose "Close" 
@toc ARexxFuncInd

@{b}@{u}Close@{ub}@{uu}


@{b}Name:@{ub} @{b}Close@{ub} -- Close a database project 

@{b}Synopsis:@{ub} @{b}Close Force/S@{ub} 
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Closes the addressed project. If you do not specify @{b}Force@{ub}, this 
   command does exactly the same as @{b}@{"Project/Quit" Link MnQuit}@{ub}. That means, it is 
   possible, that a requester opens, which asks you whether you want to 
   save the current project before proceeding or cancel.  To prevent 
   this, specify the @{b}Force@{ub} parameter. This will suppress all warnings.  

@{b}Arguments:@{ub} @{b}Force@{ub} - Suppress all warnings. 

@{b}Results:@{ub} @{b}RC@{ub} - Not equal zero, if user cancelled the warning requester. 


@endnode 


@node rxcloselistwindow "CloseListWindow" 
@toc ARexxFuncInd

@{b}@{u}CloseListWindow@{ub}@{uu}


@{b}Name:@{ub} @{b}CloseListWindow@{ub} -- Close the list window 

@{b}Synopsis:@{ub} @{b}CloseListWindow@{ub} 

@{b}Function:@{ub} Closes the list window of the currently addressed project. If 
   it is already closed, nothing will be done. 

@{b}Arguments:@{ub} None. 

@{b}Results:@{ub} None. 


@endnode 
@node rxcloseservicewindow "CloseServiceWindow" 
@toc ARexxFuncInd

@{b}@{u}CloseServiceWindow@{ub}@{uu}


@{b}Name:@{ub} @{b}CloseServiceWindow@{ub} - Close the service window 

@{b}Synopsis:@{ub} @{b}CloseServiceWindow@{ub} 

@{b}Function:@{ub} Closes the @{"service window" Link ServiceWin}, if it is not already closed. 

@{b}Arguments:@{ub} None. 

@{b}Results:@{ub} None. 


@endnode 
@node rxconvertfield "ConvertField" 
@toc ARexxFuncInd

@{b}@{u}ConvertField@{ub}@{uu}


@{b}Name:@{ub} @{b}CovertField@{ub} - Change the type of a field 

@{b}Synopsis:@{ub} @{b}ConvertField ID/A,NewType/A,Listview/S,AltFormat/S@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Changes the type of the specified field. You cannot convert 
   text, button or bar fields. The command may be only called in mask 
   mode.  

@{b}Arguments:@{ub} @{b}ID@{ub} - ID of the field.
   @{b}NewType@{ub} - New type of the field (e.g. String). 
   @{b}Listview@{ub} - Determines, wether the field becomes a listview or not.
   @{b}AltFormat@{ub} - Specify if you want to get an alternative format. 

@{b}Results:@{ub} 


@endnode 


@node rxcopyrecord "CopyRecord" 
@toc ARexxFuncInd

@{b}@{u}CopyRecord@{ub}@{uu}


@{b}Name:@{ub} @{b}CopyRecord@{ub} -- Copy a record to the clipboard 

@{b}Synopsis:@{ub} @{b}CopyRecord Record/K/N,Unit/K/N@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Copies the active or specified record to the clipboard.  This 
   command may be only called in record mode. 

@{b}Arguments:@{ub} @{b}Record@{ub} - Number of record to be copied. If not specified, the 
   active record will be copied.
   @{b}Unit@{ub} - Number of clipboard unit. Default: 0
   

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 


@node rxcountrecords "CountRecords" 
@toc ARexxFuncInd

@{b}@{u}CountRecords@{ub}@{uu}


@{b}Name:@{ub} @{b}CountRecords@{ub} - Get the number of records. 

@{b}Synopsis:@{ub} @{b}CountRecords Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui}
   @{b}Result@{ub} = @{i}Number of records@{ui} 

@{b}Function:@{ub} Returns the number of records in the active index of the 
   addressed database.  This command may be only called in record mode. 

@{b}Arguments:@{ub} 

@{b}Results:@{ub} @{b}RC@{ub} - Success
   @{b}Result@{ub} - Number of records in the active index. 


@endnode 


@node rxcreatefield "CreateField" 
@toc ARexxFuncInd

@{b}@{u}CreateField@{ub}@{uu}


@{b}Name:@{ub} @{b}CreateField@{ub} - Create a field 
   

@{b}Synopsis:@{ub} @{b}CreateField Type/A,Listview/S,ID/A@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Creates a new field in the addressed database. The attributes 
   will contain default values. It will be both in list and mask hidden. 
   To change the attributes for your own needs and to make it visible, 
   you may use the command @{b}@{"SetAttr" Link rxsetattr}@{ub}.  This command may be only called in 
   mask mode. 

@{b}Arguments:@{ub} @{b}Type@{ub} - Type of field. 
   @{b}Listview@{ub} - Specifiy, if field will get a listview field.
   @{b}ID@{ub} - ID of new field. The command will fail if the ID already exists.
   

@{b}Results:@{ub} @{b}RC@{ub} - Success. 


@endnode 


@node rxcutrecord "CutRecord" 
@toc ARexxFuncInd

@{b}@{u}CutRecord@{ub}@{uu}


@{b}Name:@{ub} @{b}CutRecord@{ub} -- Cut a record to the clipboard 

@{b}Synopsis:@{ub} @{b}CutRecord Record/K/N,Unit/K/N,Force/S@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Copies the active or specified record to the clipboard and 
   removes it from the active index.  This command may be only called in 
   record mode. 

@{b}Arguments:@{ub} @{b}Record@{ub} - Number of record to be cut. Default: active record. 
   @{b}Unit@{ub} - Number of clipboard unit. Default: 0
   @{b}Force@{ub} - Suppress all warnings.
   

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 


@node rxdeleteallrecords "DeleteAllRecords" 
@toc ARexxFuncInd

@{b}@{u}DeleteAllRecords@{ub}@{uu}


@{b}Name:@{ub} @{b}DeleteAllRecords@{ub} -- Remove all records 

@{b}Synopsis:@{ub} @{b}DeleteAllRecords Force/S@{ub} 
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Removes all records from the active index of the addressed 
   database. If you do not specify the @{b}Force@{ub} parameter, this command does 
   exactly the same as @{b}Record/Remove all@{ub}. That means, that a requester 
   may show up, which will ask you, whether you really want to remove all 
   records. To prevent this behavior, specify @{b}Force@{ub}.  This command may be 
   only called in record mode. 

@{b}Arguments:@{ub} @{b}Force@{ub} - Suppress all warnings 

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 


@node rxdeleteconstant "DeleteConstant" 
@toc ARexxFuncInd

@{b}@{u}DeleteConstant@{ub}@{uu}


@{b}Name:@{ub} @{b}DeleteConstant@{ub} - Delete a constant (7)

@{b}Synopsis:@{ub} @{b}DeleteConstant Name/A@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Deletes the specified constant in the addressed database. If a 
   constant of the specified name does not exist, an error will be 
   returned.  Constants are most commonly used in Fiasco formulas, but 
   may be also used for other purposes. The user may view and change the 
   constants of a database using the @{"Constants requester" Link rqconstants}.  

@{b}Arguments:@{ub} @{b}Name@{ub} - Name of the constant to be deleted. 

@{b}Results:@{ub} @{b}RC@{ub} - Success. 


@endnode 


@node rxdeletelvfieldentry "DeleteLVFieldEntry" 
@toc ARexxFuncInd

@{b}@{u}DeleteLVFieldEntry@{ub}@{uu}


@{b}Name:@{ub} @{b}DeleteLVFieldEntry@{ub} - Delete a listview entry 

@{b}Synopsis:@{ub} @{b}DeleteLVFieldEntry FieldID/A,Record/K/N,ListEntry/A/N@{ub} 
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Deletes the specified entry in a listview field.  This command 
   may be only called in record mode. 

@{b}Arguments:@{ub} @{b}FieldID@{ub} - ID of a listview field 
   @{b}ListEntry@{ub} - Number of the entry in the listview to be deleted 
   @{b}Record@{ub} - Number of the record, in which the entry will be deleted. If 
   you omit this argument, the active record will be used. 

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 


@node rxdeleterecord "DeleteRecord" 
@toc ARexxFuncInd

@{b}@{u}DeleteRecord@{ub}@{uu}


@{b}Name:@{ub} @{b}DeleteRecord@{ub} -- Delete a record 

@{b}Synopsis:@{ub} @{b}DeleteRecord Record/K/N,Force/S@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Removes the active or specified record from the active index. 
   The the active record is remove, another record will be activated. If 
   you do not specify the @{b}Force@{ub} parameter, this command does exactly the 
   same as @{b}Record/Remove@{ub}. That means, that a requester may show up, which 
   will ask you, whether you really want to remove this record. To 
   prevent this behavior, specify @{b}Force@{ub}.  This command may be only called 
   in record mode.  

@{b}Arguments:@{ub} @{b}Record@{ub} - Record to be deleted. The active one will be used if 
   not specified.
   @{b}Force@{ub} - No warnings. 

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 


@node rxexport "Export" 
@toc ARexxFuncInd

@{b}@{u}Export@{ub}@{uu}


@{b}Name:@{ub} @{b}Export@{ub} -- Export a database 

@{b}Synopsis:@{ub} @{b}Export File/A,RecStart=RS/K,RecEnd=RE/K,RecSep=RP/K,
   FieldStart=FS/K,FieldEnd=FE/K,FieldSep=FP,FirstRecIDs/K,
   MarkedOnly/S@{ub} 
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Calls the export function of Fiasco. See the Import/Export 
   chapter for more information about exporting. If you do not specify a 
   parameter, it will be empty. 

@{b}Arguments:@{ub} @{b}File@{ub} - File to write
   @{b}RecStart,RecEnd,RecSep,FieldStart,FieldEnd,FieldSep@{ub} - structure parameters
   @{b}LVEntrySep@{ub} - structure parameter for listview fields 
   @{b}FirstRecIDs@{ub} - First Record will contain field IDs
   @{b}MarkedOnly@{ub} - Exports only marked records 

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 
@node rxfault "Fault" 
@toc ARexxFuncInd

@{b}@{u}Fault@{ub}@{uu}


@{b}Name:@{ub} @{b}Fault@{ub} -- Convert an error code to text 

@{b}Synopsis:@{ub} @{b}Fault ErrorCode/N,Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui}
   @{b}Result@{ub} = @{i}Error text@{ui} 

@{b}Function:@{ub} Converts a Fiasco error number as found in @{b}FIASCO.LASTERROR@{ub} 
   into a human-readable format. It will be localized. Because 
   @{b}FIASCO.LASTERROR@{ub} can also return Amiga DOS error codes, this function 
   also handles these codes. 

@{b}Arguments:@{ub} @{b}ErrorCode@{ub} - Fiasco error code 

@{b}Results:@{ub} @{b}RC@{ub} - Success.
   @{b}Result@{ub} - Localized error text.
   


@endnode 
@node rxfilter "Filter" 
@toc ARexxFuncInd

@{b}@{u}Filter@{ub}@{uu}


@{b}Name:@{ub} @{b}Filter@{ub} - Create a filtered index 

@{b}Synopsis:@{ub} @{b}Filter SearchInfo/K/A,Index/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Creates a filter according to the search criteria specified in 
   the search info. It will be activated after it has been created.  This 
   command may be only called in record mode.  

@{b}Arguments:@{ub} @{b}SearchInfo@{ub} - Name of search info to use.
   @{b}Index@{ub} - Name of index to use. Default: @{b}ARexxFilter.fidx@{ub}. 

@{b}Results:@{ub} @{b}RC@{ub} - Success. 


@endnode 


@node rxfind "Find" 
@toc ARexxFuncInd

@{b}@{u}Find@{ub}@{uu}


@{b}Name:@{ub} @{b}Find@{ub} - Search for data 

@{b}Synopsis:@{ub} @{b}Find SearchInfo/K/A,Record/K/N,Reverse/S,All=Stem/K,Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui}
   @{b}Result@{ub} = @{i}Found Record@{ui}
   

@{b}Function:@{ub} Searches for a pattern that is specified in the @{b}SearchInfo@{ub}. 
   This search info may be created with the commands @{b}@{"NewSearchInfo" Link rxNewSearchInfo}@{ub} and @{b}
   @{"SetSearchField" Link rxSetSearchField}@{ub}.  This command has two modes: You may search for a 
   single matching record. In that mode you may specify the @{b}Record@{ub} @{i}after@{ui} 
   which the search will begin. The number of the next matching record or 
   of the previous matching record, if @{b}Reverse@{ub} was specified, will be 
   returned in @{b}Result@{ub}. By calling that command again with the @{b}Record@{ub} 
   argument set to the last match, you may search for the next match. See 
   the example for the use of this mode.  The second mode allows you to 
   search the whole database at one time. If you specify the name of a 
   stem variable after the keyword @{b}All@{ub}, this function will search the 
   whole database and store the record numbers of the matches in the stem 
   elements @{i}stem@{ui}.@{b}1@{ub}, . . . @{i}stem.n@{ui}. The number of matches will be stored in 
   @{i}stem.@{ui}@{b}count@{ub}. @{i}Important:@{ui} Do not use that mode if a very large number of 
   matches is predictable. In that case, the first mode is faster and 
   more memory efficient.  More about searching with ARexx can be found  
   in the section @{"Searching with ARexx" link ARexxSearch}.    This command may be only 
   called in record mode. 

@{b}Arguments:@{ub} @{b}SearchInfo@{ub} - The name of the search info to use.
   @{b}Record@{ub} - Number of record @{i}after@{ui} which the search will begin. 
   Mutually exclusive to @{b}All@{ub}.
   @{b}Reverse@{ub} - Search the database backwards. 
   @{b}All@{ub} - Search the whole database once and store all matches in the 
   specified stem variable. Mutually exclusive to @{b}Record@{ub}. 

@{b}Results:@{ub} @{b}RC@{ub} - Zero if a match has been found 
   @{b}Result@{ub} - Number of found record 

@{b}Example:@{ub}  

/* Find-Example.frx */

/* Create a new search info */

NewSearchInfo Name "ARexxSI"

/* Set the search info to search for the first record
 * in which the field with the ID Test is not empty
 */

SetSearchField SearchInfo "ARexxSI" FieldID "Test" Pattern "?#?"

rc = 0
startrecord = 0

/* Continue searching until nothing is found */

do while rc = 0            

   Find SearchInfo "ARexxSI" Record startrecord Var "startrecord"

   if rc = 0 then
   do
       /* The number of the match will be
        * stored in startrecord. Now do something
        * with it.
        */

       say startrecord
   end
end

/* All records done */


   
 


@endnode 
@node rxflushrecords "FlushRecords" 
@toc ARexxFuncInd

@{b}@{u}FlushRecords@{ub}@{uu}


@{b}Name:@{ub} @{b}FlushRecords@{ub} - Clean up memory (7)

@{b}Synopsis:@{ub} @{b}FlushRecords@{ub} 

@{b}Function:@{ub} Tries to free as much memory as possible. This is done by 
   removing records from ram, which can be reloaded from disk. 

@{b}Arguments:@{ub} None. 

@{b}Results:@{ub} None. 


@endnode 
@node rxgetattr "GetAttr" 
@toc ARexxFuncInd

@{b}@{u}GetAttr@{ub}@{uu}


@{b}Name:@{ub} @{b}GetAttr@{ub} -- Get an Fiasco attribute 

@{b}Synopsis:@{ub} @{b}GetAttr Object/A,Name/K,Attribute,Stem/K,Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui}
   @{b}Result@{ub} = @{i}Attribute value@{ui} 

@{b}Function:@{ub} Reads the specified attribute and returns it. 

@{b}Arguments:@{ub} @{b}Object@{ub} - Object type to be examined.
   @{b}Name@{ub} - Some object types require a name to be specified.
   @{b}Attribute@{ub} - Name of attribute to be returned.
   @{b}Stem@{ub} - The attributes of an object will be returned in a stem variable.
   

@{b}Results:@{ub} @{b}RC@{ub} - Success.
   @{b}Result@{ub} - Value of the requested attribute. 

@{b}Objects:@{ub} @{b}Application@{ub} - Data related to Fiasco.
   @{b}Projects@{ub} - Returns all the open databases in a stem variable. 
   No further attributes.
   @{b}Project@{ub} - Data related to one Fiasco database. Name may be 
   specified. If you specify the special value @{b}Active@{ub}, the active (in 
   contrast to the @{i}addressed@{ui}) project will be examined. Default: 
   Addressed project.
   @{b}Window@{ub} - Data related to one Fiasco database window. Name may 
   be specified. If you specify the special value @{b}Active@{ub}, the active (in 
   contrast to the @{i}addressed@{ui}) project will be examined. Default: 
   Addressed project.
   @{b}Fields@{ub} - Returns all the fields of the addressed database in a 
   stem variable. No further attributes.
   @{b}Field@{ub} - Data related to a Fiasco field in the addressed 
   database. Name required. 

@{b}Attributes for Application:@{ub} @{b}Version@{ub} - Internal version of Fiasco in the 
   format @{i}ver.rev@{ui}.
   @{b}ReleaseVersion@{ub} - Release version of Fiasco.
   @{b}Screen@{ub} - Name of public screen Fiasco runs on.
   @{b}RegUser@{ub} - Name of registered user of Fiasco. 

@{b}Attributes for Project:@{ub} @{b}ARexx@{ub} - Name of ARexx port.
   @{b}FileName@{ub} - Complete file name of database.
   @{b}Path@{ub} - Path of database.
   @{b}File@{ub} - File name of database.
   @{b}Changes@{ub} - Not equal zero if database has been changed.
   

@{b}Attributes for Window:@{ub} @{b}Left@{ub} - Left edge of window.
   @{b}Top@{ub} - Top edge of window. 
   @{b}Width@{ub} - Width of window. 
   @{b}Height@{ub} - Height of window. 
   @{b}Title@{ub} - Title of window. 
   @{b}Screen@{ub} - Public screen of window. 

@{b}Attributes for Field:@{ub} @{b}Left@{ub} - Left edge of field. 
   @{b}Top@{ub} - Top edge of field. 
   @{b}Width@{ub} - Width of field. 
   @{b}Height@{ub} - Height of field. 
   @{b}ARexxScript@{ub} - ARexx script of field. 
   @{b}PickerARexx@{ub} - ARexx script for picker button.
   @{b}Formula@{ub} - Formula for field.
   @{b}Type@{ub} - Type of field.
   @{b}ListLeft@{ub} - Left edge in list window.
   @{b}ListWidth@{ub} - Width in list window.
   @{b}Shortcut@{ub} - Keyboard shortcut for field.
   @{b}InitContType@{ub} - Type of initial content. One of @{b}LAST@{ub}, @{b}KEY@{ub} or @{b}OWN@{ub}. 
   @{b}InitContValue@{ub} - Value of initial content.
   @{b}MaxChars@{ub} - Max chars of field. Not supported by all fields.
   @{b}MinValue@{ub} - Minimum value of field. Not supported by all fields.
   @{b}MaxValue@{ub} - Maximum value of field. Not supported by all fields.
   @{b}Format@{ub} - Format of field. Not supported by all fields.
   @{b}Labels@{ub} - Labels of field. Not supported by all fields. Will be 
   returned in stem variable.
   @{b}Precision@{ub} - Precision of field. Not supported by all fields.
   @{b}Command@{ub} - Command for field. Not supported by all fields.
   @{b}Stack@{ub} - Stack for field. Not supported by all fields.
   @{b}Virtual@{ub} - Status of virtual flag of field. 1 or 0. 
   @{b}ListHidden@{ub} - Is field hidden in the list? 1 or 0. 
   @{b}Hidden@{ub} - Is field hidden in the mask? 1 or 0. 
   @{b}ReadOnly@{ub} - Is field read only? 1 or 0. 
   @{b}Listview@{ub} - Is field a listview field? 1 or 0. 


@endnode 
@node rxgetconstant "GetConstant" 
@toc ARexxFuncInd

@{b}@{u}GetConstant@{ub}@{uu}


@{b}Name:@{ub} @{b}GetConstant@{ub} - Get the value of a constant (7)

@{b}Synopsis:@{ub} @{b}GetConstant Name/A,Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui}
   @{b}Result@{ub} = @{i}Value of constant@{ui} 

@{b}Function:@{ub} Reads the value of a constant in the addressed Fiasco database. 
   If the constant does not exist, an error will be returned.  Constants 
   are most commonly used in Fiasco formulas, but may be also used for 
   other purposes. The user may view and change the constants of a 
   database using the @{"Constants requester" Link rqconstants}.  

@{b}Arguments:@{ub} @{b}Name@{ub} - Name of the constant. 

@{b}Results:@{ub} @{b}RC@{ub} - Success.
   @{b}Result@{ub} - The value of the specified constant 


@endnode 


@node rxgetfield "GetField" 
@toc ARexxFuncInd

@{b}@{u}GetField@{ub}@{uu}


@{b}Name:@{ub} @{b}GetField@{ub} -- Read the content of a field 

@{b}Synopsis:@{ub} @{b}GetField FieldID,Record/K/N,ListEntry/K/N,ListEntryCount/S, 
   ExtFormat/S,Stem/K,Var/K@{ub} 
   @{b}RC@{ub} = @{i}Success@{ui} 
   @{b}Result@{ub} = @{i}FieldContent@{ui} 

@{b}Function:@{ub} Reads the content of the specified Field in the active or 
   specified record and returns it in result.  If you specify a @{b}Stem@{ub} 
   variable, the contents of all fields will be set into that ARexx stem 
   variable. The stem elements are the field IDs. You may change after 
   this call the values of some variables and use @{b}@{"SetField" Link rxsetfield}@{ub} with its @{b}Stem@{ub} 
   argument to write the values back to the database. Please note that 
   with the @{b}Stem@{ub} argument the commands need much more execution time than 
   the simple calls. Thus, you should use these commands only if you need 
   to set several fields at a time.  This command may be only called in 
   record mode.  

@{b}Arguments:@{ub} @{b}FieldID@{ub} - ID of Field
   @{b}Record@{ub} - Number of record
   @{b}ListEntry@{ub} - Only if field is a listview field. Specifies the 
   number of the entry in the listview, whose content should be returned. 
   Counting from 1.
   @{b}ListEntryCount@{ub} - Only if field is a listview field. Returns the 
   number of entries in the listview. 
   @{b}ExtFormat@{ub} - If specified, the field content will be returned in an 
   extended format, suitable for printing, etc. This extended format may 
   use locale settings, etc. You should not make any assumptions about 
   the resulting format (for example by parsing it in ARexx scripts). See 
   also the @{b}Result@{ub} table. (Fiasco 2.2) 
   @{b}Stem@{ub} - Return all contents in the specified stem variable. 

@{b}Results:@{ub} @{b}RC@{ub} - Success 
    @{b}Result@{ub} - is equal to the current content of the field, if rc = 0.
   The format (In brackets: @{b}ExtFormat@{ub}):
   String - the string itself
   Integer - the number itself
   Float - the fp number
   Slider - the value of the slider
   Cycle - the number of the active label (the active label string) 
   Date - the date in the format @{i}DD.MM.[YY]YY@{ui} (in the current locale format)
   Time - the time in the format @{i}HH:MM:SS@{ui} (in the current locale format)
   Extern - the string itself.
   Datatyp.- the string itself.
   Var String- the string itself. Newlines will be converted to @{b}*n@{ub}.
    If the field is a listview field, you have to use the @{b}ListEntry@{ub} 
   argument to select the entry to be returned. The format will be then 
   the format of the underlying fieldtype.  

@{b}Notes:@{ub} Before release 2.2, this document claimed that the date and time 
   field data would be returned in the current locale format. However, it 
   has always been the case, that - if @{b}ExtFormat@{ub} is not specified - these 
   values are formatted independantly from the locale setting.  


@endnode 


@node rxgetrecordmark "GetRecordMark" 
@toc ARexxFuncInd

@{b}@{u}GetRecordMark@{ub}@{uu}


@{b}Name:@{ub} @{b}GetRecordMark@{ub} - Check the mark of a record 

@{b}Synopsis:@{ub} @{b}GetRecordMark Record/K/N,Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 
   @{b}Result@{ub} = @{i}Marked or not marked@{ui} 

@{b}Function:@{ub} Returns the current state of the mark of a record in the 
   addressed Fiasco database.  This command may be only called in record 
   mode. 

@{b}Arguments:@{ub} @{b}Record@{ub} - Number of record to be checked. Default: active. 

@{b}Results:@{ub} @{b}RC@{ub} - Success
   @{b}Result@{ub} - 1 if record is marked, otherwise 0. 


@endnode 


@node rxhideproject "HideProject" 
@toc ARexxFuncInd

@{b}@{u}HideProject@{ub}@{uu}


@{b}Name:@{ub} @{b}HideProject@{ub} - Hide a Fiasco project 

@{b}Synopsis:@{ub} @{b}HideProject Project/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Closes all windows of the addressed or specified project. 

@{b}Arguments:@{ub} @{b}Project@{ub} - Name of project to be hidden. May be the file name 
   or the full path. 

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 
@node rximport "Import" 
@toc ARexxFuncInd

@{b}@{u}Import@{ub}@{uu}


@{b}Name:@{ub} @{b}Import@{ub} -- Import a database 

@{b}Synopsis:@{ub} @{b}Import File/A,RecStart=RS/K,RecEnd=RE/K,RecSep=RP/K,
   FieldStart=FS/K,FieldEnd=FE/K,FieldSep=FP,
   
   SkipLines/K,StartLine/N/K,FirstRecIDs/K,AppendFields/S@{ub} 
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Calls the import function of Fiasco. The specified file will be 
   imported into the current project using the specified parameters. For 
   more information on import and export see section  @{"Import and Export" link XPort}.  
    You may also use the escape sequences of Fiasco. If you do not 
   specify a parameter, it will be empty. 

@{b}Arguments:@{ub} @{b}File@{ub} - Name of File
   @{b}RecStart,RecEnd,RecSep,FieldStart,FieldEnd,FieldSep@{ub} - the 
   structuring characters
   @{b}SkipLines@{ub} - Comment introducer 
   @{b}StartLine@{ub} - Length of initial comment 
   @{b}FirstRecIDs@{ub} - First Record contains IDs 
   @{b}AppendFields@{ub} - Append new fields 
   

@{b}Results:@{ub} @{b}Result@{ub} - Success 

@{b}Notes:@{ub} The option @{b}Overwrite old project@{ub} of the import requester is not 
   directly supported. You have to emulate it using @{b}@{"Clear" Link rxclear}@{ub}.  


@endnode 
@node rxloaddtfieldobject "LoadDTFieldObject" 
@toc ARexxFuncInd

@{b}@{u}LoadDTFieldObject@{ub}@{uu}


@{b}Name:@{ub} @{b}LoadDTFieldObject@{ub} - Load a datatypes field 

@{b}Synopsis:@{ub} @{b}LoadDTFieldObject FieldID/A@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Loads the contents of a datatypes field, which was "deferred".  
   This command may be only called in record mode. 

@{b}Arguments:@{ub} @{b}FieldID@{ub} - ID of datatypes field 

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 


@node rxlockgui "LockGUI" 
@toc ARexxFuncInd

@{b}@{u}LockGUI@{ub}@{uu}


@{b}Name:@{ub} @{b}LockGUI@{ub} - Lock Fiasco's GUI 

@{b}Synopsis:@{ub} @{b}LockGUI@{ub} 

@{b}Function:@{ub} Locks the GUI of Fiasco. The pointer will appear as a "wait 
   clock". After locking the GUI, the ARexx script can run, without the 
   danger of being influenced by the user. Before the script ends, @{b}
   @{"UnlockGUI" Link rxunlockgui}@{ub} must be called in order to give the control back to the 
   user. @{b}LockGUI@{ub} and @{b}UnlockGUI@{ub} may be nested. 

@{b}Arguments:@{ub} None. 

@{b}Results:@{ub} None. 


@endnode 
@node rxmarkmatch "MarkMatch" 
@toc ARexxFuncInd

@{b}@{u}MarkMatch@{ub}@{uu}


@{b}Name:@{ub} @{b}MarkMatch@{ub} - Mark matching records 

@{b}Synopsis:@{ub} @{b}MarkMatch SearchInfo/K/A@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Marks the records that match the specified search info. The old 
   marks will be overwritten.  This command may be only called in record 
   mode. 

@{b}Arguments:@{ub} @{b}SearchInfo@{ub} - Name of the search info to be used. 

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 


@node rxmarkrecord "MarkRecord" 
@toc ARexxFuncInd

@{b}@{u}MarkRecord@{ub}@{uu}


@{b}Name:@{ub} @{b}MarkRecord@{ub} -- Control marking of records 

@{b}Synopsis:@{ub} @{b}MarkRecord Record/K/N,All/S,Set/S,UnSet/S,Toggle/S@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} @{b}MarkRecord@{ub} can be used to change the marking of one (specified 
   or active) or @{b}all@{ub} records in the addressed database. You may @{b}set@{ub}, 
   @{b}unset@{ub} or @{b}toggle@{ub} the marking.  This command may be only called in 
   record mode. 

@{b}Arguments:@{ub} @{b}Record@{ub} - Number of record to be affected. Default: Active.
   @{b}All@{ub} - Affect all records. Mutually exlusive to @{b}Record@{ub}
   @{b}Set@{ub} - Set the mark.
   @{b}UnSet@{ub} - Remove the mark.
   @{b}Toggle@{ub} - Marked will become unmarked and vice-versa.
   

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 


@node rxmenucontrol "MenuControl" 
@toc ARexxFuncInd

@{b}@{u}MenuControl@{ub}@{uu}


@{b}Name:@{ub} @{b}MenuControl@{ub} -- Switch pull down menus on or off (8) 

@{b}Synopsis:@{ub} @{b}MenuControl On/S,Off/S@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} This command can be used to switch the pull down menus @{i}locally 
   to one database@{ui} on or off to limit the possible actions by the user. 

@{b}Arguments:@{ub} @{b}On@{ub} - Switch menus on
   @{b}Off@{ub} - Switch menus off 

@{b}Results:@{ub} @{b}RC@{ub} - Success 


@endnode 
@node rxmoverecord "MoveRecord" 
@toc ARexxFuncInd

@{b}@{u}MoveRecord@{ub}@{uu}


@{b}Name:@{ub} @{b}MoveRecord@{ub} -- Change a record's position 

@{b}Synopsis:@{ub} @{b}MoveRecord Record/K/N,To/A/N@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 

@{b}Function:@{ub} Moves the active or specified record in the active index to the 
   new specified position. This command does not work if the active index 
   does automatic sorting. This command does not affect other indices.  
   This command may be only called in record mode. 

@{b}Arguments:@{ub} @{b}Record@{ub} - Number of record to be moved. If not specified, the 
   active record will be used.
   @{b}To@{ub} - Number of record after which the record will be inserted. 
   You have to specify the number of the record before the record was 
   moved. 

@{b}Results:@{ub} 


@endnode 


@node rxnew "New" 
@toc ARexxFuncInd

@{b}@{u}New@{ub}@{uu}


@{b}Name:@{ub} @{b}New@{ub} -- Create a new project 

@{b}Synopsis:@{ub} @{b}New Project/K,Iconified/S,Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui} 
   @{b}Result@{ub} = @{i}New ARexx Port@{ui} 

@{b}Function:@{ub} Creates a new database project. If @{b}Iconified@{ub} is not specified, 
   a new window is opened and activated. It is then entirely empty. 

@{b}Arguments:@{ub} @{b}Project@{ub} - File name of new project. If not specified, 
   @{b}Unnamed.fdb@{ub} will be used. 
   @{b}Iconified@{ub} - The project window will be not opened. 
   

@{b}Results:@{ub} @{b}rc@{ub} - Success. 
   @{b}Result@{ub} - The name of the new ARexx port. Can be used with @{b}Address@{ub}. 


@endnode 
@node rxnewsearchinfo "NewSearchInfo" 
@toc ARexxFuncInd

@{b}@{u}NewSearchInfo@{ub}@{uu}


@{b}Name:@{ub} @{b}NewSearchInfo@{ub} - Create a new search info 

@{b}Synopsis:@{ub} @{b}NewSearchInfo Name/K,Fields/S,Formula/K,Var/K@{ub}
   @{b}RC@{ub} = @{i}Success@{ui}
   @{b}Result@{ub} = @{i}Search info name@{ui} 

@{b}Function:@{ub} Creates a new search info. You may specify an own name for the 
   new search info with the argument @{b}Name@{ub}. If a search info with that 
   name should already exist, it will be deleted. If you do not specify 
   the @{b}Name@{ub} argument, this function will create an unique name and return 
   it in @{b}Result@{ub}.  If you want to search for fields with that search info, 
   you will have to use the command @{b}@{"SetSearchField" link rxsetsearchfield}@{ub} to set the fields and 
   patterns to search for. If you want to search by a formula, you have 
   to specify it now with the @{b}Formula@{ub} argument. 

@{b}Arguments:@{ub} @{b}Name@{ub} - Name of the search info to create. If not specified, a 
   unique name will be created. 
   @{b}Field@{ub} - Specify if you want to search by fields. 
   @{b}Formula@{ub} - If you want to search by formula, specify the formula after 
   this keyword. 

@{b}Results:@{ub} @{b}RC@{ub} - Success
   @{b}Result@{ub} - Name of the newly created search info 


@endnode 


@node rxopen "Open" 
@toc ARexxFuncInd

@{b}@{u}Open@{ub}@{uu}


@{b}Name:@{ub} @{b}Open@{ub} - Open a Fiasco database 

@{b}Synopsis:@{ub} @{b}Open File/A,New/S,Iconified/S,Force/S,Var/K@{ub} 
   @{b}RC@{ub} = @{i}Success@{ui} 
   @{b}Result@{ub} = @{i}ARexx Port Name@{ui} 
   

@{b}Function:@{ub} Tries to read a fiasco database. If you specify only the @{b}File@{ub} 
   argument, the data will be loaded into the addressed project. If there 
   are changed data in it, a warning requester will be opened before. If 
   you want to suppress this behaviour, specify the @{b}Force@{ub} argument. If 
   you specify @{b}New@{ub}, Fiasco will load the data into a new project. If you 
   specify @{b}Iconified@{ub}, Fiasco will leave the project window closed.  

@{b}Arguments:@{ub} @{b}Name@{ub} - File name of database to be opened. 
   @{b}New@{ub} - Create a new project.
   @{b}Iconified@{ub} - Do not open the new project window. Only in 
   combination with @{b}New@{ub}. 
   @{b}Force@{ub} - No warnings. 

@{b}Results:@{ub} @{i}RC@{ui} - Success.
   @{i}Result@{ui} - Name of ARexx port of the project the database has 
   been loaded into. Useful with @{b}New@{ub}. 


@endnode 


@node rxopenlistwindow "OpenListWindow" 
@toc ARexxFuncInd

@{b}@{u}OpenListWindow@{ub}@{uu}


@{b}Name:@{ub} @{b}OpenListWindow@{ub} -- Open the list window 

@{b}Synopsis:@{ub} @{b}OpenListWindow@{ub} 

@{b}Function:@{ub} Opens the list window of the currently addressed project. If it 
   is already open, nothing will be done. 

@{b}Arguments:@{ub} None. 

@{b}Results:@{ub} None. 


@endnode 
