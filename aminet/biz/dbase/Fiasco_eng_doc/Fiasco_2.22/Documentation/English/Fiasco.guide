   field has the highest priority.
   @{b}Descending@{ub} - Sort backwards.
   @{b}Index@{ub} - Name of index to be created. Default: 
   @{b}ARexxSort.fidx@{ub}. 

@{b}Results:@{ub} 


@endnode 


@node rxunlockgui "UnlockGUI" 
