 @{" setfreename " Link "setfreename"}                  Change name of FreeX field.

 @{" getnumofrecords " Link "getnumofrecords"}              Retrieve number of records.

 @{" savepath " Link "savepath"}                     Save current database path.

 @{" setlistview " Link "setlistview"}                  Set set of record to displayed.
 @{" setview " Link "setview"}                      Set type of view.
 @{" remark1window " Link "remark1window"}                Open/close Remark1 window,.
 @{" remark2window " Link "remark2window"}                Open/close Remark2 window,.

 @{" exportselection " Link "exportselection"}              Save selection as Database.
 @{" exportascii " Link "exportascii"}                  Export records to ASCII file.
 @{" importselection " Link "importselection"}              Import database.
 @{" importascii " Link "importascii"}                  Import records from ASCII file.

 @{" dialogbox " Link "dialogbox"}                    Open a message dialogbox.
