 @{" setrecorddata " Link "setrecorddata"}                Change record field data.
 @{" duplicaterecord " Link "duplicaterecord"}              Duplicate record.
 @{" removerecord " Link "removerecord"}                 Remove record from memory.
 @{" savetemplate " Link "savetemplate"}                 Save record as template.
 @{" copytoclip " Link "copytoclip"}                   Copy record to clipboard.
 @{" getrecordgroups " Link "getrecordgroups"}              Retrieve record groups information
 @{" setrecordgroups " Link "setrecordgroups"}              Change record groups
 @{" removeduplicaterecords " Link "removeduplicaterecords"}       Remove all redundant records.
 @{" formatrecordstring " Link "formatrecordstring"}           Sprintf-like formatting or record data..

 @{" selectall " Link "selectall"}                    Add all records to selection.
 @{" selectnone " Link "selectnone"}                   Remove all records from selection.
 @{" selecttoggle " Link "selecttoggle"}                 Toggle current record from/to selection.
 @{" selectstring " Link "selectstring"}                 Filter selection by string match.
 @{" selectgroup " Link "selectgroup"}                  Filter selection by group match.
 @{" removeselection " Link "removeselection"}              Remove all selected records from database..

 @{" find " Link "find"}                         Find record by search string.
 @{" sort " Link "sort"}                         Change sort order and direction.

 @{" next " Link "next"}                         Move to next record.
 @{" previous " Link "previous"}                     Move to previous record.
