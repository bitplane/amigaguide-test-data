  @{"FONTSIZE   " link FONTSIZE} Returns the size of a font used by QuickFile
  @{"FOR        " link FOR} Initiates a conditional loop
  @{"FREEINDEX  " link FREEINDEX} Discards a temporary index
  @{"FREEVIEW   " link FREEVIEW} Unloads a view from memory
