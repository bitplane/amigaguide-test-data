///
/// Description - menu
@NODE MENU "Menü"

@{fg highlight}@{B}@{U}Menü@{fg text}@{UB}@{UU}

  @{B}*@{UB}
    @{B}Erneut öffnen@{UB}
      Öffnet des aktuelle Projekt erneut.
    @{B}<Projektname>@{UB}
      Öffnet dieses Projekt.

  @{B}Projekt@{UB}
    @{B}Neu...@{UB}
      @{"Erzeugt ein neues Projekt" LINK NEWPROJECT}.
    @{B}Öffnen...@{UB}
      Öffnet das gewählte Projekt.
    @{B}Schließen@{UB}
      Entfernt das aktuelle Projekt aus dem Speicher.
    @{B}Definieren...@{UB}
      @{"Definiert die Felder der Datenbank" LINK DEFINITION}.
    @{B}Speichern@{UB}
      Speichert das aktuelle Projekt.
    @{B}Speichern als...@{UB}
      Speichert das aktuelle Projekt mit einem neuen Namen.
    @{B}Drucken...@{UB}
      @{"Druckt das Projekt" LINK Printing}.
    @{B}Einstellungen...@{UB}
      @{"Projekt- und Programmeinstellungen" LINK SETTINGS}.
    @{B}Ikonifizieren@{UB}
      Ikonifiziert das Programm.
    @{B}Beenden@{UB}
      Beendet das Programm.

  @{B}Anzeigen@{UB}
    @{B}Hauptanzeige@{UB}
      Die mit dem Projekt gespeicherten Anzeigen.
    @{B}Andere...@{UB}
      Anzeigen laden.
    @{B}Gestaltung@{UB}
      Öffnet das Fenster @{"Anzeigegestaltung" LINK VIEW}.

  @{B}Eintrag@{UB}
    @{B}Rückgängig machen@{UB}
      Macht die letzten Änderungen im Eintrag rückgängig.
    @{B}Wiederholen@{UB}
      Bringt die rückgängig gemachten Änderungen im Eintrag wieder.
    @{B}Ausschneiden@{UB}
      Schneidet den Eintrag aus und setzt ihn in den Puffer.
    @{B}Kopieren@{UB}
      Kopiert den Eintrag in den Puffer.
    @{B}Einfügen@{UB}
      Fügt den Eintrag aus dem Puffer ein.
    @{B}Löschen@{UB}
      Löscht alle Felder.
    @{B}Zurücksetzen@{UB}
      Setzt in allen Feldern die Vorgabewerte.
    @{B}Einfügen@{UB}
      @{B}Einen Eintrag@{UB}
        Einen neuen Eintrag hinzufügen.
      @{B}Viele...@{UB}
        Fügt die gewünschte Anzahl von Einträgen hinzu.
      @{B}Datei...@{UB}
        Fügt die Einträge vom gewählten Projekt hinzu.
    @{B}Löschen@{UB}
      @{B}Aktuellen@{UB}
        Löscht den aktuellen Eintrag.
       @{B}Markierte@{UB}
         Löscht nur die markierten Einträge.
       @{B}Nicht Markierte@{UB}
         Löscht nur die nicht markierten Einträge.
      @{B}Bereich...@{UB}
        Löscht die Einträge des gewählten Bereichs.
      @{B}Alle@{UB}
        Löscht alle Einträge.
    @{B}Markieren@{UB}
      @{B}Aktuellen@{UB}
        Markiert aktuellen Eintrag.
      @{B}Bestimmte...@{UB}
        Markiert durch Suchkriterium bestimmte Felder.
      @{B}Umschalten@{UB}
        Schaltet alle Markierungen um. Nicht markierte Einträge werden markiert,
        und markierte Einträge werden demarkiert.
      @{B}Alle@{UB}
        Markiert alle Einträge.
    @{B}Demarkieren@{UB}
      @{B}Aktuellen@{UB}
        Demarkiert aktuellen Eintrag.
      @{B}Bestimmte...@{UB}
        Demarkiert durch Suchkriterium bestimmte Felder.
      @{B}Umschalten@{UB}
        Schaltet alle Markierungen um. Nicht markierte Einträge werden markiert,
        und markierte Einträge werden demarkiert.
      @{B}Alle@{UB}
        Löscht alle Markierungen.
    @{B}Sortieren@{UB}
      @{B}Nach...@{UB}
        @{"Sortiert die Einträge" LINK SORTING}.
      @{B}Nach <Feldname>@{UB}
        Sortiert nach dem Feldnamen.

  @{B}Feld@{UB}
    @{B}Rückgängig machen@{UB}
      Macht die letzten Änderungen im Feld rückgängig.
    @{B}Ausschneiden@{UB}
      Schneidet den Inhalt des gewählten Feldes aus und setzt ihn in den Puffer.
    @{B}Kopieren@{UB}
      Kopiert den Inhalt des gewählten Feldes in den Puffer.
    @{B}Einfügen@{UB}
      Fügt den Inhalt des Puffers in das gewählte Feld ein.
    @{B}Löschen@{UB}
      Löscht Inhalt des gewählten Feldes.
    @{B}Zurücksetzen@{UB}
      Setzt Vorgabewert ins Feld.
    @{B}Blättern...@{UB}
      Öffnet das Fenster @{"Blättern" LINK BROWSING}.
    @{B}Statistiken...@{UB}
      Öffnet das Fenster @{"Statistiken" LINK STATISTICS}.
    @{B}Sortieren@{UB}
      @{B}A-Z@{UB}
        Sortiert in aufsteigender Folge.
      @{B}Z-A@{UB}
        Sortiert in absteigender Folge.
    @{B}Eigenschaften@{UB}
      @{B}Definition...@{UB}
        Öffnet das Fenster @{"Felddefinition" LINK DEFINITION}.
      @{B}Eigenschaften...@{UB}
        für folgende Feldtypen:
          @{" Standard    " LINK STRINGATRR}
          @{" Betrag      " LINK STRINGATRR}
          @{" Schalter    " LINK BOOLEANATRR}
          @{" Auswahl     " LINK CYCLEATRR}
          @{" Knopf       " LINK BUTTONATRR}
          @{" Text        " LINK TEXTATRR}
      @{B}ARexx...@{UB}
        @{"Setzt ein ARexx-Programm für das Feld" LINK PRGRX}.
      @{B}Feldname...@{UB}
        Öffnet das Fenster @{"Feldname" LINK LABELS}.

  @{B}Navigation@{UB}
    @{B}Suchen...@{UB}
      @{"Sucht Elemente im Projekt" LINK SEARCHING}.
    @{B}Suche Nächsten@{UB}
      Sucht im Projekt vom aktuellen bis letzten Eintrag nach dem zuletzt definierten
      Suchkriterium.
    @{B}Suche Vorherigen@{UB}
      Sucht im Projekt vom aktuellen bis zum ersten Eintrag nach dem zuletzt
      definierten Suchkriterium.
    @{B}Gehe zu...@{UB}
        Springt zum angegebenen Eintrag.
    @{B}Nächster@{UB}
      @{B}Eintrag@{UB}
        Geht zum nächsten Eintrag.
      @{B}Markierter@{UB}
        Geht zum nächsten markierten Eintrag.
      @{B}Nicht Markierter@{UB}
        Geht zum nächsten nicht markierten Eintrag.
    @{B}Vorheriger@{UB}
      @{B}Eintrag@{UB}
        Geht zum vorherigen Eintrag.
      @{B}Markierter@{UB}
        Geht zum vorherigen markierten Eintrag.
      @{B}Nicht Markierter@{UB}
        Geht zum vorherigen nicht markierten Eintrag.
    @{B}Erster@{UB}
      @{B}Eintrag@{UB}
        Geht zum ersten Eintrag.
      @{B}Markierter@{UB}
        Geht zum ersten markierten Eintrag.
      @{B}Nicht Markierter@{UB}
        Geht zum ersten nicht markierten Eintrag.
    @{B}Letzter@{UB}
      @{B}Eintrag@{UB}
        Geht zum letzten Eintrag.
      @{B}Markierter@{UB}
        Geht zum letzten markierten Eintrag.
      @{B}Nicht Markierter@{UB}
        Geht zum letzten nicht markierten Eintrag.

  @{B}ARexx@{UB}
    @{B}Führe Programm aus...@{UB}
      Führt das gewählte ARexx-Programm aus.

@ENDNODE
///
/// Description - shortcuts
@NODE SHORTCUTS "Tastenkürzel"

@{fg highlight}@{B}@{U}Tastenkürzel@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Allgemeine Regel@{fg text}@{UB}
  @{B}[LINKE AMIGA] [<Taste>]@{UB}
    Tastenkürzel für die Felder und Knöpfe.

  @{B}[RECHTE AMIGA] [<Taste>]@{UB}
    Tastenkürzel für das Menü.

  @{B}[HELP]@{UB}
    Öffnet ein Fenster mit der Amigaguide-Dokumentation.

@{fg highlight}@{B}Operationen an Einträgen:@{fg text}@{UB}
  @{B}[Num 9]/[PFEIL LINKS]@{UB}
    Zum vorigen Eintrag.

  @{B}[Num 3]/[PFEIL RECHTS]@{UB}
    Zum nächsten Eintrag.

  @{B}[Num 7]/[Shift] [PFEIL LINKS]@{UB}
    Zum ersten Eintrag.

  @{B}[Num 1]/[Shift] [PFEIL RECHTS]@{UB}
    Zum letzten Eintrag.

  @{B}[Num 5]@{UB}
    Zum angegebenen Eintrag.

  @{B}[RECHTE Alt] [Num 9]/[PFEIL LINKS]@{UB}
    Springt zum vorigen markierten Eintrag.

  @{B}[RECHTE Alt] [Num 3]/[PFEIL RECHTS]@{UB}
    Springt zum nächsten markierten Eintrag.

  @{B}[RECHTE Alt] [Num 7]/[PFEIL LINKS]@{UB}
    Springt zum ersten markierten Eintrag.

  @{B}[RECHTE Alt] [Num 1]/[PFEIL RECHTS]@{UB}
    Springt zum letzten markierten Eintrag.

  @{B}[LINKE Alt] [Num 9]/[PFEIL LINKS]@{UB}
    Springt zum vorigen nicht markierten Eintrag.

  @{B}[LINKE Alt] [Num 3]/[PFEIL RECHTS]@{UB}
    Springt zum nächsten nicht markierten Eintrag.

  @{B}[LINKE Alt] [Num 7]/[PFEIL LINKS]@{UB}
    Springt zum ersten nicht markierten Eintrag.

  @{B}[LINKE Alt] [Num 1]/[PFEIL RECHTS]@{UB}
    Springt zum letzten nicht markierten Eintrag.

  @{B}[Num 0]/[Num +]@{UB}
    Eintrag einfügen.

  @{B}[Shift] [Num 0]/[Num +]@{UB}
    Angegebene Anzahl an Einträgen hinzufügen.

  @{B}[Ctrl] [Num 0]/[Num +]@{UB}
    Einträge aus angegebener Datei einfügen.

  @{B}[Num .]/[Num -]@{UB}
    Aktuellen Eintrag löschen.

  @{B}[RECHTE Alt] [Num .]/[Num -]@{UB}
    Löscht alle markierten Einträge.

  @{B}[LINKE Alt] [Num .]/[Num -]@{UB}
    Löschte alle nicht markierten Einträge.

  @{B}[Ctrl] [Num .]/[Num -]@{UB}
    Löscht alle Einträge.

  @{B}[Shift] [.]/[-]@{UB}
    Einträge im angewählten Bereich löschen.

@{fg highlight}@{B}Feldoperationen:@{fg text}@{UB}
  @{B}[TAB]@{UB}
    Zum nächsten Feld.

  @{B}[Shift] [TAB]@{UB}
    Zum vorigen Feld.

  @{B}[<Feld-Tastenkürzel>]/[Enter]/[LEERTASTE]@{UB}
    Feld aktivieren.

  @{B}[Shift] [<Feld-Tastenkürzel>]/[Enter]/[LEERTASTE]@{UB}
    TEXTFELD            : Öffnet Fenster vorgegebener Werte.

  @{B}[LINKE ALT] [<Feld-Tastenkürzel>]@{UB}
    Setzt Feld als aktuell ohne Aktivierung.

  @{B}[Alt] [Enter]/[LEERTASTE]@{UB}
    Fügt in das Feld den Inhalt des Feldes aus dem vorigen Eintrag ein.

  @{B}[PFEIL RUNTER]@{UB}
    TEXTFELD               : Fügt nächsten Wert aus der vorgegebenen Werteliste ein.
    MEHRZEILIGES TEXTFELD  : Scrollt abwärts.
    AUSWAHLKNOPF           : Setzt nächsten Wert.

  @{B}[PFEIL HOCH]@{UB}
    TEXTFELD               : Fügt vorigen Wert aus der vorgegebenen Werteliste ein.
    MEHRZEILIGES TEXTFELD  : Scrollt aufwärts.
    AUSWAHLKNOPF           : Setzt vorigen Wert.

@{fg highlight}@{B}Wenn das Feld aktiviert ist (Cursor ist drin), dann:@{fg text}@{UB}
  @{B}[Enter]/[TAB]@{UB}
    Zum nächsten Feld.

  @{B}[Shift] [Enter]/[TAB]@{UB}
    Zum vorigen Feld.

  @{B}[LINKE AMIGA] [Q]@{UB}
    Bringt den letzten Inhalt des Feldes wieder (RÜCKGÄNGIG MACHEN).

  @{B}[LINKE AMIGA] [X]@{UB}
    Inhalt des Feldes löschen.

  @{B}[Shift] [PFEIL RECHTS]@{UB}
    Cursor zum Ende des Textes im Feld.

  @{B}[Shift] [PFEIL LINKS]@{UB}
    Cursor zum Beginn des Textes im Feld.

  @{B}[Shift] [BACKSPACE]@{UB}
    Alle Zeichen vom Cursor zum Beginn des Textes löschen.

  @{B}[Shift] [Del]@{UB}
    Alle Zeichen vom Cursor zum Ende des Textes löschen.



@{fg highlight}@{B}Maus:@{fg text}@{UB}
  @{B}[<Doppelklick nahe dem Feldnamen>]@{UB}
    @{"Anzeige" LINK BROWSING} dieses Feldes.

  @{B}[Shift] [<Doppelklick nahe dem Feldnamen>]@{UB}
    @{"Bearbeitung der Felddefinition" LINK DEFINITION}.

  @{B}[Alt] [<Doppelklick nahe dem Feldnamen>]@{UB}
    @{"Beabeitung der Feldeigenschaften" LINK OPTIONS}.

  @{B}[Ctrl] [<Doppelklick nahe dem Feldnamen>]@{UB}
    @{"Bearbeiten des Feldnamens" LINK LABELS}.

  @{B}[Ctrl] [Shift] [<Doppelklick nahe dem Feldnamen>]@{UB}
    Verbergen des Feldes.

  @{B}[<Rechte Maustaste auf Feld>]@{UB}
    Öffnet Kontextmenü.

  @{B}[Shift] [<Rechte Maustaste auf Feld>]@{UB}
    Öffnet Kontextmenü für Bearbeitung des Feldinhalts.

  @{B}[Alt] [<Rechte Maustaste auf Feld>]@{UB}
    Setzt Feld aktuell ohne Aktivierung.

  @{" Mehrzeilige Felder " LINK MULTILINE}

@ENDNODE
///
/// Description - multiline fields
@NODE MULTILINE "Mehrzeilige Felder"

@{fg highlight}@{B}@{U}Mehrzeilige Felder@{fg text}@{UB}@{UU}

Man kann Text zum Ausschneiden, Kopieren oder Löschen frei markieren.
Beim Drücken irgendeiner alphanumerischen Taste wird der markierte 
Text durch dieses Zeichen ersetzt. Das Drücken einer Pfeiltaste bringt
den Cursor an den Beginn oder das Ende des markierten Textes.

Falls ein Teil des Textes markiert werden soll, den Cursor auf den
Beginn der gewünschten Markierung setzen, SHIFT drücken und mit der
Maus auf das gewünschte Ende der Markierung klicken.

Ansonsten gibt es noch die Möglichkeit, ein zu markierendes Wort
doppelzuklicken. Falls ein Leerzeichen zwischen zwei Wörtern betroffen
ist, werden alle Leerzeichen zwischen diesen Wörtern markiert.

@{fg highlight}@{B}Tastenkürzel:@{fg text}@{UB}
  @{B}[TAB]@{UB}
    Aktiviert nächstes Feld.

  @{B}[Shift] [TAB]@{UB}
    Aktiviert voriges Feld.

  @{B}[Shift] [PFEIL HOCH]@{UB}
    Cursor an den Anfang der aktuellen oder (falls der Cursor sich
    bereits dort befindet) der vorigen Seite.
    
  @{B}[Shift] [PFEIL RUNTER]@{UB}
    Cursor an das Ende der aktuellen oder (falls der Cursor sich 
    bereits dort befindet) der nächsten Seite.

  @{B}[Ctrl]/[Shift] [PFEIL RECHTS]@{UB}
    Cursor an das Ende der aktuellen Zeile.

  @{B}[Ctrl]/[Shift] [PFEIL LINKS]@{UB}
    Cursor an den Anfang der aktuellen Zeile.

  @{B}[Shift] [BACKSPACE]@{UB}
    Alle Zeichen vom Cursor zum Beginn der Zeile löschen.

  @{B}[Shift] [Del]@{UB}
    Alle Zeichen vom Cursor zum Ende der Zeile löschen.

  @{B}[Ctrl] [PFEIL HOCH]@{UB}
    Cursor in die erste Zeile des Textes.

  @{B}[Ctrl] [PFEIL RUNTER]@{UB}
    Cursor in die letzte Zeile des Textes.

  @{B}[Alt] [PFEIL RECHTS]@{UB}
    Cursor zum Beginn des nächsten Wortes.

  @{B}[Alt] [PFEIL LINKS]@{UB}
    Cursor zum Beginn des vorigen Wortes.

  @{B}[Alt] [PFEIL HOCH]@{UB}
    Cursor zum Textanfang.

  @{B}[Alt] [PFEIL RUNTER]@{UB}
    Cursor zum Textende.

  @{B}[Alt] [BACKSPACE]@{UB}
    Text vom Cursor zum Wortanfang löschen.

  @{B}[Alt] [Del]@{UB}
    Text vom Cursor zum Wortende löschen.

  @{B}CTRL [X]@{UB}
    Aktuelle Zeile löschen.

  @{B}[RECHTE AMIGA] [E]@{UB}
    Text im Feld komplett löschen.

  @{B}[RECHTE AMIGA] [V]@{UB}
    Text aus der Zwischenablage an der Cursorposition einfügen.

  @{B}[RECHTE AMIGA] [A]@{UB}
    Ganzen Text markieren.

@{fg highlight}@{B}Wenn der Text markiert ist:@{fg text}@{UB}
  @{B}[BACKSPACE]@{UB}
    Ganzen markierten Text löschen.

  @{B}[Del]@{UB}
    Ganzen markierten Text löschen.

  @{B}[RECHTE AMIGA] [X]@{UB}
    Ganzen markierten Text ausschneiden (in die Zwischenablage).

  @{B}[RECHTE AMIGA] [C]@{UB}
    Ganzen markierten Text in die Zwischenablage kopieren.

  @{B}[RECHTE AMIGA] [V]@{UB}
    Markierten Text mit Inhalt der Zwischenablage ersetzen.

  @{B}[<beliebige alphanumerische Taste>]@{UB}
    Markierten Text durch das gedrückte Zeichen ersetzen.

@ENDNODE
///
/// Description - running
@NODE RUNNING "Start"

@{fg highlight}@{B}@{U}Programm starten@{fg text}@{UB}@{UU}

Auf der Workbench wird XBaze durch Doppelklick auf das Piktogramm gestartet bzw.
von der Shell. Man kann @{"Argumente (in der Shell) oder Tooltypes" LINK TOOLTYPES} angeben.

@ENDNODE
///
/// Description - tooltypes
@NODE TOOLTYPES "Argumente und Tooltypes"

@{fg highlight}@{B}@{U}Argumente und Tooltypes@{fg text}@{UB}@{UU}

@{B}FILE@{UB}
  Name der automatisch zu ladenden Datei (nur Shell).

@{B}PUBSCREEN@{UB}
  Name des öffentlichen Bildschirms, auf dem das Hauptfenster von
  XBaze geöffnet wird. Falls der Bildschirm nicht gefunden wird,
  benutzt XBaze die Workbench.

@{B}FONT@{UB}
  Zu benutzender Zeichensatz, Syntax: <Schriftname/Schriftgröße>

@{B}NOICONS@{UB}
  Für Projekte werden keine Piktogramme abgespeichert.

@{B}LOCALESORT@{UB}
  Mit dieser Option werden alle Vergleiche/Sortierungen mittels der
  locale.library durchgeführt. In der englischen oder polnischen
  Sprache gibt es diese Option nicht.

@{B}IGNSAVEDWINPOS@{UB}
  Das Programm ignoriert die gespeicherten Fensterpositionen.

@{B}DATADIR@{UB}
  Verzeichnis, welches die im Menü "*" dargestellten Dateien enthält.
  Damit wird das Öffnen häufig zu bearbeitender Dateien erleichtert.

@{B}VIEWFILE@{UB}
  Datei mit einer Anzeige (nur Shell). Der Parameter FILE muss
  angegeben werden.

@{B}STARTICONIFIED@{UB}
  Das Programm startet im ikonifizierten Zustand.

@{B}PROGRESSINDICATOR@{UB}
  Die Verlaufsanzeige wird aktiviert.

@{B}USESCREENFONTINREQS@{UB}
  Die ausgewählte Schrift wird nur im Hauptfenster verwandt.

@{B}STATPRECISION@{UB}
  Als Attribut wird hier die Anzahl der in statistischen Operationen zu
  verwendenden Nachkommastellen verwandt.

@{B}LEFTTOOLBAR@{UB}
  Die Werkzeugleiste wird am linken Rand platziert, anderenfalls sitzt
  sie am unteren Rand.

@{B}NOSIZEABLE@{UB}
  Das Hauptfenster hat kein Größensymbol.

@{B}NONAVBUTTS@{UB}
  Die Knöpfe zum Navigieren werden nicht an den unteren Rand platziert.

@{B}3DLOOK@{UB}
  Die Navigationsknöpfe haben ein 3D-Aussehen.

Man kann die Einstellungen auch im Hauptprogramm unter
@{"Projekt|Einstellungen..." LINK PRGSETS} ändern.

@ENDNODE
///
/// Field - definitions
@NODE DEFINITION "Fenster Felddefinition"

@{fg highlight}@{B}@{U}Fenster Felddefinition@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Hauptfenster:
    @{B}Menü:@{UB}          Projekt|Neu...
                   Feld|Eigenschaften|Definition...
    @{B}Popupmenü:@{UB}     Eigenschaften|Definition...
    @{B}Tastenkürzel:@{UB}  [Shift] [<Doppelklick nahe dem Feldnamen>]

  @{"Anzeigegestaltung:" LINK VIEW}
    @{B}Menü:@{UB}             Feld|Definition...
    @{B}Popupmenü:@{UB}        Definition...
    @{B}Tastenkürzel:@{UB}     [<Doppelklick auf dem Feld>]

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Die Standardelemente der Datenbank sind Felder und Einträge. In
  diesem Fenster kann man die Felder bearbeiten, d.h. man kann
  Felder erstellen, verändern oder löschen.

@{fg highlight}@{B}Hinweise:@{fg text}@{UB}
  In einem Projekt müssen ein oder mehrere sichtbare speicherbare Felder
  existieren.

@{fg highlight}@{B}Tastenkürzel:@{fg text}@{UB}
  @{B}[RECHTE AMIGA] [Del]@{UB}
    Feld löschen.

  @{B}[Alt] [PFEIL HOCH]/[PFEIL RUNTER]@{UB}
    Feld eine Listenposition hoch/runter.

  @{B}[PFEIL HOCH]/[PFEIL RUNTER]@{UB}
    Markierung eine Position hoch/runter.

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Feld@{UB}
    In dieser Box befindet sich die Felderliste. Man kann hier jedes
    Feld zur Bearbeitung auswählen, z.B. zur Namensänderung, Löschen
    oder Attributänderung. Das Feld unter der Box dient der Namens-
    eingabe. Ein Feldname kann mehrmals vorkommen, dies könnte jedoch
    die Handhabung von ARexx-Skripten erschweren. Der "zweite" Roll-
    balken dieser Box dient dem Ändern der Reihenfolge in der Liste.

  @{B}Hinzufügen@{UB}
    Neues Feld hinzufügen.

  @{B}Löschen@{UB}
    Feld von der Liste löschen.

  @{B}Typ@{UB}
    @{"Feldtyp" LINK TYPES} auswählen.

  @{B}Feldname...@{UB}
    @{"Feldname" LINK LABELS} setzen.

  @{B}Eigenschaften...@{UB}
    für Feldtyp:
      @{" Standard    " LINK STRINGATRR}
      @{" Betrag      " LINK STRINGATRR}
      @{" Schalter    " LINK BOOLEANATRR}
      @{" Auswahl     " LINK CYCLEATRR}
      @{" Knopf       " LINK BUTTONATRR}
      @{" Text        " LINK TEXTATRR}

  @{B}ARexx...@{UB}
    @{"ARexx-Programm" LINK PRGRX} setzen

  @{B}Versteckt@{UB}
    Damit wird ein Feld unsichtbar, aber man kann trotzdem danach sortieren
    oder suchen lassen.

  @{B}Speicherbar@{UB}
    Hier kann man einstellen, ob der Inhalt des Feldes im angegebenen
    Eintrag gespeichert wird oder nicht. Ein Deaktivieren dieser Option
    wäre sinnvoll in ARexx-Skripten, wo sich der Feldinhalt nicht mit
    dem Eintrag ändert.

  @{B}Neue Zeile@{UB}
    Feld wird in neuer Zeile platziert.

@ENDNODE
///
/// Field - types
@NODE TYPES "Feldtypen"

@{fg highlight}@{B}@{U}Feldtypen@{fg text}@{UB}@{UU}

@{B}Standard@{UB}
  Man kann in diesen Feldern alphanumerische Zeichen verwenden. Es sind
  mehrzeilige Felder möglich sowie Vorgabewerte, die in einer Liste
  ausgesucht werden können, die sich rechts neben dem Feld befindet.
  Man kann den Startwert des Feldes angeben, welcher automatisch bei
  einem neuen Eintrag verwendet wird und man kann einen Standardwert
  angeben, welcher benutzt wird, wenn das Feld leergelassen wird. Hier
  kann man auch Variable nutzen, so z.B.: das aktuelle Datum, Zeit usw.

@{B}Betrag@{UB}
  Wie oben, aber das Feld wird beim Sortieren als Betrag angesehen.

@{B}Schalter@{UB}
  Erscheint als SCHALTER. Das Feld kann zwei Zustände annehmen. Man
  kann für FALSCH und WAHR verschiedenen Text definieren. Falls keiner
  angegeben wird, benutzt das Programm den vorgegebenen (TRUE, FALSE).
  Man kann den Startwert vorgeben.

@{B}Auswahl@{UB}
  Erscheint als Auswahlknopf. Man kann eine Position der Liste auswählen.
  Der Startwert kann angegeben werden.

@{B}Knopf@{UB}
  Dies ist ein einfacher Knopf, mit dem man ein anderes Programm starten,
  ein Bild anzeigen oder Musik spielen kann.

@{B}Text@{UB}
  Feld kann nur gelesen werden. Dank dem Variablensystem kann man hier
  z.B. den Zeitpunkt des Eintrags, der Projekterzeugung oder viele andere
  Dinge zeigen. Der Text in diesem Feld kann nur über den ARexx-Port
  verändert werden.

@ENDNODE
///
/// Field - labels
@NODE LABELS "Feldname"

@{fg highlight}@{B}@{U}Feldname@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  @{"Fenster Felddefinition:" LINK DEFINITION}
    @{B}Knopf:@{UB}         Feldname...

  Hauptfenster:
    @{B}Menü:@{UB}          Feld|Eigenschaften|Feldname...
    @{B}Popupmenü:@{UB}     Eigenschaften|Feldname...
    @{B}Tastenkürzel:@{UB}  [Ctrl] [<Doppelklick nahe dem Feldnamen>]

  @{"Anzeigegestaltung:" LINK VIEW}
    @{B}Menü:@{UB}          Feld|Feldname...
    @{B}Popupmenü:@{UB}     Feldname...
    @{B}Tastenkürzel:@{UB}  [Ctrl] [<Doppelklick auf dem Feld>]

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Hier kann man den Feldnamen sowie dessen Attribute festlegen. Der
  Name kann hervorgehoben, normal oder nicht dargestellt sein. Man
  kann dies mit dem Auswahlknopf festlegen. Im Textfeld darunter
  kann man die Bezeichnung des Feldnamens eintragen. Die vorgegebene
  Bezeichnung ist der echte Feldname.
      Normal             - Farbe des Namens ist schwarz
      Hervorgehoben      - Farbe des Namens ist weiß
      Nicht dargestellt  - Name wird verborgen

@{fg highlight}@{B}Knöpfe:@{fg text}@{UB}
  @{B}Fett@{UB}
    Der Name wird fett geschrieben dargestellt.

  @{B}Kursiv@{UB}
    Der Name wird kursiv geschrieben dargestellt.

  @{B}Unterstrichen@{UB}
    Der Name wird unterstrichen dargestellt.

@ENDNODE
///
/// Field - attributes
@node OPTIONS "Feldeigenschaften"

@{fg highlight}@{B}@{U}Feldeigenschaften@{fg text}@{UB}@{UU}

  @{fg highlight}@{B}Eigenschaften für Feldtyp:@{UB}@{fg text}
      @{" Standard    " LINK STRINGATRR}
      @{" Betrag      " LINK STRINGATRR}
      @{" Schalter    " LINK BOOLEANATRR}
      @{" Auswahl     " LINK CYCLEATRR}
      @{" Knopf       " LINK BUTTONATRR}
      @{" Text        " LINK TEXTATRR}

@endnode
///
/// Attributes - STRING and AMOUNT
@NODE STRINGATRR "Eigenschaften für Feldtypen Standard und Betrag"

@{fg highlight}@{B}@{U}Eigenschaften für Feldtypen Standard und Betrag@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  @{"Fenster Felddefinition:" LINK DEFINITION}
    @{B}Knopf:@{UB}         Eigenschaften...

  Hauptfenster:
    @{B}Menü:@{UB}          Feld|Eigenschaften|Eigenschaften...
    @{B}Popupmenü:@{UB}     Eigenschaften|Eigenschaften...
    @{B}Tastenkürzel:@{UB}  [Alt] [<Doppelklick nahe dem Feldnamen>]

  @{"Anzeigegestaltung:" LINK VIEW}
    @{B}Menü:@{UB}          Feld|Eigenschaften...
    @{B}Popupmenü:@{UB}     Eigenschaften...
    @{B}Tastenkürzel:@{UB}  [Alt] [<Doppelklick auf dem Feld>]

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Bearbeitung der zusätzlichen Feldeigenschaften.

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Ausrichtung@{UB}
    Festlegen der Textausrichtung im Feld.

  @{B}Max Zeichen@{UB}
    Maximale Anzahl an Zeichen pro Feld.

  @{B}Größe@{UB}
    Feldbreite in Zeichen.

  @{B}Zeilenanzahl@{UB}
    Anzahl an Zeilen.

  @{B}Tastenkürzel@{UB}
    Tastenkürzel zum Aktivieren des angegebenen Feldes.

  @{B}Startwert@{UB}
    Dieser Wert wird automatisch bei allen neuen Einträgen gesetzt.
    Man kann auch @{"Variablen" LINK VAR} nutzen.

  @{B}Standardwert@{UB}
    Dieser Wert wird im Feld gesetzt, wenn es freigelassen wird.
    Es können auch @{"Variablen" LINK VAR} benutzt werden.

  @{B}Zulässige Zeichen@{UB}
    Die hier eingetragenen Zeichen werden von diesem Feld akzeptiert.

  @{B}Unzulässige Zeichen@{UB}
    Die hier eingetragenen Zeichen werden von diesem Feld nicht akzeptiert.

  @{B}Vorgabewerte...@{UB}
    @{"Vorgabewerte bearbeiten" LINK PREDEF}

  @{B}Ersetzmodus@{UB}
    Ersetzmodus aktivieren.

  @{B}URL-Adresse@{UB}
    Zu diesem Feld wird ein Knopf hinzugefügt, der einen Webbrowser mit
    dem Feldwert als URL-Adresse startet.

@ENDNODE
///
/// Attributes - predefined values
@NODE PREDEF "Vorgabewerte"

@{fg highlight}@{B}@{U}Vorgabewerte@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  @{"Fenster Feldeigenschaften:" LINK STRINGATRR}
    Knopf: Vorgabewerte...

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Eine Liste der häufig für dieses Feld benötigten Werte. Zwischen diesen
  Werten kann man auswählen, wenn man den Knopf "«" rechts vom Feld drückt.
  
@{fg highlight}@{B}Tastenkürzel:@{fg text}@{UB}
  @{B}[RECHTE AMIGA] [Del]@{UB}
    Entfernt ein Element

  @{B}[Alt] [PFEIL HOCH]/[PFEIL RUNTER]@{UB}
    Element wird eine Position hoch-/runtergesetzt

  @{B}[PFEIL HOCH]/[PFEIL RUNTER]@{UB}
    Cursor eine Position hoch/runter

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Wert@{UB}
    In diesem Feld stehen alle Vorgabewerte. Man kann jeden anwählen, um
    ihn zu löschen bzw. zu verändern. Ändern kann man in dem Feld unter
    der Liste. Der rechte "Rollbalken" dient dem Ändern der Reihenfolge
    der Listeneinträge.

  @{B}Hinzufügen@{UB}
    Ein neues Element in die Liste einfügen.

  @{B}Löschen@{UB}
    Ausgewähltes Element wird gelöscht.

@ENDNODE
///
/// Attributes - CYCLE
@NODE CYCLEATRR "Eigenschaften für Feldtyp Auswahl"

@{fg highlight}@{B}@{U}Eigenschaften für Feldtyp Auswahl@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  @{"Fenster Neues Projekt:" LINK DEFINITION}
    @{B}Knopf:@{UB}         Eigenschaften...

  Hauptfenster:
    @{B}Menü:@{UB}          Feld|Eigenschaften|Eigenschaften...
    @{B}Popupmenü:@{UB}     Eigenschaften|Eigenschaften...
    @{B}Tastenkürzel:@{UB}  [Alt] [<Doppelklick nahe dem Feldnamen>]

  @{"Anzeigengestaltung:" LINK VIEW}
    @{B}Menü:@{UB}          Feld|Eigenschaften...
    @{B}Popupmenü:@{UB}     Eigenschaften...
    @{B}Tastenkürzel:@{UB}  [Alt] [<Doppelklick auf dem Feld>]

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  In diesem Fenster kann man die Feldeigenschaften einstellen und eine
  Liste der auszuwählenden Werte festlegen.

@{fg highlight}@{B}Tastenkürzel:@{fg text}@{UB}
  @{B}[RECHTE AMIGA] [Del]@{UB}
    Element entfernen

  @{B}[Alt] [PFEIL HOCH]/[PFEIL RUNTER]@{UB}
    Element wird eine Position hoch-/runtergesetzt

  @{B}[PFEIL HOCH]/[PFEIL RUNTER]@{UB}
    Cursor eine Position hoch/runter

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Wert@{UB}
    In diesem Feld stehen alle Vorgabewerte. Man kann jeden anwählen, um
    ihn zu löschen bzw. zu verändern. Ändern kann man in dem Feld unter
    der Liste. Der rechte "Rollbalken" dient dem Ändern der Reihenfolge
    der Listeneinträge.

  @{B}Hinzufügen@{UB}
    Ein neues Element in die Liste einfügen.

  @{B}Löschen@{UB}
    Ausgewähltes Element wird gelöscht.

  @{B}Größe@{UB}
    Breite des Feldes in Zeichen

  @{B}Tastenkürzel@{UB}
    Tastenkürzel zum Aktivieren des Feldes.

@ENDNODE
///
/// Attributes - BOOLEAN
@NODE BOOLEANATRR "Eigenschaften für Feldtyp Schalter"

@{fg highlight}@{B}@{U}Eigenschaften für Feldtyp Schalter@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  @{"Fenster Neues Projekt:" LINK DEFINITION}
    @{B}Knopf:@{UB}         Eigenschaften...

  Hauptfenster:
    @{B}Menü:@{UB}          Feld|Eigenschaften|Eigenschaften...
    @{B}Popupmenü:@{UB}     Eigenschaften|Eigenschaften...
    @{B}Tastenkürzel:@{UB}  [Alt] [<Doppelklick nahe dem Feldnamen>]

  @{"Anzeigengestaltung:" LINK VIEW}
    @{B}Menü:@{UB}          Feld|Eigenschaften...
    @{B}Popupmenü:@{UB}     Eigenschaften...
    @{B}Tastenkürzel:@{UB}  [Alt] [<Doppelklick auf dem Feld>]

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  In diesem Fenster kann man die Feldeigenschaften festlegen.

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Wahr@{UB}
    Text für den Status "True", d.h. der Schalter ist aktiviert.

  @{B}Falsch@{UB}
    Text für den Status "False", d.h. der Schalter ist nicht aktiviert.

  @{B}Tastenkürzel@{UB}
    Tastenkürzel zum Aktivieren des Feldes.

  @{B}Startwert@{UB}
    Wert für das Feld in einem neuen Eintrag.

@ENDNODE
///
/// Attributes - BUTTON
@NODE BUTTONATRR "Eigenschaften für Feldtyp Knopf"

@{fg highlight}@{B}@{U}Eigenschaften für Feldtyp Knopf@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  @{"Fenster Neues Projekt:" LINK DEFINITION}
    @{B}Knopf@{UB}:         Eigenschaften...

  Hauptfenster:
    @{B}Menü:@{UB}          Feld|Eigenschaften|Eigenschaften...
    @{B}Popupmenü:@{UB}     Eigenschaften|Eigenschaften...
    @{B}Tastenkürzel:@{UB}  [Alt] [<Doppelklick nahe dem Feldnamen>]

  @{"Anzeigengestaltung:" LINK VIEW}
    @{B}Menü:@{UB}          Feld|Eigenschaften...
    @{B}Popupmenü:@{UB}     Eigenschaften...
    @{B}Tastenkürzel:@{UB}  [Alt] [<Doppelklick auf dem Feld>]

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  In diesem Feld werden keine Werte abgelegt. Es dient nur dem Starten
  anderer Programme.

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Befehl@{UB}
    Name des zu startenden Programms. Man kann @{"Variablen" LINK VAR} nutzen,
    so dass man dem Programm Argumente übergeben kann.

  @{B}Konsole@{UB}
    Konsole, in der alle Rückgabewerte des Programms angezeigt werden.

  @{B}Größe@{UB}
    Breite des Feldes in Zeichen.

  @{B}Tastenkürzel@{UB}
    Tastenkürzel zum Aktivieren des Feldes.

@ENDNODE
///
/// Attributes - TEXT
@NODE TEXTATRR "Eigenschaften für Feldtyp Text"

@{fg highlight}@{B}@{U}Eigenschaften für Feldtyp Text@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  @{"Fenster Neues Projekt:" LINK DEFINITION}
    @{B}Knopf@{UB}:         Eigenschaften...

  Hauptfenster:
    @{B}Menü:@{UB}          Feld|Eigenschaften|Eigenschaften...
    @{B}Popupmenü:@{UB}     Eigenschaften|Eigenschaften...
    @{B}Tastenkürzel:@{UB}  [Alt] [<Doppelklick nahe dem Feldnamen>]

  @{"Anzeigengestaltung:" LINK VIEW}
    @{B}Menü:@{UB}          Feld|Eigenschaften...
    @{B}Popupmenü:@{UB}     Eigenschaften...
    @{B}Tastenkürzel:@{UB}  [Alt] [<Doppelklick auf dem Feld>]

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Dieses Feld gibt nur Informationen aus. Der Inhalt kann nur mittels
  eines ARexx-Programms verändert werden.
  
@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Text@{UB}
    Darzustellender Text. Man kann @{"Variablen" LINK VAR} nutzen.

  @{B}Größe@{UB}
    Breite des Feldes in Zeichen.

  @{B}Ausrichtung@{UB}
    Einstellen der Textausrichtung des Feldes.

  @{B}Kein Rahmen@{UB}
    Wenn aktiviert, dann erscheint das Feld ohne Rahmen.

@ENDNODE
///
/// Attributes - variable
@NODE VAR "Variable"

@{fg highlight}@{B}@{U}Variable@{fg text}@{UB}@{UU}

  Variable ist eine Zeichenkette beginnend mit "%". Die Variable
  steht für einen eigentlichen Wert.
  In den Textfeldern, wo man Variablen nutzen kann, befindet sich rechts
  ein "«" Knopf, welcher eine Liste der möglichen Variablen mit näheren
  Erläuterungen aufruft.

@ENDNODE
///
/// Attributes - ARexx program
@NODE PRGRX "ARexx-Programm für Felder"

@{fg highlight}@{B}@{U}ARexx-Programm für Felder@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  @{"Fenster Neues Projekt:" LINK DEFINITION}
    @{B}Knopf:@{UB}    ARexx...

  Hauptfenster:
    @{B}Menü:@{UB}      Feld|Eigenschaften|ARexx...
    @{B}Popupmenü:@{UB} Eigenschaften|ARexx...

  @{"Anzeigengestaltung:" LINK VIEW}
    @{B}Menü:@{UB}      Feld|ARexx...
    @{B}Popupmenü:@{UB} ARexx...
    @{B}Tastenkürzel:@{UB}  [Shift] [<Doppelklick auf dem Feld>]

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Das ARexx-Program startet, wenn ein Wert für das Feld festgelegt wird.

@{fg highlight}@{B}Felder:@{fg text}@{UB}
  @{B}Programm@{UB}
    Zu startendes Programm.

  @{B}Konsole@{UB}
    Konsole, in der die Rückgabewerte des Programms angezeigt werden.

@ENDNODE
///
/// Description - design window
@NODE VIEW "Anzeigengestaltung"

@{fg highlight}@{B}@{U}Anzeigengestaltung@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Hauptfenster:
    @{B}Menü:@{UB}      Anzeigen|Gestaltung...

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Man kann die Anzeige des Hauptfensters mit Maus und Tastatur ändern.
  Man kann die Größe der Felder mittels der Maus ändern, Ecke anfassen
  und ziehen. Man kann ebenso die Position der Felder ändern.


@{fg highlight}@{B}Tastenkürzel:@{fg text}@{UB}
  @{B}[PFEIL RECHTS]/[PFEIL LINKS]@{UB}
    Cursor ins nächste/vorige Feld

  @{B}[PFEIL HOCH]/[PFEIL RUNTER]@{UB}
    Cursor in die nächste/vorige Zeile

  @{B}[Enter]@{UB}
    abhängig von der Cursorposition, wird das Feld in eine neue Zeile
    geschoben oder eine Leerzeile eingefügt.

  @{B}[TAB]@{UB}
    Einfügen eines TAB zwischen zwei Zeilen

  @{B}[<unterstrichenes Zeichen>]@{UB}
    Cursor wird in das entsprechende Feld gesetzt.

  @{B}[Shift] [<unterstrichenes Zeichen>]@{UB}
    @{"Felddefinition" LINK DEFINITION}

  @{B}[Ctrl] [Shift] [<unterstrichenes Zeichen>]@{UB}
    verbirgt/zeigt das Feld

  @{B}[<Doppelklick auf Feld>]@{UB}
    @{"Felddefinition" LINK DEFINITION}

  @{B}[Alt] [<Doppelklick auf dem Feld>]@{UB}
    @{"Bearbeiten der Feldeigenschaften" LINK OPCJE}

  @{B}[Ctrl] [<Doppelklick auf dem Feld>]@{UB}
    @{"Bearbeiten des Feldnamens" LINK LABELS}

  @{B}[Ctrl] [Shift] [<Doppelklick auf dem Feld>]@{UB}
    verbirgt/zeigt das Feld

  @{B}[Ctrl] [Shift] [Enter]@{UB}
    zeigt alle Felder

@{fg highlight}@{B}Menü:@{fg text}@{UB}
  @{B}Anzeigen@{UB}
    @{B}Wiederherstellen@{UB}
      Stellt die Standardgestaltung der Anzeige wieder her.
    @{B}Öffnen...@{UB}
      Lädt Anzeige.
    @{B}Speichern...@{UB}
      Speichert Anzeige.
    @{B}TABulatorgröße@{UB}
      Setzt die TABulatorgröße.
    @{B}Verwenden@{UB}
      Akzeptiert alle Änderungen und kehrt ins Hauptfenster zurück.
    @{B}Abbrechen@{UB}
      Verwirft alle Änderungen und kehrt ins Hauptfenster zurück.

  @{B}Feld@{UB}
    @{B}Ausschneiden@{UB}
      Feld in Puffer ausschneiden.
    @{B}>Kopieren@{UB}
      Feld in Puffer kopieren.
    @{B}Einfügen@{UB}
      Feld aus Puffer einfügen.
    @{B}Einfügen...@{UB}
      Neues Feld einfügen.
    @{B}Löschen@{UB}
      Feld entfernen.
    @{B}Definition...@{UB}
      @{"Felddefinition" LINK DEFINITION}.
    @{B}Feldname...@{UB}
      @{"Bearbeiten des Feldnamens" LINK LABELS}.
    @{B}Eigenschaften...@{UB}
      für Feldtypen:
        @{" Standard    " LINK STRINGATRR}
        @{" Betrag      " LINK STRINGATRR}
        @{" Schalter    " LINK BOOLEANATRR}
        @{" Auswahl     " LINK CYCLEATRR}
        @{" Knopf       " LINK BUTTONATRR}
        @{" Text        " LINK TEXTATRR}
    @{B}ARexx...@{UB}
      Setzt das @{"ARexx-Programm" LINK PRGRX} für das Feld.

@ENDNODE
///
/// Description - printing
@NODE PRINTING "Drucken"

@{fg highlight}@{B}@{U}Drucken@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Heuptfenster:
    @{B}Menü:@{UB}      Projekt|Drucken...

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Hiermit kann man das aktuelle Projekt in verschiedenen Formaten
  entweder drucken oder exportieren.

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Ausgabe an@{UB}
    Hier kann man das Ausgabegerät für den Druck angeben. Der Knopf
    rechts lässt die Ausgabedatei auswählen.

  @{B}Drucken@{UB}
    Welche Einträge sollen gedruckt werden? Der Knopf rechts lässt eine
    nähere Auswahl zu (einen Bereich, nur markierte oder nur nicht
    markierte).

  @{B}Format@{UB}
    Festlegen des Ausgabeformats.

  @{B}Kopf@{UB}
    Name der Datei, die vor den Einträgen gedruckt wird.

  @{B}Fuß@{UB}
    Name der Datei, die nach den Einträgen gedruckt wird.

  @{B}Kopf d. Eintrags@{UB}
    Text, welcher vor jedem Eintrag gedruckt wird. Man kann
    @{"Variablen" LINK VAR} nutzen.

  @{B}Fuß d. Eintrags@{UB}
    Text, welcher vor jedem Eintrag gedruckt wird. Man kann
    @{"Variablen" LINK VAR} nutzen.

  @{B}Drucke versteckte Felder@{UB}
    Druckt auch die versteckten Felder.

  @{B}Druck@{UB}
    Druck beginnt.

@ENDNODE
///
/// Description - searching
@NODE SEARCHING "Einträge suchen"

@{fg highlight}@{B}@{U}Einträge suchen@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Hauptfenster:
    @{B}Menü:@{UB}      Suchen|Suchen...
    @{B}Popupmenü:@{UB} Suchen...

  Wenn man diese Option im Menü oder durch Tastenkürzel mit gedrückter
  [Shift]-Taste auswählt, öffnet sich das Fenster "Suche Einträge"
  ohne irgendwelche Voreinstellungen für die Suchkriterien.

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Für alle Feldtypen können Suchmuster angegeben werden. Alle AmigaDOS
  Muster sind erlaubt (außer bei Betragsfeldern), z.B.: das Muster
  (#?ski|#?ska) spricht auf alle Wörter mit den Endungen "ski" oder
  "ska" an. Näheres findet man im AmigaDOS-Handbuch.

  Bei Auswahl- oder Schalterfeldern ist die Eingabe des gesuchten Textes
  nicht notwendig. Man kann hierfür den "«" Knopf rechts neben dem
  Textfeld nutzen und den gewünschten Wert auswählen.

  Falls man mit denselben Werten weitersuchen möchte, sollte man aus
  dem Menü, "Suchen|Suche Nächsten" oder "Suchen|Suche Vorherigen"
  benutzen. Die Suche beginnt beim aktuellen Eintrag, mit einem Unter-
  schied: im ersten Fall wird vom aktuellen bis zum letzten Eintrag
  gesucht, im zweiten Fall vom aktuellen bis zum ersten Eintrag.

@{fg highlight}@{B}Tastenkürzel:@{fg text}@{UB}
  @{B}[Enter]@{UB}
     Startet Suche.

  @{B}[Shift] [Enter]@{UB}
    Startet Suche. Alle zutreffenden Einträge werden im Fenster
    @{"Blättern" LINK BROWSING} aufgelistet.

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Kriterien@{UB}
    In diesem Feld stehen alle Felder, für die Suchmuster angegeben
    werden können. Das Suchmuster kann im unteren Textfeld eingegeben
    werden. Der Auswahlknopf links definiert den Vergleichsoperator.
    Die letzten beiden Opratoren (mit G/K) unterscheiden zwischen
    Groß- und Kleinschreibung.

  @{B}Suchen@{UB}
    Hier kann der Suchbereich festgelegt werden:
      Alles     - Alle Einträge werden durchsucht.
      Zurück    - Alle Einträge vom aktuellen bis zum ersten werden durchsucht.
      Vorwärts  - Alle Einträge vom aktuellen bis zum letzten werden durchsucht.
      ·         - Einträge des angegebenen Bereichs werden durchsucht.

  @{B}Alle suchen@{UB}
    Startet Suche. Alle zutreffenden Einträge werden im Fenster
    @{"Blättern" LINK BROWSING} aufgelistet.

@ENDNODE
///
/// Description - sorting
@NODE SORTING "Einträge sortieren"

@{fg highlight}@{B}@{U}Einträge sortieren@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Hauptfenster:
    @{B}Menü:@{UB}      Eintrag|Sortieren|Nach...

  Wenn man diese Option im Menü oder durch Tastenkürzel mit gehaltener
  [Shift]-Taste aufruft, wird das Fenster "Sortiere Einträge" ohne
  irgendwelche Voreinstellungen für die Sortierkriterien geöffnet.

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Position@{UB}
    Mit diesem Knopf bzw. dem Nacheinanderanklicken der Felder kann man 
    die Sortierreihenfolge zwischen diesen festlegen, z.B.: wenn das 
    Projekt die Felder: Vorname, Zuname und Adresse enthält und man
    legt fest:
      Vorname             A-Z 2
      Zuname              A-Z 1
      Adresse             Z-A 3
    sortiert das Programm nach dem Feld "Zuname", aber bei gleichem Inhalt
    in diesem Feld entscheidet der Inhalt des Feldes "Vorname" etc.

  @{B}Reihenfolge@{UB}
    Festlegen der Sortierreihenfolge: A-Z - aufsteigend, Z-A - rückwärts.

  @{B}Entfernen@{UB}
    Entfernt das gewählte Feld aus den Sortierkriterien.

@ENDNODE
///
/// Description - browsing
@NODE BROWSING "Einträge durchblättern"

@{fg highlight}@{B}@{U}Einträge durchblättern@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Hauptfenster:
    @{B}Menü:@{UB}          Feld|Blättern...
    @{B}Popupmenü:@{UB}     Blättern...
    @{B}Tastenkürzel:@{UB}  Doppelklick nahe dem Feld

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Mit dem oberen Auswahlknopf kann man das zu durchblätternde Feld festlegen.

@{fg highlight}@{B}Tastenkürzel:@{fg text}@{UB}
  @{B}[PFEIL HOCH]/[PFEIL RUNTER]@{UB}
    nächster/voriger Eintrag

  @{B}[Enter]@{UB}
    schließt das Fenster

  @{B}[<Doppelklick irgendwo>]@{UB}
    schließt das Fenster

@{fg highlight}@{B}Menü:@{fg text}@{UB}
  @{B}Blättern@{UB}
    @{B}Nur Markierte@{UB}
      Zeigt nur die markierten Einträge.
    @{B}Zuletzt Gefundene@{UB}
      Zeigt nur die Einträge, welche mit der Option "Alle" im
      @{"Such" LINK SEARCHING}fenster gefunden wurden.
    @{B}Alle@{UB}
      Zeigt alle Einträge.
    @{B}Statistiken...@{UB}
      @{"Statistiken der Feldwerte." LINK STATISTICS}
    @{B}Schließen@{UB}
      Fenster schließen.

  @{B}Reihenfolge@{UB}
    Festlegen der Sortierreihenfolge.

@{fg highlight}@{B}Felder:@{fg text}@{UB}
  @{B}Muster@{UB}
    Hier kann ein Muster angegeben werden. Nur Einträge, die dem Muster entsprechen,
    werden angezeigt.

@ENDNODE
///
/// Description - statistics
@NODE STATISTICS "Statistiken"

@{fg highlight}@{B}@{U}Statistiken@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Hauptfenster:
    @{B}Menü:@{UB}      Feld|Statistiken...
    @{B}Popupmenü:@{UB} Statistiken...

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Das auszuwertende Feld kann mit dem oberen Auswahlknopf festgelegt werden.

@{fg highlight}@{B}Knöpfe:@{fg text}@{UB}
  @{B}Sichern...@{UB}
    Statistiken sichern.

  @{B}TSV sichern...@{UB}
    Sichert Statistiken als ASCII TSV (tabulatorgetrennte strukturierte ASCII-Datei).

@ENDNODE
///
/// Main - settings
@NODE SETTINGS "Einstellungen"

@{fg highlight}@{B}@{U}Einstellungen@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Projekteinstellungen:@{fg text}@{UB}
  @{" Informationen       " LINK PRJSETS}
  @{" Schutz              " LINK PASSETS}
  @{" ARexx               " LINK ARXSETS}
  @{" Menü                " LINK MENUSETS}

@{" Programmeinstellungen " LINK PRGSETS}

@ENDNODE
///
/// Settings - informations
@NODE PRJSETS "Projekteinstellungen - Informationen"

@{fg highlight}@{B}@{U}Projekteinstellungen - Informationen@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Hauptfenster:
    @{B}Menü:@{UB}      Projekt|Einstellungen...

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Bearbeiten der Informationen über das Projekt.

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Autor@{UB}
    Projektautor.

  @{B}Version@{UB}
    Projektversion.

  @{B}Beschreibung:@{UB}
    Kurzinformation über das Projekt.

  @{B}Zeige "Über das Projekt..." beim Start@{UB}
    Wenn dies aktiviert ist, wird beim Laden dieses Projekts das Fenster
    mit den hauptsächlichen Informationen zu diesem Projekt gezeigt.

@ENDNODE
///
/// Settings - protection
@NODE PASSETS "Projekteinstellungen - Schutz"

@{fg highlight}@{B}@{U}Projekteinstellungen - Schutz@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Hauptfenster:
    @{B}Menü:@{UB}      Projekt|Einstellungen...

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Passwortschutz für ein Projekt.

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Passwort@{UB}
    Passwort zum Schutz des Projekts.

  @{B}Überprüfen@{UB}
    Passwortüberprüfung. Bitte hier Passwort nochmals eingeben.

  @{B}Passwort nur vor dem Speichern prüfen@{UB}
    Das Passwort wird nicht beim Öffnen der Datei, sondern bei eventuellen
    Speicherversuchen abgefragt. (= Nur-Lese-Berechtigung für Passwortunkundige)

@ENDNODE
///
/// Settings - arexx
@NODE ARXSETS "Projekteinstellungen - ARexx"

@{fg highlight}@{B}@{U}Projekteinstellungen - ARexx@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Hauptfenster:
    @{B}Menü:@{UB}      Projekt|Einstellungen...

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Projekteinstellungen für die ARexx-Schnittstelle.

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Portname@{UB}
    Name des ARexx-Port des Projektes. Falls das Feld freibleibt, wird
    der Arexx-Port "XBAZE" benutzt.

  @{B}Konsole@{UB}
    Konsole, auf der alle Rückgabewerte gezeigt werden.

  @{B}Behalte Programme in "T:"@{UB}
    Alle ARexx-Programme des Projekts werden für die schnellere Ausführung
    im logischen Pfad "T:" gehalten.

@ENDNODE
///
/// Settings - menu
@NODE MENUSETS "Projekteinstellungen - Menü"

@{fg highlight}@{B}@{U}Projekteinstellungen - Menü@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Hauptfenster:
    @{B}Menü:@{UB}      Projekt|Einstellungen...

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
  Festlegen von ARexx-Programmen und Anzeigen für das Menü.

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Menü@{UB}
    Auswahl des zu bearbeitenden Menüs.

  @{B}Tastenkürzel@{UB}
    Wie soll die angegebene Datei aufgerufen werden?

  @{B}Name@{UB}
    Im Menü auftauchender Name.

  @{B}Datei@{UB}
    Pfad der Datei, welche zugewiesen werden soll.

@ENDNODE
///
/// Settings - program settings
@NODE PRGSETS "Programmeinstellungen"

@{fg highlight}@{B}@{U}Programmeinstellungen@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Aufruf:@{fg text}@{UB}
  Hauptfenster:
    @{B}Menü:@{UB}      Projekt|Einstellungen...

@{fg highlight}@{B}Knöpfe/Felder:@{fg text}@{UB}
  @{B}Öffentl. Bildschirm@{UB}
    Name des öffentlichen Bildschirms, auf dem das Hauptfenster von
    XBaze geöffnet werden soll. Falls der angegebene Bildschirm nicht
    gefunden wird, benutzt XBaze die Workbench.

  @{B}Font@{UB}
    Der vom Programm benutzte Zeichensatz, Syntax:
      <Fontname/Fontgröße>.

  @{B}Datenverzeichnis@{UB}
    Verzeichnis, in welchem die Dateien aus dem Menü "*" abgelegt werden.
    Dies erleichtert das Öffnen oft benutzter Projekte.

  @{B}Genauigkeit der Statistik (Stellen nach dem Komma)@{UB}
    Die Genauigkeit, mit der die Statistiken erstellt werden.
    Die angegebene Zahl definiert die Nachkommastellen.

  @{B}Erstelle Piktogramme@{UB}
    Mit den Projekten werden Piktogramme abgespeichert.

  @{B}Sortieren wie System@{UB}
    Damit werden alle Zeichenketten mittels einer Funktion der
    locale.library verglichen. Datenbanken in englischer oder
    polnischer Sprache können diese Option nicht verwenden.

  @{B}Ignoriere gespeicherte Fensterposition@{UB}
    Das Programm ignoriert die gespeicherten Fensterpositionen.

  @{B}Verlaufsanzeige@{UB}
    Aktiviert die Verlaufsanzeige.

  @{B}XBaze ikonifiziert starten@{UB}
    Das Programm startet im ikonifizierten Zustand.

  @{B}Benutze Bildschirmfont in Requestern und Fenstern@{UB}
    Der ausgewählte Zeichensatz wird nur im Hauptfenster verwandt.

  @{B}Werkzeugleiste am linken Rand@{UB}
    Die Werkzeugleiste wird am linken Rand platziert, anderenfalls
    erscheint sie am unteren Rand.

  @{B}Kein Größensymbol@{UB}
    Das Hauptfenster hat kein Größensymbol.

  @{B}Keine Navigationsknöpfe@{UB}
    Die Navigationsknöpfe werden nicht am unteren Rand platziert.

@ENDNODE
