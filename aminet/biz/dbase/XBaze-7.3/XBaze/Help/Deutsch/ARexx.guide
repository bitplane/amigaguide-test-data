@NODE GETFIELD "GETFIELD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}GETFIELD <Feldname>@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Gibt Feldinhalt zurück.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Bei Auswahlfeldern wird eine Zeichenkette zurückgegeben (nicht die Nummer
    der Knopfstellung), und bei Schalterfeldern die Schalterstellung.
    Wenn kein Feldname angegeben wird (auf Schreibweise achten), wird der Wert
    des aktuellen Feldes zurückgegeben.

  @{B}RC:@{UB}
    Rückgabe von -1, wenn das angegebene Feld nicht existiert.

@ENDNODE

@NODE TOGLLEMARKS "TOGLLEMARKS"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}TOGLLEMARKS@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Tauscht die Markierungen der Einträge. Wenn ein Eintrag nicht markiert ist,
    wird er markiert und umgekehrt.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    -
  @{B}RC:@{UB}
    -

@ENDNODE

@NODE TRUEGETFIELD "TRUEGETFIELD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}TRUEGETFIELD <Feldname>@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Gibt Feldinhalt zurück.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Wie @{"GETFIELD" LINK GETFIELD} mit dem Unterschied, dass bei Auswahlfeldern
    die Nummer der Knopfstellung zurückgegeben wird und bei Schalterfeldern die
    Schalterstellung.

  @{B}RC:@{UB}
    Rückgabe von -1, wenn das angegebene Feld nicht existiert.

@ENDNODE

@NODE GETFIELDTYPE "GETFIELDTYPE"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}GETFIELDTYPE <Feldname>@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Gibt den Feldtyp als Text zurück.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Abhängig vom Feldtyp ("String","Amount","Boolean","Cycle",
    "Button","Text").
    Wenn kein Feldname angegeben wird (auf Schreibweise achten),
    wird der Wert des aktuellen Feldes zurückgegeben.
  @{B}RC:@{UB}
    -

@ENDNODE

@NODE SEARCHONLYMARKED "SEARCHONLYMARKED"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}SEARCHONLYMARKED <Wert>@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Bei Eingabe von "1" sucht das Programm nur markierte Einträge.
    Bei "0" werden alle Einträge gesucht.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Wenn kein Wert angegeben wird, wird der aktuell gesetzte Wert 
    zurückgegeben.
  @{B}RC:@{UB}
    -

@ENDNODE

@NODE SETFIELD "SETFIELD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}SETFIELD <Feldname>[,<Wert>]@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Angegebener Wert wird in angegebenes Feld getragen. Bei Schalter-
    feldern werden nur numerische Werte akzeptiert (=0 - falsch,
    <>0 - wahr). Bei Auswahlfeldern muss die Nummer der gewünschten
    Knopfstellung angegeben werden.
    'Wert' ist ein optionaler Parameter.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    -
  @{B}RC:@{UB}
    Rückgabe von -1, wenn das angegebene Feld nicht existiert.

@ENDNODE

@NODE SETSEARCHOPERATOR "SETSEARCHOPERATOR"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}SETSEARCHOPERATOR <Wert>@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Setzt den Vergleichsoperator für die Suche auf den aktuellen Feld-
    inhalt. Der anzugebende Wert wird bei Auswahlfeldern verwendet.


@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    -
  @{B}RC:@{UB}
    Bei Auftritt eines Fehlers wird -1 zurückgegeben.

@ENDNODE

@NODE SETSEARCHSTRING "SETSEARCHSTRING"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}SETSEARCHSTRING <Suchmuster>@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Setzt das Suchmuster für das aktuelle Feld.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    -
  @{B}RC:@{UB}
    Bei Auftritt eines Fehlers wird -1 zurückgegeben.

@ENDNODE

@NODE CURRENTFIELD "CURRENTFIELD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}CURRENTFIELD <Feldname>@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Das angegebene Feld wird aktuell gesetzt (auf Schreibweise achten)
    Dies kann kein 'TEXT'feld oder ein Feld ohne gesetztes 'Speicherbar'
    Attribut sein.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Wenn kein Argument angegeben wird, wird der Name des aktuellen
    Feldes zurückgegeben.
  @{B}RC:@{UB}
    Rückgabe von -1, wenn das angegebene Feld nicht existiert.

@ENDNODE

@NODE FINDNEXTRECORD "FINDNEXTRECORD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}FINDNEXTRECORD@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Programm sucht vom aktuellen bis zum letzten Eintrag.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Nummer des gefundenen Eintrags. Wenn kein Eintrag gefunden wird,
    wird eine 0 zurückgegeben.
  @{B}RC:@{UB}
    Wenn kein Suchmuster angegeben ist, wird -1 zurückgegeben.

@ENDNODE

@NODE FINDPREVREORD "FINDPREVRECORD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}FINDPREVRECORD@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Programm sucht vom aktuellen bis ersten Eintrag.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Nummer des gefundenen Eintrags. Wenn kein Eintrag gefunden wird,
    wird eine 0 zurückgegeben.
  @{B}RC:@{UB}
    Wenn kein Suchmuster angegeben ist, wird -1 zurückgegeben.

@ENDNODE

@NODE FINDRECORD "FINDRECORD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}FINDRECORD@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Programm sucht vom ersten bis letzten Eintrag.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Nummer des gefundenen Eintrags. Wenn kein Eintrag gefunden wird,
    wird eine 0 zurückgegeben.
  @{B}RC:@{UB}
    Wenn kein Suchmuster angegeben ist, wird -1 zurückgegeben.

@ENDNODE

@NODE FIRSTFIELD "FIRSTFIELD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}FIRSTFIELD@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Aktiviert erstes Feld.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Feldname.
  @{B}RC:@{UB}
    -

@ENDNODE

@NODE LASTFIELD "LASTFIELD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}LASTFIELD@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Aktiviert letztes Feld.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Feldname.
  @{B}RC:@{UB}
    -

@ENDNODE

@NODE NEXTFIELD "NEXTFIELD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}NEXTFIELD@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Aktiviert nächstes Feld.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Feldname.
  @{B}RC:@{UB}
    Rückgabe von -1, wenn das Feld nicht existiert.

@ENDNODE

@NODE PREVFIELD "PREVFIELD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}PREVFIELD@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Aktiviert vorhergehendes Feld.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Feldname.
  @{B}RC:@{UB}
    Rückgabe von -1, wenn das Feld nicht existiert.

@ENDNODE

@NODE RETRYINPUT "RETRYINPUT"

@{fg highlight}@{B}@{fg text}Syntax:@{fg text}@{UB}
  @{B}RETRYINPUT@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Aktiviert das Feld, von dem das ARexx-Programm aufgerufen wurde. Wenn
    das Programm durch eine Änderung des Feldinhalts aufgerufen wurde,
    wird das nächste Feld nicht aktiviert.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    -
  @{B}RC:@{UB}
    -

@ENDNODE

@NODE ACTIVATEFIELD "ACTIVATEFIELD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}ACTIVATEFIELD <Feldname>@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Aktiviert das angegebene Feld. Dies kann nur für "Standard" oder
    "Betrag" Felder genutzt werden. Wenn kein Feldname angegeben wird,
    wird das aktuelle Feld aktiviert.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    -
  @{B}RC:@{UB}
    Wenn das angegebene Feld nicht existiert oder vom falschen Feldtyp
    ist, wird -1 zurückgegeben.

@ENDNODE

@NODE CURRENTRECORD "CURRENTRECORD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}CURRENTRECORD <Nummer des Eintrags>@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Springt zum angegebenen Eintrag.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Wenn kein Argument angegeben wird, wird die Nummer des aktuellen
    Eintrags zurückgegeben.
  @{B}RC:@{UB}
    Wenn der angegebene Eintrag außerhalb des zulässigen Bereichs
    liegt, wird -1 zurückgegeben.

@ENDNODE

@NODE FIRSTRECORD "FIRSTRECORD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}FIRSTRECORD@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Springt zum ersten Eintrag.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Eintragsnummer
  @{B}RC:@{UB}
    -

@ENDNODE

@NODE LASTRECORD "LASTRECORD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}LASTRECORD@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Springt zum letzten Eintrag.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Eintragsnummer.
  @{B}RC:@{UB}
    -

@ENDNODE

@NODE NEXTRECORD "NEXTRECORD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}NEXTRECORD@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Springt zum nächsten Eintrag.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Eintragsnummer.
  @{B}RC:@{UB}
    Wenn der Eintrag nicht existiert, wird -1 zurückgegeben.

@ENDNODE

@NODE PREVRECORD "PREVRECORD"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
  @{B}PREVRECORD@{UB}

@{fg highlight}@{B}Beschreibung:@{fg text}@{UB}
    Springt zum vorhergehenden Eintrag.

@{fg highlight}@{B}Rückgaben:@{fg text}@{UB}
  @{B}ERGEBNIS:@{UB}
    Eintragsnummer.
  @{B}RC:@{UB}
    Wenn der Eintrag nicht existiert, wird -1 zurückgegeben.

@ENDNODE

@NODE DEL "DEL"

@{fg highlight}@{B}Syntax:@{fg text}@{UB}
