@NODE SHORTCUTS "Skróty"

@{fg highlight}@{B}@{U}Skróty@{fg text}@{UB}@{UU}

@{fg highlight}@{B}Ogólna zasada@{fg text}@{UB}
  @{B}[LEWA AMIGA] [<klawisz>]@{UB}
    Skróty klawiaturowe dla gadűetów.

  @{B}[PRAWA AMIGA] [<klawisz>]@{UB}
    Skróty klawiaturowe dla menu.

  @{B}[HELP]@{UB}
    Otwiera dokument amigaguide z dokumentacjâ programu.

@{fg highlight}@{B}Operacje na rekordach:@{fg text}@{UB}
  @{B}[Num 9]/[KURSOR W LEWO]@{UB}
    Przechodzi do poprzedniego rekordu.

  @{B}[Num 3]/[KURSOR W PRAWO]@{UB}
    Przechodzi do nastëpnego rekordu.

  @{B}[Num 7]/[Shift] [KURSOR W LEWO]@{UB}
    Przechodzi do pierwszego rekordu.

  @{B}[Num 1]/[Shift] [KURSOR W PRAWO]@{UB}
    Przechodzi do ostatniego rekordu.

  @{B}[Num 5]@{UB}
    Przechodzi do rekordu o wybranym numerze.

  @{B}[PRAWY Alt] [Num 9]/[KURSOR W LEWO]@{UB}
    Przechodzi do poprzedniego zaznaczonego rekordu.

  @{B}[PRAWY Alt] [Num 3]/[KURSOR W PRAWO]@{UB}
    Przechodzi do nastëpnego zaznaczonego rekordu.

  @{B}[PRAWY Alt] [Num 7]@/[Shift] [KURSOR W LEWO]{UB}
    Przechodzi do pierwszego zaznaczonego rekordu.

  @{B}[PRAWY Alt] [Num 1]/[Shift] [KURSOR W PRAWO]@{UB}
    Przechodzi do ostatniego zaznaczonego rekordu.

  @{B}[LEWY Alt] [Num 9]/[KURSOR W LEWO]@{UB}
    Przechodzi do poprzedniego niezaznaczonego rekordu.

  @{B}[LEWY Alt] [Num 3]/[KURSOR W PRAWO]@{UB}
    Przechodzi do nastëpnego niezaznaczonego rekordu.

  @{B}[LEWY Alt] [Num 7]@/[Shift] [KURSOR W LEWO]{UB}
    Przechodzi do pierwszego niezaznaczonego rekordu.

  @{B}[LEWY Alt] [Num 1]/[Shift] [KURSOR W PRAWO]@{UB}
    Przechodzi do ostatniego niezaznaczonego rekordu.


  @{B}[Num 0]/[Num +]@{UB}
    Wstawia rekord.

  @{B}[Shift] [Num 0]/[Num +]@{UB}
    Dodaje űâdanâ iloôę rekordów.

  @{B}[Ctrl] [Num 0]/[Num +]@{UB}
    Wstawia rekordy ze wskazanego pliku..


  @{B}[Num .]/[Num -]@{UB}
    Kasuje aktualny rekord.

  @{B}[PRAWY Alt] [Num .]/[Num -]@{UB}
    Kasuje wszystkie zaznaczone rekordy.

  @{B}[LEWY Alt] [Num .]/[Num -]@{UB}
    Kasuje wszystkie niezaznaczone rekordy.

  @{B}[Ctrl] [Num .]/[Num -]@{UB}
    Kasuje wszystkie rekordy.

  @{B}[Shift] [Num .]/[Num -]@{UB}
    Kasuje rekordy z definiowanego zakresu.

@{fg highlight}@{B}Operacje na polach:@{fg text}@{UB}
  @{B}[TAB]@{UB}
    Nastëpne pole.

  @{B}[Shift] [TAB]@{UB}
    Poprzednie pole.

  @{B}[<skrót pola>]/[Enter]/[SPACJA]@{UB}
    Aktywuje pole.

  @{B}[Shift] [<skrót pola>]/[Enter]/[SPACJA]@{UB}
    CIÂG: Otwiera okno wartoôci predefiniowanych.

  @{B}[LEWY Alt] [<skrót pola>]@{UB}
    Ustawia pole jako bierzâce bez jego aktywowania go.

  @{B}[Alt] [Enter]/[SPACJA]@{UB}
    Wstawia do pola zawartoôę pola z poprzedniego rekordu

  @{B}[KURSOR W DÓÎ]@{UB}
    CIÂG:                Wstawia nastëpnâ wartoôę z listy wartoôci
                         predefiniowanych.
    CIÂG WIELOLINIJKOWY: Skroluje w dóî.
    CYKLICZNE          : Ustawia nastëpnâ wartoôę.

  @{B}[KURSOR W GÓRË]@{UB}
    CIÂG:                Wstawia poprzedniâ wartoôę z listy wartoôci
                         predefiniowanych.
    CIÂG WIELOLINIJKOWY: Skroluje w górë.
    CYKLICZNE          : Ustawia poprzedniâ wartoôę.

@{fg highlight}@{B}Jeűeli pole jest aktywne (jest w nim kursor) to:@{fg text}@{UB}
  @{B}[Enter]/[TAB]@{UB}
    Nastëpne pole.

  @{B}[Shift] [Enter]/[TAB]@{UB}
    Poprzednie pole.

  @{B}[LEWA AMIGA] [Q]@{UB}
    Przywraca poprzedniâ zawartoôę pola (UNDO).

  @{B}[LEWA AMIGA] [X]@{UB}
    Czyôci zawartoôę pola.

  @{B}[Shift] [KURSOR W PRAWO]@{UB}
    Kursor skacze na koniec tekstu w polu.

  @{B}[Shift] [KURSOR W LEWO]@{UB}
    Kursor skacze na poczâtek tekstu w polu.

  @{B}[Shift] [BACKSPACE]@{UB}
    Kasuje wszystkie znaki od kursora do poczâtku.

  @{B}[Shift] [Del]@{UB}
    Kasuje wszystkie znaki od kursora do koďca.

@{fg highlight}@{B}Mysz:@{fg text}@{UB}
  @{B}[<dwuklik w pobliűu pola>]@{UB}
