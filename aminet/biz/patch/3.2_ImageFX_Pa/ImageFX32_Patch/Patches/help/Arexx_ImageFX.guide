      None.

   @{b}RESULT@{ub}
      None.

@endnode

@node RollScreenUp "RollScreenUp"

ROLLSCREENUP

   @{b}FORMAT@{ub}
      RollScreenUp Height/N/A

   @{b}FUNCTION@{ub}
      Roll the menu screen upward to fit a new window on it.

   @{b}INPUTS@{ub}
