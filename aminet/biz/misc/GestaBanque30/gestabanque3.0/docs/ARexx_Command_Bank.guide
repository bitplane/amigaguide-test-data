@Node main "GestaCompte Banque 3.0 - Commandes ARexx"
@ToC "Bank.guide/Main"

 @{u}@{i}Interface ARexx @{ui}@{uu}

 GrŌce Ó son Interface ARexx@{fg shine}  GestaCompte  Banque  V3.0 @{fg text} peut  non  seulement
 exķcuter ses propres scripts et ainsi optimiser certaines tŌches mais il est
 ouvert Ó d'autres logiciels ayant eux aussi une Interface ARexx.

 Ainsi vous pouvez importer/exporter des donnķes vers un traitement de texte,
 un tableur, une base de donnķes, etc....


 @{u}@{i}Commandes ARexx @{ui}@{uu}

 Le nombre de commandes ARexx implantķes dans GestaCompte Banque V3.0 est  de
 33.

 @{" CLICK     " Link "a"}   @{" LOAD           " Link "g"}   @{" OPERATIONVAL     " Link "m"}   @{" SHOWMONTH        " Link "s"}
 @{" CREATE    " Link "b"}   @{" MONTH          " Link "h"}   @{" PORT             " Link "n"}   @{" SHOWYEAR         " Link "t"}
 @{" DELETE    " Link "c"}   @{" NEWCOUNT       " Link "i"}   @{" PRINT            " Link "o"}   @{" SORTCOUNTS       " Link "u"}
 @{" DELCOUNT  " Link "d"}   @{" NUMBOPERATIONS " Link "j"}   @{" PRINTPC          " Link "p"}   @{" VALIDATE         " Link "v"}
 @{" DISPLAY   " Link "e"}   @{" NUMBCOUNTS     " Link "k"}   @{" QUIT             " Link "q"}   @{" VIEW             " Link "w"}
 @{" ENTER     " Link "f"}   @{" OPERATION      " Link "l"}   @{" SAVE             " Link "r"}   @{" YEAR             " Link "x"}
 @{" EUROON    " Link "y"}   @{" STATCOUNT      " Link "ab"}   @{" STATEXPENSES     " Link "ad"}   @{" STATRECEIPTS     " Link "af"}
 @{" EUROFF    " Link "z"}   @{" STATCOUNTPERC  " Link "ac"}   @{" STATEXPENSESPERC " Link "ae"}   @{" STATRECEIPTSPERC " Link "ag"}
 @{" EUROVALUE " Link "aa"}
@EndNode
@Node a "Commandes ARexx"

 @{fg shine}Commande@{fg text}     CLICK

 @{fg shine}Description@{fg text}  Demande Ó l'utilisateur de cliquer sur une transaction.

 @{fg shine}Variable@{fg text}     -

 @{fg shine}Rķsultats@{fg text}    RC=0
              Result= Position de la transaction sķlectionnķe.

@EndNode
@Node b "Commandes ARexx"

 @{fg shine}Commande@{fg text}     CREATE @{i}somme @{ui}

 @{fg shine}Description@{fg text}  Ouverture d'un compte.

 @{fg shine}Variable@{fg text}     @{i}somme @{ui}: expression numķrique.

 @{fg shine}Rķsultats@{fg text}    RC=0
              Result= Non dķfini.

@EndNode
@Node c "Commandes ARexx"

 @{fg shine}Commande@{fg text}     DELETE @{i}position @{ui}

 @{fg shine}Description@{fg text}  Supprime une transaction.

 @{fg shine}Variable@{fg text}     @{i}position @{ui}: expression numķrique.

 @{fg shine}Rķsultats@{fg text}    RC=0
              Result= Non dķfini.

@EndNode
@Node d "Commandes ARexx"

 @{fg shine}Commande@{fg text}     DELCOUNT @{i}position @{ui}

 @{fg shine}Description@{fg text}  Supprime le libellķ de la liste des postes.

 @{fg shine}Variable@{fg text}     @{i}position @{ui}: expression numķrique comprise entre 1 et 30.

 @{fg shine}Rķsultats@{fg text}    RC=0
              Result= Non dķfini.

@EndNode
@Node e "Commandes ARexx"

 @{fg shine}Commande@{fg text}     DISPLAY

 @{fg shine}Description@{fg text}  Bascule le programme en premier plan.

 @{fg shine}Variable@{fg text}     -

 @{fg shine}Rķsultats@{fg text}    RC=0
              Result= Non dķfini.

@EndNode
@Node f "Commandes ARexx"

 @{fg shine}Commande@{fg text}     ENTER @{i}jour|mois|nature|numķrodechĶque|somme|libellķ|numķrodeposte @{ui}

 @{fg shine}Description@{fg text}  Saisie une transaction dans le mois indiquķ.

 @{fg shine}Variable@{fg text}     @{i}jour  @{ui}         : valeur numķrique Ó deux chiffres.
              @{i}mois  @{ui}         : valeur numķrique Ó deux chiffres.
              @{i}nature  @{ui}       : nature de la transaction contenant soit:

                                  @{i}CASHS  @{ui} pour espĶces,
                                  @{i}CHEQ   @{ui} pour chĶque,
                                  @{i}CARD   @{ui} pour carte bancaire,
                                  @{i}DEDUCT @{ui} pour prķlĶvement,
                                  @{i}TRANSF @{ui} pour virement,
                                  @{i}DELIVE @{ui} pour remise.

              @{i}numķroduchĶque @{ui}: valeur numķrique (obligatoire pour nature=CHEQ).
              @{i}somme          @{ui}: valeur numķrique.
              @{i}libellķ        @{ui}: chaŅne alphanumķrique limitķe Ó 20 caractĶres.
              @{i}numķrodeposte  @{ui}: valeur numķrique Ó 1 ou 2 chiffres.

 @{fg shine}Rķsultats@{fg text}    RC=0
              Result= Non dķfini.

@EndNode
@Node g "Commandes ARexx"

 @{fg shine}Commande@{fg text}     LOAD [force]

 @{fg shine}Description@{fg text}  Charge  en  mķmoire  les  opķrations  Ó  partir  d'un   support
              magnķtique.

 @{fg shine}Variable@{fg text}     force (option) : si ķgal Ó force, il n'affiche pas  le  message
              de mise en garde.

 @{fg shine}Rķsultats@{fg text}    RC=0
              Result= Non dķfini.

@EndNode
@Node h "Commandes ARexx"

 @{fg shine}Commande@{fg text}     MONTH @{i}valeur @{ui}

 @{fg shine}Description@{fg text}  Sķlection du mois en cours.

 @{fg shine}Variable@{fg text}     @{i}valeur @{ui}: expression numķrique entre 1 et 12.

 @{fg shine}Rķsultats@{fg text}    RC=0
              Result= Non dķfini.

@EndNode
@Node i "Commandes ARexx"

 @{fg shine}Commande@{fg text}     NEWCOUNT @{i}libellķ @{ui}

 @{fg shine}Description@{fg text}  InsĶre le libellķ dans la liste des postes en fin de liste.

 @{fg shine}Variable@{fg text}     @{i}libellķ @{ui}: chaŅne alphanumķrique de 20 caractĶres maxi.

 @{fg shine}Rķsultats@{fg text}    RC=0
              Result= Non dķfini.

@EndNode
@Node j "Commandes ARexx"

 @{fg shine}Commande@{fg text}     NUMBOPERATIONS

 @{fg shine}Description@{fg text}  Renvoie le nombre d'opķrations dans le mois.

 @{fg shine}Variable@{fg text}     -

 @{fg shine}Rķsultats@{fg text}    RC=0
              Result= nombre d'opķrations.

@EndNode
@Node k "Commandes ARexx"

 @{fg shine}Commande@{fg text}     NUMBCOUNTS

 @{fg shine}Description@{fg text}  Renvoie le nombre de postes connus.

 @{fg shine}Variable@{fg text}     -

 @{fg shine}Rķsultats@{fg text}    RC=0
              Result= nombre de postes.

@EndNode
@Node l "Commandes ARexx"

 @{fg shine}Commande@{fg text}      OPERATION @{i}position @{ui}

 @{fg shine}Description@{fg text}   Retourne le contenu de la transaction sķlectionnķe.

 @{fg shine}Variable@{fg text}      @{i}position @{ui}: expression numķrique.

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= transaction sous forme d'une chaŅne de caractĶres :

               jour|mois|nature|numķrodechĶque|somme|libellķ|numķrodeposte

                       Nature : @{i}CASHS  @{ui} pour espĶces,
                                @{i}CHEQ   @{ui} pour chĶque,
                                @{i}CARD   @{ui} pour carte bancaire,
                                @{i}DEDUCT @{ui} pour prķlĶvement,
                                @{i}TRANSF @{ui} pour virement,
                                @{i}DELIVE @{ui} pour remise.

@EndNode
@Node m "Commandes ARexx"

 @{fg shine}Commande@{fg text}      OPERATIONVAL @{i}position @{ui}

 @{fg shine}Description@{fg text}   Indique si la transaction sķlectionnķe est validķe ou non.

 @{fg shine}Variable@{fg text}      @{i}position @{ui}: expression numķrique.

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= 'Y' si la transaction est validķe sinon 'N'.

@EndNode
@Node n "Commandes ARexx"

 @{fg shine}Commande@{fg text}      PORT @{i}nom du port @{ui}

 @{fg shine}Description@{fg text}   Indique le port d'impression.

 @{fg shine}Variable@{fg text}      @{i}nom du port @{ui}: chaŅne de caractĶres

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= nombre d'opķrations.

@EndNode
@Node o "Commandes ARexx"

 @{fg shine}Commande@{fg text}      PRINT @{i}type d'impression @{ui}[valide]

 @{fg shine}Description@{fg text}   Impression des transactions sur le port de sortie.

 @{fg shine}Variable@{fg text}      @{i}type d'impression @{ui}:

                               @{i}month @{ui}   imprime le mois en cours.
                               @{i}nature @{ui}  imprime par nature.
                               @{i}postes @{ui}  imprime par poste.
                               @{i}cheques @{ui} imprime les chĶques de l'annķe.

               valide (option utilisķe avec `cheque') :

                               @{i}notvalidates @{ui} chĶques non encaissķs.
                               @{i}validates    @{ui} chĶques encaissķs.

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= Non dķfini.

@EndNode
@Node p "Commandes ARexx"

 @{fg shine}Commande@{fg text}      PRINTPC @{i}type d'impression @{ui}[valide]

 @{fg shine}Description@{fg text}   Impression des transactions sur le port de sortie

 @{fg shine}Variable@{fg text}      @{i}type d'impression @{ui}:

                               @{i}month @{ui}   imprime le mois en cours.
                               @{i}nature @{ui}  imprime par nature.
                               @{i}postes @{ui}  imprime par poste.
                               @{i}cheques @{ui} imprime les chĶques de l'annķe.

               valide (option utilisķe avec `cheque') :

                               @{i}notvalidates @{ui} chĶques non encaissķs.
                               @{i}validates    @{ui} chĶques encaissķs.

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= Non dķfini.

@EndNode
@Node q "Commandes ARexx"
                                    
 @{fg shine}Commande@{fg text}      QUIT

 @{fg shine}Description@{fg text}   Ferme le programme et retourne au systĶme.

 @{fg shine}Variable@{fg text}      -

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= Non dķfini.

@EndNode
@Node r "Commandes ARexx"

 @{fg shine}Commande@{fg text}      SAVE [force]

 @{fg shine}Description@{fg text}   Sauvegarde les transactions sur support magnķtique.

 @{fg shine}Variable@{fg text}      force (option) : si ķgal Ó force, il n'affiche pas le  message
               de mise en garde.

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= Non dķfini.

@EndNode
@Node s "Commandes ARexx"
                                    
 @{fg shine}Commande@{fg text}      SHOWMONTH

 @{fg shine}Description@{fg text}   Retourne le mois en cours sous GestaCompte.

 @{fg shine}Variable@{fg text}      -

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= mois (de 1 Ó 12).

@EndNode
@Node t "Commandes ARexx"

 @{fg shine}Commande@{fg text}      SHOWYEAR

 @{fg shine}Description@{fg text}   Retourne l'annķe en cours sous GestaCompte.

 @{fg shine}Variable@{fg text}      -

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= annķe sous forme de 4 chiffres.

@EndNode
@Node u "Commandes ARexx"

 @{fg shine}Commande@{fg text}      SORTCOUNTS

 @{fg shine}Description@{fg text}   Trie les postes par ordre alphabķtique.

 @{fg shine}Variable@{fg text}      -

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= Non dķfini.

@EndNode
@Node v "Commandes ARexx"

 @{fg shine}Commande@{fg text}      VALIDATE@{i} position @{ui}['jour/mois']

 @{fg shine}Description@{fg text}   Valide une transaction indiquķe par sa position.

 @{fg shine}Variable@{fg text}      @{i}position @{ui}: expression numķrique.
               jour/mois (option) : indique la date `encaissement' pour un
                                    chĶque.

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= Non dķfini.

@EndNode
@Node w "Commandes ARexx"

 @{fg shine}Commande@{fg text}      VIEW@{i} mode @{ui}

 @{fg shine}Description@{fg text}   Sķlection du mode d'affichage.

 @{fg shine}Variable@{fg text}      @{i}mode @{ui}: chaŅne de caractĶres contenant soit :

                      @{i}ALL
                      VALIDATES
                      NOTVALIDATES @{ui}

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= Non dķfini.

@EndNode
@Node x "Commandes ARexx"

 @{fg shine}Commande@{fg text}      YEAR @{i}valeur @{ui}

 @{fg shine}Description@{fg text}   Change l'annķe en cours.

 @{fg shine}Variable@{fg text}      @{i}valeur @{ui}: expression numķrique Ó 4 chiffres.

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= Non dķfini.

@EndNode
@Node y "Commandes ARexx"

 @{fg shine}Commande@{fg text}      EUROON

 @{fg shine}Description@{fg text}   Affiche les sommes en monnaie euro.

 @{fg shine}Variable@{fg text}      -

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= Non dķfini.

@EndNode
@Node z "Commandes ARexx"

 @{fg shine}Commande@{fg text}      EUROOFF

 @{fg shine}Description@{fg text}   Affiche les sommes en monnaie nationnale.

 @{fg shine}Variable@{fg text}      -

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= Non dķfini.

@EndNode
@Node aa "Commandes ARexx"

 @{fg shine}Commande@{fg text}      EUROVALUE @{i}valeur @{ui}

 @{fg shine}Description@{fg text}   Dķfini la constante de change entre  la  monnaie  euro  et  la
               monnaie nationnale.

 @{fg shine}Variable@{fg text}      @{i}valeur @{ui}: constante de change.

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= Non dķfini.

@EndNode
@Node ab "Commandes ARexx"

 @{fg shine}Commande@{fg text}      STATCOUNT @{i}poste mois @{ui}

 @{fg shine}Description@{fg text}   Retourne le montant total d'un poste pour le mois indiquķ.

 @{fg shine}Variable@{fg text}      @{i}poste @{ui}: valeur de 1 Ó 31.
               @{i}mois @{ui}: valeur de 1 Ó 12.

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= somme en francs ou en euros.

@EndNode
@Node ac "Commandes ARexx"

 @{fg shine}Commande@{fg text}      STATCOUNTPERC @{ui}poste mois @{ui}

 @{fg shine}Description@{fg text}   Retourne le pourcentage d'un poste pour le mois indiquķ.

 @{fg shine}Variable@{fg text}      @{i}poste @{ui}: valeur de 1 Ó 31.
               @{i}mois @{ui}: valeur de 1 Ó 12

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= pourcentage.

@EndNode
@Node ad "Commandes ARexx"

 @{fg shine}Commande@{fg text}      STATEXPENSES @{i}mois @{ui}

 @{fg shine}Description@{fg text}   Retourne le total des dķpenses pour le mois indiquķ.

 @{fg shine}Variable@{fg text}      @{i}mois @{ui}: valeur de 1 Ó 12

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= somme en francs ou en euros.

@EndNode
@Node ae "Commandes ARexx"

 @{fg shine}Commande@{fg text}      STATEXPENSESPERC @{i}mois @{ui}

 @{fg shine}Description@{fg text}   Retourne le pourcentage des dķpenses pour le mois indiquķ.

 @{fg shine}Variable@{fg text}      @{i}mois @{ui}: valeur de 1 Ó 12

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= pourcentage.

@EndNode
@Node af "Commandes ARexx"

 @{fg shine}Commande@{fg text}      STATRECEIPTS @{i}mois @{ui}

 @{fg shine}Description@{fg text}   Retourne le total des recettes pour le mois indiquķ.

 @{fg shine}Variable@{fg text}      @{i}mois @{ui}: valeur de 1 Ó 12

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= somme en francs ou en euros.

@EndNode
@Node ag "Commandes ARexx"

 @{fg shine}Commande@{fg text}      STATRECEIPTSPERC mois

 @{fg shine}Description@{fg text}   Retourne le pourcentage des recettes pour le mois indiquķ.

 @{fg shine}Variable@{fg text}      mois: valeur de 1 Ó 12

 @{fg shine}Rķsultats@{fg text}     RC=0
               Result= pourcentage.
               
@EndNode


