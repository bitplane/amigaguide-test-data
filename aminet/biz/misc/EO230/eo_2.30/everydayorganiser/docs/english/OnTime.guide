@{"GetActive"       link RX_GetActive}       EVENT/S,TASK/S,NOTE/S
@{"GetCalDate"      link RX_GetCalDate}      CALENDAR/N/A,FORMAT/N/K,JULIAN/S
@{"GetEntries"      link RX_GetEntries}      EVENT/S,TASK/S,NOTE/S,TOTAL/S,TITLES/S
@{"GetField"        link RX_GetField}        EVENT/S,TASK/S,NOTE/S,ENTRY/N/K,TYPE/S,FIELD/N
@{"GetFilter"       link RX_GetFilter}       EVENT/S,TASK/S
@{"GetFilterDate"   link RX_GetFilterDate}   EVENT/S,TASK/S,FORMAT/N/K,JULIAN/S
@{"GetFilterString" link RX_GetFilterString} EVENT/S,TASK/S
@{"GetInfo"         link RX_GetInfo}         DATEFORMAT/S,DATESEP/S,TIMEFORMAT/S,TIMESEP/S
@{"GetSelect"       link RX_GetSelect}       EVENT/S,TASK/S,NOTE/S,ACTIVE/S

