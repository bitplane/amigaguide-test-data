                   @{"-> <-" LINK OTWIERANIE} - Wczytywanie projektu
                   @{"-> <-" LINK IKO} - Ikonifikowanie programu
                   @{"-> <-" LINK WYCHODZENIE} - Wychodzenie z programu
                   @{"-> <-" LINK CZYSZCZENIE} - Kasowanie danych
                   @{"-> <-" LINK WYCINANIE} - Wycinanie rekordu do buforu
                   @{"-> <-" LINK KOPIOWANIE} - Kopiowanie rekordu do buforu
                   @{"-> <-" LINK WSTAWIANIE} - Wstawianie rekordu z buforu
                   @{"-> <-" LINK DODAWANIE} - Dodawanie rekordu
                   @{"-> <-" LINK KASOWANIE} - Kasowanie rekordu
