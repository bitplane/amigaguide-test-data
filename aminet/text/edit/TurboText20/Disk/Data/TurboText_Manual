	@{" Automatic Saving     " link "Automatic Saving"}
	@{" File Backups         " link "File Backups"}
	@{" Read-Only Mode       " link "Read-Only Mode"}
	@{" Quote Mode           " link "Quote Mode"}
	@{" Folds                " link "Folds"}
	@{" Icon Commands        " link "Icon Commands"}
