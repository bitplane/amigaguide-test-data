@{" · Hjälp beroende pĺ placering i programmet       " Link FEATURES_HELP}
@{" · Stöder OS 2.0, 2.1 och 3.0                     " Link FEATURES_OS_SUPPORT}
@{" · Olika sprĺk (OS 2.1 och högre)                 " Link FEATURES_LOCALE}

@{" · Stöder klippbordet                             " Link FEATURES_CLIPBOARD}
@{" · Stöder alla skärmlägen                         " Link FEATURES_SCREENMODES}
@{" · Dialogrutorna lĺser inte programmet            " Link FEATURES_NONMODAL_REQUESTERS}
