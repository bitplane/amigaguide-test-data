  @{"  kopieren            " link M1_Kopieren}
  @{"  einfügen            " link M1_Einfügen}
  @{"  löschen             " link M1_Löschen}

  @{"  speichern           " link M1_Speichern}
  @{"  drucken             " link M1_Drucken}

  @{"  einrücken           " link M1_Einrücken}
  @{"  ausrücken           " link M1_Ausrücken}

  @{"  Bereich-Anfang   " link M1_BereichAnfang}
  @{"  Bereich-Ende     " link M1_BereichEnde}
  @{"  Markierung löschen  " link M1_MarkierungLöschen}

  @{"  alle nochmal        " link M1_AlleNochmal}
  @{"  alle rückgängig     " link M1_AlleRückgängig}
  @{"  nochmal             " link M1_Nochmal}
