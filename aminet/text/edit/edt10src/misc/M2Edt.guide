  @{"  Makro abschließen      " link M5_MakroAbschließen}
  @{"  Makro ausführen        " link M5_MakroAusführen}
  @{"  Makro Makro vergessen  " link M5_MakroVergessen}
  @{"  Makro speichern        " link M5_MakroSpeichern}
  @{"  Makro zuweisen         " link M5_MakroZuweisen}
  @{"  Befehl eingeben        " link M5_BefehlEingeben}
  @{"  Befehl wiederholen     " link M5_BefehlWiederholen}
