@node "COM_CursUp" "Internal command: CursUp"

        @{fg shine}CursUp@{fg text}

@{b}Function:@{ub}       Move the cursor upward.
@{b}Syntax:@{ub}         LINES/N,PAGE/S,TOP/S,SELECT/S, SCROLL/S
@{b}Result:@{ub}         0  - Done (if possible).
                10 - No editor window open / selected.

@{b}Options:@{ub}        LINES:  Move the cursor LINES lines up.
                PAGE:   Move the cursor 1 page up.
                TOP:    Move the cursor to the top.
                SELECT: Move the cursor extend the block to the new cursor
                        position.
                SCROLL:	Keep the cursor on the same line, but scroll the
                        whole window 1 line down.

@endnode
@node "COM_CursDown" "Internal command: CursDown"

        @{fg shine}CursDown@{fg text}

@{b}Function:@{ub}       Move the cursor downward.
@{b}Syntax:@{ub}         LINES/N,PAGE/S,BOTTOM/S,SELECT/S,SCROLL/S
@{b}Result:@{ub}         0  - Done (if possible).
                10 - No editor window open / selected.

@{b}Options:@{ub}        LINES:  Move the cursor LINES lines down.
                PAGE:   Move the cursor 1 page down.
                BOTTOM: Move the cursor to the bottom.
                SELECT: Move the cursor extend the block to the new cursor
                        position.
                SCROLL:	Keep the cursor on the same line, but scroll the
                        whole window 1 line down.

@endnode
@node "COM_CursLeft" "Internal command: CursLeft"

        @{fg shine}CursLeft@{fg text}

@{b}Function:@{ub}       Move the cursor to the left.
@{b}Syntax:@{ub}         CHARS/N,WORD/S,SOL/S,SELECT/S
@{b}Result:@{ub}         0  - Done (if possible).
                10 - No editor window open / selected.

@{b}Options:@{ub}        CHARS:  Move the cursor CHARS characters to the left.
                WORD:   Move the cursor 1 word to the left.
                SOL:    Move the cursor to the Start Of the Line.
                SELECT: Move the cursor extend the block to the new cursor
                        position.

@endnode
@node "COM_CursRight" "Internal command: CursRight"

        @{fg shine}CursRight@{fg text}

@{b}Function:@{ub}       Move the cursor to the right.
@{b}Syntax:@{ub}         CHARS/N,WORD/S,EOL/S,SELECT/S
@{b}Result:@{ub}         0  - Done (if possible).
                10 - No editor window open / selected.

@{b}Options:@{ub}        CHARS:  Move the cursor CHARS characters to the right.
                WORD:   Move the cursor 1 word to the right.
                EOL:    Move the cursor to the End Of the Line.
                SELECT: Move the cursor extend the block to the new cursor
                        position.

@endnode
@node "COM_CursMode" "Internal command: CursMode"

        @{fg shine}CursMode@{fg text}

@{b}Function:@{ub}       Switch between normal cursor and the cursor in the codebar.
                When the cursor in the codebar is active you can edit any
                text as if you were using the normal @{"viewer/editor module" LINK ""},
                even when that's not the case. This is very handy for
                editing unsupported HTML tags and things like that.
@{b}Syntax:@{ub}         NORMAL/S,CODEBAR/S,TOGGLE/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window open / selected.

@{b}Options:@{ub}        NORMAL:  Activate normal cursor.
                CODEBAR: Activate cursor in the codebar.
                TOGGLE:  Toggle between the normal cursor and the cursor in
                         the codebar.

@endnode
@node "COM_WordWrap" "Internal command: WordWrap"

        @{fg shine}WordWrap@{fg text}

@{b}Function:@{ub}       Switch between the available wordwrap modes.
@{b}Syntax:@{ub}         ON/S,OFF/S,DYNAMIC/S,TOGGLE/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window open / selected.

@{b}Options:@{ub}        ON:       Normal wordwrap on.
                OFF:      All wordwrap off.
                DYNAMIC:  Dynamic wordwrap on.
                TOGGLE:   Toggle between normal wordwrap, dynamic wordwrap
                          and no wordwrap.

@endnode
@node "COM_Goto" "Internal command: Goto"

        @{fg shine}Goto@{fg text}

@{b}Function:@{ub}       Move the cursor to specific places in the document.
@{b}Syntax:@{ub}         LINE/N,COLUMN/N,POS/N,LASTCHANGE/S,BOOKMARK/N,INTOP/S,
                BLOCKSTART/S,BLOCKEND/S
@{b}Result:@{ub}         0  - Cursor moved.
                10 - No editor window open / selected.

@{b}Options:@{ub}        LINE:   Move the cursor to line LINE.
                COLUMN: Move the cursor to column COLUMN.
                POS:    Move the cursor POS characters from the start.
                LASTCHANGE:     - not implemented in version 1.03 -
                BOOKMARK:       Move the cursor to bookmark BOOKMARK.
                INTOP:  Make sure the line the cursor will be on is in top
                        of the editor window.
                BLOCKSTART: Move the cursor to the start of the selected
                            block.
                BLOCKEND:   Move the cursor to the end of the selected
                            block.

@endnode
@node "COM_SetBookmark" "Internal command: SetBookmark"

        @{fg shine}SetBookmark@{fg text}

@{b}Function:@{ub}       Set a bookmark.
@{b}Syntax:@{ub}         BOOKMARK/N
@{b}Result:@{ub}         0  - Done.
                10 - No editor window open / selected.

@{b}Options:@{ub}        BOOKMARK:       Which bookmark is to be set (1-10).

@{b}See also:@{ub}       @{"Goto" LINK COM_Goto}

@endnode
@node "COM_Backspace" "Internal command: Backspace"

        @{fg shine}Backspace@{fg text}

@{b}Function:@{ub}       Remove text on the left side of the cursor.
@{b}Syntax:@{ub}         CHARS/N,WORD/S,SOL/S
@{b}Result:@{ub}         0  - Done (if possible).
                10 - No editor window open / selected.

@{b}Options:@{ub}        CHARS:  Remove CHARS characters.
                WORD:   Remove 1 word.
                SOL:    Remove everything left of the cursor.

@endnode
@node "COM_Delete" "Internal command: Delete"

        @{fg shine}Delete@{fg text}

@{b}Function:@{ub}       Remove text on the right side of the cursor.
@{b}Syntax:@{ub}         CHARS/N,WORD/S,EOL/S
@{b}Result:@{ub}         0  - Done (if possible).
                10 - No editor window open / selected.

@{b}Options:@{ub}        CHARS:  Remove CHARS characters.
                WORD:   Remove 1.
                EOL:    Remove everything right of the cursor.

@endnode
@node "COM_Line" "Internal command: Line"

        @{fg shine}Line@{fg text}

@{b}Function:@{ub}       Edit a document on a level of lines.
@{b}Syntax:@{ub}         INSERT/S,REMOVE/S,SPLIT/S,JOIN/S,SWAP/S,DOUBLE/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window open / selected.

@{b}Options:@{ub}        INSERT: Insert a line before the line the cursor is on.
                REMOVE: Remove the line the cursor is on.
                SPLIT:  Same as a return.
                JOIN:   Join the next line with the current line.
                SWAP:   Swap the current line with the previous one.
                DOUBLE: Insert a line after the current one and copy the
                        current line to it.

@endnode
@node "COM_Insert" "Internal command: Insert"

        @{fg shine}Insert@{fg text}

@{b}Function:@{ub}       Insert a string, file or character at the cursor position.
@{b}Syntax:@{ub}         TEXT/K,FILE/K,ASCI/N,NOMOVE/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window open / selected.

@{b}Options:@{ub}        TEXT:   Insert a string (example: Insert TEXT="Hello", this
                        will insert the string 'Hello'). (For some more
                        information about how to enter a string please see:
                        @{"AmigaDOS arguments" LINK AmigaDOS_Arguments}).
                FILE:   Insert a file.
                ASCI:   Insert a character with this ASCI number.
                NOMOVE: If this option is selected the cursor won't move,
                        otherwise the cursor will move as if the text was
                        typed on the keyboard.

@endnode
@node "COM_File" "Internal command: File"

        @{fg shine}File@{fg text}

@{b}Function:@{ub}       Open, load or save a file, change it's name, open a new one
                and some other useful things.
@{b}Syntax:@{ub}         NAME/K,NEW/S,OPEN/S,LOAD/S,SAVE/S,CLOSE/S,CLEAR/S,REVERT/S,
                ADDTOPROJECT/S,ASK/S
@{b}Result:@{ub}         0  - Done.
                10 - Failed or
                     No editor window opened / selected.

@{b}Options:@{ub}        NAME:   The name of the file you want to OPEN, LOAD or
                        create with NEW. The name that should be given to
                        the current file. The name of the file that should
                        be saved (This will change the name of file you are
                        editing).
                NEW:    Open a new editor window.
                OPEN:   Open a new editor window and load the file [NAME] in
                        it.
                LOAD:   Load the file [NAME] in the current editor window.
                SAVE:   Save the text in the current editor window in the
                        file [NAME].
                CLOSE:  Close the current editor window.
                CLEAR:  Clear the text in the current editor window.
                REVERT: Revert the text in the current editor window to the
                        last saved version.
                ADDTOPROJECT:   Add the file in the current editor window to
                                the current window.
                ASK:    Don't use the file [NAME] but ask for a file using a
                        filerequester.

@endnode
@node "COM_EOLMode" "Internal command: EOLMode"

        @{fg shine}EOLMode@{fg text}

@{b}Function:@{ub}       Define what the cursor should do when it is on the end of
                the line and a 'CursRight' command is given (or when the
                right arrow is pressed on the keyboard).
@{b}Syntax:@{ub}         WRAP/S,STOP/S,IGNORE/S
@{b}Result:@{ub}         0  - Ok

@{b}Options:@{ub}        WRAP:   The cursor will move to the start of the next line,
                        if you give a 'CursLeft' command at the start of a
                        line the cursor will move to the end of the previous
                        line.
                STOP:   The cursor will never jump to the next or previous
                        line when a 'CursRight' or 'CursLeft' command is
                        given.
                IGNORE: The cursor will move on more step to the right,
                        'CursLeft' will do the same as in WRAP mode. 

@endnode
@node "COM_CursorWrap" "Internal command: CursorWrap"

        @{fg shine}CursorWrap@{fg text}

@{b}Function:@{ub}       Define what the cursor should do when a 'CursUp' or
                'CursDown' command is given which would move the cursor to
                a place after the end of the previous or next line.
@{b}Syntax:@{ub}         ON/S,OFF/S
@{b}Result:@{ub}         0  - Ok

@{b}Options:@{ub}        ON:     The cursor will now move to the last character of
                        the next or previous line.
                OFF:    The cursor will only move up and down regardless of
                        where that would be.

@{b}See also:@{ub}       @{"EOLMode" LINK COM_EOLMode}

@endnode
@node "COM_WriteProtect" "Internal command: WriteProtect"

        @{fg shine}WriteProtect@{fg text}

@{b}Function:@{ub}       This function allows you to lock a document and prevent it
                from being edited (useful for include files for example).
@{b}Syntax:@{ub}         ON/S,OFF/S,TOGGLE/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window open / selected.

@{b}Options:@{ub}        ON:     Lock the current document.
                OFF:    Unlock the current document.
                TOGGLE: Switch between locked and unlocked mode.

@endnode
@node "COM_SetTab" "Internal command: SetTab"

        @{fg shine}SetTab@{fg text}

@{b}Function:@{ub}       Change the tab size used in the current editor window.
@{b}Syntax:@{ub}         TAB/N/A
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        TAB:    The size of the tabs.

@endnode
@node "COM_BackUps" "Internal command: BackUps"

        @{fg shine}BackUps@{fg text}

@{b}Function:@{ub}       Switch the making of backups on or off.
@{b}Syntax:@{ub}         ON/S,OFF/S
@{b}Result:@{ub}         0  - Ok.

@{b}Options:@{ub}        ON:     Backups will be made.
                OFF:    No backups will be made.

@endnode
@node "COM_AutoSave" "Internal command: AutoSave"

        @{fg shine}AutoSave@{fg text}

@{b}Function:@{ub}       Switch AutoSave mode on or of, when switched on your file
                will automatically be saved once in a while. You can also let
                AmisED ask you wether or not you want to save your file.
@{b}Syntax:@{ub}         TIME/N,ON/S,OFF/S,ASK/S
@{b}Result:@{ub}         0  - Ok.

@{b}Options:@{ub}        TIME:   Set the time that has to elapse before AmisED will
                        save your file.
                ON:     Switch AutoSave mode on.
                OFF:    Switch AutoSave mode off.
                ASK:    Let AmisED ask you wether or not you want to save
                        your file.

@endnode
@node "COM_AutoIndent" "Internal command: AutoIndent"

        @{fg shine}AutoIndent@{fg text}

@{b}Function:@{ub}       Switch AutoIndent mode on or off. When switched on and you
                insert a new line (with return) AmisED will set the cursor
                under the first text on the previous line.
@{b}Syntax:@{ub}         ON/S,OFF/S
@{b}Result:@{ub}         0  - Ok.

@{b}Options:@{ub}        ON:     Switch AutoIndent on.
                OFF:    Switch AutoIndent off.

@endnode
@node "COM_CreateIcons" "Internal command: CreateIcons"

        @{fg shine}CreateIcons@{fg text}

@{b}Function:@{ub}       Switch the creating of icons on or off. When switch on
                AmisED will save an icon and tooltypes with your file. If
                your file already has an icon, this icon will be used.
                Otherwise the icon "def_text" in the "ENV:AMIS" directory
                will be used.
@{b}Syntax:@{ub}         ON/S,OFF/S
@{b}Result:@{ub}         0  - Ok.

@{b}Options:@{ub}        ON:     Switch CreateIcons on.
                OFF:    Switch CreateIcons off.

@endnode
@node "COM_FastMode" "Internal command: FastMode"

        @{fg shine}FastMode@{fg text}

@{b}Function:@{ub}       Switch FastMode on or off. When switched on everything will
                be displayed in one color, doing this scrolling will be much
                faster on 'slower' machines.

                When switched on 'FAST' will be displayed in the statusbar.

@{b}Syntax:@{ub}         ON/S,OFF/S
@{b}Result:@{ub}         0  - Ok.

@{b}Options:@{ub}        ON:     Switch FastMode on.
                OFF:    Switch FastMode off.
                TOGGLE: Toggle between FastMode on and FastMode off.

@endnode
@node "COM_OverWrite" "Internal command: OverWrite"

        @{fg shine}OverWrite@{fg text}

@{b}Function:@{ub}       Switch OverWrite on or off. When switched on AmisED will
                replace the character the cursor is on when you press a key.
                Otherwise an character will be inserted before the character
                were the cursor is on.
@{b}
                When switched on 'OVER' will be displayed in the statusbar.

@{b}Syntax:@{ub}         ON/S,OFF/S,TOGGLE/S
@{b}Result:@{ub}         0  - Ok.

@{b}Options:@{ub}        ON:     Switch OverWrite on.
                OFF:    Switch OverWrite off.
                TOGGLE: Toggle between OverWrite on and OverWrite off.


@endnode
@node "COM_Query" "Internal command: Query"

        @{fg shine}Query@{fg text}

@{b}Function:@{ub}       Get information about the current situation.
@{b}Syntax:@{ub}         LINE/S,LINES/S,CHAR/S,LINELENGTH/S,POS/S,CHARS/S,NAME/S,
                PATH/S,FLAG/N
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        LINE:   Return the line number.
                LINES:  Return the number of lines.
                CHAR:   Return the character number of the cursor relative
                        to the start of the line (0 = first of the line).
                LINELENGTH:     Return the length of the line.
                POS:    Return the character number of the cursor relative
                        to the start of the text (0 = first of the text).
                CHARS:  Return the number of characters.
                NAME:   Return the file name of the text.
                PATH:   Return the path were this file can be found.
                FLAG:   Return the status of an internal flag. Currently the
                        following values are supported:
                        1. Overwrite ON/OFF (1/0)

@endnode
@node "COM_GetWord" "Internal command: GetWord"

        @{fg shine}GetWord@{fg text}

@{b}Function:@{ub}       Return the word the cursor is on in the second result
                variable (ARexx only).
@{b}Syntax:@{ub}         -
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        -

@endnode
@node "COM_GetLine" "Internal command: GetLine"

        @{fg shine}GetLine@{fg text}

@{b}Function:@{ub}       Return the line the cursor is on in the second result
                variable (ARexx only).
@{b}Syntax:@{ub}         -
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        -

@endnode
@node "COM_GetASCII" "Internal command: GetASCII"

        @{fg shine}GetASCII@{fg text}

@{b}Function:@{ub}       Return the ASCII code of the character the cursor is on in
                the second result variable (ARexx only).
@{b}Syntax:@{ub}         -
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        -

@endnode
@node "COM_Toolbar" "Internal command: Toolbar"

        @{fg shine}Toolbar@{fg text}

@{b}Function:@{ub}       Switch the toolbar of the selected editor window on or off.
@{b}Syntax:@{ub}         ON/S,OFF/S,TOGGLE/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        ON:     Switch the toolbar on.
                OFF:    Switch the toolbar off.
                TOGGLE: Toggle between toolbar on and off.

@endnode
@node "COM_Codebar" "Internal command: Codebar"

        @{fg shine}Codebar@{fg text}

@{b}Function:@{ub}       Switch the codebar of the selected editor window on or off.
@{b}Syntax:@{ub}         ON/S,OFF/S,TOGGLE/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        ON:     Switch the codebar on.
                OFF:    Switch the codebar off.
                TOGGLE: Toggle between codebar on and off.

@endnode
@node "COM_Statusbar" "Internal command: Statusbar"

        @{fg shine}Statusbar@{fg text}

@{b}Function:@{ub}       Switch the statusbar of the selected editor window on or
                off.
@{b}Syntax:@{ub}         ON/S,OFF/S,TOGGLE/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        ON:     Switch the statusbar on.
                OFF:    Switch the statusbar off.
                TOGGLE: Toggle between statusbar on and off.

@endnode
@node "COM_Viewerbar" "Internal command: Viewerbar"

        @{fg shine}Viewerbar@{fg text}

@{b}Function:@{ub}       Switch the viewerbar of the selected editor window on or
                off.
@{b}Syntax:@{ub}         ON/S,OFF/S,TOGGLE/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        ON:     Switch the viewerbar on.
                OFF:    Switch the viewerbar off.
                TOGGLE: Toggle between viewerbar on and off.

@endnode
@node "COM_Viewer" "Internal command: Viewer"

        @{fg shine}Viewer@{fg text}

@{b}Function:@{ub}       Change the viewer for the selected editor window.
@{b}Syntax:@{ub}         NORMAL/S,ANSI/S,AMIGAGUIDE/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        NORMAL: Switch to normal viewing mode.
                ANSI:   Switch to ANSI viewing mode.
                AMIGAGUIDE:     Switch to AmigaGuide viewing mode.

@endnode
@node "COM_Request" "Internal command: Request"

        @{fg shine}Request@{fg text}

@{b}Function:@{ub}       Display a requester with info and or a question for the
                user. The number of the button the user selected will be
                passed in the second result variable. If a value is
                requested, this value will be passed along with this text
                (separated by an '|' character, for example:
                Result2='243|1' -> number: 243, button: 1).
@{b}Syntax:@{ub}         BODY,BUTTON/K,LONG/S,VALUE/N,NOCENTRE/S,VAR/K,CANCEL/N,
                RESULTNUMBER/S,LOCALE/N,TITLE/K
@{b}Result:@{ub}         0  - Ok.
                10 - Failed (for any reason).

@{b}Options:@{ub}        BODY:   Here you can give the text you want to be displayed
                        in the requester. You can separate lines by an '|'
                        character.
                BUTTON: Here you can give the text you want in your buttons.
                        Different buttons can be separated by an '|'
                        character. An '_' character will make the letter
                        behind this character a short-cut for this button.
                        If the button name starts with an '¶' character,
                        this button will be displayed in bold text and can
                        be selected with the return key.
                LONG:   Indicates that you request a number from the user.
                        This will be done by adding a integer gadget to the
                        requester.
                VALUE:  Here you can give the starting value of the integer
                        gadget.
                NOCENTRE:       By default all text in the requester is
                                centred. If you select this option all text
                                will be left-aligned.
                VAR:    Replaces a %s in the BODY text.
                CANCEL: If you select this option, the macro or key
                        defenition you use this in will be canceled if the
                        user selects the button with the number you pass in
                        this option.
                RESULTNUMBER:   If you are expecting a value to be passed
                                (you select the LONG option) you can use
                                this option to get only this value and not
                                the button number.
                LOCALE: A locale string number, which will be used instead
                        of the text givin in BODY when available.
                TITLE:  The title of the requester.

@{b}See also:@{ub}       @{"Message" LINK COM_Message}

@endnode
@node "COM_Message" "Internal command: Message"

        @{fg shine}Message@{fg text}

@{b}Function:@{ub}       Display a message for the user in the title bar of the
                editor window.
@{b}Syntax:@{ub}         TEXT/A,TIME/N
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        TEXT:   The text to be displayed in the title bar.
                TIME:   The time the message should stay in the bar, after
                        this time the message will disappear again. (With a
                        value of nul the message will stay until it is
                        overwritten by an other message).

@{b}See also:@{ub}       @{"Request" LINK COM_Request}

@endnode
@node "COM_Find" "Internal command: Find"

        @{fg highlight}Find@{fg text}

@{b}Function:@{ub}       Find a string in the text.
@{b}Syntax:@{ub}         STRING/K,NEXT/S,PREV/S,FIRST/S,CASE/S,NOCASE/S,WORDS/S,
                NOWORDS,ASK/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        STRING: Here you can give the string you want to find.
                NEXT:   Find forward form the cursor.
                PREV:   Find backward from the cursor.
                FIRST:  Find forward from the start of the text.
                CASE:   Case sensitive: 'a' is not the same as 'A'.
                NOCASE: Case insensitive: 'a' is the same as 'A'.
                WORDS:  Look for whole words: 'testing' is not good if you
                        are looking for 'test'.
                NOWORDS:A part of a word will do as well.
                ASK:    Show the 'Find...' window.

@{b}See also:@{ub}       @{"Replace" LINK COM_Replace}

@endnode
@node "COM_Replace" "Internal command: Replace"

        @{fg shine}Replace@{fg text}

@{b}Function:@{ub}       Replace the string you found with 'Find'.
@{b}Syntax:@{ub}         REPLACE/K,NEXT/S,PREV/S,ALL/S,ASK/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        REPLACE:        The string you want to be placed on the
                                place of the found string.
                NEXT:   Find the next occurrence of the string (defined with
                        'Find') after this one has been replaced.
                PREV:   Find the previous occurrence of the string after this
                        one has been replaced.
                ALL:    Replace all found occurrences of the string.
                        (Starting from the beginning of the file).
                ASK:    Show the 'Find...' window (where you can also find
                        the replace options).

@{b}See also:@{ub}       @{"Find" LINK COM_Find}

@endnode
@node "COM_FindFunctions" "Internal command: FindFunctions"

        @{fg shine}FindFunctions@{fg text}

@{b}Function:@{ub}       Show the 'Find functions...' window.
@{b}Syntax:@{ub}         ASK/S
@{b}Result:@{ub}         0  - Ok.

@{b}Options:@{ub}        ASK:    Show the 'Find functions...' window.

@endnode
@node "COM_Block" "Internal command: Block"

        @{fg shine}Block@{fg text}

@{b}Function:@{ub}       Select / unselect a block, save it, remove it, etc.
@{b}Syntax:@{ub}         START/S,END/S,WORD/S,LINE/S,ALL/S,FROMCURS/S,UNSELECT/S,
                SAVEAS/K,SAVEREQ/S,ERASE/S,WHOLELINES/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.
                20 - WORD -> no word under cursor.
                   - WHOLELINES -> no block selected.

@{b}Options:@{ub}        START:  Set the start position of the block on the current
                        cursor position.
                END:    Set the end position of the block on the current
                        cursor position.
                WORD:   Select the word under the cursor.
                LINE:   Select the line the cursor is on.
                ALL:    Select the whole text.
                FROMCURS:       Select all text beginning at the cursor
                                position. (Same as 'Block ALL', followed by
                                'Block START')
                UNSELECT:       Unselect the block.
                SAVEAS:         Save the block in the file with the name
                                given after this keyword.
                SAVEREQ:        Save the block using a filerequester.
                ERASE:          Erase the block from the text (not copied to
                                the clipboard!).
                WHOLELINES:     Enlarge the selected area in such a way that
                                all lines in the block are completely
                                selected.

@{b}See also:@{ub}       @{"CutBlock" LINK COM_CutBlock}, @{"CopyBlock" LINK COM_CopyBlock}, @{"PasteBlock" LINK COM_PasteBlock}

@endnode
@node "COM_BlockLayout" "Internal command: BlockLayout"

        @{fg shine}BlockLayout@{fg text}

@{b}Function:@{ub}       This command can add or remove spaces at the beginning of
                all lines in a block in such a way that the text will be
                centered, left aligned or right aligned.
@{b}Syntax:@{ub}         CENTER/S,LEFT/S,RIGHT/S,JUSTIFY/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        CENTER: This will center the text on the lines in the block.
                LEFT:   This will left align the text.
                RIGHT:  This will right align the text.
                JUSTIFY:This will outline the text.

@endnode
@node "COM_BlockMode" "Internal command: BlockMode"

        @{fg shine}BlockMode@{fg text}

@{b}Function:@{ub}       With this command you can switch between normal (horizontal)
                blocks and vertical blocks. The best way to see the
                difference is try it. I don't really know how to explain
                this.
@{b}Syntax:@{ub}         HORIZONTAL/S,VERTICAL/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened.

@{b}Options:@{ub}        HORIZONTAL:     Switch to horizontal blocks.
                VERTICAL:       Swicth to vertical blocks.

@endnode
@node "COM_CutBlock" "Internal command: CutBlock"

        @{fg shine}CutBlock@{fg text}

@{b}Function:@{ub}       Remove the selected block from the text and copy it to the
                clipboard.
@{b}Syntax:@{ub}         CLIP/N
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        CLIP:   The number of the clip you want to copy the block
                        to.

@{b}See also:@{ub}       @{"Block" LINK COM_Block}, @{"CopyBlock" LINK COM_CopyBlock}, @{"PasteBlock" LINK COM_PasteBlock}

@endnode
@node "COM_CopyBlock" "Internal command: CopyBlock"

        @{fg shine}CopyBlock@{fg text}

@{b}Function:@{ub}       Copy the selected block to the clipboard.
@{b}Syntax:@{ub}         CLIP/N
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        CLIP:   The number of the clip you want to copy the block
                        to.

@{b}See also:@{ub}       @{"Block" LINK COM_Block}, @{"CutBlock" LINK COM_CutBlock}, @{"PasteBlock" LINK COM_PasteBlock}

@endnode
@node "COM_PasteBlock" "Internal command: PasteBlock"

        @{fg shine}PasteBlock@{fg text}

@{b}Function:@{ub}       Insert text from the clipboard in the text.
@{b}Syntax:@{ub}         CLIP/N
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        CLIP:   The number of the clip you want to copy the text
                        from.

@{b}See also:@{ub}       @{"Block" LINK COM_Block}, @{"CutBlock" LINK COM_CutBlock}, @{"CopyBlock" LINK COM_CopyBlock}

@endnode
@node "COM_Undo" "Internal command: Undo"

        @{fg shine}Undo@{fg text}

@{b}Function:@{ub}       Undo the last action.
@{b}Syntax:@{ub}         SHOWLIST/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        SHOWLIST:       Show a list with all undo's in memory.
                (No option:     normal undo)

@endnode
@node "COM_Redo" "Internal command: Redo"

        @{fg shine}Redo@{fg text}

@{b}Function:@{ub}       Redo the action you undid with 'Undo'.
@{b}Syntax:@{ub}         -
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        -

@endnode
@node "COM_Macro" "Internal command: Macro"

        @{fg shine}Macro@{fg text}

@{b}Function:@{ub}       Record or play a macro.
@{b}Syntax:@{ub}         NAME/K,PLAY/S,RECORD/S,STOPREC/S,ASK/S
@{b}Result:@{ub}         0  - Ok.

@{b}Options:@{ub}        NAME:   Here you can give the name of the macro that should
                        be played / recorded.
                PLAY:   Play the selected macro.
                RECORD: Record a new macro (with name NAME or if not given:
                        'New Macro').
                STOPREC:        Stop recording.
                ASK:    Show the 'Macro...' window.

@endnode
@node "COM_SelectWindow" "Internal command: Select Window"

        @{fg shine}SelectWindow@{fg text}

@{b}Function:@{ub}       Select an editor window.
@{b}Syntax:@{ub}         NAME/K,NEXT/S,PREV/S,NUMBER/N
@{b}Result:@{ub}         0  - Window selected.
                5  - No window selected.
                10 - There are no windows at all.

@{b}Options:@{ub}        NAME:   The window with this name will be selected (if there
                        is no window with the given name the function will
                        return 5 as result and no window will be selected).
                NEXT:   The next window will be selected.
                PREV:   The previous window will be selected.
                NUMBER: The window with this number will be selected (if
                        there is no window with that number the function
                        will return 5 as result and no window will be
                        selected).

@{b}See also:@{ub}       @{"Window" LINK COM_Window}, @{"ArrangeWindows" LINK COM_ArrangeWindows}

@endnode
@node "COM_Window" "Internal command: Window"

        @{fg shine}Window@{fg text}

@{b}Function:@{ub}       Change window size and position, lock or unlock a window or
                hide or reveal a window.
@{b}Syntax:@{ub}         X/N,Y/N,WIDTH/N,HEIGHT/N,LOCK/S,UNLOCK/S,HIDE/S,REVEAL/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        X:      Set the x position of the window.
                Y:      Set the y position of the window.
                WIDTH:  Set the width of the window.
                HEIGHT: Set the height of the window.
                LOCK:   Lock the window from user input (and busy pointer).
                UNLOCK: Make user input possible again.
                HIDE:   Hide the current window.
                REVEAL: Make a window visible again.

@{b}See also:@{ub}       @{"SelectWindow" LINK COM_SelectWindow}, @{"ArrangeWindows" LINK COM_ArrangeWindows}

@endnode
@node "COM_ArrangeWindows" "Internal command: ArrangeWindows"

        @{fg shine}ArrangeWindows@{fg text}

@{b}Function:@{ub}       Change the position and size of the windows in an orderly
                way.
@{b}Syntax:@{ub}         HORIZONTAL/S,VERTICAL/S,STACKED/S,DIAGONAL/S,FULLSIZE/S
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        HORIZONTAL:     All windows over the full width, equally
                                divided over the height of the screen.
                VERTICAL:       All windows over the full height, equally
                                divided over the width of the screen.
                STACKED:        The first window fullsize, the next windows
                                every time a little shorter. All title bars
                                will be visible.
                DIAGONAL:       Same as stacked, but now also every time a
                                little smaller. Now the depth gadget of
                                every window will always be visible.
                FULLSIZE:       All windows over the full screen size.

@{b}See also:@{ub}       @{"SelectWindow" LINK COM_SelectWindow}, @{"Window" LINK COM_Window}

@endnode
@node "COM_Compile" "Internal command: Compile"

        @{fg shine}Compile@{fg text}

@{b}Function:@{ub}       Compile the file (it has to be a C source code and thus the
                file name should end with .c, .cpp, .cxx, .C, .CPP or .CXX).
@{b}Syntax:@{ub}         -
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        -

@{b}See also:@{ub}       @{"Assemble" LINK COM_Assemble}, @{"Link" LINK COM_Link}, @{"Debug" LINK COM_Debug}, @{"Run" LINK COM_Run}, @{"ParserError" LINK COM_ParserError}

@endnode
@node "COM_Assemble" "Internal command: Assemble"

        @{fg shine}Assemble@{fg text}

@{b}Function:@{ub}       Assemble the file (it has to be a ASM source code and thus
                the file name should end with .a, .s, .asm, .A, .S or .ASM).
@{b}Syntax:@{ub}         -
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        -

@{b}See also:@{ub}       @{"Compile" LINK COM_Compile}, @{"Link" LINK COM_Link}, @{"Debug" LINK COM_Debug}, @{"Run" LINK COM_Run}, @{"ParserError" LINK COM_ParserError}

@endnode
@node "COM_Link" "Internal command: Link"

        @{fg shine}Link@{fg text}

@{b}Function:@{ub}       Link the file. It has to be a source code file. If so the
                file name without the extension (.a or .c, etc.) will be
                inserted in the link command string (see program settings).
@{b}Syntax:@{ub}         -
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        -

@{b}See also:@{ub}       @{"Compile" LINK COM_Compile}, @{"Assemble" LINK COM_Assemble}, @{"Debug" LINK COM_Debug}, @{"Run" LINK COM_Run}, @{"ParserError" LINK COM_ParserError}

@endnode
@node "COM_Debug" "Internal command: Debug"

        @{fg shine}Debug@{fg text}

@{b}Function:@{ub}       Debug the file. It has to be a source code file. If so the
                file name without the extension (.a or .c, etc.) will be
                inserted in the debug command string (see program settings).
                Which debug command string (Asm or C) depends on the file
                extension.
@{b}Syntax:@{ub}         -
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        -

@{b}See also:@{ub}       @{"Compile" LINK COM_Compile}, @{"Assemble" LINK COM_Assemble}, @{"Link" LINK COM_Link}, @{"Run" LINK COM_Run}, @{"ParserError" LINK COM_ParserError}

@endnode
@node "COM_Run" "Internal command: Run"

        @{fg shine}Run@{fg text}

@{b}Function:@{ub}       Run the file. It has to be a source code file. If so the
                file name without the extension (.a or .c, etc.) will be
                send to the system as a dos command.
@{b}Syntax:@{ub}         -
@{b}Result:@{ub}         0  - Ok.
                10 - No editor window opened / selected.

@{b}Options:@{ub}        -

@{b}See also:@{ub}       @{"Compile" LINK COM_Compile}, @{"Assemble" LINK COM_Assemble}, @{"Link" LINK COM_Link}, @{"Debug" LINK COM_Debug}, @{"ParserError" LINK COM_ParserError}

@endnode
@node "COM_ParserError" "Internal command: ParserError"

        @{fg shine}ParserError@{fg text}

@{b}Function:@{ub}       Go to a line where an error was reported by the compiler or
                assembler.
@{b}Syntax:@{ub}         NEXT/S, PREVS/, FIRST/S, LAST/S
@{b}Result:@{ub}         0 - Ok.

@{b}Options:@{ub}        NEXT:   Go to the line with the next error.
                PREV:   Go to the line with the previous error.
                FIRST:  Go to the line with the first error.
                LAST:   Go to the line with the last error.

@{b}See also:@{ub}       @{"Compile" LINK COM_Compile}, @{"Assemble" LINK COM_Assemble}, @{"Link" LINK COM_Link}, @{"Debug" LINK COM_Debug}, @{"Run" LINK COM_Run}

@endnode
@node "COM_Project" "Internal command: Project"

        @{fg shine}Project@{fg text}

@{b}Function:@{ub}       Open or save a project, start a new one, close the active
                project or show the 'Project Manager' window.
@{b}Syntax:@{ub}         NAME/K,NEW/S,OPEN/S,SAVE/S,CLOSE/S,MANAGER/S
@{b}Result:@{ub}         0  - Ok.

@{b}Options:@{ub}        NAME:   The file name of the project you want to open,
                        create or the file name were you want to save the
                        selected project to. ('.prj' will be added).
                NEW:    Start a new project with name NAME, if not given you
                        will get a filerequester to enter a name.
                OPEN:   Open the project with file name NAME, if not given a
                        filerequester will be used.
                SAVE:   Save the selected project in file NAME, if not given
                        a filerequester will be used.
                CLOSE:  Close the selected project.
                MANAGER:Show the 'Project Manager' window.

@endnode
