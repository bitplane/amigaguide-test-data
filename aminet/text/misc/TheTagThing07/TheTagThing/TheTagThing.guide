@node MENU_LOAD "The Tag Thing Menus:  Project - Open & Append"
@toc MENUS

@{bg shine}@{u}Project            @{uu}@{bg background}
         :
@{bg shine}Open...        [A]O@{bg background}
@{bg shine}Append...      [A]+@{bg background}
         :


@{u}@{b}Open...@{ub}@{uu}
  Opens a file requester; the selected file will replace the current tag file.

@{b}Menu Shortcut:@{ub}  <Right Amiga> O


@{u}@{b}Append...@{ub}@{uu}
  Opens a file requester; the selected file will be appended to the current tag
file.

@{b}Menu Shortcut:@{ub}  <Right Amiga> +
@endnode


@node MENU_SAVE "The Tag Thing Menus:  Project - Save & Save As"
@toc MENUS

@{bg shine}@{u}Project            @{uu}@{bg background}
         :
@{bg shine}Save           [A]S@{bg background}
@{bg shine}Save As...     [A]A@{bg background}
         :


@{u}@{b}Save@{ub}@{uu}
  Saves the contents of the listview using the name in the @{"Tag File" link GAD_QFILE} gadget.
If this is blank, a file requester will open.

@{b}Menu Shortcut:@{ub}  <Right Amiga> S


@{u}@{b}Save As...@{ub}@{uu}
  Opens a file requester allowing the listview contents to be saved under a
different name.

@{b}Menu Shortcut:@{ub}  <Right Amiga> A
