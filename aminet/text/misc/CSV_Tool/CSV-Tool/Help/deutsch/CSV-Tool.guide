@node PROLOG "CSV-Tool Hilfe:  Prolog"
@smartwrap
@font helvetica.font 13
@toc MAIN
@{jleft}@{lindent 8}

@{Title_Header "P R O L O G"}
@{Title_String "Ein paar generelle, einleitende Worte"}
@{Title_Footer "zu dem verwendeten Vorlagensystem."}
@{lindent 8}


@{bold "D"}ieses Programm unterstützt die nachfolgenden Platzhalter,
innerhalb der dafür vorgesehenen Vorlagen (@{bold "Bitte beachten"}):@{par}


Innerhalb der @{white "@{b}Vorlagen@{ub}"}: @{Menu_Title " Header "} @{Menu_Title " Footer "}@{par}

@{" [FILENAME] " link "EXPORT"}  (FILE#? bezogen auf die Importdatei)@{par}
    |_@{white "Platzhalter für den"} @{bold "Dateinamen"} [ohne Endung] - (Englisch: @{bold "FILENAME"})@{par}

@{" [FILECOMMENT] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für den"} @{bold "Dateikommentar"} - (Englisch: @{bold "FILECOMMENT"})@{par}

@{" [FILEDATE] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für das"} @{bold "Dateidatum"} [DD-Mon-YYYY] - (Englisch: @{bold "FILEDATE"})@{par}

@{" [FILETIME] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für die"} @{bold "Dateizeit"} [HH:MM:SS] - (Englisch: @{bold "FILETIME"})@{par}

@{" [FILESIZE] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für die"} @{bold "Dateigröße"} - (Englisch: @{bold "FILESIZE"})@{par}

@{" [THEDATE] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für das"} @{bold "aktuelle Datum"} [DD-Mon-YYYY] - (Englisch: @{bold "THEDATE"})@{par}

@{" [THETIME] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für die"} @{bold "aktuelle Uhrzeit"} [HH:MM:SS] - (Englisch: @{bold "THETIME"})@{par}


Innerhalb der @{white "@{b}Vorlagen@{ub}"}: @{Menu_Title " Even Lines "} @{Menu_Title " Odd Lines "}@{par}

@{" [COUNT] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für den aktuellen"} @{bold "Zeilenzähler"} - (Englisch: @{bold "COUNTER"})@{par}

@{" [CELL_A] " link "EXPORT"} bis @{" [CELL_Z] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für die aktuellen"} @{bold "Zellenwerte"} - (Englisch: @{bold "CELLS"})@{par}

@{" [INDEXFILE] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für den Namen der"} @{bold "Exportdatei"}@{par}

@{" [RECORDFILE] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für den Namen des aktuellen"} @{bold "Datensatzes"}@{par}


Innerhalb der @{white "@{b}Vorlage@{ub}"}: @{Menu_Title " Columnes "}@{par}

@{" [COLUMN_A] " link "EXPORT"} bis @{" [COLUMN_Z] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für die"} @{bold "Spaltentitel"} - (Englisch: @{bold "COLUMNES"})@{par}


Innerhalb der @{white "@{b}Vorlage@{ub}"}: @{Menu_Title " Records "}@{par}

@{" [COUNT] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für den aktuellen"} @{bold "Zeilenzähler"} - (Englisch: @{bold "COUNTER"})@{par}

@{" [CELL_A] " link "EXPORT"} bis @{" [CELL_Z] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für die aktuellen"} @{bold "Zellenwerte"} - (Englisch: @{bold "CELLS"})@{par}

@{" [COLUMN_A] " link "EXPORT"} bis @{" [COLUMN_Z] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für die"} @{bold "Spaltentitel"} - (Englisch: @{bold "COLUMNES"})@{par}

@{" [INDEXFILE] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für den Namen der"} @{bold "Exportdatei"}@{par}

@{" [RECORDFILE] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für den Namen des aktuellen"} @{bold "Datensatzes"}@{par}

@{" [PREVRECORD] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für den Namen des vorigen"} @{bold "Datensatzes"}@{par}

@{" [NEXTRECORD] " link "EXPORT"}@{par}
    |_@{white "Platzhalter für den Namen des nächsten"} @{bold "Datensatzes"}@{par}
@{pard}


@endnode

