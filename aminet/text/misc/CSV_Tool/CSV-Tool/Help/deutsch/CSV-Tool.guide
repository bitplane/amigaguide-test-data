@node MENUS "CSV-Tool Hilfe:  Menüs"

@{white "@{b}Tabulatorseite@{ub}"}: @{Menu_Title " Import "} @{Menu_Title " Format "} @{Menu_Title " Export "}

 @{Menu_Title " Project "}
 @{Menu_ItemKS " New             " "N"} - Eine neue, leere Projekt-Datei erstellen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Open...         " "O"} - Eine existierende Projekt-Datei öffnen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Save            " "S"} - Das aktuelle Projekt speichern.
 @{Menu_ItemKS " Save as...      " "A"} - Das aktuelle Projekt unter neuem Namen speichern.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Help            " "H"} - Dieses Dokument aufrufen und anzeigen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " about CanDo...  " "?"} - Dialogfenster mit Infos über die Programmiersprache anzeigen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Quit            " "Q"} - Alles schließen und das Programm beenden.


@{white "@{b}Tabulatorseite@{ub}"}: @{Menu_Title " Export "}

 @{Menu_Title " Edit "}
 @{Menu_ItemKS " Cut             " "X"} - Den aktuellen Text ausschneiden.
 @{Menu_BR-Bar " Copy...         "}
     @{Menu_ItemKS " All         " "C"} - Den aktuellen Text kopieren.
     @{Menu_ItemKS " Line        " "L"} - Die aktuelle Zeile kopieren.
     @{Menu_ItemKS " Word        " "W"} - Das aktuelle Wort kopieren.
 @{Menu_ItemKS " Paste           " "V"} - Den Inhalt der Zwischenablage einfügen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Replace         " "R"} - Den Text durch den Inhalt der Zwischenablage ersetzen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_BR-Bar " Delete...       "}
     @{Menu_ItemKS " All         " "E"} - Den aktuellen Text löschen.
     @{Menu_ItemKS " to SOL      " "<"} - Zum Anfang der aktuellen Zeile löschen.
     @{Menu_ItemKS " to EOL      " ">"} - Zum Ende der aktuellen Zeile löschen.
     @{Menu_ItemKS " Line        " "-"} - Die aktuelle Zeile löschen.
     @{Menu_ItemKS " Word        " "."} - Das aktuelle Wort löschen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Clone Line      " "+"} - Die aktuelle Zeile verdoppeln.
 @{Menu_ItemKS " Trim Line       " "#"} - Überflüssige Leerzeichen in der aktuellen Zeile löschen.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_BR-Bar " Word Case to... "}
     @{Menu_ItemKS " UPPER       " "U"} - Das aktuelle Wort in Großschreibung.
     @{Menu_ItemKS " lower       " "\\"} - Das aktuelle Wort in Kleinschreibung.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_BR-Bar " Search...       "}
     @{Menu_ItemKS " String      " "F"} - Öffnet das Dialogfenster zum Suchen.
     @{Menu_ItemKS " Next        " "G"} - Nächste Zeichenkette finden.
     @{Menu_ItemKS " Word        " ","} - Nächstes Vorkommen des aktuellen Wortes finden.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_BR-Bar " Replace...      "}
     @{Menu_ItemKS " String      " "P"} - Öffnet das Dialogfenster zum Suchen und Ersetzen.
     @{Menu_ItemKS " Next        " "B"} - Nächste gefundene Zeichenkette durch die Ersatzzeichenkette ersetzen.
     @{Menu_ItemKS " All         " "T"} - Die Suchzeichenkette durch die Ersatzzeichenkette global ersetzen.

@endnode

@node KEYS "CSV-Tool Hilfe:  Tastatur"
@smartwrap
@font helvetica.font 13
@{jleft}@{lindent 8}

@{Title_Header "T A S T A T U R"}
@{Title_String "Die @{b}Tasten-Kürzel@{ub} zum schnellen"}
@{Title_Footer "Zugriff auf wichtige Funktionen."}
@{lindent 8}


@{white "@{b}Tabulatorseite@{ub}"}: @{Menu_Title " Import "} @{Menu_Title " Format "} @{Menu_Title " Export "}@{par}

@{Key_Button "N"} - @{white "neues Projekt"}  (Englisch: @{bold "N"}ew)@{par}
|_@{italic "...das Tasten-Kürzel zum Erstellen eines neuen, leeren Projektes."}@{par}

@{Key_Button "O"} - @{white "Projekt öffnen"}  (Englisch: @{bold "O"}pen)@{par}
|_@{italic "...das Tasten-Kürzel zum Öffnen einer existierenden Projekt-Datei mittels Datei-Requester."}@{par}

@{Key_Button "S"} - @{white "Projekt speichern"}  (Englisch: @{bold "S"}ave)@{par}
|_@{italic "...das Tasten-Kürzel zum Speichern der aktuellen Projekt-Datei unter dem aktuellen Pfad/Namen."}@{par}

@{Key_Button "A"} - @{white "Projekt speichern als"}  (Englisch: Save @{bold "A"}s)@{par}
|_@{italic "...das Tasten-Kürzel zum Speichern der aktuellen Projekt-Datei unter einem neuen Pfad/Namen."}@{par}

@{Key_Button "H"} | @{Key_Pressed "Help"} - @{white "Hilfe aufrufen"}  (Englisch: @{bold "H"}elp)@{par}
|_@{italic "...die Tasten-Kürzel zum Aufruf dieses Dokumentes."}@{par}

@{Key_Button "Q"} - @{white "Programm beenden"}  (Englisch: @{bold "Q"}uit)@{par}
|_@{italic "...das Tasten-Kürzel zum Beenden des Programmes."}@{par}


@{white "@{b}Tabulatorseite@{ub}"}: @{Menu_Title " Export "}@{par}

@{Key_Button "X"} - @{white "Text ausschneiden"}  (Englisch: Cut)@{par}
|_@{italic "...das Tasten-Kürzel zum Ausschneiden des aktuellen Textes."}@{par}

@{Key_Button "C"} - @{white "Text kopieren"}  (Englisch: @{bold "C"}opy)@{par}
|_@{italic "...das Tasten-Kürzel zum Kopieren des aktuellen Textes."}@{par}

@{Key_Button "V"} - @{white "Text einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen der letzten Kopie."}@{par}

@{Key_Button "R"} - @{white "Text wieder herstellen"}  (Englisch: @{bold "R"}eplace)@{par}
|_@{italic "...das Tasten-Kürzel zum Ersetzen des aktuellen Textes durch den Inhalt der Zwischenablage."}@{par}

@{Key_Button "L"} - @{white "Zeile kopieren"}  (Englisch: copy @{bold "L"}ine)@{par}
|_@{italic "...das Tasten-Kürzel zum Kopieren der aktuellen Zeile."}@{par}

@{Key_Button "W"} - @{white "Wort kopieren"}  (Englisch: copy @{bold "W"}ord)@{par}
|_@{italic "...das Tasten-Kürzel zum Kopieren des aktuellen Wortes."}@{par}

@{Key_Button "E"} - @{white "Text leeren"}  (Englisch: @{bold "E"}mpty)@{par}
|_@{italic "...das Tasten-Kürzel zum Leeren des aktuellen Textes."}@{par}

@{Key_Button "<"} | @{Key_Pressed "Shift"} @{Key_Pressed "Back"} - @{white "Zum Zeilenanfang löschen"}  (Englisch: @{bold "S"}tart @{bold "O"}f @{bold "L"}ine)@{par}
|_@{italic "...das Tasten-Kürzel zum Löschen bis zum Zeilenanfang."}@{par}

@{Key_Button ">"} | @{Key_Pressed "Shift"} @{Key_Pressed "Del"} - @{white "Zum Zeilenende löschen"}  (Englisch: @{bold "E"}nd @{bold "O"}f @{bold "L"}ine)@{par}
|_@{italic "...das Tasten-Kürzel zum Löschen bis zum Zeilenende."}@{par}

@{Key_Button "-"} - @{white "Zeile löschen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Löschen der aktuellen Zeile."}@{par}

@{Key_Button "."} - @{white "Wort löschen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Löschen des aktuellen Wortes."}@{par}

@{Key_Button "+"} - @{white "Zeile verdoppeln"}@{par}
|_@{italic "...das Tasten-Kürzel zum Verdoppeln der aktuellen Zeile."}@{par}

@{Key_Button "#"} - @{white "Zeile trimmen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Trimmen der aktuellen Zeile."}@{par}

@{Key_Button "U"} - @{white "Großschreibung"}  (Englisch: @{bold "U"}ppercase)@{par}
|_@{italic "...das Tasten-Kürzel für Großschreibung."}@{par}

@{Key_Button "\\"} - @{white "Kleinschreibung"}@{par}
|_@{italic "...das Tasten-Kürzel für Kleinschreibung."}@{par}

@{Key_Button "F"} - @{white "Suchfenster"}  (Englisch: @{bold "F"}ind)@{par}
|_@{italic "...das Tasten-Kürzel zum Öffnen des Suchfensters."}@{par}

@{Key_Button "G"} - @{white "Suche nächstes"}@{par}
|_@{italic "...das Tasten-Kürzel zum Finden der nächsten Zeichenkette."}@{par}

@{Key_Button ",."} - @{white "Suche Wort"}@{par}
|_@{italic "...das Tasten-Kürzel zum Finden des nächsten Vorkommen des aktuellen Wortes."}@{par}

@{Key_Button "P"} - @{white "Such- und Ersetzfenster"}  (Englisch: re@{bold "P"}lace)@{par}
|_@{italic "...das Tasten-Kürzel zum Öffnen des Suchen- und Ersetzenfensters."}@{par}

@{Key_Button "B"} - @{white "Ersetze nächstes"}@{par}
|_@{italic "...das Tasten-Kürzel zum Ersetzen der nächst gefundenen Zeichenkette."}@{par}

@{Key_Button "T"} - @{white "Ersetze alles"}  (Englisch: replace @{bold "T"}otal)@{par}
|_@{italic "...das Tasten-Kürzel zum globalen Ersetzen aller gefundenen Zeichenketten."}@{par}



@{Key_Pressed "F1"} - @{bold "[CELL_A]"} --> @{Key_Pressed "F10"} - @{bold "[CELL_J]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen der Platzhalter für den "}@{heavy "1. "}@{italic "bis "}@{heavy "10. Zellenwert "}@{par}


@{Key_Pressed "Shift"} @{Key_Pressed "F1"} - @{bold "[COLUMN_A]"} --> @{Key_Pressed "Shift"} @{Key_Pressed "F10"} - @{bold "[COLUMN_J]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen der Platzhalter für den "}@{heavy "1. "}@{italic "bis "}@{heavy "10. Spaltentitel "}@{par}


@{Key_Pressed "Alt"} @{Key_Pressed "F1"} - @{bold "[FILENAME]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen des Platzhalters für den "}@{heavy "Dateinamen "}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F2"} - @{bold "[FILECOMMENT]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen des Platzhalters für den "}@{heavy "Dateikommentar "}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F3"} - @{bold "[FILEDATE]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen des Platzhalters für das "}@{heavy "Dateidatum "}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F4"} - @{bold "[FILETIME]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen des Platzhalters für die "}@{heavy "Dateizeit "}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F5"} - @{bold "[FILESIZE]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen des Platzhalters für die "}@{heavy "Dateigröße "}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F6"} - @{bold "[THEDATE]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen des Platzhalters für das "}@{heavy "aktuelle Datum "}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F7"} - @{bold "[THETIME]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen des Platzhalters für die "}@{heavy "aktuelle Uhrzeit "}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F8"} - @{bold "[INDEXFILE]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen des Platzhalters für den Namen der "}@{heavy "Exportdatei "}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F9"} - @{bold "[RECORDFILE]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen des Platzhalters für den Namen des "}@{heavy "aktuellen Datensatzes "}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F10"} - @{bold "[COUNT]"} @{white "einfügen"}@{par}
|_@{italic "...das Tasten-Kürzel zum Einfügen des Platzhalters für den "}@{heavy "Zeilenzähler "}@{par}
@{lindent 8}

@endnode

@node MOUSE "CSV-Tool Hilfe:  Maus"
@smartwrap
@font helvetica.font 13
@{jleft}@{lindent 8}

@{Title_Header "M A U S"}
@{Title_String "Hier gibt es Informationen die"}
@{Title_Footer "sonst nirgendwo hinpaßten."}
@{lindent 8}


@{bold "MERKE:"}@{lindent 24}
    Wenn Sie ein @{white "Piktogramm"} auf das Fenster von @{bold "CSV-Tool"} ziehen,
überprüft das Programm ob es sich um eine Projekt-Datei handelt,
und lädt diese dann gegebenenfalls ein.@{par}
Falls Sie ein @{white "Piktogramm"} auf das Fenster ziehen,
dass einem Verzeichnis entspricht, und die aktuelle @{white "@{b}Tabulatorseite@{ub}"}: @{Menu_Title " Export "} ist,
dann sucht das Programm in diesem Verzeichnis nach den Vorlagendateien...@{par}

@{blue "Columnes.tpl EvenLines.tpl Footer.tpl Header.tpl OddLines.tpl Records.tpl"}@{par}

...und lädt diese dann gegebenenfalls als Set ein.
@{lindent 8}


@endnode

@node IMPORT "CSV-Tool Hilfe:  Import"
@smartwrap
@font helvetica.font 13
@{jleft}@{lindent 8}

@{Title_Header "I M P O R T"}
@{Title_String "@{B}A@{UB} - Import der Datenliste als"}
@{Title_Footer "CSV-Datei in zwei Schritten."}


@{bold "Bereich I"}@{lindent 24}

Import File@{par}
@{" Pfad:zu/der/Datei                                      " link ""}@{"   " link ""}@{par}

Als Erstes muß eine @{white "CSV"}- bzw. @{white "TSV"}-Datei eingeladen werden.
Die ersten beiden Zeilen dieser Datei erscheinen dann als Vorschau.@{par}

Preview of the first three Lines@{par}
@{Menu_BR-Bar " ID;LastName;FirstName;ZIP;Adress;Country      "}@{par}
@{Menu_BR-Bar " 01;Doe;John;4011 NY;First Avenue 183;U.S.A. "}@{par}
@{Menu_BR-Bar " 02;Doe;Jane;4011 NY;First Avenue 183;U.S.A. "}@{par}
@{lindent 8}


@{bold "Bereich II"}@{lindent 24}

Cell Separator Character@{par}
@{"   " link ""} Comma @{tab}@{"   " link ""} Semicolon@{tab}@{"   " link ""} Tabulator@{tab}@{"   " link ""}@{" ; " link ""} Char@{tab}@{par}

Value Prefix / Suffix Character@{par}
@{"   " link ""} Dbl. Quote@{tab}@{"   " link ""} Sgl. Quote@{tab}@{"   " link ""} None@{tab}@{tab}@{"   " link ""}@{"   " link ""} Char@{tab}@{par}

Als Zweites müssen die Zeichen definiert werden, die einmal zur Separation der @{white "Zellinhalte "}
und eventuell zur Klammerung der @{white "Zellwerte"} benutzt werden sollen. Das Programm ermittelt
@{bold "selbsständig"} die gebräuchlichsten Zeichenkombinationen.@{par}
Die Interpretation der gemachten Einstellungen der zweiten Zeile erscheinen dann als Vorschau.@{par}

Preview of the Value Interpretation@{par}
@{Menu_Title " [COLUMN_A] "} @{Menu_Title " [COLUMN_B] "} @{Menu_Title " [COLUMN_C] "} @{Menu_Title " [COLUMN_D] "} @{Menu_Title " [COLUMN_E] "}@{par}
@{" 01                " link ""}@{" Doe              " link ""}@{" John             " link ""}@{" 4011 NY        " link ""}@{" First Avenue " link ""}@{par}

@{"   " link ""} @{white "use #1 Line as Columnes"}@{par}

@{bold "#1 Line as Columnes"} - Die erste Zeile definiert die Spaltenüberschriften.@{par}

@{"   " link ""} start at #2 Line@{par}

@{bold "start at #2 Line"} - Die erste Zeile wird ignoriert.@{par}


@endnode

@node FORMAT "CSV-Tool Hilfe:  Format"
@smartwrap
@font helvetica.font 13
@{jleft}@{lindent 8}

@{Title_Header "F O R M A T"}
@{Title_String "@{B}B@{UB} - @{U}Optionale@{UU} Formatierung der"}
@{Title_Footer "Spaltenwerte in einem Schritt."}


@{bold "Bereich I"}@{lindent 24}

@{uline "Optional"} kann eine Formatierung der Daten nach Spalten erfolgen.@{par}

@{"    Columne    " link ""}@{" Original Value           " link ""}@{" Formated Value           " link ""}@{par}
@{Menu_Title  " [COLUMN_A]   01                              01                              "}@{par}
@{Menu_BR-Bar " [COLUMN_B]   Doe                            Doe                            "}@{par}
@{Menu_BR-Bar " [COLUMN_C]   John                           John                          "}@{par}
@{Menu_BR-Bar " [COLUMN_D]   4011 NY                      4011 NY                    "}@{par}
@{Menu_BR-Bar " [COLUMN_E]   First Avenue 183           First Avenue 183        "}@{par}
@{Menu_BR-Bar " [COLUMN_F]   U.S.A.                          U.S.A.                        "}@{par}
@{Menu_BR-Bar " [COUNT]         2                                 2                               "}@{par}

@{"   " link ""} @{white "trim String"} @{tab}@{"   " link ""} UPPER Case @{tab}@{"   " link ""} lower Case @{par}

@{bold "trim String"} - Entfernt alle Leerzeichen vom Anfang und Ende der
Zeichenkette, sowie alle doppelten Leerzeichen innerhalb der Zeichenkette.
@{bold "UPPER Case"} - Wandelt die Zeichenkette in Großbuchstaben oder
@{bold "lower Case"} in Kleinbuchstaben um.@{par}

@{"   " link ""} @{white "if empty..."}@{tab}@{"                                       " link ""} insert this Value@{par}

@{bold "if empty"} - Falls kein Wert vorhanden ist, setzte nachfolgende Zeichenkette ein.@{par}

@{"   " link ""} @{white "format numeric Value"}  @{"                           " link ""} with this Pattern@{par}

@{bold "format numeric Value"} - Formatiere numerische Werte mittels nachfolgender @{" Maske " link "PATTERN"}.@{par}

@{"   " link ""} @{white "max. Chars"} @{tab}@{Menu_BR-Bar "   1   "} @{"                                                        " link ""}@{par}

@{bold "max. Chars"} - Reduziere die maximale Anzahl darzustellender Zeichen auf den nachfolgenden Wert.@{par}


@{"   " link ""} the [COUNT]er starts at @{tab}@{Menu_BR-Bar "    1    "} @{"                                       " link ""}@{par}

@{bold "Counter"} - Legt die Startnummer fest mit der der Zeilenzähler anfängt.@{par}

@endnode

@node EXPORT "CSV-Tool Hilfe:  Export"
@smartwrap
@font helvetica.font 13
@{jleft}@{lindent 8}

@{Title_Header "E X P O R T"}
@{Title_String "@{B}C@{UB} - Export der Datenliste als"}
@{Title_Footer "(HTML?)-Datei in zwei Schritten."}


@{bold "Bereich I"}@{lindent 24}

Als Erstes sollten die Vorlagendateien erstellt bzw. eingeladen werden.
Dazu bieten sich die Zwischenablage, externe Dateien oder der @{white "integrierte Editor"} an.
Das Programm unterstützt bestimmte @{" Platzhalter " link "PROLOG"} innerhalb der Vorlagen.@{par}

Template Documents@{tab}@{tab}@{tab}@{tab}@{tab}@{tab}    @{"  Records  " link ""}@{par}
@{"   Header   " link ""}@{"  Columnes  " link ""}@{"  Even Lines  " link ""}@{"  Odd Lines  " link ""}@{"   Footer   " link ""}@{par}
|_@{bold "Header"}@{tab}@{tab}- @{white "Kopfnoten"}@{par}
|_@{bold "Columnes"}@{tab}- @{white "Spaltentitel"}@{par}
|_@{bold "Even Lines"}@{tab}- @{white "Gerade Zeilen"}@{par}
|_@{bold "Odd Lines"}@{tab}- @{white "Ungerade Zeilen"}@{par}
|_@{bold "Footer"}@{tab}@{tab}- @{white "Fussnoten"}@{par}
|_@{bold "Records"}@{tab}@{tab}- @{white "Datensätze"}@{par}

@{" Line: <n> of <n> · Column: <n> of <n> · Size: <n> · ASCII: <n>  " link ""}@{par}
|_@{bold "Line"}@{tab}- @{white "Zeile <Nummer> von <Anzahl>"}@{par}
|_@{bold "Column"}@{tab}- @{white "Spalte <Nummer> von <Anzahl>"}@{par}
|_@{bold "Size"}@{tab}- @{white "Anzahl der Bytes des Dokumentes"}@{par}
|_@{bold "ASCII"}@{tab}- @{white "Nummer des aktuellen Zeichens in der ASCII-Tabelle"}@{par}

@{"   Load...    " link ""}@{"   Load Set   " link ""}@{tab}@{tab}@{tab}@{"   Save Set   " link ""}@{"  Save as   " link ""}@{par}

@{bold "Load Set"} - Auswahl eines Verzeichnisses das Vorlagendateien enthält.
Das Programm sucht in diesem Verzeichnis nach den Vorlagendateien
@{blue "Columnes.tpl EvenLines.tpl Footer.tpl Header.tpl OddLines.tpl Records.tpl"}
 und lädt diese dann gegebenenfalls nacheinander als Set ein.@{par}

@{bold "Save Set"} - Auswahl eines Verzeichnisses in das die Vorlagendateien
unter den Dateinamen @{blue "Columnes.tpl EvenLines.tpl Footer.tpl Header.tpl OddLines.tpl Records.tpl"}
 abgespeichert werden sollen.@{par}
@{lindent 8}

@{bold "Bereich II"}@{lindent 24}

Export File@{par}
@{" Pfad:zu/der/Datei                                      " link ""}@{"   " link ""}@{par}

Als Zweites muß ein @{white "Datei"}-Name bzw. -Pfad zur Speicherung des Exports definiert werden.@{par}

@{"   " link ""} ...use HTML Char Encoding@{par}

@{bold "HTML Char Encoding"} - Alle Zeichen oberhalb von ASCII 127 werden nach dem HTML-Muster maskiert
(z.B. aus Ü wird &Uuml;).@{par}

@{"   " link ""} @{white "Record List"}@{par}

@{bold "Record List"} - Alle Datensätze @{italic "(bzw. Indexe) "}werden als Liste in die
unter @{bold "Export File"} definierte Datei geschrieben.@{par}

@{"   " link ""} single File@{par}

@{bold "single File"} - Sowohl die Indexliste, als auch alle Datensätze werden in eine einzige Datei
geschrieben @{italic "(z.B. AmigaGuide-Datei)."}@{par}

@{"   " link ""} multiple Records@{par}

@{bold "multiple Records"} - Alle Datensätze werden in einzelne Dateien abgespeichert.@{par}

Name @{"              " link ""} [COUNT] @{"              " link ""} .Suffix@{par}

Definition der Dateinamen der zu schreibenden Datensätze.@{par}
@{pard}

@endnode

