@ENDNODE
@NODE MW_BY "Gadgets - BY:"
@{CODE}@{JCENTER}@{FG SHINE}HTML Map Maker

@{FG TEXT}Version : @{FG HIGHLIGHT}1.03
@{FG TEXT}Release Date : @{FG HIGHLIGHT}18 August 1997.@{FG TEXT}
