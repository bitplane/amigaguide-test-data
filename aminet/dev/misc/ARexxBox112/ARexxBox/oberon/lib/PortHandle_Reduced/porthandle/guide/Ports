@Node "--interface--()" "Ports/--interface--"

DEFINITION Ports;

IMPORT
  e := Exec;

TYPE
  PortPtr = POINTER TO Port;
  Port = RECORD (BT.ANYDesc) 
    port : e.MsgPortPtr;
    PROCEDURE (VAR port:Port) Uninit;
    PROCEDURE (VAR port:Port) Handle();
  END;
  PublicPortPtr = POINTER TO PublicPort;
  PublicPort = RECORD (Port) 
    name : ARRAY 80 OF CHAR;
  END;

CONST
  upperCase = 0;
  onlyOne = 1;

PROCEDURE Init(VAR port: Port): BOOLEAN;
PROCEDURE ShanghaiPort(VAR port: Port; p: e.MsgPortPtr);

END Ports.

@EndNode

@Node "Init()" "Ports/Init"

   NAME
       Init -- initialize private Port

   SYNOPSIS
       Init (VAR port: Port): BOOLEAN;

   FUNCTION
       Creates a message port and enters it to port.port.

   INPUTS
       port  - Port structure to be initialized

   RESULT
       FALSE if the message port couldn't be created

   SEE ALSO
       InitPublic(), @{"exec/CreateMsgPort()" Link "exec/CreateMsgPort()"}

@EndNode

@Node "Port.Handle()" "Ports/Port.Handle"

   NAME
       Port.Handle -- handle messages arrived at the port (method)

   SYNOPSIS
       (VAR port: Port) Handle;

   FUNCTION
       ** none, abstract method **
       should become redefined by a concrete method by subclasses.

@EndNode

@Node "Port.Uninit()" "Ports/Port.Uninit"

   NAME
       Port.Uninit -- delete private Port              (method)

   SYNOPSIS
       (VAR port: Port) Uninit;

   FUNCTION
       Replies all pending messages and deletes the MessagePort
       associated with port

   SEE ALSO
       @{"exec/DeleteMsgPort()" Link "exec/DeleteMsgPort()"}, @{"exec/ReplyMsg()" Link "exec/ReplyMsg()"}

@EndNode

@Node "ShanghaiPort()" "Ports/ShanghaiPort"

   NAME
       ShanghaiPort -- enter a message port into Port

   SYNOPSIS
       ShanghaiPort (VAR port: Port; p: e.MsgPortPtr);

   FUNCTION
       Enters an already existing message port (e.g. a windows
       user port) into the port, so it can be handled like a
       port allocated with @{"Init()" Link "Init()"}.

       Port must not be initialized.
       You MUST NOT call Uninit() for this Port structure
       afterwards.

   NOTES
       Do NOT call this procedure for public ports exept you know
       exactly what you are doing.

   INPUTS
       p  - pointer to an already allocated Exec.MessagePort

   SEE ALSO
       @{"exec/ports.h/MsgPort" Link "exec/ports.h/Main" 29}

@EndNode

