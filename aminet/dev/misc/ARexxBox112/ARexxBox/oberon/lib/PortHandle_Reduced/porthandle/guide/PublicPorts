@Node "--interface--()" "PublicPorts/--interface--"

DEFINITION PublicPorts;

IMPORT
  e := Exec;

TYPE
  PublicPortPtr = POINTER TO PublicPort;
  PublicPort = RECORD (Ports.Port) 
    name : ARRAY 80 OF CHAR;
  END;

CONST
  upperCase = 0;
  onlyOne = 1;

PROCEDURE Init(VAR port: PublicPort; name: e.STRPTR; default: ARRAY OF CHAR; 
pri: SHORTINT; flags: SET): BOOLEAN;

END PublicPorts.

@EndNode

@Node "Init()" "PublicPorts/Init"

   NAME
       Init -- initialize a public Port

   SYNOPSIS
       Init (VAR port: PublicPort;
                 name: e.STRPTR;
              default: ARRAY OF CHAR;
                  pri: SHORTINT;
                flags: SET): BOOLEAN;

   FUNCTION
       Creates a public message port, adds it to the public port list
       and enters it to port.port.

       If the upperCase flag is set, the port name will become uppercase.

       If the onlyOne flag is set, the function doesn't try to make the
       port name unique by appending a '.#' where # is a number. If there
       already exists a port with this name, the function will fail.

       If name is not given or points to an empty string, default will
       be used as name. This is useful for supplying name as user given
       option (e.g. parameter).
       default must be null terminated.

       If neither of the flags and name is supplied the ports name will
       become default appended by '.1'. If this name is not unique, the
       number will be incremented by 1 for each try.

   INPUTS
       port    - PublicPort to be initialized
       name    - points to a null terminated string
       default - name to be used if name is NIL or points to
                 an empty string
       pri     - priority the port shouls become
       flags   - additional function flags (see --interface--)

   RESULT
       FALSE if initialization failed

   SEE ALSO
       Ports/Init(), @{"exec/CreateMsgPort()" Link "exec/CreateMsgPort()"}

@EndNode

@Node "PublicPort.Uninit()" "PublicPorts/PublicPort.Uninit"

   NAME
       PublicPort.Uninit -- delete a public Port         (method)

   SYNOPSIS
       (VAR port: PublicPort) Uninit;

   FUNCTION
       Removes port from the public port list, replies all pending
       messages and deletes the MessagePort associated with port.

   SEE ALSO
       Port.Uninit(), @{"exec/DeleteMsgPort()" Link "exec/DeleteMsgPort()"}, @{"exec/ReplyMsg()" Link "exec/ReplyMsg()"}

@EndNode

