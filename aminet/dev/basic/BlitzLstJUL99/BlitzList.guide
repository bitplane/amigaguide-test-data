Check attached. Thats how it`s done, you need amigalibs.res
, amigalibsII.res, mui.res, mui2.res or amigalibsNCS.res setup int
the compiler menu.

There are a few rastport tests in there ;)

Hope this helps,
Cya.

> Kind regards
-- 

Rob,
-- 
MAILTO:loki@sds.in2home.co.uk | #ICQ:# 27181384
#FAX:# 0870 0888470
#SDS FOUNDER:# URL: http://www.satanicdreams.freeserve.co.uk/
#PROJECT INFO:# Minimum Safe Distance [####------ 40% ish complete. ]
#HOME OF:# /MorrisTheMaggot, BB2MUIUpdate, TimeSwipe, NIB,/
/CTTM2, BlitzBFB, Prefs2000 & TMS. And too much other stuff./
[ "What sort of frog?"    "A *dead* frog." ]

--BOUNDARY.274957936.2
Content-Disposition: attachment; filename="WindowTest.ASC"

;
; Crap(tm) Window Test.
;

  WbToScreen 0                       ; Find a screen.
  RRandomize Timer                   ; Randomize off timer.

  Window 0,0,0,400,200,$1800,"",0,1  ; Open a window.

  *Win.Window = Peek.l(Addr Window(0)) ; Peek the address.

  SetAPen_ *Win\RPort,1   ; Setup.
  Move_ *Win\RPort,0,0    ;

  While Joyb(0)=0
    VWait

    Count+1

    X.w=Int(Rnd(400))           ;
    Y.w=Int(Rnd(200))           ; Tests.
    Draw_ *Win\RPort,X.w,Y.w    ;

    If Count>=30
      Count=0
      ScrollRaster_ *Win\RPort,Int(RRnd(-20,20)),Int(RRnd(-20,20)),0,0,400,200
    EndIf

  Wend




--BOUNDARY.274957936.2

