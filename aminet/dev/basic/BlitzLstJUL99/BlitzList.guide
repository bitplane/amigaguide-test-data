Content-Disposition: attachment; filename="ASMPeekTest.ASC"

;
; Pull a byte from mem test.
;


  Function.b ArseHole{*B}
    MOVE   D0,A0
    MOVE.b (A0),D0
    AsmExit
;    Function Return X.b
  End Function

  *mem=AllocMem(200,1)
  If *mem<>0
    Poke.b *mem,40
    NPrint "Basic Peek: ",Peek.b(*mem)
    NPrint "ASM Peek:   ",ArseHole{*mem}

    FreeMem *mem,200
  EndIf




