--BOUNDARY.273567144.1
Content-Disposition: attachment; filename="SAFI.ASC"

;
; SDS Application information reader V1.00
; (C) Satanic Dreams Software 1999
; Simple CLI version. GUI version to be written later.
;

Function.s SDSStripTrail{STRIP$}
  For XXX=0 To Len(STRIP$)
    If Done=0
      Chopped$=Mid$(STRIP$,XXX,1)
      Values=Asc(Chopped$)
      If Values<32 OR Values>126
        Done$=Mid$(STRIP$,7,XXX-7)
        Done=1
      EndIf
    EndIf
  Next
  Function Return Done$
End Function


If NumPars=0
  DefaultOutput
  NPrint "Not enough arguments."
  End
EndIf

If NumPars>1
  DefaultOutput
  NPrint "Too many arguments."
  End
EndIf

If Par$(1)="?"
  DefaultOutput
  NPrint "SDSGUI Application File Inspector, SAFI V1.00. (CLI Version!)"
  NPrint "Written by Robert Hutchinson (14/04/1999)."
  NPrint ""
  NPrint " USAGE: SAFI <executable_file_path>"
  NPrint "    EG: SAFI "+Chr$(34)+"RAM:SAFI"+Chr$(34)
  NPrint ""
  End
Else

  Dim Binary$(10)
  Dim Types$(3)
  Dim FindPos(3)
  Dim FindByte(3)
  Types$(0)="$VER:"
  Types$(1)="$APP:"
  Types$(2)="$AUT:"
  Types$(3)="$TYP:"

  DefaultOutput
  NPrint "SDSGUI Application File Inspector, SAFI V1.00. (CLI Version!)"
  NPrint "Attempting to Examine executable..."
  NPrint ""

  If ReadFile(0,Par$(1))
    FileInput 0
    CaseSense Off

    For TMP=0 To 10
      If NOT Eof(0)
        Binary$(TMP)=Edit$(1000)
      EndIf
    Next

    CloseFile 0
    DefaultOutput

    For TSP=0 To 10
      If Instr(Binary$(TSP),"SHDRA",1)<>0
        Found=TSP
      EndIf
    Next

    If Found=0
      NPrint "Executable is not an SDSGUI Application."
      End
    EndIf

    For TSP=0 To 3
      For TMP=0 To 10
        DaByte=Instr(Binary$(TMP),Types$(TSP),1)
        If DaByte<>0
          FindPos(TSP)=TMP
          FindByte(TSP)=DaByte
        EndIf
      Next
    Next

    SDSVER$=Mid$(Binary$(FindPos(0)),FindByte(0),200)
    SDSAPP$=Mid$(Binary$(FindPos(1)),FindByte(1),200)
    SDSAUT$=Mid$(Binary$(FindPos(2)),FindByte(2),200)
    SDSTYP$=Mid$(Binary$(FindPos(3)),FindByte(3),200)

    SDSVER$=SDSStripTrail{SDSVER$}
    SDSAPP$=SDSStripTrail{SDSAPP$}
    SDSAUT$=SDSStripTrail{SDSAUT$}
    SDSTYP$=SDSStripTrail{SDSTYP$}

    NPrint "  Application Version:   ",SDSVER$
    NPrint "  Application Name:      ",SDSAPP$
    NPrint "  Application Author(s): ",SDSAUT$
    NPrint "  Application Type:      ",SDSTYP$
    NPrint ""
    End

  Else
    NPrint "Cant find file: `"+Par$(1)+"'"
    End
  EndIf
EndIf

End




--BOUNDARY.273567144.1

