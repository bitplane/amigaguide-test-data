--------------822C3A3D0FE156D456A1E4A8
Encoding: 7bit
Content-Disposition: inline; filename="IffLibTest.bb2"

; TestAnim5 - By Mathias 'Corto' PARNAUDEAU

; 28/07/99

; Just an example to show how to save a small anim (2 frames !)

; -> Change the name of the images to load
;    ... and the image sizes, the viewmode, and ... that's all

WBStartup
NoCli

Screen 0,0,0,640,256,3,$8000,"Sauve Iff Anim",1,2
ScreensBitMap 0,0

BitMap 1,640,256,3
BitMap 2,640,256,3

LoadBitMap 1,"Images:pic1.iff",1
CopyBitMap 1,0
Use Palette 1
ShowBitMap 0

err.l=CSaveFirstFrame(1,"ram:anim.anim",640,$8000,1)

LoadBitMap 2,"Images:pic2.iff",2

Use Palette 1
CopyBitMap 2,0
ShowBitMap 0

err.l=CSaveNextFrame(1,2,"ram:anim",640,1)

; Just to check everything is alright
s=RTEZRequest("ErreurNum",Str$(err.l),"Ok")

End





--------------822C3A3D0FE156D456A1E4A8

