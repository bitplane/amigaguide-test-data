--BOUNDARY.1748706216.1
Content-Disposition: attachment; filename="DefTool.asc"
Content-Description: Nearly there?


; change filename below - make sure your file actually HAS
; a default tool first!

d$="ram:amigerman.txt" ; default tool of this is "ppmore"

*do.DiskObject=GetDiskObjectNew_(&d$)

If *do

  dt$=Peek$(&*do\do_DefaultTool)

  FreeDiskObject_(*do)

Else Request "","Didn't get icon...","OK"
EndIf

NPrint dt$

MouseWait

End



--BOUNDARY.1748706216.1

