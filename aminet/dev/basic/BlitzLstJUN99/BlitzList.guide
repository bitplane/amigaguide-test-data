For additional commands, e-mail: blitz-list-help@netsoc.ucd.ie



@ENDNODE
@NODE "Mail_124" "Re: DiskFree"
From: James L Boyd <jamesboyd@all-hail.freeserve.co.uk>
Date: Fri, 18 Jun 1999 18:13:09 +0100
Subject: Re: DiskFree
X-UIDL: 0f33417dc2a68fcda9c13c4afba809e9

--BOUNDARY.1748363312.1

Victor Bell churned out *this* drivel:

> I've just discovered a problem with the 'DiskFree' command - it returns
> a value of 0 if you 'AnalyzeDisk "Ram:"'  Probably because Ram: is always
> 100% full.
 
> Does anyone know a better way?

I do!

See the attached, and yes, it works for the RAM: disk :)
 
See ya,
-- 
<tsb>
<sb>James L Boyd - jamesboyd@all-hail.freeserve.co.uk
<sb>Member of Team *AMIGA*, and *Dogbert's New Ruling Class.*
<sb>Connected from Dundee, Scotland. 
<sb>(http://surf.to/all-hail/)
<tsb>

Tact is the ability to describe others as they see themselves.
-- Abraham Lincoln

--BOUNDARY.1748363312.1
Content-Disposition: attachment; filename="info.asc"
Content-Description: Disk info


d$="Sys:"

lock.l=Lock_(&d$,#MODE_OLDFILE)

If lock

  DEFTYPE.InfoData id

  If Info_(lock,&id)

    NPrint "Disk information for ",d$
    NPrint ""

; ****** What you want! ******
    NPrint "Disk size   : ",id\id_NumBlocks*id\id_BytesPerBlock," bytes"
    NPrint "In use      : ",id\id_NumBlocksUsed*id\id_BytesPerBlock," bytes"

; remember that the Workbench windows' "in-use/free" readouts are
; only approximate!

; ****************************

    Print  "Disk state  : "

    Select id\id_DiskState
      Case #ID_WRITE_PROTECTED
        NPrint "Disk is write-protected"
      Case #ID_VALIDATING
        NPrint "Disk is validating"
      Case #ID_VALIDATED
        NPrint "Disk is OK!"
    End Select

    NPrint "Soft errors : ",id\id_NumSoftErrors

    Print  "Disk type   : "

    Select id\id_DiskType
      Case #ID_NO_DISK_PRESENT
        NPrint "Disk not present"
      Case #ID_UNREADABLE_DISK
        NPrint "Disk unreadable/corrupt"
      Case #ID_DOS_DISK
        NPrint "OFS disk"
      Case #ID_FFS_DISK
        NPrint "FFS disk"
      Case #ID_INTER_DOS_DISK
        NPrint "International OFS disk"
      Case #ID_INTER_FFS_DISK
        NPrint "International FFS disk"
      Case #ID_FASTDIR_DOS_DISK
        NPrint "Diskcached OFS disk"
      Case #ID_FASTDIR_FFS_DISK
        NPrint "Diskcached FFS disk"
      Case #ID_NOT_REALLY_DOS
        NPrint "Non-DOS disk"
      Case #ID_KICKSTART_DISK
        NPrint "Kickstart disk"
      Case #ID_MSDOS_DISK
        NPrint "MS-DOS disk"
    End Select

  EndIf

UnLock_ lock

Else End
EndIf

MouseWait
End


--BOUNDARY.1748363312.1

