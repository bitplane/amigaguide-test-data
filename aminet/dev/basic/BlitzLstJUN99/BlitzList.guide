@NODE "Mail_279" "Including a picture - with NCS-Libs"
From: Leigh Parry <lparry@free4all.co.uk>
Date: Wed, 23 Jun 1999 01:43:29 +0000
Subject: Including a picture - with NCS-Libs
X-UIDL: 6d915e547399037aed895274d00cd48d

--BOUNDARY.19376528.2

Hello,

I would like to know if it's possible to 'IncBin' a picture (iff) into an
executable which uses the N-Libs by Frederic.

Cya,

    Leigh.

-- 
<sb>
<sb>Leigh Parry
<sb>EMail: lparry@free4all.co.uk
<sb>URL: www.free0024068.free4all.co.uk
<sb>
<sb>Smile - People will wonder what you're thinking.
<sb>

--BOUNDARY.19376528.2
Content-Disposition: attachment; filename="picture-no-incbin"

; Statements : PointerOff {} : PointerOn {}
; Author : James L Boyd - jamesboyd@all-hail.freeserve.co.uk

Statement PointerOff {}
  Delay_ 1
  Poke.w $dff096,$20
  Delay_ 1
End Statement

Statement PointerOn {}
  Delay_ 1
  Poke.w $dff096,$8020
  Delay_ 1
End Statement

DEFTYPE .l

WBStartup

; N-LIBS VERSION

NInitScreen 0
NInitBitMap 0
NInitPalette 0
NInitPicture 0

If NLoadPicture(0,"ram:picture")>0      ; HAVE TO LOAD FILE
  NGetPicturePalette 0,NPictureID
  If NBitMap(0,NPictureWidth,NPictureHeight,NPictureDepth)
    If NScreen(0,NPictureWidth,NPictureHeight,NPictureDepth,0)
      NDisplayPalette 0,NScreenID
      NPictureToBitmap 0,NBitMapID
      NDrawingOutput NScreenRastPort
      NCopybitMap NBitMapID,0,0,0,0,NPictureWidth,NPictureHeight
    EndIf
  EndIf
EndIf

; Normal way

;BitMap 0,320,256,8
;ILBMGrab ?pic,0,0                       ; CAN 'INCBIN' FILE
;
;Screen 0,0,0,320,256,6,0,"",-1,-1
;ShowPalette 0
;
;Window 0,0,0,320,256,$800,"",-1,-1
;BitMaptoWindow 0,0

;-------------------

_rest
PointerOff{}

XBDecodeSound 0,?snd

Delay_ 100
XBSound 0,15

Delay_ 250
PointerOn{}

Free XBSound 0
;Free BitMap 0
;Free Window 0
;Free Screen 0
End

;pic
;  IncBin "Ram:pictur"
snd
  IncBin "Ram:sample"


--BOUNDARY.19376528.2

