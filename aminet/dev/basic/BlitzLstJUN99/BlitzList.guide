Content-Disposition: attachment; filename="screennotifytest.asc"
Encoding: binary

DEFTYPE .l
WBStartup
NoCli
WbToScreen 0
WBenchToFront_

#SCREENNOTIFY_TYPE_CLOSESCREEN=3
#SCREENNOTIFY_TYPE_PUBLICSCREEN=3
#SCREENNOTIFY_TYPE_PRIVATESCREEN=3
#SCREENNOTIFY_TYPE_WORKBENCH=3

NEWTYPE .ScreenNotifyMessage
  snm_Message.Message
  snm_Type.l
  snm_Value.l
End NEWTYPE

Statement CreateWindow {}
  DefaultIDCMP #IDCMP_CLOSEWINDOW
  Window 0,20,20,200,100,$E,"ScreenNotify Test",-1,-1
End Statement

*p.MsgPort=CreateMsgPort_ ()
If *p
  *AWC=AddWorkbenchClient_(*p,0)
  If *AWC
    CreateWindow{}
    *Win.Window=Peek.l(Addr Window(0))
    active=True
    If *Win
      portmask = 1 LSL *p\mp_SigBit
      winmask  = 1 LSL *Win\UserPort\mp_SigBit
      While active
        sigs=Wait_(portmask|winmask)
        If (sigs AND portmask)
          *snm.ScreenNotifyMessage=GetMsg_(*p)
          If *snm\snm_Type=#SCREENNOTIFY_TYPE_WORKBENCH
            Select *snm\snm_Value
              Case 0                                        ; shut window down
                If *Win
                  Free Window 0
                  Free Screen 0
                  *Win=0
                  winmask=0
                End If
              Case 1
                If Win=0                                    ; re-open window (any drawing needs to be re-done)
                  WbToScreen 0                              ; along with any gadgets etc.
                  CreateWindow{}
                  *Win.Window=Peek.l(Addr Window(0))
                  winmask=1 LSL *Win\UserPort\mp_SigBit
               End If
            End Select
          End If
          ReplyMsg_(*snm)
        End If
        If (sigs AND winmask)
          *msg.IntuiMessage=GetMsg_(*Win\UserPort)
          If *msg\Class=#IDCMP_CLOSEWINDOW
            active=False
            ReplyMsg_(*msg)
          End If
;
;        if *msg\Class=#IDCMP_ -> events - gosub routines to handle them
;
        End If
      Wend
      Free Window 0
    End If
    Repeat
      suc=RemWorkbenchClient_(*AWC)
      Delay_ 10
    Until suc
  End If
  DeleteMsgPort_(*p)
End If
End






--BOUNDARY.19675240.1
