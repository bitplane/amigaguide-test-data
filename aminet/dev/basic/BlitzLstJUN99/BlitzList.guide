--BOUNDARY.2016210656.2
Content-Disposition: attachment; filename="laced.bb2"
Content-Description: Interlaced Coplist. Might be hires as well.

; Description:  Make a hires laced display using displaylib. Not sure about
;               some of the code.
; Type:         BLITZ

WBStartup
CloseEd
NoCli

#BPLMOD1=$108
#BPLMOD2=$10A
#BPLCON0=$100

;Width of the bitmap. Dunno why this is 1088, change it.
;May have to be a mutiple of 16... I can't remember.
#Bitmapsize=1088
#Modulo=(((#Bitmapsize-320)/8)-2)*2

;Build our user copperlist for Laced displays.
COP$=Mki$(#BPLMOD1)+Mki$(#Modulo)
COP$+Mki$(#BPLMOD2)+Mki$(#Modulo)
COP$+Mki$(#BPLCON0)+Mki$($f004)

BitMap 0,#Bitmapsize,512,7
InitPalette 0,128
For i=1 To 127
  AGAPalRGB 0,i,i*2,100,Int(Rnd*256)
Next

;Init our laced copperlist.
InitCopList 0,44,256,$11517,8,128,-3
DisplayUser 0,0,COP$

;Go to BLITZ mode.
VWait 50
BLITZ
CreateDisplay 0
DisplayBitMap 0,0
DisplayPalette 0,0
Use BitMap 0

;Swap between odd and even lines.
SetInt 5
  If Peek($dff004)<0
    DisplayBitMap 0,0,0,0
  Else
    DisplayBitMap 0,0,0,1
  EndIf
End SetInt

;Draw some junk.
For i=0 To 30
  x1=Int(Rnd*640)
  y1=Int(Rnd*512)
  x2=Int(Rnd*640)
  y2=Int(Rnd*512)
  c=Int(Rnd*256)
  Line x1,y1,x2,y2,c
Next

MouseWait
End



--BOUNDARY.2016210656.2

