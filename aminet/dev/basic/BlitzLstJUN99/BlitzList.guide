@NODE "Mail_659" "Text scrolling"
 for scott@online.u-net.com; Tue, 1 Jun 1999 19:00:35 +0100
From: "Oliver Marks" <oly@enterprise.net>
Organization: Private
Date: 1 Jun 99 18:46:52 +0100
Subject: Text scrolling
Encoding: 7bit

Hi,

I manage to write a program that scrolls text thanks for the help but
it does not scroll it that smoothly and the scrolling seems to be one
pixel out not sure why any one have any ideas ?

WBStartup
WbToScreen 0
Use Screen 0

Dim html$(200)
count=0
counter=1
c=0
currchar=1
width=8
Window 0,0,0,800,100,$0001|$0002|$0004|$0400,"Song Scroller",0,1

LoadFont 0,"FONTS:xen.font",width
WindowFont 0

        If ReadFile(0,"textfile.txt")
            FileInput 0
            While NOT Eof(0)
                html$(count)=Edit$(800)
                count=count+1
            Wend
        EndIf
        text$=html$(0)
WLocate 0,0
While currchar<=Len(text$)
VWait 40
  WLocate 0,0
  Print Mid$(text$,currchar,30)
  For a=1 To 2
    WScroll 0,0,800,100,width/2,0
    VWait 40
  Next a
  a=0
  currchar+1
Wend
MouseWait
End

-- 
ICQ#:  33315204
Url :  http://www.homepages.enterprise.net/oly/games/index.htm



