@NODE "Mail_384" "Re: MUI Help Please ;)"
From: Rob Hutchinson <loki@sds.in2home.co.uk>
Date: Wed, 16 Jun 1999 07:50:44 +0100
Organization: Satanic Dreams Software.
Subject: Re: MUI Help Please ;)
X-UIDL: 5237831f1cd873ceb65873a767c63116

--BOUNDARY.273726384.2
Encoding: binary

Hello Daniel
     Hiya, Daniel... ,on 16-Jun-99 you mailed me about: MUI Help Please ;)! So I`ma reply`in...

[=> Hi everyone,
[=> 
[=> I've been trying to find out what object is current selected in the TAB
[=> CycleChain.
[=> 
[=> When the user hits TAB the little white box moves around the selected
[=> objects which you've set, how do you find the number of this object,
[=> i.e. the Blitz reference number.
[=> 
[=> I've got a pointer so far used like this :
[=> 
[=>    *object_active=muiget(#WINDOW,#MUIA_Window_ActiveObject)
[=> 

Attached is the only way I can see to do it.. But it works fine.. Why not
just do it this way?..

By the way, you`ll be needing MUI2.RES to compile this :).. 

Hope this is of some help.

Regards
-- 
<tsb>
<sb>*CONTACTING MEEEEEEE:*
<sb>loki@sds.in2home.co.uk | *ICQ:* 27181384
<sb>SDS FOUNDER: URL: http://www.satanicdreams.freeserve.co.uk/
<tsb>
<sb>*PROJECT INFO:*
<sb>Minimum Safe Distance [3%]
<sb>/After a few trips to the toilet, the following appeared:/
<sb>MorrisTheMaggot, CTTM2, TimeSwipe, NIB, BlitzBFB, Prefs2000 & TMS.
<sb>
<sb>This whole party'll be for nothing if they see us. - Han Solo
<tsb>

--BOUNDARY.273726384.2
Content-Disposition: attachment; filename="ActiveCycle.ASC"
Encoding: binary

  ;
  ; Test Cycle active chain. By Robert Hutchinson 1999
  ; loki@sds.in2home.co.uk
  ;
  ; This example requires NList.mcc, EFMUILib and MUI2.RES
  ; MUI2.RES can be found at: http://www.satanicdreams.freeserve.co.uk/
  ;

  WBStartup

  !StackOpen{12000} ;Add 12k to the stack, as Suggested for NLists.

  MUIApplicationTitle       "Test"
  MUIApplicationVersion     "$VER: Test 1.00 (16.06.99)"
  MUIApplicationCopyright   "(C)SDSoftware 1999"
  MUIApplicationAuthor      "Rob Hutchinson"
  MUIApplicationDescription "TEST"
  MUIApplicationBase        "TESTME"

  #MUI_App               = 0
    #MUI_Window1         = 1
      #MUI_GroupB1       = 2
        #MUI_Text1       = 3
        #MUI_GroupA1     = 4
          #MUI_NList1    = 5
          #MUI_NList1B   = 6
          #MUI_NList2    = 7
          #MUI_NList2B   = 8
          #MUI_Balance1  = 9

  Dim TB.MUIP_Toolbar_Description(20)
  Dim L1.l(1000)
  Dim L2.l(1000)
  NL1.l=&L1.l(0)
  NL2.l=&L2.l(0)

  MUIAddTags   #MUI_NList1 ,#MUIA_NList_Title,Null("This is list 1")
  MUIAddTags   #MUI_NList1 ,#MUIA_NList_SourceArray,NL1.l
  MUIAddTags   #MUI_NList1 ,#MUIA_CycleChain,1
  MUINewObject #MUI_NList1B,"NList.mcc",0
  MUINewObject #MUI_NList1 ,"NListview.mcc",#MUI_NList1B

  MUIBalanceObject #MUI_Balance1

  MUIAddTags   #MUI_NList2 ,#MUIA_NList_Title,Null("This is list 2")
  MUIAddTags   #MUI_NList2 ,#MUIA_NList_SourceArray,NL2.l
  MUIAddTags   #MUI_NList2 ,#MUIA_CycleChain,1
  MUINewObject #MUI_NList2B,"NList.mcc",0
  MUINewObject #MUI_NList2 ,"NListview.mcc",#MUI_NList1B

  MUIAddObjsHGroup #MUI_GroupA1,#MUI_NList1,#MUI_Balance1,#MUI_NList2
  MUIAddTags       #MUI_GroupA1,#MUIA_Group_HorizSpacing,2
  MUICreateHGroup  #MUI_GroupA1

  ;---------------

  MUIAddTags   #MUI_Text1,!TextFrame
  MUIAddTags   #MUI_Text1,#MUIA_Text_Contents,Null(Chr$(27)+"cHit the "+Chr$(27)+"bTAB"+Chr$(27)+"n key!")
  MUINewObject #MUI_Text1,"Text.mui",0

  MUIAddObjsVGroup #MUI_GroupB1,#MUI_Text1,#MUI_GroupA1
  MUICreateVGroup  #MUI_GroupB1

  MUICreateWindow #MUI_Window1,"Testing123 V1.0","Test",#MUI_GroupB1
  MUIAddSubWindow #MUI_Window1

  If MUICreateApplication<>True Then End
  MUIApplicationObj #MUI_App

  MUINotifyApp  #MUI_Window1,#MUIA_Window_CloseRequest,1,1
  MUINotifyApp  #MUI_Window1,#MUIA_Window_ActiveObject,#MUIV_EveryTime,2
  MUIOpenWindow #MUI_Window1

  Repeat
    ev.l=MUIEvent
    VWait

    If ev=2
      DefaultOutput
      Select MUIGet(#MUI_Window1,#MUIA_Window_ActiveObject)
        Case MUIObjLoc(#MUI_NList1)
          NPrint "ListView 1 is selected"
        Case MUIObjLoc(#MUI_NList2)
          NPrint "ListView 2 is selected"
      End Select
    EndIf

  Until ev=1


  !StackClose
  End








--BOUNDARY.273726384.2

