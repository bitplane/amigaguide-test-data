@NODE "Mail_261" "Help using screennotify.library"
From: Leigh Parry <lparry@free4all.co.uk>
Date: Sat, 26 Jun 1999 04:42:40 +0000
Subject: Help using screennotify.library
X-UIDL: e3746cbbc6e59cb2c016f1ec72673c0e

--BOUNDARY.18912192.2

Hello,

I've converted the '.fd' of 'screennotify.library' (into lib no. 218) and have
had a go at converting the example in the archive (on aminet), but have had
some problems, can someone (anyone) help me sort this out as I need this to
prevent problems with a program I'm writing.

Any help would be appreciated. 

Included is the example I converted and the '.fd' conversion

Cya,

    Leigh.

-- 
<sb>
<sb>Leigh Parry
<sb>EMail: lparry@free4all.co.uk
<sb>URL: www.free0024068.free4all.co.uk
<sb>
<sb>Smile - People will wonder what you're thinking.
<sb>

--BOUNDARY.18912192.2
Content-Disposition: attachment; filename="screennotifytest.asc"

DEFTYPE .l
WBStartup
NoCli
WbToScreen 0
WBenchToFront_

#SCREENNOTIFY_TYPE_CLOSESCREEN=3
#SCREENNOTIFY_TYPE_PUBLICSCREEN=3
#SCREENNOTIFY_TYPE_PRIVATESCREEN=3
#SCREENNOTIFY_TYPE_WORKBENCH=3

NEWTYPE .ScreenNotifyMessage
  snm_Message.Message
  snm_Type.l
  snm_Value.l
End NEWTYPE

Statement CreateWindow {}
  Window 0,20,20,200,100,$E,"ScreenNotify Test",-1,-1
End Statement

*p.MsgPort=CreateMsgPort_ ;()
If *p
  *AWC=AddWorkbenchClient_(*p,0)
  If *AWC
    CreateWindow{}
    *Win.Window=Peek.l(Addr Window(0))
    active=True
    If *Win
      portmask.b = 1 LSL *p/mp_SigBit
      winmask.b  = 1 LSL *Win/UserPort/mp_SigBit
      While active
        sigs.b=Wait_(portmask|winmask)
        If (sigs & portmask)
          *snm.ScreenNotifyMessage=GetMsg_(*p)
          While *snm
            switch=*snm/snm_Value
            If switch=True ;False or True  which is it ??????  maybe >0 ?
              If *Win
                CloseWindow 0
                *Win=0
                winmask=0
              End If
            Else
              If Win=0
                CreateWindow{}
                *Win.Window=Peek.l(Addr Window(0))
                winmask=1 LSL *Win/UserPort/mp_SigBit
              End If
            End If
            ReplyMsg_(*snm)
          Wend
        End If
        If (sigs AND winmask)
          *msg.IntuiMessage=GetMsg_(*Win/UserPort)
          If *msg/Class=#IDCMP_CLOSEWINDOW
            active=False
            ReplyMsg_(*msg)
          End If
        End If
      Wend
      CloseWindow_ *Win
    End If
    While RemWorkbenchClient_(*AWC)
      Delay_ 10
    Wend
  End If
  DeleteMsgPort_(*p)
End If
End






--BOUNDARY.18912192.2
