@NODE "Mail_256" "Re: GUIGFX-lib examples please."
From: James L Boyd <jamesboyd@all-hail.freeserve.co.uk>
Date: Wed, 30 Jun 1999 12:37:54 +0100
Subject: Re: GUIGFX-lib examples please.
X-UIDL: fefd3b14bed6d3627c189f83e684e9c8

--BOUNDARY.1747808288.1

Leigh Parry churned out *this* drivel:

> I've just been trying to use the GUIGFX library examples (by Andreas
> Falkenhahn ?) but get an error on compiling (GURU - ILLEGAL instuction) at
> the LoadPicture_ command.

Well, check for these (I know some are obvious ;)

LIBS: guigfx.library
LIBS: render.library

and :

Blitzlibs:amigalibs : guigfx1.library
Blitzlibs:amigalibs : render1.library (not sure if this is needed?)

I've attached something that was sent to the list last year (I think),
but doesn't work for me...

Also, might be worth trying to reinstall the blitzlibs with numbers >200 (ish)
because <200 often results in "GURU - Illegal instruction"s for me...

Another library you should check is mysticlib.lha, which uses guigfx and render
to do everything really easily (apparently) - saves you working directly with
those two...

See ya,
-- 
<tsb>
<sb>James L Boyd - jamesboyd@all-hail.freeserve.co.uk
<sb>Member of Team *AMIGA*, and *Dogbert's New Ruling Class.*
<sb>Connected from Dundee, Scotland. 
<sb>(http://surf.to/all-hail/)
<tsb>

Attention to health is life's greatest hindrance.
-- Plato

--BOUNDARY.1747808288.1
Content-Disposition: attachment; filename="guigfx.asc"
Encoding: quoted-printable
Content-Description: example

End

; GuiGFX Demonstration v1.1
; done by Andreas Falkenhahn `98
;
; requires: NCommandSet by AlphaSound
; ~~~~~~~~~ guigfx.res by me
;           guigfx.library by Timm Mueller
;           render.library by Timm Mueller
;           amigalibs.res by Acid
;
; features: datatype support
; ~~~~~~~~~ picture will be remapped to wb`s palette
;           support for OCS/ECS/AGA/RTG
;           realtime scaling in wb window
;           fully fontsensitive
;
; GuiGFX rules...
;
; Andreas.Falkenhahn@gmx.de, November 18th, 15:32 CET
;

WBStartup
WbToScreen 0

DEFTYPE .BitMapHeader *bmhd

Dim methods.TagItem(2)
Dim attrs.TagItem(2)

attrs(0)\ti_Tag =3D #PICATTR_Width,650
attrs(1)\ti_Tag =3D #TAG_DONE,0

MaxLen p$=3D192
MaxLen f$=3D192

p$=3D"RAM:"

*SC.Screen=3DPeek.l(Addr Screen(0))
*SCFONT.TextAttr=3D*SC.Screen\Font
*USEDFONT.TextAttr=3D*SCFONT.TextAttr
HEIGHT_WBFONT=3D(*SCFONT.TextAttr\ta_YSize)

f$=3DASLFileRequest$("Select picture :",p$,f$)

*pic.l=3DLoadPictureA_(f$,0)

If *pic

  *dto.l=3DNewDTObjectA_(f$,0)

  If *dto

    GetAttr_ #PDTA_BitMapHeader,*dto,&*bmhd

    DisposeDTObject_ *dto

    width=3D*bmhd\bmh_Width+14+HEIGHT_WBFONT
    height=3D*bmhd\bmh_Height+5+HEIGHT_WBFONT

    If Window(0,0,0,width,height,$000000F|$1000,"GuiGfx Test",1,2)
      *w.Window=3DPeek.l(Addr Window(0))
      *rp.RastPort=3DRastPort(0)
      *vp.ViewPort=3DViewPort(0)
      *dhl.l=3DObtainDrawHandleA_(0, *rp, *vp\ColorMap, 0)
      If *dhl
        *suc.l=3DDrawPictureA_(*dhl,*pic,4,HEIGHT_WBFONT+3,0)
        Repeat
           ev.l=3DWaitEvent
           Select ev
                 Case $2
                     methods(0)\ti_Tag =3D *w\Width-14-HEIGHT_WBFONT,*w\H=
eight-HEIGHT_WBFONT-5
                     methods(1)\ti_Tag =3D #TAG_DONE,0
                     *suc.l=3DDoPictureMethodA_(*pic,#PICMTHD_SCALE,metho=
ds(0))
                     If *suc
                       *suc.l=3DDrawPictureA_(*dhl,*pic,4,HEIGHT_WBFONT+3=
,0)
                     Else
                       NPrint "Error scaling picture"
                     EndIf
           End Select
        Until ev=3D$200
      Else
        NPrint "Cannot obtain pic"
      EndIf
      ReleaseDrawHandle_ *dhl
      CloseWindow(0)
    Else
      NPrint "Cannot open window"
    EndIf
    DeletePicture_ *pic
  Else
    NPrint "Error loading dto"
  EndIf
Else
  NPrint "Cannot open pic"
EndIf

End


--BOUNDARY.1747808288.1

