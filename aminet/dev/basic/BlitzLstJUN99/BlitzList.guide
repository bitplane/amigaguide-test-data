Content-Disposition: attachment; filename="asm_plot.bb2"
Content-Description: DM's (crap) asm plot function

; Description:  Implementation of an ASM plot routine. Test includes
;               a speed thing, where it shows how much of the frame
;               is taken by asm plot and how much is taken by normal
;               plot. Now that I've noticed the different for loop
;               values, my asm routine is slower.
; Type:         SYSTEM

BitMap 0,320,256,4
For i.w=0 To 15
  PalRGB 0,i,i,0,0
Next

Statement asm_plot{bmp.l, x.w, y.w, col.w}
.asmplt
  MOVEA.l  d0,a0

  MOVEQ.l #0,d0

  MOVE.w  (a0),d4           ; Get bytes needed to get to next row
  MULU.w  d2,d4             ; Get y pos byte offset

  MOVE.w  d1,d0
  ASR.w   #3,d0             ; Get x pos byte offset
  ADD.l   d0,d4             ; Get total byte offset

  NOT.b   d1                ; Get pixel in byte to alter

  MOVE.w  4(a0),d7          ; Get depth of bitmap
  ANDI.w  #$FF,d7
  SUBQ.w  #1,d7
  ADDQ.l  #8,a0             ; Move pointer to bitplanes

  'loop
  MOVE.l  (a0)+,a1          ; Get plane pointer
  ADD.l   d4,a1             ; Add total byte offset to pointer
  ASR.w   #1,d3             ; Move plane data for pixel into carry flag
  BCS     'drawme           ; If carry is set, then pixel needs to be
                            ; drawn on this plane, so do that
  BCLR    d1,(a1)           ; Else clear that pixel
  BRA     'skip             ; And jump to end of loop

  'drawme
  BSET    d1,(a1)           ; Draw pixel

  'skip
  DBRA    d7,'loop          ; Go onto next plane
  AsmExit
End Statement

InitCopList 0,$4
VWait 50
BLITZ
CreateDisplay 0
DisplayBitMap 0,0
DisplayPalette 0,0

d.l =Addr BitMap(0)

While Joyb(0)=0
  For i.w=1 To 200
    asm_plot{d, 160,128,8}
  Next
  MOVE.w #$00F,$dff180        ; The bigger the black bit
  VWait                       ; the sloweer this is
Wend

While Joyb(0)<>0:Wend

While Joyb(0)=0
  For i.w=1 To 200
    Plot 161,129,8
  Next
  MOVE.w #$0F0,$dff180
  VWait
Wend
End

--BOUNDARY.2016182992.1
Content-Disposition: attachment; filename="killer.bb2"
Encoding: quoted-printable
Content-Description: Steve Mc's killer prog

;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
; Draw a nice  starfield + cute ship animation....
; Written by Stephen McNamara of Leading Edge Software
;
; Alter #num to change the number of stars in the field,
; Higher numbers for faster processors!
; Try:    #num=3D300 for a standard 1200
;         #num=3D800 for a fastram 1200
;         #num=3D1000 (?)for a 030 50 mhz
;         #num=3D???  for a 500/600
;=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D

#num=3D1360

WBStartup

DEFTYPE.w
DEFTYPE.l h

; Lowres bitmap star field drawer
; Table points to a structure:
;                             +0=3Dnum of stars
;                             +2=3Dnull field
;                             +4=3Dlist of x,y,speed co-ordinates (words)=

BLITZ
Statement Drawfield {table.l,bitm.l,deltax.w,ytable.l}
=2ESDrawfield:
  MOVEM.l   a4-a6,-(a7)

  MOVE.l    d0,a0
  MOVE.l    d1,a6
  ADDQ.l    #8,a6
  MOVEM.l   (a6)+,a1-a4

  MOVE.l    d3,a5

  MOVE.l    d2,d4
  MOVE.w    (a0),d7
  SUBQ.w    #1,d7
  ADDQ.l    #6,a0

  LEA       'jump_table(pc),a6
  MOVEQ.l   #0,d3
  MOVEQ.l   #0,d2
  MOVEQ.l   #0,d0
  MOVEQ.l   #0,d1
'loop
  MOVE.w    (a0)+,d0
  MOVE.w    (a0),d1
  MOVE.w    2(a0),d2
  ASL.w     #1,d2

  MOVE.w    d1,d3
  ADD.w     d0,d3
  CMPI.w    #320,d3
  BLT       'okay
  SUB.w     #320,d3
'okay:
  MOVE.w    d3,d5
  ASR.w     #3,d3
  ADD.w     0(a5,d2.w),d3

  NOT.b     d5
  BCLR      d5,0(a1,d3.w)
  BCLR      d5,0(a2,d3.w)
  BCLR      d5,0(a3,d3.w)

  SUB.w     d0,d1
  BPL       'no_x_shift
  ADD.w     #320,d1
'no_x_shift:
  MOVE.w    d1,(a0)
  ADDQ.l    #4,a0

  MOVE.w    d1,d3
  ASR.w     #3,d3

  ADD.w     0(a5,d2.w),d3

  NOT.b     d1

  SUBQ.w    #1,d0
  ROL.w     #1,d0
  MOVE.w    'jump_table(pc,d0.w),d2
  JMP       'jump_table(pc,d2.w)

'jump_table:
  Dc.w      'test1-'jump_table
  Dc.w      'test2-'jump_table
  Dc.w      'test3-'jump_table
  Dc.w      'test4-'jump_table
  Dc.w      'test5-'jump_table
  Dc.w      'test6-'jump_table
  Dc.w      'test7-'jump_table
  Dc.w      'test8-'jump_table
  Dc.w      'test9-'jump_table
  Dc.w      'test10-'jump_table
  Dc.w      'test11-'jump_table
  Dc.w      'test12-'jump_table
  Dc.w      'test13-'jump_table
  Dc.w      'test14-'jump_table
  Dc.w      'test15-'jump_table
  Dc.w      'test15-'jump_table
  Dc.w      'test15-'jump_table

'test1:
  BSET      d1,0(a1,d3.w)
  BCLR      d1,0(a2,d3.w)
  BCLR      d1,0(a3,d3.w)
  DBRA      d7,'loop
  MOVEM.l   (a7)+,a4-a6
  AsmExit

'test2:
  BCLR      d1,0(a1,d3.w)
  BSET      d1,0(a2,d3.w)
  BCLR      d1,0(a3,d3.w)
  DBRA      d7,'loop
  MOVEM.l   (a7)+,a4-a6
  AsmExit

'test3:
  BSET      d1,0(a1,d3.w)
  BSET      d1,0(a2,d3.w)
  BCLR      d1,0(a3,d3.w)
  DBRA      d7,'loop
  MOVEM.l   (a7)+,a4-a6
  AsmExit

'test4:
  BCLR      d1,0(a1,d3.w)
  BCLR      d1,0(a2,d3.w)
  BSET      d1,0(a3,d3.w)
  DBRA      d7,'loop
  MOVEM.l   (a7)+,a4-a6
  AsmExit

'test5:
  BSET      d1,0(a1,d3.w)
  BCLR      d1,0(a2,d3.w)
  BSET      d1,0(a3,d3.w)
  DBRA      d7,'loop
  MOVEM.l   (a7)+,a4-a6
  AsmExit

'test6:
  BCLR      d1,0(a1,d3.w)
  BSET      d1,0(a2,d3.w)
  BSET      d1,0(a3,d3.w)
