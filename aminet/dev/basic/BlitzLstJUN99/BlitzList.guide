  WbToScreen 0
  WBenchToFront_

  ;--- Constants..
  ;
  #SScreen  =3D 1
  #SPalette =3D 0
  #SBitMap  =3D 0
  #SWidth   =3D 800
  #SHeight  =3D 800
  #SDepth   =3D 4

  ;--- The Bitmap..
  ;
  BitMap #SBitMap,#SWidth,#SHeight,#SDepth
  Use BitMap #SBitMap
  Bit.l=3DAddr BitMap(#SBitMap)

  ;--- Put shit on our bitmap..
  ;
  For TMP=3D0 To 300
    Line RRnd(0,#SWidth),RRnd(0,#SHeight),RRnd(0,#SWidth),RRnd(0,#SHeight=
),RRnd(0,2^#SDepth)
  Next

  ;--- Get a palette
  ;
  InitPalette  #SPalette,2^#SDepth
  PaletteRange #SPalette,0,2^#SDepth-1,$FF,$FF,0,$FF,0,0

  ;--- Tags for the screen.
  ;
  Dim Tags.TagItem(10)
  Tags(0)\ti_Tag  =3D #SA_BitMap,Bit
  Tags(1)\ti_Tag  =3D #SA_Quiet,1
  Tags(2)\ti_Tag  =3D #SA_Draggable,1
  Tags(3)\ti_Tag  =3D #SA_AutoScroll,1
  Tags(4)\ti_Tag  =3D #SA_Width,#SWidth
  Tags(5)\ti_Tag  =3D #SA_Overscan,#OSCAN_STANDARD
  Tags(6)\ti_Tag  =3D #SA_Height,#SHeight
  Tags(7)\ti_Tag  =3D #SA_Depth,#SDepth
  Tags(8)\ti_Tag  =3D #SA_DisplayID,0
  Tags(9)\ti_Tag  =3D #SA_SysFont,1
  Tags(10)\ti_Tag =3D #TAG_DONE,0

  ;--- Open the screen..
  ;
  ScreenTags #SScreen,"",&Tags(0)
  ;Use Screen #SScreen
  ScreenToFront_ Addr Screen(#SScreen)
  Use Palette #SPalette

  ;MouseWait
  ClickButton 0     ;heh, heh - now Intuition thinks we clicked
                    ;on the screen   ;)
  VWait 30

  ;--- Loop.
  ;
  Repeat
    VWait
  Until Joyb(0)

  End







