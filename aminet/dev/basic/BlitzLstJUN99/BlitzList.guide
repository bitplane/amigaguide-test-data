--BOUNDARY.274174912.2
Content-Disposition: attachment; filename="Screeny.ASC"
Encoding: binary


  ;
  ; Some testy screeny thingy, by Rob Hutchinson.
  ; Needs AmigaLibs.Res.
  ;

  ;--- Startup
  ;
  WBStartup
  WbToScreen 0
  WBenchToFront_

  ;--- Constants..
  ;
  #SScreen  = 1
  #SPalette = 0
  #SBitMap  = 0
  #SWidth   = 640
  #SHeight  = 512
  #SDepth   = 8

  ;--- The Bitmap..
  ;
  BitMap #SBitMap,#SWidth,#SHeight,#SDepth
  Use BitMap #SBitMap
  Bit.l=Addr BitMap(#SBitMap)

  ;--- Put shit on our bitmap..
  ;
  For TMP=0 To 300
    Line RRnd(0,#SWidth),RRnd(0,#SHeight),RRnd(0,#SWidth),RRnd(0,#SHeight),RRnd(0,2^#SDepth)
  Next

  ;--- Get a palette
  ;
  InitPalette  #SPalette,2^#SDepth
  PaletteRange #SPalette,0,2^#SDepth-1,$FF,$FF,0,$FF,0,0

  ;--- Tags for the screen.
  ;
  Dim Tags.TagItem(10)
  Tags(0)\ti_Tag  = #SA_BitMap,Bit
  Tags(1)\ti_Tag  = #SA_Quiet,1
  Tags(2)\ti_Tag  = #SA_Draggable,1
  Tags(3)\ti_Tag  = #SA_AutoScroll,1
  Tags(4)\ti_Tag  = #SA_Width,#SWidth
  Tags(5)\ti_Tag  = #SA_Overscan,#OSCAN_STANDARD
  Tags(6)\ti_Tag  = #SA_Height,#SHeight
  Tags(7)\ti_Tag  = #SA_Depth,#SDepth
  Tags(8)\ti_Tag  = #SA_DisplayID,$8004
  Tags(9)\ti_Tag  = #SA_SysFont,1
  Tags(10)\ti_Tag = #TAG_DONE,0

  ;--- Open the screen..
  ;
  ScreenTags #SScreen,"",&Tags(0)
  ScreenToFront_ Addr Screen(#SScreen)
  ClickButton 0
  Use Palette #SPalette

  MouseWait
  VWait 30

  ;--- Loop.
  ;
  Repeat
    VWait
  Until Joyb(0)

  End






--BOUNDARY.274174912.2

