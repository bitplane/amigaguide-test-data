Content-Disposition: attachment; filename="Search.asc"
X-MD2-FilePath: Cache:Search.asc

; Uses Commands from RIDosLib to search devicelist
;

#LD_DEVICES   =%100                           ;
#LD_VOLUMES   =%1000                          ; Saves using .res file
#LD_ASSIGNS   =%10000                         ;

Statement Search{}

  SearchFlags = %1                            ; Bit 1 must be set

  SearchFlags = SearchFlags | #LD_VOLUMES     ; Search for Volumes

;  SearchFlags = SearchFlags | #LD_DEVICES     ; include Devices as well ?

;  SearchFlags = SearchFlags | #LD_ASSIGNS     ; include Assigns as well ?

  GetDeviceList SearchFlags

  flag=0

  While (flag=0)
    a$=NextDevice
    If a$
      NPrint a$
    Else
      flag=1
    EndIf
  Wend

  FreeDeviceList

End Statement


Search{}

MouseWait

End


--=_=8<==MD2375436A4-7ADE408D==8<=_=

