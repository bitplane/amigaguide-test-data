Date:  Mon, 28 Jun 1999 13:27:29 -0300 (ADT)
Sender: John Mason <ah210@chebucto.ns.ca>
From: John Mason <ah210@chebucto.ns.ca>
Subject: IORequests
X-UIDL: b5b4418f7ad4f969a8b3b84daa95aad6

Hi all,

  I've been playing with IORequests and trying to read a chunk of data
directly from my CD ROM drive (for the eventual purpose of playing CD
audio).  All I have been able to get it to do is reset the drive -- when I
try to use the CMD_READ command it just stops at that point forever.  I've
pasted the code in below, if anyone can point out what I'm doing wrong I'd
appreciate it!  Thanks in advance!

-- 

John Mason   --   ICQ 17931257
http://chebucto.ns.ca/~ah210/Profile.html
Home of NewStuff and Reminder!

------

WBStartup


.vars

devname.s = "atapi.device"
unit = 2

readsize.l = 200000

DEFTYPE .IOStdReq myior  ; iorequest

.getmem

mem.l = AllocMem_(readsize, #MEMF_FAST)

If mem = 0
  Request "Error","Couldn't allocate memory!","Ok"
  End
EndIf
 
.initdevice

*myport.MsgPort = CreateMsgPort_

If *myport > 0

  *myior=CreateIORequest_(*myport, SizeOf .MsgPort+4096)

  If *myior > 0

    If OpenDevice_(&devname, unit, &myior, 0)=0

      myior\io_Length = readsize  ; set amount to read
      myior\io_Data = mem         ; set memory to fill with read data

      myior\io_Command = #CMD_READ

      result=DoIO_(&myior)

      NPrint "Start result was ",Str$(result)
      NPrint "Transferred ",Str$(myior\io_Actual), " bytes."

      If OpenFile(0, "dh1:t/cd_data")
        WriteMem 0,mem,readsize
        CloseFile 0
        NPrint "Wrote ",Str$(readsize), " bytes."
      EndIf

      MouseWait

      CloseDevice_(&myior)

    Else
      Request "Error","Couldn't open device!","Ok"
    EndIf
    DeleteIORequest_(*myior)
  Else
    Request "Error","Couldn't init IORequest!","Ok"
  EndIf
  DeleteMsgPort_(*myport)
Else
  Request "Error","Couldn't create msgport!","Ok"
EndIf

result=FreeMem_(mem, readsize)


-------


