@NODE "Mail_379" "More Prehistoric Clipped Blitter Code"
From: "Wiremu Te Kani" <tekani@yahoo.com>
Subject: More Prehistoric Clipped Blitter Code
Date: Sun, 6 Jun 1999 20:26:25 +1200
Encoding: 7bit
X-UIDL: b174bc798a88e5652a9a5f29448fef9b

------=_NextPart_000_01BEB05A.D954A160
Encoding: 7bit

Hello, Wiremu here.
-------------------

Check this out: This is a routine I managed to jury-rig together from
C and now I'm trying to convert it to assembler. The Basic routine
works just fine. It's assembler counterpart does not. It simply
doesn't blit!

I can't figure out what (or better IF) I've done anything wrong.
Maybe it's something to do with the stack(?).

The assembler routine is REMed (;) to death so it should be easier
to understand.

Here's the BBasic source.

Statement Blitfill{x1,y1,x2,y2}
  DEFTYPE.bitmap *dest
  *dest=Addr BitMap(0)
  ; /* Reserve Blitter and wait it to be free */
  BTST.b #DMAB_BLTDONE-8,DMACONR
  waitblit: BTST.b #DMAB_BLTDONE-8,DMACONR:BNE waitblit

  ; /* Set line mode, descending operation, and a minterm of 0xF0 (a) */
    Poke.w #BLTCON0,$9f0
    Poke.w #BLTCON1,$012

  ; /* Set masks */
    Poke.w #BLTAFWM,$FFFF LSL (15-(x2&15))
    Poke.w #BLTALWM,$FFFF LSR (x1&15)

  ; /* Stuff ending address of point x1,y1 into BLTAPT and BLTDPT
    tmp.l=*dest\_data[0]             ; The bitmap pointer!
    tmp.l+(y2*40)+(x2 LSR 3)         ; add the offset
    Poke.l #BLTAPT,tmp
    Poke.l #BLTDPT,tmp
  ; /* Byte width goes into BLTAMOD and BLTDMOD */
    tmp.l=40-(((x2-x1)LSR 3)+1)
    Poke.w #BLTAMOD,tmp
    Poke.w #BLTDMOD,tmp
  ; /* Start blitter operation */
    Poke.w #BLTSIZE,(((y2-y1)+1)LSL 6)+(((x2-x1)LSR 4)+1)
End Statement

      ---------------------------------------------------------
                 Now, here's the assembler version:
      ---------------------------------------------------------

Statement Bfill{x1.w,y1.w,x2.w,y2.w,Adr.l}
  UNLK    a4
  MOVEM.l d0-d7/a0-a6,-(a7) ; Bookmark
; Put Bitmap into a4
  LEA     $dff000,a5   ; a5=Blitter Pointer
  MOVE.l  d4,d6        ; d6=Adr
WaitBlit
  BTST    #6,$dff002
  BNE     WaitBlit
; Set line mode, descending operation, and a minterm of F0 (A)
  MOVE.w  #$9f0,$40(a5)  ;BLTCON0
  MOVE.w  #$00a,$42(a5)  ;BLTCON1
; Set up mask bits enclose spec. area
  MOVE.w  d2,d4       ; x2
  AND     #$f,d4      ; x2 & $f
  MOVE.w  #$f,d5      ; d5 = $f
  SUB .w  d4,d5       ; d5 = $f - (x2 & $f)
  MOVE.w  #$ffff,d4   ; d4 = $ffff
  LSL .w  d5,d4       ; d4 = $ffff lsl d5 ($f - (x2 & $f))
  MOVE.w  d4,$dff044  ;BLTAFWM
  MOVE.w  d0,d4       ; x1
  AND .w  #$f,d4      ; x1 & $f
  MOVE.w  #$ffff,d5   ; d5 = $ffff
  LSR .w  d4,d5       ; d5 = $ffff lsr d4 (x1 & $f)
  MOVE.w  d5,$dff046  ;BLTALWM
; Calculate ending address of area to fill
  MOVE.l  d6,d4       ; d4=d6 (Adr.l *dest\data[0])
  MOVE.w  d3,d5       ; d5=d3 (y2)
  MULU   #40,d5       ; d5*40 (y2*40)
  ADD .l  d5,d4       ; Adr.l+(y2*40)
  MOVE.l  d2,d5       ; d5=x2
  LSR .l  #3,d5       ; d5=x2/8
  ADD .l  d5,d4       ; *dest\_data[0]+(y2*40)+(x2 lsr 3)
  MOVE.l  d4,$dff050  ;BLTAPT
  MOVE.l  d4,$dff054  ;BLTDPT
; Calculate modulo for area
  MOVE.w  d2,d4       ; d4=x2
  SUB .w  d0,d4       ; d4=x2-x1
  LSR .w  #3,d4       ; d4=(x2-x1)/8
  ADDQ.w  #1,d4       ; d4=((x2-x1)/8)+1
  MOVE.w  #40,d5      ; d5=40
  SUB .w  d4,d5       ; d5=40-((x2-x1)/8)+1
  MOVE.w  d5,$64(a5)  ;BLTAMOD
  MOVE.w  d5,$66(a5)  ;BLTDMOD
; Start Blitter Operation
  MOVE.w  d3,d4       ; d4=y2
  SUB .w  d1,d4       ; d4=y2-y1
  ADDQ    #1,d4       ; +1
  LSL .w  #6,d4       ; d4=((y2-y1)+1)*64
  MOVE.w  d2,d5       ; d5=x2
  SUB .w  d0,d5       ; d5=x2-x1
  LSR .w  #4,d5       ; d5=(x2-x1)/16
  ADD .w  d4,d5       ; d5=(((y2-y1)+1)*64)+((x2-x1)/16)
  ADD .w  #1,d5       ; +1
  MOVE.w  d5,$58(a5)  ;BLTSIZE (FILL ME!!!)
Blitwit
  BTST    #6,$dff002
  BNE     Blitwit
  MOVEM.l (a7)+,d0-d7/a0-a6 ; Find your place
  RTS
End Statement

__________________________________________________________________________

                            OTHER STUFF:
                            ------------

I'm back to work on PUNCH-Special Edition. I'm using Manfred Linzners
CPU-Blitter routine because this game uses about 600-700K in Bobs and
I want this thing to work inside an A500 1/2Meg CHIP 1/2Meg FAST. Its
former incarnation, "PUNCH!" was written in AM*S in '94 and only used
about 200K (Suprise suprise). Yes, I realise it's sheer madness.

PUNCH-Special edition is in COLOUR for a start, and the pictures are
sharper, smoother and - well just better. Currently it requires
1.6 MEGS to run it because the Bobs haven't been divvyed up properly
and it's currently in HAM. The new versions are 16 colours per
character with a new palette for each character frame.
__________________________________________________________________________


                          ***  TRUE BLITZ!!!  ***

                     Startrek TNG ASCII impersonations:

                                   ]-)

                              Geordi La Forge

