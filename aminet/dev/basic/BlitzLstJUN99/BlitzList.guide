--BOUNDARY.31928216.1
Content-Disposition: attachment; filename="GTAtest.asc"

WBStartup : NoCli : CloseEd
Screen 1,0,0,640,512,5,$8004,"",1,2
BitMap 1,640,512,5
LoadPalette 1,"GTAcar.anbr" : Use Palette 1
LoadShape 1,"GTAcar.anbr",1
Cls 0
Buffer 1,16384
img=10
plx=100 : ply=100
ShowBitMap 1
BitMapOutput 1
VWait
Colour 31,0
Repeat
  pass+1 : If pass>50 Then pass=1
  If pass=50
    Locate 0,0 : Print "X: "+Str$(plx)+"     Y: "+Str$(ply)
    UnBuffer 1
    BBlit 1,img,plx,ply
    VWait
    If Joyx(1)=-1 AND Joyy(1)=-1
      img-1
      If img<1 Then img=36
    EndIf
    If Joyx(1)=1 AND Joyy(1)=-1
      img+1
      If img>36 Then img=1
    EndIf
    If Joyy(1)=-1
      If img=1 Then plx-5 : ply-0
      If img=2 Then plx-5 : ply-1
      If img=3 Then plx-4 : ply-2
      If img=4 Then plx-4 : ply-2
      If img=5 Then plx-3 : ply-3
      If img=6 Then plx-3 : ply-3
      If img=7 Then plx-2 : ply-4
      If img=8 Then plx-2 : ply-5
      If img=9 Then plx-1 : ply-5
      If img=10 Then plx-0 : ply-5
      If img=11 Then plx+1 : ply-5
      If img=12 Then plx+2 : ply-4
      If img=13 Then plx+2 : ply-4
      If img=14 Then plx+3 : ply-3
      If img=15 Then plx+3 : ply-3
      If img=16 Then plx+4 : ply-2
      If img=17 Then plx+4 : ply-2
      If img=18 Then plx+5 : ply-1
      If img=19 Then plx+5 : ply-0
      If img=20 Then plx+5 : ply+1
      If img=21 Then plx+4 : ply+2
      If img=22 Then plx+4 : ply+2
      If img=23 Then plx+3 : ply+3
      If img=24 Then plx+3 : ply+3
      If img=25 Then plx+2 : ply+4
      If img=26 Then plx+2 : ply+4
      If img=27 Then plx+1 : ply+5
      If img=28 Then plx-0 : ply+5
      If img=29 Then plx-1 : ply+5
      If img=30 Then plx-2 : ply+5
      If img=31 Then plx-2 : ply+4
      If img=32 Then plx-3 : ply+4
      If img=33 Then plx-3 : ply+3
      If img=34 Then plx-4 : ply+3
      If img=35 Then plx-4 : ply+2
      If img=36 Then plx-5 : ply+2
      If plx<=20 Then plx=20
      If plx=>620 Then plx=620
      If ply<=20 Then ply=20
      If ply=>450 Then ply=450
    EndIf
  EndIf
Until Joyb(1)=1


--BOUNDARY.31928216.1
