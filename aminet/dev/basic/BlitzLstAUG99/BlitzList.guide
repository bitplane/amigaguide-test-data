Men talk of killing time, while time quietly kills them.
-- Dion Boucicault 


--BOUNDARY.1749112792.4
Content-Disposition: attachment; filename="GetWBFont.asc"
Content-Description: Shows Workbench font


wb$="Workbench"

*scr.Screen=LockPubScreen_ (&wb$)

If *scr

  *scfont.TextAttr=*scr.Screen\Font
  fname$=Peek$(*scfont.TextAttr\ta_Name)
  fheight.b=*scfont.TextAttr\ta_YSize

  NPrint "Workbench font - ",fname$," : ",fheight

  UnlockPubScreen_ &wb$,*scr

Else NPrint "Failed to lock Workbench screen!"
EndIf

NPrint "":NPrint "Click mouse..."
MouseWait
End


--BOUNDARY.1749112792.4

