NResetTagList #WA_Flags , #WFLG_CLOSEGADGET | #WFLG_DEPTHGADGET | #WFLG_DRAGBAR
      NAddTag #WA_IDCMP , #IDCMP_CLOSEWINDOW
      NAddTag #WA_Title , &Title
If NWindow(0, 10, 80, 200, 150, TagList)   ; If our window is opened...

  rred.w=NObtainBestPen(255,0,0,-1)
  ggreen.w=NObtainBestPen(0,255,0,-1)
  bblue.w=NObtainBestPen(0,0,255,-1)

  NFrontColour(rred)
  NDPrint("This is our red text :-) []-[]")
  NFrontColour(bblue)
  NDPrint("and this is blue text.... []-[]")
  NFrontColour(ggreen)
  NDPrint("and green []-[]")
    Repeat
    idcmp.l = NWaitWindowEvent
  Until idcmp = #IDCMP_CLOSEWINDOW
  NCloseWindow (0)
  NReleasePen(rred)
  NReleasePen(bblue)
  NReleasePen(ggreen)
  End
Else
  NDPrint "Fail to open window ;("
  End
EndIf



