BoxWidth.w  = BoxRight - BoxLeft
GTScroller 0,1,BoxRight,BoxTop,16,BoxHeight,"",#GT_Vertical+#GT_Immediate,10,10,0
AttachGTList 0,0
GadgetBorder BoxLeft,BoxTop,BoxWidth,BoxHeight
Repeat
Until WaitEvent = #IDCMP_CLOSEWINDOW
End


--=_=8<==MD2373AFAF0-512AEA26==8<=_=

