Hi,

Below is my first attempt at assembler but it does not work could some
one tell me why?

WBStartup
WbToScreen 0
Use Screen 0
num.b=0

Macro INP
    GTInteger 0,0,10,10,50,15,"input",$4,0
    Window 0,100,100,100,100,$4|$4|$8|$400,"Assembler programs",0,1
    AttachGTList 0,0
    Repeat
    Select WaitEvent
        Case $400   ;close gadget hit
            exit=1
        Case $40     ;gadgethit
            Select GadgetHit
                Case 0
                    num=GTGetInteger(0,0)
                    exit=1
            End Select
        End Select
    Until exit=1
    exit=0
    DetachGTList 0
    Free Window 0
    Free GTList 0
    PutReg d0,num
End Macro

Macro OUP
    GetReg  d0,num
    NPrint num
End Macro

Gosub assem

MouseWait

.assem
        !INP
        MOVE.b  d0,d1
        !INP
        MOVE.b  d0,d2
        CMP.b   d1,d2
        BGT     GREAT
        MOVE.b  d2,d0
        !OUP
        MOVE.b  d1,d0
        !OUP
        RTS
GREAT:  MOVE.b  d1,d0
        !OUP
        MOVE.b  d2,d0
        !OUP
        RTS
Return





