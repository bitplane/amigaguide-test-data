Content-Disposition: attachment; filename="IEPrefs.ASC"
Encoding: binary


;
; Icon Extreme Preferences V1.0
; Types:
;   1=on/off type
;   2=File Request type
;   3=integer/string type
;   4=Path request type
;

INCLUDE "Blitz2:IconExtreme3/SourceCode/PIPEProcs.BB2"

If OpenPIPE{"DBPREFS"}=False
  TMP=Request("Error","IEDBPrefs is already running!","Ok!")
  End
EndIf

Dim Prefs$(40)

INCLUDE "Blitz2:IconExtreme3/SourceCode/IEDBPrefsSTARTUP.BB2"
PrefsBase$="ENV:IconExtremeDB.Prefs":Gosub ReadPreferences
USEPATH PrefsList()

  ListPos.w=1
  PrefsTitleString$="Icon Extreme "+VER$+" DataBase Preferences:"

  DefPrefsH=(GadHeight*3)+(4*5)+((FontSize*10)+6)+14
  DefPrefsW=TextLen{PrefsTitleString$,0}+100

  PrefsOffX=(ScreenWidth/2-(DefPrefsW/2))+4
  PrefsOffY=(ScreenHeight/2-(DefPrefsH/2))+((FontSize+4)/2)

  SizeLimits DefPrefsW,DefPrefsH,ScreenWidth,ScreenHeight

  DefaultIDCMP $40027C|$2|$100
  Window 1,PrefsOffX,PrefsOffY,DefPrefsW,DefPrefsH,$1000|$400|$2|$4|$8|$1|$20,"",1,$80

  Use Window 1
  WindowOutput 1

  GTSetMenu 1

  WTit$="Icon Extreme Icon DataBase Prefs "+VER$
  STit$=WTit$+" - CONTACT: loki@napalmdeath.freeserve.co.uk"

  WTitle WTit$,STit$:WindowFont 0:CatchDosErrs

  Gosub AddPrefsGadgets
  CloseWindow_(0)

  ResetList PrefsList()
  FirstItem PrefsList()
  Gosub ChangeAttribs

  If OpenPIPE{"DBPREFS"}=False
    TMP=Request("Error","Cant open PIPE: device!|Please mount it and try again.","Ok!")
    ClosePIPE{}
    End
  EndIf

  Repeat
    EV.l=WaitEvent
    VWait 1

    Select EV
      Case $2
        Gosub GrabCurrent
        WCls
        DetachGTList 1
        Free GTList 1
        Gosub AddPrefsGadgets
        Gosub ChangeAttribs

      Case $40
        FlushEvents
        Select GadgetHit
          Case 51
            Gosub GrabCurrent

            EC.w=EventCode
            ResetList PrefsList()
            FirstItem PrefsList()
            For ListPos.w=1 To EC
              NextItem PrefsList()
            Next
            Gosub ChangeAttribs
          Case 54
            Lock.l=RTLockWindow(1)
            RTEZSetDefaultDirectory 3,Prefs$(\ArrayData)
            Select \DataType
              Case 2
                RTEZSetDefaultDirectory 3,""
                DaFile$=RTEZLoadFile("Select a File","")

                If DaFile$<>""
                  GTSetString 1,53,DaFile$
                EndIf

              Case 4
                RTEZSetDefaultDirectory 3,Prefs$(\ArrayData)
                DaFile$=RTEZPathRequest("Select a Path")

                If DaFile$<>""
                  GTSetString 1,53,DaFile$
                EndIf

            End Select

            RTUnlockWindow 1,Lock
          Case 55
            Gosub SavePrefs

          Case 56
            Gosub UsePrefs

          Case 57
            Lock.l=RTLockWindow(1)
            TMP=Request("Discard?","Are you sure you want to discard|the current preferences?","Yes|NO!")
            If TMP=1
              ClosePIPE{}
              End
            EndIf
            RTUnlockWindow 1,Lock

        End Select
      Case $100

        Select MenuHit
          Case 0
            Select ItemHit
              Case 0:Gosub SavePrefs
              Case 1:Gosub UsePrefs

              Case 3:Gosub SaveAs

              Case 5:ClosePIPE{}:End
            End Select
        End Select
    End Select
  Until EV=$200
ClosePIPE{}
End


AddPrefsGadgets

  PWW=InnerWidth:PWH=InnerHeight

  PInnerAdd=PWW-((4*4)+4)
  ActButSize=PInnerAdd/3

  SYPos=-26+GadOff

  GTText 1,50,2,SYPos,PWW-12,GadHeight,PrefsTitleString$,$10,""

  GTTags       $80080035,0

  LVHeight=PWH-((GadHeight*3)+(4*5)+2)
    LVYPos=(SYPos+4)+GadHeight

  GTTags     $80080035,0
  GTListView 1,51,2,LVYPos,PWW-12,LVHeight,"",$1,PrefsList(),ListPos-1

  CycleWidth=TextLen{"Off/NO",0}+40
  SelectorWidth=20

  FirstRowYpos =LVYPos+LVHeight+4
  SecondRowYpos=FirstRowYpos+(GadHeight+4)

  GTCycle    1,52,2,FirstRowYpos,CycleWidth,GadHeight,"",$1,"OFF/No|ON/Yes"
  GTString   1,53,6+CycleWidth,FirstRowYpos,PWW-((6+CycleWidth)+(SelectorWidth+14)),GadHeight,"",$1,500,CurrentPref$
  GTButton   1,54,PWW-(SelectorWidth+10),FirstRowYpos,SelectorWidth,GadHeight,"<",$10

  GTButton   1,55,2,SecondRowYpos,ActButSize,GadHeight,"_Save",$10
  GTButton   1,56,6+ActButSize,SecondRowYpos,ActButSize,GadHeight,"_Use",$10
  GTButton   1,57,10+(ActButSize*2),SecondRowYpos,ActButSize,GadHeight,"_Discard",$10

  AttachGTList 1,1

  If GUIBorder=1
    GTBevelBox 1,0,0,PWW,PWH,0
  EndIf

Return


ReadPreferences
  If ReadFile(0,PrefsBase$)
    FileInput 0
    Temp=0
    While NOT Eof(0)
      Prefs$(Temp)=Edit$(500)
      Temp+1
    Wend
    GUIBorder=Val(Prefs$(1))
    If Prefs$(0)<>"#IEDBPHDR"
      TMP=Request("IEDBPrefs Request","Corrupt or Malformed|Preferences file in ENV:|Using defaults!","Ok!")
      Gosub SetPrefsAsDefaults
    EndIf
    CloseFile 0
  Else
    TMP=Request("IEDBPrefs Request","Non-existant Preferences file in ENV:|Using defaults!","Ok!")
    Gosub SetPrefsAsDefaults
    CloseFile 0
  EndIf
Return

SetPrefsAsDefaults

   Prefs$(0)="#IEDBPHDR"
   Prefs$(1)="1"
   Prefs$(2)=""
   Prefs$(3)="IconExtremeDB"
   Prefs$(4)="IconExtremeDB"
   Prefs$(5)="10"
   Prefs$(6)="10"
   Prefs$(7)="1"
   Prefs$(8)="1"
   Prefs$(9)="0"
  Prefs$(10)="0"
  Prefs$(11)="0"
  Prefs$(12)="0"
  Prefs$(13)="0"
  Prefs$(14)="1"
  Prefs$(15)="0"
  Prefs$(16)="100"
  Prefs$(17)="Bin/"
  Prefs$(18)="Documents/"
  Prefs$(19)="RAM:"
  Prefs$(20)="IEDBBrushOutput"
  Prefs$(21)="1"
  Prefs$(22)="0"
  Prefs$(23)="SYS:Utilities/Multiview"

  GUIBorder=Val(Prefs$(1))
Return





ChangeAttribs
  GadToggle{52,1,1,On}
  GadToggle{53,1,1,On}
  GadToggle{54,1,1,On}
  GTSetString 1,53,""

  Select \DataType
    Case 1
      GadToggle{53,1,1,Off}
      GadToggle{54,1,1,Off}
      GTSetAttrs 1,52,#GTCY_Active,Val(Prefs$(\ArrayData))

    Case 2
      GadToggle{52,1,1,Off}
      GTSetString 1,53,Prefs$(\ArrayData)

    Case 3
      GadToggle{52,1,1,Off}
      GadToggle{54,1,1,Off}
      GTSetString 1,53,Prefs$(\ArrayData)

    Case 4
      GadToggle{52,1,1,Off}
      GTSetString 1,53,Prefs$(\ArrayData)

  End Select

Return

GrabCurrent
  Select \DataType
    Case 1
      CYNum=GTGetAttrs(1,52,#GTCY_Active)
      Prefs$(\ArrayData)=Str$(CYNum)

    Case 2
      Prefs$(\ArrayData)=GTGetString(1,53)

    Case 3
      Prefs$(\ArrayData)=GTGetString(1,53)

    Case 4
      Prefs$(\ArrayData)=GTGetString(1,53)

  End Select
Return


SavePreferences
  If WriteFile(0,PrefsBase$)
    FileOutput 0
    For TMPS=0 To 23
      NPrint Prefs$(TMPS)
    Next
    CloseFile 0
  Else
    TMP=Request("IEDBPrefs Request","Cannot write to file:| "+PrefsBase$,"Ok!")
    CloseFile 0
  EndIf
Return


UsePrefs
  Lock.l=RTLockWindow(1)
  Gosub GrabCurrent
  PrefsBase$="ENV:IconExtremeDB.Prefs":Gosub SavePreferences
  RTUnlockWindow 1,Lock
  ClosePIPE{}
  End
Return


SavePrefs
  Lock.l=RTLockWindow(1)
  Gosub GrabCurrent
  PrefsBase$="ENVARC:IconExtremeDB.Prefs":Gosub SavePreferences
  PrefsBase$="ENV:IconExtremeDB.Prefs":Gosub SavePreferences
  RTUnlockWindow 1,Lock
  ClosePIPE{}
  End
Return


SaveAs
  RTEZSetDefaultDirectory 3,"ENV:"
  DaFile$=RTEZSaveFile("Select a file to save as..","IconExtremeDB.Prefs")

  If DaFile$=""
    CancelIt=1
  EndIf

  If CancelIt=0
    Lock.l=RTLockWindow(1)
    Gosub GrabCurrent
    PrefsBase$=DaFile$:Gosub SavePreferences
    RTUnlockWindow 1,Lock
  EndIf
  CancelIt=0
Return






--BOUNDARY.273602464.3
Content-Disposition: attachment; filename="IEPrefsStartup.ASC"
Encoding: binary


;
; Startup for IE Prefs
;

VER$="V3.01"
Goto PassVER:Even:Dc.b "$VER: Icon Extreme DB Prefs V1.00, (C) Robert Hutchinson 1999 (08/03/99)":Even:PassVER

WBenchToFront_:WbToScreen 0:WBStartup
ShowRequesters 1

*ThisScreen.Screen=Peek.l(Addr Screen (0))
FontName$=Peek$(*ThisScreen\Font\ta_Name)
FontSize.b=*ThisScreen\Font\ta_YSize
GadOff=28-FontSize
GadHeight=FontSize+6

AboutTitleString$="IE Prefs"

; --- Dummy window

Window 0,0,0,1,1,$1000,"",1,0
LoadFont 0,FontName$,FontSize
WindowFont 0

; --- text length grabber:

Function.l TextLen{Text$,Wind}
  Tx.l=TextLength_(RastPort(Wind),&Text$,Len(Text$))
  Function Return Tx
End Function

; --- Box in win

Statement WBoxFill{X,Y,W,H,C}
  Width=X+W-1
  Height=Y+H-1
  WBox X,Y,Width,Height,C
End Statement

; --- ZoneOpen

Statement ZoneOpen{Z,X,Y,W,H}
  Width=X+W-1
  Height=Y+H-1
  ZoneInit Z
  SetZone Z,X,Y,Width,Height
End Statement

; --- Toggle GT gadgets

Statement GadToggle{Gadg,Wind,GTL,SetTo}
  SetTo$=UCase$(SetTo$)
  If SetTo=On
    GTEnable GTL,Gadg
    Redraw Wind,Gadg
  Else
    GTDisable GTL,Gadg
    Redraw Wind,Gadg
  EndIf
End Statement

NEWTYPE .PrefsList
  Flags.w
  Text.s
  ArrayData.b
  DataType.b
End NEWTYPE

Dim List PrefsList.PrefsList(40)
AddFirst PrefsList()
PrefsList()\Text="Border program GUIs?":                PrefsList()\ArrayData=1: PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Default Icon.Base path:":             PrefsList()\ArrayData=2: PrefsList()\DataType=4:AddItem PrefsList()
PrefsList()\Text="Icon file for AppIcon Imagary:":      PrefsList()\ArrayData=3: PrefsList()\DataType=2:AddItem PrefsList()
PrefsList()\Text="AppIcon Icon name:":                  PrefsList()\ArrayData=4: PrefsList()\DataType=3:AddItem PrefsList()
PrefsList()\Text="AppIcon Icon X position:":            PrefsList()\ArrayData=5: PrefsList()\DataType=3:AddItem PrefsList()
PrefsList()\Text="AppIcon Icon Y position:":            PrefsList()\ArrayData=6: PrefsList()\DataType=3:AddItem PrefsList()
PrefsList()\Text="Show about Requester on Startup?":    PrefsList()\ArrayData=7: PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Auto SEND on exit?":                  PrefsList()\ArrayData=8: PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Auto Attempt IE Spawn on Startup?":   PrefsList()\ArrayData=9: PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Ask when deleting DataBase entries?": PrefsList()\ArrayData=10:PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Confirm program termination?":        PrefsList()\ArrayData=11:PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Always Save Icon.Base data on exit?": PrefsList()\ArrayData=12:PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Always Save preferences on exit?":    PrefsList()\ArrayData=13:PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Case-Sensitive searches?":            PrefsList()\ArrayData=14:PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Auto Iconify?":                       PrefsList()\ArrayData=15:PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Auto Iconify after ?? seconds:":      PrefsList()\ArrayData=16:PrefsList()\DataType=3:AddItem PrefsList()
PrefsList()\Text="Binary (Bin/) Directory:":            PrefsList()\ArrayData=17:PrefsList()\DataType=4:AddItem PrefsList()
PrefsList()\Text="Help Guides (Documents/) Directory:": PrefsList()\ArrayData=18:PrefsList()\DataType=4:AddItem PrefsList()
PrefsList()\Text="IconToShape(s) Output Path:":         PrefsList()\ArrayData=19:PrefsList()\DataType=4:AddItem PrefsList()
PrefsList()\Text="IconToShape(s) Name Prefix:":         PrefsList()\ArrayData=20:PrefsList()\DataType=3:AddItem PrefsList()
PrefsList()\Text="Iconify to ToolsMenu instead of Icon?":PrefsList()\ArrayData=21:PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Show names only in Multi Icon Lister?":PrefsList()\ArrayData=22:PrefsList()\DataType=1:AddItem PrefsList()
PrefsList()\Text="Multiview File path:":                PrefsList()\ArrayData=23:PrefsList()\DataType=3:


  GTMenuTitle 1,0,"Project"
    GTMenuItem 1,0,0,0,"Save Preferences","S"
    GTMenuItem 1,0,0,1,"Use Preferences","U"
    GTMenuItem 1,0,0,2
    GTMenuItem 1,0,0,3,"Save Preferences As...","A"
