> > decrunching
> > code to the list...
> 
>   Ahh, yes pleaseeee!!! :)

Right, here yer go then! :)


-- 
BootBlock/Satanic Dreams, from Grimsby, England. - ICQ#: 14864929
HTTP://fly.to/ParpsVille - Amiga/PC/PSX, Blitz2, Emulation, etc...
A1200T/020-28/AMD2-300/AGP gfx card/2+4+64Mb/2.1+4.3Gb/56k/CDD3600 SCSI
ReWriter
--------------1DB6DF2BEAAA3B1723D43753
 name="stc.txt"
Encoding: 7bit
Content-Disposition: inline;
 filename="stc.txt"

;
; Decrunched StoneCrack'ed File v0.99
;  by BootBlock/Carnage

;    BootBlock@Bigfoot.com
;    HTTP://Fly.to/ParpsVille
;
;This  code  will  load  in a file and check to see if it's crunched with
;StoneCracker  (awesome  file/data  (de)cruncher),  if so, it'll allocate
;some memory, load the file in and decrunch it within that located memory
;(so it's effectively decrunching over itself).  The fptr (File's Pointer
;in memory) and ulen (Uncrunched Length) variables will be set to reflect
;the location and length of the decrunched file.

;If  the  file is not crunched with StoneCracker, the file will be loaded
;into  memory and then the fptr and ulen variables will set to the file's
;location in memory and the length of the file held in memory.

  Filename$ = "RAM:MyStoneCrunchedFile.stc"

  If ReadFile(0,Filename$)<>0
    FileInput 0

    flen.l  = Lof(0)                  ;Length of file on disk.
    HEADER$ = Edit$(16)
    FileSeek  0,0

    ;--- Is this a StoneCracked file? ...
    ;
    If Left$(HEADER$,4)="S404"
      HEAD.l  = &HEADER$
      ulen.l  = STCLength(HEAD)     ;Unpacked length.
      slen.l  = STCSafeLen(HEAD)    ;Security length. (full filesize)
      ptr     = AllocMem_(slen,2)   ;Allocate memory. (plus security length)

      ;--- Was there enough free mem to allocate? ...
      ;
      If ptr=0
        NPrint ""
        NPrint "Couldn't allocate memory, wanted ",slen," bytes (",slen/1024,"k)."
        CloseFile 0 : Delay_ 50 : VWait 100 : End
      EndIf

      ;--- Read the file into the
      ;    allocated memory block...
      ;
      ReadMem 0,ptr,flen

      ;--- Decrunch the file ...
      ;
      STCDecrunch ptr

      ;--- Find where the start of
      ;    the file resides ...
      ;
      fptr.l  = STCStart(ptr)         ;File Pointer.
                                      ;(start of decrunched file in memory)
    Else
      ptr    = AllocMem_(flen,2)
      ReadMem  0,ptr,flen
      fptr.l = ptr
      ulen.l = flen
    EndIf
    CloseFile 0
  Else
    ptr  = 0
    fptr = 0
    ulen = 0
  EndIf

--------------1DB6DF2BEAAA3B1723D43753--



@ENDNODE
