@NODE "Mail.565" "Chunky CPUBlit commands"
Date: Mon, 30 Mar 1998 10:09:46 +0100
From: James Marshall <homegrown@eclipse.co.uk>
Subject: Chunky CPUBlit commands

This is a multi-part message in MIME format.
--------------A1ABCB7CF1AAD2F74142FB5A

Hi all,
  here are the ASM routines I developed... a little untidy, and they
could probably be optimised, so if you improve them please post them
back onto the list! I don't mind anyone using these routines for any
purpose, but I accept no responsibility for whatever you do with them or
they do with you! I implemented the commands as subroutines within my
screen drawing function, for speed purposes... maybe someone would like
to make a library of chunky blit commands? I don't have the experience
though.
    James

--
Homegrown Software - Independent Amiga Games Developers
Web - http://www.eclipse.co.uk/homegrown
email - homegrown@eclipse.co.uk


--------------A1ABCB7CF1AAD2F74142FB5A
Content-Disposition: inline; filename="Chunky_c"

Dim shapes.b(#largest_shape_width-1,#largest_shape_height-1,#maximum_shape_number-1) ;this stores the shapes
Dim shape_handles.b(#Minimap_buffer-1,4) ;this stores the shapes sizes and handles (1 & 2=x & y handle, 3 & 4=x & y size
Dim chunky.b(#bitmap_width-1,#bitmap_height-1) ;this is the chunky bitmap
;
blit_shape=shape_num
blit_shapeX=x
blit_shapeY=y
Gosub cpu_block
;
blit_shape=shape_num
blit_shapeX=x-shape_handles(shape_num,1)
blit_shapeY=y-shape_handles(shape_num,2)
Gosub cpu_clipblit
;
blit_shape=shape_num
blit_shapeX=x
blit_shapeY=y
Gosub cpu_blit
;
.cpu_block
GetReg a0,&shapes(0,0,blit_shape)
GetReg a1,&chunky(blit_shapeX,blit_shapeY)
GetReg d0,0
GetReg d1,0
xline1
MOVE.b (a0),(a1)
ADD.l #1,a0
ADD.l #1,a1
ADD.b #1,d0 : CMP #64,d0 : BLT xline1 ;hard coded for 64 pixel wide shape
CLR.b d0
ADD.l #576,a1
ADD.b #1,d1 : CMP #32,d1 : BLT xline1 ;hard coded for 32 pixel high shape
Return
;
.cpu_blit
GetReg a0,&shapes(0,0,blit_shape)
GetReg a1,&chunky(blit_shapeX,blit_shapeY)
GetReg d0,0
GetReg d1,0
xline2
CMP.b #0,(a0) : BEQ plot_done1 ;hard coded for colour 0 as transparent
MOVE.b (a0),(a1)
plot_done1
ADD.l #1,a0
ADD.l #1,a1
ADD.b #1,d0 : CMP #64,d0 : BLT xline2 ;hard coded for 64 pixel wide shape
CLR.b d0
ADD.l #576,a1
ADD.b #1,d1 : CMP #32,d1 : BLT xline2 ;hard coded for 32 pixel high shape
Return
;
.cpu_clipblit
;clipping hard coded for 640 pixel wide, 256 pixel high bitmap
If blit_shapeX+shape_handles(blit_shape,3)>639
  If blit_shapeX>639
    Return
  Else
    stopX=640-blit_shapeX
  End If
Else
  stopX=shape_handles(blit_shape,3)
End If
If blit_shapeY+shape_handles(blit_shape,4)>255
  If blit_shapeY>255
    Return
  Else
    stopY=256-blit_shapeY
  End If
Else
  stopY=shape_handles(blit_shape,4)
End If
If blit_shapeX<0
  If blit_shapeX+shape_handles(blit_shape,3)<0
    Return
  Else
    startX=blit_shapeX*-1
    blit_shapeX=0
  End If
Else
  startX=0
End If
If blit_shapeY<0
  If blit_shapeY+shape_handles(blit_shape,4)<0
    Return
  Else
    startY=blit_shapeY*-1
    blit_shapeY=0
  End If
Else
  startY=0
End If
GetReg a0,&shapes(startX,startY,blit_shape)
GetReg a1,&chunky(blit_shapeX,blit_shapeY)
GetReg d0,startX
GetReg d1,startY
GetReg d2,stopX
GetReg d3,stopY
GetReg d4,64-stopX ;hard coded to maximum shape width of 64
GetReg d5,startX
xline3
CMP.b #0,(a0) : BEQ plot_done2 ;hard coded for colour 0 as transparent
MOVE.b (a0),(a1)
plot_done2
ADD.l #1,a0
ADD.l #1,a1
ADD.b #1,d0 : CMP d2,d0 : BLT xline3
ADD.l d4,a0
ADD.l d5,a0
MOVE d5,d0
ADD.l #640,a1
ADD.l d0,a1
SUB.l d2,a1
ADD.b #1,d1 : CMP d3,d1 : BLT xline3
Return


--------------A1ABCB7CF1AAD2F74142FB5A--



@ENDNODE
