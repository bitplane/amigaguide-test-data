@NODE "Mail.428" "Re: Loading Pictures Formats"
Date: 12 Mar 98 19:43:38 +0100
From: FreeJack <klein21@ibm.net>
Subject: Re: Loading Pictures Formats

>>   Just go to my homepage, and download the file DTPicLoad.asc ;-)
>>The code will show you how to load a picture by using the datatypes...
>>You will need the MethodBBLib from Erwan Fouret.

>I downloaded this source code, and it is great, but I was wondering how one
>would go about displaying the datatype picture in a window on the Workbench
>screen.

>Any ideas?  I was hoping to maybe use a bit of this code to show a picture in
>the background of of the window the game I'm writing.

I've got once a code which can do it - I changed it somehow now idea who did
it first maybe you can use it ...

I used this for tryingh some more things --- most of them completly stupid/unusable
for you so don't worry for some stupid stuff in this code :)

---------------------------------------------------snip---------------------------

WBStartup
LoadFont 0,"topaz.font",8
Let version$="Datatype Demo v0.01 ? 1997 by Jürgen Klein"
Let Adresse$="|Dornbachstr. 22|D-61440 Oberursel|Germany||klein21@ibm.net"
Let vers$=LSet$(version$,19)
Let vers.l=Null(version$)

#TAG_USER=(1LSL31)

#DTA_DUMMY = #TAG_USER + $1000
#GA_DUMMY = #TAG_USER + $30000

#DTA_SOURCETYPE = #DTA_DUMMY + $101
#DTA_GROUPID = #DTA_DUMMY + $31

#DTST_FILE = 2

#GA_LEFT = #GA_DUMMY + $0001
#GA_TOP = #GA_DUMMY + $0003
#GA_RELWIDTH = #GA_DUMMY + $0006
#GA_RELHEIGHT = #GA_DUMMY + $0008


Dim Tags.TagItem(7) ;items in the taglist

Tags(0)\ti_Tag=#DTA_SOURCETYPE,#DTST_FILE  ; source of the data, it's a file
Tags(1)\ti_Tag=#DTA_GROUPID,&GID_PICTURE   ; we want a picture
Tags(2)\ti_Tag=#GA_LEFT,4                  ; left edge of object
Tags(3)\ti_Tag=#GA_TOP,11                  ; top edge of object
Tags(4)\ti_Tag=#GA_RELWIDTH,-22            ; relative width (not sure why this is -22)
Tags(5)\ti_Tag=#GA_RELHEIGHT,-13           ; relative height
Tags(6)\ti_Tag=#TAG_DONE,0



Function.w GetScreenData {ScreenNr}
   SHARED ScrB.w
   SHARED ScrH.w
   ScreenPtr.l  = Peek.l (Addr Screen (ScreenNr))
   ScrB.w       = Peek.w (ScreenPtr+12)
   ScrH.w       = Peek.w (ScreenPtr+14)
   FontPtr.l    = Peek.l (ScreenPtr+40)
   FontHeight.w = Peek.w (FontPtr+4)
   Function Return FontHeight
End Function


NEWTYPE .screeninfo
  id.l
  width.l
  height.l
  tiefe.w
  overscan.w
  autoscroll.w
  bmapw.l
  bmash.l
End NEWTYPE



Let y=GetScreenData{0}+3
Let Anzahl.l=(ScrB.w/8)-1
Let Zeilen.l=(ScrH.w-50)/8
Let StatLn.w=(ScrB.w-90)
Let TextLn.w=(ScrB.w-160)/2

WbToScreen 0
ScreensBitMap 0,0


AddIDCMP $200000

MenuTitle 0,0,"Project"
MenuItem  0,0,0,0,"Öffnen  ...          ","o"
MenuItem  0,0,0,1,"Sichern ...","s"
MenuItem  0,0,0,2,"Über","?"
MenuItem  0,0,0,3,"Beenden","q"
MenuTitle 0,1,"Funktionen"
MenuItem  0,0,1,0,"ScreenData","1"


;Window 0, 0,y,640,256, $2|$4|$8|$1000,version$,0,1
Window 0, 0,12,640,256, $20140e,version$,0,1
WindowFont 0
SetMenu 0
Gosub ViewDatatype


GTText     0,1, 80,  2, StatLn, 12, "Status:",0,vers$
GTString   0,2, 80, 14, TextLn, 12, "Enter",0,1024
GTButton   0,3,  4, 26,  72, 12, "_About", 0
GTText     0,4, 80, 26, StatLn, 12, "",0,"O.K."
GTString   0,5, TextLn+152, 14, TextLn, 12, "Enter2",0,1024

BorderPens 2,1
GadgetBorder 8,14,ScrB.w-16,36


AttachGTList 0,0
Auswahl.w=0



; Hier Start Program


Repeat
   ev.l = WaitEvent
   Let Ev$=Str$(ev)+"EventCode: "+Str$(EventCode)
   GTSetString 0,4,Ev$+"Window:"+Str$(EventWindow)
   Select EventWindow
      Case 0
      Select ev
         Case 256
         Select MenuHit
            Case 0
            Select ItemHit
               Case 0: Gosub Load
               Case 2: Gosub About
               Case 3: Gosub Quit
            End Select
            Case 1
            Select ItemHit
               Case 0: Gosub GetData
            End Select
         End Select
         Case $40
         Select GadgetHit
            Case  0: Gosub About
            Case  1: Gosub About
            Case  3: Gosub About
         End Select
         Case $200000
         Select EventCode
            Case  27: Gosub Quit
            Case  97: Gosub About
         End Select
      End Select
   End Select
Until ev = $200

End

.Load
 MaxLen Pfad$=1024
 MaxLen Filen$=1024
 Let Pfad$="S:"
 Let Filen$="Shell-Startup"
 Let Files$=""
 Files$=ASLFileRequest$("Loading ...",Pfad$,Filen$,"#?")
 If Files$<>""
    If Exists(Files$)
      LoadBank 0,Files$,$10000
      Let FileLange=BankSize(0)
    EndIf
 EndIf
Return


.About
  Let check=Request (version$,version$+Adresse$+"|Programmed in Blitz Basic","Thanks Jürgen")

Return

.Quit
   Let check=Request (vers$,"Really Quit ?","Yes, quit|No, continue")
   If check=1
      result = RemoveDTObject_(*mywin.Window,*myobj.Gadget)
      result = DisposeDTObject_(*myobj)
      CloseWindow 0
      Forbid_
      End
   EndIf
Return


.GetData
   GTSetString 0,1," ScreenMode: "+ID$+" Breite:"+Breite$+" Höhe: "+Hoehe$
Return


.ViewDatatype

   fname.s="Blitz2:.Gfx/Back.iff"
   *myobj.Gadget = NewDTObjectA_(fname,&Tags(0))
   If *myobj<>0 ; Object was allocated normally
      *mywin.Window = Peek.l(Addr Window(0))
      If (AddDTObject_(*mywin,-1,*myobj,-1))<>0 ; object was added without problems
         Repeat                        ; wait until picture's ready
            si.l = *myobj\SpecialInfo
            myobjflags.l = si + 46
            result = Delay_(25)
         Until (Peek.l(myobjflags) AND 1) = False
         res = RefreshDTObjectA_(*myobj,*mywin,-1,-1)  ; display picture
      EndIf
   EndIf
Return


---------------------------------------------------snap---------------------------






-- 
Software written in Blitz: #CyberShape# - iff conversion on cgx screens
#Trojan Carrier# - hide binaries within .iff {both on AmiNet]
--
>AMIGA 4000, 68060/50MHz, 54 MB Ram, cgx 2.0, 6,5 GB HD, 24x CD-Rom, CD-R
