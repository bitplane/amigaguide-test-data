@DATABASE Font V1.30
$VER: Font V1.30 (26.07.1998) by Laboureur -> AlphaSOUND <- Frťdťric
@NODE MAIN "Font V1.30"

    @{b}Font V1.30 General Information:@{ub}

  * Blitz Basic II library number         : #41
  * Library size when linked to executable: 368 bytes
  * Number of commands                    : 5
  * Ressources automatically freed at end : Yes
  * Blitz Basic II libraries now obsolete :
      - basic/fontlib.obj


    @{b}Commands summary:@{ub}

  @{" NCloseFont   " LINK NCloseFont} Statement
  @{" NFontID      " LINK NFontID} Function (FontID.l)
  @{" NInitFont    " LINK NInitFont} Function (Boolean)
  @{" NLoadFont    " LINK NLoadFont} Function (FontID.l)
  @{" NUseFont     " LINK NUseFont} Statement

@ENDNODE


@NODE NCloseFont

    @{b}SYNTAX@{ub}
  NCloseFont(#Font)

    @{b}STATEMENT@{ub}
  Close the given Font.

@ENDNODE


@NODE NInitFont

    @{b}SYNTAX@{ub}
  result.l = NInitFont(#NumFontMax)

    @{b}FUNCTION@{ub}
  Init all the Font environnement for  later  use.  You  must  put  this
  functions  on  top  of  your  source code if you want to use the NFont
  commands. This function try to open the diskfont.library V36+. If  the
  result  is  NULL,  this  library  can't be opened. You should test its
  result at top of your program and quit if the  diskfont.library  isn't
  found.

  #NumFontMax : Maximum number of Font to handle.

@ENDNODE


@NODE NFontID

    @{b}SYNTAX@{ub}
  FontID.l = NFontID

    @{b}FUNCTION@{ub}
  Return the Intuition Font pointer. Very useful.

@ENDNODE


@NODE NLoadFont

    @{b}SYNTAX@{ub}
  FontID.l = NLoadFont(#Font, Name$.font, YSize)

    @{b}FUNCTION@{ub}
  Try to open a font from memory, and if it failed it will try  to  open
  it  from disk (via diskfont.library). This function is very useful. If
  the returned FontID is NULL, the font can't be found.

@ENDNODE


@NODE NUseFont

    @{b}SYNTAX@{ub}
  NUseFont(#Font)

    @{b}STATEMENT@{ub}
  Change the used Font to given Font.

@ENDNODE
