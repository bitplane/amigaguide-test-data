@ENDNODE OVERVIEW

@NODE clockAll "CLOCKLIB"

@{fg shine}Statement: clockAll@{fg text}
----------------------------------------------------------------------------
Modes  : 
Syntax : time.l=clockAll

return the number of seconds since the last reboot (for all cpu)


@ENDNODE clock

@NODE clock "CLOCKLIB"

@{fg shine}Statement: clock@{fg text}
----------------------------------------------------------------------------
Modes  : 
Syntax : time.l=clock

return the number of seconds since the last reboot (optimized for 020+)

@ENDNODE clock

@NODE clockAllms "CLOCKLIB"

@{fg shine}Statement: clockAllms@{fg text}
----------------------------------------------------------------------------
Modes  : 
Syntax : time.l=clockAllms

return the number of milliseconds since the last reboot (for all cpu)

@ENDNODE clockAllms

@NODE clockms "CLOCKLIB"

@{fg shine}Statement: clockms@{fg text}
----------------------------------------------------------------------------
Modes  : 
Syntax : time.l=clockms

return the number of milliseconds since the last reboot (optimized for 020+)

@ENDNODE clockms

@NODE MAIN "CLOCKLIB"

.---------------------------------------------------------------------------.
|                                 @{b}CLOCKLIB@{ub}                                  |
`---------------------------------------------------------------------------'

                             @{"     Overview     " link OVERVIEW}

                               Command Index                                

                           @{"    clockAll           " link clockAll}
                           @{"    clock (020+)       " link clock}
                           @{"    clockAllms         " link clockAllms}
                           @{"    clockms (020+)     " link clockms}

                              

@ENDNODE MAIN

