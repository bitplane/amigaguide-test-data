@NODE "Patterns" "Patterns"
@TOC "Download"

@{par}                                   @{fg shine}Patterns@{fg text}
@{par}
@{par}This archive includes the following patterns:
@{par}
@{par}  ClassicDOpus.pat                 ClassicMarble.pat
@{par}  DOpusStone.pat                   DOpusStone0_LoRes.pat
@{par}  DOpusStone1_LoRes.pat            DOpusStone2_LoRes.pat
