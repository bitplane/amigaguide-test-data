@toc Main
@{settabs 10 40 70}	@{" bottom " link ARexxBottom}	@{" nextfile " link ARexxNextFile}	@{" showsubdirs " link ARexxShowSubDirs}
	@{" bottomdir " link ARexxBottomDir}	@{" nextleveldir " link ARexxNextLevelDir}	@{" stop " link ARexxStop}
	@{" bottomfile " link ARexxBottomFile}	@{" overwrite " link ARexxOverwrite}	@{" tagdir " link ARexxTagDir}
	@{" dirleft " link ARexxDirLeft}	@{" parentdir " link ARexxParentDir}	@{" tagfile " link ARexxTagFile}
	@{" dirright " link ARexxDirRight}	@{" prevdir " link ARexxPrevDir}	@{" taggeddircount " link ARexxTaggedDirCount}
	@{" fdisplay " link ARexxFDisplay}	@{" prevfile " link ARexxPrevFile}	@{" taggedfilecount " link ARexxTaggedFileCount}
	@{" fileinfo " link ARexxFileInfo}	@{" prevleveldir " link ARexxPrevLevelDir}	@{" top " link ARexxTop}
	@{" fileleft " link ARexxFileLeft}	@{" quit " link ARexxQuit}	@{" topdir " link ARexxTopDir}
	@{" fileright " link ARexxFileRight}	@{" restore " link ARexxRestore}	@{" topfile " link ARexxTopFile}
	@{" hidesubdirs " link ARexxHideSubDirs}	@{" search " link ARexxSearch}	@{" verify " link ARexxVerify}
	@{" katfile " link ARexxKatFile}	@{" searchnext " link ARexxSearchNext}	@{" verifyoptions " link ARexxVerifyOptions}
	@{" nextdir " link ARexxNextDir}	@{" sortfiles " link ARexxSortFiles}	@{" version " link ARexxVersion}
@endnode
