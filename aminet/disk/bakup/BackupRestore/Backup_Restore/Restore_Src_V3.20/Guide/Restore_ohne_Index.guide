@node ARexxBottom "ARexx-Befehl bottom"
@toc Main
@{settabs 12 20 30}@{b}bottom@{ub}
	@{lindent 12}zur letzten Datei im letzten Verzeichnis auf dem aktuellen Datenträger
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxBot¸tomDir "ARexx-Befehl bottomdir"
@toc Main
@{settabs 12 20 30}@{b}bottomdir@{ub}
	@{lindent 12}zum letzten Verzeichnis auf dem aktuellen Datenträger
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxBottomFile "ARexx-Befehl bottomfile"
@toc Main
@{settabs 12 20 30}@{b}bottomfile@{ub}
	zur letzten Datei im aktuellen Verzeichnis
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxDirLeft "ARexx-Befehl dirleft"
@toc Main
@{settabs 12 20 30}@{b}dirleft@{ub}
	@{lindent 12}Verzeichnis-Anzeige 1 Spalte nach links scrollen
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxDirRight "ARexx-Befehl dirright"
@toc Main
@{settabs 12 20 30}@{b}dirright@{ub}
	@{lindent 12}Verzeichnis-Anzeige 1 Spalte nach rechts scrollen
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxFDisplay "ARexx-Befehl fdisplay"
@toc Main
@{settabs 12 30 40}@{b}fdisplay@{ub} [name|size|date|time|prot]
@{par}@{pard}	Optionen zur Datei-Anzeige festlegen:
	@{b}name@{ub}	nur Dateinamen anzeigen
		löscht alle anderen Datei-Anzeige Optionen
	@{b}size@{ub}	auch Dateigröße anzeigen
	@{b}date@{ub}	auch Datei-Datum und -Uhrzeit anzeigen
	@{b}prot@{ub}	auch Protection-Flags anzeigen
@{par}@{pard}	@{lindent 12}liefert immer die Dateianzeige-Optionen vor dem fdisplay-Befehl, z.B. "name" oder "size prot date".
@{par}@{pard}rc=7  - kein Datenträger vorhanden
	rc=8  - Busy (gerade bei restore, verify oder search)
	rc=11 - unbekannter Parameter
@endnode
----------------------------------------------------------------------------
@node ARexxFileInfo "ARexx-Befehl fileinfo"
@toc Main
@{settabs 12 20 30}@{b}fileinfo@{ub} [name|size|date|time|prot|comment]
	liefert Informationen über die gerade ausgewählte Datei
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
	rc=9 - Prüfsummenfehler im Verzeichnis-Eintrag
@endnode
----------------------------------------------------------------------------
@node ARexxFileLeft "ARexx-Befehl fileleft"
@toc Main
@{settabs 12 20 30}@{b}fileleft@{ub}
	@{lindent 12}Datei-Anzeige 1 Spalte nach links scrollen
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxFileRight "ARexx-Befehl fileright"
@toc Main
@{settabs 12 20 30}@{b}fileright@{ub}
	@{lindent 12}Datei-Anzeige 1 Spalte nach rechts scrollen
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxHideSubDirs "ARexx-Befehl hidesubdirs"
@toc Main
@{settabs 12 20 30}@{b}hidesubdirs@{ub}
	@{lindent 12}Alle Unterverzeichnisse des aktuellen Verzeichnisses werden versteckt, sind also in der Verzeichnis-Anzeige nicht mehr sichtbar und werden auch bei "nextdir" und "prevdir" übersprungen.
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxKatFile "ARexx-Befehl katfile"
@toc Main
@{settabs 12 20 30}@{b}katfile@{ub}
	@{lindent 12}versucht, vom letzten Sicherungs-Datenträger das Sicherungsprotokoll zu lesen
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxNextDir "ARexx-Befehl nextdir"
@toc Main
@{settabs 12 20 30}@{b}nextdir@{ub}
	@{lindent 12}zum nächsten Verzeichnis
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxNextFile "ARexx-Befehl nextfile"
@toc Main
@{settabs 12 20 30}@{b}nextfile@{ub}
	@{lindent 12}zur nächsten Datei im aktuellen Verzeichnis
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxNextLevelDir "ARexx-Befehl nextleveldir"
@toc Main
@{settabs 12 20 30}@{b}nextleveldir@{ub}
	@{lindent 12}zum nächsten Verzeichnis auf derselben Schachtelungstiefe z.B. zum Überspringen von Unterverzeichnissen.
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxOverwrite "ARexx-Befehl overwrite"
@toc Main
@{settabs 12 30 40}@{b}overwrite@{ub} [always|never|ask|older]
	Optionen beim Überschreiben vorhandener Dateien festlegen :
	@{b}always@{ub}	es wird alles überschrieben
	@{b}never@{ub}	keine Dateien werden überschrieben
	@{b}ask@{ub}	es wird bei jeder Datei nachgefragt
	@{b}older@{ub}	es werden nur ältere Dateien überschrieben
@{par}@{pard}	@{lindent 12}liefert immer die Überschreib-Option vor dem overwrite-Befehl, z.B. "always" oder "ask".
@{par}@{pard}rc=8  - Busy (gerade bei restore, verify oder search)
	rc=11 - unbekannter Parameter
@endnode
----------------------------------------------------------------------------
@node ARexxParentDir "ARexx-Befehl parentdir"
@toc Main
@{settabs 12 20 30}@{b}parentdir@{ub}
	@{lindent 12}zum Mutterverzeichnis (Parent) des momentanen Verzeichnis
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxPrevDir "ARexx-Befehl prevdir"
@toc Main
@{settabs 12 20 30}@{b}prevdir@{ub}
	@{lindent 12}zum vorigen Verzeichnis
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxPrevFile "ARexx-Befehl prevfile"
@toc Main
@{settabs 12 20 30}@{b}prevfile@{ub}
	@{lindent 12}zur vorigen Datei im aktuellen Verzeichnis
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxPrevLevelDir "ARexx-Befehl prevleveldir"
@toc Main
@{settabs 12 20 30}@{b}prevleveldir@{ub}
	@{lindent 12}zum vorigen Verzeichnis auf derselben Schachtelungstiefe z.B. zum Überspringen von Unterverzeichnissen.
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxQuit "ARexx-Befehl quit"
@toc Main
@{settabs 12 20 30}@{b}quit@{ub}
	Programm beenden
@endnode
----------------------------------------------------------------------------
@node ARexxRestore "ARexx-Befehl restore"
@toc Main
@{settabs 12 20 30}@{BG Highlight}Restore@{BG Background}
	@{lindent 12}Restaurieren aller markierten oder des gerade ausgewählten Dateien
@{par}@{pard}rc=3  - abgebrochen
	rc=7  - kein Datenträger vorhanden
	rc=8  - Busy (gerade bei restore, verify oder search)
	rc=10 - Fehler beim Restaurieren
@endnode
----------------------------------------------------------------------------
@node ARexxSearch "ARexx-Befehl search"
@toc Main
@{settabs 12 20 30}@{b}search@{ub} <SuchText> [dir|file|forward|backward]
	@{lindent 12}Suche ab der momentanen Position nach einer Datei oder einem Verzeichnis
@{par}@{pard}rc=2  - nicht gefunden
	rc=3  - abgebrochen
	rc=7  - kein Datenträger vorhanden
	rc=8  - Busy (gerade bei restore, verify oder search)
	rc=11 - unbekannter Parameter
@endnode
----------------------------------------------------------------------------
@node ARexxSearchNext "ARexx-Befehl searchnext"
@toc Main
@{settabs 12 20 30}@{b}searchnext@{ub}
	@{lindent 12}Weitersuchen mit den zuletzt verwendeten Such-Einstellungen
@{par}@{pard}rc=2 - nicht gefunden
	rc=3 - abgebrochen
	rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxShowSubDirs "ARexx-Befehl showsubdirs"
@toc Main
@{settabs 12 20 30}@{b}showsubdirs@{ub}
	@{lindent 12}Die versteckten Unterverzeichnisse des aktuellen Verzeichnisses werden wieder sichtbar gemacht. Sie sind danach wieder in der Verzeichnis-Anzeige sichtbar und können mit @{"nextdir" link ARexxNextDir} und @{"prevdir" link ARexxPrevDir} erreicht werden.
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxSortFiles "ARexx-Befehl sortfiles"
@toc Main
@{settabs 12 30 40}@{b}sortfiles@{ub} none|name|size|datetime
	Legt fest, wie die Dateien in der Anzeige sortiert werden:
	@{b}none@{ub}		Keine Sortierung
	@{b}name@{ub}		Dateien werden aufsteigend nach ihrem Namen angezeigt
	@{b}size@{ub}		Dateien werden aufsteigend nach Größe angezeigt
	@{b}datetime@{ub}		Dateien werden absteigend nach Datu,/Uhrzeit angezeigt
@{par}@{pard}	rc=11 - unbekannter Parameter
@endnode
----------------------------------------------------------------------------
@node ARexxStop "ARexx-Befehl stop"
@toc Main
@{settabs 12 20 30}@{b}stop@{ub}
	@{lindent 12}Abbrechen eines laufenden Restore- Verify- oder Such-Kommandos
@endnode
----------------------------------------------------------------------------
@node ARexxTagDir "ARexx-Befehl tagdir"
@toc Main
@{settabs 12 20 30}@{b}tagdir@{ub}
	@{lindent 12}momentan ausgewähltes Verzeichnis markieren
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxTagFile "ARexx-Befehl tagfile"
@toc Main
@{settabs 12 20 30}@{b}tagfile@{ub}
	@{lindent 12}momentan ausgewählte Datei markieren
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxTaggedDirCount "ARexx-Befehl taggeddircount"
@toc Main
@{settabs 12 20 30}@{b}taggeddircount@{ub}
	@{lindent 12}liefert die Anzahl der gerade ausgewählten Verzeichnisse. Entspricht der Anzeige im Fenster-Titel.
@{par}@{pard}rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxTaggedFileCount "ARexx-Befehl taggedfilecount"
@toc Main
@{settabs 12 20 30}@{b}taggedfilecount@{ub}
	@{lindent 12}liefert die Anzahl der gerade ausgewählten Dateien. Entspricht der Anzeige im Fenster-Titel.
@{par}@{pard}rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxTop "ARexx-Befehl top"
@toc Main
@{settabs 12 20 30}@{b}top@{ub}
	@{lindent 12}zur ersten Datei im ersten Verzeichnis
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxTopDir "ARexx-Befehl topdir"
@toc Main
@{settabs 12 20 30}@{b}topdir@{ub}
	@{lindent 12}zum ersten Verzeichnis
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxTopFile "ARexx-Befehl topfile"
@toc Main
@{settabs 12 20 30}@{b}topfile@{ub}
	@{lindent 12}zur ersten Datei im aktuellen Verzeichnis
@{par}@{pard}rc=7 - kein Datenträger vorhanden
	rc=8 - Busy (gerade bei restore, verify oder search)
@endnode
----------------------------------------------------------------------------
@node ARexxVerify "ARexx-Befehl verify"
@toc Main
@{settabs 12 20 30}@{b}verify@{ub}
	@{lindent 12}Verifizieren aller markierten Datei oder der gerade ausgewählten Datei.
@{par}@{pard}rc=3  - abgebrochen
	rc=7  - kein Datenträger vorhanden
	rc=8  - Busy (gerade bei restore, verify oder search)
	rc=10 - Verify-Fehler
@endnode
----------------------------------------------------------------------------
@node ARexxVerifyOptions "ARexx-Befehl verifyoptions"
@toc Main
@{settabs 12 20 30}@{b}verifyoptions@{ub} none
	@{lindent 12}Setzt die aktuellen Verify-Optionen auf "none".
@{par}@{pard}@{b}verifyoptions@{ub} [date|filenote|protection]
	@{lindent 12}Erweitert die Verify-Optionen.
@{par}@{pard}	@{lindent 12}liefert immer die Verify-Flags vor dem verifyoptions-Befehl, z.B. "none" oder "date filenote".
@{par}@{pard}rc=8  - Busy (gerade bei restore, verify oder search)
	rc=11 - unbekannter Parameter
@endnode
----------------------------------------------------------------------------
@node ARexxVersion "ARexx-Befehl version"
@toc Main
@{settabs 12 20 30}@{b}version@{ub}
	liefert Programmname und Versionsnummer, z.B. "@{BG Highlight}Restore@{BG Background} V3.13"
@endnode
----------------------------------------------------------------------------
@font topaz.font 8
----------------------------------------------------------------------------
@node FileInfoWindow "Fenster 'Restore Datei Info'"
@toc Main
@{settabs 12 20 30}@{"so sieht es aus" link Restore_FIWindow.iff/main}
@{par}@{pard}+----------------------------------------------------------+
|                         Dateiname                        |
| @{"System:sc/Backup/Backup.c                              " link GadgFIName} |
|                         Kommentar                        |
| @{"                                                       " link GadgFIFilenote} |
|                                                          |
| @{"58266/18640 Bytes    " link GadgFIBytes} @{"Flags ----rwed " link GadgFIFlags}  @{"XPK-komprimiert" link GadgFIcompress} |
| @{"Datum 20.02.1994 19:13:46             " link GadgFIDate}  @{"um 69%         " link GadgFIpercent} |
| @{"Datei komplett : ja  " link GadgFIComplete} @{"Extension #0   " link GadgFIExtension}                   |
| @{"Disk Offset $00000200" link GadgFIOffset} @{"(Block 1)      " link GadgFIBlock}                   |
|                                             @{"   Ok   " link GadgFIOk}    |
+----------------------------------------------------------+
@endnode
----------------------------------------------------------------------------
@font helvetica.font 13
----------------------------------------------------------------------------
@node GadgFIName "Dateiname"
@toc Main
@{settabs 12 20 30}Hier wird der Name der Datei angezeigt.
@endnode
----------------------------------------------------------------------------
@node GadgFIFilenote "Kommentar"
@toc Main
@{settabs 12 20 30}Hier wird der Kommentar (Filenote) zur Datei angezeigt.
@endnode
----------------------------------------------------------------------------
@node GadgFIBytes "Größe"
@toc Main
@{settabs 12 20 30}Zeigt bei Dateien die Größe in Bytes an.
Bei komprimierten Dateien stehen hier originale und komprimierte Größe, z.B. @{i}58266/18640 Bytes@{ui}.
@{par}@{pard}Bei Links wird hier @{i}(SoftLink)@{ui} oder @{i}(HardLink)@{ui} angezeigt.
Bei Verzeichnissen steht an dieser Stelle @{i}(Verzeichnis)@{ui}.
@endnode
----------------------------------------------------------------------------
@node GadgFIFlags "Datei-Attribute"
@toc Main
@{settabs 12 30 50}Hier werden die Datei-Attribute angezeigt, z.B. "----rwed".
Dabei bedeuten:
@{par}@{pard}h	Hidden		Diese Datei ist versteckt
s	Script		Dies ist ein CLI-Script.
p	Pure		Dieses Programm kann resident gemacht werden.
a	Archive		Diese Datei wurde seit der letzten Sicherung nicht verändert.
r	Read		Aus dieser Datei darf gelesen werden.
w	Write		In diese Datei darf geschrieben werden.
e	Execute		Diese Datei kann ein ausführbares Programm sein.
d	Delete		Diese Datei darf gelöscht werden.
@endnode
----------------------------------------------------------------------------
@node GadgFIcompress "komprimiert"
@toc Main
@{settabs 12 20 30}Hier wird angezeigt, ob die Datei komprimiert gesichert ist.
@{par}@{pard}@{i}komprimiert @{ui}
	@{lindent 12}Die Datei wurde mit dem eingebauten Komprimierer gesichert.
@{par}@{pard}@{i}XPK-komprimiert @{ui}
	@{lindent 12}Diese Datei wurde mit einem XPK-Modul gesichert.
@{par}@{pard}
@endnode
----------------------------------------------------------------------------
@node GadgFIDate "Datum und Uhrzeit"
@toc Main
@{settabs 12 20 30}Hier werden Datum und Uhrzeit der letzten Änderung dieser Datei angezeigt.
@endnode
----------------------------------------------------------------------------
@node GadgFIpercent "Kompressionsgrad"
@toc Main
@{settabs 12 20 30}Bei komprimierten Dateien wird hier der erzielte Kompressionsgrad angezeigt, z.B. @{i}um 69%@{ui}.
Hier bedeuten 69%, daß die Datei auf 31\%\ ihrer Originalgröße verdichtet wurde.
@endnode
----------------------------------------------------------------------------
@node GadgFIComplete "komplett: ja/nein"
@toc Main
@{settabs 12 20 30}Hier wird angezeigt, ob das Ende dieser Datei auf dem aktuellen Backup-Datenträger enthalten ist (ja) oder ob sie auf dem nächsten Datenträger fortgesetzt wird (Nein).
@endnode
----------------------------------------------------------------------------
@node GadgFIExtension "Extension-Nummer"
@toc Main
@{settabs 12 20 30}Hier wird die sogenannte Extension-Nummer dieses Eintrags angezeigt.
Wird eine große Datei auf mehrere Datenträger verteilt, hat sie auf jedem Datenträger einen eigenen Verzeichnis-Eintrag.
Die Folge-Einträge haben dann von 1 an aufsteigende Extension-Nummern.
@{par}@{pard}Eine Extension-Nummer von 3 bedeutet also, diese Datei ist auf mindestens 4 Disketten verteilt und im Moment ist gerade die vierte Disk eingelegt.
@{par}@{pard}Diese Information ist zur Fehlerdiagnose gedacht und für die normale Anwendung des Programms nicht von Bedeutung.
@endnode
----------------------------------------------------------------------------
@node GadgFIOffset "Byte-Offset auf dem Datenträger"
@toc Main
@{settabs 12 20 30}Hier wird die hexadezimale Adresse auf dem Datenträger angezeigt, ab der die Datei beginnt.
@{par}@{pard}Diese Information ist zur Fehlerdiagnose gedacht und für die normale Anwendung des Programms nicht von Bedeutung.
@endnode
----------------------------------------------------------------------------
@node GadgFIBlock "Blocknummer auf dem Datenträger"
@toc Main
@{settabs 12 20 30}Hier wird die Nummer des Blocks auf dem Datenträger angezeigt, in dem die Datei beginnt.
@{par}@{pard}Diese Information ist zur Fehlerdiagnose gedacht und für die normale Anwendung des Programms nicht von Bedeutung.
@endnode
----------------------------------------------------------------------------
@node GadgFIOk "Gadget 'Ok'"
@toc Main
@{settabs 12 20 30}Hiermit wird das @{"Fenster 'Restore Datei-Info'" link FileInfoWindow} geschlossen.
@endnode
----------------------------------------------------------------------------
@font topaz.font 8
----------------------------------------------------------------------------
@node DeviceSelectWindow "Fenster 'Restore: Gerät auswählen'"
@toc Main
@{settabs 12 20 30}@{"so sieht es aus" link Restore_NewDevWindow.iff/main}
@{par}@{pard}+-------------------------------+
|+-----------------------------+|
||@{"                            " link GadgDSList}||
||@{"                            " link GadgDSList}||
||@{"                            " link GadgDSList}||
||@{"                            " link GadgDSList}||
||@{"                            " link GadgDSList}||
||@{"                            " link GadgDSList}||
|+-----------------------------+|
|@{"   Ok   " link GadgDSOk}             @{" Abbruch " link GadgDSCancel}|
+-------------------------------+
@endnode
----------------------------------------------------------------------------
@font helvetica.font 13
----------------------------------------------------------------------------
@node GadgDSList "Geräte-Liste"
@toc Main
@{settabs 12 20 30}Zeigt eine Liste aller Geräte (Laufwerke) an, in denen Backup-Datenträger identifiziert werden konnten.
Zu jedem Eintrag werden Datum und Uhrzeit der Sicherung angezeigt.
@endnode
----------------------------------------------------------------------------
@node GadgDSOk "Gadget 'Ok'"
@toc Main
@{settabs 12 20 30}Dieses Gadget schließt das @{"Fenster 'Restore: Gerät auswählen'" link DeviceSelectWindow} und übernimmt das neu ausgewählte Gerät.
@endnode
----------------------------------------------------------------------------
@node GadgDSCancel "Gadget 'Abbruch'"
@toc Main
@{settabs 12 20 30}Dieses Gadget schließt das @{"Fenster 'Restore: Gerät auswählen'" link DeviceSelectWindow} und verwirft neu ausgewählte Geräte.
@endnode
----------------------------------------------------------------------------
@font topaz.font 8
----------------------------------------------------------------------------
@node AboutWindow "Fenster 'Über Restore'"
@toc Main
@{settabs 12 20 30}@{"so sieht es aus" link Restore_AboutWindow.iff/main}
@{par}@{pard}+-------------------------------+
|                               |
|                               |
|                               |
|                               |
|                               |
|    @{"ARexx Port: Restore.1" link GadgAboutARexxPortName}     |
|            @{"   Ok   " link GadgAboutOk}          |
+-------------------------------+
@endnode
----------------------------------------------------------------------------
@font helvetica.font 13
----------------------------------------------------------------------------
@node GadgAboutOk "Gadget 'Ok'"
@toc Main
@{settabs 12 20 30}Dieses Gadget schließt das @{"Fenster 'Über Restore'" link AboutWindow}.
@endnode
----------------------------------------------------------------------------
@node GadgAboutARexxPortName "Anzeige 'ARexx Port'"
@toc Main
@{settabs 12 20 30}??????
@endnode
----------------------------------------------------------------------------
@font topaz.font 8
----------------------------------------------------------------------------
@node NewDestWindow "Fenster 'Neues Ziel für Restore'"
@toc Main
@{settabs 12 20 30}@{"so sieht es aus" link Restore_NewDestWindow.iff/main}
@{par}@{pard}+-------------------------------------------------+
|                 Altes Ziel :                    |
|@{"                                                " link GadgNDOldDest}|
|                                                 |
|                  Neues Ziel :                   |
|@{"XX" link GadgNDFR} @{"                                             " link GadgNDNewDest}|
|                                                 |
| @{"   Ok   " link GadgNDOk}                             @{" Abbruch " link GadgNDCancel} |
+-------------------------------------------------+
@endnode
----------------------------------------------------------------------------
@font helvetica.font 13
----------------------------------------------------------------------------
@node GadgNDOldDest "Gadget 'Altes Ziel'"
@toc Main
@{settabs 12 20 30}Hier wird der originale (alte) Pfad angezeigt, der vom gerade markierten Eintrag in der @{"Verzeichnis-Anzeige" link DirDisplay} übernommen wird.
Die markierten Teile des Pfades werden später durch den Text im @{"Gadget 'Neues Ziel'" link GadgNDNewDest} ersetzt.
@{par}@{pard}Durch Ziehen mit der Maus kann die Größe der Markierung nach eingestellt werden. Ein Doppelklick markiert jeweils einen Teilpfad.
@endnode
----------------------------------------------------------------------------
@node GadgNDNewDest "Gadget 'Neues Ziel'"
@toc Main
@{settabs 12 20 30}Der Text in diesem Gadget ersetzt nach Betätigen von @{"Ok" link GadgNDOk} den markierten Text im @{"Gadget 'Altes Ziel'" link GadgNDOldDest}.
@{par}@{pard}Der neue Pfad kann auch ohne Tastatur mit einem @{"Verzeichnisauswahlfenster" link GadgNDFR} ausgesucht werden.
@endnode
----------------------------------------------------------------------------
@node GadgNDFR "Gadget 'Neues Ziel'"
@toc Main
@{settabs 12 20 30}Das Betätigen dieses Gadgets öffnet ein Verzeichnisauswahlfenster, mit dem ein neuer Pfad in das @{"Gadget 'Neues Ziel'" link GadgNDNewDest} eingetragen werden kann.
der ausgesuchte Pfad ersetzt nach Betätigen von @{"Ok" link GadgNDOk} den markierten Text im @{"Gadget 'Altes Ziel'" link GadgNDOldDest}.
@endnode
----------------------------------------------------------------------------
@node GadgNDOk "Gadget 'Ok'"
@toc Main
@{settabs 12 20 30}Hiermit wird das @{"Fenster 'Neues Ziel für Restore'" link NewDestWindow} geschlossen.
Für die Rücksicherung wird danach der veränderte Pfad benutzt.
@endnode
----------------------------------------------------------------------------
@node GadgNDCancel "Gadget 'Abbruch'"
@toc Main
@{settabs 12 20 30}Hiermit wird das @{"Fenster 'Neues Ziel für Restore'" link NewDestWindow} geschlossen.
Der Pfad für die Rücksicherung wird @{b}nicht@{ub} verändert.
@endnode
----------------------------------------------------------------------------
@font topaz.font 8
----------------------------------------------------------------------------
@node PwdWindow "Fenster 'Restore: Paßwort benötigt'"
@toc Main
@{settabs 12 20 30}@{"so sieht es aus" link Restore_PwdWindow.iff/main}
@{par}@{pard}Wenn die gesicherten Daten verschlüsselt sind, wird vor Beginn des ersten Rücksicherungs- oder Prüfvorganges mit diesem Fenster das benötigte Paßwort abgefragt.
Ohne Eingabe des gültigen Paßwortes kann auf die gesicherten Daten @{b}nicht@{ub} zugegriffen werden.
@{par}@{pard}+-----------------------------+
+  Paßwort zum Entschlüsseln  |
|@{"                            " link GadgPwdPassword}|
|                             |
|@{"   Ok   " link GadgPwdOk}        @{"  Abbruch  " link GadgPwdCancel}|
+-----------------------------+
@endnode
----------------------------------------------------------------------------
@font helvetica.font 13
----------------------------------------------------------------------------
@node GadgPwdOk "Gadget 'Ok'"
@toc Main
@{settabs 12 20 30}Bestätigt das eingegebene @{"Paßwort" link GadgPwdPassword} zum Entschlüsseln und beginnt die Rücksicherung oder das Prüfen.
@{par}@{pard}siehe auch
	@{"Gadget 'Abbruch'" link GadgPwdCancel}
@endnode
----------------------------------------------------------------------------
@node GadgPwdCancel "Gadget 'Abbruch'"
@toc Main
@{settabs 12 20 30}Verwirft ein eingebenes @{"Paßwort" link GadgPwdPassword} und bricht die Rücksicherung oder das Prüfen ab.
@{par}@{pard}siehe auch
	@{"Gadget 'Ok'" link GadgPwdOk}
@endnode
----------------------------------------------------------------------------
@node GadgPwdPassword "Gadget 'Paßwort für Verschlüsselung'"
@toc Main
@{settabs 12 20 30}Geben Sie hier Ihr Paßwort für die Entschlüsselung der Daten beim Rücksichern oder Prüfen an.
@endnode
----------------------------------------------------------------------------
@font topaz.font 8
----------------------------------------------------------------------------
@node FileSelectWindow "Fenster 'Restore Dateiauswahl'"
@toc Main
@{settabs 12 20 30}@{"so sieht es aus" link Restore_SelectWindow.iff/main}
@{par}@{pard}+--------------------------------------+
| @{"         alles        " link GadgFSSelectRange} Anwenden auf  |
|                                      |
|+-nach Name--------------------------+|
||@{"#?                    " link GadgFSInclude} Einschließen ||
||@{"                      " link GadgFSExclude} Ausschließen ||
|+------------------------------------+|
|                                      |
|+-nach Datum-------------------------+|
||+------------+     +------------+   ||
||| @{" " link GadgFSYounger} jünger   |     | @{" " link GadgFSOlder} älter   |   ||
||| @{" 1.01.80  " link GadgFSFromDate} | @{"<>" link GadgFSSwapDate} | @{" 17.07.96 " link GadgFSToDate} |   ||
||+------------+     +------------+   ||
|+------------------------------------+|
|                                      |
| @{"    egal   " link GadgFSCheckArchive} nach Archiv-Bit          |
|                                      |
| @{"   auswählen   " link GadgFSDoSelect}     @{"    abwählen   " link GadgFSDoDeselect} |
+--------------------------------------+
@endnode
----------------------------------------------------------------------------
@font helvetica.font 13
----------------------------------------------------------------------------
@node GadgFSSelectRange "Gadget 'Anwenden auf'"
@toc Main
@{settabs 12 20 30}Legt fest, auf welchen Bereich der Sicherung die Dateiauswahlkriterien angewandt werden:
@{par}@{pard}@{b}alles@{ub}	@{lindent 12}Es werden alle Verzeichnisse der gesamten Sicherung berücksichtigt.
@{par}@{pard}@{b}aktuelles Baum@{ub}	@{lindent 12}@{par}@{pard}Es wird das gerade ausgewählte Verzeichnis inclusive aller enthaltenen Unterverzeichnisse brücksichtigt.
@{par}@{pard}@{b}aktuelles Verzeichnis@{ub}	@{lindent 12}@{par}@{pard}Es wird nur das gerade ausgewählte Verzeichnis, ohne enthaltene Unterverzeichnisse, brücksichtigt.
@{par}@{pard}
@endnode
----------------------------------------------------------------------------
@node GadgFSToDate "Gadget 'End-Datum'"
@toc Main
@{settabs 12 20 30}@{b}dd.mm.tt @{ub}
@{lindent 12}	Es werden nur Dateien markiert, die vor dem Tag @{b}tt.mm.jj@{ub} verändert wurden, also alle Dateien älter als @{b}dd.mm.tt@{ub}.
@{lindent 0}
Dieses Datum wird ignoriert, wenn das @{"Gadget 'älter als'" link GadgFSOlder} ausgeschaltet ist.
@{par}@{pard}siehe auch
	@{"Gadget 'jünger'" link GadgFSYounger}
	@{"Gadget 'Start-Datum'" link GadgFSFromDate}
	@{"Gadget '<>'" link GadgFSSwapDate}
@endnode
----------------------------------------------------------------------------
@node GadgFSFromDate "Gadget 'Start-Datum'"
@toc Main
@{settabs 12 20 30}@{b}dd.mm.tt @{ub}
@{lindent 12}	Es werden nur Dateien markiert, die am oder nach dem Tag @{b}tt.mm.jj@{ub} verändert wurden, also alle Dateien jünger als @{b}dd.mm.tt@{ub}.
@{lindent 0}
Dieses Datum wird ignoriert, wenn das @{"Gadget 'jünger'" link GadgFSYounger} ausgeschaltet ist.
@{par}@{pard}siehe auch
	@{"Gadget 'älter'" link GadgFSOlder}
	@{"Gadget 'End-Datum'" link GadgFSToDate}
	@{"Gadget '<>'" link GadgFSSwapDate}
@endnode
----------------------------------------------------------------------------
@node GadgFSExclude "Gadget 'Ausschließen'"
@toc Main
@{settabs 12 20 30}Es werden keine Dateien markiert, deren Name auf dieses Muster paßt.
@{par}@{pard}Voreingestellt ist "", also @{b}keine@{ub} Dateien ausschließen.
@{par}@{pard}siehe auch
	@{"Gadget 'Einschließen'" link GadgFSInclude}
@endnode
----------------------------------------------------------------------------
@node GadgFSInclude "Gadget 'Einschließen'"
@toc Main
@{settabs 12 20 30}Es werden alle Dateien zur Markierung berücksichtigt, deren Name auf dieses Muster paßt.
@{par}@{pard}Voreingestellt ist "#?", also @{b}alle@{ub} Dateien einschließen.
@{par}@{pard}siehe auch
	@{"Gadget 'Ausschließen'" link GadgFSExclude}
@endnode
----------------------------------------------------------------------------
@node GadgFSSwapDate "Gadget '<>'"
@toc Main
@{settabs 12 20 30}vertauscht im Fenster @{"Restore Dateiauswahl" link FileSelectWindow} die Einträge für das @{"Start-Datum" link GadgFSFromDate} und das @{"End-Datum" link GadgFSToDate}.
@{par}@{pard}siehe auch
	@{"Gadget 'jünger'" link GadgFSYounger}
	@{"Gadget 'älter'" link GadgFSOlder}
@endnode
----------------------------------------------------------------------------
@node GadgFSOlder "Gadget 'älter'"
@toc Main
@{settabs 12 20 30}Wenn dieses Gadget eingeschaltet ist, werden nur die Dateien markiert, die älter sind als das @{"End-Datum" link GadgFSToDate}.
@{par}@{pard}siehe auch
	@{"Gadget 'jünger'" link GadgFSYounger}
	@{"Gadget 'Start-Datum'" link GadgFSFromDate}
	@{"Gadget '<>'" link GadgFSSwapDate}
@endnode
----------------------------------------------------------------------------
@node GadgFSYounger "Gadget 'jünger'"
@toc Main
@{settabs 12 20 30}Wenn dieses Gadget eingeschaltet ist, werden nur die Dateien markiert, die jünger sind als das @{"Start-Datum" link GadgFSFromDate}.
@{par}@{pard}siehe auch
	@{"Gadget 'End-Datum'" link GadgFSToDate}
	@{"Gadget 'älter'" link GadgFSOlder}
	@{"Gadget '<>'" link GadgFSSwapDate}
@endnode
----------------------------------------------------------------------------
@node GadgFSCheckArchive "Gadget 'nach Archiv-Bit'"
@toc Main
@{settabs 12 20 30}Es werden alle Dateien anhand des Archiv-Bits markiert:
@{par}@{pard}@{b}egal@{ub}	@{lindent 12}Es werden ALLE Dateien, unabhängig vom Archiv-Bit, zur Markierung berücksichtigt.
@{par}@{pard}@{b}gelöscht@{ub}	@{lindent 12}@{par}@{pard}Es werden nur Dateien mit gelöschtem Archiv-Bit zur Markierung berücksichtigt, also Dateien, die seit der letzten Sicherung verändert wurden.
@{par}@{pard}@{b}gesetzt@{ub}	@{lindent 12}@{par}@{pard}Es werden nur Dateien mit gesetztem Archiv-Bit zur Markierung berücksichtigt, also Dateien, die seit der letzten Sicherung nicht verändert wurden.
@endnode
----------------------------------------------------------------------------
@node GadgFSDoSelect "Gadget 'auswählen'"
@toc Main
@{settabs 12 20 30}Hiermit werden sämtliche Dateien, die die Auswahlkriterien erfüllen, markiert.
@{par}@{pard}siehe auch
	@{"Gadget 'abwählen'" link GadgFSDoDeselect}
	@{"Gadget 'Anwenden auf'" link GadgFSSelectRange}
	@{"Gadget 'Start-Datum'" link GadgFSFromDate}
	@{"Gadget 'End-Datum'" link GadgFSToDate}
	@{"Gadget 'Einschließen'" link GadgFSInclude}
	@{"Gadget 'Ausschließen'" link GadgFSExclude}
	@{"Gadget 'nach Archiv-Bit'" link GadgFSCheckArchive}
@endnode
----------------------------------------------------------------------------
@node GadgFSDoDeselect "Gadget 'abwählen'"
@toc Main
@{settabs 12 20 30}Hiermit werden bei sämtlichen Dateien, die die Auswahlkriterien erfüllen, die Markierung aufgehoben.
@{par}@{pard}siehe auch
	@{"Gadget 'auswählen'" link GadgFSDoSelect}
	@{"Gadget 'Anwenden auf'" link GadgFSSelectRange}
	@{"Gadget 'Start-Datum'" link GadgFSFromDate}
	@{"Gadget 'End-Datum'" link GadgFSToDate}
	@{"Gadget 'Einschließen'" link GadgFSInclude}
	@{"Gadget 'Ausschließen'" link GadgFSExclude}
	@{"Gadget 'nach Archiv-Bit'" link GadgFSCheckArchive}
@endnode
----------------------------------------------------------------------------
@font topaz.font 8
----------------------------------------------------------------------------
@node OptionsWindow "Fenster 'Restore Einstellungen:Anzeige'"
@toc Main
@{settabs 12 20 30}@{"so sieht es aus" link Restore_OptionsWindow1.iff/main}
@{par}@{pard}
+------------------------------------------------+
| @{b}Anzeige@{ub}   @{"Restaurieren" link OptionsWindowRestore}    @{"Prüfen" link OptionsWindowVerify}   @{"allgemein" link OptionsWindowGlobal}  |
|------------------------------------------------|
| +Attribute anzeigen+ +----Sortieren nach----+  |
| | @{" " link GadgViewSize} Dateigröße     | | @{" " link GadgSortFiles} unsortiert        |  |
| | @{" " link GadgViewFlags} Flags          | | @{" " link GadgSortFiles} nach Name         |  |
| | @{" " link GadgViewDate} Datum          | | @{" " link GadgSortFiles} nach Größe        |  |
| | @{" " link GadgViewTime} Uhrzeit        | | @{" " link GadgSortFiles} nach Datum/Uhrzeit|  |
| +------------------+ +----------------------+  |
|                                                |
|   @{" " link GadgSplitFileDisplay} Dateianzeige aufteilen                     |
|                                                |
+------------------------------------------------+
@endnode
----------------------------------------------------------------------------
@node OptionsWindowRestore "Fenster 'Restore Einstellungen:Restaurieren'"
@toc Main
@{settabs 12 20 30}@{"so sieht es aus" link Restore_OptionsWindow2.iff/main}
@{par}@{pard}
+------------------------------------------------+
| @{"Anzeige" link OptionsWindow}   @{b}Restaurieren@{ub}    @{"Prüfen" link OptionsWindowVerify}   @{"allgemein" link OptionsWindowGlobal}  |
|------------------------------------------------|
| +----------Dateien überschreiben------------+  |
| | @{" " link GadgOverwrite} nach Bestätigung                        |  |
| | @{" " link GadgOverwrite} immer                                   |  |
| | @{" " link GadgOverwrite} niemals                                 |  |
| | @{" " link GadgOverwrite} nur ältere Dateien                      |  |
| | @{" " link GadgOverwrite} jüngere Dateien bestätigen              |  |
| +-------------------------------------------+  |
|                                                |
|   @{" " link GadgSafeRestore} Sicheres Restaurieren                      |
|                                                |
+------------------------------------------------+
@endnode
----------------------------------------------------------------------------
@node OptionsWindowVerify "Fenster 'Restore Einstellungen:Prüfen'"
@toc Main
@{settabs 12 20 30}@{"so sieht es aus" link Restore_OptionsWindow3.iff/main}
@{par}@{pard}
+------------------------------------------------+
| @{"Anzeige" link OptionsWindow}   @{"Restaurieren" link OptionsWindowRestore}    @{b}Prüfen@{ub}   @{"allgemein" link OptionsWindowGlobal}  |
|------------------------------------------------|
|   @{" " link GadgVerifyContents} Inhalt prüfen                              |
|   @{" " link GadgVerifyFlags} Flags prüfen                               |
|   @{" " link GadgVerifyDateTime} Uhrzeit&Datum prüfen                       |
|   @{" " link GadgVerifyFilenote} Kommentar prüfen                           |
|                                                |
|                                                |
+------------------------------------------------+
@endnode
----------------------------------------------------------------------------
@node OptionsWindowGlobal "Fenster 'Restore Einstellungen:allgemein'"
@toc Main
@{settabs 12 20 30}@{"so sieht es aus" link Restore_OptionsWindow4.iff/main}
@{par}@{pard}
+------------------------------------------------+
| @{"Anzeige" link OptionsWindow}   @{"Restaurieren" link OptionsWindowRestore}    @{"Prüfen" link OptionsWindowVerify}   @{b}allgemein@{ub}  |
|------------------------------------------------|
| +-----------Von Hand eintragen--------------+  |
| | @{" " link GadgManualFileName} Dateinamen         @{" " link GadgManualLinkDest} Link-Ziele        |  |
| +-------------------------------------------+  |
|                                                |
|   @{" " link GadgStopOnError} Anhalten bei Fehlern                       |
