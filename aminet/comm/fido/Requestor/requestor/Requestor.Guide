Path settings
-------------

    Lha      @{" Stringgadget " link mstringpath} @{"@" link mrequesterpath}
    Unzip    @{" Stringgadget " link mstringpath} @{"@" link mrequesterpath}
    Zip      @{" Stringgadget " link mstringpath} @{"@" link mrequesterpath}
    Spot     @{" Stringgadget " link mstringpath} @{"@" link mrequesterpath}
    TrapDoor @{" Stringgadget " link mstringpath} @{"@" link mrequesterpath}
    TrapList @{" Stringgadget " link mstringpath} @{"@" link mrequesterpath}
