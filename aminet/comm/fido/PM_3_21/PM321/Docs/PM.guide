@NODE Introduction "Introduction of PM V3.21"
@PREV "Main"
@NEXT "Overall"
@TOC "Main"
   Introduction

                           @{b}@{u}Point Manager V3.21@{uu}@{ub}


                             Full Integrated
                          Tosser/Scanner/Editor


