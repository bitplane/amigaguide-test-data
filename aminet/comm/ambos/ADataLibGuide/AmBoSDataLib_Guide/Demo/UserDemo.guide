@database AmigaGuide.guide
@master Guide f³r die Demos zur Library

@node "UserDemo" "UserDemo"

/*-------------------------------------*/
/* Programm:    User Listen            */
/*-------------------------------------*/
/* Funktion:  Listet alle User dieser  */
/*            Mail Box                 */
/*-------------------------------------*/

/*-------- Standart Includes ----------*/

#include <exec/exec.h>
#include <utility/tagitem.h>
#include <dos/dos.h>

#include <clib/exec_protos.h>
#include <clib/dos_protos.h>
#include <pragmas/exec_pragmas.h>
#include <pragmas/dos_pragmas.h>
/*-------------------------------------*/

/*----- AmBoSDataLibrary Includes -----*/

#include <clib/AmBoSData_protos.h>
#include <libraries/AmBoSTags.h>

/*-------------------------------------*/

/* f³r die Dos.Library             */
/* kommt von der c.o  ;-)) bei SAS */

extern struct Library *DOSBase;

/* Festlegung der Variablen */

char UserName[128];
ULONG ULoad,DLoad;

/* AmBoSDataLibrary ÷ffnen */

struct Library *ADL_Open(void)
{
  AmBoSDataBase = OpenLibrary("ambosdata.library",0L);
  return (AmBoSDataBase);
}

/* AmBoSDataLibrary schlie▀en */

void ADL_Close(void)
{
  if(AmBoSDataBase)
    CloseLibrary(AmBoSDataBase);
}
/*-------------------------------------*/
/* Funktion:  Ermitelt die lõnge eines */
/*            Textes                   */
/*-------------------------------------*/
/* Parameter:                          */
/*    Text Zeiger auf einen String     */
/* R³ckgabe :                          */
/*    Die lõnge/String mu▀ Null        */
/*    Terminiert sein                  */
/*-------------------------------------*/

int GetLen(char *Text)
{
  int i = 0;

  while(Text[i] != 0)
  {
    i++;
  }
  return (i);
}

/*-------------------------------------*/
/* Funktion: Ausgabe eines Textes und  */
/*           zweier ULONG werte        */
/*-------------------------------------*/
/* Parameter:                          */
/*          char *Name Zeiger auf Text */
/*         ULONG Upload, Download      */
/* R³ckgabe :                          */
/*           Keine R³ckgabe            */
/*-------------------------------------*/

void Print(char *Name, ULONG UL, ULONG DL)
{
char fuel[] = "                              ";

  Name[30] = 0; /* mehr wie 30, un³bersichtlich */

  FPuts(Output(),Name); /* Text ausgeben */
  FPuts(Output(),&fuel[GetLen(Name)]); /* Leerzeichen auff³llen */
    /* Down und Upload ausgeben */
	FPuts(Output(),&fuel[(VFPrintf(Output(),
                        "Uploads   :%lu",&UL)+10)]);
	FPuts(Output(),&fuel[(VFPrintf(Output(),
                        "Downloads :%lu",&DL)+10)]);
}
	

APTR GetNext(APTR User)
{
  APTR NUser;

  if(! User)      /* Nichts bekommen wieder */
    return (NULL);/* zur³ck, mit nichts     */

  /* Neues User Objekt holen, altes freigeben */
  NUser = ADataSetTag(DATASET_Next,User,
                      DATASET_Free,User,TAG_DONE);
  return (NUser); /* Neues Objekt zur³ck */
}

/*-------------------------------------*/
/*    Ausgabe der User dieser Box      */
/*-------------------------------------*/
/* Parameter: Keine                    */
/* R³ckgabe :                          */
/*            Immer Null               */
/*-------------------------------------*/

int main (void)
{
APTR User;  /* F³r das User Objekt */

  if(! ADL_Open())  /* Eigene ųffnungs Routine */
  {
    /* Falls das ųfnen Fehlschlug */

    FPuts(Output()," Hallo, hallo, Irgenwas lupt hier nicht !\\n");
    FPuts(Output()," AmBoS mu▀ laufen und die AmBoSDataLibrary\\n");
    FPuts(Output()," mu▀ ebenfalls Installiert sein !\\n");
    return 0;
  }

    /*---------------------------------*/
    /*   Das Objekt f³r Userzugriff    */
    /*---------------------------------*/

    User = ADataSetTag(DATASET_First,DATATYPE_User,TAG_DONE);

      /* Erstes User-Objekt erhalten */
    while(User)
    {
      /* User Namen hollen */

      if(AGetAttrTag(User, USER_UserName, UserName,USER_Uploads,&ULoad,
						USER_Downloads,&DLoad,TAG_DONE) != FALSE) 
      {
        /* Bei Erfolg ausgeben */
        FPuts(Output(),"\\n");
        Print(UserName,ULoad,DLoad);

         if(CheckSignal(SIGBREAKF_CTRL_C))    /* CTRL&C Checken */
         {
          ADataSetTag(DATASET_Free,User,TAG_DONE);
          ADL_Close();
          FPuts(Output(),"\\nTschaui, mu▀ das schon sein ?\\n");
          return (NULL);
         }
      }

      /* Nõchstes User Objekt holen */
      User = GetNext(User);
    }

    FPuts(Output(), "\\n\\n Das warn denn wohl alle !\\n");

    /* AmBoSData.Library wieder schlie▀en */

    ADL_Close();
    return (NULL);
}

			@{"Hauptmen³" link "AmBoSDataLibrary.guide/main" 0}
