@node con " ..............Contris!-SCRIPT-FILE........... "
@Next "Contris"
@Prev "Contris"
@Toc "Menue"
       ..............Contris!-SCRIPT-FILE...........

       .key UserName
       .bra {
       .ket }

       assign DOORS: <contris!-DIR>
       assign USER:  <contris!-DIR/USER>

       IF NOT EXISTS USER:{UserName}
       makedir USER:{UserName}
       ; Wir stellen einmal die Farbanzahl (z.B. des Sysops) auf 8
       ; den Rest geben wie nach Vorgabe ein, dann kopieren wir
       ; das contris.data aus USER:Sysop in Doors: und schon kann
       ; es mit diesem Script abgehen! ;))
       copy Doors:contris.data.8Farben to USER:{UserName}/contris.data
       Contris! {UserName} contris.config
       ..............................................

@EndNode

