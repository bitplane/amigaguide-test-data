@node cardsc " ..............CardGuppies-SCRIPT-FILE........... "
@Next "card"
@Prev "card"
@Toc "Menue"
       ..............CardGuppies-SCRIPT-FILE...........

       .key UserName
       .bra {
       .ket }

       assign DOORS: <ParentDIR vom CardGuppies-III-DIR>
       ; z.B: BBS:doors bei bbs:doors/CardGuppies-III/CardGuppies-III
       assign XBULLETINS:  <Pfad zum CardGuppies-III-DIR>
       ; z.B: bbs:doors/CardGuppies-III

       CardGuppies-III {UserName} . 100 .
       ..............................................

