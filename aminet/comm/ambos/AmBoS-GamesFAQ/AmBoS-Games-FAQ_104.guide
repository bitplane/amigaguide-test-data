@node XBJ " .................XBJ-SCRIPT-FILE............. "
@Next "BlackJack"
@Prev "BlackJack"
@Toc "Menue"

                      .................XBJ-SCRIPT-FILE.............
 
                      .key UserName
                      .bra {
                      .ket }
                      
                      stack 8000
                      assign DOORS: <ParentDIR vom XBJ-DIR>
                      ; z.B: BBS:doors bei bbs:doors/XBJ/XBJ
                      XBJ {UserName}
                      ..............................................


