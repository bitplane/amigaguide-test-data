@node smud " ..............AmigaMUD-SCRIPT-FILE........... "
@Next "AmigaMUD"
@Prev "AmigaMUD"
@Toc "Menue"

                      ..............AmigaMUD-SCRIPT-FILE...........
 
                      .key UserName  ; wenn man den USER:
                      .bra {         ; M.Bruchmann bei sich spielen
                      .ket }         ; lassen will, muß man diese Zeilen
                                     ; und das -N{UserName} weglassen :))
                                     ; sowie das {U} bei Optionen
                      stack 20000
                      SMUD -r -a -N{UserName}
                      echo ""
                      echo ""
                      echo ">>>>>>>Updating MUD-Data...<<<<<<<"
                      echo ""

                      MUDFlush
                      ..............................................


@EndNode

