       5  - event window is not open
       30 - failure

   @{b}EXAMPLE@{ub}

   @{b}NOTES@{ub}
       New for THOR 2.0

   @{b}BUGS@{ub}

   @{b}SEE@{ub} @{b}ALSO@{ub}
       @{"READBREVENT" LINK "BBSReadRexx.guide/READBREVENT" 0}

@ENDNODE

