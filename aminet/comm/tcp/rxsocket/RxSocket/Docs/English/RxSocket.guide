  @{b}Result@{ub}
    ip - host part

  @{b}See@{ub}
    @{"InetMakeAddr()" LINK "InetMakeAddr"} @{"InetNetOf()" LINK "InetNetOf"}

@EndNode

@Node "InetMakeAddr" "RxSocket Functions - InetMakeAddr"

  @{b}InetMakeAddr@{ub} - create an IP address from network
                 number and host

  @{b}Synopsis@{ub}
    ip=InetMakeAddr(net,lna)
    <addr>,<lna>

  @{b}Function@{ub}
    It takes an Internet network number and a local network
    address and constructs an Internet address from it.

    This function has been deprecated, because it depends
    on an obsolete fixed Internet addressing scheme.

  @{b}Inputs@{ub}
    net - network number
    lna - host number

  @{b}Result@{ub}
    ip - ip address

  @{b}See@{ub}
    @{"InetLnaOf()" LINK "InetLnaOf"} @{"InetNetOf()" LINK "InetNetOf"}

@EndNode

@Node "InetNetOf" "RxSocket Functions - InetNetOf"

  @{b}InetNetOf@{ub} - returns network part of IP address

  @{b}Synopsis@{ub}
    ip=InetNetOf(addr)
    <addr>

  @{b}Function@{ub}
    It breaks apart Internet host addresses returning
    only the network number.

    This function has been deprecated, because it depends
    on an obsolete fixed Internet addressing scheme.

  @{b}Inputs@{ub}
    addr - ip address

  @{b}Result@{ub}
    ip - network part

  @{b}See@{ub}
    @{"InetLnaOf()" LINK "InetLnaOf"} @{"InetMakeAddr()" LINK "InetMakeAddr"}

@EndNode

@Node "InetNTOA" "RxSocket Functions - InetNTOA"

  @{b}InetNTOA@{ub} - converts from integer to dotted

  @{b}Synopsis@{ub}
    addrString=InetNTOA(addr)
    <addr>

  @{b}Function@{ub}
    Converts 'addr', a string of decimal digits, to dotted.

  @{b}Inputs@{ub}
