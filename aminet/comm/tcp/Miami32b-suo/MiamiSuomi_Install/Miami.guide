 @{" Tiedosto " Link "NODE_GUI_LOGGING_FILE"}                                `Tiedosto'-kenttð
 @{" Kðytð syslogia " Link "NODE_GUI_LOGGING_SYSLOG"}                          `Kðytð syslog.library-kirjastoa'-valinta
 @{" Puhelinloki " Link "NODE_GUI_LOGGING_PHONE"}                             `Puhelinloki'-ryhmð
 @{" PPP-loki " Link "NODE_GUI_LOGGING_PPP"}                                `PPP-loki'-ryhmð


