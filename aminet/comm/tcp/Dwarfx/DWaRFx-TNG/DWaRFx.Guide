                          -f -r Now Im female robotic
                          -m -n Male Natural!
                          -s300 -f -r -p100 Fast, female, robotic and low pitch!

                          -s<40-400> = speed -m = Male -f = Female -n= Natural
                          -p<65-320> = Pitch -r = Robotic
