@NODE "FileArea" "FileArea"

 @{b}FileArea@{ub} = Shows the selected FileArea. This is the filearea to which the file is added.
@ENDNODE

@NODE "SelectFileArea" "Select FileArea"

 @{b}O@{ub} = Selects a FileArea.
@ENDNODE

@NODE "Description" "File Description"

 @{b}File Description@{ub} = Shows the current file description. Dubble clicking on it will restore the Line Description.
@ENDNODE

@NODE "LineDescription" "Line Description"

 @{b}Line Description@{ub} = Here you can edit the file description.
@ENDNODE

@NODE "EditDescription" "Edit FileDescription"

 @{b}O@{ub} = Here you can edit the file description with an external editor. The external editor must be set with the tooltype EDITOR.
@ENDNODE

@NODE "File" "Select File Action"

 @{b}File@{ub} = You can select whether you want to COPY or MOVE the file to the filearea.
@ENDNODE

@NODE "AutoDesc" "Automatic Description"

 @{b}Description@{ub} = Select what type of autodescripion you want. You can select None/Aminet or FileID. to use the FileID you have to set the tooltype FILEID.
@ENDNODE

@NODE "Uploader" "Name Uploader"

 @{b}Uploader@{ub} = Uploaders name.
@ENDNODE

@NODE "filename" "FileName"

 @{b}FileName@{ub} = Full filename and path.
@ENDNODE

@NODE "filepopup" "Select Filename"

 @{b}FilePopup@{ub} = Pops up a filerequestor. Select a filename (with full path)
@ENDNODE

@NODE "UPLOAD" "Uploading"

 @{b}Uploading@{ub} = Uploads a File to the selected FileArea.
@ENDNODE

@NODE "CLEAR" "Clearing Fields"

 @{b}Clear@{ub} = Resets the Description, Line Descriptions and Filename to default.
@ENDNODE

@NODE "BULK"

 @{b}Bulk@{ub} = NOT YET IMPLEMENTED
@ENDNODE

@NODE "README" "Reads .readme"

 @{b}Readme@{ub} = Reads the aminet .readme in an external editor. The tooltype EDITOR has to be set.
@ENDNODE

@NODE "Status" Status Field"

 @{b}Status@{ub} = Displays the current status of MUIUploaderX. The following Status fields are know:

     - Successfull.
     - Adding file to catalogue.
     - Failure, file already in catalogue.
     - Editing file description.
     - Reading Aminet .readme.
     - Searching for File_ID.Diz.
@ENDNODE

@NODE "Bugs" "Known Bugs"
 - None That I know of.
@ENDNODE

