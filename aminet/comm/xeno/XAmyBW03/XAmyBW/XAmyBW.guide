 - Settings Menu -


@{"ĀDirectoriesĀ" link "Directories" 0}
@{"ĀEditorĀ" link "Editor" 0}
@{"ĀGUIĀ" link "GUI" 0}
@{"ĀOptionsĀ" link "Options" 0}
