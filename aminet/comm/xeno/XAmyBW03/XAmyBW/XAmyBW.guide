@{"ĀMoveĀ" link "Move" 0}
@{"ĀWriteĀ" link "Write" 0}
@{"ĀWriteĀInĀArea" link "Write_In_Area" 0}
@{"ĀForwardĀ" link "Forward" 0}
@{"ĀSaveĀAsĀ" link "Save_as" 0}
