@node rectype "3.2.1 record types"
@{U}3.2.1 Record types@{uu}

#define mode_hilight            0x8000
#define mode_phone              0x9000
#define mode_remind             0x9100
#define mode_expense            0x9200
#define mode_memo               0xA000
#define mode_schedule           0xB000
#define mode_biz_card           0xC000
#define mode_to_do              0xC100


@endnode

