@Node "x1_0"
@Title "Menu-Help per il sottomenu īīScreen-Formatīī"

               Sottomenu "Screen-Format" (= "formato di schermo")
               =========================

      voce  @{" einstellen " Link x1_0_0}  (= "settare")
      voce  @{" Standard laden " Link x1_0_1}  (= "caricare come standard")
      voce  @{" laden " Link x1_0_2}  (= "caricare")
      voce  @{" sichern als Standard " Link x1_0_3}  (= "salvare come standard")
