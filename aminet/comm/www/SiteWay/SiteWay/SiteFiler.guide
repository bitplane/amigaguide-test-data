@macro bold "@{b}$1@{ub}"
@macro italic "@{i}$1@{ui}"
@macro uline "@{u}$1@{uu}"
@macro white "@{fg highlight}$1@{fg text}"
@macro black "@{bg shadow}$1@{bg background}"
@macro blue "@{b}@{fg fill}$1@{fg text}@{ub}"

@macro Title_Header "@{bg fill}@{b}@{fg highlight} SITE  @{bg background}@{tab}$1@{ub}@{fg text}@{par}"
@macro Title_String "@{bg fill}@{b}@{fg highlight} WAY @{fg text}@{ub}@{bg background}@{tab}$1@{par}"
@macro Title_Footer "@{bg highlight}@{b}@{fg fill}  ˛°°°   @{fg text}@{ub}@{bg background}@{tab}$1@{par}"

@macro Menu_Title  "@{fg shine}@{bg shadow}@{b}$1@{ub}@{bg background}@{fg text}"
@macro Menu_ItemKS "@{fg shadow}@{bg shine}@{b}$1@{fg shine}@{bg shadow}  A  @{ub}@{bg shine}@{fg shadow} $2 @{fg text}@{bg background}"
@macro Menu_ItemNK "@{fg shadow}@{bg shine}@{b}$1@{ub}@{fg text}@{bg background}"
@macro Menu_BR-Bar "@{fg shadow}@{bg shine}$1@{ub}@{fg text}@{bg background}"

@macro Key_Pressed "@{bg fill} @{fg background}@{b}$1@{ub} @{bg background}@{fg text}"
@macro Key_Button "@{bg fill} @{fg background}@{b}@{i}A@{ui}  @{bg background}@{fg fill} $1@{ub}@{fg text}@{bg background}"

