@node "Manually" "Manuall installation"
@prev "Installation"


 @{fg shine}Manual installation:@{fg text}


 Copy contents of "bin/amirc" to "@{fg fill}?@{fg text}/Amirc/".

 Delete "Fonts:funfont#?".

 Rename "Envarc:MUI/AMIRC.1.prefs" to "Envarc:MUI/AMIRC.1.prefs.bak".

 "lha x -X -q bin/fonts/@{fg fill}??@{fg text}.fnt Fonts:".

 Copy "bin/envarc/amirc@{fg fill}?@{fg text}" to "Envarc:MUI/AMIRC.1.prefs".


 @{fg shine}Do you want to install an enhanced keymap ?@{fg text}

 Copy "bin/keymaps/@{fg fill}???@{fg text}" to "Keymaps:FunFont".

 Copy "bin/misc/key" to "Keymaps:FunFont.info".

 Rename "Envarc:SYS/Input.prefs" to "Envarc:SYS/Input.prefs.bak".

 Copy "bin/envarc/input" to "Envarc:SYS/Input.prefs".


 @{fg shine}Select the support files to be installed...@{fg text}

 Create New Directory: "@{fg fill}?@{fg text}:FunFont".

 Copy "bin/misc/DRW" to "@{fg fill}?@{fg text}:FunFont.info".

 Copy "GUIDE" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "GUIDE.info" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "bin/fonts/FFGuide.font" to "Fonts:".

 Copy contents of "bin/fonts/FFGuide" to "Fonts:FFGuide/".

 Copy contents of "Images" to "@{fg fill}?@{fg text}:FunFont/Images/".

 Copy "bin/misc/ADVUSR" to "@{fg fill}?@{fg text}:FunFont/Images/".

 Copy "bin/misc/CODES" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "bin/misc/CODES.info" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "bin/misc/FANSI" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "bin/misc/FANSI.info" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "bin/misc/KEYS" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "bin/misc/KEYS.info" to "@{fg fill}?@{fg text}:FunFont/".


 @{fg shine}Select the EXTRA files to install...@{fg text}

 Copy "bin/misc/FONTINSTALL" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "bin/misc/FONTINSTALL.info" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "bin/fonts/#?.fnt" to "@{fg fill}?@{fg text}:FunFont/Fonts/".

 Copy "images/FontPreview.pic" to "@{fg fill}?@{fg text}:FunFont/Images/".

 Copy "AMIRC#?" to "@{fg fill}?@{fg text}:FunFont/Fonts/".

 Copy "bin/misc/FANSIMAKER" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "bin/misc/FANSIMAKER.info" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "bin/misc/NEW.fansi" to "@{fg fill}?@{fg text}:FunFont/".

 Copy "bin/misc/GEditor" to "C:".

 Copy "bin/envarc/GEDITOR" to "Envarc:MUI/GEDITOR.1.prefs".

 Copy "bin/misc/Textfield.gadget" to "SYS:Classes/Gadgets/" (if none/old).


