        @{"     SendModem               " link TBSendModem}
        @{"     SendModemWD             " link TBSendModemWD}
        @{"     SetAccessPreset         " link TBSetAccessPreset}
        @{"     SetAreaMode             " link TBSetAreaMode}
        @{"     SetAverageCps           " link TBSetAverageCps}
        @{"     SetByteRatio            " link TBSetByteRatio}
        @{"     SetBytesDownloaded      " link TBSetBytesDownloaded}
        @{"     SetBytesLeft            " link TBSetBytesLeft}
        @{"     SetBytesUploaded        " link TBSetBytesUploaded}
        @{"     SetCallsDay             " link TBSetCallsDay}
        @{"     SetCallsLeft            " link TBSetCallsLeft}
        @{"     SetFileRatio            " link TBSetFileRatio}
        @{"     SetFilesDownloaded      " link TBSetFilesDownloaded}
        @{"     SetFilesLeft            " link TBSetFilesLeft}
        @{"     SetFilesUploaded        " link TBSetFilesUploaded}
        @{"     SetHighRead             " link TBSetHighRead}
        @{"     SetMask                 " link TBSetMask}
        @{"     SetMaxTimeBank          " link TBSetMaxTimeBank}
        @{"     SetMessages             " link TBSetMessages}
        @{"     SetPassword             " link TBSetPassword}
        @{"     SetSimpleTerm           " link TBSetSimpleTerm}
        @{"     SetSlowTerm             " link TBSetSlowTerm}
        @{"     SetStatus               " link TBSetStatus}
        @{"     SetStripAll             " link TBSetStripAll}
        @{"     SetStripCols            " link TBSetStripCols}
        @{"     SetTerminalLines        " link TBSetTerminalLines}
        @{"     SetTimeBank             " link TBSetTimeBank}
        @{"     SetTimeCall             " link TBSetTimeCall}
        @{"     SetTimeDay              " link TBSetTimeDay}
        @{"     SetTimeLeft             " link TBSetTimeLeft}
        @{"     SetTotalCalls           " link TBSetTotalCalls}
        @{"     SetUploader             " link TBSetUploader}
        @{"     SetUserAccess           " link TBSetUserAccess}
        @{"     SetUserCharSet          " link TBSetUserCharSet}
        @{"     SetUserExtension        " link TBSetUserExtension}
        @{"     SetUserLanguage         " link TBSetUserLanguage}
        @{"     SetUserName             " link TBSetUserName}
        @{"     SetUserProtocol         " link TBSetUserProtocol}
        @{"     SetUserTimeLeft         " link TBSetUserTimeLeft}
        @{"     ShowMessage             " link TBShowMessage}
        @{"     UpdateFileList          " link TBUpdateFileList}
        @{"     Upload                  " link TBUpload}
        @{"     WriteMsg                " link TBWriteMsg}


@{b}Functions:@{ub}

TechnoBBS doesn't add itself to the ARexx function handler list, but gets
functions routed through TechCon.  All TechnoBBS functions must have the
node number as the first argument.

        @{"     AskInput                " link TBAskInput}
        @{"     CheckCarrier            " link TBCheckCarrier}
        @{"     CheckPassword           " link TBCheckPassword}
        @{"     CurrentSIG              " link TBCurrentSIG}
        @{"     GetAreaMode             " link TBGetAreaMode}
        @{"     GetAverageCps           " link TBGetAverageCps}
        @{"     GetByteRatio            " link TBGetByteRatio}
        @{"     GetBytesDownloaded      " link TBGetBytesDownloaded}
        @{"     GetBytesLeft            " link TBGetBytesLeft}
        @{"     GetBytesUploaded        " link TBGetBytesUploaded}
        @{"     GetCallsDay             " link TBGetCallsDay}
        @{"     GetCallsLeft            " link TBGetCallsLeft}
