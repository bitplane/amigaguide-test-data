@(C) SYSOP@starbase.pfalz.de    ( ab 01.11.1995 SYSOP@starbase.inka.de )
@NODE MAIN        " AmigaE-Modules for the ConnectLine 5.0 - Libraries "

                        AmigaE-Modules for Connectline5.0
                      -===================================-

  @{" clb.lib           " Link _clclb.m           }   @{" clb.lib<CONST>    " Link _clclb_lvo.m       }   @{" clcheck.lib       " Link _clclcheck.m       } 
  @{" clcheck.lib<CONST>" Link _clclcheck_lvo.m   }   @{" cll.lib           " Link _clcll.m           }   @{" clmacro.lib       " Link _clclmacro.m       } 
  @{" clmidb.lib        " Link _clclmidb.m        }   @{" clonline.lib      " Link _clclonline.m      }   @{" clp.lib           " Link _clclp.m           } 
  @{" clp_4.lib         " Link _clclp_4.m         }   @{" cls.lib           " Link _clcls.m           }   @{" clutil.lib        " Link _clclutil.m        } 
  @{" cl_accounts.lib   " Link _clcl_accounts.m   }   @{" cl_ipc.lib        " Link _clcl_ipc.m        }   @{" cl_log.lib        " Link _clcl_log.m        } 
  @{" cl_mail.lib       " Link _clcl_mail.m       }   @{" cl_mailmaster.lib " Link _clcl_mailmaster.m }   @{" cl_mail_fido.lib  " Link _clcl_mail_fido.m  }  
  @{" cl_mail_janus.lib " Link _clcl_mail_janus.m }   @{" cl_message.lib    " Link _clcl_message.m    }   @{" cl_mproc.lib      " Link _clcl_mproc.m      } 
  @{" cl_msg.lib        " Link _clcl_msg.m        }   @{" cl_mui.lib        " Link _clcl_mui.m        }   @{" cl_prefs.lib      " Link _clcl_prefs.m      } 
  @{" cl_route.lib      " Link _clcl_route.m      }   @{" cl_shell.lib      " Link _clcl_shell.m      }   @{" cl_system.lib     " Link _clcl_system.m     } 
  @{" cl_text.lib       " Link _clcl_text.m       }   @{" cl_xfer.lib       " Link _clcl_xfer.m       }   @{" cl_ansi.lib       " Link _clclansi.m        }
@ENDNODE

