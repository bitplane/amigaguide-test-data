    o @{"CLSET_UserMaxKB" link "Userdaten_Main" 464}(<username>,<maxkb>)
    o @{"CLSET_UserMaxDays" link "Userdaten_Main" 475}(<username>,<maxdays>)
    o @{"CLSET_UserUploads" link "Userdaten_Main" 486}(<username>,<uploads>)
    o @{"CLSET_UserDownloads" link "Userdaten_Main" 496}(<username>,<downloads>)
    o @{"CLSET_UserFreeFiles" link "Userdaten_Main" 506}(<username>,<freefiles>)
    o @{"CLSET_UserFreeKByte" link "Userdaten_Main" 516}(<username>,<freekbyte>)
    o @{"CLSET_UserRate" link "Userdaten_Main" 526}(<username>,<ratio>)




    o @{b}@{i}@{u}CLSET_UserPassword(<username>,<passwort>)@{ub}@{ui}@{uu}

       Setzt für einen User das Passwort.

       @{u}Parameter:@{uu}

        username - Username des Users
        passwort - Passwort des Users


    o @{b}@{i}@{u}CLSET_UserPriority(<username>,<priorität>)@{ub}@{ui}@{uu}

       Setzt die Priorität eines Users.

       @{u}Parameter:@{uu}

        username - Username des Users
        priorität- Priorität (0<=x<=99)


    o @{b}@{i}@{u}CLSET_UserPath(<username>,<pfad>)@{ub}@{ui}@{uu}

       Setzt den Pfad des Users.

       @{u}Parameter:@{uu}

        username - Username des Users
        pfad     - gültiger DOS-Pfad des Userverzeichnisses


    o @{b}@{i}@{u}CLSET_UserGroup(<username>,<gruppennr> [,<flag>])@{ub}@{ui}@{uu}

       Trägt den User in eine Gruppe ein bzw. aus.

       @{u}Parameter:@{uu}

        username - Username des Users
        gruppennr- Nummer der Gruppe
        flag     - optionales Flag; ist es '0', wird der User aus dieser
                   Gruppe ausgetragen. Ist es '1' oder fehlt es gänzlich,
                   wird ein Eintragen in die angegebene Gruppe versucht.


    o @{b}@{i}@{u}CLSET_UserRealname(<username>,<realname>)@{ub}@{ui}@{uu}

       Setzt den Realnamen des Users.

       @{u}Parameter:@{uu}

        username - Username des Users
        realname - Realname des Users


    o @{b}@{i}@{u}CLSET_UserAddress(<username>,<adresse>)@{ub}@{ui}@{uu}

       Setzt die Adresse des Users.

       @{u}Parameter:@{uu}

        username - Username des Users
        adresse  - Adresse des Users


    o @{b}@{i}@{u}CLSET_UserTelephone(<username>,<telefon>)@{ub}@{ui}@{uu}

       Setzt die Telefonnummer des Users.

       @{u}Parameter:@{uu}

        username - Username des Users
        telefon  - Telefonnummer des Users (String)


    o @{b}@{i}@{u}CLSET_UserSysopInfo(<username>,<sysopinfo>)@{ub}@{ui}@{uu}

       Setzt die Sysopinfo des Users.

       @{u}Parameter:@{uu}

        username - Username des Users
        sysopinfo- Informationstext


    o @{b}@{i}@{u}CLSET_UserMessage(<username>,<message>)@{ub}@{ui}@{uu}

       Setzt die Userinfo des Users.

       @{u}Parameter:@{uu}

        username - Username des Users
        unserinfo- Informationstext


    o @{b}@{i}@{u}CLSET_UserCopyTo(<username>,<vertreter>)@{ub}@{ui}@{uu}

       Setzt den Vertreter des Users.

       @{u}Parameter:@{uu}

        username - Username des Users
        vertreter- Vertreter des Users


    o @{b}@{i}@{u}CLSET_UserTerminal(<username>,<terminal>)@{ub}@{ui}@{uu}

       Setzt Terminaleinstellung des Users.

        @{u}Parameter:@{uu}

         username - Username des Users
         terminal - Entweder 'ANSI', 'VT100' oder 'TTY'


    o @{b}@{i}@{u}CLSET_UserLanguage(<username>,<sprache>)@{ub}@{ui}@{uu}

       Setzt die Spracheinstellung des Users.

       @{u}Parameter:@{uu}

        username - Username des Users
        sprache  - Sprache des Users (Default: 'DEUTSCH')


    o @{b}@{i}@{u}CLSET_UserKeyboard(<username>,<zeichensatz>)@{ub}@{ui}@{uu}

       Setzt den Zeichensatz des Users.

        @{u}Parameter:@{uu}

         username    - Username des Users
         zeichensatz - Entweder "IBM" oder "ISO"


    o @{b}@{i}@{u}CLSET_UserTimeout(<username>,<timeout>)@{ub}@{ui}@{uu}

       Setzt den Zeitlimit des Users.

        @{u}Parameter:@{uu}

         username - Username des Users
         timeout  - Zeitlimit des Users in Minuten


    o @{b}@{i}@{u}CLSET_UserAccount(<username>,<konto>)@{ub}@{ui}@{uu}

       Setzt den Kontostand des Users.

        @{u}Parameter:@{uu}

         username - Username des Users
         konto    - Kontostand des Users


    o @{b}@{i}@{u}CLSET_UserCredit(<username>,<kredit>)@{ub}@{ui}@{uu}

       Setzt den erlaubten Kredit des Users.

        @{u}Parameter:@{uu}

         username - Username des Users
         kredit   - Kredit


    o @{b}@{i}@{u}CLSET_UserLines(<username>,<zeilenzahl>)@{ub}@{ui}@{uu}

       Setzt die Zeilenzahl-Einstellung des Users.

        @{u}Parameter:@{uu}

         username   - Username des Users
         zeilenzahl - Zeilenzahl des Users


    o @{b}@{i}@{u}CLSET_UserProtocol(<username>,<protokoll>)@{ub}@{ui}@{uu}

       Setzt das Übertragungsprotokoll.

        @{u}Parameter:@{uu}

         username - Username des Users
         protokoll- Übertragungsprotokoll (Default: "ZMODEM")


    o @{b}@{i}@{u}CLSET_UserMaxKB(<username>,<maxkb>)@{ub}@{ui}@{uu}

       Setzt das maximale Haltevolumen in Kilobyte für den Cruncher im
       Postfach des Users.

        @{u}Parameter:@{uu}

         username - Username des Users
         maxkb    - Maximalvolumen


    o @{b}@{i}@{u}CLSET_UserMaxDays(<username>,<maxdays>)@{ub}@{ui}@{uu}

       Setzt die maximale Haltezeit in Tagen für den Cruncher im Postfach
       des Users.

        @{u}Parameter:@{uu}

         username - Username des Users
         maxdays  - maximale Haltezeit


    o @{b}@{i}@{u}CLSET_UserUploads(<username>,<uploads>)@{ub}@{ui}@{uu}

       Setzt die Uploads des Users in Kilobyte.

        @{u}Parameter:@{uu}

         username - Username des Users
         uploads  - Uploads


    o @{b}@{i}@{u}CLSET_UserDownloads(<username>,<downloads>)@{ub}@{ui}@{uu}

       Setzt die Downloads des Users in Kilobyte.

        @{u}Parameter:@{uu}

         username - Username des Users
         downloads- Downloads


    o @{b}@{i}@{u}CLSET_UserFreeFiles(<username>,<freefiles>)@{ub}@{ui}@{uu}

       Setzt die freien Files des Users.

        @{u}Parameter:@{uu}

         username - Username des Users
         freefiles- Anzahl der freien Files.


    o CLSET_UserFreeKByte(<username>,<freekbyte>)

       Setzt den Downloadfreiraum des Users.

        Parameter:

         username - Username des Users
         freekbyte- Downloadfreiraum


    o @{b}@{i}@{u}CLSET_UserRate(<username>,<ratio>)@{ub}@{ui}@{uu}

       Setzt die Up-/Downloadratio des Users.

        @{u}Parameter:@{uu}

         username - Username des Users
         ratio    - Up-/Downloadratio (1:x)



 3.4 Befehle zum Lesen der Userflags
 -----------------------------------

    Ist das jeweilige Flag gesetzt, liefern die Funktionen '1' zurück,
    ansonsten '0'.

    o @{"CLIS_UserInvisible" link "Userdaten_Main" 551}(<username>)
    o @{"CLIS_UserNetworkEnabled" link "Userdaten_Main" 556}(<username>)
    o @{"CLIS_UserAutoEntry" link "Userdaten_Main" 561}(<username>)
    o @{"CLIS_UserAutoRemove" link "Userdaten_Main" 567}(<username>)




    o @{b}@{i}@{u}CLIS_UserInvisible(<username>)@{ub}@{ui}@{uu}

       Abfrage, ob der User unsichtbar ist.


    o @{b}@{i}@{u}CLIS_UserNetworkEnabled(<username>)@{ub}@{ui}@{uu}

       Abfrage, ob der User netzberechtigt ist.


    o @{b}@{i}@{u}CLIS_UserAutoEntry(<username>)@{ub}@{ui}@{uu}

       Abfrage, ob der User automatisch eingetragen wurde (unbearbeiteter
       Userantrag).


    o @{b}@{i}@{u}CLIS_UserAutoRemove(<username>)@{ub}@{ui}@{uu}

       Abfrage, ob der User automatisch entfernt werden soll.




 3.5 Befehle zum Setzen der Userflags
 ------------------------------------

    Bei den Funktionen dieses Abschnittes sind die zu übergebenden Parameter
    von Funktion zu Funktion identisch und haben folgenden Inhalt:

        @{u}Parameter:@{uu}

         username  - Name des Users
         flag       - '0' bedeutet, das Flag wird gelöscht (FALSE)
                      '1' bedeutet, das Flag wird gesetzt (TRUE)

    o @{"CLSET_UserInvisible" link "Userdaten_Main" 594}(<username>,<flag>)
    o @{"CLSET_UserNetworkEnabled" link "Userdaten_Main" 599}(<username>,<flag>)
    o @{"CLSET_UserAutoEntry" link "Userdaten_Main" 604}(<username>,<flag>)
    o @{"CLSET_UserAutoRemove" link "Userdaten_Main" 609}(<username>,<flag>)




    o @{b}@{i}@{u}CLSET_UserInvisible(<username>,<flag>)@{ub}@{ui}@{uu}

       Flag, ob der User unsichtbar ist.


    o @{b}@{i}@{u}CLSET_UserNetworkEnabled(<username>,<flag>)@{ub}@{ui}@{uu}

       Flag, ob der User Netzberechtigung hat.


    o @{b}@{i}@{u}CLSET_UserAutoEntry(<username>,<flag>)@{ub}@{ui}@{uu}

       Flag, ob der User automatisch eingetragen wurde.


    o @{b}@{i}@{u}CLSET_UserAutoRemove(<username>,<flag>)@{ub}@{ui}@{uu}

       Flag, ob der User automatisch gelöscht wird.
@endnode

@node "Systemdaten_Main" "Befehle für Zugriffe auf Systeme"
@next "Online-Funktionen_Main"
@prev "Userdaten_Main"

 4. Befehle für Zugriff auf Systemdaten
 --------------------------------------

    Allgemeine Anmerkungen:
    -----------------------

    Wenn versucht wird, auf ein nicht existentes System zuzugreifen, wird
    beim Lesen generell ein Leerstring zurückgegeben, beim Schreiben '0'.


    4.1 @{"Allgemeine Befehle" link "Systemdaten_Main" 19}
    4.2 @{"Befehle zum Auslesen der Systemdaten" link "Systemdaten_Main" 77}
    4.3 @{"Befehle zum Setzen der Systemdaten" link "Systemdaten_Main" 198}




 4.1 Allgemeine Befehle
 ----------------------

    o @{"CL_SystemSavelist" link "Systemdaten_Main" 32}()
    o @{"CL_SystemNew" link "Systemdaten_Main" 38}(<systemname>)
    o @{"CL_SystemDelete" link "Systemdaten_Main" 45}(<systemname>)
    o @{"CLGET_SystemNumberOf" link "Systemdaten_Main" 50}()
    o @{"CLGET_SystemName" link "Systemdaten_Main" 55}(<index>)
    o @{"CLIS_SystemExists" link "Systemdaten_Main" 69}(<systemname>)




    o @{b}@{i}@{u}CL_SystemSavelist()@{ub}@{ui}@{uu}

       Wurde die Systemliste verändert, wird sie bei Aufruf dieser Funktion
       gespeichert.


    o @{b}@{i}@{u}CL_SystemNew(<systemname>)@{ub}@{ui}@{uu}

       Erzeugt ein neues System mit dem Namen @{i}<systemname>@{ui}. Danach sollten
       mit den CLSET_SystemX()-Befehlen (siehe Abschnitt @{"4.3" link "Systemdaten_Main" 198}) alle Daten
       ergänzt werden.


    o @{b}@{i}@{u}CL_SystemDelete(<systemname>)@{ub}@{ui}@{uu}

        Das System @{i}<systemname>@{ui} wird aus der Systemliste gelöscht.


    o @{b}@{i}@{u}CLGET_SystemNumberOf()@{ub}@{ui}@{uu}

        Diese Funktion gibt die Anzahl aller eingetragenen Systeme zurück.


    o @{b}@{i}@{u}CLGET_SystemName(<index>)@{ub}@{ui}@{uu}

        Nach Aufruf gibt die Funktion den Namen des Systems mit der Nummer
        @{i}<index>@{ui} zurück.

        @{u}Beispiel:@{uu}

         anzahl=@{"CLGET_SystemNumberOf" link "Systemdaten_Main" 50}()   /* Anzahl der Systeme ermitteln */

         do x=1 to anzahl
            system.x=CLGET_SystemName(x)
            end


    o  @{b}@{i}@{u}CLIS_SystemExists(<systemname>)@{ub}@{ui}@{uu}

        Liefert '1', wenn das System @{i}<systemname>@{ui} in der Systemliste einge-
        tragen ist, ansonsten '0'.




 4.2 Befehle zum Auslesen der Systemdaten
 ----------------------------------------

    o @{"CLGET_SystemDomain" link "Systemdaten_Main" 97}(<systemname>)
    o @{"CLGET_SystemRoute" link "Systemdaten_Main" 102}(<systemname>)
    o @{"CLGET_SystemNet" link "Systemdaten_Main" 119}(<systemname>)
    o @{"CLGET_SystemProtocol" link "Systemdaten_Main" 125}(<systemname>)
    o @{"CLGET_SystemPackerIn" link "Systemdaten_Main" 131}(<systemname>)
    o @{"CLGET_SystemPackerOut" link "Systemdaten_Main" 137}(<systemname>)
    o @{"CLGET_SystemGroup" link "Systemdaten_Main" 143}(<systemname>,<gruppennr>)
    o @{"CLGET_SystemPointuser" link "Systemdaten_Main" 149}(<systemname>)
    o @{"CLGET_SystemTelephone" link "Systemdaten_Main" 155}(<systemname>)
    o @{"CLGET_SystemPriority" link "Systemdaten_Main" 173}(<systemname>)
    o @{"CLGET_SystemLastCall" link "Systemdaten_Main" 178}(<systemname>)
    o @{"CLIS_SystemAutoEntry" link "Systemdaten_Main" 184}(<systemname>)
    o @{"CLIS_SystemMapsAccess" link "Systemdaten_Main" 190}(<systemname>)




    o @{b}@{i}@{u}CLGET_SystemDomain(<systemname>)@{ub}@{ui}@{uu}

        Diese Funktion gibt die Domain eines eingetragenen Systems zurück.


    o @{b}@{i}@{u}CLGET_SystemRoute(<systemname>)@{ub}@{ui}@{uu}

        Diese Funktion liefert das Routesystem von @{i}<systemname>@{ui}. Bei nicht
        existentem System @{i}<systemname>@{ui} oder bei aktiviertem PathAlias-/Do-
        mainrouting wird ein Leerstring zurückgeliefert.

         @{u}Beispiel:@{uu}

          route=CLGET_SystemRoute(systemname)
          if route='' then do
              if ~@{"CLIS_SystemExists" link "Systemdaten_Main" 69}(systemname) then
                  say 'Dieses System ist nicht eingetragen!'
              else
                  say 'Mail wird per PathAlias/Domainrouting geroutet!'
              end


    o @{b}@{i}@{u}CLGET_SystemNet(<systemname>)@{ub}@{ui}@{uu}

       Liefert den Netznamen vom System @{i}<systemname>@{ui} im Klartext (JANUS,
       ZERBERUS, UUCP oder FIDO).


    o @{b}@{i}@{u}CLGET_SystemProtocol(<systemname>)@{ub}@{ui}@{uu}

       Liefert den Namen des für @{i}<systemname>@{ui} eingestellten Transferproto-
       kolls im Klartext.


    o @{b}@{i}@{u}CLGET_SystemPackerIn(<systemname>)@{ub}@{ui}@{uu}

       Liefert den Packer der von @{i}<systemname>@{ui} eingehenden Puffer im Klar-
       text.


    o @{b}@{i}@{u}CLGET_SystemPackerOut(<systemname>)@{ub}@{ui}@{uu}

       Liefert den Packer der an @{i}<systemname>@{ui} ausgehenden Puffer im Klar-
       text.


    o @{b}@{i}@{u}CLGET_SystemGroup(<systemname>,<gruppennr>)@{ub}@{ui}@{uu}

       Liefert '1', wenn das System @{i}<systemname>@{ui} in die Gruppe mit der Num-
       mer @{i}<gruppennr>@{ui} eingetragen ist, ansonsten '0'.


    o @{b}@{i}@{u}CLGET_SystemPointuser(<systemname>)@{ub}@{ui}@{uu}

       Falls es sich bei dem System um einen Point handelt, wird der Name
       des Pointusers zurückgegeben, ansonsten ein Leerstring.


    o @{b}@{i}@{u}CLGET_SystemTelephone(<systemname>)@{ub}@{ui}@{uu}

       Diese Funktion gibt die Telefonnummer des Systems @{i}<systemname>@{ui} zu-
       rück.

        Beispiel:

         /* Einlesen der einzelnen Telefonnummern eines Systems in eine
            STEM-Variable                                                */

         string=translate(CLGET_SystemTelephone(system),' ','|')
         if string~='' then do
             do x=1 to words(string)
                 telefon.x=word(string,x)
                 end
             end


    o @{b}@{i}@{u}CLGET_SystemPriority(<systemname>)@{ub}@{ui}@{uu}

       Diese Funktion gibt die Priorität des Systems @{i}<systemname>@{ui} zurück.


    o @{b}@{i}@{u}CLGET_SystemLastCall(<systemname>)@{ub}@{ui}@{uu}

       Liefert das Datum des letzten Anrufs vom System @{i}<systemname>@{ui} im For-
       mat 'DD.MM.YYYY HH:MM:SS'.


    o @{b}@{i}@{u}CLIS_SystemAutoEntry(<systemname>)@{ub}@{ui}@{uu}

        Liefert den Rückgabewert '1', wenn das System die Berechtigung zum
        Autoeintrag neuer Brett hat, ansonsten '0'.


    o @{b}@{i}@{u}CLIS_SystemMapsAccess(<systemname>)@{ub}@{ui}@{uu}

        Liefert den Rückgabewert '1', wenn das System Zugriff auf Maps
        hat, ansonsten '0'.




 4.3 Befehle zum Setzen der Systemdaten
 --------------------------------------

    Bei Erfolg wird generell '1' zurückgegeben, bei Mißerfolg '0'.

    o @{"CLSET_SystemPassword" link "Systemdaten_Main" 220}(<systemname>,<passwort>)
    o @{"CLSET_SystemDomain" link "Systemdaten_Main" 225}(<systemname>,<domain>)
    o @{"CLSET_SystemRoute" link "Systemdaten_Main" 230}(<systemname>,<routesystem>)
    o @{"CLSET_SystemNet" link "Systemdaten_Main" 236}(<systemname>,<netzname>)
    o @{"CLSET_SystemProtocol" link "Systemdaten_Main" 241}(<systemname>,<protokoll>)
    o @{"CLSET_SystemPackerIn" link "Systemdaten_Main" 246}(<systemname>,<packer>)
    o @{"CLSET_SystemPackerOut" link "Systemdaten_Main" 251}(<systemname>,<packer>)
    o @{"CLSET_SystemGroup" link "Systemdaten_Main" 256}(<systemname>,<gruppennr> [,<flag>])
    o @{"CLSET_SystemPointuser" link "Systemdaten_Main" 270}(<systemname>,<username>)
    o @{"CLSET_SystemTelephone" link "Systemdaten_Main" 282}(<systemname>,<telefon>)
    o @{"CLSET_SystemPriority" link "Systemdaten_Main" 303}(<systemname>,<priorität>)
    o @{"CLSET_SystemAutoEntry" link "Systemdaten_Main" 313}(<systemname>,<flag>)
    o @{"CLSET_SystemMapsAccess" link "Systemdaten_Main" 324}(<systemname>,<flag>)




    o @{b}@{i}@{u}CLSET_SystemPassword(<systemname>,<passwort>)@{ub}@{ui}@{uu}

       Trägt für das System das Passwort @{i}<passwort>@{ui} ein.


    o @{b}@{i}@{u}CLSET_SystemDomain(<systemname>,<domain>)@{ub}@{ui}@{uu}

       Trägt für das System die Domain @{i}<domain>@{ui} ein.


    o @{b}@{i}@{u}CLSET_SystemRoute(<systemname>,<routesystem>)@{ub}@{ui}@{uu}

       Trägt für das System das Routesystem @{i}<routesystem>@{ui} ein und schaltet
       ein evt. eingeschaltetes PathAlias/Domainrouting ab.


    o @{b}@{i}@{u}CLSET_SystemNet(<systemname>,<netzname>)@{ub}@{ui}@{uu}

       Setzt den Netznamen des Systems (Default "JANUS").


    o @{b}@{i}@{u}CLSET_SystemProtocol(<systemname>,<protokoll>)@{ub}@{ui}@{uu}

       Setzt das Transferprotokoll des Systems (Default "ZMODEM").


    o @{b}@{i}@{u}CLSET_SystemPackerIn(<systemname>,<packer>)@{ub}@{ui}@{uu}

       Setzt den Packer für eingehende Puffer vom System (Default "LHA").


    o @{b}@{i}@{u}CLSET_SystemPackerOut(<systemname>,<packer>)@{ub}@{ui}@{uu}

       Setzt den Packer für ausgehende Puffer an das System (Default "LHA").


    o @{b}@{i}@{u}CLSET_SystemGroup(<systemname>,<gruppennr> [,<flag>])@{ub}@{ui}@{uu}

       Trägt das System in eine Gruppe ein.

        @{u}Parameter:@{uu}

         systemname  - Name des Systems
         gruppennr   - Nummer der Gruppe
         flag        - Optionaler Parameter; ist es "0", wird das System
                       aus der Gruppe ausgetragen, ist es "1" oder wird
                       weggelassen, wird das System in die Gruppe einge-
                       tragen.


    o @{b}@{i}@{u}CLSET_SystemPointuser(<systemname>,<username>)@{ub}@{ui}@{uu}

       Setzt einen Pointuser für das System.

        @{u}Parameter:@{uu}

         systemname  - Name des Systems
         username    - Pointuser. Wird hier ein Leerstring übergeben,
                       wird die Verknüpfung gelöscht und das System
                       nicht weiter als Point betrachtet.


    o @{b}@{i}@{u}CLSET_SystemTelephone(<systemname>,<telefon>)@{ub}@{ui}@{uu}

       Setzt die Telefonnummer des Systems.

        @{u}Parameter:@{uu}

         systemname  - Name des Systems
         telefon     - String mit einer oder mehreren Telefonnummern,
                       bei mehreren durch '|' getrennt

        @{u}Beispiel:@{uu}

         if zaehler>1 then do
             do x=1 to zaehler-1     /* Mehrere Nummern aneinanderhängen */
                 telefon=nummer.x'|'
                 end
             end
         telefon=telefon||nummer.zaehler /* Nur ein Port bzw. der letzte */
         call CLSET_SystemTelephone(system,telefon)


    o @{b}@{i}@{u}CLSET_SystemPriority(<systemname>,<priorität>)@{ub}@{ui}@{uu}

       Setzt die Priorität des Systems.

        @{u}Parameter:@{uu}

         systemname  - Name des Systems
         priorität   - Priorität des Systems (0<=x<=99)


    o @{b}@{i}@{u}CLSET_SystemAutoEntry(<systemname>,<flag>)@{ub}@{ui}@{uu}

       Setzt die Berechtigung zum Autoeintrag von Brettern.

        @{u}Parameter:@{uu}

         systemname  - Name des Systems
         flag        - '1' erlaubt Autoeintrag
                       '0' verweigert Autoeintrag


    o @{b}@{i}@{u}CLSET_SystemMapsAccess(<systemname>,<flag>)@{ub}@{ui}@{uu}

       Setzt die Berechtigung zum Zugriff auf Maps.

        @{u}Parameter:@{uu}

         systemname  - Name des Systems
         flag        - '1' erlaubt Mapszugriff
                       '0' verweigert Mapszugriff
@endnode

@node "Online-Funktionen_Main" "Funktionen für Onlinebefehle"
@next "Nachrichten_Main"
@prev "Systemdaten_Main"
 5. Funktionen für Onlinebefehle
 -------------------------------

    Allgemeine Anmerkungen:
    -----------------------

    Alle CLONL_X()-Befehle liefern bei Erfolg '1' und bei Mißerfolg '0' zu-
    rück. Es sollte zumindest bei ersten Aufruf überprüft werden, ob eine
    '1' zurückgegeben wurde, damit man weiß, ob das ANSI-System korrekt ini-
    tialisiert wurde.

     @{u}Beispiel:@{uu}

      if ~@{"CLONL_ClearScreen" link "Online-Funktionen_Main" 267}() then do
          say "Can't init ANSI-System!"
          exit 10
          end


    o @{"CL_Edit" link "Online-Funktionen_Main" 45}(<filename> [,<flag>])
    o @{"CLONL_GotoXY" link "Online-Funktionen_Main" 61}(<x>,<y>)
    o @{"CLONL_Normal" link "Online-Funktionen_Main" 75}()
    o @{"CLONL_DeleteEOL" link "Online-Funktionen_Main" 82}()
    o @{"CLONL_DeleteLine" link "Online-Funktionen_Main" 88}()
    o @{"CLONL_InsertLine" link "Online-Funktionen_Main" 94}()
    o @{"CLONL_BlueMode" link "Online-Funktionen_Main" 101}()
    o @{"CLONL_Color" link "Online-Funktionen_Main" 107}(<color>,<bcolor>,<style>)
    o @{"CLONL_BlueRead" link "Online-Funktionen_Main" 121}(<länge> [,<vorgabe>]
    o @{"CLONL_Wait" link "Online-Funktionen_Main" 134}()
    o @{"CLONL_DoCommand" link "Online-Funktionen_Main" 143}(<befehl> [,<parameter>])
    o @{"CLONL_SendMail" link "Online-Funktionen_Main" 155}(<absender>,<empfänger>,<betreff>,<filename>)
    o @{"CLGET_Key()" link "Online-Funktionen_Main" 167}
    o @{"CLONL_Transfer" link "Online-Funktionen_Main" 199}(<filename> [,<sendfilename>]
    o @{"CLONL_Receive" link "Online-Funktionen_Main" 219}(<port>)
    o @{"CLIS_KeyPressed" link "Online-Funktionen_Main" 240}()
    o @{"CLONL_ShortMenu" link "Online-Funktionen_Main" 245}(<eintrag> {,<einträge>})
    o @{"CLONL_ShortMenuVertical" link "Online-Funktionen_Main" 253}(<eintrag> {,<einträge>})
    o @{"CLONL_SetObscure" link "Online-Funktionen_Main" 261}(<flag>)
    o @{"CLONL_ClearScreen" link "Online-Funktionen_Main" 267}()
    o @{"CLONL_PrintFile" link "Online-Funktionen_Main" 272}(<filename>)
    o @{"CLONL_SetEnv" link "Online-Funktionen_Main" 277}(<port>)



    o @{b}@{i}@{u}CL_Edit(<filename> [,<flag>])@{ub}@{ui}@{uu}

       Ruft den Editor auf.

        @{u}Parameter:@{uu}

         filename    - Pfad und Name der Datei @{i}<filename>@{ui}
         online      - Optionaler Parameter; ist er angegeben, wird
                       der Online-Editor anstelle des Offline-Editors
                       benutzt.

        @{u}Beispiel:@{uu}

         call CL_Edit('T:test',) /* Online-Editor benutzen */


    o @{b}@{i}@{u}CLONL_GotoXY(<x>,<y>)@{ub}@{ui}@{uu}

        Setzt den Cursor auf die Position x,y.

        @{u}Parameter:@{uu}

         x - Nummer der Spalte
         y - Nummer der Zeile

        @{u}Beispiel:@{uu}

         call CLONL_GotoXY(1,1)  /* Cursor in die linke obere Ecke */


    o @{b}@{i}@{u}CLONL_Normal()@{ub}@{ui}@{uu}

       Schaltet die Textausgabe auf ANSI-Style "Normal" zurück. Das Resultat
       ist von Terminal zu Terminal verschieden; üblicherweise ist es Schrift-
       farbe weiß, Hintergrundfarbe Schwarz, kein Style.


    o @{b}@{i}@{u}CLONL_DeleteEOL()@{ub}@{ui}@{uu}

       Per ANSI-Steuersequenz wird von der aktuellen Cursorposition bis zum
       Ende der Zeile alles gelöscht.


    o @{b}@{i}@{u}CLONL_DeleteLine()@{ub}@{ui}@{uu}

       Per ANSI-Steuersequenz wird die aktuelle Zeile vollständig gelöscht,
       nachfolgende Zeilen rücken auf.


    o @{b}@{i}@{u}CLONL_InsertLine()@{ub}@{ui}@{uu}

       Per ANSI-Steuersequenz wird an der aktuellen Position des Cursors eine
       Zeile eingefügt und die nachfolgende Zeilen um eine Zeile nach unten
       verschoben.


    o @{b}@{i}@{u}CLONL_BlueMode()@{ub}@{ui}@{uu}

       Es wird auf den 'Blue'-Mode umgestellt. Hierbei handelt es sich um einen
       besonders markanten Eingabe- und Titelmodus.


    o @{b}@{i}@{u}CLONL_Color(<color>,<bcolor>,<style>)@{ub}@{ui}@{uu}

       Die Cursorfarbe wird zur weiteren Ausgabe umgestellt, ein Schriftstil
       wird benutzt.

        @{u}Parameter:@{uu}

          color - Schriftfarbe (BLACK, RED, GREEN, YELLOW, BLUE, PINK, CYAN
                                oder WHITE)
          bcolor- Hintergrundfarbe (BLACK, RED, GREEN, YELLOW, BLUE, PINK,
                                    CYAN oder WHITE)
          style - Schriftstil (NORMAL, BOLD, KURSIV, UNDERLINE oder INVERSE)


    o @{b}@{i}@{u}CLONL_BlueRead(<länge> [,<vorgabe>]@{ub}@{ui}@{uu}

       Über eine blaue Eingabezeile wird ein String-Gadget simuliert. Exis-
       tiert eine Vorgabe, so steht diese bereits im Feld. Nach einer Bestä-
       tigung der Eingabe der 'Return'-Taste wird der Inhalt des Feldes zu-
       rückgegeben.

        Parameter:

         länge   - Länge der Eingabezeile in Zeichen
         vorgabe - Text, der als Default in der Eingabezeile stehen soll


    o @{b}@{i}@{u}CLONL_Wait()@{ub}@{ui}@{uu}

       Es wird eine Meldung "<Bitte Taste drücken>" ausgegeben und auf einen
       Tastendruck gewartet. Wird eine '1' zurückgegeben, wurde eine Taste
       gedrückt. Bei einem Rückgabewert '0' sollte sich das Programm auf jeden
       Fall vollständig beenden, da der User dann CTRL-C/Q/X gedrückt hat oder
       der Carrier verloren wurde.


    o @{b}@{i}@{u}CLONL_DoCommand(<befehl> [,<parameter>])@{ub}@{ui}@{uu}

       Ruft einen in den Shellprefs eingetragenen Onlinebefehl auf, so, als
       würde der User den Befehl selbst aufrufen.

        @{u}Parameter:@{uu}

         befehl      - Onlinebefehl
         parameter   - Optionaler Parameter; beinhaltet einen String, der an
                       den Befehl als Parameter übergeben wird.


    o @{b}@{i}@{u}CLONL_SendMail(<absender>,<empfänger>,<betreff>,<filename>)@{ub}@{ui}@{uu}

        Verschickt eine Textnachricht. Siehe auch CL_SendMailFull().

         @{u}Parameter:@{uu}

          absender   - Absender der Nachricht
          empfänger  - Empfänger der Nachricht
          betreff    - Betreff der Nachricht
          filename   - Pfad und Name des zu verschickenden Files.


    o @{b}@{i}@{u}CLGET_Key()@{ub}@{ui}@{uu}

       Wartet auf einen Tastendruck und gibt sie zurück. Ein String '-1'
       bedeutet, daß ein Abbruch stattgefunden hat oder der Carrier verloren
       wurde; in beiden Fällen sollte sich das ARexx-Skript umgehend selbst
       beenden.

       Bei gedrückten Cursortasten werden folgende Werte zurückgegeben:

        Cursor nach oben  : "-UP"
        Cursor nach unten : "-DOWN"
        Cursor nach links : "-LEFT"
        Cursor nach rechts: "-RIGHT"

        @{u}Beispiel:@{uu}

          menu:
             say '[1] Nachricht editieren'
             say '[2] Nachricht verschicken'
             say '[E] Programm verlassen'
             say ''
          loop:
             taste=CLGET_Key()
             select
                 when taste='1' then call edit
                 when taste='2' then call send
                 when (taste='E')|(taste='-1') then exit
                 otherwise call loop
                 end
             call menu


    o @{b}@{i}@{u}CLONL_Transfer(<filename> [,<sendfilename>]@{ub}@{ui}@{uu}

       Verschickt ein File an den User. Bei dieser Funktion kann es Probleme
       geben, wenn sie in ihrem System XPR-Treiber-Protokolle anstelle der
       Connectline Built-in-Übertragungsprotokolle verwenden.

        @{u}Parameter:@{uu}

         filename    - Name des zu übertragenden Files
         sendfilename- Optionaler Parameter; ist er angegeben, wird das File
                       mit diesem Namen verschickt.

        @{u}Beispiel:@{uu}

        if ~CLONL_Transfer('JANUS:'||point||'/'||point||'.PRE') then
            say 'Transfer fehlgeschlagen!'
        else
            say 'Transfer erfolgreich!'


    o @{b}@{i}@{u}CLONL_Receive(<port>)@{ub}@{ui}@{uu}

       Empfängt ein File auf Port @{i}<port>@{ui} und gibt den kompletten Pfad zurück,
       bzw. einen Leerstring bei fehlgeschlagener Übertragung. Werden mehrere
       Files empfangen, so werden die Filenamen durch Leerzeichen getrennt in
       einem String zurückgegeben. Die empfangenen Files sollten auf jeden
       Fall entsorgt werden, da sie sonst vom Onlinebefehl SENDEN als
       Bimodem-Übertragungsfiles behandelt werden.

        @{u}Beispiel:@{uu}

         string=CLONL_Receive(port)
         if string~='' then do
             do x=1 to words(string)
                 rename(word(string,x),'T:'||word(string,words(translate(string,
' ','/'))))
                 end
             end
         else say 'Übertragung fehlgeschlagen!'


    o @{b}@{i}@{u}CLIS_KeyPressed()@{ub}@{ui}@{uu}

       Liefert '1', wenn eine Taste gedrückt wurde, ansonsten '0'.


    o @{b}@{i}@{u}CLONL_ShortMenu(<eintrag> {,<einträge>})@{ub}@{ui}@{uu}

       Es wird ein kleines einzeiliges Menü aus den Einträgen aufgebaut.
       Die maximale Anzahl der Parameter liegt bei 20. Der erste Buch-
       stabe eines jeden Eintrages wird als Hotkey verwendet. Der Hot-
       key des ausgewählten Eintrages wird zurückgegeben.


    o @{b}@{i}@{u}CLONL_ShortMenuVertical(<eintrag> {,<einträge>})@{ub}@{ui}@{uu}

       Es wird ein kleines vertikales Menü aus den Einträgen aufgebaut.
       Die maximale Anzahl der Parameter liegt bei 20. Der erste Buch-
       stabe eines jeden Eintrages wird als Hotkey verwendet. Der Hot-
       key des ausgewählten Eintrages wird zurückgegeben.


    o @{b}@{i}@{u}CLONL_SetObscure(<flag>)@{ub}@{ui}@{uu}

       Setzt den Obscure-Modus. Ist das Flag gesetzt, ist ein Mitlesen
       auf der Console nicht mehr möglich.


    o @{b}@{i}@{u}CLONL_ClearScreen()@{ub}@{ui}@{uu}

       Per ANSI-Steuersequenz wird der Bildschirm gelöscht.


    o @{b}@{i}@{u}CLONL_PrintFile(<filename>)@{ub}@{ui}@{uu}

       Gibt das File <filename> als Text aus.


    o @{b}@{i}@{u}CLONL_SetEnv(<port>)@{ub}@{ui}@{uu}

       Setzt die lokalen ENV-Variablen des Ports <port> als lokale
       ENV-Variablen des aktuellen ARexx-Prozesses. Dies erlaubt das
       Aufrufen von Online-Befehlen aus einem ARexx-Skript heraus.

        Beispiel:

         /* Ruft 'TopUser' aus einem ARexx-Skript auf */

         port=arg(1)
         call CLONL_SetEnv(port)
         address command 'CONNECTLINE:Commands/TopUser'
         exit
@endnode

@node "Nachrichten_Main" "Befehle für Zugriff auf Nachrichten"
@next "Ports_Main"
@prev "Online-Funktionen_Main"
 6. Befehle für Zugriffe auf Nachrichten
 ---------------------------------------

    6.1 @{"Befehle zum Lesen von Nachrichtendaten" link "Nachrichten_Main" 10}
    6.2 @{"Befehle zum Setzen von Nachrichtendaten" link "Nachrichten_Main" 112}




 6.1 Befehle zum Lesen von Nachrichtendaten
 ------------------------------------------

    o @{"CLGET_MsgNumberOf" link "Nachrichten_Main" 31}(<brettname>)
    o @{"CLGET_MsgSubject" link "Nachrichten_Main" 38}(<brettname>,<nr>)
    o @{"CLGET_MsgFilename" link "Nachrichten_Main" 43}(<brettname>,<nr>)
    o @{"CLGET_MsgShortComment" link "Nachrichten_Main" 48}(<brettname>,<nr>)
    o @{"CLGET_MsgFrom" link "Nachrichten_Main" 53}(<brettname>,<nr>)
    o @{"CLGET_MsgMsgID" link "Nachrichten_Main" 58}(<brettname>,<nr>)
    o @{"CLGET_MsgReadcount" link "Nachrichten_Main" 63}(<brettname>,<nr>)
    o @{"CLGET_MsgIncomeDate" link "Nachrichten_Main" 68}(<brettname>,<nr>)
    o @{"CLGET_MsgSendDate" link "Nachrichten_Main" 74}(<brettname>,<nr>)
    o @{"CLIS_MsgBinary" link "Nachrichten_Main" 79}(<brettname>,<nr>)
    o @{"CLGET_MsgBody" link "Nachrichten_Main" 85}(<brettname>,<nr>,<filename>)
    o @{"CLGET_MsgBodyLength" link "Nachrichten_Main" 91}(<brettname>,<nr>)
    o @{"CLGET_MsgComment" link "Nachrichten_Main" 97}(<brettname>,<nr>,<filename>)
    o @{"CLGET_MsgCommentLength" link "Nachrichten_Main" 104}(<brettname>,<nr>)




    o @{b}@{i}@{u}CLGET_MsgNumberOf(<brettname>)@{ub}@{ui}@{uu}

       Liefert die Anzahl der Nachrichten im Brett @{i}<brettname>@{ui} zurück.
       Existiert das Brett nicht oder konnte der Index nicht gelockt wer-
       den, wird eine '-1' zurückgegeben.


    o @{b}@{i}@{u}CLGET_MsgSubject(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Liefert den Betreff von Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brettname>@{ui}.


    o @{b}@{i}@{u}CLGET_MsgFilename(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Liefert den Filenamen von Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brettname>@{ui}.


    o @{b}@{i}@{u}CLGET_MsgShortComment(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Liefert den Kurzkommentar von Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brettname>@{ui}.


    o @{b}@{i}@{u}CLGET_MsgFrom(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Liefert den Absender von Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brettname>@{ui}.


    o @{b}@{i}@{u}CLGET_MsgMsgID(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Liefert die MsgID von Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brettname>@{ui}.


    o @{b}@{i}@{u}CLGET_MsgReadcount(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Liefert den Zugriffszähler von Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brettname>@{ui}.


    o @{b}@{i}@{u}CLGET_MsgIncomeDate(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Liefert das Einsortierdatum von Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brett-@{ui}
       @{i}name>@{ui}.


    o @{b}@{i}@{u}CLGET_MsgSendDate(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Liefert das Absendedatum von Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brettname>@{ui}.


    o @{b}@{i}@{u}CLIS_MsgBinary(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Liefert '1', wenn die Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brettname>@{ui} ein File
       ist, ansonsten '0'.


    o @{b}@{i}@{u}CLGET_MsgBody(<brettname>,<nr>,<filename>)@{ub}@{ui}@{uu}

       Diese Funktion lagert den Body der Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brett-@{ui}
       @{i}name>@{ui} mit dem Filenamen @{i}<filename>@{ui} aus.


    o @{b}@{i}@{u}CLGET_MsgBodyLength(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Diese Funktion gibt die Länge des Mailbodies der Nachricht Nr. @{i}<nr>@{ui}
       im Brett @{i}<brettname>@{ui} zurück.


    o @{b}@{i}@{u}CLGET_MsgComment(<brettname>,<nr>,<filename>)@{ub}@{ui}@{uu}

       Diese Funktion dient dem Auslagern des langen Kommentars (KOM:) der
       Nachricht Nr. @{i}<nr>@{ui} des Brettes @{i}<brettname>@{ui} unter dem Filename @{i}<file-@{ui}
       @{i}name>@{ui}.


    o @{b}@{i}@{u}CLGET_MsgCommentLength(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Diese Funktion gibt die Länge des langen Kommentars (KOM:) der Nach-
       richt Nr. @{i}<nr>@{ui} des Brettes @{i}<brettname>@{ui} zurück.




 6.2 Befehle zum Setzen von Nachrichtendaten
 -------------------------------------------

    o @{"CLSET_MsgSubject" link "Nachrichten_Main" 115}(<brettname>,<nr>,<betreff>)
    o @{"CLSET_MsgShortComment" link "Nachrichten_Main" 128}(<brettname>,<nr>,<kommentar>)
    o @{"CLSET_MsgDelete" link "Nachrichten_Main" 134}(<brettname>,<nr>)




    o @{b}@{i}@{u}CLSET_MsgSubject(<brettname>,<nr>,<betreff>)@{ub}@{ui}@{uu}

       Setzt den Betreff von Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brettname>@{ui} auf
       @{i}<betreff>@{ui}.


    o @{b}@{i}@{u}CLSET_MsgShortComment(<brettname>,<nr>,<kommentar>)@{ub}@{ui}@{uu}

       Setzt den Kurzkommentar von Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brettname>@{ui}
       auf @{i}<kommentar>@{ui}.


    o @{b}@{i}@{u}CLSET_MsgDelete(<brettname>,<nr>)@{ub}@{ui}@{uu}

       Setzt das Löschflag von Nachricht Nr. @{i}<nr>@{ui} im Brett @{i}<brettname>@{ui}. Die
       Nachricht wird beim nächsten Crunchen des Brettes vollständig ent-
       fernt.
@endnode

@node "Ports_Main" "Befehle für Zugriffe auf die Ports"
@next "Pfade_Main"
@prev "Nachrichten_Main"
 7. Befehle für Zugriffe auf die Ports
    -------------------------------------

    Allgemeine Anmerkungen:
    -----------------------

    Diese Funktionen benötigen als Übergabeparameter die Nummer des Ports,
    von welchem aus das Skript gestartet wurde. Diese erhalten sie entweder
    beim Aufruf als Parameter oder über den ARexx-Port des CL-PORTx.

    Ist niemand eingeloggt, geben die Funktionen - solange nicht anders ver-
    merkt - einen Leerstring zurück.


    o @{"CLGET_PortUsername" link "Ports_Main" 23}(<port>)
    o @{"CLGET_PortCurrentboard" link "Ports_Main" 28}(<port>)
    o @{"CLGET_PortTerminal" link "Ports_Main" 33}(<port>)
    o @{"CLGET_PortLines" link "Ports_Main" 39}(<port>)




    o @{b}@{i}@{u}CLGET_PortUsername(<port>)@{ub}@{ui}@{uu}

       Liefert den Usernamen des eingeloggten Users.


    o @{b}@{i}@{u}CLGET_PortCurrentboard(<port>)@{ub}@{ui}@{uu}

       Liefert den Namen des Brettes, in welchem sich der User gerade aufhält.


    o @{b}@{i}@{u}CLGET_PortTerminal(<port>)@{ub}@{ui}@{uu}

       Liefert die aktuelle Terminaleinstellung des Users im Klartext ("ANSI",
       "VT100" oder "TTY").


    o @{b}@{i}@{u}CLGET_PortLines(<port>)@{ub}@{ui}@{uu}

       Liefert die aktuelle maximale Zeilenzahl des Users. Ist niemand ein-
       geloggt, wird eine '-1' zurückgegeben.
@endnode

@node "Pfade_Main" "Befehle zum Auslesen von Defaultpfaden"
@next "Server"
@prev "Ports_Main"
 8. Befehle zum Auslesen von Defaultpfaden
 ------------------------------------------

    o @{"CLGET_PathJANUS()" link "Pfade_Main" 12}
    o @{"CLGET_PathZERBERUS" link "Pfade_Main" 28}()
    o @{"CLGET_PathSpool" link "Pfade_Main" 45}()
    o @{"CLGET_PathTrash" link "Pfade_Main" 50}()
    o @{"CLGET_PathBoard" link "Pfade_Main" 44}()
    o @{"CLGET_PathUser" link "Pfade_Main" 50}()



    o @{b}@{i}@{u}CLGET_PathJANUS()@{ub}@{ui}@{uu}

        Liefert den in den JANUS-Prefs eingestellten Pfad des JANUS-Verzeich-
        nisses zurück. Beim Aufruf dieser Funktion muß Connectline laufen.

        @{u}Beispiel:@{uu}

        /* Abfragen, ob Connectline zur Zeit läuft */

        if ~show('P','CL-SERVER') then do
            say 'Bitte erst Connectline 5.0 starten!'
            exit
            end
        JANUS=CLGET_PathJANUS()


    o @{b}@{i}@{u}CLGET_PathZERBERUS()@{ub}@{ui}@{uu}

        Liefert den in den Z38-Prefs eingestellten Pfad des ZERBERUS-Ver-
        zeichnisses zurück. Beim Aufruf dieser Funktion muß Connectline laufen.

        @{u}Beispiel:@{uu}

        /* Abfragen, ob Connectline zur Zeit läuft */

        if ~show('P','CL-SERVER') then do
            say 'Bitte erst Connectline 5.0 starten!'
            exit
            end
        ZERBERUS=CLGET_PathZERBERUS()


    o @{b}@{i}@{u}CLGET_PathSpool()@{ub}@{ui}@{uu}

       Liefert den Pfad des JANUS-Spoolverzeichnisses zurück.


    o @{b}@{i}@{u}CLGET_PathTrash()@{ub}@{ui}@{uu}

       Liefert den Pfad des JANUS-Trashverzeichnisses zurück.


    o @{b}@{i}@{u}CLGET_PathBoard()@{ub}@{ui}@{uu}

        Liefert den in der Hauptkonfiguration eingestellten Defaultpfad der
        Bretter zurück.


    o @{b}@{i}@{u}CLGET_PathUser()@{ub}@{ui}@{uu}

        Liefert den in der Hauptkonfiguration eingestellten Defaultpfad der
        Userverzeichnisse zurück.
@endnode

