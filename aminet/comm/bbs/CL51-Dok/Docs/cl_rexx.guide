    o @{"CLSET_UserMessage" link "Userdaten_Main" 364}(<username>,<message>)
    o @{"CLSET_UserCopyTo" link "Userdaten_Main" 374}(<username>,<vertreter>)
    o @{"CLSET_UserTerminal" link "Userdaten_Main" 384}(<username>,<terminal>)
