@{" LINE 09: " link "filecheck.config" 55} FILE_ID-STRIPCHARS        ( ASCII/EXAMPLE: 13 26 )
@{" LINE 10: " link "filecheck.config" 59} FILE_ID-CONVERTCHARS      ( IBM-MODE / EXAMPLE: 50=51 )
@{" LINE 11: " link "filecheck.config" 63} FILE_ID-CONVERTCHARS      ( AMIGA-MODE )
@{" LINE 12: " link "filecheck.config" 66} LINEADD         ADDY      ( ENV-VARS ALLOWED E.G. ${FILE} )
@{" LINE 13: " link "filecheck.config" 71} SETRETURN: FILE_ID
@{" LINE 14: " link "filecheck.config" 75} SETRETURN: NO FILE_ID
