@node "E-Security ??" "E-Security ??"

                            @{fg shine}S e c u r i t y   ? ?@{fg text}


@{b}Security BM@{ub} : @{fg fill}0-100@{fg text}
   Security Level für Bulletins Menu

@{b}Security FS@{ub} : @{fg fill}0-100@{fg text}
   Security Level für File System

@{b}Security MB@{ub} : @{fg fill}0-100@{fg text}
   Security Level für Message Board

@{b}Security PM@{ub} : @{fg fill}0-100@{fg text}
   Security Level für Private Mail

@{b}Security SM@{ub} : @{fg fill}0-100@{fg text}
   Security Level für Setup Menu

@{b}Security UM@{ub} : @{fg fill}0-100@{fg text}
   Security Level für User Menu

Siehe auch @{"§Cycle Gadget 1" link "E-§Cycle Gadget 1" 0}
@endnode

@node "E-Total ??" "E-Total ??"

                               @{fg shine}T o t a l   ? ?@{fg text}


@{b}Total RM`s@{ub} : @{fg fill}0-65535@{fg text}
   Anzeige der Anzahl der gelesenen Dokumente

@{b}Total WM`s@{ub} : @{fg fill}0-65535@{fg text}
   Anzeige der Anzahl der geschriebenen Dokumente

@{b}Total RP`s@{ub} : @{fg fill}0-65535@{fg text}
   Anzeige der Anzahl der gelesenen persönlichen Nachrichten

@{b}Total WP`s@{ub} : @{fg fill}0-65535@{fg text}
   Anzeige der Anzahl der geschriebenen persönlichen Nachrichten
@endnode

