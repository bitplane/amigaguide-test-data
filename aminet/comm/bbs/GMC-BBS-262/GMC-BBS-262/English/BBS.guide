 @{"BBS Number   " link "E-BBS Number" 0} ++431 985 38 96.....                       @{"   Next User   " link "E-Next User" 0}

 @{"FAX Number   " link "E-FAX Number" 0} ++431 985 38 96.....                       @{"   Prev User   " link "E-Prev User" 0}

 @{"Date of Birth" link "E-Date of Birth" 0} DD-MM-YY  @{"Password" link "E-Password" 0} ....................

