@NODE Aguide35 "DreamDoor.library/SetSerial"

    NAME
        SetSerial - Disable/Enable Serial output

    SYNOPSIS
        SetSerial(dif, state)
                   D0   D1
        
        void SetSerial(struct *DIFace, ULONG);

    FUNCTION
        Set serial state to ON/OFF. Note: If you turn serial off,
        you should turn it on before exiting door.

    INPUTS
        dif - A Pointer to the DIFace returned by InitDoor()
        state - new state of serial. 0 = Disable, 1 = Enable
@ENDNODE
