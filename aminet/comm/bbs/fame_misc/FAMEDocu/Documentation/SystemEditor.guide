                       @{"    Upload on Door Download     " link "SEExtXfrModUlonDoorDl"}
                       @{"   Upload on Message Download   " link "SEExtXfrModUlonMsgDl"}
                       @{"     Upload on ASL Download     " link "SEExtXfrModUlonASLDl"}
                       @{" Remote Auto Download (BEWARE!) " link "SEExtXfrModRemoteADl"}

                       @{"              SAVE              " link "SEExtXfrModSAVE"}
