@node "asc" "Ascii Escape sequences"

 @{b}@{bg shine}ASCII Escape Sequences@{ub}@{bg back}

 You may use Escape sequences in all your texts and ansis
 to get more control over cursor, style and colors of the
 texts and its typing.
 if you set i.e. an @{b}Esc[2J@{ub} at the beginning of a textfile,
 there will come a ClearScreen bevor the text is typed.
 (see below)

 The chars `Esc` representing the Esc-Key on the keyboard.
 It is normally not visible in texts.

      @{bg highlight}Sequence@{bg back}     @{bg highlight}Discription@{bg back}
 ----------------------------------------------------------------
          Esc@{b}@{bg shine}c@{ub}@{bg back}     Reset window

        Esc@{b}@{bg shine}[xA@{ub}@{bg back}     x lines up
        Esc@{b}@{bg shine}[xB@{ub}@{bg back}     x lines down
        Esc@{b}@{bg shine}[xC@{ub}@{bg back}     x chars left
        Esc@{b}@{bg shine}[xD@{ub}@{bg back}     x chars right

        Esc@{b}@{bg shine}[xE@{ub}@{bg back}     x lines down and move to the left
        Esc@{b}@{bg shine}[xF@{ub}@{bg back}     x lines up and move to char 1

      Esc@{b}@{bg shine}[x;yH@{ub}@{bg back}     move cursor to line x, char y

        Esc@{b}@{bg shine}[xJ@{ub}@{bg back}     ClearScreen:   x=0 clear all below
                                  x=2 clear all and move to bottom

         Esc@{b}@{bg shine}[K@{ub}@{bg back}     Clear line to the right of cursor

        Esc@{b}@{bg shine}[xL@{ub}@{bg back}     Insert x lines above current line
        Esc@{b}@{bg shine}[xM@{ub}@{bg back}     Insert x lines and move current line up

        Esc@{b}@{bg shine}[xm@{ub}@{bg back}     Change output: style x=(0,1,3,4,7) 
                   (normal,bold,italic,underlined,inverted)
     Esc@{b}@{bg shine}[xm;ym@{ub}@{bg back}     foreground y=(30,31,32,33)
                   (blue,white,black,orange)
  Esc@{b}@{bg shine}[xm;ym;zm@{ub}@{bg back}     background z=(40,41,42,43)
                   (blue,white,black,orange)

        Esc@{b}@{bg shine}[xP@{ub}@{bg back}     Delete x to the left of cursor

       Esc@{b}@{bg shine}[0 p@{ub}@{bg back}     Remove cursor
        Esc@{b}@{bg shine}[0p@{ub}@{bg back}     Bring back cursor

        Esc@{b}@{bg shine}[xS@{ub}@{bg back}     Move current line x lines up
        Esc@{b}@{bg shine}[xT@{ub}@{bg back}     Move current line x lines down

        Esc@{b}@{bg shine}[xt@{ub}@{bg back}     x=number of lines in window
        Esc@{b}@{bg shine}[xU@{ub}@{bg back}     x=number of column in window

        Esc@{b}@{bg shine}[xu@{ub}@{bg back}     x=chars per line

        Esc@{b}@{bg shine}[xx@{ub}@{bg back}     x=pixels from left border
        Esc@{b}@{bg shine}[xy@{ub}@{bg back}     x=pixels from top border

 @{"Main" link "MAIN" 0}
@endnode

