@Node "ST_OpenSerTrans()" "SerTrans.Library/ST_OpenSerTrans"

@{b}   NAME@{ub}
	ST_OpenSerTrans -- Opens SerTrans External Port (V10)

@{b}   SYNOPSIS@{ub}
	stport = ST_OpenSerTrans( portnumber )
	  D0                          D0    

@{b}   FUNCTION@{ub}
	Opens the SerTrans Port for external Modules. I.e. UserLogin
	UploadChecker, StatusCheck etc.

@{b}   INPUTS@{ub}
	portnumber    - Port ID (Must be NULL for now! In later
		      versions it identifies the Number of the Port)

@{b}   RESULT@{ub}
	stport	    - The @{"MsgPort" Link "TEXT_INCLUDE:exec/ports.h/Main" 29} of SerTrans

@{b}   BUGS@{ub}
	None Known

@{b}   SEE ALSO@{ub}
	@{"SerTrans.Library/ST_CloseSerTrans()" Link "ST_CloseSerTrans()"}

@EndNode

@Node "ST_CloseSerTrans()" "SerTrans.Library/ST_CloseSerTrans"

@{b}   NAME@{ub}
	ST_CloseSerTrans -- Closes the external Port of SerTrans (V10)

@{b}   SYNOPSIS@{ub}
	void = ST_CloseSerTrans( stport )
	  D0                    D0

@{b}   FUNCTION@{ub}
	Closes the External Port of SerTrans so SeTrans can work on the
	normal way

@{b}   INPUTS@{ub}
	stport        - STPort which is returned by OpenSerTrans

@{b}   RESULT@{ub}
	NONE

@{b}   BUGS@{ub}
	None Known

@{b}   SEE ALSO@{ub}
	@{"SerTrans.Library/ST_OpenSerTrans()" Link "ST_OpenSerTrans()"}

@EndNode

@Node "ST_Send()" "SerTrans.Library/ST_Send"

@{b}   NAME@{ub}
	ST_Send -- Sends a String (V10)

@{b}   SYNOPSIS@{ub}
	void = ST_Send( stport, string )
	  D0              D0      A0

@{b}   FUNCTION@{ub}
	Sends a given string to the Modem and the Console. If the Console
	is closed nothing will happen. The String will send only to the
	Modem. On the other hand, if no carrier is detected the string
	will only be shown on the console.

@{b}   INPUTS@{ub}
	stport        - STPort which is returned by OpenSerTrans
	string        - A null-terminated String

@{b}   RESULT@{ub}
	NONE

@{b}   BUGS@{ub}
	None Known

@{b}   SEE ALSO@{ub}
	@{"SerTrans.Library/ST_Read()" Link "ST_Read()"}

@EndNode

@Node "ST_Read()" "SerTrans.Library/ST_Read"

@{b}   NAME@{ub}
	ST_Read -- Reads a String (V10)

@{b}   SYNOPSIS@{ub}
	void = ST_Read( stport, len, blueline, protect, blankenter,
	  D0              D0     D1    D2        D3         D4

					 buffer, text, title)
					   A0     A1    A2

@{b}   FUNCTION@{ub}
	Reads a string from the Modem or the Console. Also you can
	specify wether the line is blue undergrounded or the chars
	will be protected (i.e. Password Input).

@{b}   INPUTS@{ub}
	stport        - STPort which is returned by OpenSerTrans
	len           - Number of chars to read. Must be at least 1.
	blueline      - Underground is Blue
		      (TRUE for blue Underground / FALSE for NONE)
	protect	    - Chars will be protected with a star
		      (TRUE for protected Chars / FALSE for Normal)
	blankenter    - Allows no blank input. The User has to enter
		      one or more chars. (TRUE = Disable / TRUE = Enable)
	buffer	    - A pointer to allocated memory, where to put the
		      entered string in.
	text	    - The Text which could be stored in the line where
		      the User has to enter a string. May be NULL
	title	    - The title which is standing in front of the
		      line. May be NULL

@{b}   RESULT@{ub}
	The given Pointer to the MemoryBlock

@{b}   BUGS@{ub}
	None Known

@{b}   SEE ALSO@{ub}
	@{"SerTrans.Library/ST_Send()" Link "ST_Send()"}

@EndNode

@Node "ST_CursorInput()" "SerTrans.Library/ST_CursorInput"


@{b}   NAME@{ub}
	ST_CursorInput -- Waits for Input via CursorKeys (V10)

@{b}   SYNOPSIS@{ub}
	number = ST_CursorInput( stport, ypos, array )
	  D0                    D0     D1    A0

@{b}   FUNCTION@{ub}
	Prints a line with options on the @{"Screen" Link "TEXT_INCLUDE:intuition/screens.h/Main" 97} so that the user can
	select one of those Items via CursorKeys. Also the User can
	select them with the shortcuts which are shown in the line.

@{b}   INPUTS@{ub}
	stport        - STPort which is returned by OpenSerTrans
	ypos          - Y-Position where to place the ItemLine
	Array         - An null terminated String

@{b}   EXAMPLE@{ub}
	Example 1: "_Select Another one|_Old One|_Keep this|_Try again",0
	Example 2: "_Continue|_Nonstop|_Cancel",0

	The '_' means that the Char after that will be highlighted for 
	the shortcut.
	The '|' truncates the words.

@{b}   RESULT@{ub}
	The number of the selected Item.

@{b}   BUGS@{ub}
	None Known

@{b}   SEE ALSO@{ub}
	@{"SerTrans.Library/ST_Read()" Link "ST_Read()"} @{"SerTrans.Library/ST_Send()" Link "ST_Send()"}
	@{"SerTrans.Library/ST_HorizCursorInput()" Link "ST_HorizCursorInput()"}

@EndNode

@Node "ST_ReceiveFile()" "SerTrans.Library/ST_ReceiveFile"


@{b}   NAME@{ub}
	ST_ReceiveFile -- Receives a File (V10)

@{b}   SYNOPSIS@{ub}
	void = ST_ReceiveFile( stport, path )
	 D0                      D0     A0

@{b}   FUNCTION@{ub}
	Receives a File from the User and places it to the given Path

@{b}   INPUTS@{ub}
	stport        - STPort which is returned by OpenSerTrans
	path          - Path where to put the file

@{b}   RESULT@{ub}
	NONE

@{b}   BUGS@{ub}
	None Known

@{b}   SEE ALSO@{ub}
	@{"SerTrans.Library/ST_SendFile()" Link "ST_SendFile()"}

@EndNode

@Node "ST_SendFile()" "SerTrans.Library/ST_SendFile"

@{b}   NAME@{ub}
	ST_SendFile -- Sends a File (V10)

@{b}   SYNOPSIS@{ub}
	void = ST_SendFile( stport, array )
	 D0                   D0     A0

@{b}   FUNCTION@{ub}
	Sends one or more Files to the User

@{b}   INPUTS@{ub}
	stport        - STPort which is returned by OpenSerTrans
	array         - An Null terminated array of Filenames

@{b}   EXAMPLE@{ub}

	(not language specified)

	array = AllocMem(12,$10000)

	array+0 = &File1		; Means Pointer of String
	array+4 = &File2		; Means Pointer of String
	array+8 = 0		; Null for Array termination

	FreeMem(array,12)

@{b}   RESULT@{ub}
	NONE

@{b}   BUGS@{ub}
	None Known

@{b}   SEE ALSO@{ub}
	SerTrans.Library/ST_SendFile()

@EndNode

