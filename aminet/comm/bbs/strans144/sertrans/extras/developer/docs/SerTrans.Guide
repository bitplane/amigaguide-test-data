@Node "ST_CheckCarrier()" "SerTrans.Library/ST_CheckCarrier"

@{b}   NAME@{ub}
	ST_CheckCarrier -- Checks if a Carrier is present (V11)

@{b}   SYNOPSIS@{ub}
	BOOL = ST_CheckCarrier( stport )
	 D0                       D0   

@{b}   FUNCTION@{ub}
	Checks if a Carrier is on the Serial device present or a SysopLogin
	is done.

@{b}   INPUTS@{ub}
	stport        - STPort which is returned by OpenSerTrans

@{b}   RESULT@{ub}
	BOOL	- TRUE  for Carrier
		- FALSE for NO CARRIER

@{b}   NOTE@{ub}
	New for V13 of SerTrans.Lib, SerTrans will return a TRUE
	when a User logged in or the Sysop has done a SysopLogin. If no
	login is done, this Function will return FALSE

@{b}   BUGS@{ub}
	None Known

@EndNode

