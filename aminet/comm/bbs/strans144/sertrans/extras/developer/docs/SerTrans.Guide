@Node "ST_WriteProtocol()" "SerTrans.Library/ST_WriteProtocol"

@{b}   NAME@{ub}
	ST_WriteProtocol -- Writes a String to the Protocol (V11)

@{b}   SYNOPSIS@{ub}
	void = ST_WriteProtocol( stport, string )
	 D0                        D0      A0

@{b}   FUNCTION@{ub}
	Writes a string to the opened Protocol. This function is
	usefull, because you can't open the Systems Protocol to write
	in it. While the User is logged in, a @{"Lock()" Link "dos/Lock()"} will disable
	any work with it. So if you want to write something into the
	Protocol use this function.

@{b}   INPUTS@{ub}
	stport        - STPort which is returned by OpenSerTrans
	string        - String to write

@{b}   RESULT@{ub}
	NONE

@{b}   BUGS@{ub}
	None Known

@{b}   SEE ALSO@{ub}
	@{"SerTrans.Library/ST_SerPutString()" Link "ST_SerPutString()"}  @{"SerTrans.Library/ST_SerPutString()" Link "ST_SerPutString()"}
	@{"Dos.Library/Lock()" Link "dos/Lock()"}

@EndNode

