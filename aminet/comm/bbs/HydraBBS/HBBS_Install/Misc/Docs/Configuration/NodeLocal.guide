@Database CFG_NODELOCAL

@Index HBBS:Docs/Misc/Index.guide/MAIN

@Node Main "HBBS:Nodes/Node<XX>/NodeLocal"

  >> Quick Access Buttons @{" EDIT " system "run >nil: TTX HBBS:Docs/Configuration/NodeLocal.Guide"}

  HBBS:Nodes/Node<XX>/NodeLocal
  =============================

  Description:

  The HBBS:Nodes/Node<XX>/NodeLocal files define the settings for the
  individual node.  The options in this file override the settings
  specified In HBBS:Nodes/NodeGlobal

  Options:

  All The Settings Below are EXACTLY the same as in @{"NodeGlobal" link HBBS:Docs/Configuration/NodeGlobal.guide/MAIN}

  SysopAccount=<string>                  @{" More... " link HBBS:Docs/Configuration/BBSGlobal.guide/SysopAccount}

 *NodeName=<string>                      @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/NodeName}
 *NodePhone=<string>                     @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/NodePhone}
 *NodeConnectScript<path>                @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/NodeConnectScript}

  AskUserPW=<boolean>                    @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/AskUserPW}

  UseSysPW=<boolean>                     @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/UseSysPW}
  SysPW=<string>                         @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/SysPW}
  SysPWScript=<path>                     @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/SysPWScript}
  SysPWPrompt=<string>                   @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/SysPWPrompt}

 *UseNodePW=<boolean>                    @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/UseNodePW}
 *NodePW=<string>                        @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/NodePW}
 *NodePWScript=<path>                    @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/NodePWScript}
 *NodePWPrompt=<string>                  @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/NodePWPrompt}

  UserNamePrompt=<string>                @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/UserNamePrompt}
  UserPWPrompt=<string>                  @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/UserPWPrompt}

 *NodeLogFile=<path>                     @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/NodeLogFile}
 *ModemLogFile=<path>                    @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/ModemLogFile}
 *CallersLogFile=<path>                  @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/CallersLogFile}

 *UploadLog=<boolean>                    @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/UploadLog}
 *DownloadLog=<boolean>                  @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/DownloadLog}

  ChatFlag=<boolean>                     @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/ChatFlag}
  Iconified=<boolean>                    @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/Iconified}
  UseOwnScreen=<boolean>                 @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/UseOwnScreen}
  OpenWatch=<boolean>                    @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/OpenWatch}

  ScrModeID=<numeric>                    @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/ScrModeID}
  ScrHeight=<numeric>                    @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/ScrHeight}
  ScrWidth=<numeric>                     @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/ScrWidth}
  ScrDepth=<numeric>                     @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/ScrDepth}

  AccessRequired=<numeric>               @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/AccessRequired}

 *UseDevice=<boolean>                    @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/UseDevice}
  AllowNewUsers=<boolean>                @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/AllowNewUsers}

  InactivitySeconds=<boolean>            @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/InactivitySeconds}
  InactivityDisconnectOverride=<boolean> @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/InactivityDisconnectOverride}

  CheckNodeScreens=<boolean>             @{" More... " link HBBS:Docs/Configuration/NodeGlobal.guide/CheckNodeScreens}

@EndNode
