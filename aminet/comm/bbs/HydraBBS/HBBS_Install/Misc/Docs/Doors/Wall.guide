@Database DOOR_<DoorName>

@Node Main "Wall"

  Wall V1.0 Written by Hydra/!cP!

  @{" Description          " link Description}
  @{" Installation         " link Installation}
  @{" System Options       " link SystemOptions}
  @{" Command Line Options " link CmdLineOptions}
  @{" Screens Displayed    " link ScreensDisplayed}
  @{" Doors Called         " link DoorsCalled}
  @{" Returns              " link Returns}
  @{" Config Files         " link ConfigFiles}
  @{" ToDo                 " link ToDo}
  @{" History              " link History}

@EndNode

@Node Description "Description"

  Description
  ===========

    Cool door that displays a lines of text entered by the users.

    The users handle is displayed on the right on the same line as the text
    written by that user.

    All wall items are written to a wall history file called
    Progdir:Wall.History (i.e. HBBS:Doors/User/Wall/Wall.History)

    There is no maximum of lines that can be displayed. (but the user might
    get bored at over 40 wall lines).

@EndNode


