    ADD "Jean-Marc Xiume" "jmx@mygale.org" "co-auteur de GoodNews"

@{b}Voir ťgalement :@{ub} @{"GoodNews.Book" Link "CF_UMS_BOOK"} @{"Le carnet d'adresses" Link "WI_BOOK_EDIT"}
@EndNode

