        ||| @{"MAILPART" LINK "DownloadPrefs-MAILPART"}.:                                    |||
        ||| @{"DATE" LINK "DownloadPrefs-DATE"}.....:                                    |||
        |||           @{" TOP " LINK "DownloadPrefs-TOP"}@{" << " LINK "DownloadPrefs-<<"}@{" < " LINK "DownloadPrefs-<"}@{" > " LINK "DownloadPrefs->"}@{" >> " LINK "DownloadPrefs->>"}@{" END " LINK "DownloadPrefs-END"}         |||
        |||          @{" DELETE " LINK "DownloadPrefs-DELETE"}@{" READ " LINK "DownloadPrefs-READ"}@{" WAIT " LINK "DownloadPrefs-WAIT"}@{" LOAD  " LINK "DownloadPrefs-LOAD"}        |||
