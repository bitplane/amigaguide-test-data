 ; the Amiga Magazine BBS

  @{"BBSID" link "config_standard_options" 3}      DIVO
  @{"DOWNLOAD" link "config_standard_options" 15}   DH0:COMMS/DOWNLOAD
  @{"UPLOAD" link "config_standard_options" 23}     DH0:COMMS/UPLOAD

  @{"INBOUND" link "config_standard_options" 32}    MAIL:INBOUND
  @{"OUTBOUND" link "config_standard_options" 42}   MAIL:OUTBOUND
  @{"TEMP" link "config_standard_options" 51}       MAIL:TEMP

  @{"BBS_NODE" link "config_standard_options" 61}   99:999/999
  @{"POINT_NODE" link "config_standard_options" 72} 99:999/999.9

  @{"CONVERT_NETMAIL" link "config_standard_options" 92}
  @{"NETMAIL_AREA E-MAIL" link "config_standard_options" 80}

  @{"USERAREA" link "config_qwk2fido" 14}
  @{"AREA_NAMES_TO_UPPER" link "config_qwk2fido" 30}

