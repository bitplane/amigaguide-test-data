 @{"#LINECHAR     " link "#LINECHAR"}
 @{"#LINKCHAR     " link "#LINKCHAR"}
 @{"#LISTNOACC    " link "#LISTNOACC"}
 @{"#LISTREAD     " link "#LISTREAD"}
 @{"#LISTWRITE    " link "#LISTWRITE"}
 @{"#LISTPOLICY   " link "#LISTPOLICY"}
 @{"#LISTINACTIVE " link "#LISTINACTIVE"}
 #LISTHARD

