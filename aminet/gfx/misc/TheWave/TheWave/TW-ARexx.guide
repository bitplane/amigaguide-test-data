/*E*/

/*S*/ Befehle
@NODE "ABOUT" "Befehl About"

  Befehl: ABOUT
  -------------------------------------

  Kategorie:
    Allgemein

  Funktion:
    Es wird das Informationsfenster geöffnet

  Parameter:
    ON/S
      Mit ON wird das Fenster geöffnet (falls es das nicht schon ist).
    OFF/S
      Mit OFF wird das Fenster geschlossen (falls es das nicht schon ist).
    TOGGLE/S
      Mit TOGGLE wird das Fenster geschlossen wenn es offen ist und
      anders herum.
@ENDNODE


@NODE "NEW" "Der Befehl NEW"

  Befehl: NEW
  -------------------------------------

  Kategorie:
    Allgemein

  Funktion:
    Das aktuelle Projekt wird gelöscht.

  Parameter:
    FORCE/S
      Wird dieser Parameter nicht angegeben, so wird vorher eine
      Sicherheitsabfrage gemacht.

@ENDNODE

@NODE "QUIT" "Der Befehl QUIT"

  Befehl: QUIT
  -------------------------------------

  Kategorie:
    Allgemein

  Funktion:
    Beenden von TheWave

  Parameter:
    FORCE/S
      Wird dieser Parameter nicht angegeben, so wird vorher eine
      Sicherheitsabfrage gemacht.

@ENDNODE

@NODE "LOAD" "Der Befehl LOAD"

  Befehl: LOAD
  -------------------------------------

  Kategorie:
    Allgemein

  Funktion:
    Laden eines Projektes.

  Parameter:
    ASK/S
      Wird dieser ASK angegeben, so kann man über einen FileRequester
      die zu ladende Datei auswählen.
    NAME
      Hier wird die Datei angegeben die geladen werden soll.
      In Verbindung mit ASK wird so die Datei des FileRequesters
      voreingestellt.

@ENDNODE

@NODE "SAVE" "Der Befehl SAVE"

  Befehl: SAVE
  -------------------------------------

  Kategorie:
    Allgemein

  Funktion:
    Speichern des Projektes.

  Parameter
    ASK/S
      Wird dieser ASK angegeben, so kann man über einen FileRequester
      die Datei auswählen als die das Projekt gespeichert werden soll.
    FORCE/S
      Wird FORCE mit angegeben, so wird vor dem Überschreiben von Dateien
      gewarnt.
    NAME
      Hier wird der Name der Datei angegeben, unter dem das Projekt ge-
      speichert werden soll. In Verbindung mit ASK wird so die Datei des
      Filerequesters voreingestellt.

@ENDNODE

@NODE "QUERY" "Der Befehl QUERY"

  Befehl: QUERY
  -------------------------------------

  Kategorie:
    Allgemein

  Funktion:
    Ermitteln von Daten über das Projekt, der Umgebung und TheWave selbst.

  Parameter:
    VERSION/S
      Gibt die Version von TheWave zurück.
    LANGUAGE/S
      Gibt die in der Oberfläche verwendete Sprache zurück.
    STONECOUNT/S
      Gibt die Anzahl der Steine im aktuellen Projekt zurück.
    WAVECOUNT/S
      Gibt die Anzahl der Wellen im aktuellen Projekt zurück.
    COLORCOUNT/S
      Gibt die Anzahl der Farben im aktuellen Projekt zurück.
    PROJECTNAME/S
      Ermittelt den Datei-Namen des aktuellen Projekts (ohne Pfad)
    PROJECT/S
      Stellt fest, ob es ein Projekt gibt oder nicht.
    PROJECTPATH/S"
      Ermittelt den Pfad-Namen des aktuellen Projekts (nur Pfad)

@ENDNODE

@NODE "OPENWINDOW" "Der Befehl OPENWINDOW"

  Befehl: OPENWINDOW
  -------------------------------------

  Kategorie:
    Allgemein

  Funktion:
    Öffnet diverse Fenster

  Parameter:
    STONES/S
      Das Steinlisten-Fenster
    WAVES/S
      Das Wellenlisten-Fenster
    COLORS/S
      Das Farblisten-Fenster
    SETTINGS/S
      Das EinstellungsFenster
    ABOUT/S
      Das Informationsfenster
    MAIN/S
      Das Hauptfenster (nicht das Projektfenster)
    GRAPH/S
      Das Wellengraf-Fenster (nur wenn das Wellenfenster offen ist)

@ENDNODE

@NODE "CLOSEWINDOW" "Der Befehl CLOSEWINDOW"

  Befehl: CLOSEWINDOW
  -------------------------------------

  Kategorie:
    Allgemein

  Funktion:
    Schließt diverse Fenster

  Parameter:
    STONES/S
      Das Steinlisten-Fenster
    WAVES/S
      Das Wellenlisten-Fenster
    COLORS/S
      Das Farblisten-Fenster
    SETTINGS/S
      Das EinstellungsFenster
    ABOUT/S
      Das Informationsfenster
    MAIN/S
      Das Hauptfenster (nicht das Projektfenster)
    GRAPH/S
      Das Wellengraf-Fenster (nur wenn das Wellenfenster offen ist)

@ENDNODE

@NODE "TOGGLEWINDOW" "Der Befehl TOGGLEWINDOW"

  Befehl: TOGGLEWINDOW
  -------------------------------------

  Kategorie:
    Allgemein

  Funktion:
    Öffnet diverse Fenster wenn sie geschlossen und schließt sie wenn
    sie offen sind.

  Parameter:
    STONES/S
      Das Steinlisten-Fenster
    WAVES/S
      Das Wellenlisten-Fenster
    COLORS/S
      Das Farblisten-Fenster
    SETTINGS/S
      Das EinstellungsFenster
    ABOUT/S
      Das Informationsfenster
    MAIN/S
      Das Hauptfenster (nicht das Projektfenster)
    GRAPH/S
      Das Wellengraf-Fenster (nur wenn das Wellenfenster offen ist)

@ENDNODE

@NODE "RENDER" "Der Befehl RENDER"

  Befehl: RENDER
  -------------------------------------

  Kategorie:
    Allgemein

  Funktion:
    Starten/Stoppen des Renderers

  Parameter:
    START/S
      Starten
    STOP/S

     Stoppen
@ENDNODE
@NODE "NEWSTONE" "Der Befehl NEWSTONE"

  Befehl: NEWSTONE
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Erzeugen eines neuen Steines.

  Parameter:
    NAME
      Der Name des neuen Steines
    X=XPOS
      Die Position (angegeben in %, 100% = Teichbreite)
    Y=YPOS
      Die Position (angegeben in %, 100% = Teichbreite)

@ENDNODE

@NODE "REMOVESTONE" "Der Befehl REMOVESTONE"

  Befehl: REMOVESTONE
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Löschen eines Steines

  Parameter:
    NAME
      Der Name des Steins der gelöscht werden soll.
    NUMBER/K
      Man kann den Stein auch über seine Nummer löschen indem man
      hier seine Nummer angibt
    ALL/S
      Wenn alle Steine gelöscht werden sollen, dann diesen Parameter
      mit angeben.

@ENDNODE

@NODE "RENAMESTONE" "Der Befehl RENAMESTONE"

  Befehl: RENAMESTONE
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Umbenennen eines Steines

  Parameter:
    OLDNAME/A
      Der alte Name des Steines (der umbenannt werden soll).
      Tip: Wer den alten Namen des Steines nicht weiß, kann ihn
      mit @{"GETSTONENAME" LINK "GETSTONENAME"} und der Angabe seiner Nummer ermitteln.
    NEWNAME/A
      Der neue Name des Steines

@ENDNODE

@NODE "SETSTONEPOSITION" "Der Befehl SETSTONEPOSITION"

  Befehl: SETSTONEPOSITION
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Setzen einer Position eines Steines

  Parameter:
    NAME
      Der Name des Steines der umpositioniert werden soll
    NUMBER/K
      Die Nummer des Steines der umpositioniert werden soll.
      Dieser Parameter ermöglicht eine identifizierung des Steines
      ohne dessen Namen (muß nicht angegeben werden)
    X
      Die prozentuale X-Koordinate (100%=Projektfensterbreite)
    Y
      Die prozentuale Y-Koordinate (100%=Projektfensterhöhe)

@ENDNODE

@NODE "MOVESTONE" "Der Befehl MOVESTONE"

  Befehl: MOVESTONE
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Verschieben eines Steines

  Parameter:
    NAME
      Der Name des Steines der umpositioniert werden soll
    NUMBER/K
      Die Nummer des Steines der umpositioniert werden soll.
      Dieser Parameter ermöglicht eine identifizierung des Steines
      ohne dessen Namen (muß nicht angegeben werden)
    X
      Die prozentuale Verschiebung in X-Richtung (100%=Projektfensterbreite)
    Y
      Die prozentuale Verschiebung in Y-Richtung (100%=Projektfensterhöhe)

@ENDNODE

@NODE "GETSTONENAME" "Der Befehl GETSTONENAME"

  Befehl: GETSTONENAME
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Ermittlen eines Steinnamens

  Parameter:
    NUMBER/A
      Die Nummer des Steines, dessen Namen ermittelt werden soll

@ENDNODE

@NODE "GETSTONENUMBER" "Der Befehl GETSTONENUMBER"

  Befehl: GETSTONENUMBER
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Ermitteln einer Steinnummer

  Parameter:
    NAME/A
      Der Name des Steines dessen Nummer ermittelt werden soll.

@ENDNODE

@NODE "COPYSTONE" "Der Befehl COPYSTONE"

  Befehl: COPYSTONE
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Kopieren (Duplizieren) eines Steines

  Parameter:
    SOURCENAME
      Der Name des Steines der kopiert werden soll.
    NUMBER/K
      Anstatt dem Namen des Steines kann auch seine Nummer angegeben
      werden.
    DESTNAME
      Der Name des neu angelegten Steines

@ENDNODE

@NODE "SETSTONEWAVE" "Der Befehl SETSTONEWAVE"

  Befehl: SETSTONEWAVE
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
      Auswählen einer Welle für einen Stein

  Parameter:
      NAME
        Der Name des Steins für den die Welle gesetzt werden soll
      NUMBER/K
        Anstatt des Namens des Steins, kann auch seine Nummer ange-
        geben werden
      ASK/S
        Wird ASK mit angegeben, so kann die Welle vom Benutzer in
        einem Dialogfenster ausgewählt werden.
      WAVENAME
        Der Name der Welle die dem Stein zugewiesen werden soll.
      WAVENUMBER/K
        Anstatt des Namens der Welle kann auch ihre Nummer ange-
        geben werden.

@ENDNODE

@NODE "SETSTONECOLOR" "Der Befehl SETSTONECOLOR"

  Befehl: SETSTONECOLOR
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Auswählen einer Farbe für einen Stein

  Parameter:
      NAME
        Der Name des Steins für den eine Farbe gesetzt werden soll.
      NUMBER/K
        Anstatt des Namens kann auch die Steinnummer angegeben werden.
      ASK/S
        Wird ASK mit angegeben, so kann die Farbe vom Benutzer
        in einem Dialogfenster ausgewählt werden.
      COLORNAME
        Der Name der Farbe, die dem Stein zugewiesen werden soll.
      COLORNUMBER/K"
       Anstatt des Namens der Welle kann auch ihre Nummer ange-

      geben werden.
@ENDNODE
------------------------------------------------------------
@NODE "GETSTONEXPOS" "Der Befehl GETSTONEXPOS"

  Befehl: GETSTONEXPOS
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Ermitteln der (prozentualen) X-Position eines Steines
    (100%=Projektfensterbreite)

  Parameter:
    NAME
      Der Name des Steins der gemeint ist
    NUMBER/K
      Anstatt des Namens, kann auch seine Nummer angegeben werden.

@ENDNODE

@NODE "GETSTONEYPOS" "Der Befehl GETSTONEYPOS"

  Befehl: GETSTONEYPOS
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Ermitteln der (prozentualen) Y-Position eines Steines
    (100%=Projektfensterhöhe)

  Parameter:
    NAME
      Der Name des Steins der gemeint ist
    NUMBER/K
      Anstatt des Namens, kann auch seine Nummer angegeben werden.

@ENDNODE

@NODE "GETSTONEWAVE" "Der Befehl GETSTONEWAVE"

  Befehl: GETSTONEWAVE
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Ermitteln des Wellennamens der Welle die auf einen Stein
    eingestellt ist.

  Parameter:
    NAME
      Der Name des Steins der gemeint ist
    NUMBER/K
      Anstatt des Namens, kann auch seine Nummer angegeben werden.

@ENDNODE

@NODE "GETSTONECOLOR" "Der Befehl GETSTONECOLOR"

  Befehl: GETSTONECOLOR
  -------------------------------------

  Kategorie:
    Befehle für Steine

  Funktion:
    Ermitteln des Farbamens der Farbe die auf einen Stein
    eingestellt ist.

  Parameter:
    NAME
      Der Name des Steins der gemeint ist
    NUMBER/K
      Anstatt des Namens, kann auch seine Nummer angegeben werden.

@ENDNODE

@NODE "NEWWAVE" "Der Befehl NEWWAVE"

  Befehl: NEWWAVE
  -------------------------------------

  Kategorie:
    Befehle für Wellen

  Funktion:
    ARexx-Befehl für die Erzeugung einer neuen Welle

  Parameter:
    NAME
      Der Name für die neue Welle
    WEAKENING
      Die Abschwächung der Welle angegeben über eine Halbwertsdistanz
      der Welle in %
      (100%=Projektfenster-Diagonale)
      Erklärung: In dieser prozentualen Entfernung zum Wellenmaximum
      halbiert sich die Amplitude der Welle. 0 für keine Abschwächung.
      Ansonsten gilt also: Je kleiner desto stärker nimmt die Amplitude
      ab.
    DISTANCE
      Der Abstand des Wellenmaximums von der Steinposition. Damit kann
      man Bilder erzeugen, die
      (Diese Idee ist mir übrigens in der Badewanne gekommen, Heureka!)
    PERIOD
      Die Periodenlänge der Welle in %
      (100%=Projektfenster-Diagonale)
    AMPLITUDE
      Die Startamplitude bzw. die Maximalamplitude der Welle
      (100% = Farbanzahl/(Steine*2), klingt kompliziert, ist aber so)

@ENDNODE

@NODE "REMOVEWAVE" "Der Befehl REMOVEWAVE"

  Befehl: REMOVEWAVE
  -------------------------------------

  Kategorie:
    Befehle für Wellen

  Funktion:
    Löschen einer Welle

  Parameter:
    NAME
      Der Name der Welle die gelöscht werden soll
    NUMBER/K
      Anstatt des Namens kann man auch die Nummer der Welle angeben
    ALL/S
      Wir ALL angegeben, so werden alle Wellen gelöscht

@ENDNODE

@NODE "RENAMEWAVE" "Der Befehl RENAMEWAVE"

  Befehl: RENAMEWAVE
  -------------------------------------

  Kategorie:
    Befehle für Wellen

  Funktion:
