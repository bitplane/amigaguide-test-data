@macro prog "@{b}P I C@{ub} @{fg shine}BASE@{fg text}"
@macro title "@{bg shine}       @{bg background} @{fg shine}@{bg shadow}  @{b}$1@{ub}  @{bg background}@{fg text}@{par}"
@macro block "    "
@macro bold "@{b}$1@{ub}"
@macro italic "@{i}$1@{ui}"
@macro uline "@{u}$1@{uu}"
@macro white "@{fg highlight}$1@{fg text}"
@macro black "@{bg shadow}$1@{bg background}"
@macro bitm "@{bg shine} @{b}$1@{ub}  $2 @{bg background}"
@macro item "@{bg shine} $1  $2 @{bg background}"
@macro sitm "@{bg shine} $1 $2 @{bg background}"
@macro menu "@{bg shadow}@{fg shine} $1 @{fg text}@{bg background}"
@macro mark "@{bg fill} @{fg shine}$1@{fg text} @{bg background}"
@macro link "@{u}@{apen 247}$1@{fg text}@{uu}"

