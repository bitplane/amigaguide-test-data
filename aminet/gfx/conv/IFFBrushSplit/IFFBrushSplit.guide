@DATABASE "IFFSplit.guide"
@WIDTH 77
@HEIGHT 24

@node main "IFFSplit.guide"
                              ------------
                             | ---------- |
                             || IFFSplit ||
                             | ---------- |
                              ------------

  This is a program, which unpackes an IFF and creates a unpacked-IFF File

  with @{"CMAP" link CMAP}, @{"CAMG" link CAMG}, @{"BODY" link BODY} und @{"BMHD" link BMHD}, other not important.

  A second file, i call it @{"COLOUR-File" link ColourFile}, has the ColourTable.

  A third file, i call it @{"RAW-File" link RawFile}, has the BODY-Data.



                               @{"The Author" link Autor}

@endnode

@node CAMG "CAMG"

 Description   : Commodore Amiga Views

 C-Source-Code : typedef struct CommodoreAmiga
                 {
                     UWORD PadWord;
                     UWORD ViewModes;
                  };

@endnode

@node BODY "BODY"

 Description : Bitplane-Datas

@endnode

@node CMAP "CMAP"

 Description   : Color-Map

 C-Source-Code : typedef struct ColorRegister
                 {
                     UBYTE red;              /* red-value
                     UBYTE green;            /* green-value
                     UBYTE blue;             /* blue-value
                 };

@endnode

@node BMHD "BMHD"

 Description   : Bitmap-Header

 C-Source-Code : typedef struct BitMapHeader
                 {
                     UWORD w;                  /* width of brush
                     UWORD h;                  /* height of brush
                     WORD x;                   /* x-offset
                     WORD y;                   /* y-offsett
                     UBYTE nPlanes;            /* count of bitmaps
                     UBYTE masking;            /* masking
                     UBYTE compression;        /* compressed or uncompressed
                     UBYTE pad1;               /* pad
                     UWORD transparentColor;   /* colornumber, which is transparent
                     UBYTE xAspect;            /* x-aspect (width:height)
                     UBYTE yAspect;            /* y-aspect (width:height)
                     WORD Width;               /* screen-width
                     WORD Height;              /* screen-height
                 };

@endnode

@node RawFile "BODY-DATA"

  here are the different Bitmaps saved, the first to the last.

@endnode

@node ColourFile "CMAP-DATA"

 here is saved the color-values (red,green,blue).

@endnode

