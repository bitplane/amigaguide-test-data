          - CGM
          - DR2D
          - HPGL
          - WW
          - AI
          - WMF
          - JMF
          - FIG
      - PRINT @{"opens a requester" LINK "PRINT_REQUESTER"}
      - Plot @{"opens a requester" LINK "PLOT_REQUESTER"}
      - PostScript @{"opens a requester" LINK "PS_REQUESTER"}
