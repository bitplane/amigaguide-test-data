    @{"ASKNUM  " LINK ASKNUM} saisie d'un nombre
    @{"ASKTEXT " LINK ASKTEXT} saisie d'une chaÓne de caractŤres
    @{"CURSMODE" LINK CURSMODE} place le curseur en mode placement objet
    @{"GETLINE " LINK GETLINE} dťfinition d'une ligne ŗ l'aide de la souris
    @{"GETPOINT" LINK GETPOINT} choix d'un point ŗ l'aide de la souris
    @{"GETZONE " LINK GETZONE} dťfinition d'une zone ŗ l'aide de la souris
