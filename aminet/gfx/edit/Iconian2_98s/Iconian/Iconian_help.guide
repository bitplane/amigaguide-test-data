@node "RX_ABOUT" "ARexx: ABOUT"
@{b}ABOUT@{ub}

Function:
     Display information window.

Syntax:
     ABOUT
@endnode

@node "RX_AIRBRUSH" "ARexx: AIRBRUSH"
@{b}AIRBRUSH@{ub}

Function:
     Activates and controls airbrush draw tool.

Syntax:
     AIRBRUSH ("SMALL" | "MED" | "LARGE")
              ("DRIP" | "NORMAL")
              ("FOCAS" | "EVEN")

Template:
     SMALL/S,MED/S,LARGE/S,DRIP/S,NORMAL/S,FOCAS/S,EVEN/S

Options:
    "SMALL", "MED", "LARGE"
       Select airbrush area size.

    "DRIP", "NORMAL"
       Select spraypaint method.

    "FOCAS", "EVEN"
       Select aiming method.

Example:
     /*Activate airbrush draw tool, sets small and no focasing attributes:*/
     AIRBRUSH SMALL EVEN
@endnode

@node "RX_BUFFERSIZE" "ARexx: BUFFERSIZE"
@{b}BUFFERSIZE@{ub}

Function:
     Change buffer size of current project.

Syntax:
     BUFFERSIZE <width> <height> | <width> | "H" <height>

Template:
     W/N/A,H/N/A

@endnode

@node "RX_BRUSH" "ARexx: BRUSH"
@{b}BRUSH@{ub}

Function:
     Activate and cut brushes.

Syntax:
     BRUSH (<left> <top> <width> <height> ("CUT")) (<whichbrush>)

Template:
     LEFT/N,TOP/N,WIDTH/N,HEIGHT/N,CUT/S,WHICH/N

Options:
     LEFT <left> TOP <top> WIDTH <width> HEIGHT <height>
       Defines upperleft corner.

     CUT
       Area will be cleared after brush is grabbed.

     WHICH <whichbrush>
       Selects current brush to use.  Valid range is 0 thru 4.

Example:
     /*Cut out a brush and store it in buffer #3*/
     BRUSH WHICH=3 0 0 15 15 CUT
@endnode

@node "RX_CHANGESAVEDEPTH" "ARexx: CHANGESAVEDEPTH"
@{b}CHANGESAVEDEPTH@{ub}

Function:
     Changes the save depth method of the current project.

Syntax:
     CHANGESAVEDEPTH <savedepth>

Template:
     MODE/N/A

Options:
     MODE <savedepth>
       A value of 0 thru 2, corresponding to the following:
         0. Strip Planes
         1. Current Depth
         2. Force Eight
@endnode

@node "RX_CHANGESAVEMODE" "ARexx: CHANGESAVEMODE"
@{b}CHANGESAVEMODE@{ub}

Function:
     Select how an icons dimensions are obtained when saved.

Syntax:
     CHANGESAVEMODE <sizemethod>

Template:
     MODE/N/A

Options:
     MODE <sizemethod>
       A value of 0 thru 4, corresponding to the following:
         0. Auto Size
         1. Full Size
         2. Custom Size
         3. NewIcon Standard Size
         4. Explode Method
@endnode

@node "RX_CIRCLE" "ARexx: CIRCLE"
@{b}CIRCLE@{ub}

Function:
     Activate circle draw tool, and to draw circles.

Syntax:
     CIRCLE (<xcoord> <ycoord> <xradius> (<yradius>) ("FILL"))

Template:
     X/N,Y/N,RADX/N,RADY/N,FILL/S

Options:
     X <xcoord>, Y <ycoord>
       Selects the circle/oval center point.

     RADX <xradius>, RADY <yradius>
       Adjusts the circle size.

     "FILL"
       Fills the circle interior.

Example:
     /*Draw a plain circle.*/
     CIRCLE 50 50 25 25
@endnode

@node "RX_CLEAR" "ARexx: CLEAR"
@{b}CLEAR@{ub}

Function:
     Clears the graphics buffer of the current project, using the current background pen.

Syntax:
     CLEAR
@endnode

@node "RX_CLOSE" "ARexx: CLOSE"
@{b}CLOSE@{ub}

Function:
     Closes a project window.

Syntax:
     CLOSE (<project>) ("FORCE")

Template:
     PROJECT/N,FORCE/S

Options:
     PROJECT <project>
       Selects which project window to close.

     "FORCE"
       Closes window, even if project has not been saved.
@endnode

@node "RX_CLOSESTCOLOR" "ARexx: CLOSESTCOLOR"
@{b}CLOSESTCOLOR@{ub}

Function:
     Locates the pen nearest the given color values.

Syntax:
     CLOSESTCOLOR <red> <green> <blue>

Template:
     RED/N/A,GREEN/N/A,BLUE/N/A

Result:
     The pen number of the closest color found.

Options:
     RED <red>, GREEN <green>, BLUE <blue>
       Selects the RGB values to locate.

Example:
     /*Locate a greyish color pen.*/
     CLOSESTCOLOR 128 128 128
     greypen=result
@endnode

@node "RX_COLOR" "ARexx: COLOR"
@{b}COLOR@{ub}

Function:
     Activates the "Color" brush draw mode.

Syntax:
     COLOR
@endnode

@node "RX_COPY" "ARexx: COPY"
@{b}COPY@{ub}

Function:
     Copies the current graphic buffer to the clipboard device.

Syntax:
     COPY
@endnode

@node "RX_CUT" "ARexx: CUT"
@{b}CUT@{ub}

Function:
     Cuts the current graphic buffer to the clipboard device.

Syntax:
     CUT
@endnode

@node "RX_DOTISSTANDARD" "ARexx: DOTISSTANDARD"
@{b}DOTISSTANDARD@{ub}

Function:
     Specifies that the Newicon old style image is a dot.

Syntax:
     DOTISSTANDARD

Results:
     none
@endnode

@node "RX_DOUBLEBRUSH" "ARexx: DOUBLEBRUSH"
@{b}DOUBLEBRUSH@{ub}

Function:
     Doubles the brush size in the specified direction(s).

Syntax:
     DOUBLEBRUSH ("X") ("Y")

Template:
     X/S,Y/S
@endnode

@node "RX_ERASE" "ARexx: ERASE"
@{b}ERASE@{ub}

Function:
     Erases the graphics buffer of the current project, using color 0.

Syntax:
     ERASE
@endnode

@node "RX_EXCHANGE" "ARexx: EXCHANGE"
@{b}EXCHANGE@{ub}

Function:
     Swaps the normal and selected graphics buffers.

Syntax:
     EXCHANGE
@endnode

@node "RX_FILL" "ARexx: FILL"
@{b}FILL@{ub}

Function:
     Fills in enclosed areas.

Syntax:
     FILL (<xcoord> <ycoord>)

Template:
     X/N,Y/N

Options:
     X <xcoord>, Y <ycoord>
       Selects where to fill from.
@endnode

@node "RX_FLUSHUNDOS" "ARexx: FLUSHUNDOS"
@{b}FLUSHUNDOS@{ub}

Function:
     Frees undo buffer memory.

Syntax:
     FLUSHUNDOS ("ALL") ("FORCE")

Template:
     ALL/S,FORCE/S

Options:
     "ALL"
       All undo buffers will be flushed, not only the current image.

     "FORCE"
       Suppresses verification requester.
@endnode

@node "RX_FREEHAND" "ARexx: FREEHAND"
@{b}FREEHAND@{ub}

Function:
     Selects freehand drawing tool.

Syntax:
     FREEHAND ("FILL")

Template:
     FILL/S

Options:
     "FILL"
       Activates filled polygon method.
@endnode

@node "RX_GETBGCOLOR" "ARexx: GETBGCOLOR"
@{b}GETBGCOLOR@{ub}

Function:
     Obtains the current background pen value.

Syntax:
     GETGBCOLOR

Result:
     The current secondary (background) pen.
@endnode

@node "RX_GETBUFFERSIZE" "ARexx: GETBUFFERSIZE"
@{b}GETBUFFERSIZE@{ub}

Function:
     Obtains the current buffer width or height.

Syntax:
     GETBUFFERSIZE "WIDTH" | "HEIGHT"

Template:
     W=WIDTH/S,H=HEIGHT/S

Result:
     Either the width or height in pixels.
@endnode

@node "RX_GETCOORD" "ARexx: GETCOORD"
@{b}GETCOORD@{ub}

Function:
     Obtains the current user mouse location.

Syntax:
     GETCOORD "X" | "Y"

Template:
     X/S,Y/S

Result:
     The mouse location, either horizontally or vertically.

Notes:
     The value returned may be outside the bufferspace.  Use GETBUFFERSIZE to check if the returned location is valid, and handle appropriatly.

Example:
     /*Get the current mouse location, and store these in mousex and mousey*/
     OPTIONS RESULTS
     GETCOORD X
     mousex=RESULT
     GETCOORD Y
     mousey=RESULT
@endnode

@node "RX_GETFGCOLOR" "ARexx: GETFGCOLOR"
@{b}GETFGCOLOR@{ub}

Function:
     Obtains the current foreground pen value.

Syntax:
     GETFBCOLOR

Result:
     The current primary (foreground) pen.
@endnode

@node "RX_GETPIXEL" "ARexx: GETPIXEL"
@{b}GETPIXEL@{ub}

Function:
     Get the color value at a specified coordinate.

Syntax:
     GETPIXEL <xcoord> <ycoord>

Template:
     X/N/A,Y/N/A

Result:
     The value at the specified coordinate.

Notes:
     No checking is done to see if this is a legal coordinate.  0 will be returned if it outside the buffer area.
@endnode

@node "RX_GETSCREENDEPTH" "ARexx: GETSCREENDEPTH"
@{b}GETSCREENDEPTH@{ub}

Function:
     Returns the number of bitplanes of the screen Iconian is running on.

Syntax:
     GETSCREENDEPTH

Result:
     The actual number of bitplanes of the screen Iconian is running on.
@endnode

@node "RX_HIGHLIGHT" "ARexx: HIGHLIGHT"
@{b}HIGHLIGHT@{ub}

Function:
     Changes the highlight method of an icon.

Syntax:
     HIGHLIGHT "COMPLEMENT" | "BACKFILL" | "IMAGE"

Template:
     C=COMPLEMENT/S,B=BACKFILL/S,I=IMAGE/S
@endnode

@node "RX_ICONTYPE" "ARexx: ICONTYPE"
@{b}ICONTYPE@{ub}

Function:
     Changes the icon type of an icon.

Syntax:
     ICONTYPE <type> | "PROJECT" | "TOOL" | "DRAWER"

Template:
     TYPE/N,PROJECT/S,TOOL/S,DRAWER/S

Options:
     TYPE <type>
       Where type is one of the following:
         1. Disk
         2. Drawer
         3. Tool
         4. Project
         5. Trashcan
         6. Device
         7. Kickstart
         8. AppIcon
@endnode

@node "RX_LEFTMOUSE" "ARexx: LEFTMOUSE"
@{b}LEFTMOUSE@{ub}

Function:
     Controls the left mouse button state.

Syntax:
     LEFTMOUSE "UP" | "DOWN" | "CLICK"

Template:
     UP/S,DOWN/S,CLICK/S

Options:
     "UP"
       Acts as if the user has released the left button.

     "DOWN"
       Acts as if the user has pressed the left button.

     "CLICK"
       Acts as if the user has clicked the mouse button rapidly.

Notes:
     The command, like all the other mouse commands, only activates drawing states and methods.  Other mouse functions like gadgets, windows, and menus are not affected by these commands.

     Attempting to start drawing while the macro-cursor position is outside the drawing area will fail.  To ensure that a click or mouse down command will take affect, use the GETBUFFERSIZE commands.  Check the desired position against 0,0 and width-1,height-1.
@endnode

@node "RX_LOADDATATYPE" "ARexx: LOADDATATYPE"
@{b}LOADDATATYPE@{ub}

Function:
     Begins the datatype loading procedure.

Syntax:
     LOADDATATYPE file ("FILLCMAP")

Template:
     FILE/A,FILLCMAP/S

Options:
     FILE file
       Specifies the picture to load.

     FILLCMAP "FILLCMAP"
       This switch will load the colormap associated with the picture.

Example:
     /*Load a picture into the buffer, using current DT settings.*/
     LOADDATATYPE picture.gif FILLCMAP
@endnode

@node "RX_LOCKGUI" "ARexx: LOCKGUI"
@{b}LOCKGUI@{ub}

Function:
     Disables user input into Iconian.

Syntax:
     LOCKGUI ("FASTDRAW")

Template:
     FASTDRAW/S

Options:
     FASTDRAW "FASTDRAW"
       This switch disables all visual updates.  Once an UNLOCKGUI is issued, all visual information is updated.  This reduces the overhead of long scripts.
@endnode
@node "RX_MARKASSTANDARD" "ARexx: MARKASSTANDARD"
@{b}MARKASSTANDARD@{ub}

Function:
     Marks the current project as the NewIcon standard image.

Syntax:
     MARKASSTANDARD
@endnode
@node "RX_MATTE" "ARexx: MATTE"
@{b}MATTE@{ub}

Function:
     Selects the "matte" brush drawing mode.

Syntax:
     MATTE
@endnode
@node "RX_MOVETO" "ARexx: MOVETO"
@{b}MOVETO@{ub}

Function:
     Specifies the script mouse position, for use with LEFTMOUSE/RIGHTMOUSE.

Syntax:
     MOVETO <xcoord> <ycoord>

Template:
     X/N/A,Y/N/A
@endnode
@node "RX_OPEN" "ARexx: OPEN"
@{b}OPEN@{ub}

Function:
     Loads an icon, with option of opening a new project window.

Syntax:
     OPEN file ("NEW") | "NEW"

Template:
     FILE,NEW/S

Result:
     The number of the new window, but only if the "NEW" keyword is used.

Options:
     NEW "NEW"
       A new window will be opened to accept the icon file.
@endnode

@node "RX_PASTE" "ARexx: PASTE"
@{b}PASTE@{ub}

Function:
     Pastes from the clipboard, if an image is present.  Also will copy from the other project buffer.

Syntax:
     PASTE ("OTHER")

Template:
     OTHER/S

Options:
     OTHER "OTHER"
       Unrelated to the clipboard.  Instead, the image from the other buffer, from the same project, will be copied into the current buffer.
@endnode

@node "RX_PLOT" "ARexx: PLOT"
@{b}PLOT@{ub}

Function:
     Sets a pixel at a specified location.

Syntax:
     PLOT <x> <y>

Template:
     X/N/A,Y/N/A
@endnode

@node "RX_QUIT" "ARexx: QUIT"
@{b}QUIT@{ub}

Function:
     Closes the Iconian program.

Syntax:
     QUIT ("FORCE")

Template:
     FORCE/S

Options:
     FORCE "FORCE"
       Ignores any unsaved, modified projects.
@endnode
@node "RX_REDO" "ARexx: REDO"
@{b}REDO@{ub}

Function:
     Redoes an operation, if available.

Syntax:
     REDO
@endnode

@node "RX_REPLACE" "ARexx: REPLACE"
@{b}REPLACE@{ub}

Function:
     Selects the "replace" brush drawing mode.

Syntax:
     REPLACE
@endnode

@node "RX_RESTORE" "ARexx: RESTORE"
@{b}RESTORE@{ub}

Function:
     Restores an icon to it's original, last saved state.

Syntax:
     RESTORE ("FORCE")

Template:
     FORCE/S

Options:
     FORCE "FORCE"
       Ignores any unsaved, modified projects.
@endnode

@node "RX_RIGHTMOUSE" "ARexx: RIGHTMOUSE"
@{b}RIGHTMOUSE@{ub}

Function:
     Controls the right mouse button state.

Syntax:
     RIGHTMOUSE "UP" | "DOWN" | "CLICK"

Template:
     UP/S,DOWN/S,CLICK/S

Options:
     "UP"
       Acts as if the user has released the right button.

     "DOWN"
       Acts as if the user has pressed the right button.

     "CLICK"
       Acts as if the user has clicked the mouse button rapidly.

Notes:
     The command, like all the other mouse commands, only activates drawing states and methods.  Other mouse functions like gadgets, windows, and menus are not affected by these commands.

     Attempting to start drawing while the macro-cursor position is outside the drawing area will fail.  To ensure that a click or mouse down command will take affect, use the GETBUFFERSIZE commands.  Check the desired position against 0,0 and width-1,height-1.
@endnode

@node "RX_RUBTHRU" "ARexx: RUBTHRU"
@{b}RUBTHRU@{ub}

Function:
     Selects the "rubthru" brush drawing mode.

Syntax:
     RUBTHRU
@endnode

@node "RX_SAVE" "ARexx: SAVE"
@{b}SAVE@{ub}

Function:
     Saves an icon to disk.

Syntax:
     SAVE (file) ("NEWICON")

Template:
     FILE,NEWICON/S

Options:
     file "FILE"
       A new name to save under.  Otherwise the original name is used.

     NEWICON "NEWICON"
       Saves the icon in NewIcon format.
@endnode

@node "RX_SCREENTOFRONT" "ARexx: SCREENTOFRONT"
@{b}SCREENTOFRONT@{ub}

Function:
     Brings Iconian's screen to the front position.

Syntax:
     SCREENTOFRONT
@endnode

@node "RX_SETFGCOLOR" "ARexx: SETFGCOLOR"
@{b}SETFGCOLOR@{ub}

Function:
     Sets the color of the primary (foreground) pen.

Syntax:
     SETFGCOLOR <pennumber>

Template:
     PENNUM/N/A

Options:
     PENNUM <pennumber>
       The new pen register to use for primary drawing.
@endnode

@node "RX_SETBGCOLOR" "ARexx: SETBGCOLOR"
@{b}SETBGCOLOR@{ub}

Function:
     Sets the color of the secondary (background) pen.

Syntax:
     SETBGCOLOR <pennumber>

Template:
     PENNUM/N/A

Options:
     PENNUM <pennumber>
       The new pen register to use for secondary drawing.
@endnode

@node "RX_SMOOTH" "ARexx: SMOOTH"
@{b}SMOOTH@{ub}

Function:
     Selects the "smooth" brush drawing mode.

Syntax:
     SMOOTH
@endnode
