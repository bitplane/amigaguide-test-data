@node "MENU#00A8" "Menu Item:Air Brush"
 Menu: @{fg shine}Paint@{fg text}
 Item: @{fg shine}Air Brush@{fg text}

 Subs: @{fg shine}Small@{fg text}
       @{fg shine}Medium@{fg text}
       @{fg shine}Large@{fg text}

