 Acts like a spray paint can.
@endnode

@node "MENU#00AE" "Menu Item:Dither"
 Menu: @{fg shine}Paint@{fg text}
 Item: @{fg shine}Dither@{fg text}

 Subs: @{fg shine}None@{fg text}
       @{fg shine}94%@{fg text}
       @{fg shine}88%@{fg text}
       @{fg shine}75%@{fg text}
       @{fg shine}63%@{fg text}
       @{fg shine}50%@{fg text}
       @{fg shine}38%@{fg text}
