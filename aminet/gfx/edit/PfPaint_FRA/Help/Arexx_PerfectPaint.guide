@NODE "ExDialog" "Exemple de dialogue"

/**/

    options results
    parse ARG Port b
    
    ADDRESS value Port

  /* Initialisation d'une boite de dialogue comprenant 2 Gadget */
    pp_DialogInit 320 200 "*ESSAI*" 2

  /* Initialisation du gadget slider
      pp_Slider 0 100 5 100 16 "Slider" 1 10 200 50

  /* Initialisation du gadget Cycle */    
      pp_Cycle 1 100 25 100 16 "Cycle" 1 "1|2|3|4|5|6" 2

  /* Affichage de la boite de dialogue */
    pp_Dialog

    rc=result
    if rc=0 then        /* le gadget 'Cancel' a été selectionné, on */
      do                /* quitte le programme */
        EXIT
      end    
    
    pp_GetDialog 0      /* on récupčre les contenu du gadget 0 */
    S=result

    pp_GetDialog 1      /* on récupčre les contenu du gadget 1 */
    C=result


/* ...... */

@ENDNODE
