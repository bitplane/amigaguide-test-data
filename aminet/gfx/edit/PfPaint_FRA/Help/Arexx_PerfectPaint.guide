@{" Gradient exemple       " link GradientEx}

@ENDNODE

@NODE "GradientEx" "Gradient exemple"

    pp_EffectOn
    /* Active le mode effet */

    pp_Gradient 0 2 100 100
    /* Active l'effet Gradient
       range=0
       Type=2 (Radian sun)
       100, 100: centre du soleil */

    pp_ClearRange 0
    /* Efface le Range=0 */

    pp_setRange 0 4 0 0 0
    /* remplie le range 0 avec ā la position 4
       la couleur RGB=(0,0,0) */

    pp_setRange 0 19 255 255 255
    /* remplie le range 0 avec ā la position 19
       la couleur RGB=(255,255,255) */

    pp_CircleF 100 100 100
    /* Dessine un cercle */
    

@ENDNODE

