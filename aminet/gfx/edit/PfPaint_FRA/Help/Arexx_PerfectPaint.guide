@NODE "Minimum" "Minimum"

    pp_Minimum Taille

  Taille: Taille de la Brosse

	Active L'effet Minimum

@ENDNODE

@NODE "Median" "Median"

    pp_Median Taille

  Taille: Taille de la Brosse 1-4
	
	Active L'effet Median

@ENDNODE

@NODE "PolarC" "PolarC"

    pp_PolarC

	Active L'effet Coordonnées polaires

@ENDNODE

@NODE "Progresstext" "Progresstext"

    pp_Progresstext text$

	Affiche le texte text$ dans l'indicateur de progression

@ENDNODE

@NODE "Progress" "Progress"

    pp_Progress Current Max
 
  Current: Le nombre en cours
  Max: nombre total

	Affiche une bar de progression

@ENDNODE

@NODE "Progressclr" "Progressclr"

    pp_Progressclr

  Initialise la bar de progression
 

@ENDNODE

@NODE "lockPfPaint" "LockPfPaint"

    pp_LockPfPaint

  Bloque la boite a outils  
 
@ENDNODE

@NODE "UlockPfPaint" "UlockPfPaint"

    pp_UlockPfPaint

  Libčre la boite ā outils
 

@ENDNODE

@NODE "ScreentoFront" "ScreenToFront"

    pp_ScreenToFront Nom$

    Nom$: Nom de l'écran qui doit etre placé en
          premier plan.

@ENDNODE

@NODE "PlaceGui" "PaceGui"

    pp_PlaceGui Title$
    Title$: Titre de la fenetre

    Ouvre une fenetre, et permet a
    l'utilisateur de choisir une position.
    ( comme la fenetre qui s'ouvre lorsque l'on
    selectionne le fonction 'inserer image')

    Retourne la position selectionnée.
      -----------------
      |  00 | 10 | 20 |
      -----------------
      |  03 | 13 | 23 |
      -----------------
      |  06 | 16 | 26 |
      -----------------
    ou -1 si l'utilisateur a annulé la demande.

@ENDNODE

@NODE "Convert2RGB" "Convert2RGB"

    pp_Convert2RGB
    
    Convertit l'image en cours en 24Bits.

@ENDNODE

@NODE "ScalePicture" "ScalePicture"

    pp_ScalePicture NewWidth NewHeight
    
    Vous permet de changer la taille de l'image en cours.

@ENDNODE

@NODE "GetLocale" "GetLocale"

    pp_GetLocale Nb

    Nb: Numero de la variable texte.
        Retourne le texte localisé.
        Voir PerfectPaint.cd.
    
@ENDNODE

@NODE "ClosestColorL" "ClosestColorL"

    pp_ClosestColorL couleur Brightness

    Couleur: numero de la couleur
    Darkness: pourcentage de luminosité (0-100%)

    Retourne le numéro de couleur de la palette en cours dont
		la luminosité est la plus proche.

@ENDNODE

@NODE "RemapBrush" "pp_RemapBrush"

	pp_RemapBrush
	Reconstruit la brosse en cours avec la palette en cours.

@ENDNODE

@NODE "SetRGBcolor" "pp_SetRGBcolor"

	pp_SetRGBcolor C R G B
	Change la valeur RGB de la couleur numero C dans la palette en cours.

@ENDNODE


@NODE "PickColor" "pp_PickColor"

	pp_PickColor x y
	Capture la valeur RGB du point a la position x,y

	@{B}pp_GetPickRed@{UB}
		Retourne la valeur rouge

	@{B}pp_GetPickGreen@{UB}
		Retourne la valeur Verte		

	@{B}pp_GetPickBlue@{UB}
		Retourne la valeur Bleu

@ENDNODE
	
@NODE "AddFrames" "pp_AddFrames"

	pp_AddFrames N
	Ajoutera N images dans l'animation en cours a la position courante.
	Retourne 0 si c'est un succés.

@ENDNODE

@NODE "TextGui" "pp_TextGui"

	pp_TextGui
	Affichera le requester de fonte de PfPaint.

@ENDNODE



