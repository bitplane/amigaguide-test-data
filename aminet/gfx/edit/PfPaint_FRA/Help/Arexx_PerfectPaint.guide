@ENDNODE
@NODE "extexte" "Construction d'une brosse texte (exemple)"

/* exemple */

.......

   pp_TextAntialiasing 2
     /* antialiasing de niveau 2 */
     /* si vous omettez cette commande, le parametre en cours sera utilisé */

   pp_TextEffect 1 2
     /* L'effet Outline est utlisé avec une amplitude de 2 */
     /* si vous omettez cette commande, le parametre en cours sera utilisé */

   pp_TextFontName 'CGTimes.font'
     /* si vous omettez cette commande, le parametre en cours sera utilisé */

   pp_TextSize 50
     /* si vous omettez cette commande, le parametre en cours sera utilisé */

   pp_TextStyle 0
     /* Pas de Style */
     /* si vous omettez cette commande, le parametre en cours sera utilisé */

   pp_TextMake 'Bonjour*tout*le*monde'
     /* Construction de la brosse texte avec la phrase 'Bonjour tout le monde' */
     /* avec pp_TextMake "", le texte en cours sera utilisé */
   
   pp_TextDraw 100 100
     /* Dessine la brosse texte aux coorconnées 100,100 */
   
.......


@ENDNODE
