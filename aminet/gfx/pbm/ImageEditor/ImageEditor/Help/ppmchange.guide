@DATABASE "ppmchange.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: ColorChange [ppmchange]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}ColorChange@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Change all pixels of one color to another in a portable pixmap.@{UB}@{LINE}
@{PAR}Reads a portable pixmap as input. Changes all pixels of oldcolor to newcolor,
leaving all others unchanged. Up to 4 colors may be replaced by specifying couples of colors.@{LINE}
@{PAR}See also @{" GreyToColor " LINK "pgmtoppm.guide/MAIN"}.@{LINE}
