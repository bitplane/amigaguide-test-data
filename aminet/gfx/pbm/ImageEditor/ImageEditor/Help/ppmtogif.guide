@DATABASE "ppmtogif.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Saver: GIF [ppmtogif]"
@TOC "Saver.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}GIF@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Convert a portable pixmap into a GIF file.@{UB}@{LINE}
@{PAR}Reads a portable pixmap as input. Produces a GIF file as output.@{LINE}
@{LINDENT 8}@{LINE}
@{B}Transparent Color@{UB}@{LINE}
@{LINDENT 12}
    Mark the given color as transparent in the GIF file.
Note that this option outputs a GIF89a format file.@{LINE}
@{LINDENT 8}@{LINE}
@{B}Use Colormap@{UB}@{LINE}
@{LINDENT 12}
    Uses the colors found in the mapfile to create the colormap in the GIF file,
instead of the colors from ppmfile. The mapfile can be any ppm file;
all that matters is the colors in it. If the colors in ppmfile
do not match those in mapfile, they are matched to a "best match".@{LINE}
@{LINDENT 4}
@{PAR}See also the @{" GIF " LINK "giftopnm.guide/MAIN"} loader.@{LINE}
@{PAR}[@{B}ppmtogif@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1989 by Jef Poskanzer @{UI}@{FG TEXT}@{LINE}

@ENDNODE
