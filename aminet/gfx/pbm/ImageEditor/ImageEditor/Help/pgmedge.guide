@DATABASE "pgmedge.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: GreyRelief [pgmedge]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}GreyRelief@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Edge-detect a portable graymap.@{UB}@{LINE}
@{PAR}Reads a portable graymap as input.
Outlines the edges, and writes a portable graymap as output.@{LINE}
@{PAR}The edge detection technique used is to take the Pythagorean sum of two Sobel gradient operators at 90 degrees to each other.@{LINE}
@{PAR}See also @{" ColorRelief " LINK "ppmrelief.guide/MAIN"}.@{LINE}
