@DATABASE "ppmmix.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: ColorMixer [ppmmix]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}ColorMixer@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Blend together two portable pixmaps.@{UB}@{LINE}
@{PAR}Reads two portable pixmaps as input. Mixes them together using the specified fade factor.
The fade factor may be in the range from 0% (only Backgrnd Image data) to 100% (only WorkFile Image data).
Anything in between gains a smooth blend between the two images.@{LINE}
@{PAR}The two pixmaps must have the same size and format.@{LINE}
@{PAR}See also @{" Compose " LINK "pnmcomp.guide/MAIN"}.@{LINE}
@{PAR}[@{B}ppmmix@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1993 by Frank Neumann @{UI}@{FG TEXT}@{LINE}

@ENDNODE
