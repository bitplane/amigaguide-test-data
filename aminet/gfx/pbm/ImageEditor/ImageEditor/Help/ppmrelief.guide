@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: ColorRelief [ppmrelief]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}ColorRelief@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Run a Laplacian relief filter on a portable pixmap.@{UB}@{LINE}
@{PAR}Reads a portable pixmap as input. Does a Laplacian relief filter, and writes a portable pixmap as output.@{LINE}
@{PAR}The Laplacian relief filter is a sort of edge-detection.@{LINE}
@{PAR}See also @{" GreyRelief " LINK "pgmedge.guide/MAIN"}.@{LINE}
