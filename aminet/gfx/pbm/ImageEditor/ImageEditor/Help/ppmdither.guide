@DATABASE "ppmdither.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: ColorDither [ppmdither]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}ColorDither@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Ordered dither for color images.@{UB}@{LINE}
@{PAR}Reads a portable pixmap as input, and applies dithering to it to reduce the number of colors used down to the specified number of shades for each primary.@{LINE}
@{PAR}The default number of shades is RED 5, GREEN 9, BLUE 5, for a total of 225 colors.
The size of the dithering matrix must be a power of 2.@{LINE}
@{PAR}To convert the image to a binary rgb format suitable for color printers, use RED 2, GREEN 2, BLUE 2.
The maximum number of colors that can be used is 256 and will be computed as the product of the number of RED, GREEN and blue SHADES.@{LINE}
@{PAR}See also @{" ColorReduce " LINK "ppmquant.guide/MAIN"} and @{" Depth " LINK "pnmdepth.guide/MAIN"}.@{LINE}
@{PAR}[@{B}ppmdither@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1991 by Christos Zoulas @{UI}@{FG TEXT}@{LINE}

@ENDNODE
