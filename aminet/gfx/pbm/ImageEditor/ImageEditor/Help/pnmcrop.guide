@DATABASE "pnmcrop.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Operator: Crop [pnmcrop]"
@TOC "Operator.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}Crop@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Crop a portable anymap.@{UB}@{LINE}
@{PAR}Reads a portable anymap as input. Removes edges that are the background color,
and produces a portable anymap as output.@{LINE}
@{PAR}By default, it makes a guess as to what the background color is.
You can override the default with white or black.
The options left, right, top and bottom restrict cropping to the sides specified.@{LINE}
@{PAR}See also @{" Pad " LINK "pnmpad.guide/MAIN"} and @{" Cut " LINK "pnmcut.guide/MAIN"}.@{LINE}
@{PAR}[@{B}pnmcrop@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1989 by Jef Poskanzer @{UI}@{FG TEXT}@{LINE}

@ENDNODE
