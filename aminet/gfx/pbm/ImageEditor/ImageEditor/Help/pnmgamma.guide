@DATABASE "pnmgamma.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Operator: Gamma [pnmgamma]"
@TOC "Operator.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}Gamma@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Perform gamma correction on a portable anymap.@{UB}@{LINE}
@{PAR}Reads a portable anymap as input. Performs gamma correction, and produces a portable anymap as output.@{LINE}
@{PAR}The arguments specify what gamma value(s) to use. A value of 0 leaves the image alone,
less than one darkens it, and greater than one lightens it.@{LINE}
@{PAR}[@{B}pnmgamma@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1991 by Jef Poskanzer @{UI}@{FG TEXT}@{LINE}

@ENDNODE
