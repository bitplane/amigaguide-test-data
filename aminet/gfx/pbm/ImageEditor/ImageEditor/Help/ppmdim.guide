@DATABASE "ppmdim.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: ColorToDark [ppmdim]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}ColorToDark@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Dim a portable pixmap down to total blackness.@{UB}@{LINE}
@{PAR}Reads a portable pixmap as input. Diminishes its brightness by the specified percentage down to total blackness.
100% equals total blackness and 0% equals original picture's brightness.@{LINE}
@{PAR}ColorToDark is similar to the  @{" ColorSaturation " LINK "ppmbrighten.guide/MAIN"} converter.
See also @{" ColorToLight " LINK "ppmflash.guide/MAIN"} and @{" Gamma " LINK "pnmgamma.guide/MAIN"}.@{LINE}
@{PAR}[@{B}ppmdim@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1993 by Frank Neumann @{UI}@{FG TEXT}@{LINE}

@ENDNODE
