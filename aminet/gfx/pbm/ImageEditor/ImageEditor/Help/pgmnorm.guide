@DATABASE "pgmnorm.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: GreyContrast [pgmnorm]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}GreyContrast@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Normalize the contrast in a portable graymap.@{UB}@{LINE}
@{PAR}Reads a portable graymap as input. Normalizes the contrast by forcing the lightest pixels to white,
the darkest pixels to black, and linearly rescaling the ones in between;
and produces a portable graymap as output.@{LINE}
@{PAR}By default, the darkest 2 percent of all pixels are mapped to black,
and the lightest 1 percent are mapped to white. You can override these percentages.
If you want to lighten the image, then set blackness to 0 and just fiddle with whiteness;
similarly, to darken the image, set whiteness to 0 and play with blackness.@{LINE}
@{PAR}See also @{" ColorContrast " LINK "ppmnorm.guide/MAIN"}.@{LINE}
@{PAR}[@{B}pgmnorm@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1989 by Jef Poskanzer. @{UI}@{FG TEXT}@{LINE}

@ENDNODE
