@DATABASE "ppmflash.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Converter: ColorToLight [ppmflash]"
@TOC "Converter.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}ColorToLight@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Brighten a picture up to complete whiteness.@{UB}@{LINE}
@{PAR}Reads a portable pixmap as input. Increases its brightness by the specified percentage up to total whiteness.
100% equals total whiteness and 0% equals original picture's brightness.@{LINE}
@{PAR}ColorToLight is similar to the  @{" ColorSaturation " LINK "ppmbrighten.guide/MAIN"} converter.
See also @{" ColorToDark " LINK "ppmdim.guide/MAIN"} and @{" Gamma " LINK "pnmgamma.guide/MAIN"}.@{LINE}
@{PAR}[@{B}ppmflash@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1993 by Frank Neumann @{UI}@{FG TEXT}@{LINE}

@ENDNODE
