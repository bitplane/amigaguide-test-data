@DATABASE "pnmenlarge.guide"
@INDEX "ImageEditor.guide/INDEX"
@FONT helvetica.font 13
@SMARTWRAP

@NODE MAIN "ImageEditor - Operator: Enlarge [pnmenlarge]"
@TOC "Operator.guide/MAIN"

@{LINDENT 4}
@{PAR}@{FG HIGHLIGHT}@{B}Enlarge@{UB}@{FG TEXT}@{LINE}
@{PAR}@{B}Read a portable anymap and enlarge it N times.@{UB}@{LINE}
@{PAR}Reads a portable anymap as input. Replicates its pixels N times, and produces a portable anymap as output.
It can only enlarge by integer factors. The slower but more general @{" Scale " LINK "pnmscale.guide/MAIN"} can enlarge or reduce by arbitrary factors.@{LINE}
@{PAR}If you enlarge by a factor of 3 or more, you should probably add a smooth step; otherwise, you can see the original pixels in the resulting image.@{LINE}
@{PAR}See also @{" Scale " LINK "pnmscale.guide/MAIN"}.@{LINE}
@{PAR}[@{B}pnmenlarge@{UB}] @{FG HIGHLIGHT}@{I}Copyright (C) 1989 by Jef Poskanzer @{UI}@{FG TEXT}@{LINE}

@ENDNODE
