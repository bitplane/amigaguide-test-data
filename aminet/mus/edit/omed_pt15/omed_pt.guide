@node "ctrl" "CTRL"
@next "lshift"
@prev "cuts"


  @{b}@{bg fill} CTRL F1 @{ub}@{bg back}          Kill cmds to end of track.
  @{b}@{bg fill} CTRL F2 @{ub}@{bg back}          Kill cmds to start of track.

                     @{b}@{u}@{fg shine}NOTE:@{ub}@{uu}@{fg text} The latter two actually 
                     @{i}@{u}cut@{ui}@{uu} the range. This might affect 
                     the buffer; although it is not likely.

  @{b}@{bg fill} CTRL F3 @{ub}@{bg back}          Cut cmds
  @{b}@{bg fill} CTRL F4 @{ub}@{bg back}          Copy cmds
  @{b}@{bg fill} CTRL F5 @{ub}@{bg back}          Paste cmds

  @{b}@{bg fill} CTRL F6-F10 @{ub}@{bg back}      Play song from F-key line.

  @{b}@{bg fill} CTRL RETURN @{ub}@{bg back}      Push following cmds down and insert a clear
                     cmd at cursor position. Doing this at the
                     last line will jump the cursor to the first.

  @{b}@{bg fill} CTRL BACKSPACE @{ub}@{bg back}   Drag following cmds up and kill cmd above
                     cursor. Doing this at line 00 will jump the
                     cursor to the last line.

  @{b}@{bg fill} CTRL LALT RETURN/ @{ub}@{bg back}Pushes/pulls ONLY the notes.
  @{b}@{bg fill} BACKSPACE @{ub}@{bg back}

  @{b}@{bg fill} CTRL CRSR L/R @{ub}@{bg back}    Samplenumber down/up.

  @{b}@{bg fill} CTRL NumPad @{ub}@{bg back}      Gives you the next 16 samples. 
                     The first 16 you can access via the @{"NumPad" link "others" 39}.
                     All samples are accessable by CTRL CRSR L/R.

  @{b}@{bg fill} CTRL RALT @{ub}@{bg back}        Continue song.

  @{b}@{bg fill} CTRL RAMIGA @{ub}@{bg back}      Continue block.

  @{b}@{bg fill} CTRL LALT S @{ub}@{bg back}      Search backward.@{" See LALT S." link "lalt" 25}

  @{b}@{bg fill} CTRL A @{ub}@{bg back}           Toggles current channel on/off.

  @{b}@{bg fill} CTRL LSHIFT A @{ub}@{bg back}    Turns current channel on and all others off.

  @{b}@{bg fill} CTRL LALT A @{ub}@{bg back}      Turns all channels on. That's the same PT
                     used CTRL Q for. Never knew why 'Q' (like
                     "'Q'unmute channels"?!), so kicked that
                     one. Take care, CTRL Q has a new function
                     now ('Q'uit range! :).

  @{b}@{bg fill} CTRL B @{ub}@{bg back}           Select range. Move the cursors up and down
                     whilst pressing LSHIFT to mark your range.
                     Use the F-Keys to jump to predefined
                     postions.

  @{b}@{bg fill} CTRL C @{ub}@{bg back}           Copy range to buffer.

                     @{b}@{u}@{fg shine}NOTE:@{ub}@{uu}@{fg text} @{b}@{bg fill} CTRL LSHIFT C @{ub}@{bg back} is not an extra cut
                     because the insert/paste cmds simply 
                     extract the cmds from the buffer.

  @{b}@{bg fill} CTRL D @{ub}@{bg back}           Delete range, drag following notes up.

  @{b}@{bg fill} CTRL LSHIFT D @{ub}@{bg back}    Delete ranged cmds, drag following up.

  @{b}@{bg fill} CTRL E @{ub}@{bg back}           Expand track. Inserts a blank note every
                     second line starting with the one under
                     current position.
   
       @{b}@{u}@{fg shine}NOTE:@{ub}@{uu}@{fg text}         Has nothing to do with the BLOCKEXPAND. This
                     is completely different.

  @{b}@{bg fill} CTRL H @{ub}@{bg back}           Transpose @{u}ranged@{uu} notes one half note up.

  @{b}@{bg fill} CTRL I @{ub}@{bg back}           Insert buffer at cursor, push following notes
                     down.

                     @{b}@{i}@{u}@{fg shine}WARNING!@{ub}@{ui}@{uu}@{fg text} Notes pushed beyond last line will
                     be lost!

  @{b}@{bg fill} CTRL LSHIFT I @{ub}@{bg back}    Insert cmds, push following down

  @{b}@{bg fill} CTRL L @{ub}@{bg back}           Transpose @{u}ranged@{uu} notes one half note down.

  @{b}@{bg fill} CTRL N @{ub}@{bg back}           Remark last range on current track.

  @{b}@{bg fill} CTRL O @{ub}@{bg back}           Shrink track. Deletes every second note,
                     starting with the one under current position.

  @{b}@{bg fill} CTRL P @{ub}@{bg back}           Paste buffer at cursor position.

                     @{b}@{i}@{u}@{fg shine}WARNING!@{ub}@{ui}@{uu}@{fg text} This @{i}OVERRIDES@{ui} the following notes
                     (as the word PASTE indicates)!

  @{b}@{bg fill} CTRL LSHIFT P @{ub}@{bg back}    Paste cmds.

  @{b}@{bg fill} CTRL Q @{ub}@{bg back}           Quit range.

  @{b}@{bg fill} CTRL R @{ub}@{bg back}           Restore F-Keys.

  @{b}@{bg fill} CTRL S @{ub}@{bg back}           Toggle spacing (see CTRL 1-9 and ambients).

  @{b}@{bg fill} CTRL LSHIFT S @{ub}@{bg back}    It takes the RANGE you have selected before
                     and uses it as the spacing mentioned in the
                     KeyBoardOptions Menu. To skip the range while
                     editing (=spacing) you turn on the SPACE
                     Gadget in the main control or hit CTRL S
                     respectively.

  @{b}@{bg fill} CTRL T @{ub}@{bg back}           Swap Tracks. You specify a track to change
                     the current track with via the requester.

  @{b}@{bg fill} CTRL V @{ub}@{bg back}           Toggle AdvanceVoice (KeyboardOptions Window).

  @{b}@{bg fill} CTRL X @{ub}@{bg back}           Cut range to buffer.

  @{b}@{bg fill} CTRL LSHIFT X @{ub}@{bg back}    Cut ranged cmds

  @{b}@{bg fill} CTRL 1-9 @{ub}@{bg back}         Sets spacing value to 1-9, according to PT,
                     and checks the keyboard option 'move down'.
                     To get values higher than 10 and use the
                     spacing see CTRL LSHIFT S.

  @{b}@{bg fill} CTRL LSHIFT 1-9 @{ub}@{bg back}  Sets spacing value to 1-9, according to PT,
                     and checks the keyboard option 'move up'.
                     To get values higher than 10 and use the
                     spacing see CTRL LSHIFT S.

  @{b}@{bg fill} CTRL 0 @{ub}@{bg back}           Checks keyboard option 'stay'.
@endnode

@node "lshift" "LSHIFT"
@next "lalt"
@prev "ctrl"


  @{b}@{bg fill} LSHIFT F1 @{ub}@{bg back}        Kill track to end.
  @{b}@{bg fill} LSHIFT F2 @{ub}@{bg back}        Kill track to start.
  @{b}@{bg fill} LSHIFT F3 @{ub}@{bg back}        Cut track
  @{b}@{bg fill} LSHIFT F4 @{ub}@{bg back}        Copy track
  @{b}@{bg fill} LSHIFT F5 @{ub}@{bg back}        Paste track

  @{b}@{bg fill} LSHIFT F6-F10 @{ub}@{bg back}    Define function key lines.

  @{b}@{bg fill} LSHIFT CRSR UP/DN @{ub}@{bg back}Mark range (after having pressed @{"CTRL B" link "ctrl" 43}).

  @{b}@{bg fill} LSHIFT CRSR L/R @{ub}@{bg back}  Sequence down/up.

  @{b}@{bg fill} LSHIFT RETURN @{ub}@{bg back}    Insert blank note and move following down.
                     Doing this at last line will jump the cursor
                     to the first line.

                     @{b}@{i}@{u}@{fg shine}WARNING!@{ub}@{ui}@{uu}@{fg text} Notes beyond last line will be
                     lost!!!

  @{b}@{bg fill} LSHIFT BACKSPACE @{ub}@{bg back} Delete note and CMD above and drag the
                     following up. Doing this at line 00 will jump
                     the cursor to the last line.

  @{b}@{bg fill} LSHIFT DEL @{ub}@{bg back}       Delete note and cmd.

       @{b}@{u}@{fg shine}NOTE:@{ub}@{uu}@{fg text}         When used with @{"SPACE ON" link "ctrl" 89} all delete functions
                     skip the spacerange (as PT did).
                     Also note that the '@{"destructive space" link "lalt" 17}' flag
                     won't be taken in account.

  @{b}@{bg fill} LSHIFT HELP @{ub}@{bg back}      Opens OMED_PT guide. Defaults to
                     SYS:Utilities/xpkguide octamed:omed_pt.guide.

  @{b}@{bg fill} LSHIFT TAB @{ub}@{bg back}       Move cursor to previous track.

  @{b}@{bg fill} LSHIFT S @{ub}@{bg back}         Search for a certain block in the playseqs.

  @{b}@{bg fill} LSHIFT 0-9 @{ub}@{bg back}       Store current cmd on selected key.
@endnode

@node "lalt" "LALT"
@next "others"
@prev "lshift"


  @{b}@{bg fill} LALT F1 @{ub}@{bg back}          Kill to end of block.
  @{b}@{bg fill} LALT F2 @{ub}@{bg back}          Kill to start of block.
  @{b}@{bg fill} LALT F3 @{ub}@{bg back}          Cut block to buffer
  @{b}@{bg fill} LALT F4 @{ub}@{bg back}          Copy block
  @{b}@{bg fill} LALT F5 @{ub}@{bg back}          Paste block

  @{b}@{bg fill} LALT F6-F10 @{ub}@{bg back}      Play block from F-key line.

  @{b}@{bg fill} LALT RETURN/ @{ub}@{bg back}     Pushes/pulls NOTES and CMDS in all visible
  @{b}@{bg fill} BACKSPACE @{ub}@{bg back}        tracks (PT-fashion).

  @{b}@{bg fill} LALT DEL @{ub}@{bg back}         Delete cmd only.

  @{b}@{bg fill} LALT CRSR L/R @{ub}@{bg back}    Blocknumber down/up.

  @{b}@{bg fill} LALT D @{ub}@{bg back}           Toggle Destructive Spacing
                     (Keyboard Options).

  @{b}@{bg fill} LALT K @{ub}@{bg back}           Delete current sample in current track.

  @{b}@{bg fill} LALT R @{ub}@{bg back}           Replace command. Opens/activates replace window.
                     See Search (LALT S).

  @{b}@{bg fill} LALT S @{ub}@{bg back}           Search forward. Opens/activates replace window.
                     If the note in the replace window is the one to
                     search for click YES. Else click NO and (reopen
                     the window and) insert the wanted note/cmd 
                     while pressing the LMB. Repeat procedure.
                     For how to insert a note manually see the main
                     manual.

  @{b}@{bg fill} LALT T @{ub}@{bg back}           Sets transpose options for out-of-range-notes.

  @{b}@{bg fill} LALT Y to , @{ub}@{bg back}      Toggle channels 0-7 separately

       @{b}@{u}@{fg shine}NOTE:@{ub}@{uu}@{fg text}         LALT Z is the same as LALT Y for American
                     keyboards.

  @{b}@{bg fill} LALT '\' @{ub}@{bg back}           Clone cmd from current line-1.
                     Key left from BACKSPACE.

  @{b}@{bg fill} LALT ` @{ub}@{bg back}           Clone cmd from current line-1 and add 1.
                     Key 2 left from BACKSPACE.
                     (American keyboard: '=')

  @{b}@{bg fill} LALT ß @{ub}@{bg back}           Clone cmd from current line-1 and substract
                     1. Key right from 0.
                     (American keyboard: '-')

  @{b}@{bg fill} LALT 0-9 @{ub}@{bg back}         Insert note in current track.

       @{b}@{u}@{fg shine}NOTE:@{ub}@{uu}@{fg text}         Be careful, this @{u}OVERRIDES@{uu} the NOTE as 
                     well as the former CMD!!! To keep the note you
                     open the programmable keys menu and make the 
                     note transparent by hitting return whilst
                     clicking it in that window.
                     A little complicated, but you'll manage it. :)
@endnode

@node "others" "OTHERS"
@next "cuts"
@prev "LALT"


  @{b}@{bg fill} F1-F5 @{ub}@{bg back}            Octave 01-05.

  @{b}@{bg fill} F6-F10 @{ub}@{bg back}           Go to lines 0/16/32/48/63 (by default).

  @{b}@{bg fill} DEL @{ub}@{bg back}              Delete note under cursor.

  @{b}@{bg fill} CRSR UP/DOWN @{ub}@{bg back}     Does both move the cursor normally around and
                     control the range.

  @{b}@{bg fill} CRSR LEFT/RIGHT @{ub}@{bg back}  Move it to the left/right position from
                     current.

  @{b}@{bg fill} LAMIGA RETURN @{ub}@{bg back}    Open/close Sampleeditor.

  @{b}@{bg fill} LAMIGA SPACE @{ub}@{bg back}     Activate Editor window.

  @{b}@{bg fill} HELP @{ub}@{bg back}             Opens default Guide.

  @{b}@{bg fill} ESCAPE @{ub}@{bg back}           Stop sound.

  @{b}@{bg fill} ` (above TAB) @{ub}@{bg back}    WB to front.

  @{b}@{bg fill} TAB @{ub}@{bg back}              Move cursor to next track.

  @{b}@{bg fill} SPACE @{ub}@{bg back}            Toggle Stop/Edit.

  @{b}@{bg fill} RAMIGA @{ub}@{bg back}           Play block.

  @{b}@{bg fill} RALT @{ub}@{bg back}             Play song.

       @{b}@{u}@{fg shine}NOTE:@{ub}@{uu}@{fg text}         This is @{fg shine}NOT@{fg text} identical with the PLAY SONG
                     gadget in the main control. On the contrary,
                     it starts playing with the current sequence
                     (PT-style again ;).

  @{b}@{bg fill} RSHIFT @{ub}@{bg back}           Record track.

  @{b}@{bg fill} NumPad 1st row @{ub}@{bg back}   Select samples 1-4
         @{b}@{bg fill} 2nd row @{ub}@{bg back}   Select samples 5-8
         @{b}@{bg fill} 3rd row @{ub}@{bg back}   Select samples 9-12
         @{b}@{bg fill} 4th row @{ub}@{bg back}   Select samples 13-16
         @{b}@{bg fill} 0 @{ub}@{bg back}         Select sample 17
                    @{" See also CTRL CRSR L/R." link "ctrl" 21} and
                    @{" CTRL NumPad " link "ctrl" 23}.
@endnode

