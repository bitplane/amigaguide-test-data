@node usage "SampleE - Uso"

@{B}@{U}Uso@{UB}@{UU}

   @{U}Ventana Principal@{UU}

   @{"Info-tamańo " link infowindow}
   @{"Info-tiempo " link infowindow}
   @{"Sample      " link samplewindow}
   @{"Stereo      " link stereowindow}
   @{"Zoom-Marcar " link toolwindow}
   @{"Audio       " link audiowindow}

   @{"Editar      " link editwindow}
   @{"Volumen     " link volumewindow}
   @{"Mover       " link shiftwindow}
   @{"Mezclar     " link mixwindow}
   @{"Eco         " link echowindow}
   @{"Frecuencia  " link frequenzwindow}

   @{"Proyecto    " link projectwindow}
   @{"Sobre       " link aboutwindow}

   @{"Usar        " link prefsuse}
   @{"Salvar      " link prefssave}

   Puede acceder de la ventana principal a las otras ventanas/opciones.
   Un doble-click en la opción deseada abre una nueva ventana con dicha
   opción, si ya está abierta la mueve al frente. Si está minimizada
   se abre al máximo.

   El gadget de cerrar la ventana principal cierra SampleE.


  PS. No soy bueno escribiendo documentos (N.T. lo mismo que el
      traductor :-( ), pero espero que sea fácil entender (N.T. y yo).
      Aunque el mejor método es el de "intentarlos por su cuenta",
      para entender las funciones y parámetros.

  ˇDiviértase con SampleE!
@endnode


@node prefssave "Salvar"
@{B}@{U}Salvar@{UB}@{UU}

  Se salva la configuración en: ENVARC:SampleE.prefs
@endnode


@node prefsuse "Usar"
@{B}@{U}Usar@{UB}@{UU}

  Se salva la configuración en: ENV:SampleE.prefs
  Después de un reset esta configuración se pierde.
@endnode



#########################################################################
#									#
#   Zoom-Marcar 							#
#									#
#########################################################################
@node toolwindow "Zoom-Marcar"
@{B}@{U}Zoom-Marcar@{UB}@{UU}

    Zoom     Marcar
 @{"   1:1   " link zoom}@{"  todo   " link mark}
 @{" ampliar " link zoom}@{"  área   " link mark}
 @{" reducir " link zoom}@{"         " link toolwindow}
 @{" marcar  " link zoom}@{" deshacer" link mark}
 @{"  todo   " link zoom}@{"@   l    " link sampledisplay}
@endnode


@node zoom "Zoom"
@{B}@{U}Zoom@{UB}@{UU}

  '   1:1   ': muestra el sample a una escala 1:1 (zoom máximo).
  ' ampliar ': muestra una parte más grande del sample.
  ' reducir ': muestra una parte más pequeńa del sample.
  ' marcar  ': muestra el area marcada.
  '  todo   ': muestra el sample completo.
@endnode


@node mark "Marcar"
@{B}@{U}Marcar@{UB}@{UU}

  '   todo  ': se marca el sample entero.
  '   área  ': se marca la parte visible del sample.
  ' deshacer': se anula el marcado.
@endnode


@node sampledisplay "Visualización del sample"
@{B}@{U}Visualización del sample@{UB}@{UU}

   Se puede ver el sample de las siguinets formas:

   'l': líneas.
   'p': puntos.
   's': sólido.
@endnode




#########################################################################
#									#
#   Editar								#
#									#
#########################################################################
@node editwindow "Editar"
@{B}@{U}Editar@{UB}@{UU}

   Búfer    Editor
 @{" smp>búf " link cbuf}@{" cortar  " link edit}
 @{" búf>smp " link cbuf}@{" copiar  " link edit}
 @{" limpiar " link cbuf}@{" limpiar " link edit}
 @{"M" link buffertype}        @{" borrar  " link edit}
	   @{" limpiar " link edit}
 @{"izq./dch." link reverse}@{"arr./aba." link inverse}
@endnode


@node cbuf "Funciones del Búfer"
@{B}@{U}Funciones del Búfer@{UB}@{UU}

  ' smp>búf ': copia el sample al búfer.
  ' búf>smp ': copia del búfer al sample.
  ' limpiar ': elimina los datos del búfer.
@endnode


@node buffertype "Búfer mono/stereo"
@{B}@{U}Búfer mono/stereo@{UB}@{UU}

   Una 'M' significa que el búfer contiene datos en mono.
   Una 'S' significa, lo ha adivinado, que el búfer está en stereo.
@endnode


@node edit "Editar"
@{B}@{U}Editar@{UB}@{UU}

  ' cortar  ': el área marcada del sample se corta al búfer.
  ' copiar  ': el área marcada del sample se copia al búfer.
  ' pegar   ': el contenido del búfer se inserta al principio
	       de la marca.
  ' borrar  ': el área marcada del sample se borra.
  ' limpiar ': el área marcada se pone a 0.
@endnode


@node reverse "invertir izq./dch."
@{B}@{U}invertir izq./dch.@{UB}@{UU}

  Se invierte de izquierda a derecha el área marcada.
@endnode


@node inverse "invertir arr./aba."
@{B}@{U}invertir arr./aba.@{UB}@{UU}

  Se invierte de arriba a abajo el área marcada.
@endnode




