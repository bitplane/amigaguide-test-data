  @{"                 |                " link shiftval}@{">" link shiftval}@{"    0" link shiftval}

  @{"  Haut   " link shiftmode} @{"   Bas   " link shiftmode} @{" Centrer " link shiftmode} @{"  Zéro   " link shiftmode}
