   | @{" Volume slider  " link voli}@{" New " link new}@{" Add " link add}@{" Del " link delete}@{" Prg " link prg}@{" M " link move}@{" S " link sort}@{" Pr " link prefsb} |
   |                                                    |
   | @{" F " link fsli} --------------------------------------------- |
   | @{" i " link fsli} |                                           | |
