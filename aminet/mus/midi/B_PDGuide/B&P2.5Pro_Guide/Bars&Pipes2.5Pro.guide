    use             nutzen

    variable        veränderlich, veränderbar
    very            sehr
    visual          sichtbar (auf dem Bildschirm)
    volume          Lautstärke

    way             Weg
    window          Fenster
    with            mit, an

    zoom in         vergrößern
    zoom out        verkleinern

@endnode
