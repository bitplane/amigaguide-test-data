    @{"FeedbLevl" link "FeedbLevl" 0}   Feedback Level
    @{"HpfCutoff" link "XGREVERBHPFLPFCUTOFF" 0}   High pass frequency cutoff
    @{"LpfCutoff" link "XGREVERBHPFLPFCUTOFF" 0}   Low pass frequency cutoff
