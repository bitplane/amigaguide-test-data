@NODE reco_crypto "* Format Heatseeker *"

 ********************************************************************
 * ------ ModËle d'en-tÍte du format << Heatseeker mc1.0 >> ------- *
 * ---------------------------------------------------------------- *
 * -- Provenance : DÈmo CRYPTOBURNERS "Party Time" (cool zoom !) -- *
 ********************************************************************

 000: 0CA2000C 00090C99 09CA0028 090100C9   Au dÈbut, les sample_data
 010: 08600008 02A005C0 38C4000F 38A8001C   (length, vol, repeat, replen)
 020: 02120020 00000001 0B5C001A 00000001   pour les 31 sons possibles...
 030: 0A9D001A 00000001 08CA0030 00000001
 040: 03EA0011 00000001 0FEF0013 00000001
 050: 12F0000A 000112EF 00000000 00000001   Il n'y a pas de caractËres
 060: 00000000 00000001 00000000 00000001   comme "M.K." permettant de
 070: 00000000 00000001 00000000 00000001   reconnaitre facilement ce type
 080: 00000000 00000001 00000000 00000001   de module, mais il faut juste
 090: 00000000 00000001 00000000 00000001   sauver comme indiquÈ ici,
 0A0: 00000000 00000001 00000000 00000001   ‡ partir de $000, o˘ commence
 0B0: 00000000 00000001 00000000 00000001   le header.
 0C0: 00000000 00000001 00000000 00000001   Quelques petits calculs 
 0D0: 00000000 00000001 00000000 00000001   ‡ faire donc pour retrouver 
 0E0: 00000000 00000001 00000000 00000001   le dÈbut...
 0F0: 00000000 00000001 1B7F0001 02030405   En $F8, le nombre de positions
 100: 06070809 0A0B0A0C 0D0E0F10 11121314   dans la zik, la constante $7F,
 110: 15161516 17000000 00000000 00000000   et le numÈro des
 120: 00000000 00000000 00000000 00000000   patterns jouÈs.
 130: 00000000 00000000 00000000 00000000
 140: 00000000 00000000 00000000 00000000
 150: 00000000 00000000 00000000 00000000
 160: 00000000 00000000 00000000 00000000
 170: 00000000 00000000 00000140 3C010000   En $17A, les patterns !
 180: 0C010000 0C020000 0C030000 0C040000   sous forme PROTRACK sauf...
 190: 0C050000 0C060000 0C070000 0C080000                    sauf...
 1A0: 0C090000 0C0A0000 0C0B0000 0C0C0000                 sauf que...
 1B0: 0C0D0000 0C0E0000 0C0F0000 0C0F0000
 1C0: 0C0F0000 0C0E0000 0C0E0000 0C0D0000
 1D0: 0C0D0000 0C0C0000 0C0C0000 0C0B0000
 1E0: 0C0B0000 0C0A0000 0C0A0000 0C090000
 1F0: 0C090000 0C080000 0C08021A 30000000
 200: 0C020000 0C030000 0C040000 0C050000
 210: 0C060000 0C070000 0C080000 0C090000
 220: 0C0A0000 0C0B0000 0C0C0000 0C0D0000
 230: 0C0E0000 0C0F0000 0C100000 0C110000
 240: 0C110000 0C120000 0C120000 0C130000
 250: 0C130000 0C140000 0C140000 0C150000
 260: 0C150000 0C160000 0C160000 0C170000
 270: 0C170000 0C180000 0C1801AC 1C038000   Ici par exemple, en $27e,
 280: 00020000 0C058000 00020000 0C068000   on trouve $8000 + une valeur
 290: 00020000 0C078000 0002021A 1C0A8000   Pour info, ca correspond au
 2A0: 000E0168 10008000 001E0000 0E000000   nombres de lignes vides
 2B0: 0C000000 0C000000 0C000000 0C000000   ‡ sauter...
 2C0: 0C000000 0C000000 0C000000 0C000000
 2D0: 0C000000 0C000000 0C000000 0C000000
 2E0: 0C000000 0C000000 0C000194 3C000000
 2F0: 0C010000 0C020000 0C030000 0C040000
@ENDNODE

