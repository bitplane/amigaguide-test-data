@DATABASE "resample.doc"

@NODE MAIN "resample.doc"


                             "Resample"/"Rs16":
      Change the size and sampling rate of digital audio by an integer
                   ratio (e. g. 1:2), but avoid aliasing.


@{" What does it do? " Link 1.}
@{" Who needs it? " Link 2.}
@{" The filters that we use " Link 3.}
@{" Command line arguments " Link 4.}
@{" Examples " Link 5.}
@{" The 16bit version " Link 6.}
@{" Bugs and Features " Link 7.}
