@node "DLPrint.rexx" "MegaD 3.1 ARexx Commands Copyright © 1993 John L. Jones"

DLPrint.rexx:
============

/* Automate printing labels for each disk inserted into drive DF0: */

address REXX

options results

address MEGAD
@{" dbug " link "dbug"}

do forever
	@{" diskin " link "diskin"}
	if result == "ABORT" then leave
	"@{" mark " link "mark"} df0:"
	@{" selectall " link "selectall"}
	@{" NextItem " link "NextItem"} Name /* will test for at lease one item on the disk to print label for */
	if result ~= "" then @{" label " link "label"}
	@{" freeVolumes " link "freeVolumes"}
end
@endnode





@node "MarkDemo.rexx" "MegaD 3.1 ARexx Commands Copyright © 1993 John L. Jones"

MarkDemo.rexx:
=============

/*  Mark Demo
	This file demonstrates the uses of 
	@{" Mark " link "Mark"}, @{" Dest " link "Dest"}, @{" Lock " link "Lock"}, @{" Child " link "Child"}, @{" Parent " link "Parent"}, 
	@{" SelectItem " link "SelectItem"} and @{" UnSelectItem " link "UnSelectItem"}.
	Outside of this, this program is pretty much useless
*/
options results

ADDRESS MEGAD
@{" dbug " link "dbug"} TRUE

/* open window to the Ram Disk: and Mark it */
	@{" Mark " link "Mark"} 'ram:' 
/* display actual name of opened directory */
	SAY result	
/* save name for later */
	rootname = result 
/* User select the Marked directory's 'Dest'ination gadget */
	@{" Dest " link "Dest"} TRUE		
/* Select the Marked directory's 'Lock' gadget */
	@{" Lock " link "Lock"} TRUE		
/* move to the subdirectory */
	@{" child " link "child"} t
/* display actual name */
	say result	
/* save name for later */
	childname = result	
/* Mark the child directory */
	@{" mark " link "mark"} "'"result"'"	
/* User select the Marked directory's 'Dest'ination gadget */
	@{" Dest " link "Dest"} TRUE
/* Select the Marked directory's 'Lock' gadget */
	@{" Lock " link "Lock"} TRUE
/* Move to the parent directory */
	@{" parent " link "parent"}
/* display actual name */
	say result	
/* Mark the Parent directory */
	@{" mark " link "mark"} "'"result"'"
/* Flash the T directory 40 times */
	DO 40				
		@{" SelectItem " link "SelectItem"} t
		@{" UnSelectItem " link "UnSelectItem"} t
		END
	@{" mark " link "mark"} "'"childname"'"
/* close the child */
	@{" CloseMark " link "CloseMark"}
	@{" mark " link "mark"} "'"rootname"'"
/* close the parent */
	@{" CloseMark " link "CloseMark"}

@endnode





@node "MDARexxStart.rexx" "MegaD 3.1 ARexx Commands Copyright © 1993 John L. Jones"

MDARexxStart.rexx:
=================

/*	MegaD will look for the MDARexxStart.rexx file in its home directory
	when it is first run. If it is found it will be executed.
	  
	This ARexx program will clear all of the internal strings to NULL.
*/
ADDRESS REXX

OPTION RESULT

ADDRESS MEGAD

@{" dbug " link "dbug"} TRUE

/* Send output to a console window on the MegaD Screen */
call close 'STDOUT'
call open 'STDOUT','con:0/12/640/100/MegaD RX/SCREEN MEGAD', 'W'

subscript = 0
DO 40
	SAY 'Clearing string 'subscript' to NULL'
	@{" SetString " link "SetString"} subscript NULL
	subscript = subscript + 1
	END


@endnode





@node "NextItem.rexx" "MegaD 3.1 ARexx Commands Copyright © 1993 John L. Jones"

NextItem.rexx:
=============

/* example of NextItem */

ADDRESS REXX
CALL CLOSE 'STDOUT'
CALL OPEN 'STDOUT','con:0/12/640/100/MegaD RX/SCREEN MEGAD', 'W'

OPTIONS RESULTS
OPTIONS FAILAT 20
SIGNAL ON FAILURE
	
ADDRESS MEGAD
@{" dbug " link "dbug"}

@{" CloseWindows " link "CloseWindows"}	/* close any open windows */
@{" Mark " link "Mark"} "Ram:" 	/* open the ram disk */
SAY RESULT
@{" SelectAll " link "SelectAll"}		/* select everything */

DO FOREVER
	@{" NextItem " link "NextItem"} Name
	IF RESULT = "" THEN LEAVE
	SAY RESULT
	@{" NextItem " link "NextItem"} Filename
	SAY RESULT
	@{" NextItem " link "NextItem"} Path
	SAY RESULT
	@{" NextItem " link "NextItem"} Size
	SAY RESULT
	@{" NextItem " link "NextItem"} Date
	SAY RESULT
	@{" NextItem " link "NextItem"} Comment
	IF RESULT ~= "" THEN SAY RESULT
	@{" NextItem " link "NextItem"} Type clear 	/* Clear the item */
	SAY RESULT
	END
EXIT

failure:
	IF RC ~= 0 THEN SAY "Script Failed, RC = " RC
	EXIT

@endnode





@node "OpenSE.rexx" "MegaD 3.1 ARexx Commands Copyright © 1993 John L. Jones"

OpenSE.rexx:
===========

/* Open file from Arguments */
/* this is an example of how to modify '@{" Parse.rexx " link "Parse.rexx"}' 
	to perform a more useful task, it will open files to the SAS/C editor.
	I call this from an ARexx Program Control. The Program Control has the
	following items checked.
	
	Skip selected directories
	Work without selected items
	Skip .info files
	Combine all selected on one line
	Workbench screen to front at start
	
*/

IF ~SHOW("L","rexxsupport.library") THEN CALL ADDLIB"rexxsupport.library",0,-30
OPTIONS RESULTS

/******************************************************************/
/* set specific for the program that we will use this script with */
/******************************************************************/
open_command = 'OW'
port_name = 'SC_SE'
program_name = '"SC:C/SE"'

arguments =  ARG(1)
/* if no arguments were sent test for the port and if it is 
	not available run the program without an argument */
if arguments = "" then do
	if ~show("P",port_name) then do
		ADDRESS COMMAND 'run ' || program_name
		END
	EXIT
	END
DO WHILE arguments ~= ""
	/* test for quote at first of name */
	/* if it starts with a Quote it ends with a Quote */
	delim = " " /* default to space as a delimiter */
	IF LEFT(arguments,1) = '"' THEN delim = '"'
	ELSE  arguments = " " || arguments /* add space to front */
	PARSE VAR arguments (delim) filename (delim) arguments
	filename = STRIP(filename)
	arguments = STRIP(arguments,L)
	if ~show("P",port_name) then do
		ADDRESS COMMAND 'run ' || program_name || ' ' || filename
		ADDRESS COMMAND 'WaitForPort ' || port_name
		END
	else do
		ADDRESS (port_name)
		open_command filename || d2c(13) /* return character require for SE */
		END
END

@endnode





@node "Parse.rexx" "MegaD 3.1 ARexx Commands Copyright © 1993 John L. Jones"

Parse.rexx:
==========

/* parse command line */
/* To use this with MegaD, add an ARexx Program Control that will call this
	Drag select a few files in an open directory window, select a ARexx button
	that will call this script.
	
	It will display each selected item in the console window that will open.
	The program has little value except for demonstrating how to parse
	information sent from MegaD.  See @{" OpenSE.rexx " link "OpenSE.rexx"} for 
	another example.
*/
 
/* open output to MegaD screen */
CALL CLOSE 'STDOUT'
CALL OPEN 'STDOUT','con:0/12/640/100/MegaD RX/SCREEN MEGAD', 'W'

arguments =  ARG(1)
/* test for quote at first of name */
DO WHILE arguments ~= ""
	
	/* if it starts with a Quote it ends with a Quote */
	delim = " " /* default to space as a delimiter */
	IF LEFT(arguments,1) = '"' THEN delim = '"'
	ELSE  arguments = " " || arguments /* add space to front */
	PARSE VAR arguments (delim) filename (delim) arguments
	filename = STRIP(filename)
	arguments = STRIP(arguments,L)
	SAY filename
END

value = Delay(5 * 50) /* Five second delay to see window on MegaD screen */

@endnode





@node "RenameOther.rexx" "MegaD 3.1 ARexx Commands Copyright © 1993 John L. Jones"

RenameOther.Rexx:
================

/* example of Rename */
/*
	This program will rename every other item in a slected directory
	to the same name with an underscore at the front.  If you want to 
	test this out use the ARexx program MakeLikeFiles.rexx, it will create
	a number of files in the T: directory with the name likeFile1, likeFile2...
	
	A user wanted a quick way to rename a number of animation frames so that he
	could use every other file, and so, this program was written.
*/
ADDRESS REXX

OPTIONS RESULTS
OPTIONS FAILAT 20
SIGNAL ON FAILURE
	
ADDRESS MEGAD
@{" dbug " link "dbug"} 

/* First, we need to make sure that the items are sorted by Name */
"@{" MenuCheck " link "MenuCheck"} 'show,sort on,name' Check"
directory  = ARG(1)
if directory = '' then exit
/******************************************************************************* 
The directory argument can be sent in one of two ways
Selected Directory in MegaD window
	ARexx Gadget Program Control should have only the below two items checked
		Skip selected files
		Skip .info files
	and the Path and Program name should be the correct path to this script.
	This will require the user to select at least one directory to rename
	every other file to have an underscore in front of it.
User Input required
	ARexx Gadget Program Control should have only the below five items checked
		Skip select4d directories
		Skip selected files
		work without selected items
		skip .info files
		Query for 'Flags to add'
	and the Path and Program name should be the correct path to this script.
	This method will require a valid Path to the correct directory to
	be typed by the user.
*******************************************************************************/
	
@{" CloseWindows " link "CloseWindows"}	/* close any open windows */
@{" Mark " link "Mark"} directory 	/* open the ram disk */
IF RESULT = '' then exit
@{" SelectAll " link "SelectAll"}		/* select everything */

/* disable directory sorting or we will be rename files renamed once before */
"@{" MenuCheck " link "MenuCheck"} 'show,sort on,none' Check"

DO FOREVER
	@{" NextItem " link "NextItem"} Filename
	if result = "" then leave
	ELSE DO
		name = '_' || result
		@{" Rename " link "Rename"} name  /* Rename will unselect the first selected item */
		END
	/* skip the next selected item */
	@{" NextItem " link "NextItem"} Filename clear /* unselect the next item too */
	IF RESULT = "" then leave
	END

/* re-enable the sorting on Name */
"@{" MenuCheck " link "MenuCheck"} 'show,sort on,name' Check"
/* force and update of the window */
"@{" Menu " link "Menu"} 'show,Reset All'"

exit

failure:
	if RC ~= 0 then say "Script Failed, RC = " RC
	exit

@endnode

