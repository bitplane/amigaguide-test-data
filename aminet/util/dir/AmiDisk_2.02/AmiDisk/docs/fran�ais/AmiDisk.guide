    @{"READMAP " LINK READMAP} lecture d'une macro clavier
    @{"RUNCLI  " LINK RUNCLI} exťcution d'une commande
    @{"RUNWB   " LINK RUNWB} lancement commande Workbench
    @{"SCRNAME " LINK SCRNAME} nom de l'ťcran utilisť par AmiDisk
    @{"SETBUFF " LINK SETBUFF} dťtermine la taille du tampon d'ťcriture
    @{"SETVAR  " LINK SETVAR} affectation variable globale
    @{"SHEIGHT " LINK SHEIGHT} renvoie la hauteur de l'ťcran
    @{"STOBACK " LINK STOBACK} passage de l'ťcran en arriŤre-plan
    @{"STOFRONT" LINK STOFRONT} passage de l'ťcran an avant-plan
    @{"SWIDTH  " LINK SWIDTH} renvoie la largeur de l'ťcran
    @{"TIME    " LINK TIME} renvoie l'heure courante
    @{"TOOLBAR " LINK TOOLBAR} gestion des barres d'outils
    @{"UNMAP   " LINK UNMAP} annulation d'une macro clavier
    @{"VERSION " LINK VERSION} numťro de version du programme
    @{"WHEIGHT " LINK WHEIGHT} hauteur de la fenÍtre
    @{"WTOBACK " LINK WTOBACK} renvoie la fenÍtre active en arriŤre-plan
    @{"WTOFRONT" LINK WTOFRONT} renvoie la fenÍtre active en avant-plan
    @{"WWIDTH  " LINK WWIDTH} largeur de la fenÍtre
@ENDNODE
@NODE "Interactivitť" "Fonctions ARexx permettant le dialogue avec l'utilisateur"
@TOC Index†thťmatique

    @{"BUBBLES " LINK BUBBLES}  utilisation des bulles d'aide
    @{"CLOSEBAR" LINK CLOSEBAR} fermeture d'une barre d'outils externe
    @{"DBLCLICK" LINK DBLCLICK} utilisation des doubles clics
    @{"EDITBAR" LINK EDITBAR} edition d'une barre d'outils externe
    @{"EXIT    " LINK EXIT} demande fermeture du programme
    @{"HELP    " LINK HELP} affichage aide AmigaGuide
    @{"LOADBAR " LINK LOADBAR} chargement d'une barre d'outils
    @{"MESSAGE " LINK MESSAGE} affichage d'un message
    @{"REQACT  " LINK REQACT} requÍte choix action
    @{"REQBITS " LINK REQBITS} ťdition des bits de protection
    @{"REQCOLS " LINK REQCOLS} ťdition des largeurs des colonnes d'une liste
    @{"REQCOMM " LINK REQCOMM} ťdition du commentaire
    @{"REQFILE " LINK REQFILE} choix d'un fichier
    @{"REQFUNC " LINK REQFUNC} saisie d'une fonction
    @{"REQLIST " LINK REQLIST} choix d'une chaÓne parmi n
    @{"REQNUM  " LINK REQNUM} saisie d'un nombre
    @{"REQOVER " LINK REQOVER} confirmation copies
    @{"REQPREFS" LINK REQPREFS} ouverture requÍte prťfťrences
