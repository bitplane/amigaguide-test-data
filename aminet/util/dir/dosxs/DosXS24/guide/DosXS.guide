@NODE 7.1. "Funktionsübersicht"

@{b}Funktionsübersicht@{ub}

 Übersicht aller DosXS-internen Funktionen
 
  @{"Clone Side    " Link 4.1. }  Verzeichnis in aktive Seite übernehmen.
  @{"Comment       " Link 4.2. }  Ordner/Dateien mit Kommentar versehen.
  @{"Copy          " Link 4.3. }  Ordner/Dateien in inaktive Seite kopieren.
  @{"Copy As       " Link 4.4. }  wie Copy mit neuem Namen.
  @{"Delete        " Link 4.5. }  Datei(en)/Dir(s) löschen.
  @{"Delete Pattern" Link 4.6. }  Datei(en)/Dir(s) löschen, die mit einem Muster
                   übereinstimmen.
  @{"DirCache Clear" Link 4.7. }  Verzeichnispuffer leeren.
  @{"DirCache OFF  " Link 4.8. }  Verzeichnispufferung abschalten.
  @{"DirCache ON   " Link 4.9. }  Verzeichnispufferung wieder aktivieren.
  @{"DirSize       " Link 4.10.}  Größe der selektierten Ordner ermitteln.
  @{"DiskInfo      " Link 4.11.}  Laufwerkinformationen der aktuellen Seite.
  @{"Iconify       " Link 4.12.}  DosXS als Icon verkleinern.
  @{"MakeDir       " Link 4.13.}  Verzeichnis erzeugen.
  @{"Maske 1-5     " Link 4.14.}  Maskenvoreinstellung benutzen.
  @{"Move          " Link 4.15.}  Ordner/Dateien verschieben.
  @{"MultiShow     " Link 4.16.}  Icon, IFF-ILBM-Bild oder Font anzeigen.
  @{"Parent        " Link 4.17.}  Ins übergeordnete Verzeichnis wechseln.
  @{"PlaySample    " Link 4.18.}  Sample abspielen.
  @{"Print         " Link 4.19.}  Datei(en) oder Verzeichnislisten drucken.
  @{"Protect       " Link 4.20.}  Schutz-Bits für Datei(en)/Dir(s) ändern.
  @{"ReadASCII     " Link 4.21.}  Datei(en) im ASCII-Format anzeigen.
  @{"ReadHEX       " Link 4.22.}  Datei(en) im HEX-Format anzeigen.
  @{"Read Dir      " Link 4.23.}  Verzeichnis einlesen.
  @{"Reload Config " Link 4.24.}  Neue Konfiguration laden.
  @{"Rename        " Link 4.25.}  Datei(en)/Dir(s) umbenennen.
  @{"ReRead Dir    " Link 4.26.}  Verzeichnis ohne Puffer neu einlesen.
  @{"Reset Config  " Link 4.27.}  Konfiguration zurücksetzen.
  @{"Select All    " Link 4.28.}  Alle Ordner/Dateien selektieren.
  @{"Select Clear  " Link 4.29.}  Auswahl der akt. Seite aufheben.
  @{"Select Icon   " Link 4.30.}  zugehörige Icons selektieren.
  @{"Select Invert " Link 4.31.}  Auswahl invertieren.
  @{"Select Pattern" Link 4.32.}  Datei(en)/Dir(s) nach Muster auswählen.
  @{"Set Date      " Link 4.41.}  Datum der selek. Datei(en)/Dir(s) ändern.
  @{"ShowCacheList " Link 4.34.}  Verzeichnispuffer anzeigen.
  @{"ShowDeviceList" Link 4.33.}  Device/Assign-Liste anzeigen.
  @{"SuperPlay     " Link 4.35.}  Objekte mit superplay.library abspielen.
  @{"SuperPlaySTOP " Link 4.36.}  spielendes superplay-Objekt stoppen.
  @{"Swap Sides    " Link 4.37.}  Inhalt aktive/inaktive Seite tauschen.
  @{"Quit DosXS    " Link 4.38.}  DosXS verlassen.
 
  @{"EXTERN        " Link 4.39.}  Externen Befehl einbinden.
 
@ENDNODE

