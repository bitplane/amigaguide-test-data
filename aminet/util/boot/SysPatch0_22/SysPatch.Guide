@NODE UnlockLayerRom "UnlockLayerRom"

  Library:              Graphics
  Patchtyp:             @{" Ersatz " LINK patchtypes}
  Kickstartversion:     ab 1.2 (33)
  CPU:                  ab 68020
  Entfernbar:           Ja
  Konfigurierbar:       Ja
  Besonderheiten:       Wird von @{" UnlockLayer " LINK UnlockLayer} und @{" UnlockLayerInfo " LINK UnlockLayerInfo}
                        mitbenutzt, wenn es also abeschaltet wird,
                        sollten die Beiden auch abgeschaltet werden.
  Zusammenhang:		Fensterverwaltung
  Funktion:		Meldet den Zugriff auf ein Fenster nach einer
                        Ausgabe in das Fenster ab.
@ENDNODE

@NODE Draw "Draw"

  Library:              Graphics
  Patchtyp:             @{" Ergänzung " LINK patchtypes}
  Kickstartversion:     ab 1.2 (33)
  CPU:                  ab 68020
  Entfernbar:           Ja
  Konfigurierbar:       Ja
  Besonderheiten:	-
  Zusammenhang:		Linien ziehen, Fensterrahmen und Gadgets zeichnen.
  Funktion:		Zeichnet eine Line von der aktuellen Grafikcursor-
                        Position zur neuen Position.
			Der Patch bezieht sich nur auf Linien die exakt
                        vertikal oder horizontal verlaufen, wie z.B. in
                        Fensterrahmen. Beachten Sie dazu auch die Hinweise
                        zu @{" MCP " LINK MCP}.
@ENDNODE

