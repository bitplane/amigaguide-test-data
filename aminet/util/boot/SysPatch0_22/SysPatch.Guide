@ENDNODE

@NODE LockLayerRom "LockLayerRom"

  Library:              Graphics
  Patchtyp:             @{" Ersatz " LINK patchtypes}
  Kickstartversion:     ab 1.2 (33)
  CPU:                  ab 68020
  Entfernbar:           Ja
  Konfigurierbar:       Ja
