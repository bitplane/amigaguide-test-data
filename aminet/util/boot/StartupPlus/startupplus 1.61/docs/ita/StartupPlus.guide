@node "INSTALLING" "Installazione"
 @{b}Come installare il programma@{ub}

 Copia 'WBStartup/StartupPlus' nel cassetto 'WBStartup'
 Copia 'Prefs/SUPPrefs' nel cassetto 'Prefs'
 Copia 'Libs/dospath.library' in 'Libs:'
 Copia 'Libs/wbstart.library' in 'Libs:'
 Copia 'SUPKeyFile' in 'ENV:' e 'ENVARC:'
 Copia 'StartupPlus.guide' in 'Help:'
@endnode
