@database GZRT
@master "GZRT.1"
@remark "manual page source format generated by PolyglotMan v3.2 available at http://polyglotman.sourceforge.net/"
@wordwrap
@tab 8

@node sect0 "Name"
gzrecover - gzip recovery toolkit 
@endnode

@node sect1 "Synopsis"
@{b}gzrecover@{ub} [@{i}options@{ui}]@{i} file@{ui} 
@endnode

@node sect2 "Description"
@{b}gzrecover@{ub} will attempt to skip over corrupted data in a gzip archive, allowing the remaining data to be recovered. 
@endnode

@node sect3 "Options"


· @{b}-h@{ub} @{lindent 3}

Show usage statement. @{lindent 0}

· @{b}-v@{ub} @{lindent 3}

Turn on verbose mode. @{lindent 0}

· @{b}-s@{ub} @{lindent 3}

Turn on split mode. @{lindent 0}

· @{b}-o@{ub} @{lindent 3}
@{i}file@{ui} 
Set the output file. @{lindent 0}


@endnode

@node sect4 "See Also"
@{b}gzip@{ub}(1), @{b}cpio@{ub}(1). 
@endnode

@node sect5 "Author"
gzrecover was written by Aaron M. Renn <arenn@urbanophile.com>. 
@endnode
