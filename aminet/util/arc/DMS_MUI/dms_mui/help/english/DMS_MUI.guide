@NODE gui "MUI DMS Window"




	  The MUI DMS window have two folders :

		1 - @{"Pack" LINK compresser}

		2 - @{"UnPack" LINK decompresser}
	  
@ENDNODE
@NODE COMPRESSER "Pack"



	      @{FG shine}Path for Packed files @{FG text}

	      Enter the path of the directory where you want to put the packed
	      archive of the floppy disk.

	      

	      @{FG shine}Device to read@{FG text}

	      Choose the device to pack (DF0: DF1: PC0: PC1:)
	      WARNING : you must choose a device used by DMS.
	      see the DMS documentation.
	      

	      @{FG shine}Compression Mode@{FG text}

	      Choose the compression mode of DMS (Default BEST)

	      @{FG shine}Name of archive (option)@{FG text}

	      You can give the name you want to substitute the default name
	      of the archive
	      (The default name for the floppy 'foobar' is 'foobar.dms')
	      

	      @{FG shine}Add volume name@{FG text}

	      select the button if you want to add the floppy name at the name of
	      archive.
	      example:
	      the floppy disk name is: 'disk1'
	      If you put 'foobar_' in @{FG shine}Name of archive@{FG text}
	      and select @{FG shine}Add volume name@{FG text}
	      the name of archive will be : foobar_disk1.dms.


	      @{FG shine}Click OK for packing@{FG text}

@ENDNODE

@NODE decompresser "UnPack"






	      @{FG shine}Device to write@{FG text}

	      Select the name of device where you want to unpack the archive.
	      (DF0: DF1: PC0: PC1: etc ...)
	      WARNING : you must choose a device used by DMS.
	      see the DMS documentation.

	      @{FG shine}File to unpack@{FG text}

	      Select  the name of the archive you want to unpack.
	      ('foobar.dms')


	      @{FG shine}Click OK for unpacking@{FG text}

@ENDNODE
