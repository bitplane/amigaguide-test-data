@NODE 4.1 "Tooltypes  Supportķs"




  CX_POPKEY=<key pour activer le programme> 
     
  CX_CLOSEKEY=<key pour quitter le programme>

  CX_CONFIGKEY=<key pour configurer le programme>
  
  CX_WINDDOWKEY=<key pour lister les fenĻtres>
  
  CX_TABKEY=<key pour passer d'une fenĻtre Ó l'autre>
  
  WBSCREEN=1 Fenetre de choix toujours sur le workbench
  	  =0 Fenetre de choix sur l'ķcran en premier plan
  	  
  PUBLIC=1 ne liste que les ķcrans publics
  
  APPER=1 Fais apparaitre une fenetre info au dķmarrage

  OPTIONxx="nom du programme avec chemin complet"
  
