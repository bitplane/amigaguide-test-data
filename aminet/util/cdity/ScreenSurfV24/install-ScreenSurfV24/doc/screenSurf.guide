@NODE 4.1 "Supported Tooltypes"




  CX_POPKEY=<key for activate the program> 
     
  CX_CLOSEKEY=<key for quit the program>

  CX_CONFIGKEY=<key for config >
  
  CX_WINDOWKEY=<key for window utilities>
  
  WBSCREEN=1 always on workbench
  	  =0 on the first screen
  	  
  PUBLIC=1  only publicscreen




@ENDNODE

