@NODE "checkwbmainwin" "WinFunctions/checkwbmainwin()"

   @{B}NAME@{UB}
	checkwbmainwin -- checks if window is Workbenchs main window

   @{B}SYNOPSIS@{UB}
	checkwbmainwin( win )

	VOID checkwbmainwin( struct window *);

   @{B}FUNCTION@{UB}
	Simply checks some specials of the workbench-main-window
	to the pointed window. If they are ok, the function returns
	TRUE (window is workbenchs main window), if not it returns
	FALSE (window is NOT workbenchs backdrop window).

   @{B}INPUTS@{UB}
	win = pointer to a window structure

   @{B}RESULTS@{UB}
	returns a bool variable:
	 TRUE  - window is workbenchs main window
	 FALSE - window is not workbenchs main window

   @{B}NOTE@{UB}

   @{B}SEE ALSO@{UB}
	@{"checkwbwin()" LINK "checkwbwin"}
@ENDNODE

@NODE "checklast" "WinFunctions/checklast()"

   @{B}NAME@{UB}
	checklast -- checks, if window is the last one on screen

   @{B}SYNOPSIS@{UB}
	checklast(win)

	struct window * == checklast(struct window *);

   @{B}FUNCTION@{UB}
	Checks if window is the last one in its window list. If this
	is true, it will return screens firstwindow, else it will
	return the next window in list.

   @{B}INPUTS@{UB}
	win == pointer to a window structure

   @{B}RESULTS@{UB}
	returns a window structure
@ENDNODE

@NODE "parentwin" "WinFunctions/parentwin()"

   @{B}NAME@{UB}
	parentwin -- moves window below its parent window

   @{B}SYNOPSIS@{UB}
	parentwin(win)

	VOID parentwin( struct window *, xoffset=0);

   @{B}FUNCTION@{UB}
	Moves the pointed window below the border of its parent one.
        The window will be placed xoffset pixels beside the leftborder
	of its parentwindow. 

   @{B}INPUTS@{UB}
	win     == pointer to a window structure
	xoffset == a long variable naming the offset from leftborder

   @{B}RESULTS@{UB}
	- none -

   @{B}NOTE@{UB}
        This function uses the @{"setWindow()" LINK "setWindow"}-function of
        this module

@ENDNODE

@NODE "centerwin" "WinFunctions/centerwin()"

   @{B}NAME@{UB}
	centerwin -- centers the window on its screen

   @{B}SYNOPSIS@{UB}
	centerwin(win)

	VOID centerwin(struct window *);

   @{B}FUNCTION@{UB}
	centers the pointed window on its screen

   @{B}INPUTS@{UB}
	win == pointer to a window structure

   @{B}RESULTS@{UB}
	- none -

   @{B}NOTE@{UB}
        This function uses the @{"setWindow()" LINK "setWindow"}-function of
        this module

@ENDNODE

@NODE "checkwbwin" "WinFunctions/checkwbwin()"

   @{B}NAME@{UB}
	checkwbwin -- checks if window has workbench flag

   @{B}SYNOPSIS@{UB}
	checkwbwin(win)

	ULONG == checkwbwin(struct window *);

   @{B}FUNCTION@{UB}
	checks if the window has a WFLG_WBENCHWINDOW

   @{B}INPUTS@{UB}
	win == a pointer to a window structure

   @{B}RESULTS@{UB}
	returns a bool variable:
	 TRUE  the pointed window has WFLG_WBENCHWINDOW
	 FALSE the pointed window has no WFLG WBENCHWINDOW
   @{B}NOTE@{UB}

   @{B}SEE ALSO@{UB}
	@{"checkwbmainwin()" LINK "checkwbmainwin"}

   @{B}BUGS@{UB}

@ENDNODE

@NODE "togglewin" "WinFunctions/togglewin()"

   @{B}NAME@{UB}
	togglewin -- brings next window to front

   @{B}SYNOPSIS@{UB}
	togglewin(win)

	VOID togglewin(struct window *);

   @{B}FUNCTION@{UB}
	Searches for the next window in list, brings it to front and
	activates it.

   @{B}INPUTS@{UB}
	win == a pointer to a window structure

   @{B}RESULTS@{UB}
	- none -

   @{B}NOTE@{UB}
	Workbenchs backdropwindow will not be activated.
        Borderless and other backdropwindows will not be activated.
@ENDNODE

@NODE "closewin" "WinFunctions/closewin()"

   @{B}NAME@{UB}
	closewin -- closes the pointed window

   @{B}SYNOPSIS@{UB}
	closewin(win, broker_mp)

	closewin(struct window *, struct mp)

   @{B}FUNCTION@{UB}
	This function closes the pointed window via IDCMP_CLOSEWINDOW
	Message to this window.
	for a correct reply there is the need of a replyport, which is
	'broker_mp' a normal message_port (from exec/ports.mp)
	This function waits UNTIL window has replyed the message.

   @{B}INPUTS@{UB}
	win       = a pointer to a window structure
	broker_mp = a messageport structure

   @{B}BUGS@{UB}
	Causes a system-crash (Guru 80000003) if you do this to a real
	CON: window. If you use KingCon, everything went ok.
@ENDNODE
	 
@NODE "closewbwins" "WinFunctions/closewbwins()"

   @{B}NAME@{UB}
	closwbwins -- closes all workbenchwindows

   @{B}SYNOPSIS@{UB}
	closewbwins(win, mp_broker)

	VOID closewbwins(struct window *, struct mp *);
   @{B}FUNCTION@{UB}
	closes all windows, following to the pointed one, which have
	a WFLG_WBENCHWINDOW.
	You can specify any window in screen structure, then all
	parentwindows and this window will be closed

   @{B}INPUTS@{UB}
	win == a pointer to a window
	broker_mp == a pointer to a messageport (mp)

   @{B}NOTE@{UB}
	This function uses closewin() and checkwbmainwin()
	This function is recursive! Each call reserves at least
	170 Bytes (for empty structures - but they are filled!)
	So, if you call it with many windows on screen, it will
	a time to parse to the last one window and then the
	called functions start to return with closewindow(),
	which reserves again at least 170 Bytes each time.
	So, if you close around 100 Windows on an 68030 with 50MHz
	takes around 3 Minutes (while machine takes 100% CPU time
	and you will see nothing for the first 2 Minutes!)

   @{B}BUGS@{UB}
	none anymore, if crashes, this is not my bug
@ENDNODE

@NODE "topleft" "WinFunctions/topleft()"

   @{B}NAME@{UB}
	topleft -- moves the window in top left corner

   @{B}SYNOPSIS@{UB}
	topleft(win)

	VOID topleft(struct window *);
   @{B}FUNCTION@{UB}
	Moves the pointed window to the top left corner below the
	screen bar.
	You can specify any window in screen structure, but the
	function will move only nonborderless and movable windows

   @{B}INPUTS@{UB}
	win == a pointer to a window

   @{B}RESULTS@{UB}
	- none -

   @{B}NOTE@{UB}
        This function uses the @{"setWindow()" LINK "setWindow"}-function of
        this module
@ENDNODE

@NODE "setWindow" "WinFunctions/setWindow()"

   @{B}NAME@{UB}
	setWindow -- moves the window to specified position

   @{B}SYNOPSIS@{UB}
	setWindow(win, x, y)

	VOID setWindow(struct window *, word, word);
   @{B}FUNCTION@{UB}
	Moves the pointed window to the position defined by x
        and y

   @{B}INPUTS@{UB}
	win == a pointer to a window
        x   == the x-position where the window should be placed to
        y   == the y-position where the window should be palced to
@ENDNODE
