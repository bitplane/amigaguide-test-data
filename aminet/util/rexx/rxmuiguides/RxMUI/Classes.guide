     +--@{"Image" LINK "ImageClass.guide/Main"}                  image display
     +--@{"Lamp" LINK "LampClass.guide/Main"}                   lamp images
     +--@{"MonthNavigator" LINK "MonthNavigatorClass.guide/Main"}         field of days
     +--@{"MysticView" LINK "MysticViewClass.guide/Main"}             images displayed via mysticview.library
     +--@{"Picture" LINK "PictureClass.guide/Main"}                datatype picture images
     +--@{"Rectangle" LINK "RectangleClass.guide/Main"}              spacing object
     +--@{"SpeedButton" LINK "SpeedButtonClass.guide/Main"}            very cute image buttons
