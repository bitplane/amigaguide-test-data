  RootClass                     BOOPSI's base class
  +--@{"Notify" LINK "NotifyClass.guide/Main"}                    implements notification mechanism
  +--Family                     handles multiple children
     +--@{"Menu" LINK "MenuClass.guide/Main"}                   describes a single menu
     +--@{"Menuitem" LINK "MenuClass.guide/Main"}               describes a single menu item
     \\--@{"Menustrip" LINK "MenuClass.guide/Main"}              describes a complete menu strip
  +--@{"Application" LINK "ApplicationClass.guide/Main"}               main class for all applications
  +--@{"Window" LINK "WindowClass.guide/Main"}                    main class for all windows
     +--@{"BWin" LINK "BWinClass.guide/Main"}                   beautiful borderless window
     \\--@{"CompactWindow" LINK "CompactWindowClass.guide/Main"}          mini tiny windows
  \\--@{"Area" LINK "AreaClass.guide/Main"}                      base class for all GUI elements
     +--@{"Balance" LINK "BalanceClass.guide/Main"}                balancing separator bar
     +--@{"BetterBalance" LINK "BetterBalanceClass.guide/Main"}          position-savable balancing separator bar
     +--@{"Bitmap" LINK "BitmapClass.guide/Main"}                 area filled with an image
     +--@{"Busy" LINK "BusyClass.guide/Main"}                   busy bar
     +--@{"Colorfield" LINK "ColorfieldClass.guide/Main"}             colored rectangle
     +--@{"DTPic" LINK "DTPicClass.guide/Main"}                  datatype images
     +--@{"Gfxpic" LINK "GfxpicClass.guide/Main"}                 images displayed via guigfx.library
     +--@{"GIFAnim" LINK "GIFAnimClass.guide/Main"}                gif pictures and animations
