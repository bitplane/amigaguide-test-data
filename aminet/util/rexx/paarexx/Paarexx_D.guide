@ENDNODE

@NODE beispiel "beispiel.rexx"
/*

** AREXX-Skript fuer Paarexx von Dieter Sabathi

**

**$VER: beispiel.rexx fuer Paarexx 1.0 (23.12.95)© 1995 Dieter Sabathi, Bernd Gollesch

*/


ADDRESS "AREXX"


h_stat=SHOW("P","Paarexx")


IF ~ h_stat THEN DO

   SAY

   SAY "Paarexx wurde noch nicht gestartet!"

   SAY

   EXIT

END


ADDRESS "Paarexx"

OPTIONS RESULTS           /* fuer STATUS und INFO */

OPTIONS PROMPT "PRESS RETURN"


SAY

SAY "Ruecksetzen aller Bits mittels CLEARALL"

PULL LINE


CLEARALL

STATUS

h_stat = RESULT


SAY

SAY "Status: " h_stat

SAY

SAY "Setzten der Bits 0 bis 7 (ohne Ruecksetzen)"

PULL LINE

SAY


DO i = 0 TO 7

   SETBIT i

   STATUS

   h_stat = RESULT

   SAY "Setze Bit" i", Status = " h_stat

END


CLEARALL


SAY

SAY "Setzten der Bits 0 bis 7 (mit Ruecksetzen)"

PULL LINE

SAY


DO i = 0 TO 7

   SETBIT i

   STATUS

   h_stat = RESULT

   SAY "Setze Bit" i", Status = " h_stat

   CLEARBIT i

END


CLEARALL


SAY

SAY "Setzen aller Bits mittels SETALL"

PULL LINE


SETALL

STATUS

h_stat = RESULT


SAY

SAY "Status: " h_stat

SAY

SAY "Holen des Infotextes mittels INFO"

PULL LINE


INFO

h_text = RESULT

SAY h_text

SAY

SAY "*** Ende des Beispielskriptes ***"


EXIT

@ENDNODE
