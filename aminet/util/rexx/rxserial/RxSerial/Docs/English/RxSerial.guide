@Node "Help" "RxSerial Functions - Help"

  @{b}Help@{ub} - returns RxSerial functions help strings

  @{b}Synopsis@{ub}
    help=help(funName)
    <funName>

  @{b}Function@{ub}
    Returns the arguments mask string of RxSerial function
    @{i}funName@{ui}.

  @{b}Inputs@{ub}
    funName - a RxSerial function name

  @{b}Result@{ub}
    help - the help string associated with @{i}funName@{ui}

@EndNode

@Node "SERAbortIO" "RxSerial Functions - SERAbortIO"

  @{b}SERAbortIO@{ub} - aborts an async request

  @{b}Synopsis@{ub}
    call SERAbortIO(ID)
    <ID/N>

  @{b}Function@{ub}
    Aborts an async request. Actually just @{"SERRead()" LINK "SERRead"} and
    @{"SERWrite()" LINK "SERWrite"} use async io, so this function may be used
    only after the 2 above to abort the request.

  @{b}Inputs@{ub}
    ID - SER device descriptor

  @{b}Result@{ub}
    Always 0

  @{b}See@{ub}
    @{"SERCheckIO()" LINK "SERCheckIO"} @{"SERWaitIO()" LINK "SERWaitIO"}

@EndNode

@Node "SERBreak" "RxSerial Functions - SERBreak"

  @{b}SERBreak@{ub} - sends a break signal over the serial line

  @{b}Synopsis@{ub}
    res=SERBreak(ID)
    <ID/N>

  @{b}Function@{ub}
      This command sends a break signal (serial line held
      low for an extended period) out the serial port.

      After a duration (user specifiable via @{"SERSetParams()" LINK "SERSetParams"},
      default 250000 microseconds) the bit is reset and the
      signal discontinued.

      If QueuedBrk is set via @{"SERSetOptions()" LINK "SERSetOptions"} or @{"SERSetParams()" LINK "SERSetParams"}
      the request is placed at the back of the write-request
      queue and executed in turn. If QueuedBrk is not set,
      the break is started immediately, control returns to the
      caller, and the timer discontinues the signal after the
      duration is completed. Be aware that calling SERBreak()
      affects other commands such as @{"SERAbortIO()" LINK "SERAbortIO"}, @{"SERFlush()" LINK "SERFlush"}
      @{"SERStop()" LINK "SERStop"}, @{"SERStart()" LINK "SERStart"}, etc...

  @{b}Inputs@{ub}
    ID - SER device descriptor

  @{b}Result@{ub}
    res - the device error

@EndNode

@Node "SERCheckIO" "RxSerial Functions - SERCheckIO"

  @{b}SERCheckIO@{ub} - checks for a request completion

  @{b}Synopsis@{ub}
    res=SERCheckIO(ID)
    <ID/N>

  @{b}Function@{ub}
    Checks for a request completion.
    See @{"SERAbortIO()" LINK "SERAbortIO"}.

  @{b}Inputs@{ub}
    ID - SER device descriptor

  @{b}Result@{ub}
    res - an ARexx boolean

  @{b}See@{ub}
    @{"SERAbortIO()" LINK "SERAbortIO"} @{"SERWaitIO()" LINK "SERWaitIO"}

@EndNode

@Node "SERClear" "RxSerial Functions - SERClear"

  @{b}SERClear@{ub} - clears the serial port's read buffer

  @{b}Synopsis@{ub}
    res=SERClear(ID)
    <ID/N>

  @{b}Function@{ub}
    This command resets the serial port's read
    buffer pointers.

  @{b}Inputs@{ub}
    ID - SER device descriptor

  @{b}Result@{ub}
    res - the device error

@EndNode

@Node "SERCreate" "RxSerial Functions - SERCreate"

  @{b}SERCreate@{ub} - creates a SER object

  @{b}Synopsis@{ub}
    ID = SERCreate(device,unit,opts)
    [device],[unit/N],[opts]

  @{b}Function@{ub}
    Creates an internal SER object and returns its descriptor.

  @{b}Inputs@{ub}
      device - an exec device name (default "serial.device")
      unit   - the device unit (default 0)
      opts   - a combination of:
                   . Shared
                   . Wire7

  @{b}Result@{ub}
    ID - a SER object descriptor

  @{b}See@{ub}
    @{"SERDispose()" LINK "SERDispose"} @{"SERSignal()" LINK "SERSignal"}

@EndNode

@Node "SERDispose" "RxSerial Functions - SERDispose"

  @{b}SERDispose@{ub} - disposes a SER object

  @{b}Synopsis@{ub}
    call SERDispose(ID)
    <ID/N>

  @{b}Function@{ub}
    Disposes an internal SER object created with @{"SERCreate()" LINK "SERCreate"}.

  @{b}Inputs@{ub}
    ID - SER device descriptor

  @{b}Result@{ub}
    Always returns 0.

  @{b}See@{ub}
    @{"SERCreate()" LINK "SERCreate"} @{"SERSignal()" LINK "SERSignal"}

@EndNode

@Node "SERFlush" "RxSerial Functions - SERFlush"

  @{b}SERFlush@{ub} - clears all queued I/O requests for the serial port

  @{b}Synopsis@{ub}
    res=SERFlush(ID)
    <ID/N>

  @{b}Function@{ub}
    This command purges the read and write request queues for the serial
    device. Flush will not affect active requests.


  @{b}Inputs@{ub}
    ID - SER device descriptor

  @{b}Result@{ub}
    res - the device error

@EndNode

@Node "SERSetOptions" "RxSerial Functions - SERSetOptions"

  @{b}SERSetOptions@{ub} - sets many options

  @{b}Synopsis@{ub}
    res=SERSetOptions(ID,opt)
    <ID/N>,[opts]

  @{b}Function@{ub}
    Sets many options for the following requests.

    @{i}opts@{ui} may be a combination of:
        o EOFMode
          Activate EOFMode

        o QueuedBrk
          See SERBreak()

    Note that if an option is not supplied it is cleared.

  @{b}Inputs@{ub}
    ID   - SER device descriptor
    opts - the options to set

  @{b}Result@{ub}
    Always 0

@EndNode

@Node "SERQuery" "RxSerial Functions - SERQuery"

  @{b}SERQuery@{ub} - queries the device

  @{b}Synopsis@{ub}
    res=SERQuery(ID,stem)
    <ID/N>,<stem/V>

  @{b}Function@{ub}
    Queries the device about its current configuration.

    The fields set in @{i}stem@{ui} are:

        o Actual/N
        o XON/N
        o XOFF/N
        o INQ/N
        o ACK/N
        o RBufLen/N
        o MarkSpaceON
        o Mark/B
        o Baud/N
        o BrkTime/N
        o ReadLen/N
        o WriteLen/N
        o StopBits/N
        o XDisabled/B
        o EOFMode/B
        o Shared/B
        o RadBoogie/B
        o QueuedBrk/B
        o Wire7/B
        o ParityOdd/B
        o ParityON/B
        o ParallelSelect/B
        o DataSetReady/B
        o ClearToSend/B
        o CarrierDetect/B
        o ReadyToSend/B
        o DataTerminalReady/B
        o ReadOverrun/B
        o BreakSent/B
        o BreakReceived/B
        o TransmitXOFFed/B
        o ReceiveXOFFed/B
        o TermArray/S

  @{b}Inputs@{ub}
    ID   - SER device descriptor
    stem - where to write results

  @{b}Result@{ub}
    res - the device error

  @{b}See@{ub}
    @{"SERSetParams()" LINK "SERSetParams"}

@EndNode

@Node "SERRead" "RxSerial Functions - SERRead"

  @{b}SERRead@{ub} - reads from the serial port

  @{b}Synopsis@{ub}
    res=SERRead(ID,len)
    <ID/N>,[len]

  @{b}Function@{ub}
    This function causes a stream of characters to be read in from
    the serial port buffer. The number of characters is specified
    in @{i}len@{ui} (default 1).

    @{"SERQuery()" LINK "SERQuery"} can be used to check how many characters
    are currently waiting in the serial port buffer.
    If more characters are requested than are currently
    available, the request will be queued until it can
    be satisfied.

    The best way to handle reads is to first query to get the number
    of characters currently in the buffer. Then post a read request
    for that number of characters.

    If zero characters are in the buffer, post a request
    for 1 character.  When at least one is ready, the device will
    return it. Now start over with another query.

  @{b}Inputs@{ub}
    ID    - SER device descriptor
    len   - the number of characters to read (default 1)

  @{b}Result@{ub}
     res -  0 if the read succeded.
           >0 if the read failed, to indicate problems such as parity
              mismatch, break, and buffer overrun.

@EndNode

@Node "SERReset" "RxSerial Functions - SERReset"

  @{b}SERReset@{ub} - reinitializes the serial port

  @{b}Synopsis@{ub}
    res=SERReset(ID)
    <ID/N>

  @{b}Function@{ub}
    This command resets the serial port to its freshly initialized
    condition. It aborts all requests both queued and current,
    relinquishes the current buffer, obtains a new default sized
    buffer, and sets the port's flags and parameters to their
    boot-up time default values.

  @{b}Inputs@{ub}
    ID - SER device descriptor

  @{b}Result@{ub}
    res - the device error

@EndNode

@Node "SERSetParams" "RxSerial Functions - SERSetParams"

  @{b}SERSetParams@{ub} - sets parameters

  @{b}Synopsis@{ub}
    res=SERSetParams(ID)
    <ID/N>,<stem/V>

  @{b}Function@{ub}
    Sets device parameters.

    The fields read from @{i}stem@{ui} are:
	    o Termarray/S
	    o XON/N
	    o XOFF/N
	    o RbufLen/N
	    o MarkSpaceON/B
	    o Mark/B
	    o Baud/N
	    o BrkTime/N
	    o ReadLen/N
	    o WriteLen/N
	    o StopBits/N
	    o XDisabled/B
	    o EOFMode/B
	    o Shared/B
	    o RadBoogie/B
	    o QueuedBrk/B
	    o Wire7/B
	    o ParityOdd/B
	    o ParityON/B

  @{b}Inputs@{ub}
    ID   - SER device descriptor
    stem - where to read params

  @{b}Result@{ub}
    res - the device error

  @{b}See@{ub}
    @{"SERQuery()" LINK "SERQuery"}

@EndNode

@Node "SERSignal" "RxSerial Functions - SERSignal"

  @{b}SERSignal@{ub} - obtains the device port signal

  @{b}Synopsis@{ub}
    sig=SERSignal(ID)
    <ID/N>

  @{b}Function@{ub}
    Obtains the signal to wait for async request.

  @{b}Inputs@{ub}
    ID - SER device descriptor

  @{b}Result@{ub}
    sig - the signal to wait

  @{b}See@{ub}
    @{"SERCreate()" LINK "SERCreate"} @{"SERDispose()" LINK "SERDispose"}

@EndNode

@Node "SERStart" "RxSerial Functions - SERStart"

  @{b}SERStart@{ub} - restarts paused I/O

  @{b}Synopsis@{ub}
    res=SERStart(ID)
    <ID/N>

  @{b}Function@{ub}
    This function restarts all current I/O on the serial port by
    sending an xON to the "other side", and submitting a "logical
    xON" to "our side", if/when appropriate to current activity.

  @{b}Inputs@{ub}
    ID - SER device descriptor

  @{b}Result@{ub}
    res - the device error

  @{b}See@{ub}
    @{"SERStop()" LINK "SERStop"}

@EndNode

@Node "SERStop" "RxSerial Functions - SERStop"

  @{b}SERStop@{ub} - pauses all current I/O

  @{b}Synopsis@{ub}
    res=SERStop(ID)
    <ID/N>

  @{b}Function@{ub}
    This command halts all current I/O on the serial port by
    sending an xOFF to the "other side", and submitting a "logical
    xOFF" to "our side", if/when appropriate to current activity.

  @{b}Inputs@{ub}
    ID - SER device descriptor

  @{b}Result@{ub}
    res - the device error

  @{b}See@{ub}
    @{"SERStart()" LINK "SERStart"}

@EndNode

@Node "SERWaitIO" "RxSerial Functions - SERWaitIO"

  @{b}SERWaitIO@{ub} - waits for a request completion

  @{b}Synopsis@{ub}
    call SERWaitIO(ID,var)
    <ID/N>,<var/S>

  @{b}Function@{ub}
    Waits for a request completion.
    See @{"SERAbortIO()" LINK "SERAbortIO"}.

    Note that this function must always be used after a @{"SERRead()" LINK "SERRead"}
    to get the received characters.

  @{b}Inputs@{ub}
    ID  - SER device descriptor
    var - an ARexx var name, filled with the current read buffer;
          note that has sense only after a @{"SERRead()" LINK "SERRead"}.

  @{b}Result@{ub}
    Always 0

  @{b}Example@{ub}
    id=SERCreate()
    if id=0 then exit
    sig=SERSignal(id)
    call SERRead(id,16)
    call wait(sig)
    call SERWaitIO(id,"data")
    say data

  @{b}See@{ub}
    @{"SERAbortIO()" LINK "SERAbortIO"} @{"SERCheckIO()" LINK "SERCheckIO"}

@EndNode

@Node "SERWrite" "RxSerial Functions - SERWrite"

  @{b}SERWrite@{ub} - sends output to serial port

  @{b}Synopsis@{ub}
    res = SERWrite(ID,data)
    <ID/N>,<data>

  @{b}Function@{ub}
    This command causes a stream of characters
    to be written out the serial port.
    The request is performed in sync way.

  @{b}Inputs@{ub}
    ID    - SER device descriptor
    data  - the data to send

  @{b}Result@{ub}
    res -  If the write succeded, then 0
           If the write failed, then >0

  @{b}See@{ub}
    @{"SERWriteAsync()" LINK "SERWriteAsync"}

@EndNode

@Node "SERWriteSync" "RxSerial Functions - SERWriteSync"

  @{b}SERWriteAsync@{ub} - sends output to serial port in sync way

  @{b}Synopsis@{ub}
    res = SERWriteSync(ID,data,quick)
    <ID/N>,<data>,[quick/N]

  @{b}Function@{ub}
    This command causes a stream of characters
    to be written out the serial port.
    The request is performed in sync way.

  @{b}Inputs@{ub}
    ID    - SER device descriptor
    data  - the data to send
    quick - if supplied and 1, try quick I/O

  @{b}Result@{ub}
    res -  If the write succeded, then 0
           If the write failed, then >0

  @{b}See@{ub}
    @{"SERWrite()" LINK "SERWrite"}

@EndNode
