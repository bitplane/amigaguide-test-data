    @{" Neuerungen    " link "Neuerungen" 0}          Was hat sich geändert

  @{b}Verschiedenes@{ub}

    @{" Rechtliches   " link "GCBProdukte:GCBRecht.guide/main" 0}          Wann sind Sie offizieller Nutzer
