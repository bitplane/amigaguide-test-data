@node PRG_IREQ "Icon Programs:  InfoReq"

@{u}@{b}InfoReq@{ub}@{uu}

@{b}Version:@{ub}   1.1
@{b}Requires:@{ub}  WB 3.0 or above.

@{b}Purpose:@{ub}  Opens Workbench's icon information requester on given files.


@{b}Usage:@{ub}    IconReq [FILES] <filename(s)> [PS=PUBSCREEN <public screen>]
@{b}Template:@{ub} FILES/M/A,PS=PUBSCREEN/K

@{b}Options:@{ub}
  FILES - Full path & name of the file(s) to open.  @{b}Required@{ub}.
          It isn't necessary to supply the ".info" extension.
          The keyword "FILES" is optional.

  PUBSCREEN - The name of the public screen to oprn the information
              requester on.  @{b}Optional@{ub} (defaults to the default public
              screen).


@{b}History:@{ub}
@{b}v1.1@{ub}
  - Removed an unnecessary check.
  - Ends with a return code.
@endnode


@node PRG_CLONE "Icon Programs:  CloneIcon"

@{u}@{b}CloneIcon@{ub}@{uu}

@{b}Version:@{ub}   1.1
@{b}Requires:@{ub}  WB 2.04 or above.

@{b}Purpose:@{ub}  Makes copies of a supplied icon.  The icon's tooltypes are
         @{u}not@{uu} copied to the new icon(s).

@{b}Usage:@{ub}     CloneIcon [FROM] <filename> TO <filename(s)>
@{b}Template:@{ub}  FROM/M/A,TO/K/M/A

@{b}Options:@{ub}
  FROM - Path/name of an icon to copy.  @{b}Required@{ub}.
         It isn't necessary to supply the ".info" extension.
         The keyword "FROM" is optional.

  TO - Path/name(s) for the new icon(s).
       It isn't necessary to supply the ".info" extension.


@{b}History:@{ub}
@{b}v1.1@{ub}
  - Uses exceptions.
  - Ends with a return code.
@endnode


@node PRG_MKDEF "Icon Programs:  MakeDefIcon"

@{u}@{b}MakeDefIcon@{ub}@{uu}

@{b}Version:@{ub}   1.1
@{b}Requires:@{ub}  WB 2.04 or above.

@{b}Purpose:@{ub}  Creates icons for iconless files using the "ENV:Sys/Def_" icons.
         If an icon already exists for a given file it will remain unchanged.

@{b}Usage:@{ub}     MakeDefIcon [FILES] <filename(s)>
@{b}Template:@{ub}  FILES/M/A

@{b}Options:@{ub}
  FILES - Full path & name of the file(s) to create icons for.  @{b}Required@{ub}.
          It isn't necessary to supply the ".info" extension.
          The keyword "FILES" is optional.


@{b}History:@{ub}
@{b}v1.1@{ub}
  - Ends with a return code.
@endnode


@node PRG_FTT "Icon Programs:  FileToTT"

@{u}@{b}FileToTT@{ub}@{uu}

@{b}Version:@{ub}   1.0
@{b}Requires:@{ub}  WB 2.04 or above.

@{b}Purpose:@{ub}  Copy lines from a text file to an icon's tooltype list.

@{b}Usage:@{ub}     FileToTT [FROM] <filename> TO <filename> [A=APPEND]
@{b}Template:@{ub}  FROM/A,TO/K/A,A=APPEND/S

@{b}Options:@{ub}
  FROM - Path/name of an ASCII text file.  @{b}Required@{ub}.
         The keyword "FROM" is optional.

  TO - Path/name of the icon to recieve the new tooltypes.  @{b}Required@{ub}.
       It isn't necessary to supply the ".info" extension.

  APPEND - Add the file's text to the tooltype list, rather than replacing the
          existing tooltypes.  @{b}Optional@{ub} (default behavior is to overwrite the
          tooltype list).


@{b}Note:@{ub}
  - Tooltypes are limited to 128 characters.  Lines longer than this will be
   truncated.
@endnode


@node PRG_TTF "Icon Programs:  TTToFile"

@{u}@{b}TTToFile@{ub}@{uu}

@{b}Version:@{ub}   1.0
@{b}Requires:@{ub}  WB 2.04 or above.

@{b}Purpose:@{ub}  Output an icon's tooltypes to an ASCII text file.

@{b}Usage:@{ub}     TTToFile [FROM] <filename> TO <filename> [A=APPEND]
@{b}Template:@{ub}  FROM/A,TO/K/A,A=APPEND/S

@{b}Options:@{ub}
  FROM - Path/name of an icon.  @{b}Required@{ub}.
         The keyword "FROM" is optional.
         It isn't necessary to supply the ".info" extension.

  TO - Path/name to write the tooltypes to.  @{b}Required@{ub}.

  APPEND - Adds the tooltypes to the end of the existing file, rather than
          replacing the file's contents.  @{b}Optional@{ub} (default behavior is to
          overwrite the file).
@endnode


