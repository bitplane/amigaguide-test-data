@node "AI_Future" "AddIndex - Zukünftiges"
@toc "AddIndex"

   @{b}AddIndex - Zukünftiges@{ub}
  ---------------------------

   Ihre persönlichen Wünsche.
@endnode
@node "AI_Buglist" "AddIndex - Bekannte Fehler"
@toc "AddIndex"

   @{b}AddIndex - Bekannte Fehler@{ub}
   ----------------------------

