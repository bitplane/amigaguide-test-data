@node Installation "AmiGOD - Instalace"

				@{B}Instalace@{ub}
				=========

	- pouze si zkopírujte adresáę "AmiGOD" na Váî disk :)
	- nepęejmenovávejte prosím soubor 'AmiGOD.tests'

@endnode

@node Requirements "AmiGOD - Poůadavky"

				@{B}Systémové poůadavky@{ub}
				===================

	systém :	Amiga 0S 3.0 nebo lepîí (OS 2.0 netestován)
	procesor :	68k, PPC
	pamëď :		0,2 MB volné pamëti
	software :	identify.library

@endnode

@node Tooltypes "AmiGOD - Tooltypy"

				@{b}Tooltypy@{ub}
				========

USERFONT = YES|NO	základnë NO           - pokud zadáte NO, nepouůije ze
						font z tooltypű, ale Váî systémový
FONT     = X.font	základnë Courier.font - vlastní font
SIZE     = çíslo        základnë 13           - velikost fontu
LANGUAGE = xxx		default ENGLISH

 - kde xxx je název nëjakého souboru v adresáęi Languages
 - podporované jazyky:

        - 'czech'       program & dokumentace!
        - 'deutsch'     program
        - 'english'     program & dokumentace!
        - 'francais'    program
        - 'italiano'    program
        - 'magyar'      program
        - 'polski'      program & dokumentace!
	- 'portuguese'  program
	- 'russian'     program
        - 'slovak'      program

@endnode

