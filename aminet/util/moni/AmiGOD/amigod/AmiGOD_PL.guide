@node Installation "AmiGOD - Instalacja"

				@{B}Instalacja@{ub}
				==========

	- wystrczy skopiowaę katalog o nazwie "AmiGOD" :)
	- nie zmieniaj nazwy pliku 'AmiGOD.tests'

@endnode

@node Requirements "AmiGOD - Wymagania"

				@{B}Wymagania systemowe@{ub}
				===================

	  system :	Amiga 0S 3.0 lub lepszy (nie testowany na OS 2.0)
	procesor :	68k lub PPC
	  pamiëę :	0,2 MB wolnej pamiëci RAM
	programy :	identify.library

@endnode

@node Tooltypes "AmiGOD - Tooltypy"

				@{b}Tooltypy@{ub}
				========

USERFONT = YES|NO	standartowo NO           - czy uűywaę innego fontu
FONT     = X.font	standartowo Courier.font - jakiego fontu chcemy uűyę
SIZE     = number	standartowo 13           - wielkoôę fontu
LANGUAGE = xxx		standartowo ENGLISH

 - gdzie xxx jest nazwâ jakiegoô pliku z katalogu Languages
 - dostëpne jëzyki:

        - 'czech'       program i dokumentacja!
        - 'deutsch'     program
        - 'english'     program i dokumentacja!
        - 'francais'    program
        - 'italiano'    program
        - 'magyar'      program
        - 'polski'      program i dokumentacja!
	- 'portuguese'  program
	- 'russian'	program
        - 'slovak'      program

@endnode

