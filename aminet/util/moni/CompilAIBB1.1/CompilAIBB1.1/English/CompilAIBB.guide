@node A2000-XX-ROM20 "Module Amiga 2000, Supra 28"
    @{fg highlight}Module Amiga 2000, Supra 28 :@{fg text}

@{i}Daniel Higgins @{ui}@{fg fill}danbo@ccwf.cc.utexas.edu@{fg text}

