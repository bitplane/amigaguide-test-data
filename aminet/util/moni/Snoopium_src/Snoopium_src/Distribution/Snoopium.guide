@node ChangeDir
@title "ChangeDir command"

Command: CHANGEDIR
         NOCHANGEDIR
@endnode

@node ClearBuffer
@title "ClearBuffer command"

Command: CLEARBUFFER
@endnode

@node CloseFormat
@title "CloseFormat command"

Command: CLOSEFORMAT
@endnode

@node CloseFunction
@title "CloseFunction command"

Command: CLOSEFUNCTION
@endnode

@node CloseSetup
@title "CloseSetup command"

Command: CLOSESETUP
@endnode

@node CopyBuffer
@title "CopyBuffer command"

Command: COPYBUFFER
@endnode

@node CreateIcons
@title "CreateIcons command"

Command: CREATEICONS
         NOCREATEICONS
@endnode

@node Delete
@title "Delete command"

Command: DELETE
         NODELETE
@endnode

@node Disable
@title "Disable command"

Command: DISABLE
@endnode

@node DisableWhenHidden
@title "DisableWhenHidden command"

Command: DISABLEWHENHIDDEN
         NODISABLEWHENHIDDEN
@endnode

@node Enable
@title "Enable command"

Command: ENABLE
@endnode

@node Execute
@title "Execute command"

Command: EXECUTE
         NOEXECUTE
@endnode

@node FindPort
@title "FindPort command"

Command: FINDPORT
         NOFINDPORT
@endnode

@node FindResident
@title "FindResident command"

Command: FINDRESIDENT
         NOFINDRESIDENT
@endnode

@node FindSemaphore
@title "FindSemaphore command"

Command: FINDSEMAPHORE
         NOFINDSEMAPHORE
@endnode

@node FindTask
@title "FindTask command"

Command: FINDTASK
         NOFINDTASK
@endnode

@node Format
@title "Format command"

Command: FORMAT "formatstring"

Example: FORMAT "%u %p %a %n %o %r"
@endnode

@node FormatWindowPos
@title "FormatWindowPos command"

Command: FORMATWINDOWPOS=<left>,<top>

Example: FORMATWINDOWPOS=0,20
@endnode

@node Functions
@title "Functions command"

Command: FUNCTIONS=ALL | NONE | ALLDOS | NODOS | ALLSYSTEM | NOSYSTEM

Example: FUNCTIONS=ALLDOS
@endnode

@node FunctionWindowPos
@title "FunctionWindowPos command"

Command: FUNCTIONWINDOWPOS=<left>,<top>

Example: FUNCTIONWINDOWPOS=0,20
@endnode

@node GetVar
@title "GetVar command"

Command: GETVAR
         NOGETVAR
@endnode

@node GotoLine
@title "GotoLine command"

Command: GOTOLINE <n>

Example: GOTOLINE 100
@endnode

@node Help
@title "Help command"

Command: HELP <topic>

Example: HELP MainWindow

Not supported yet.
@endnode

@node Hide
@title "Hide command"

Command: HIDE
@endnode

@node IgnoreShell
@title "IgnoreShell command"

Command: IGNORESHELL
         NOIGNORESHELL

Enables or disables Snoopium's Ignore Ambient/Shell setting.
@endnode

@node LoadDefSettings
@title "LoadDefSettings command"

Command: LOADDEFSETTINGS
@endnode

@node LoadSeg
@title "LoadSeg command"

Command: LOADSEG
         NOLOADSEG
@endnode

@node LoadSettings
@title "LoadSettings command"

Command: LOADSETTINGS "settingsfile"
         LOADSETTINGS "con:////Snoopium Command Window/CLOSE"

Example: LOADSETTINGS "ram:Snoopium.prefs"
@endnode

@node Lock
@title "Lock command"

Command: LOCK
         NOLOCK
@endnode

@node LockScreen
@title "LockScreen command"

Command: LOCKSCREEN
         NOLOCKSCREEN
@endnode

@node MainWindowPos
@title "MainWindowPos command"

Command: MAINWINDOWPOS=<left>,<top>

Example: MAINWINDOWPOS=0,20
@endnode

@node MainWindowSize
@title "MainWindowSize command"

Command: MAINWINDOWSIZE=<width>,<height>

Example: MAINWINDOWSIZE=640,150
@endnode

@node MakeDir
@title "MakeDir command"

Command: MAKEDIR
         NOMAKEDIR
@endnode

@node MakeLink
@title "MakeLink command"

Command: MAKELINK
         NOMAKELINK
@endnode

@node MatchName
@title "MatchName command"

Command: MATCHNAME "pattern"

Example: MATCHNAME "~(AmIRC|Voyager)"
@endnode

@node MonitorPackets
@title "MonitorPackets command"

Command: MONITORPACKETS
         NOMONITORPACKETS
@endnode

@node MonitorROMCalls
@title "MonitorROMCalls command"

Command: MONITORROMCALLS
         NOMONITORROMCALLS
@endnode

@node OnlyShowFails
@title "OnlyShowFails command"

Command: ONLYSHOWFAILS
         NOONLYSHOWFAILS
@endnode

@node Open
@title "Open command"

Command: OPEN
         NOOPEN
@endnode

@node OpenDevice
@title "OpenDevice command"

Command: OPENDEVICE
         NOOPENDEVICE
@endnode

@node OpenFont
@title "OpenFont command"

Command: OPENFONT
         NOOPENFONT
@endnode

@node OpenFunction
@title "OpenFunction command"

Command: OPENFUNCTION
@endnode

@node OpenLibrary
@title "OpenLibrary command"

Command: OPENLIBRARY
         NOOPENLIBRARY
@endnode

@node OpenResource
@title "OpenResource command"

Command: OPENRESOURCE
         NOOPENRESOURCE
@endnode

@node PacketDebugger
@title "PacketDebugger command"

Command: PACKETDEBUGGER
         NOPACKETDEBUGGER
@endnode

@node Pause
@title "Pause command"

Command: PAUSE

Pauses Snoopium and monitored tasks won't proceed until Snoopium is
UNPAUSEd or SINGLESTEP action is taken.
@endnode

@node Quit
@title "Quit command"

Command: QUIT
@endnode

@node ReadToolTypes
@title "ReadToolTypes command"

Command: READTOOLTYPES
         NOREADTOOLTYPES
@endnode

@node Rename
@title "Rename command"

Command: RENAME
         NORENAME
@endnode

@node RunCommand
@title "RunCommand command"

Command: RUNCOMMAND
         NORUNCOMMAND
@endnode

@node SaveBuffer
@title "SaveBuffer command"

Command: SAVEBUFFER "filename"

Example: SAVEBUFFER "ram:Snoopium.txt"
@endnode

@node SaveDefSettings
@title "SaveDefSettings command"

Command: SAVEDEFSETTINGS
@endnode

@node SaveSettings
@title "SaveSettings command"

Command: SAVESETTINGS "settingsfile"

Example: SAVESETTINGS "ram:Snoopium.prefs"
@endnode

@node SendRexx
@title "SendRexx command"

Command: SENDREXX
         NOSENDREXX
@endnode

@node Settings
@title "Settings command"

Command: SETTINGS="name"

Example: SETTINGS="ENVARC:Snoopium.prefs"
@endnode

@node SetupWindowPos
@title "SetupWindowPos command"

Command: SETUPWINDOWPOS=<left>,<top>

Example: SETUPWINDOWPOS=0,20
@endnode

@node SetVar
@title "SetVar command"

Command: SETVAR
         NOSETVAR
@endnode

@node ShowCLI
@title "ShowCLI command"

Command: SHOWCLI
         NOSHOWCLI
See also: @{" Command Index " link CommandIndex}
@endnode

@node ShowFullPaths
@title "ShowFullPaths command"

Command: SHOWFULLPATHS
         NOSHOWFULLPATHS

@endnode

@node SingleStep
@title "SingleStep command"

Command: SINGLESTEP
@endnode

@node System
@title "System command"

Command: SYSTEM
         NOSYSTEM

Enables or disables monitoring of the System() dos.library call.
@endnode

@node TaskPri
@title "TaskPri command"

Command: TASKPRI <n>

Example: TASKPRI 5

Valid range is -20...20
@endnode

@node Unpause
@title "Unpause command"

Command: UNPAUSE
@endnode

@node UseDeviceNames
@title "UseDeviceNames command"

Command: USEDEVICENAMES
         NOUSEDEVICENAMES

Enables or disables UseDeviceNames setting.
@endnode

