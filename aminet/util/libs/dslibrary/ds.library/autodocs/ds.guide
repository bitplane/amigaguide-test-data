@NODE "DS_BTreeOpen" "ds.library/DS_BTreeOpen()"
@{b}

   NAME@{ub}
        DS_BTreeOpen -- open or create a new b-tree on disk (V37)@{b}

   SYNOPSIS@{ub}
        result = DS_BTreeOpen(btree,filename,keysize,datasize,comparefunction);
        D0                    D1    D2       D3      D4       D5

        int DS_BTreeOpen(@{"BTREE" LINK "libraries/ds.h/File" 24} *, char *, int, int, (*int)(void *,void *) );@{b}

   FUNCTION@{ub}
        Opens or creates a b-tree on disk with the filename and the corresponding
        keysize and datasize. The comparefunction is used to compate two keys/entries.@{b}

   INPUTS@{ub}
        btree    - a pointer to a variable of type @{"BTREE" LINK "libraries/ds.h/File" 24}
        keysize  - an integer value telling the size of the key
        datasize - an integer value for the size of the whole data structure to
                    be stored in the file
        comparefunction - a pointer to a function awaiting two parameters; this
                    function returns 1 if argument 1 is greater than argument 2,
                    it returns 0 if both arguments are equal, and it return -1 else.@{b}

   RESULT@{ub}
        result  - 1 if the b-tree could be opened or created,
                    0 if something went wrong@{b}

   SEE ALSO@{ub}
        @{"DS_BTreeClose" LINK "DS_BTreeClose"}

@ENDNODE
@NODE "DS_BTreeClose" "ds.library/DS_BTreeClose()"
@{b}

   NAME@{ub}
        DS_BTreeClose -- close a b-tree on disk@{b}

   SYNOPSIS@{ub}
        DS_BTreeClose(btree)
                      D1

        void DS_BTreeClose(@{"BTREE" LINK "libraries/ds.h/File" 24});@{b}

   INPUTS@{ub}
        btree - the tree to be closed.@{b}

   RESULT@{ub}
        none@{b}

   SEE ALSO@{ub}
        @{"DS_BTreeOpen()" LINK "DS_BTreeOpen"}

@ENDNODE
@NODE "DS_BTreeInsert" "ds.library/DS_BTreeInsert()"
@{b}

   NAME@{ub}
        DS_BTreeInsert -- insert a node into the b-tree@{b}

   SYNOPSIS@{ub}
        result = @{"DS_BTreeClose" LINK "DS_BTreeClose"}(btree,key,data)
        D0                     D1    D2  D3

        int @{"DS_BTreeClose" LINK "DS_BTreeClose"}(@{"BTREE" LINK "libraries/ds.h/File" 24}, void *, void *);@{b}

   INPUTS@{ub}
        btree   - the b-tree on disk
        key     - a pointer to the key of the data to be inserted.
        data    - a pointer to the the data structure to be inserted.@{b}

   RESULT@{ub}
        result  - 1 if key could be inserted.
                    0 if key was already present in b-tree@{b}

   SEE ALSO@{ub}
        @{"DS_BTreeDelete()" LINK "DS_BTreeDelete"}

@ENDNODE
@NODE "DS_BTreeDelete" "ds.library/DS_BTreeDelete()"
@{b}

   NAME@{ub}
        DS_BTreeDelete -- delete a node from a b-tree on disk@{b}

   SYNOPSIS@{ub}
        result = @{"DS_BTreeClose" LINK "DS_BTreeClose"}(btree, key)
        D0                     D1     D2

        int @{"DS_BTreeClose" LINK "DS_BTreeClose"}(@{"BTREE" LINK "libraries/ds.h/File" 24}, void *);@{b}

   INPUTS@{ub}
        btree   - the b-tree on disk
        key     - a pointer to the key of the data structure to be deleted.@{b}

   RESULT@{ub}
        result  - 1 if key is deleted
                    0 if key was not in the b-tree@{b}

   SEE ALSO@{ub}
        @{"DS_BTreeInsert()" LINK "DS_BTreeInsert"}

@ENDNODE
@NODE "DS_BTreeGetEntry" "ds.library/DS_BTreeGetEntry()"
@{b}

   NAME@{ub}
        DS_BTreeGetentry -- get an entry from a b-tree on disk@{b}

   SYNOPSIS@{ub}
        result = @{"DS_BTreeClose" LINK "DS_BTreeClose"}(btree, key, buffer)
        D0                     D1     D2   D3

        int @{"DS_BTreeClose" LINK "DS_BTreeClose"}(@{"BTREE" LINK "libraries/ds.h/File" 24}, void *, void *);@{b}

   INPUTS@{ub}
        btree   - the b-tree on disk
        key     - a pointer to the key of the data structure to get.
        memory  - a pointer to a memory area where the data will be copied to.
                    rememer: this area MUST be large enough !@{b}

   RESULT@{ub}
        result  - 1 if key was found and data copied
                    0 if key was not in the b-tree@{b}

   SEE ALSO@{ub}
        @{"DS_BTreeInsert()" LINK "DS_BTreeInsert"}, @{"DS_BTreeDelete()" LINK "DS_BTreeDelete"}

@ENDNODE
