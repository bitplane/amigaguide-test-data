@node oStrStr "OpenUtil.library / String Functions / oStrStr()"

  NAME
        oStrStr -- Find a string in another string


  SYNOPSIS
        oStrStr (Source, MatchString)
                   A0         A1

        STRPTR oStrStr (STRPTR, STRPTR)

  FUNCTION
        Find MatchString in the Source string. If a match is found, Result points
        to the first match inside the Source string. If no match was found, Result
        will be NULL. This function is not case-sensitive.

  INPUTS
        Source      - The source string.

        Matchstring - The string which to search for.

  RESULT
        NewString   - A pointer to the match position in the search string
                      or NULL if nothing was found.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oStrStrCase() " link "oStrStrCase"}, @{" oStrLeft() " link "oStrLeft"}, @{" oStrRight() " link "oStrRight"}, @{" oStrChr() " link "oStrChr"},
@endnode
@node oStrStrCase "OpenUtil.library / String Functions / oStrStrCase()"

  NAME
        oStrStrCase -- Find a string in another string


  SYNOPSIS
        oStrStrCase (Source, MatchString)
                       A0         A1

        STRPTR oStrStrCase (STRPTR, STRPTR)

  FUNCTION
        Find a string in a string. If a match is found, Result points to the
        first match inside the string. If no match was found, Result will be
        NULL. This function is case-sensitive.

  INPUTS
        Source      - The source string.

        Matchstring - The string which to search for.

  RESULT
        NewString   - A pointer to the string position of the search string
                      or NULL if nothing was found.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oStrStr() " link "oStrStr"}, @{" oStrLeft() " link "oStrLeft"}, @{" oStrRight() " link "oStrRight"}, @{" oStrChr() " link "oStrChr"},
@endnode
@node oStrTo64 "OpenUtil.library / String Functions / oStrTo64()"

  NAME
        oStrTo64 -- Convert a decimal string to a 64-Bit number

  SYNOPSIS
        oStrTo64 (String, DestHi, DestLo)
                    A0      A1      A2

        long oStrTo64 (STRPTR, ULONG *, ULONG *)

  FUNCTION
        Converts a decimal string to a 64-Bit (QUAD-WORD) value.

        Like dos.library/StrToLong(), leading TABs and Spaces get
        skipped; then, all numeric chars get converted until the
        string ends or any non-numeric char is detected.

  INPUTS
        String  - The string to convert.

        DestHi  - A pointer to a ULONG which receives the upper 32 bits
                  of the destination value

        DestLo  - A pointer to a ULONG which receives the lower 32 bits
                  of the destination value.

  RESULT
        long    - Number of decimal characters converted. If NULL, nothing
                  was converted, and DestHi & DestLo are set to NULL. Else,
                  DestHi & DestLo contain the converted value. A Result of
                  NULL indicates that no numeric chars were found or the
                  value is still too large for 64 bits.
  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oNum64ToStr() " link "oNum64ToStr"}
@endnode
@node oStrToLower "OpenUtil.library / String Functions / oStrToLower()"

  NAME
        oStrToLower -- lower-case a string


  SYNOPSIS
        oStrToLower (String, MaxLen)
                       A0      D0

        STRPTR oStrToLower (STRPTR, ULONG)

  FUNCTION
        Lower-case a string. Result is the same string as passed.

  INPUTS
        String  - The string to convert.

        MaxLen  - Maximum number of chars to convert. Conversion ends when
                  MaxLen is reached or the Source string ends.

  RESULT
        String  - A pointer to the converted string (same as input).

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oStrToUpper() " link "oStrToUpper"}
@endnode
@node oStrToUpper "OpenUtil.library / String Functions / oStrToUpper()"

  NAME
        oStrToUpper -- upper-case a string


  SYNOPSIS
        oStrToUpper (String, MaxLen)
                       A0      D0

        STRPTR oStrToUpper (STRPTR, ULONG)

  FUNCTION
        Upper-case a string. Result is the same string as passed.

  INPUTS
        String  - The string to convert.

        MaxLen  - Maximum number of chars to convert. Conversion ends when
                  MaxLen is reached or the Source string ends.

  RESULT
        String  - A pointer to the converted string (same as input).

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oStrToLower() " link "oStrToLower"}
@endnode
@node oSubU64 "OpenUtil.library / Math Functions / oSubU64()"

  NAME
        oSubU64       -- perform a QuadWord (64-bit) subtraction

  SYNOPSIS
        oSubU64 (SrcHi, SrcLo, DestHi, DestLo)
                   D0     D1     A0      A1

        long oSubU64 (ULONG, ULONG, ULONG *, ULONG *)

  FUNCTION
        Subtracts a 64-bit value (SrcHi/SrcLo) from another (DestHi/DestLo).

  INPUTS
        SrcHi           - The upper 32 bits of the 64-bit value to subtract.

        SrcLo           - The lower 32 bits of the 64-bit value to subtract.

        DestHi          - A pointer to the upper 32 bits (ULONG) of the second
                          (destination) value where to subtract the first number
                          from.

        DestLo          - A pointer to the lower 32 bits of the destination
                          value.

  RESULT
        Underflow       - BOOL. TRUE signals an underflow, which happens when
                          Src is greater than Dest.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{"oAddU64()" link "oAddU64"}, @{" oMulU64L() " link "oMulU64L"}, @{" oDivU64L() " link "oDivU64L"}
@endnode
@node oSuggestWindowPosA "OpenUtil.library / User Interface / oSuggestWindowPosA()"

  NAME
        oSuggestWindowPosA  -- Suggest x/y position for a Window
        oSuggestWindowPos   -- varargs stub for oSuggestWindowPosA()

  SYNOPSIS
        oSuggestWindowPosA (Screen, WindowLeft, WindowTop, Width, Height, Tags)
                              A0        A1          A2       D0     D1     A3

        oSuggestWindowPos  (Screen, WindowLeft, WindowTop, Width, Height, FirstTag, ...)

        long oSuggestWindowPosA (struct Screen *, ULONG *, ULONG *, ULONG, ULONG, struct TagItem *)

        long oSuggestWindowPos  (struct Screen *, ULONG *, ULONG *, ULONG, ULONG, Tag, ...)

  FUNCTION
        This function is mostly used with temporary or application-independent
        Windows, such as Requesters. oSuggestWindowPosA() suggests an x/y position
        for opening such Windows, in relation to a passed Screen.

  INPUTS
        Screen          - The Screen where to open the Window. Must be a valid
                          Screen pointer.

        WindowLeft      - A pointer to a ULONG which receives the x-position.

        WindowTop       - A pointer to a ULONG which receives the y-position.

                          Let WindowLeft & WindowTop point to the ti_Data fields
                          of your WA_Left & WA_Top Tags and you're set.

        Width           - The overall width of the Window.

        Height          - The overall height of the Window.

        Tags            - Currently, there's only one Tag defined, but using
                          Tags here will keep future flexibility.

                        oSWP_MouseGadget

                          (struct Gadget *). This Tag awaits an already created
                          Gadget to use with the Window. This Gadget should be
                          your "default" user interaction Gadget. The Window
                          will then be placed with the passed Gadget appearing
                          under the Mouse Pointer, or as close as possible
                          without placing the Window outside the passed Screen.
                          If this Tag isn't used, the Window gets centered on
                          the passed Screen.

  RESULT
        void            - WindowLeft and WindowTop get set with the suggested
                          Window position.

  EXAMPLE

        C:

        // we have already opened a Screen (or locked the Default Public Screen),
        // created all Gadgets etc. and now we're going to open the Window.

        struct Screen * myScreen;
        struct Gadget * myDefaultGadget;
        struct Window * myWindow;

        // The Window position is stored directly in the Window's TagList:

        struct TagItem myWindowTags [] =
        {
          {WA_Left,     0},
          {WA_Top,      0},
          {WA_Width,  400},
          {WA_Height, 200},
          {TAG_DONE}
        };

        oSuggestWindowPos(myScreen,
                          &myWindowTags[0].ti_Data,   /* points to WA_Left.ti_Data */
                          &myWindowTags[1].ti_Data);  /* points to WA_Top.ti_Data */
                          myWindowTags[2].ti_Data,    /* Window width  */
                          myWindowTags[3].ti_Data,    /* Window height */
                          oSWP_MouseGadget, myDefaultGadget,
                          TAG_DONE);

        oOpenWindowTagList(0,myWindowTags);

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)
@endnode
@node oSwap16 "OpenUtil.library / Misc. Functions / oSwap16()"

  NAME
        oSwap16 -- Swap the upper 16 bits with the lower 16 bits of a 32-bit value

  SYNOPSIS
        oSwap16 (Value)
                   D0

        ULONG oSwap16 (ULONG)

  FUNCTION
        This very simple thing does nothing more than swapping the upper word
        with the lower word of a 32-bit variable.

        May be useful when working with WORD pairs and if Assembler isn't
        available or wanted.

  INPUTS
        Value           - Anything which has 32-bit size

  RESULT
        NewValue        - The passed Value, swapped.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)
@endnode
@node oTextHeight "OpenUtil.library / String Functions / oTextHeight()"

  NAME
        oTextHeight -- get the number of text lines in an ASCII string

  SYNOPSIS
        oTextHeight (String)
                       A0

        ULONG oTextHeight (STRPTR)

  FUNCTION
        This function counts the number of text lines in a given string.

  INPUTS
        String          - the string where to count the text lines

  RESULT
        NumLines        ULONG. Number of text lines in the passed String.
                        Note that the last char in the String gets skipped if
                        it's a LineFeed character, so the blank line at the
                        bottom doesn't count.
                        
  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oTextWidth() " link "oTextWidth"}
@endnode
@node oTextWidth "OpenUtil.library / String Functions / oTextWidth()"

  NAME
        oTextWidth -- get the length of the longest text line in an ASCII string

  SYNOPSIS
        oTextWidth (String)
                      A0

        ULONG oTextWidth (STRPTR)

  FUNCTION
        This function counts the number of chars in the longest text line
        of a given string, which is the overall text width for that string.

  INPUTS
        String          - the string where to get the width of

  RESULT
        NumChars        ULONG. All but Line Feed characters count.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oTextHeight() " link "oTextHeight"}
@endnode
@node oUnlockWindow "OpenUtil.library / User Interface / oUnlockWindow()"

  NAME
        oUnlockWindow      -- Re-enable user input in a locked Window

  SYNOPSIS
        oUnlockWindow (WindowLock)
                           A0

        void oUnlockWindow (struct oWindowLock *)

  FUNCTION
        This function unlocks a Window which was locked using @{"oLockWindow()" link "oLockWindow"};
        the oWindowLock gets freed back to memory.

  INPUTS
        WindowLock      - An oWindowLock structure, as returned by @{"oLockWindow()" link "oLockWindow"}.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oLockWindow() " link "oLockWindow"}
@endnode
@node oUpdateMsgWait "OpenUtil.library / User Interface / oUpdateMsgWait()"

  NAME
        oUpdateMsgWait   -- Update the Status Bar in a MsgWait Window

  SYNOPSIS
        oUpdateMsgWait (MsgWait, Value)
                           A0      D0

        long oUpdateMsgWait (struct oMsgWait *, ULONG)

  FUNCTION
        Updates the Status Bar in an oMsgWait Window to the current state.

  INPUTS
        MsgWait         - oMsgWait structure, as created by @{"oOpenMsgWaitA()" link "oOpenMsgWaitA"}.

        Value           - New current value. If >= MaxValue, the Status Bar
                          gets drawn in full size. To reset the Status Bar
                          for re-use pass NULL here.

  RESULT
        LastAction      0 = Normal exit. If the oMsgWait Window was opened without
                            a GadgetText passed, this is the only possible Result.

                            If an action Gadget is used, Result can also be one of:

                        1 = The action Gadget was clicked (by mouse or hotkey).

                       -1 = The Window's CloseGadget was clicked.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oOpenMsgWaitA() " link "oOpenMsgWaitA"}, @{" oCloseMsgWait() " link "oCloseMsgWait"}, 
        @{" oUpdateStatusBar() " link "oUpdateStatusBar"}
@endnode
@node oUpdateStatusBar "OpenUtil.library / User Interface / oUpdateStatusBar()"

  NAME
        oUpdateStatusBar  -- Update a Status Bar with a new progress value

  SYNOPSIS
        oUpdateStatusBar (StatusBar, Value)
                             A0        D0

        void oUpdateStatusBar (struct oStatusBar *, ULONG)

  FUNCTION
        This function is used for updating a Status Bar to the current progress
        state.

  INPUTS
        StatusBar       - oStatusBar structure.

        Value           - New current value. If >= MaxValue, the Status Bar
                          gets drawn in full size. To reset a Status Bar
                          for re-use pass NULL here.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oCreateStatusBarA() " link "oCreateStatusBarA"}, @{" oDeleteStatusBar() " link "oDeleteStatusBar"},
        @{" oUpdateMsgWait() " link "oUpdateMsgWait"}, 
@endnode
