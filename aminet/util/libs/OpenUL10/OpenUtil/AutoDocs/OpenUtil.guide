@$VER: OpenUtil.library AmigaGuide documentation 1.0
@node oAddU64 "OpenUtil.library / Math Functions / oAddU64()"
@prev Main

  NAME
        oAddU64       -- perform a QuadWord (64-bit) addition

  SYNOPSIS
        oAddU64 (SrcHi, SrcLo, DestHi, DestLo)
                   D0     D1     A0      A1

        long oAddU64 (ULONG, ULONG, ULONG *, ULONG *)

  FUNCTION
        Adds a 64-bit value (SrcHi/SrcLo) to another (DestHi/DestLo).

  INPUTS
        SrcHi           - The upper ULONG (32 bits) of the 64-bit value to add.

        SrcLo           - The lower ULONG (32 bits) of the 64-bit value to add.

        DestHi          - A pointer to the upper 32 bits (ULONG) of the second
                          (destination) value where to add the first number to.

        DestLo          - A pointer to the lower 32 bits of the destination
                          value.

  RESULT
        Overflow        - BOOL. TRUE if an overflow occured (64-bit boundary
                          of the Destination value exceeded).

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oSubU64() " link "oSubU64"}, @{" oMulU64L() " link "oMulU64L"}, @{" oDivU64L() " link "oDivU64L"}
@endnode
@node oAddExecHeader "OpenUtil.library / List Functions / oAddExecHeader()"

  NAME
        oAddExecHeader   -- Add an Exec List Header to a Node chain

  SYNOPSIS
        oAddExecHeader (MemPool, FirstNode)
                           A0        A1

        struct List * oAddExecHeader (void *, struct Node *)

  FUNCTION
        This function allocates & initializes an Exec List Header and links
        it with a passed Node chain to a full Exec List.

  INPUTS
        MemPool    - An Exec Memory Pool for allocating the List Header,
                     or NULL (using the system main memory instead).

        FirstNode  - An Exec Node (chain). You may pass NULL here, which
                     returns an initialized, empty Exec List, which can also be
                     done (easier) using @{" oCreateList() " link "oCreateList"}.

  RESULT
        List       - Exec List Header where the passed Node chain is linked to,
                     or NULL if out of Memory.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oRemExecHeader() " link "oRemExecHeader"}
@endnode
@node oAllocVecPooledA "OpenUtil.library / Memory Functions / oAllocVecPooledA()"

  NAME
        oAllocVecPooledA -- AllocVec() from main memory or any Exec Memory Pool
        oAllocVecPooled  -- varargs stub for oAllocVecPooledA()

  SYNOPSIS
        oAllocVecPooledA (PoolHeader, MemSize, Flags)
                              A0         D0      D1

        oAllocVecPooled  (PoolHeader, MemSize, ...)

        void * oAllocVecPooledA (void *, ULONG, ULONG *)

        void * oAllocVecPooled  (void *, ULONG, ...)

  FUNCTION
        This is the general allocation function which is used by all OpenUtil
        functions which allocate any kind of memory. It supplies AllocVec() style
        allocations from either the system main memory or any other Exec Memory
        Pool. The memory returned by oAllocVecPooledA() is guaranteed to be
        QUADWORD (64-bit) aligned.

  INPUTS
        PoolHeader - Exec Memory Pool created using CreatePool(), or NULL if
                     you want to allocate from the system main memory, where
                     oAllocVecPooledA() will use AllocVec() instead.

        MemSize    - Required memory size in bytes

        Flags      - (ULONG *) If you pass NULL for PoolHeader, you must pass your
                     desired MemAttrs here for AllocVec(). If using a Pool, the
                     Flags are ignored, because they were already set when the
                     pool was created.

  RESULT
        Memory     - The allocated memory (QUADWORD aligned) or NULL.

  NOTES
        oAllocVecPooledA() has an allocation overhead of 12-16 bytes each allocation,
        so keep in mind that ThreshSize must be at least 16 bytes smaller than
        PuddleSize when calling CreatePool() !

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oFreeVecPooled() " link "oFreeVecPooled"}
@endnode
@node oAllTrim "OpenUtil.library / String Functions / oAllTrim()"

  NAME
        oAllTrim   -- Strip leading & trailing TAB and SPACE chars from a string

  SYNOPSIS
        oAllTrim (String)
                    A0

        STRPTR oAllTrim (STRPTR)

  FUNCTION
        This function removes all TAB and SPACE characters from the left and
        the right side of a given string.

  INPUTS
        String     - The string to trim

  RESULT
        String     - The modified string (address equal to input)

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oLTrim() " link "oLTrim"}, @{" oRTrim() " link "oRTrim"}
@endnode
@node oAtol "OpenUtil.library / String Functions / oAtol()"

  NAME
        oATol -- Convert a string to a long value using StrToLong().

  SYNOPSIS
        oATol (String)
                 A0

        long oAtol (STRPTR)

  FUNCTION
        This function converts a string to a long value. It's a simplified
        StrToLong() replacment.

  INPUTS
        String      - The string to convert.

  RESULT
        A numeric value or NULL if string contains non-numeric chars.
        Same rules as with StrToLong().

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oStrTo64() " link "oStrTo64"}, @{" oNumToStr() " link "oNumToStr"}, @{" oNum64ToStr() " link "oNum64ToStr"}
@endnode
@node oBuildDirInfoA "OpenUtil.library / File Operations / oBuildDirInfoA()"

  NAME
        oBuildDirInfoA       -- create directory tree information
        oBuildDirInfo        -- varargs stub for oBuildDirInfoA()

  SYNOPSIS
        oBuildDirInfoA (DirLock, Tags)
                           A0     A1

        oBuildDirInfo  (DirLock, FirstTag, ...)

        struct oDirInfo * oBuildDirInfoA (BPTR, struct TagItem *)

        struct oDirInfo * oBuildDirInfo  (BPTR, Tag, ...)

  FUNCTION
        oBuildDirInfoA() creates a structure which contains information about
        how many files, dirs & bytes are stored in the passed directory.
        Optional, a full directory tree can be created.

  INPUTS
        DirLock    - A directory Lock, shared or exclusive.

        Tags       - The following Tags may be passed:

            oBDI_BuildDirTree

                BOOL. If TRUE, oBuildDirInfoA() builds a directory tree,
                which is stored in the DirTree field of the returned oDirInfo
                structure. For more information about the oDirInfo & oDirEntry
                structures please refer to include:libraries/OpenUtil.h.
                Default: FALSE (don't build DirTree).

            oBDI_MatchAny

                STRPTR. Only entries which contain the passed string at any
                position get added to the oDirInfo file & byte counts, and
                (if used) to the DirTree.

            oBDI_MatchBegin

                STRPTR. Only entries which begin with the passed string
                get added to the oDirInfo file & byte counts, and (if used)
                to the DirTree.

            oBDI_MatchEnd

                STRPTR. Only entries which end with the passed string
                get added to the oDirInfo file & byte counts, and (if used)
                to the DirTree.

            oBDI_MatchExact

                STRPTR. Only entries of the specified name get added to the
                oDirInfo file & byte counts, and (if used) to the DirTree.

            oBDI_MatchPattern

                STRPTR. A file pattern string may be passed here, which affects
                both the oDirEntry info and (if oBDI_BuildDirTree is set) the
                DirTree. Entries which do not match the pattern get skipped.
                Provide 2 KB Stack space when using a pattern; especially when
                scanning dirs recursively.

            oBDI_CaseSensitive

                BOOL. Used together with one of the oBDI_MatchXxx Tags for file
                name filtering. If TRUE, match is case-sensitive. Default: FALSE.

            oBDI_Recursive

                BOOL. If TRUE, the passed directory is scanned recursively with
                all sub-dirs & files, else only the contents of the passed
                directory itself get processed, which affects the ByteCount,
                FileCount, DirCount and DirTree fields of the returned oDirInfo
                structure. Default: FALSE (no recursion).

            oBDI_ScanInfoHook

                struct Hook *. This one points to a Hook which receives the name
                of the directory which is currently scanned. Useful when scanning
                a high-level directory with tons of entries to show up that your
                application is still alive and working. You may also use the Hook
                for aborting the scan. If your ScanInfoHook returns FALSE (abort),
                oBuildDirInfoA() sets IoErr to ERROR_BREAK. If you're also using
                an Error Hook, note that a user break also calls the Error Hook.

                Hook example (as defined in include:utility/hooks.h):

                ULONG __saveds __asm ScanInfoHookEntry (register __a0 struct Hook * hook,
                                                        register __a2 APTR          object,
                                                        register __a1 APTR          message);
                {
                  Printf("%s\n", object);

                  if (UserHasAborted)
                  {
                    return(FALSE);      // Stop
                  }
                  return(TRUE);         // Continue
                }

                If oBDI_Recursive isn't set, the ScanInfo Hook is only called once.

            oBDI_ErrorHook

                struct Hook *. This is a pointer to a Hook which is called if
                an error occurs. If the error is of fatal type (bad parameters,
                out of memory etc.), the Error Hook isn't called. Else, it
                receives the file name of dhe directory which is currently
                scanned. The actual error is returned by IoErr() then.

                The Error Hook result informs oBuildDirInfoA() about how to
                go on. It *must* always be one of the values as defined in
                the oBDI_OnError Tag description:

                oBDION_Continue

                  - Continues scanning, gaining as much information as possible.

                oBDION_Break

                  - Breaks the scan at the current position and returns the
                    oDirInfo structure as-is.

                oBDION_Abort

                  - Completely aborts, freeing back all ressources.

                Error Hook example:

                ULONG __saveds __asm ErrorHookEntry (register __a0 struct Hook * hook,
                                                     register __a2 APTR          object,
                                                     register __a1 APTR          message);
                {
                  oMsgFault("File Error", "Error while scanning %s", object);

                  if (HardDisk_Is_Damaged_But_We_Must_Get_What_We_Can)
                  {
                    return(oBDI_Continue);
                  }
                  else if (Shit_But_Lets_See_What_We_Have)
                  {
                    return(oBDI_Break);
                  }
                  else /* if (All_Or_Nothing) */
                  {
                    return(oBDION_Abort);
                  }
                }

                If oBDI_Recursive isn't set, the ScanInfo Hook is only called once.

            oBDI_SortOrder

                ULONG. The DirTree created by oBuildDirInfoA() comes always
                alphabetically sorted. With this Tag, you may choose a primary
                sort order, which may be one of:

                oBDISO_DirsFirst   - Directories first

                oBDISO_FilesFirst  - Files first

                oBDISO_Mixed       - Strictly sorted, files & dirs mixed

                Ignored if oBDI_BuildDirTree isn't set. Default: oBDISO_Mixed.

            oBDI_NoDirs

                BOOL. If TRUE, directories get skipped (from adding to the
                oDirInfo->DirCount and, if used, from adding to the directory
                tree). Only files get added (with full path). Default: FALSE.

            oBDI_NoFiles

                BOOL. If TRUE, files get skipped (from adding to oDirInfo->FileCount
                & ByteCount and, if used, from adding to the directory tree).
                oBDI_NoDirs and oBDI_NoFiles exclude each other; if both are set
                to TRUE, oBuildDirInfoA() returns NULL. Default: FALSE.

            oBDI_OnError

                ULONG. There are several things which may happen when trying
                to scan a directory. oBuildDirInfoA() always fails when running
                out of memory, where all ressources get freed back immediately
                and IoError gets set to ERROR_NO_FREE_STORE.

                For other errors, the oBDI_OnError Tag allows to specify what to
                do in such cases. For example, this could be ERROR_OBJECT_IN_USE
                when trying to examine a write-locked sub-directory (recursively).
                Another error source may be a real filing system problem or a
                disk read error. However, this Tag provides three ways to react:

                oBDION_Continue

                  - Continues scanning, gaining as much information as possible.

                oBDION_Break

                  - Breaks the scan at the current position and returns the
                    oDirInfo structure as is.

                oBDION_Abort

                  - Completely aborts, freeing back all ressources.

                Default: oBDION_Abort.

                Note: the return code of an Error Hook, if used, overrides the
                oBDI_OnError Tag. This Tag is useful when not using an Error Hook.

  RESULT
        oDirInfo        - An oDirInfo structure, filled with all requested
                          information, or NULL on failure. Use IoErr() to
                          get information about the error. The oDirInfo structure
                          must be freed using @{"oFreeDirInfo()" link "oFreeDirInfo"}.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oFreeDirInfo() " link "oFreeDirInfo"}
@endnode
@node oChrCut "OpenUtil.library / String Functions / oChrCut()"

  NAME
        oChrCut -- cut a string at search char position

  SYNOPSIS
        oChrCut (String, CutChar, MaxRange)
                   A0       D0       D1

        STRPTR oChrCut (STRPTR, UBYTE, ULONG)

  FUNCTION
        Cut a string at the first position of a specified char.
        The CutChar is searched inside the source string; if a match is
        found, the right part of the source string gets cut at that position.
        If nothing was found, nothing gets changed. This function is not
        case-sensitive.

  INPUTS
        String          - The string to truncate

        CutChar         - The char to search for

        MaxRange        - the maximum string length to search for the Char,
                          which normally is sizeof(String).

  RESULT
        Result points to the (new) end position of the passed string, no
        matter if the CutChar was found or not. Result always points to
        the trailing NULL byte of the string.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oChrCutCase() " link "oChrCutCase"}, @{" oStrCut() " link "oStrCut"}
@endnode
@node oChrCutCase "OpenUtil.library / String Functions / oChrCutCase()"

  NAME
        oChrCutCase -- cut a string at a search char position

  SYNOPSIS
        oChrCutCase (String, CutChar, MaxRange)
                       A0      D0        D1

        STRPTR oChrCutCase (STRPTR, UBYTE, ULONG)

  FUNCTION
        Cut a string at the first position of a specified char.
        The CutChar is searched inside the source string; if a match is
        found, the right part of the source string gets cut at that position.
        If nothing was found, nothing gets changed. This function is case-
        sensitive.

  INPUTS
        String          - The string to truncate

        CutChar         - The char to search for

        MaxRange        - the maximum string length to search for the Char,
                          which normally is sizeof(String).

  RESULT
        Result points to the (new) end position of the passed string, no
        matter if the CutChar was found or not. Result always points to
        the trailing NULL byte of the string.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oChrCut() " link "oChrCut"}, @{" oStrCut() " link "oStrCut"}
@endnode
@node oClearList "OpenUtil.library / List Functions / oClearList()"

  NAME
        oClearList      -- delete all records in an Exec List

  SYNOPSIS
        oClearList (Base)
                     A0

        struct List * oClearList (struct List *)

  FUNCTION
        This function empties an exec List and frees all records by calling
        @{"oFreeVecPooled()" link "oFreeVecPooled"}. So all List Nodes (records) must have been allocated
        using @{"oAllocVecPooledA()" link "oAllocVecPooledA"} or any other OpenUtil function.

  INPUTS
        Base            - Exec List (may be empty).

  RESULT
        The passed List (emptied).

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oDeleteList() " link "oDeleteList"}, @{" oCutList() " link "oCutList"}, @{" oRemExecHeader() " link "oRemExecHeader"}
@endnode
@node oClearMem "OpenUtil.library / Memory Functions / oClearMem()"

  NAME
        oClearMem   -- Clear a memory block

  SYNOPSIS
        oClearMem (Buffer, Size)
                    A0      D0

        APTR oClearMem (APTR, ULONG)

  FUNCTION
        This function clears a memory block by filling it with null-bytes.

  INPUTS
        Buffer     - The Buffer to clear.

        Size       - Number of bytes; may be odd.

  RESULT
        Buffer     - The Buffer you've passed.

  NOTES
        This function uses @{"oFillMem()" link "oFillMem"} for clearing a buffer, which is optimized
        for larger buffers.

  BUGS
        Due to function internal reasons, Size is currently limited to 13.631.280
        bytes, so if you're working with a Buffer larger than approx. 12MB, you'll
        need to call this function twice or several times.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oFillMem() " link "oFillMem"}
@endnode
