@node oStrLeft "OpenUtil.library / String Functions / oStrLeft()"

  NAME
        oStrLeft     -- extract the left part of a string

  SYNOPSIS
        oStrLeft (Source, Destination, MaxLen)
                    A0        A1         D0

        STRPTR oStrLeft (STRPTR, STRPTR, ULONG)

  FUNCTION
        This function copies the left part of a string to a destination buffer.

  INPUTS
        Source          - Source string where to extract from.

        Destination     - Destination (string) buffer where to copy to

        MaxLen          - Maximum number of chars to copy. Copying ends when
                          MaxLen is reached or the Source string ends.

  RESULT
        Destination     - (STRPTR). The new Destination string.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oStrRight() " link "oStrRight"}, @{" oStrMid() " link "oStrMid"}
@endnode
@node oStrLen "OpenUtil.library / String Functions / oStrLen()"

  NAME
        oStrLen      -- Return the length of a string

  SYNOPSIS
        oStrLen (String)
                   A0

        ULONG oStrLen (STRPTR)

  FUNCTION
        This function returns the length of a given string. Note that ANSI-C
        strlen() is slightly faster when compiled as inline function, of course.

  INPUTS
        String        - The string to count

  RESULT
        Length        - The string length in bytes.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)
@endnode
@node oStrMid "OpenUtil.library / String Functions / oStrMid()"

  NAME
        oStrMid -- extract a sub string from a string

  SYNOPSIS
        oStrMid (Source, Destination, StartPos, MaxChars)
                   A0         A1         D0        D1

        STRPTR oStrMid (STRPTR, STRPTR, ULONG, ULONG)

  FUNCTION
        oStrMid() copies a part of the passed source string to the Destination.
        A maximum of MaxChars gets copied, or less if a null-byte was found.
        The destination string is always null-terminated.

        To extract a string's right part, set MaxChars to -1; the left part
        can be extracted by setting StartPos to NULL.

  INPUTS
        Source        - The source string.

        Destination   - The destination string.

        StartPos      - Start position (Source offset) for copying.

        MaxChars      - Maximum number of chars to copy.

  RESULT
        NewString     - The passed Destination string. If StartPos points beyond
                        the Source string, NewString will be valid, but empty.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oStrLeft() " link "oStrLeft"}, @{" oStrRight() " link "oStrRight"}
@endnode
@node oStrNComp "OpenUtil.library / String Functions / oStrNComp()"

  NAME
        oStrNComp     -- Compare two strings, non-case-sensitive

  SYNOPSIS
        oStrNComp (Source, Destination, MaxLen)
                     A0        A1         D0

        STRPTR oStrNComp (STRPTR, STRPTR, ULONG)

  FUNCTION
        This function compares two strings, non-case-sensitive.

  INPUTS
        Source        - a string

        Destination   - another string

        MaxLen        - Maximum compare length. If the first <MaxLen> chars
                        are equal, oStrNComp() returns NULL (equality).

  RESULT
        long          0 if both strings are equal,
                      1 if Source (String 1) is higher,
                     -1 if Source (String 1) is lower.

  AUTHOR
        Oliver "Bloodrock" Lange (bloodrock@bloody.in-berlin.de)

  SEE ALSO
        @{" oStrNCompCase() " link "oStrNCompCase"}, @{" oStrComp() " link "oStrComp"}
@endnode
