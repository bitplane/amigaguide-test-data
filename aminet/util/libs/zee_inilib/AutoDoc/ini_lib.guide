@NODE "iniGetFloat" "ini.library/iniGetFloat"

@{b}NAME@{ub}
@{fg shine}       @{b}iniGetFloat@{ub} -- Gets a quick floating point value

@{fg text}
@{b}SYNOPSIS@{ub}
       QFloatValue = @{b}iniGetFloat@{ub}( ContextStr, ContextItemLine, Default );
       D0                         A0          A1               D0

       LONG @{b}iniGetFloat@{ub}( struct iniContext *, struct iniContextItemLine *,
           LONG );


@{b}FUNCTION@{ub}
       Reads a quick float value out of the given context item line


@{b}INPUTS@{ub}
       ContextStr - Context structure where quick float value lies in
       ContextItemLine - Context item line where to extract quick float
       Default - Default value to take if it can't be evaluated


RESULT
       QFloatValue - The quick float value extracted out of the context item
           line


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       LONG MyFloat;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       MyFloat = iniGetFloat ( context, contextitem, 0x28000 ));

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 3.0

          then MyFloat will contain 0x30000. If this context or context item
          is not available, MyFloat will contain 0x28000 (default) instead.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniReadFloat" Link "iniReadFloat"}().
       Only the first four fractional digits are evaluated. However, the
       5th digit is evaluated for rounding purposes.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniGetLong" Link "iniGetLong"}(), @{"iniGetStr" Link "iniGetStr"}(), @{"iniGetFloatA" Link "iniGetFloatA"}(), @{"iniPutFloat" Link "iniPutFloat"}(),
       @{"iniReadFloat" Link "iniReadFloat"}(), @{"iniWriteFloat" Link "iniWriteFloat"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniGetFloatA" "ini.library/iniGetFloatA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniGetFloatA@{ub} -- Gets quick floating point value(s) out of an array

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniGetFloatA@{ub}( ContextStr, ContextItemLine, Array, Entries );
       D0                      A0          A1               A2     D0

       BOOL @{b}iniGetFloatA@{ub}( struct iniContext *, struct iniContextItemLine *,
           LONG *, ULONG );


@{b}FUNCTION@{ub}
       Reads one or more quick float value(s) out of the given context item
       line


@{b}INPUTS@{ub}
       ContextStr - Context structure where quick float values lie in
       ContextItemLine - Context item line where to extract quick floats
       Array - The array where to store the quick float values
       Entries - Number of array entries. If the array in the INI file is
            bigger, the remaining entries will be ignored.


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       LONG MyFloat[4] = {-0x10000, -0x8000, 0, 0x8000};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniGetFloatA ( context, contextitem, MyFloat,
                      (sizeof (MyFloat) / sizeof (LONG)) );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 1.0, 1.5, 2.0, 2.5

          then
          MyFloat[4] = {0x10000, 0x18000, 0x20000, 0x28000};
          Entries which can't be evaluated are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniReadFloatA" Link "iniReadFloatA"}().
       Only the first four fractional digits are evaluated. However, the
       5th digit is evaluated for rounding purposes.
       Array fields which can't be evaluated (e.g. bad syntax) are left
       unchanged. So it's good to fill the array with default values first.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniGetLongA" Link "iniGetLongA"}(), @{"iniGetStrA" Link "iniGetStrA"}(), @{"iniGetFloat" Link "iniGetFloat"}(), @{"iniPutFloatA" Link "iniPutFloatA"}(),
       @{"iniReadFloatA" Link "iniReadFloatA"}(), @{"iniWriteFloatA" Link "iniWriteFloatA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniGetLong" "ini.library/iniGetLong"

@{b}NAME@{ub}
@{fg shine}       @{b}iniGetLong@{ub} -- Gets a long integer value

@{fg text}
@{b}SYNOPSIS@{ub}
       LongValue = @{b}iniGetLong@{ub}( ContextStr, ContextItemLine, Default );
       D0                      A0          A1               D0

       LONG @{b}iniGetLong@{ub}( struct iniContext *, struct iniContextItemLine *,
           LONG );


@{b}FUNCTION@{ub}
       Reads a long integer value out of the given context item line


@{b}INPUTS@{ub}
       ContextStr - Context structure where long integer value lies in
       ContextItemLine - Context item line where to extract long integer
       Default - Default value to take if it can't be evaluated


RESULT
       LongValue - The long integer value extracted out of the context item
           line


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       LONG MyLong;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       MyLong = iniGetLong ( context, contextitem, 12345678 );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = -256

          then MyLong will contain -256. If this context or context item
          is not available, MyLong will contain 12345678 (default) instead.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniReadLong" Link "iniReadLong"}().

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniGetFloat" Link "iniGetFloat"}(), @{"iniGetStr" Link "iniGetStr"}(), @{"iniGetLongA" Link "iniGetLongA"}(), @{"iniPutLong" Link "iniPutLong"}(),
       @{"iniReadLong" Link "iniReadLong"}(), @{"iniWriteLong" Link "iniWriteLong"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniGetLongA" "ini.library/iniGetLongA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniGetLongA@{ub} -- Gets long integer value(s) out of an array

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniGetLongA@{ub}( ContextStr, ContextItemLine, Array, Entries );
       D0                     A0          A1               A2     D0

       BOOL @{b}iniGetLongA@{ub}( struct iniContext *, struct iniContextItemLine *,
           LONG *, ULONG );


@{b}FUNCTION@{ub}
       Reads one or more long integer value(s) out of the given context item
       line


@{b}INPUTS@{ub}
       ContextStr - Context structure where long integer values lie in
       ContextItemLine - Context item line where to extract long integers
       Array - The array where to store the long integer values
       Entries - Number of array entries. If the array in the INI file is
            bigger, the remaining entries will be ignored.


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       LONG MyArray[4] = {4096, 65536, 16777216, 2147483647};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniGetLongA ( context, contextitem, MyArray,
                     (sizeof (MyArray) / sizeof (LONG)) );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = -4096, -65536, -16777216, -2147483648

          then
          MyArray[4] = {-4096, -65536, -16777216, -2147483648};
          Entries which can't be evaluated are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniReadLongA" Link "iniReadLongA"}().
       Array fields which can't be evaluated (e.g. bad syntax) are left
       unchanged. So it's good to fill the array with default values first.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniGetFloatA" Link "iniGetFloatA"}(), @{"iniGetStrA" Link "iniGetStrA"}(), @{"iniGetLong" Link "iniGetLong"}(), @{"iniPutLongA" Link "iniPutLongA"}(),
       @{"iniReadLongA" Link "iniReadLongA"}(), @{"iniWriteLongA" Link "iniWriteLongA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniGetNumArrays" "ini.library/iniGetNumArrays"

@{b}NAME@{ub}
@{fg shine}       @{b}iniGetNumArrays@{ub} -- Gets the amount of array fields

@{fg text}
@{b}SYNOPSIS@{ub}
       Arrays = @{b}iniGetNumArrays@{ub}( ContextStr, ContextItemLine );
       D0                        A0          A1

       ULONG @{b}iniGetNumArrays@{ub}( struct iniContext *,
           struct iniContextItemLine *);


@{b}FUNCTION@{ub}
       Returns the amount of array entries in the given context item array.


@{b}INPUTS@{ub}
       ContextStr - Context structure where array lies in
       ContextItemLine - Context item line structure where array starts


RESULT
       Arrays - Number of arrays in the given context item line

@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       WORD *Palette;
       ULONG PaletteEntries;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "Screen" );

       if (!( contextitem = FindContextItem ( context, "Palette" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "Palette" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       PaletteEntries = iniGetNumArrays ( context, contextitem )

       Palette = (WORD *) AllocMem ( PaletteEntries * sizeof (WORD),
                                     MEMF_CHIP|MEMF_PUBLIC|MEMF_CLEAR );

       iniGetWordA ( context, contextitem, Palette, PaletteEntries );


@{b}NOTES@{ub}
@{fg shine}       This function usually is used for dynamic array fields.
       If an error occurs during evaluation, NULL is returned.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniGetLongA" Link "iniGetLongA"}(), @{"iniGetWordA" Link "iniGetWordA"}(), @{"iniGetByteA" Link "iniGetByteA"}(), @{"iniGetFloatA" Link "iniGetFloatA"}(),
       @{"iniGetStrA" Link "iniGetStrA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniGetStr" "ini.library/iniGetStr"

@{b}NAME@{ub}
@{fg shine}       @{b}iniGetStr@{ub} -- Gets a string

@{fg text}
@{b}SYNOPSIS@{ub}
       String = @{b}iniGetStr@{ub}( ContextStr, ContextItemLine, Default );
       D0                  A0          A1               A2

       STRPTR @{b}iniGetStr@{ub}( struct iniContext *, struct iniContextItemLine *,
           STRPTR );

@{b}FUNCTION@{ub}
       Reads a string out of the given context item line


@{b}INPUTS@{ub}
       ContextStr - Context structure where string lies in
       ContextItemLine - Context item line where to extract string
       Default - Default value to take if it can't be evaluated


RESULT
       String - The string extracted out of the context item line


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       STRPTR MyStr;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       MyStr = iniGetStr ( context, contextitem, "MyString" ));

       puts ( MyStr );

       iniFreeNameStr ( MyStr );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = Hello world!

          then MyStr will contain "Hello world!". If this context or context
          item is not available, MyStr will contain "MyString" (default)
          instead.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniReadStr" Link "iniReadStr"}().
       This function calls @{"iniGetContextItemData" Link "iniGetContextItemData"}() with no buffer, this
       means that the string returned must be deallocated with
       @{"iniFreeNameStr" Link "iniFreeNameStr"}()

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniGetContextItemData" Link "iniGetContextItemData"}(), @{"iniGetLongA" Link "iniGetLongA"}(), @{"iniGetFloatA" Link "iniGetFloatA"}(), iniGetStr(),
       @{"iniPutStr" Link "iniPutStr"}(), @{"iniReadStrA" Link "iniReadStrA"}(), @{"iniWriteStrA" Link "iniWriteStrA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniGetStrA" "ini.library/iniGetStrA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniGetStrA@{ub} -- Extracts strings out of an array

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniGetStrA@{ub}( ContextStr, ContextItemLine, Array, Entries );
       D0                    A0          A1               A2     D0

       BOOL @{b}iniGetStrA@{ub}( struct iniContext *, struct iniContextItemLine *,
           STRPTR *, ULONG );


@{b}FUNCTION@{ub}
       Reads one or more strings out of the given context item line


@{b}INPUTS@{ub}
       ContextStr - Context structure where string values lie in
       ContextItemLine - Context item line where to extract strings
       Array - The array where to store the pointers to the strings
       Entries - Number of array entries. If the array in the INI file is
            bigger, the remaining entries will be ignored.


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       STRPTR MyStr[4] = {NULL, NULL, NULL, NULL};

       MyStr[0] = iniAllocNameStr ( "String 1" );
       MyStr[1] = iniAllocNameStr ( "String 2" );
       MyStr[2] = iniAllocNameStr ( "String 3" );
       MyStr[3] = iniAllocNameStr ( "String 4" );

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniGetStrA ( context, contextitem, MyStr,
                     (sizeof (MyStr) / sizeof (STRPTR)) );

       printf ( "%s, %s, %s, %s\n", MyStr[0], MyStr[1], MyStr[2], MyStr[3]);

       iniFreeNameStr ( MyStr[0] );
       iniFreeNameStr ( MyStr[1] );
       iniFreeNameStr ( MyStr[2] );
       iniFreeNameStr ( MyStr[3] );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = Hello 1, Hello 2, Hello 3, Hello 4

          then
          MyStr[4] = {"Hello 1", "Hello 2", "Hello 3", "Hello 4"};
          Entries which can't be evaluated are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniReadStrA" Link "iniReadStrA"}().
       This function calls @{"iniGetContextItemData" Link "iniGetContextItemData"}() with no buffer.
       Array fields which can't be evaluated (e.g. bad syntax) are left
       unchanged. So it's good to fill the array with default strings first.
       All entries of the array must be deallocated with @{"iniFreeNameStr" Link "iniFreeNameStr"}()
       when the strings are no longer of use. This means that the default
       entries of the array must be @{"iniAllocNameStr" Link "iniAllocNameStr"}() strings!

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniGetLongA" Link "iniGetLongA"}(), @{"iniGetFloatA" Link "iniGetFloatA"}(), @{"iniGetStr" Link "iniGetStr"}(), @{"iniPutStrA" Link "iniPutStrA"}(),
       @{"iniReadStrA" Link "iniReadStrA"}(), @{"iniWriteStrA" Link "iniWriteStrA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniGetWordA" "ini.library/iniGetWordA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniGetWordA@{ub} -- reads a context item array into a (U)WORD array.

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniGetWordA@{ub}( ContextStr, ContextItemLine, Array, Entries );
       D0                     A0          A1               A2     D0

       BOOL @{b}iniGetWordA@{ub}( struct iniContext *, struct iniContextItemLine *,
           WORD *, ULONG );


@{b}FUNCTION@{ub}
       Reads a context item array and stores the read words into a
       (U)WORD table you specified.


@{b}INPUTS@{ub}
       ContextStr - The context structure where the context line is in
       ContextItemLine - The context item line where the array is
       Array - An (U)WORD array where to store the values
       Entries - Number of entries to read (further entries will be ignored)


RESULT
       success - TRUE if line could be evaluated else FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       WORD MyArray[4] = {16, 64, 256, 4096};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniGetWordA ( context, contextitem, MyArray,
                     (sizeof (MyArray) / sizeof (WORD)) );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 10000, 1000, 10, 1

          then
          MyArray[4] = {10000, 1000, 10, 1};
          Entries which can't be evaluated are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       Make sure that the given array is big enough to hold all values or
       some memory area may be overwritten.

       Fields which can't be evaluated are left unchanged.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniGetByteA" Link "iniGetByteA"}(), @{"iniGetLongA" Link "iniGetLongA"}(), @{"iniReadWordA" Link "iniReadWordA"}(), @{"iniPutWordA" Link "iniPutWordA"}(),
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniInsertContext" "ini.library/iniInsertContext"

@{b}NAME@{ub}
@{fg shine}       @{b}iniInsertContext@{ub} -- inserts a context in an INI file structure

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniInsertContext@{ub}( iniFile, ContextStr, PredContext );
                         A0       A1          A2

       void @{b}iniInsertContext@{ub}( struct iniFile *, struct iniContext *,
           struct iniContext *);


@{b}FUNCTION@{ub}
       Inserts a context in an INI file and all its associated lines.


@{b}INPUTS@{ub}
       iniFile - INI file structure where to insert context structure
       ContextStr - The context structure to be inserted
       PredContext - Context structure of the structure where to insert it


RESULT


@{b}NOTES@{ub}
@{fg shine}
@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniFreeContext" Link "iniFreeContext"}(), @{"iniRemContext" Link "iniRemContext"}(), @{"iniDeleteContext" Link "iniDeleteContext"}(),
      <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniInsertContextItem" "ini.library/iniInsertContextItem"

@{b}NAME@{ub}
@{fg shine}       @{b}iniInsertContextItem@{ub} -- inserts a context item line in an INI file.

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniInsertContextItem@{ub}( ContextStr, ContextItemLine, PredLine );
                             A0          A1               A2

       void @{b}iniInsertContextItem@{ub}( struct iniContext *,
           struct iniContextItemLine *, struct iniContextItemLine *);


@{b}FUNCTION@{ub}
       Inserts a context item line in an INI context.


@{b}INPUTS@{ub}
       ContextStr - The pointer of the context structure where to insert item
       ContextItemLine - The pointer of the context item line to be inserted.
       PredLine - The context item line where to insert it.


RESULT


@{b}NOTES@{ub}
@{fg shine}
@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniFreeContextItem" Link "iniFreeContextItem"}(), @{"iniRemContextItem" Link "iniRemContextItem"}(), @{"iniDeleteContextItem" Link "iniDeleteContextItem"}(),
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>


@ENDNODE


@NODE "iniIntToStr" "ini.library/iniIntToStr"

@{b}NAME@{ub}
@{fg shine}       @{b}iniIntToStr@{ub} -- Converts an integer value to a string.

@{fg text}
@{b}SYNOPSIS@{ub}
       string = @{b}iniIntToStr@{ub}( Buffer, Integer, Format, Len, ZeroSep );
       D0                    A0      D0       D1      D2   D3:8

       STRPTR @{b}iniIntToStr@{ub}( STRPTR, ULONG, ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       This function is used to convert an integer value to a standard
       ASCII string.


@{b}INPUTS@{ub}
       Buffer - A pointer to a buffer or NULL to create a new one.
           The buffer must be large enough to hold all values.
       Integer - Integer value to convert.
       Format - Format of the outputted string. Can be any of:
           INI_FORMAT_DEC - Use decimal with no precedor
           INI_FORMAT_DEC_CHAR - Use decimal with # precedor
           INI_FORMAT_HEX - Use hexadecimal with $ precedor
           INI_FORMAT_HEX_0X - Use hexadecimal with 0x precedor
           INI_FORMAT_BIN - Use binary with % precedor
           INI_FORMAT_OCT - Use octal with & precedor
           INI_FORMAT_YESNO - Use No for zero, Yes for all others
           INI_FORMAT_YN - Use N for zero, Y for all others
           INI_FORMAT_TRUEFALSE - Use False for zero, True for all others
           INI_FORMAT_ONOFF - Use Off for zero, On for all others
           INI_UNSIGNED - Add this to indicate unsigned integer
       Len - Forced length of outputted string or NULL for no force.
       ZeroSep - Zero character for Len leading zeroes. Usually " " or "0"


RESULT
       string - Pointer to the string where the converted string is stored.


@{b}EXAMPLE@{ub}
       STRPTR Buffer;

       Buffer = iniIntToStr ( 0x4000, INI_FORMAT_DEC_CHAR, 7, '0');

       /* Buffer will contain: "#0016384" */

       puts ( Buffer );

       iniFreeNameStr ( Buffer );


@{b}NOTES@{ub}
@{fg shine}
@{fg text}
@{b}BUGS@{ub}
@{fg shine}      The buffer is not checked for overflow. That means, IntLen should
      should be lesser than your buffer.

@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniStrToInt" Link "iniStrToInt"}(), @{"iniStrToFloat" Link "iniStrToFloat"}(), @{"iniFloatToStr" Link "iniFloatToStr"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniOpenDefault" "ini.library/iniOpenDefault"

@{b}NAME@{ub}
@{fg shine}       @{b}iniOpenDefault@{ub} -- Opens INI file for read access

@{fg text}
@{b}SYNOPSIS@{ub}
       iniFile = @{b}iniOpenDefault@{ub}( address, name, len );
       D0                        A0       A1    D0

       struct iniFile *@{b}iniOpenDefault@{ub}( APTR, STRPTR name, ULONG );


@{b}FUNCTION@{ub}
       Opens an INI file for read access and creates a iniFile structure
       for it. If the file doesn't exist, a default file will be created.


@{b}INPUTS@{ub}
       address - Address where default INI file lies (in memory)
       name - File name of the INI file to be accessed
       len - Length of the default INI file


RESULT
       iniFile - A valid INI file structure ready to be evaluated.


@{b}EXAMPLE@{ub}
       char DefaultINI[] = "/* Default INI file settings */\n\
           [MyContext]\n\
           MyItem = 5\n";
       struct iniFile *ini;
       ULONG MyValue;

       /* Now let's open the INI file and create, if necessary an default
          ini file */

       ini = iniOpenDefault ( DefaultINI, "ENVARC:MyPrefs.INI",
                              sizeof (DefaultINI));

       MyValue = iniReadLong ( ini, "MyContext", "MyItem", 5L, 0L );

       printf ( "%ld\n", MyValue );

       iniClose ( ini );


@{b}NOTES@{ub}
@{fg shine}       The default file will only be created, if the Open() fails with
       an ERROR_OBJECT_NOT_FOUND (code 205) error.
       If the default file can't be created (disk full, etc.) the function
       will use the default file in memory.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniOpenFile" Link "iniOpenFile"}(), @{"iniOpenMem" Link "iniOpenMem"}(), @{"iniClose" Link "iniClose"}(), @{"iniSaveFile" Link "iniSaveFile"}(),
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniOpenFile" "ini.library/iniOpenFile"

@{b}NAME@{ub}
@{fg shine}       @{b}iniOpenFile@{ub} -- Prepares an INI file for context access

@{fg text}
@{b}SYNOPSIS@{ub}
       iniFile = @{b}iniOpenFile@{ub}( name, accessMode );
       D0                     D1    D2

       struct iniFile *@{b}iniOpenFile@{ub}( STRPTR name, LONG );


@{b}FUNCTION@{ub}
       Opens an INI file for read access and prepares an iniFile structure
       for evaluation. After this the INI file contents can be evaluated


@{b}INPUTS@{ub}
       name - Name of the INI file to be opened.
       accessMode - Read mode of file (see <@{"libraries/dos.h" Link "INCLUDE:libraries/dos.h/Main" 0}> for details)


RESULT
       iniFile - An INI file structure which is ready for evaluation


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       ULONG MyValue;

       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       MyValue = iniReadLong ( ini, "MyContext", "MyItem", 5L, 0L );

       printf ( "%ld\n", MyValue );

       iniClose ( ini );


@{b}NOTES@{ub}
@{fg shine}
@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniOpenDefault" Link "iniOpenDefault"}(), @{"iniOpenFromFH" Link "iniOpenFromFH"}(), @{"iniOpenMem" Link "iniOpenMem"}(), @{"iniClose" Link "iniClose"}(),
       @{"iniSaveFile" Link "iniSaveFile"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>, <@{"libraries/dos.h" Link "INCLUDE:libraries/dos.h/Main" 0}>



@ENDNODE


@NODE "iniOpenFromFH" "ini.library/iniOpenFromFH"

@{b}NAME@{ub}
@{fg shine}       @{b}iniOpenFromFH@{ub} -- initializes an INI file from an already open file

@{fg text}
@{b}SYNOPSIS@{ub}
       iniFile = @{b}iniOpenFromFH@{ub}( fh, len );
       D0                       D1  D2

       struct iniFile *@{b}iniOpenFromFH@{ub}( BPTR, ULONG );


@{b}FUNCTION@{ub}
       Reads the INI data from an already open file and initializes the
       iniFile structure.


@{b}INPUTS@{ub}
       fh - BPTR to an file handle of the already opened file to be read.
       len - Length of file (or length of bytes to read at maximum)


RESULT
       iniFile - An initialized INI file structure ready for evaluation


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       BPTR fh;
       ULONG MyValue;

       fh = Open ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );
       ini = iniOpenFromFH ( fh, -1 );

       MyValue = iniReadLong ( ini, "MyContext", "MyItem", 5L, 0L );

       printf ( "%ld\n", MyValue );

       iniClose ( ini );


@{b}NOTES@{ub}
@{fg shine}
@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniOpenDefault" Link "iniOpenDefault"}(), @{"iniOpenFile" Link "iniOpenFile"}(), @{"iniOpenMem" Link "iniOpenMem"}(), @{"iniClose" Link "iniClose"}(),
       @{"iniSaveFile" Link "iniSaveFile"}(), @{"iniSaveToFH" Link "iniSaveToFH"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniOpenMem" "ini.library/iniOpenMem"

@{b}NAME@{ub}
@{fg shine}       @{b}iniOpenMem@{ub} -- Initializes a INI file structure from an INI file
           already in memory.

@{fg text}
@{b}SYNOPSIS@{ub}
       iniFile = @{b}iniOpenMem@{ub}( address, len );
       D0                    A0       D0

       struct iniFile *@{b}iniOpenMem@{ub}( APTR, ULONG );


@{b}FUNCTION@{ub}
       Initializes an INI file structure from an INI file already in
       memory.


@{b}INPUTS@{ub}
       address - Address where the INI file lies
       len - Length of INI file in memory


RESULT
       iniFile - Valid initialized INI file structure ready to be evaluated


@{b}NOTES@{ub}
@{fg shine}       Used internally. Comes also in handy when you're going to read the
       file by yourself when it's crunched (so you can read XPK packed INIs).

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniOpenDefault" Link "iniOpenDefault"}(), @{"iniOpenFile" Link "iniOpenFile"}(), @{"iniOpenFromFH" Link "iniOpenFromFH"}(), @{"iniClose" Link "iniClose"}(),
      @{"iniSaveFile" Link "iniSaveFile"}(), @{"iniSaveToFH" Link "iniSaveToFH"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniPutByteA" "ini.library/iniPutByteA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniPutByteA@{ub} -- writes an (U)BYTE array into an context item array.

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniPutByteA@{ub}( ContextStr, ContextItemLine, Array, Entries,
       D0                     A0          A1               A2     D0
                              Format, Len, ZeroSep );
                              D1      D2   D3:8

       BOOL @{b}iniPutByteA@{ub}( struct iniContext *, struct iniContextItemLine *,
           BYTE *, ULONG, ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes the values of the given (U)BYTE table to the specified context
       item array.


@{b}INPUTS@{ub}
       ContextStr - The context structure where context line should be put
       ContextItemLine - The context item line where the array is
       Array - An (U)BYTE array where to take the values from
       Entries - Number of entries to write
       Format - Format of array entries to write out:
           INI_FORMAT_DEC - Use decimal with no precedor
           INI_FORMAT_DEC_CHAR - Use decimal with # precedor
           INI_FORMAT_HEX - Use hexadecimal with $ precedor
           INI_FORMAT_HEX_0X - Use hexadecimal with 0x precedor
           INI_FORMAT_BIN - Use binary with % precedor
           INI_FORMAT_OCT - Use octal with & precedor
           INI_FORMAT_YESNO - Use No for zero, Yes for all others
           INI_FORMAT_YN - Use N for zero, Y for all others
           INI_FORMAT_TRUEFALSE - Use False for zero, True for all others
           INI_FORMAT_ONOFF - Use Off for zero, On for all others
           INI_UNSIGNED - Add this to indicate unsigned integer
       Len - Forced length of outputted string or NULL for no force.
       ZeroSep - Zero character for Len leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if line could be written else FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       BYTE MyArray[4] = {-2, -1, 0, 1};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniPutByteA ( context, contextitem, MyArray, sizeof (MyArray),
                     INI_FORMAT_DEC, 3L, '0' );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 25, 50, 75, 100

          then it will become:
          [MyContext]
          MyItem = -002, -001, 000, 001

          Entries which can't be stored are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is currently relatively slow. Especially with
       arrays with more than 16 entries.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniPutWordA" Link "iniPutWordA"}(), @{"iniPutLongA" Link "iniPutLongA"}(), @{"iniWriteByteA" Link "iniWriteByteA"}(), @{"iniGetByteA" Link "iniGetByteA"}(),
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniPutFloat" "ini.library/iniPutFloat"

@{b}NAME@{ub}
@{fg shine}       @{b}iniPutFloat@{ub} -- Puts a quick floating point value into given item line

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniPutFloat@{ub}( ContextStr, ContextItemLine, Value,
       D0                     A0          A1               D0
                              Format, Len, ZeroSep );
                              D1      D2   D3:8

       BOOL @{b}iniPutFloat@{ub}( struct iniContext *, struct iniContextItemLine *,
           LONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes a quick float value into the given context item line


@{b}INPUTS@{ub}
       ContextStr - Context structure where quick float value should be put
       ContextItemLine - Context item line where to store quick float
       Value - Value to be written
       FltFormat - Format of the floating point value. Can be any of:
           INI_FLOAT_FORMAT_DEC - Use decimal with point separator
           INI_FLOAT_UNSIGNED - Add this to indicate unsigned quick float
       IntLen - Forced length of integer part or NULL for no force.
       FracLen - Forced length of fractional part or NULL for no force.
       ZeroSep - Zero character for IntLen leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if successful write else FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniPutFloat ( context, contextitem, 0x28000, INI_FLOAT_FORMAT_DEC,
                     0L, 3L, ' ' );

       /* After this, ENVARC:MyPrefs.INI will contain:
          [MyContext]
          MyItem = 2.500

          If the context or the context item doesn't exist, the value won't
          be written.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniWriteFloat" Link "iniWriteFloat"}().

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniPutLong" Link "iniPutLong"}(), @{"iniPutStr" Link "iniPutStr"}(), @{"iniPutFloatA" Link "iniPutFloatA"}(), @{"iniGetFloat" Link "iniGetFloat"}(),
       @{"iniWriteFloat" Link "iniWriteFloat"}(), @{"iniReadFloat" Link "iniReadFloat"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniPutFloatA" "ini.library/iniPutFloatA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniPutFloatA@{ub} -- Puts quick floating point value(s) into item line(s)

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniPutFloatA@{ub}( ContextStr, ContextItemLine, Array, Entries,
       D0                      A0          A1               A2     D0
                               FltFormat, IntLen, FracLen, ZeroSep );
                               D1         D2      D3       D4:8

       BOOL @{b}iniPutFloatA@{ub}( struct iniContext *, struct iniContextItemLine *,
           LONG *, ULONG, ULONG, ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes one or more quick float value(s) from an array into the given
       context item line


@{b}INPUTS@{ub}
       ContextStr - Context structure where quick float values should be put
       ContextItemLine - Context item line where to store quick floats
       Array - The array where to take the quick float values from
       Entries - Number of array entries. If the array in the INI file is
            bigger, the remaining entries will be ignored.
       FltFormat - Format of the floating point value. Can be any of:
           INI_FLOAT_FORMAT_DEC - Use decimal with point separator
           INI_FLOAT_UNSIGNED - Add this to indicate unsigned quick float
       IntLen - Forced length of integer part or NULL for no force.
       FracLen - Forced length of fractional part or NULL for no force.
       ZeroSep - Zero character for IntLen leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       LONG MyFloat[4] = {-0x10000, -0x8000, 0, 0x8000};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniPutFloatA ( context, contextitem, MyFloat,
                      (sizeof (MyFloat) / sizeof (LONG)),
                      INI_FLOAT_FORMAT_DEC, 3L, 4L, '0' );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 13.5, 17.25, 1.116, 3.1416

          then it will become:
          [MyContext]
          MyItem = -001.0000, -000.5000, 000.0000, 000.5000

          Entries which can't be stored are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniWriteFloatA" Link "iniWriteFloatA"}().
       This function is currently relatively slow. Especially with
       arrays with more than 16 entries.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniPutLongA" Link "iniPutLongA"}(), @{"iniPutStrA" Link "iniPutStrA"}(), @{"iniPutFloat" Link "iniPutFloat"}(), @{"iniGetFloatA" Link "iniGetFloatA"}(),
       @{"iniWriteFloatA" Link "iniWriteFloatA"}(), @{"iniReadFloatA" Link "iniReadFloatA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniPutLong" "ini.library/iniPutLong"

@{b}NAME@{ub}
@{fg shine}       @{b}iniPutLong@{ub} -- Puts a long integer value into the context item line

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniPutLong@{ub}( ContextStr, ContextItemLine, Value, Format,
       D0                    A0          A1               D0     D1
                             Len, ZeroSep );
                             D2   D3:8

       BOOL @{b}iniPutLong@{ub}( struct iniContext *, struct iniContextItemLine *,
           LONG, ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes a long integer value into the given context item line


@{b}INPUTS@{ub}
       ContextStr - Context structure where the long integers should be put
       ContextItemLine - Context item line where to store long integer
       Value - Value to be written
       Format - Format of the outputted string. Can be any of:
           INI_FORMAT_DEC - Use decimal with no precedor
           INI_FORMAT_DEC_CHAR - Use decimal with # precedor
           INI_FORMAT_HEX - Use hexadecimal with $ precedor
           INI_FORMAT_HEX_0X - Use hexadecimal with 0x precedor
           INI_FORMAT_BIN - Use binary with % precedor
           INI_FORMAT_OCT - Use octal with & precedor
           INI_FORMAT_YESNO - Use No for zero, Yes for all others
           INI_FORMAT_YN - Use N for zero, Y for all others
           INI_FORMAT_TRUEFALSE - Use False for zero, True for all others
           INI_FORMAT_ONOFF - Use Off for zero, On for all others
           INI_UNSIGNED - Add this to indicate unsigned integer
       Len - Forced length of outputted string or NULL for no force.
       ZeroSep - Zero character for Len leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if value could successfully be written or FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniPutLong ( context, contextitem, 13750, INI_FORMAT_HEX_0X,
                    8L, ' ' );

       /* After this, ENVARC:MyPrefs.INI will contain:
          [MyContext]
          MyItem = 0x000035B6

          If the context or the context item doesn't exist, the value won't
          be written.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniWriteLong" Link "iniWriteLong"}().

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniPutFloat" Link "iniPutFloat"}(), @{"iniPutStr" Link "iniPutStr"}(), @{"iniPutLongA" Link "iniPutLongA"}(), @{"iniGetLong" Link "iniGetLong"}(),
       @{"iniWriteLong" Link "iniWriteLong"}(), @{"iniReadLong" Link "iniReadLong"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniPutLongA" "ini.library/iniPutLongA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniPutLongA@{ub} -- Puts long integer value(s) into context item line(s)

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniPutLongA@{ub}( ContextStr, ContextItemLine, Array, Entries,
       D0                     A0          A1               A2     D0
                              Format, Len, ZeroSep );
                              D1      D2   D3:8

       BOOL @{b}iniPutLongA@{ub}( struct iniContext *, struct iniContextItemLine *,
           LONG *, ULONG, ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes one or more long integer value(s) from the given array into
       the specified context item line(s).


@{b}INPUTS@{ub}
       ContextStr - Context structure where the long integers should be put
       ContextItemLine - Context item line where to store long integers
       Array - The array where to take the long integer values from
       Entries - Number of array entries.
       Format - Format of the outputted string. Can be any of:
           INI_FORMAT_DEC - Use decimal with no precedor
           INI_FORMAT_DEC_CHAR - Use decimal with # precedor
           INI_FORMAT_HEX - Use hexadecimal with $ precedor
           INI_FORMAT_HEX_0X - Use hexadecimal with 0x precedor
           INI_FORMAT_BIN - Use binary with % precedor
           INI_FORMAT_OCT - Use octal with & precedor
           INI_FORMAT_YESNO - Use No for zero, Yes for all others
           INI_FORMAT_YN - Use N for zero, Y for all others
           INI_FORMAT_TRUEFALSE - Use False for zero, True for all others
           INI_FORMAT_ONOFF - Use Off for zero, On for all others
           INI_UNSIGNED - Add this to indicate unsigned integer
       Len - Forced length of outputted string or NULL for no force.
       ZeroSep - Zero character for Len leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       LONG MyArray[4] = {-200000, -100000, 0, 100000};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniPutLongA ( context, contextitem, MyArray,
                     (sizeof (MyArray) / sizeof (LONG)),
                     INI_FORMAT_DEC, 0L, '0' );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 12345678, 76543210, 50000, -12345678

          then it will become:
          [MyContext]
          MyItem = -200000, -100000, 0, 100000

          Entries which can't be stored are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniWriteLongA" Link "iniWriteLongA"}().
       This function is currently relatively slow. Especially with
       arrays with more than 16 entries.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniPutFloatA" Link "iniPutFloatA"}(), @{"iniPutStrA" Link "iniPutStrA"}(), @{"iniPutLong" Link "iniPutLong"}(), @{"iniGetLongA" Link "iniGetLongA"}(),
       @{"iniWriteLongA" Link "iniWriteLongA"}(), @{"iniReadLongA" Link "iniReadLongA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniPutStr" "ini.library/iniPutStr"

@{b}NAME@{ub}
@{fg shine}       @{b}iniPutStr@{ub} -- Puts a string into context item line

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniPutStr@{ub}( ContextStr, ContextItemLine, String );
       D0                   A0          A1               A2

       BOOL @{b}iniPutStr@{ub}( struct iniContext *, struct iniContextItemLine *,
           STRPTR );


@{b}FUNCTION@{ub}
       Writes a string into the given context item line.


@{b}INPUTS@{ub}
       ContextStr - Context structure where string should be put
       ContextItemLine - Context item line where to store string
       String - String to be written


RESULT
       success - TRUE if writing was successful else FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyMessages.INI", MODE_OLDFILE );

       context = FindContext ( ini, "Messages" );

       if (!( contextitem = FindContextItem ( context, "Basty" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "Basty" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniPutStr ( context, contextitem, "I love Zuzana Burkertová !" );

       /* After this, ENVARC:MyMessages.INI will contain:
          [Messages]
          Basty = I love Zuzana Burkertová !

          If the context or the context item doesn't exist, the value won't
          be written.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniReadStr" Link "iniReadStr"}().

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniPutLongA" Link "iniPutLongA"}(), @{"iniPutFloatA" Link "iniPutFloatA"}(), iniPutStr(), @{"iniGetStr" Link "iniGetStr"}(),
       @{"iniWriteStrA" Link "iniWriteStrA"}(), @{"iniReadStrA" Link "iniReadStrA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniPutStrA" "ini.library/iniPutStrA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniPutStrA@{ub} -- Stores array(s) of string into the context item line(s)

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniPutStrA@{ub}( ContextStr, ContextItemLine, Array, Entries );
       D0                    A0          A1               A2     D0

       BOOL @{b}iniPutStrA@{ub}( struct iniContext *, struct iniContextItemLine *,
           STRPTR *, ULONG );


@{b}FUNCTION@{ub}
       Writes one or more strings into the given context item line from an
       specified array.


@{b}INPUTS@{ub}
       ContextStr - Context structure where strings should be put
       ContextItemLine - Context item line where to store strings
       Array - The array where to take the pointers to the strings from
       Entries - Number of array entries. If the array in the INI file is
            bigger, the remaining entries will be ignored.


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       STRPTR MyStr[4] = {"String 1", "String 2", "String 3", "String 4"};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniPutStrA ( context, contextitem, MyStr,
                     (sizeof (MyStr) / sizeof (STRPTR)) );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = Hello 1, Hello 2, Hello 3, Hello 4

          then it will become:
          [MyContext]
          MyItem = String 1, String 2, String 3, String 4

          Entries which can't be written are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is called from @{"iniWriteStrA" Link "iniWriteStrA"}().

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniPutLongA" Link "iniPutLongA"}(), @{"iniPutFloatA" Link "iniPutFloatA"}(), @{"iniPutStr" Link "iniPutStr"}(), @{"iniGetStrA" Link "iniGetStrA"}(),
       @{"iniWriteStrA" Link "iniWriteStrA"}(), @{"iniReadStrA" Link "iniReadStrA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniPutWordA" "ini.library/iniPutWordA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniPutWordA@{ub} -- writes a (U)WORD array into a context item array.

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniPutWordA@{ub}( ContextStr, ContextItemLine, Array, Entries,
       D0                     A0          A1               A2     D0
                              Format, Len, ZeroSep );
                              D1      D2   D3:8

       BOOL @{b}iniPutWordA@{ub}( struct iniContext *, struct iniContextItemLine *,
           WORD *, ULONG, ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes a context item array and stores the write words from a
       (U)WORD table you specified.


@{b}INPUTS@{ub}
       ContextStr - The context structure where the context line is in
       ContextItemLine - The context item line where the array is
       Array - An (U)WORD array where to store the values
       Entries - Number of entries to read (further entries will be ignored)
       Format - Format of the outputted string. Can be any of:
           INI_FORMAT_DEC - Use decimal with no precedor
           INI_FORMAT_DEC_CHAR - Use decimal with # precedor
           INI_FORMAT_HEX - Use hexadecimal with $ precedor
           INI_FORMAT_HEX_0X - Use hexadecimal with 0x precedor
           INI_FORMAT_BIN - Use binary with % precedor
           INI_FORMAT_OCT - Use octal with & precedor
           INI_FORMAT_YESNO - Use No for zero, Yes for all others
           INI_FORMAT_YN - Use N for zero, Y for all others
           INI_FORMAT_TRUEFALSE - Use False for zero, True for all others
           INI_FORMAT_ONOFF - Use Off for zero, On for all others
           INI_UNSIGNED - Add this to indicate unsigned integer
       Len - Forced length of outputted string or NULL for no force.
       ZeroSep - Zero character for Len leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;
       WORD MyArray[4] = {-2000, -1000, 0, 1000};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }

       iniPutWordA ( context, contextitem, MyArray,
                     (sizeof (MyArray) / sizeof (WORD)),
                     INI_FORMAT_DEC_CHAR, 0L, '0' );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 1000, 2000, 3000, -10000

          then it will become:
          [MyContext]
          MyItem = -#2000, -#1000, #0, #1000

          Entries which can't be stored are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is currently relatively slow. Especially with
       arrays with more than 16 entries.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniPutByteA" Link "iniPutByteA"}(), @{"iniPutLongA" Link "iniPutLongA"}(), @{"iniWriteWordA" Link "iniWriteWordA"}(), @{"iniReadWordA" Link "iniReadWordA"}(),
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniReadByteA" "ini.library/iniReadByteA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniReadByteA@{ub} -- reads a context item array into a (U)BYTE array.

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniReadByteA@{ub}( iniFile, ContextName, ItemName, Array,
       D0                      A0       A1           A2        A3
                               Entries, Flags );
                               D0       D1

       BOOL @{b}iniReadByteA@{ub}( struct iniFile *, STRPTR, STRPTR, BYTE *,
           ULONG, ULONG );


@{b}FUNCTION@{ub}
       Searches a context item in a context you specified by name and stores
       the read bytes into a (U)BYTE table you specified.


@{b}INPUTS@{ub}
       iniFile - INI file to be evaluated
       ContextName - Name of the context where context item is
           v32+: ContextName can be NULL. In this case all are searched
       ItemName - Name of the context item to be searched
       Array - An (U)BYTE array where to store the values
       Entries - Number of entries to read (further entries will be ignored)
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.


RESULT
       success - TRUE if line could be evaluated else FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       BYTE MyArray[4] = {-2, -1, -0, 1};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniReadByteA ( ini, "MyContext", "MyItem", MyArray,
                      sizeof (MyArray), 0L );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 25, 50, 75, 100

          then
          MyArray[4] = {25, 50, 75, 100};
          Entries which can't be evaluated are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       Make sure that the given array is big enough to hold all values or
       some memory area may be overwritten.

       Fields which can't be evaluated are left unchanged.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniReadWordA" Link "iniReadWordA"}(), @{"iniReadLongA" Link "iniReadLongA"}(), @{"iniGetByteA" Link "iniGetByteA"}(), @{"iniWriteByteA" Link "iniWriteByteA"}(),
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniReadFloat" "ini.library/iniReadFloat"

@{b}NAME@{ub}
@{fg shine}       @{b}iniReadFloat@{ub} -- Reads a quick floating point value

@{fg text}
@{b}SYNOPSIS@{ub}
       QFloatValue = @{b}iniReadFloat@{ub}( iniFile, ContextName, ItemName, Default,
       D0                          A0       A1           A2        D0
                                   Flags );
                                   D1

       LONG @{b}iniReadFloat@{ub}( struct iniFile *, STRPTR, STRPTR, LONG, ULONG );


@{b}FUNCTION@{ub}
       Searches the INI file for the desired context and the desired context
       items and returns its quick floating point value.


@{b}INPUTS@{ub}
       
       iniFile - INI file to be evaluated
       ContextName - Name of the context where context item is
           v32+: ContextName can be NULL. In this case all are searched
       ItemName - Name of the context item to be searched
       Default - Default value to take if contents could not be evaluated
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.


RESULT
       QFloatValue - The quick float value extracted out


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       LONG MyFloat;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       MyFloat = iniReadFloat ( ini, "MyContext", "MyItem", 0x28000, 0L ));

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 3.0

          then MyFloat will contain 0x30000. If this context or context item
          is not available, MyFloat will contain 0x28000 (default) instead.
       */


@{b}NOTES@{ub}
@{fg shine}       Only the first four fractional digits are evaluated. However, the
       5th digit is evaluated for rounding purposes.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniReadLong" Link "iniReadLong"}(), @{"iniReadStr" Link "iniReadStr"}(), @{"iniReadFloatA" Link "iniReadFloatA"}(), @{"iniWriteFloat" Link "iniWriteFloat"}(),
       GetFloat(), @{"iniPutFloat" Link "iniPutFloat"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniReadFloatA" "ini.library/iniReadFloatA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniReadFloatA@{ub} -- Reads quick floating point value(s) into an array

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniReadFloatA@{ub}( iniFile, ContextName, ItemName, Array,
       D0                       A0       A1           A2        D0
                                Entries, Flags );
                                D1       D2

       BOOL @{b}iniReadFloatA@{ub}( struct iniFile *, STRPTR, STRPTR, LONG *,
           ULONG, ULONG );


@{b}FUNCTION@{ub}
       Searches the context given for the string given in context item and
       reads one or more quick float value(s) and stores them into the
       specified array.


@{b}INPUTS@{ub}
       iniFile - INI file to be evaluated
       ContextName - Name of the context where context item is
           v32+: ContextName can be NULL. In this case all are searched
       ItemName - Name of the context item to be searched
       Default - Default value to take if contents could not be evaluated
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       LONG MyFloat[4] = {-0x10000, -0x8000, 0, 0x8000};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniReadFloatA ( ini, "MyContext", "MyItem", MyFloat,
                       (sizeof (MyFloat) / sizeof (LONG)), 0L );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 1.0, 1.5, 2.0, 2.5

          then
          MyFloat[4] = {0x10000, 0x18000, 0x20000, 0x28000};
          Entries which can't be evaluated are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       This function is currently relatively slow. Especially with
       arrays with more than 16 entries.
       Only the first four fractional digits are evaluated. However, the
       5th digit is evaluated for rounding purposes.
       Array fields which can't be evaluated (e.g. bad syntax) are left
       unchanged. So it's good to fill the array with default values first.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniWriteLongA" Link "iniWriteLongA"}(), @{"iniWriteStrA" Link "iniWriteStrA"}(), @{"iniReadFloat" Link "iniReadFloat"}(), @{"iniWriteFloatA" Link "iniWriteFloatA"}(),
       @{"iniGetFloatA" Link "iniGetFloatA"}(), @{"iniPutFloatA" Link "iniPutFloatA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniReadLong" "ini.library/iniReadLong"

@{b}NAME@{ub}
@{fg shine}       @{b}iniReadLong@{ub} -- Reads a long integer value

@{fg text}
@{b}SYNOPSIS@{ub}
       LongValue = @{b}iniReadLong@{ub}( iniFile, ContextName, ItemName, Default,
       D0                       A0       A1           A2        D0
                                Flags );
                                D1

       LONG @{b}iniReadLong@{ub}( struct iniFile *, STRPTR, STRPTR, LONG, ULONG );


@{b}FUNCTION@{ub}
       Searches the INI file for the desired context and the desired context
       items and returns its long integer value.


@{b}INPUTS@{ub}
       
       iniFile - INI file to be evaluated
       ContextName - Name of the context where context item is
           v32+: ContextName can be NULL. In this case all are searched
       ItemName - Name of the context item to be searched
       Default - Default value to take if contents could not be evaluated
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.


RESULT
       LongValue - The long integer extracted out


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       LONG MyLong;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       MyLong = iniReadLong ( ini, "MyContext", "MyItem", 12345678, 0L );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = -256

          then MyLong will contain -256. If this context or context item
          is not available, MyLong will contain 12345678 (default) instead.
       */


@{b}NOTES@{ub}
@{fg shine}
@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       iniReadLong(), @{"iniReadStr" Link "iniReadStr"}(), @{"iniReadFloatA" Link "iniReadFloatA"}(), @{"iniWriteFloat" Link "iniWriteFloat"}(),
       @{"iniGetFloat" Link "iniGetFloat"}(), @{"iniPutFloat" Link "iniPutFloat"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniReadLongA" "ini.library/iniReadLongA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniReadLongA@{ub} -- Reads long integer value(s) into an array

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniReadLongA@{ub}( iniFile, ContextName, ItemName, Array,
       D0                      A0          A1        A2        D0
                               Entries, Flags );

       BOOL @{b}iniReadLongA@{ub}( struct iniFile *, STRPTR, STRPTR, LONG *,
           LONG, ULONG );


@{b}FUNCTION@{ub}
       Searches the context given for the string given in context item and
       reads one or more long integer value(s) and stores them into the
       specified array.


@{b}INPUTS@{ub}
       iniFile - INI file to be evaluated
       ContextName - Name of the context where context item is
           v32+: ContextName can be NULL. In this case all are searched
       ItemName - Name of the context item to be searched
       Default - Default value to take if contents could not be evaluated
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       LONG MyArray[4] = {4096, 65536, 16777216, 2147483647};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniReadLongA ( ini, "MyContext", "MyItem", MyArray,
                      (sizeof (MyArray) / sizeof (LONG)), 0L );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = -4096, -65536, -16777216, -2147483648

          then
          MyArray[4] = {-4096, -65536, -16777216, -2147483648};
          Entries which can't be evaluated are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       Array fields which can't be evaluated (e.g. bad syntax) are left
       unchanged. So it's good to fill the array with default values first.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniPutLongA" Link "iniPutLongA"}(), @{"iniPutStrA" Link "iniPutStrA"}(), @{"iniGetFloat" Link "iniGetFloat"}(), @{"iniPutFloatA" Link "iniPutFloatA"}(),
       @{"iniReadFloatA" Link "iniReadFloatA"}(), @{"iniWriteFloatA" Link "iniWriteFloatA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniReadStr" "ini.library/iniReadStr"

@{b}NAME@{ub}
@{fg shine}       @{b}iniReadStr@{ub} -- Gets a string

@{fg text}
@{b}SYNOPSIS@{ub}
       String = @{b}iniReadStr@{ub}( iniFile, ContextName, ItemName, Default,
       D0                   A0       A1           A2        A3
                            Flags );
                            D0

       STRPTR @{b}iniReadStr@{ub}( struct iniFile *, STRPTR, STRPTR, STRPTR, ULONG );


@{b}FUNCTION@{ub}
       Searches the given context item in the given context and returns, if
       found the context item data as a string.


@{b}INPUTS@{ub}
       iniFile - INI file to be evaluated
       ContextName - Name of the context where context item is
           v32+: ContextName can be NULL. In this case all are searched
       ItemName - Name of the context item to be searched
       Default - Default string to take if contents could not be evaluated
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.


RESULT
       String - The string value extracted out


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       STRPTR MyStr;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       MyStr = iniReadStr ( ini, "MyContext", "MyItem", "MyString", 0L ));

       puts ( MyStr );

       iniFreeNameStr ( MyStr );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = Hello world!

          then MyStr will contain "Hello world!". If this context or context
          item is not available, MyStr will contain "MyString" (default)
          instead.
       */


@{b}NOTES@{ub}
@{fg shine}       The string returned must be deallocated with @{"iniFreeNameStr" Link "iniFreeNameStr"}() after
       use.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniReadLongA" Link "iniReadLongA"}(), @{"iniReadFloatA" Link "iniReadFloatA"}(), @{"iniWriteStr" Link "iniWriteStr"}(), @{"iniGetStrA" Link "iniGetStrA"}(),
       @{"iniPutStrA" Link "iniPutStrA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniReadStrA" "ini.library/iniReadStrA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniReadStrA@{ub} -- Extracts strings out of an array

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniReadStrA@{ub}( iniFile, ContextName, ItemName, Array,
       D0                     A0       A1           A2        A3
                              Entries, Flags );
                              D0       D1

       BOOL @{b}iniReadStrA@{ub}( struct iniFile *, STRPTR, STRPTR, STRPTR *, ULONG,
           ULONG );


@{b}FUNCTION@{ub}
       Searches for the given context item in the given context and reads
       the string(s) into the specified array.


@{b}INPUTS@{ub}
       iniFile - INI file to be evaluated
       ContextName - Name of the context where context item is
           v32+: ContextName can be NULL. In this case all are searched
       ItemName - Name of the context item to be searched
       Array - Array where to put the pointers to the strings
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       STRPTR MyStr[4] = {NULL, NULL, NULL, NULL};

       MyStr[0] = iniAllocNameStr ( "String 1" );
       MyStr[1] = iniAllocNameStr ( "String 2" );
       MyStr[2] = iniAllocNameStr ( "String 3" );
       MyStr[3] = iniAllocNameStr ( "String 4" );

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniReadStrA ( ini, "MyContext", "MyItem", MyStr,
                     (sizeof (MyStr) / sizeof (STRPTR)), 0L );

       printf ( "%s, %s, %s, %s\n", MyStr[0], MyStr[1], MyStr[2], MyStr[3]);

       iniFreeNameStr ( MyStr[0] );
       iniFreeNameStr ( MyStr[1] );
       iniFreeNameStr ( MyStr[2] );
       iniFreeNameStr ( MyStr[3] );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = Hello 1, Hello 2, Hello 3, Hello 4

          then
          MyStr[4] = {"Hello 1", "Hello 2", "Hello 3", "Hello 4"};
          Entries which can't be evaluated are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       Array fields which can't be evaluated (e.g. bad syntax) are left
       unchanged. So it's good to fill the array with default strings first.
       All array fields must be deallocated with @{"iniFreeNameStr" Link "iniFreeNameStr"}() when they
       are not required anymore. This means that the default entries of the
       array must be @{"iniAllocNameStr" Link "iniAllocNameStr"}() strings!
@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniReadLongA" Link "iniReadLongA"}(), @{"iniReadFloatA" Link "iniReadFloatA"}(), @{"iniReadStr" Link "iniReadStr"}(), @{"iniWriteStrA" Link "iniWriteStrA"}(),
       @{"iniGetStrA" Link "iniGetStrA"}(), @{"iniPutStrA" Link "iniPutStrA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniReadWordA" "ini.library/iniReadWordA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniReadWordA@{ub} -- reads a context item array into a (U)WORD array.

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniReadWordA@{ub}( iniFile, ContextName, ItemName, Array,
       D0                      A0       A1           A2        A3
                               Entries, Flags );
                               D0       D1

       BOOL @{b}iniReadWordA@{ub}( struct iniFile *, STRPTR, STRPTR, WORD *,
           ULONG, ULONG );


@{b}FUNCTION@{ub}
       Searches a context item in a context you specified by name and stores
       the read bytes into a (U)WORD table you specified.


@{b}INPUTS@{ub}
       iniFile - INI file to be evaluated
       ContextName - Name of the context where context item is
           v32+: ContextName can be NULL. In this case all are searched
       ItemName - Name of the context item to be searched
       Array - An (U)WORD array where to store the values
       Entries - Number of entries to read (further entries will be ignored)
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.


RESULT
       success - TRUE if line could be evaluated else FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       WORD MyArray[4] = {16, 64, 256, 4096};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniReadWordA ( ini, "MyContext", "MyItem",
                      (sizeof (MyArray) / sizeof (WORD)), 0L );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 10000, 1000, 10, 1

          then
          MyArray[4] = {10000, 1000, 10, 1};
          Entries which can't be evaluated are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       Make sure that the given array is big enough to hold all values or
       some memory area may be overwritten.

       Fields which can't be evaluated are left unchanged.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniReadByteA" Link "iniReadByteA"}(), @{"iniReadLongA" Link "iniReadLongA"}(), @{"iniGetWordA" Link "iniGetWordA"}(), @{"iniWriteWordA" Link "iniWriteWordA"}(),
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniRemContext" "ini.library/iniRemContext"

@{b}NAME@{ub}
@{fg shine}       @{b}iniRemContext@{ub} -- removes the last context from an INI file structure

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniRemContext@{ub}( iniFile );
                      A0

       void @{b}iniRemContext@{ub}( struct iniFile *);


@{b}FUNCTION@{ub}
       Removes a previously generated and added context from a specified
       INI file structure. The entry removed is the last one.


@{b}INPUTS@{ub}
       iniFile - Pointer to INI structure where to remove from


@{b}NOTES@{ub}
@{fg shine}       This function *DOESN'T* do any deallocations. It just removes the
       node from the context list.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniCreateContext" Link "iniCreateContext"}(), @{"iniFreeContext" Link "iniFreeContext"}(), @{"iniAddContext" Link "iniAddContext"}(),
       @{"iniInsertContext" Link "iniInsertContext"}(), @{"iniDeleteContext" Link "iniDeleteContext"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniRemContextItem" "ini.library/iniRemContextItem"

@{b}NAME@{ub}
@{fg shine}       @{b}iniRemContextItem@{ub} -- removes the last context item line from a
                            context structure

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniRemContextItem@{ub}( ContextStr );
                          A0

       void @{b}iniRemContextItem@{ub}( struct iniContext *);


@{b}FUNCTION@{ub}
       Removes a previously generated context item line from a context
       structure. The context item line removed is the last one.


@{b}INPUTS@{ub}
       ContextStr - Pointer to context structure where to remove from


@{b}NOTES@{ub}
@{fg shine}       This function just removes the node, it *DOESN'T* deallocate any
       memory.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniCreateContextItem" Link "iniCreateContextItem"}(), @{"iniFreeContextItem" Link "iniFreeContextItem"}(), iniRemContextItem(),
       @{"iniInsertContextItem" Link "iniInsertContextItem"}(), @{"iniDeleteContextItem" Link "iniDeleteContextItem"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniSaveFile" "ini.library/iniSaveFile"

@{b}NAME@{ub}
@{fg shine}       @{b}iniSaveFile@{ub} -- Saves an .INI file from an INI structure to disk

@{fg text}
@{b}SYNOPSIS@{ub}
       written = @{b}iniSaveFile@{ub}( iniFile, name, accessMode );
       D0                     A0       D1    D2

       ULONG @{b}iniSaveFile@{ub}( struct iniFile *, STRPTR, LONG );


@{b}FUNCTION@{ub}
       Saves an INI file to disk using the current INI structure. This
       function usually is called when the user selects 'Save' in an
       application.


@{b}INPUTS@{ub}
       iniFile - INI structure to be saved
       name - Name of the INI file to be created.
       accessMode - Write mode of file (see <@{"libraries/dos.h" Link "INCLUDE:libraries/dos.h/Main" 0}> for details)


RESULT
       written - Number of bytes written in total or -1 on error.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       ULONG Length;

       /* Open old INI file */

       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       /* Write some value. Create contexts and/or
          context item if necessary */

       iniWriteLong ( ini, "MyContext", "MyItem", 5L, 0L );

       /* Now write back the INI file to disk */

       Length = iniSaveFile ( ini, "ENVARC:MyPrefs.INI", MODE_NEWFILE );

       iniClose ( ini );


@{b}NOTES@{ub}
@{fg shine}
@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       iniOpen(), @{"iniOpenDefault" Link "iniOpenDefault"}(), @{"iniOpenFromFH" Link "iniOpenFromFH"}(), @{"iniOpenMem" Link "iniOpenMem"}(),
       @{"iniClose" Link "iniClose"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>, <@{"libraries/dos.h" Link "INCLUDE:libraries/dos.h/Main" 0}>



@ENDNODE


@NODE "iniSaveToFH" "ini.library/iniSaveToFH"

@{b}NAME@{ub}
@{fg shine}       @{b}iniSaveToFH@{ub} -- Saves an INI structure to an already opened file

@{fg text}
@{b}SYNOPSIS@{ub}
       written = @{b}iniSaveToFH@{ub}( fh, iniFile );
       D0                     A0  A1

       ULONG @{b}iniSaveToFH@{ub}( BPTR, struct iniFile *);


@{b}FUNCTION@{ub}
       Writes the INI data from the specified INI structure to the file
       already opened. The file won't be closed after writing, so you can
       add more data manually.


@{b}INPUTS@{ub}
       fh - BPTR to an file handle of the already opened file to be written.
       iniFile - INI structure to be saved


RESULT
       written - Number of bytes written in total or -1 on error.


@{b}NOTES@{ub}
@{fg shine}       The file is not closed after the data is written. Called from
       @{"iniSaveFile" Link "iniSaveFile"}() after opening the file.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniOpenDefault" Link "iniOpenDefault"}(), @{"iniOpenFile" Link "iniOpenFile"}(), @{"iniOpenFromFH" Link "iniOpenFromFH"}(), @{"iniOpenMem" Link "iniOpenMem"}(),
       @{"iniClose" Link "iniClose"}(), @{"iniSaveFile" Link "iniSaveFile"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniSetNameStr" "ini.library/iniSetNameStr"

@{b}NAME@{ub}
@{fg shine}       @{b}iniSetNameStr@{ub} -- sets a name string in a given structure offset

@{fg text}
@{b}SYNOPSIS@{ub}
       namestring = @{b}iniSetNameStr@{ub}( StructPos, namestring );
       D0                          A0

       STRPTR @{b}iniSetNameStr@{ub}( STRPTR *, STRPTR namestring );


@{b}FUNCTION@{ub}
       Stores a name string into an structure position. This is required
       if you use own strings in the library handlers.


@{b}INPUTS@{ub}
       StructPos - A memory pointer where the string pointer should be
           assigned.
       namestring - The already iniAllocNameStr()ed name string to be
           assigned.


RESULT
       namestring - The name string stored or NULL on error. 


@{b}EXAMPLE@{ub}
       STRPTR MyStr[4] = {NULL, NULL, NULL, NULL}
       STRPTR TmpStr;

       /* Fill in the buffers with some shit */

       MyStr[0] = iniAllocNameStr ( "String 1" );
       MyStr[1] = iniAllocNameStr ( "String 2" );
       MyStr[2] = iniAllocNameStr ( "String 3" );
       MyStr[3] = iniAllocNameStr ( "String 4" );

       /* Now we have to change the strings for some reasons. We don't have
          to care about the old values, they're freed automatically. */

       TmpStr = iniAllocNameStr ( "Changed 1" );
       iniSetNameStr ( (STRPTR *) &(MyStr[0]), TmpStr );

       TmpStr = iniAllocNameStr ( "Changed 2" );
       iniSetNameStr ( (STRPTR *) &(MyStr[1]), TmpStr );

       TmpStr = iniAllocNameStr ( "Changed 3" );
       iniSetNameStr ( (STRPTR *) &(MyStr[2]), TmpStr );

       TmpStr = iniAllocNameStr ( "Changed 4" );
       iniSetNameStr ( (STRPTR *) &(MyStr[3]), TmpStr );


@{b}NOTES@{ub}
@{fg shine}       Internally called from @{"iniSetString" Link "iniSetString"}(). You need this function to
       assign a already iniAllocNameStr()ed to a structure.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniAllocNameStr" Link "iniAllocNameStr"}(), @{"iniFreeNameStr" Link "iniFreeNameStr"}(), @{"iniSetString" Link "iniSetString"}()



@ENDNODE


@NODE "iniSetString" "ini.library/iniSetString"

@{b}NAME@{ub}
@{fg shine}       @{b}iniSetString@{ub} -- allocates and sets a name string in a given structure
           offset

@{fg text}
@{b}SYNOPSIS@{ub}
       namestring = @{b}iniSetString@{ub}( StructPos, string );
       D0                          A0

       STRPTR @{b}iniSetNameStr@{ub}( STRPTR *, STRPTR string );


@{b}FUNCTION@{ub}
       Allocates a name string out of a standard NULL-terminated C-String
       and assigns the allocated pointer to the structure position.
       This is required if you use own strings in the library handlers.


@{b}INPUTS@{ub}
       StructPos - A memory pointer where the string pointer should be
           assigned.
       string - The C-String to be assigned.


RESULT
       namestring - The name string stored or NULL on error. 


@{b}EXAMPLE@{ub}
       STRPTR MyStr[4] = {NULL, NULL, NULL, NULL}

       /* Fill in the buffers with some shit */

       MyStr[0] = iniAllocNameStr ( "String 1" );
       MyStr[1] = iniAllocNameStr ( "String 2" );
       MyStr[2] = iniAllocNameStr ( "String 3" );
       MyStr[3] = iniAllocNameStr ( "String 4" );

       /* Now we have to change the strings for some reasons. We don't have
          to care about the old values, they're freed automatically. */

       iniSetString ( (STRPTR *) &(MyStr[0]), "Changed 1" );
       iniSetString ( (STRPTR *) &(MyStr[1]), "Changed 2" );
       iniSetString ( (STRPTR *) &(MyStr[2]), "Changed 3" );
       iniSetString ( (STRPTR *) &(MyStr[3]), "Changed 4" );


@{b}NOTES@{ub}
@{fg shine}       The namestring is a copy of string, but it's freed via @{"iniFreePMem" Link "iniFreePMem"}()

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniAllocNameStr" Link "iniAllocNameStr"}(), @{"iniFreeNameStr" Link "iniFreeNameStr"}(), @{"iniSetNameStr" Link "iniSetNameStr"}()



@ENDNODE


@NODE "iniStrToFloat" "ini.library/iniStrToFloat"

@{b}NAME@{ub}
@{fg shine}       @{b}iniStrToFloat@{ub} -- Converts a string to a quick float value.

@{fg text}
@{b}SYNOPSIS@{ub}
       QFloat = @{b}iniStrToFloat@{ub}( String, Default );
       D0                      A0      D0

       LONG @{b}iniStrToFloat@{ub}( STRPTR, LONG );


@{b}FUNCTION@{ub}
       This function is used to convert a standard ASCII string to a
       quick float value. The string may have signs (+/-) and a decimal
       point. A quick float value has in it's upper 16-bits the decimal
       value and in the lower 16-bits the fraction. That means, the highest
       possible accuracy is 1/65536. If the string can't be converted for
       any reason, the default value is used.


@{b}INPUTS@{ub}
       String - The string containing the quick float value.
       Default - Default quick float value to use if error.


RESULT
       QFloat - The converted quick float value or the default value.


@{b}EXAMPLE@{ub}
       LONG QFloat;

       QFloat = iniStrToFloat ( "3.14159", 0x10000 );

       QFloat will be 0x3243F (3.1416). If an error would have occured,
       QFloat would default to 0x10000 (1.0).


@{b}NOTES@{ub}
@{fg shine}       The string's value may not exceed -65536/+65535 or an overflow error
       will occur. The value after the period will only be interpreted up
       to 4 digits. However, the 5th digit will be interpreted for rounding
       purposes.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniStrToInt" Link "iniStrToInt"}(), @{"iniIntToStr" Link "iniIntToStr"}(), @{"iniFloatToStr" Link "iniFloatToStr"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniStrToInt" "ini.library/iniStrToInt"

@{b}NAME@{ub}
@{fg shine}       @{b}iniStrToInt@{ub} -- Converts a string to an (un)signed 32-bit integer.

@{fg text}
@{b}SYNOPSIS@{ub}
       Integer = @{b}iniStrToInt@{ub}( String, Default );
       D0                     A0      D0

       LONG @{b}iniStrToInt@{ub}( STRPTR, LONG );


@{b}FUNCTION@{ub}
       This function is used to convert a standard ASCII string to a
       standard 32-bit (un)signed integer value. The string may have signs
       (+/-) and can be in hexadecimal, decimal, binary and octal formats.
       Hexadecimal strings are preceded with $ or 0x. Binary strings with
       %, octal strings with & and decimal strings start either with nothing
       or with a #. In addition to this, the following strings will return
       -1: Yes, Y, True, On
        0: No, N, False, Off

       The match isn't case sensitive, so e.g. YES will also return -1.
       This makes evaluations easier of context items like:
       EnableFunction = Yes.

       This means that iniReadLong, etc. automatically take care of this.

@{b}INPUTS@{ub}
       String - The string containing the integer value.
       Default - Default integer value to use if error.


RESULT
       Integer - The converted integer value or the default value.


@{b}EXAMPLE@{ub}
       LONG IntValue;

       IntValue = iniStrToInt ( "%1111000011110000", 0x10000 );

       IntValue will be 0xF0F0 (61680) after calling this function.
       If an error would have occured during conversion, IntValue would
       default to 0x10000 (65536).


@{b}NOTES@{ub}
@{fg shine}       However, the string's value may not exceed -4,294,967,296 and
       +4,294,967,295 (32 bit limit) or an overflow error will occur.
       This function is used for all string to integer conversions.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniStrToFloat" Link "iniStrToFloat"}(), @{"iniIntToStr" Link "iniIntToStr"}(), @{"iniFloatToStr" Link "iniFloatToStr"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniWriteByteA" "ini.library/iniWriteByteA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniWriteByteA@{ub} -- writes an (U)BYTE array into an context item array.

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniWriteByteA@{ub}( iniFile, ContextName, ItemName, Array,
       D0                       A0       A1           A2        A3
                                Entries, Flags, Format, Len, ZeroSep );
                                D0       D1     D2      D3   D4:8

       BOOL @{b}iniWriteByteA@{ub}( struct iniFile *, STRPTR, STRPTR, BYTE *,
           ULONG, ULONG, ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes the values of the given (U)BYTE table to the specified context
       item in the given context.


@{b}INPUTS@{ub}
       iniFile - INI structure of the INI file which should be affected
       ContextName - The context name (C-String) in which context to store
           v32+: the context will be created if it's not existant
       ItemName - The context item name (C-String) in which the context item
           lies to write to.
           v32+: the context item will be created if it's not existant
       Array - An (U)BYTE array where to take the values from
       Entries - Number of entries to write
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.
       Format - Format of array entries to write out:
           INI_FORMAT_DEC - Use decimal with no precedor
           INI_FORMAT_DEC_CHAR - Use decimal with # precedor
           INI_FORMAT_HEX - Use hexadecimal with $ precedor
           INI_FORMAT_HEX_0X - Use hexadecimal with 0x precedor
           INI_FORMAT_BIN - Use binary with % precedor
           INI_FORMAT_OCT - Use octal with & precedor
           INI_FORMAT_YESNO - Use No for zero, Yes for all others
           INI_FORMAT_YN - Use N for zero, Y for all others
           INI_FORMAT_TRUEFALSE - Use False for zero, True for all others
           INI_FORMAT_ONOFF - Use Off for zero, On for all others
           INI_UNSIGNED - Add this to indicate unsigned integer
       Len - Forced length of outputted string or NULL for no force.
       ZeroSep - Zero character for Len leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if line could be written else FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       BYTE MyArray[4] = {-2, -1, 0, 1};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniWriteByteA ( ini, "MyContext", "MyItem", MyArray,
                       sizeof (MyArray), INI_FORMAT_DEC, 3L, '0' );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 25, 50, 75, 100

          then it will become (even if MyContext or MyItem don't exist yet):
          [MyContext]
          MyItem = -002, -001, 000, 001

          Entries which can't be stored are left unchanged.
       */


@{b}NOTES@{ub}
@{fg shine}       This function calls @{"iniPutByteA" Link "iniPutByteA"}() which is currently relatively slow.
       Especially with arrays with more than 16 entries.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniWriteWordA" Link "iniWriteWordA"}(), @{"iniWriteLongA" Link "iniWriteLongA"}(), @{"iniPutByteA" Link "iniPutByteA"}(), @{"iniReadByteA" Link "iniReadByteA"}(),
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniWriteFloat" "ini.library/iniWriteFloat"

@{b}NAME@{ub}
@{fg shine}       @{b}iniWriteFloat@{ub} -- Writes a quick floating point value into given
           item line

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniWriteFloat@{ub}( iniFile, ContextName, ItemName, Value,
       D0                       A0       A1           A2        D0
                                Flags, FltFormat, IntLen, FracLen, ZeroSep );
                                D1     D2         D3      D4       D5:8

       BOOL @{b}iniWriteFloat@{ub}( struct iniFile *, STRPTR, STRPTR, LONG, ULONG,
           ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes a quick float value into the given context item, belonging
       to the specified context.


@{b}INPUTS@{ub}
       iniFile - INI structure of the INI file to be accessed
       ContextName - Name of the context where context item lies
           v32+: the context will be created if it's not existant
       ItemName - Name of the context item where context item line lies
           v32+: the context item will be created if it's not existant
       Value - Quick float value to be written
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.
       FltFormat - Format of the floating point value. Can be any of:
           INI_FLOAT_FORMAT_DEC - Use decimal with point separator
           INI_FLOAT_UNSIGNED - Add this to indicate unsigned quick float
       IntLen - Forced length of integer part or NULL for no force.
       FracLen - Forced length of fractional part or NULL for no force.
       ZeroSep - Zero character for IntLen leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if successful write else FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniWriteFloat ( ini, "MyContext", "MyItem", 0x28000,
                       INI_FLOAT_FORMAT_DEC, 0L, 3L, ' ' );

       /* After this, ENVARC:MyPrefs.INI will contain:
          [MyContext]
          MyItem = 2.500

          If the context or the context item doesn't exist, they will be
          created in order to be written.
       */


@{b}NOTES@{ub}
@{fg shine}       This function calls from @{"iniPutFloat" Link "iniPutFloat"}().

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniWriteLong" Link "iniWriteLong"}(), @{"iniWriteStr" Link "iniWriteStr"}(), @{"iniWriteFloatA" Link "iniWriteFloatA"}(), @{"iniReadFloat" Link "iniReadFloat"}(),
       @{"iniPutFloat" Link "iniPutFloat"}(), @{"iniGetFloat" Link "iniGetFloat"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniWriteFloatA" "ini.library/iniWriteFloatA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniWriteFloatA@{ub} -- Writes quick floating point value(s) into
           item line(s)

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniWriteFloatA@{ub}( iniFile, ContextName, ItemName, Array,
       D0                        A0       A1           A2        A3
                                 Entries, Flags, FltFormat, IntLen, FracLen,
                                 D0       D1     D2         D3      D4:8
                                 ZeroSep );
                                 D5

       BOOL @{b}iniWriteFloatA@{ub}( struct iniFile *, STRPTR, STRPTR, LONG *,
           ULONG, ULONG, ULONG, ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes one or more quick float value(s) from an array into the given
       context item, belonging to the specified context.


@{b}INPUTS@{ub}
       iniFile - INI structure where to assign write to
       ContextName - The name of the context to be affected
           v32+: the context will be created if it's not existant
       ItemName - The name of the context item where to write array to
           v32+: the context item will be created if it's not existant
       Array - The array where to write the quick float values to
       Entries - Number of array entries. If the array in the INI file is
            bigger, the remaining entries will be ignored.
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.
       FltFormat - Format of the floating point value. Can be any of:
           INI_FLOAT_FORMAT_DEC - Use decimal with point separator
           INI_FLOAT_UNSIGNED - Add this to indicate unsigned quick float
       IntLen - Forced length of integer part or NULL for no force.
       FracLen - Forced length of fractional part or NULL for no force.
       ZeroSep - Zero character for IntLen leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       LONG MyFloat[4] = {-0x10000, -0x8000, 0, 0x8000};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniWriteFloatA ( ini, "MyContext", "MyItem", MyFloat,
                        (sizeof (MyFloat) / sizeof (LONG)),
                        INI_FLOAT_FORMAT_DEC, 3L, 4L, '0' );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 13.5, 17.25, 1.116, 3.1416

          then it will become:
          [MyContext]
          MyItem = -001.0000, -000.5000, 000.0000, 000.5000

          If the context or the context item do not exist, they will be
          created in order to be written.
       */


@{b}NOTES@{ub}
@{fg shine}       This function calls @{"iniPutFloatA" Link "iniPutFloatA"}() which is currently relatively slow.
       Especially with arrays with more than 16 entries.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniWriteLongA" Link "iniWriteLongA"}(), @{"iniWriteStrA" Link "iniWriteStrA"}(), @{"iniWriteFloat" Link "iniWriteFloat"}(), @{"iniReadFloatA" Link "iniReadFloatA"}(),
       @{"iniPutFloatA" Link "iniPutFloatA"}(), @{"iniGetFloatA" Link "iniGetFloatA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniWriteLong" "ini.library/iniWriteLong"

@{b}NAME@{ub}
@{fg shine}       @{b}iniWriteLong@{ub} -- Writes a long integer value into the context item line

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniWriteLong@{ub}( iniFile, ContextName, ItemName, Value,
       D0                      A0       A1           A2        D0
                               Flags, Format, Len, ZeroSep );
                               D1     D2      D3   D4:8

       BOOL @{b}iniWriteLong@{ub}( struct iniFile *, STRPTR, STRPTR, LONG, ULONG,
           ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes a long integer value into the specified context item line,
       belonging to the given context.


@{b}INPUTS@{ub}
       iniFile - INI structure of the INI file which should be affected
       ContextName - Name of the context where the value should be stored
           v32+: the context will be created if it's not existant
       ItemName - Name of the context item where to store value to
           v32+: the context item will be created if it's not existant
       Value - Value to be written
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.
       Format - Format of the outputted string. Can be any of:
           INI_FORMAT_DEC - Use decimal with no precedor
           INI_FORMAT_DEC_CHAR - Use decimal with # precedor
           INI_FORMAT_HEX - Use hexadecimal with $ precedor
           INI_FORMAT_HEX_0X - Use hexadecimal with 0x precedor
           INI_FORMAT_BIN - Use binary with % precedor
           INI_FORMAT_OCT - Use octal with & precedor
           INI_FORMAT_YESNO - Use No for zero, Yes for all others
           INI_FORMAT_YN - Use N for zero, Y for all others
           INI_FORMAT_TRUEFALSE - Use False for zero, True for all others
           INI_FORMAT_ONOFF - Use Off for zero, On for all others
           INI_UNSIGNED - Add this to indicate unsigned integer
       Len - Forced length of outputted string or NULL for no force.
       ZeroSep - Zero character for Len leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if value could successfully be written or FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniWriteLong ( ini, "MyContext", "MyItem", 13750,
                      INI_FORMAT_HEX_0X, 8L, ' ' );

       /* After this, ENVARC:MyPrefs.INI will contain:
          [MyContext]
          MyItem = 0x000035B6

          If the context or the context item do not exist, they will be
          created in order to be written.
       */


@{b}NOTES@{ub}
@{fg shine}       This function calls @{"iniPutLong" Link "iniPutLong"}().

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniWriteFloat" Link "iniWriteFloat"}(), @{"iniWriteStr" Link "iniWriteStr"}(), @{"iniWriteLongA" Link "iniWriteLongA"}(), @{"iniReadLong" Link "iniReadLong"}(),
       @{"iniPutLong" Link "iniPutLong"}(), @{"iniGetLong" Link "iniGetLong"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniWriteLongA" "ini.library/iniWriteLongA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniWriteLongA@{ub} -- writes an (U)LONG array into an context item array.

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniWriteLongA@{ub}( iniFile, ContextName, ItemName, Array,
       D0                       A0       A1           A2        A3
                                Entries, Flags, Format, Len, ZeroSep );
                                D0       D1     D2      D3   D4:8

       BOOL @{b}iniWriteLongA@{ub}( struct iniFile *, STRPTR, STRPTR, LONG *,
           ULONG, ULONG, ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes the values of the given (U)LONG table to the specified context
       item in the given context.


@{b}INPUTS@{ub}
       iniFile - INI structure of the INI file which should be affected
       ContextName - The context name (C-String) in which context to store
           v32+: the context will be created if it's not existant
       ItemName - The context item name (C-String) in which the context item
           lies to write to.
           v32+: the context item will be created if it's not existant
       Array - An (U)LONG array where to take the values from
       Entries - Number of entries to write
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.
       Format - Format of array entries to write out:
           INI_FORMAT_DEC - Use decimal with no precedor
           INI_FORMAT_DEC_CHAR - Use decimal with # precedor
           INI_FORMAT_HEX - Use hexadecimal with $ precedor
           INI_FORMAT_HEX_0X - Use hexadecimal with 0x precedor
           INI_FORMAT_BIN - Use binary with % precedor
           INI_FORMAT_OCT - Use octal with & precedor
           INI_FORMAT_YESNO - Use No for zero, Yes for all others
           INI_FORMAT_YN - Use N for zero, Y for all others
           INI_FORMAT_TRUEFALSE - Use False for zero, True for all others
           INI_FORMAT_ONOFF - Use Off for zero, On for all others
           INI_UNSIGNED - Add this to indicate unsigned integer
       Len - Forced length of outputted string or NULL for no force.
       ZeroSep - Zero character for Len leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if line could be written else FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       LONG MyArray[4] = {-200000, -100000, 0, 100000};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniWriteLongA ( ini, "MyContext", "MyItem", MyArray,
                       (sizeof (MyArray) / sizeof (LONG)),
                       INI_FORMAT_DEC, 0L, '0' );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 12345678, 76543210, 50000, -12345678

          then it will become:
          [MyContext]
          MyItem = -200000, -100000, 0, 100000

          If the context or the context item do not exist, they will be
          created in order to be written.
       */


@{b}NOTES@{ub}
@{fg shine}       This function calls @{"iniPutLongA" Link "iniPutLongA"}() which is currently relatively slow.
       Especially with arrays with more than 16 entries.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniWriteByteA" Link "iniWriteByteA"}(), @{"iniWriteWordA" Link "iniWriteWordA"}(), @{"iniPutLongA" Link "iniPutLongA"}(), @{"iniReadLongA" Link "iniReadLongA"}(),
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniWriteStr" "ini.library/iniWriteStr"

@{b}NAME@{ub}
@{fg shine}       @{b}iniWriteStr@{ub} -- Writes a string into a context item line

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniWriteStr@{ub}( iniFile, ContextName, ItemName, String,
       D0                     A0       A1           A2        A3
                              Flags );
                              D0
                              

       BOOL @{b}iniWriteStr@{ub}( struct iniFile *, STRPTR, STRPTR, STRPTR, ULONG );


@{b}FUNCTION@{ub}
       Writes a string into the given context item belonging to the
       specified context.


@{b}INPUTS@{ub}
       iniFile - INI structure of the INI file to be written
       ContextName - Name of the context where the item lies
           v32+: the context will be created if it's not existant
       ItemName - Name of the context item where string should be put
           v32+: the context item will be created if it's not existant
       String - String to be written
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.


RESULT
       success - TRUE if writing was successful else FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyMessages.INI", MODE_OLDFILE );

       iniWriteStr ( ini, "Messages", "Basty",
                     "I love Zuzana Burkertová !" );

       /* After this, ENVARC:MyMessages.INI will contain:
          [Messages]
          Basty = I love Zuzana Burkertová !

          If the context or the context item do not exist, they will be
          created in order to be written.
       */


@{b}NOTES@{ub}
@{fg shine}       This function calls @{"iniPutStr" Link "iniPutStr"}().

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniWriteLongA" Link "iniWriteLongA"}(), @{"iniWriteFloatA" Link "iniWriteFloatA"}(), iniWriteStr(), @{"iniReadStr" Link "iniReadStr"}(),
       @{"iniPutStrA" Link "iniPutStrA"}(), @{"iniGetStrA" Link "iniGetStrA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniWriteStrA" "ini.library/iniWriteStrA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniWriteStrA@{ub} -- Writes an array of string(s) into the context item
           line(s)

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniWriteStrA@{ub}( iniFile, ContextName, ItemName, Array,
       D0                      A0       A1           A2        A3
                               Entries, Flags );
                               D0       D1

       BOOL @{b}iniWriteStrA@{ub}( struct iniFile *, STRPTR, STRPTR, STRPTR *,
           ULONG, ULONG );


@{b}FUNCTION@{ub}
       Writes one or more strings into the given context item line,
       belonging to the specified context from an given array.


@{b}INPUTS@{ub}
       iniFile - INI file structure 
       ContextName - Name of the context where context item lies
           v32+: the context will be created if it's not existant
       ItemName - Name of the context item to be accessed
           v32+: the context item will be created if it's not existant
       Array - The array where to take the pointers of the strings from
       Entries - Number of array entries. If the array in the INI file is
            bigger, the remaining entries will be ignored.
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.


RESULT
       success - TRUE if accessing was successful else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       STRPTR MyStr[4] = {"String 1", "String 2", "String 3", "String 4"};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniWriteStrA ( ini, "MyContext", "MyItem" MyStr,
                      (sizeof (MyStr) / sizeof (STRPTR)) );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = Hello 1, Hello 2, Hello 3, Hello 4

          then it will become:
          [MyContext]
          MyItem = String 1, String 2, String 3, String 4

          If the context or the context item do not exist, they will be
          created in order to be written.
       */


@{b}NOTES@{ub}
@{fg shine}       This function calls @{"iniPutStrA" Link "iniPutStrA"}().

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniWriteLongA" Link "iniWriteLongA"}(), @{"iniWriteFloatA" Link "iniWriteFloatA"}(), @{"iniWriteStr" Link "iniWriteStr"}(), @{"iniReadStrA" Link "iniReadStrA"}(),
       @{"iniPutStrA" Link "iniPutStrA"}(), @{"iniGetStrA" Link "iniGetStrA"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniWriteWordA" "ini.library/iniWriteWordA"

@{b}NAME@{ub}
@{fg shine}       @{b}iniWriteWordA@{ub} -- writes an (U)WORD array into an context item array.

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniWriteWordA@{ub}( iniFile, ContextName, ItemName, Array,
       D0                       A0       A1           A2        A3
                                Entries, Flags, Format, Len, ZeroSep );
                                D0       D1     D2      D3   D4:8

       BOOL @{b}iniWriteWordA@{ub}( struct iniFile *, STRPTR, STRPTR, WORD *,
           ULONG, ULONG, ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       Writes the values of the given (U)WORD table to the specified context
       item in the given context.


@{b}INPUTS@{ub}
       iniFile - INI structure of the INI file which should be affected
       ContextName - The context name (C-String) in which context to store
           v32+: the context will be created if it's not existant
       ItemName - The context item name (C-String) in which the context item
           lies to write to.
           v32+: the context item will be created if it's not existant
       Array - An (U)WORD array where to take the values from
       Entries - Number of entries to write
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.
       Format - Format of array entries to write out:
           INI_FORMAT_DEC - Use decimal with no precedor
           INI_FORMAT_DEC_CHAR - Use decimal with # precedor
           INI_FORMAT_HEX - Use hexadecimal with $ precedor
           INI_FORMAT_HEX_0X - Use hexadecimal with 0x precedor
           INI_FORMAT_BIN - Use binary with % precedor
           INI_FORMAT_OCT - Use octal with & precedor
           INI_FORMAT_YESNO - Use No for zero, Yes for all others
           INI_FORMAT_YN - Use N for zero, Y for all others
           INI_FORMAT_TRUEFALSE - Use False for zero, True for all others
           INI_FORMAT_ONOFF - Use Off for zero, On for all others
           INI_UNSIGNED - Add this to indicate unsigned integer
       Len - Forced length of outputted string or NULL for no force.
       ZeroSep - Zero character for Len leading zeroes. Usually " " or "0"


RESULT
       success - TRUE if line could be written else FALSE


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       WORD MyArray[4] = {-2000, -1000, 0, 1000};

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       iniWriteWordA ( ini, "MyContext", "MyItem", MyArray,
                       (sizeof (MyArray) / sizeof (WORD)),
                       INI_FORMAT_DEC_CHAR, 0L, '0' );

       /* Let's say, ENVARC:MyPrefs.INI contains:
          [MyContext]
          MyItem = 1000, 2000, 3000, -10000

          then it will become:
          [MyContext]
          MyItem = -#2000, -#1000, #0, #1000

          If the context or the context item do not exist, they will be
          created in order to be written.
       */


@{b}NOTES@{ub}
@{fg shine}       This function calls @{"iniPutWordA" Link "iniPutWordA"}() which is currently relatively slow.
       Especially with arrays with more than 16 entries.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniWriteByteA" Link "iniWriteByteA"}(), @{"iniWriteLongA" Link "iniWriteLongA"}(), @{"iniPutWordA" Link "iniPutWordA"}(), @{"iniReadWordA" Link "iniReadWordA"}(),
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE

