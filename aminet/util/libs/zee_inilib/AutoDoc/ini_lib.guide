       Buffer = @{b}iniGetContextItemData@{ub}( ContextStr, ContextItemLine, Buffer );
       D0                              A0          A1               A2

       STRPTR @{b}iniGetContextItemData@{ub}( struct iniContext *,
           struct iniContextItemLine *, STRPTR );


