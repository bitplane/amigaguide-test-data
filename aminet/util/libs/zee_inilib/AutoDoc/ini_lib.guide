@NODE "--background--" "ini.library/--background--"

@{b}PURPOSE@{ub}

       The 'ini.library' was created, because there was no easy way of
       handling configuration files. Each program had it's own format.

       This library tries to help you in making a standard file format for
       configuration files. These files are in plain ASCII, so you can use
       your favourite text editor to edit them, and, in addition, of course,
       you can use the prefs section of your program.


@{b}OVERVIEW@{ub}

       The initialization files (INI files) come from Microsoft Windows 3.x.
       They are built up as follows:
       [Context1]
         Item1 = Long1
         Item2 = Long2
         Item3 = LongA1, LongA2, LongA3,
                 LongA4, LongA5, LongA6,
         Item4 = Float1
         Item5 = String1

       [Context2]
         Item1 = Float1
       ...

       * Easy accessable

       The library makes it easy to read/write access those context/item
       fields. You can easily add/remove new items, contexts, etc.

       * Comments, etc. are all handled & preserved automatically!

       Yes, if you update an INI context item, the comment after the line
       is preserved. That means, if you update the INI file in a program,
       you don't need to have any fears of lossing something.

       * Both high- and low-level access functions
  
       You can choose between simply access and complex access. Low level
       functions are for complex access, high level functions are for quick
       and easy access. But the high level functions are a little slower.




@ENDNODE


@NODE "iniAddContext" "ini.library/iniAddContext"

@{b}NAME@{ub}
@{fg shine}       @{b}iniAddContext@{ub} -- adds a new freshly allocated context to an INI file
                        structure

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniAddContext@{ub}( iniFile, ContextStr );
                      A0       A1

       void @{b}iniAddContext@{ub}( struct iniFile *, struct iniContext *);


@{b}FUNCTION@{ub}
       Adds a freshly created context to a specified INI file.
       To add items, you first need to add context items, see there.


@{b}INPUTS@{ub}
       iniFile - Pointer to INI structure where to add it
       ContextStr - Freshly context structure to add


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       /* Check if "MyContext" already exists */
       if (!( context = FindContext ( ini, "MyContext" )))
       {
         /* If not, create it! */
         if (!( context = CreateContext ( "MyContext" )))
         {
           puts ( "Couldn't create my context !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContext ( ini, context );
       }


@{b}NOTES@{ub}
@{fg shine}       You need to call this function to make a *NEW* context available
       to the other functions.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniCreateContext" Link "iniCreateContext"}(), @{"iniFreeContext" Link "iniFreeContext"}(), @{"iniRemContext" Link "iniRemContext"}(),
       @{"iniInsertContext" Link "iniInsertContext"}(), @{"iniDeleteContext" Link "iniDeleteContext"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniAddContextItem" "ini.library/iniAddContextItem"

@{b}NAME@{ub}
@{fg shine}       @{b}iniAddContextItem@{ub} -- adds a new freshly allocated context item to
                            an context structure

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniAddContextItem@{ub}( ContextStr, ContextItemLine );
                          A0          A1

       void @{b}iniAddContextItem@{ub}( struct iniContext *,
           struct iniContextItemLine *);


@{b}FUNCTION@{ub}
       Adds a freshly created context item to a specified context.


@{b}INPUTS@{ub}
       ContextStr - Pointer to context structure where to add it
       ContextItemLine - Freshly context item structure to add


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }


@{b}NOTES@{ub}
@{fg shine}       You need to call this function to make a *NEW* context item available
       to the other functions.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniCreateContextItem" Link "iniCreateContextItem"}(), @{"iniFreeContextItem" Link "iniFreeContextItem"}(), @{"iniRemContextItem" Link "iniRemContextItem"}(),
       @{"iniInsertContextItem" Link "iniInsertContextItem"}(), @{"iniDeleteContextItem" Link "iniDeleteContextItem"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniAllocNameStr" "ini.library/iniAllocNameStr"

@{b}NAME@{ub}
@{fg shine}       @{b}iniAllocNameStr@{ub} -- allocate a name string compatible with the library

@{fg text}
@{b}SYNOPSIS@{ub}
       namestring = @{b}iniAllocNameStr@{ub}( string );
       D0                            A0

       STRPTR @{b}iniAllocNameStr@{ub}( STRPTR string );


@{b}FUNCTION@{ub}
       Allocates a name string out of a standard C-String. This is required
       if you use own strings in the library handlers.


@{b}INPUTS@{ub}
       string - The string to be allocated. Must be null terminated.


RESULT
       namestring - The initialized name structure. To deallocate, use
           @{"iniFreeNameStr" Link "iniFreeNameStr"}() on this result.


@{b}NOTES@{ub}
@{fg shine}       The namestring is a copy of string, but it's freed via @{"iniFreePMem" Link "iniFreePMem"}()

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniFreeNameStr" Link "iniFreeNameStr"}(), @{"iniSetNameStr" Link "iniSetNameStr"}(), @{"iniSetString" Link "iniSetString"}()



@ENDNODE


@NODE "iniAllocPMem" "ini.library/iniAllocPMem"

@{b}NAME@{ub}
@{fg shine}       @{b}iniAllocPMem@{ub} -- allocate MEMF_PUBLIC|MEMF_CLEAR memory like AllocMem()
                       but use memory pools if running under OS3.0+

@{fg text}
@{b}SYNOPSIS@{ub}
       memoryBlock = @{b}iniAllocPMem@{ub}( byteSize );
       D0                          D0

       APTR @{b}iniAllocPMem@{ub}( ULONG );


@{b}FUNCTION@{ub}
       Allocates memory always with MEMF_PUBLIC and MEMF_CLEAR flags set and
       uses, if possible, the OS3.0+ memory pools. I have decided to
       implement this function, because the INI library allocates often
       very small chunks of memory, which is handled more efficiency with
       memory pools.

       Each memory pool has a size of 32768 bytes and a threshold of
       4096 bytes.


@{b}INPUTS@{ub}
       byteSize - number of bytes to allocate.


RESULT
       memoryBlock - the first byte of the allocated memory or NULL if
           the allocation failed.


@{b}NOTES@{ub}
@{fg shine}       Please note that you MUST deallocate memory allocated with
       iniAllocPMem() with @{"iniFreePMem" Link "iniFreePMem"}() or it *MAY* crash!

       iniAllocPMem() is used always for internal purposes, so that you
       *MUST* allocate all structures used with this lib with this function.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniFreePMem" Link "iniFreePMem"}(), exec.library/AllocMem(), exec.library/AllocPooled()



@ENDNODE


@NODE "iniCheckComment" "ini.library/iniCheckComment"

@{b}NAME@{ub}
@{fg shine}       @{b}iniCheckComment@{ub} -- Checks if a context line belongs to a comment

@{fg text}
@{b}SYNOPSIS@{ub}
       success = @{b}iniCheckComment@{ub}( ContextStr, ContextItemLine );
       D0                         A0          A1

       BOOL @{b}iniCheckComment@{ub}( struct iniContext *,
           struct iniContextItemLine *);


@{b}FUNCTION@{ub}
       Checks if the given context item line is part of a multiline comment.
       This function is mainly for internal use to easy handle the parsing
       of lines.


@{b}INPUTS@{ub}
       ContextStr - A pointer to context structure which contains the line
           to be examined.
       ContextItemLine - A pointer to the context item line which should be
           examined.


RESULT
       success - TRUE if the line is commented else NULL.


@{b}NOTES@{ub}
@{fg shine}
@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniClose" "ini.library/iniClose"

@{b}NAME@{ub}
@{fg shine}       @{b}iniClose@{ub} -- Deallocate a loaded INI file

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniClose@{ub}( iniFile );
                 A0

       void @{b}iniClose@{ub}( struct iniFile *);


@{b}FUNCTION@{ub}
       This function is used to deallocate the memory required by the
       the loaded INI file. It deallocates everything in the given INI
       file structure.


@{b}INPUTS@{ub}
       iniFile - A pointer to the INI file structure to be freed


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       ULONG Width;

       /* Let's open an INI file to fiddle around with */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       /* Let's do some evaluating (read screen width) */
       Width = iniReadLong ( ini, "Screen", "Width", 640L, 0L );

       /* We have the info we need. So close it and free memory */
       iniClose ( ini );


@{b}NOTES@{ub}
@{fg shine}       All memory blocks inside must be allocated using @{"iniAllocPMem" Link "iniAllocPMem"}() or
       @{"iniAllocNameStr" Link "iniAllocNameStr"}() or it may crash!

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniOpenFile" Link "iniOpenFile"}(), @{"iniOpenFromFH" Link "iniOpenFromFH"}(), @{"iniOpenMem" Link "iniOpenMem"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniCreateContext" "ini.library/iniCreateContext"

@{b}NAME@{ub}
@{fg shine}       @{b}iniCreateContext@{ub} -- Creates a new context chunk to be used

@{fg text}
@{b}SYNOPSIS@{ub}
       ContextStr = @{b}iniCreateContext@{ub}( ContextName );
       D0                             A0

       struct iniContext *@{b}iniCreateContext@{ub}( STRPTR ContextName );


@{b}FUNCTION@{ub}
       Creates a new context structure. It must be added with @{"iniAddContext" Link "iniAddContext"}()
       to an INI file structure. The name given mustn't be an AllocNameStr()
       string. Because it's created automatically during the creation
       process.


@{b}INPUTS@{ub}
       ContextName - The line string of the context


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       /* Check if "MyContext" already exists */
       if (!( context = FindContext ( ini, "MyContext" )))
       {
         /* If not, create it! */
         if (!( context = CreateContext ( "MyContext" )))
         {
           puts ( "Couldn't create my context !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContext ( ini, context );
       }


@{b}NOTES@{ub}
@{fg shine}       ContextName is only the context name itself, not the full line,
       e.g. "Display", and not "[ Display ]".

@{fg text}
@{b}BUGS@{ub}
@{fg shine}       In ini.library v31 you had to give the full context line, i.e.
       "[ Display ]".

@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniCreateContextItem" Link "iniCreateContextItem"}(), @{"iniFreeContext" Link "iniFreeContext"}(), @{"iniAddContext" Link "iniAddContext"}(),
       @{"iniInsertContext" Link "iniInsertContext"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniCreateContextItem" "ini.library/iniCreateContextItem"

@{b}NAME@{ub}
@{fg shine}       @{b}iniCreateContextItem@{ub} -- creates a new context item to be used

@{fg text}
@{b}SYNOPSIS@{ub}
       ContextItemLine = @{b}iniCreateContextItem@{ub}( CStr );
       D0                                      A0

       struct iniContextItemLine *@{b}iniCreateContextItem@{ub}( STRPTR CStr );


@{b}FUNCTION@{ub}
       Creates a new context item line to be used. The string will be used
       as a context line name. Add the result structure to the context
       structure to make it available in the INI file structure.


@{b}INPUTS@{ub}
       CStr - A null terminated string which will be stored as a
           @{"iniAllocNameStr" Link "iniAllocNameStr"}() string.


RESULT
       ContextItemLine - The context item structure that can be added to
           the desired context.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }


@{b}NOTES@{ub}
@{fg shine}       The context item is initialized with 0.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}       In ini.library v31 the context item was not initialized.

@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniCreateContext" Link "iniCreateContext"}(), @{"iniFreeContextItem" Link "iniFreeContextItem"}(), @{"iniAddContextItem" Link "iniAddContextItem"}(),
      @{"iniInsertContextItem" Link "iniInsertContextItem"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniDeleteContext" "ini.library/iniDeleteContext"

@{b}NAME@{ub}
@{fg shine}       @{b}iniDeleteContext@{ub} -- deletes a context from an INI file structure

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniDeleteContext@{ub}( ContextStr );
                         A0

       void @{b}iniDeleteContext@{ub}( struct iniContext *);


@{b}FUNCTION@{ub}
       Deletes a context of an INI file and all its associated lines.
       Memory will not be freed. To deallocate, use @{"iniFreeContext" Link "iniFreeContext"}()


@{b}INPUTS@{ub}
       ContextStr - The context structure to be deleted


RESULT


@{b}NOTES@{ub}
@{fg shine}       Please note that this function removes only the node from the
       INI file structure and doesn't deallocate any memory.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniFreeContext" Link "iniFreeContext"}(), @{"iniRemContext" Link "iniRemContext"}(), @{"iniInsertContext" Link "iniInsertContext"}(),
      <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniDeleteContextItem" "ini.library/iniDeleteContextItem"

@{b}NAME@{ub}
@{fg shine}       @{b}iniDeleteContextItem@{ub} -- deletes a context item line from an INI file.

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniDeleteContextItem@{ub}( ContextItemLine );
                             A0

       void @{b}iniDeleteContextItem@{ub}( struct iniContextItemLine *);


@{b}FUNCTION@{ub}
       Deletes a context item line from an INI context. It doesn't
       deallocate any memory, so it can be added otherwise.


@{b}INPUTS@{ub}
       ContextItemLine - The pointer of the context item line to be deleted.


RESULT


@{b}NOTES@{ub}
@{fg shine}       Please note that just the node is removed from the context structure
       and there are no deallocation processes. Use @{"iniFreeContextItem" Link "iniFreeContextItem"}()
       for this purpose.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniFreeContextItem" Link "iniFreeContextItem"}(), @{"iniRemContextItem" Link "iniRemContextItem"}(), @{"iniInsertContextItem" Link "iniInsertContextItem"}(),
       <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniFindContext" "ini.library/iniFindContext"

@{b}NAME@{ub}
@{fg shine}       @{b}iniFindContext@{ub} -- Search for a context in an INI file.

@{fg text}
@{b}SYNOPSIS@{ub}
       ContextStr = @{b}iniFindContext@{ub}( iniFile, ContextName, Flags );
       D0                           A0       A1           D0

       struct iniContext *@{b}iniFindContext@{ub}( struct iniFile *,
           STRPTR, ULONG );


@{b}FUNCTION@{ub}
       Searches a loaded INI file for the specified context.


@{b}INPUTS@{ub}
       iniFile - Pointer to INI structure to search
       ContextName - Name of the context to be searched
       Flags - Search flags. They're currently defined as:
           INIF_ContextCase - Set this flag if the search of the context
               name should be case sensitive.


RESULT
       ContextStr - The context structure if the context was found else
           NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       /* Check if "MyContext" already exists */
       if (!( context = FindContext ( ini, "MyContext" )))
       {
         /* If not, create it! */
         if (!( context = CreateContext ( "MyContext" )))
         {
           puts ( "Couldn't create my context !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContext ( ini, context );
       }


@{b}NOTES@{ub}
@{fg shine}
@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniCreateContext" Link "iniCreateContext"}(), @{"iniFindItem" Link "iniFindItem"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniFindItem" "ini.library/iniFindItem"

@{b}NAME@{ub}
@{fg shine}       @{b}iniFindItem@{ub} -- finds a context item in a specified context

@{fg text}
@{b}SYNOPSIS@{ub}
       ContextItemLine = @{b}iniFindItem@{ub}( ContextStr, ContextItemName, Flags );
       D0                             A0          A1               D0

       struct iniContextItemLine *@{b}iniFindItem@{ub}( struct iniContext *,
           STRPTR, ULONG );


@{b}FUNCTION@{ub}
       Searches for a context item in the specified context


@{b}INPUTS@{ub}
       ContextStr - Context structure where to search in
       ContextItemName - Name of the context item to be searched
       Flags - Search flags. They're currently defined as:
           INIF_ContextItemCase - Set this flag if the search of the context
               item name should be case sensitive.


RESULT
       ContextItemLine - The context item structure if the context item
           was found else NULL.


@{b}EXAMPLE@{ub}
       struct iniFile *ini;
       struct iniContext *context;
       struct iniContextItemLine *contextitem;

       /* Let's open an INI file */
       ini = iniOpenFile ( "ENVARC:MyPrefs.INI", MODE_OLDFILE );

       context = FindContext ( ini, "MyContext" );

       if (!( contextitem = FindContextItem ( context, "MyItem" )))
       {
         /* If not, create it! */
         if (!( contextitem = CreateContextItem ( "MyItem" )))
         {
           puts ( "Couldn't create my context item !" );

           exit ( 20 );
         }

         /* Make context available for access */
         AddContextItem ( context, contextitem );
       }


@{b}NOTES@{ub}
@{fg shine}
@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniCreateContextItem" Link "iniCreateContextItem"}(), @{"iniFindContext" Link "iniFindContext"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniFloatToStr" "ini.library/iniFloatToStr"

@{b}NAME@{ub}
@{fg shine}       @{b}iniFloatToStr@{ub} -- Converts a quick float value to a string.

@{fg text}
@{b}SYNOPSIS@{ub}
       string = @{b}iniFloatToStr@{ub}( Buffer, Float, FltFormat, IntLen, FracLen,
       D0                      A0      D0     D1         D2      D3
                               ZeroSep );
                               D4:8

       STRPTR @{b}iniFloatToStr@{ub}( STRPTR, ULONG, ULONG, ULONG, ULONG, UBYTE );


@{b}FUNCTION@{ub}
       This function is used to convert a quick float value to a standard
       ASCII string. A quick float value has in it's upper 16-bits the
       decimal value and in the lower 16-bits the fraction. That means, the
       highest possible accuracy is 1/65536.


@{b}INPUTS@{ub}
       Buffer - A pointer to at least a 128 byte buffer or NULL to create a
           new one.
       Float - Quick float value to convert.
       FltFormat - Format of the floating point value. Can be any of:
           INI_FLOAT_FORMAT_DEC - Use decimal with point separator
           INI_FLOAT_UNSIGNED - Add this to indicate unsigned quick float
       IntLen - Forced length of integer part or NULL for no force.
       FracLen - Forced length of fractional part or NULL for no force.
       ZeroSep - Zero character for IntLen leading zeroes. Usually " " or "0"


RESULT
       string - Pointer to the string where the converted string is stored.


@{b}EXAMPLE@{ub}
       STRPTR Buffer;

       Buffer = iniFloatToStr ( 0x28000, INI_FLOAT_FORMAT_DEC, 3, 2, ' ');

       /* Buffer will contain: "  2.50" */

       puts ( Buffer );

       iniFreeNameStr ( Buffer );

@{b}NOTES@{ub}
@{fg shine}
@{fg text}
@{b}BUGS@{ub}
@{fg shine}      The buffer is not checked for overflow. That means, IntLen and FracLen
      should not be greater than 90% of your buffer when added together.

@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniStrToFloat" Link "iniStrToFloat"}(), @{"iniStrToInt" Link "iniStrToInt"}(), @{"iniIntToStr" Link "iniIntToStr"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniFreeContext" "ini.library/iniFreeContext"

@{b}NAME@{ub}
@{fg shine}       @{b}iniFreeContext@{ub} -- Deletes if necessary and deallocates a context
           structure.

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniFreeContext@{ub}( ContextStr );
                       A0

       void @{b}iniFreeContext@{ub}( struct iniContext *);


@{b}FUNCTION@{ub}
       This function removes first (see @{"iniDeleteContext" Link "iniDeleteContext"}()), if necessary a
       context structure and then deallocates the memory used by it using
       @{"iniFreePMem" Link "iniFreePMem"}() and @{"iniFreeNameStr" Link "iniFreeNameStr"}().


@{b}INPUTS@{ub}
       ContextStr - A pointer to a context structure to be deallocated.


RESULT


@{b}NOTES@{ub}
@{fg shine}       The structure MUST be allocated with @{"iniAllocPMem" Link "iniAllocPMem"}() and the strings
       must be allocated with @{"iniAllocNameStr" Link "iniAllocNameStr"}()

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniCreateContext" Link "iniCreateContext"}(), @{"iniRemContext" Link "iniRemContext"}(), @{"iniDeleteContext" Link "iniDeleteContext"}(),
       @{"iniFreeContextItem" Link "iniFreeContextItem"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniFreeContextItem" "ini.library/iniFreeContextItem"

@{b}NAME@{ub}
@{fg shine}       @{b}iniFreeContextItem@{ub} -- Deallocates a context item structure

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniFreeContextItem@{ub}( ContextItemLine );
                           A0

       void @{b}iniFreeContextItem@{ub}( struct iniContextItemLine *);


@{b}FUNCTION@{ub}
       Removes (if necessary) a context item line and deallocates the memory
       required by it afterwards. @{"iniFreePMem" Link "iniFreePMem"}() and @{"iniFreeNameStr" Link "iniFreeNameStr"}() are
       used for deallocation.


@{b}INPUTS@{ub}
       ContextItemLine - Pointer to the context item line to be deallocated.


RESULT


@{b}NOTES@{ub}
@{fg shine}       The structure MUST be allocated with @{"iniAllocPMem" Link "iniAllocPMem"}() and the strings
       need to be allocated with @{"iniAllocNameStr" Link "iniAllocNameStr"}().

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
      @{"iniCreateContextItem" Link "iniCreateContextItem"}(), @{"iniRemContextItem" Link "iniRemContextItem"}(), @{"iniDeleteContextItem" Link "iniDeleteContextItem"}(),
      @{"iniFreeContext" Link "iniFreeContext"}(), <@{"libraries/ini_lib.h" Link "INCLUDE:libraries/ini_lib.h/Main" 0}>



@ENDNODE


@NODE "iniFreeNameStr" "ini.library/iniFreeNameStr"

@{b}NAME@{ub}
@{fg shine}       @{b}iniFreeNameStr@{ub} -- Deallocate an @{"iniAllocNameStr" Link "iniAllocNameStr"}() name structure.

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniFreeNameStr@{ub}( namestring );
                       A0

       void @{b}iniFreeNameStr@{ub}( STRPTR );


@{b}FUNCTION@{ub}
       Deallocates a name structure, allocated previously by
       @{"iniAllocNameStr" Link "iniAllocNameStr"}()


@{b}INPUTS@{ub}
       namestring - A pointer to a previously allocated name string. The
           size of deallocation is calculated automatically.


RESULT


@{b}NOTES@{ub}
@{fg shine}       Please deallocate ONLY those things allocated with @{"iniAllocNameStr" Link "iniAllocNameStr"}()
       with this function, since the allocation mechanism may change at any
       time!

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniAllocNameStr" Link "iniAllocNameStr"}(), @{"iniAllocPMem" Link "iniAllocPMem"}(), @{"iniFreePMem" Link "iniFreePMem"}()



@ENDNODE


@NODE "iniFreePMem" "ini.library/iniFreePMem"

@{b}NAME@{ub}
@{fg shine}       @{b}iniFreePMem@{ub} -- deallocates memory allocated by @{"iniAllocPMem" Link "iniAllocPMem"}()

@{fg text}
@{b}SYNOPSIS@{ub}
       @{b}iniFreePMem@{ub}( memoryBlock, byteSize)
                    A1           D0

       void @{b}iniFreePMem@{ub}( APTR, ULONG );


@{b}FUNCTION@{ub}
       Deallocates any memory allocated by iniFreePMem(), it works just like
       the exec.library/FreeMem function.


@{b}INPUTS@{ub}
       memoryBlock - The block that should be deallocated
       byteSize - Number of bytes to be deallocated. It is aligned
           automatically.


RESULT


@{b}NOTES@{ub}
@{fg shine}       Please use this function to deallocate ONLY @{"iniAllocPMem" Link "iniAllocPMem"}() blocks,
       if you don't do this, the system may crash within OS3.0+, since the
       function uses memory pools in that case.

@{fg text}
@{b}BUGS@{ub}
@{fg shine}
@{fg text}
@{b}SEE ALSO@{ub}
       @{"iniAllocPMem" Link "iniAllocPMem"}()



@ENDNODE


@NODE "iniGetArrayLine" "ini.library/iniGetArrayLine"

