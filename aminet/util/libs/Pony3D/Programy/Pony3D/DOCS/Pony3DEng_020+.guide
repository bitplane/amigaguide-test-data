@node "p3dRotate" "p3dRotate"

pony3d.library/p3dRotate                                     pony3d.library/p3dRotate

   NAME
	p3dRotate -- Revolving point by given angle

   SYNOPSIS
	p3dRotate( anglex, angley, anglez, cubestructpoints, rotatedpoints )
		   D4	   D5	   D6      A0		     A1

	VOID p3dRotate(ULONG, ULONG, ULONG, struct cubestructpoints *, struct rotatedpoints *)

   FUNCTION
	Function revolving all point in cubestructpoints table by given
	angle.

   INPUTS
	anglex - angle of revolve in X axis
	angley - angle of revolve in Y axis
	anglez - angle of revolve in Z axis
	cubestructpoints - pointer to cubestructpoints structure where are
			   the points co-ordinates.
	rotatedpoints - pointer to memory array where results co-ordinates
			will be write (rotatedpoints).

   NOTE
	Cubestructpoints looks like that:

	CubeStructPoints:

		dc.l	n-1
		dc.l	x,y,z		;P1
		dc.l	x,y,z		;P2
		dc.l	x,y,z		;P3
		...
		dc.l	x,y,z		;Pn

	where:
	
	n - quantity of vertexs
	x - x co-ordinate
	y - y co-ordinate
	z - z co-ordinate

	Size of the array for rotatedpoints sructure you can count
	from formula: n*12+4, wher n means quantity of vertexs.
	This structure looks like that:

	RotatedPoints:

		dc.l	n-1
		dc.l	xr,yr,zr	 ;P1
		dc.l	xr,yr,zr	 ;P2
		dc.l	xr,yr,zr	 ;P3
		...
		dc.l	xr,yr,zr	 ;Pn

	where:
	
	n - quantity of vertexs
	xr - revolved x co-ordinate
	yr - revolved x co-ordinate
	zr - revolved x co-ordinate

@endnode

@node "p3dMove" "p3dMove"

pony3d.library/p3dMove                                     pony3d.library/p3dMove

   NAME
	p3dMove -- Moves rotated point.

   SYNOPSIS
	p3dMove( movex, movey, movez, rotatedpoints, movedpoints )
		 D0	D1     D2     A0	     A1

	VOID p3dMove(ULONG, ULONG, ULONG, struct rotatedpoints *, struct movedpoints *)

   FUNCTION
	This function moves all points in table.Points should be already
	revolved.

   INPUTS
	movex - shift in X axis
	movey - shift in Y axis
	movez - shift in Z axis
	rotatedpoints - pointer to structure rotatedpoints (created by
		        p3dRotate) where are the vertex co-ordinates.
	movedpoints - pointer to array of memory where results will be
		      write (movedpoints).

   NOTE

	Structure rotatedpoints looks like that:

	RotatedPoints:

		dc.l	n-1
		dc.l	xr,yr,zr	 ;P1
		dc.l	xr,yr,zr	 ;P2
		dc.l	xr,yr,zr	 ;P3
		...
		dc.l	xr,yr,zr	 ;Pn

	where:
	
	n - quantity of vertexs
	xr - revolved x co-ordinate
	yr - revolved y co-ordinate
	zr - revolved z co-ordinate

	Size of array for structure movedpoints you can count
	from formula: n*12+4, where n means quantity of vertexs.
	This structure looks like that:

	MovedPoints:

		dc.l	n-1
		dc.l	xrm,yrm,zrm	 ;P1
		dc.l	xrm,yrm,zrm	 ;P2
		dc.l	xrm,yrm,zrm	 ;P3
		...
		dc.l	xrm,yrm,zrm	 ;Pn

	where:
	
	n - quantity of vertexs
	xrm - revolved and moved x co-ordinate
	yrm - revolved and moved y co-ordinate
	zrm - revolved and moved z co-ordinate

@endnode

@node "p3dPerspective" "p3dPerspective"

pony3d.library/p3dPerspective                                     pony3d.library/p3dPerspective

   NAME
	p3dPerspective -- Makes perspective throw of already revolved
			  and moved points.

   SYNOPSIS
	p3dPerspective( distance, width, height, movedpoints, 2dcords )
		 	D0	  D1     D2      A0	      A1

	VOID p3dPerspective(ULONG, ULONG, ULONG, struct movedpoints *, struct 2dcords *)

   FUNCTION
	This function makes perspective throw so we get co-ordinates on
	plane.Points have to be already revolved and moved.

   INPUTS
	distance - distance between plane and observer in Z axis
	width - width of screen
	height - height of screen
	movedpoints - pointer to structure movedpoints (created by
			p3dMove) where are points co-ordinates.
	2dcords - pointer to array of memory in which results will
		  be write(2dcords).

   NOTE

	Structure movedpoints looks like that:

	MovedPoints:

		dc.l	n-1
		dc.l	xrm,yrm,zrm	 ;P1
		dc.l	xrm,yrm,zrm	 ;P2
		dc.l	xrm,yrm,zrm	 ;P3
		...
		dc.l	xrm,yrm,zrm	 ;Pn

	where:
	
	n - quantity of vertexs
	xrm - revolved and moved x co-ordinate
	yrm - revolved and moved y co-ordinate
	zrm - revolved and moved z co-ordinate

	Size of array for 2dcords structure you can count
	from formula: n*8+4, where n means quantity of vertexs.
	This structure looks like that:

	2DCords:

		dc.l	n-1
		dc.l	x`,y`		 ;P1
		dc.l	x`,y`		 ;P2
		dc.l	x`,y`		 ;P3
		...
		dc.l	x`,y`		 ;Pn

	where:
	
	n - quantity of vertexs
	x` - x co-ordinate on plane
	y` - y co-ordinate on plane

@endnode

@node "p3dPointRepresent" "p3dPointRepresent"

pony3d.library/p3dPointRepresent                                     pony3d.library/p3dPointRepresent

   NAME
	p3dPointRepresent -- Show all the vertexs and only vertexs on
			     the screen.

   SYNOPSIS
	p3dPointRepresent( 2dcords , plane )
		 	   A0	     A1

	VOID p3dPerspective(struct 2dcords *, APTR)

   FUNCTION
	Function show on the screen points with given co-ordinates.
	The points are not conected.

   INPUTS
	2dcords - pointer to 2dcords structure (created by
		  p3dPerspective) where are the points co-ordinates.
	plane - pointer to the screen.

   NOTE

	Structure 2dcords looks like that:

	2DCords:

		dc.l	n-1
		dc.l	x`,y`		 ;P1
		dc.l	x`,y`		 ;P2
		dc.l	x`,y`		 ;P3
		...
		dc.l	x`,y`		 ;Pn

	where:
	
	n - quantity of vertexs
	x` - x co-ordinate on plane
	y` - y co-ordinate on plane

@endnode

