@node "midi.datatype" "midi.datatype/midi.datatype"

    @{b}NAME@{ub}
        midi.datatype -- data type for midi stream files with timestamps

    @{b}FUNCTION@{ub}
        The midi data type, a base-class of all midi data, is used to
        load, save and play standard midi files and similar music files
        (using datatypes subclasses). A control panel can be applied to a
        window.
        The control panel currently is very simple and triggers one of
        @{"STM_PLAY" link "include:datatypes/datatypesclass.h/main" 364} and @{"STM_PAUSE" link "include:datatypes/datatypesclass.h/main" 363}, depending on the playing state.
        The midi player makes use of camd.library and realtime.library.

    @{b}PREFS@{ub}
        The data type tries to load the prefs file from
        "ENV:DataTypes/midi.prefs" and parses it using @{"ReadArgs()" link "dos/ReadArgs()"} on each
        @{"OM_NEW" link "include:intuition/classusr.h/main" 63} method to set up the attributes. The template is:

        CLUSTER/K,VOLUME/N/K

        CLUSTER   - sets @{"MDTA_Cluster" link "include:datatypes/midiclass.h/main" 42} to the given name, default is "out.0".
        VOLUME    - sets @{"SDTA_Volume" link "include:datatypes/soundclass.h/main" 43} to the given value, default is 64.

        The options can be on several lines. The prefs file must end with
        a line feed, so you cannot use SETENV.

    @{b}METHODS@{ub}
        @{"OM_NEW" link "include:intuition/classusr.h/main" 63} -- Create a new object from a SMF file

        @{"OM_DISPOSE" link "include:intuition/classusr.h/main" 64} -- dispose the object (triggers @{"STM_STOP" link "include:datatypes/datatypesclass.h/main" 380})

        @{"OM_GET" link "include:intuition/classusr.h/main" 66} -- get a attribute of the object

        @{"OM_SET" link "include:intuition/classusr.h/main" 65} -- set attributes of the object

        @{"OM_UPDATE" link "include:intuition/classusr.h/main" 70} -- update some attributes of the object

        @{"GM_HITTEST" link "include:intuition/gadgetclass.h/main" 188} -- check if gadget has been hit

        @{"GM_GOACTIVE" link "include:intuition/gadgetclass.h/main" 192} -- gadget pressed

        @{"GM_GOINACTIVE" link "include:intuition/gadgetclass.h/main" 194} -- gadget released

        @{"GM_HANDLEINPUT" link "include:intuition/gadgetclass.h/main" 193} -- handle intuition input events

        @{"GM_LAYOUT" link "include:intuition/gadgetclass.h/main" 199} -- layout the control panel (calculate sizes)

        @{"GM_RENDER" link "include:intuition/gadgetclass.h/main" 191} -- attach the control panel to a window

        @{"DTM_REMOVEDTOBJECT" link "include:datatypes/datatypesclass.h/main" 266} -- remove control panel from window

        @{"DTM_WRITE" link "include:datatypes/datatypesclass.h/main" 285}
            @{"DTWM_RAW" link "include:datatypes/datatypesclass.h/main" 429} writes a SMF file
            @{"DTWM_IFF" link "include:datatypes/datatypesclass.h/main" 426} is unsupported, since there is no IFF-MIDI format yet

        @{"DTM_TRIGGER" link "include:datatypes/datatypesclass.h/main" 279}
            @{"STM_PLAY" link "include:datatypes/datatypesclass.h/main" 364} starts playing (a separate process will be launched)
                     or continues playing after pause
            @{"STM_PAUSE" link "include:datatypes/datatypesclass.h/main" 363} pauses playing (might start playing first)
            @{"STM_STOP" link "include:datatypes/datatypesclass.h/main" 380} stops playing and removes the player process

    @{b}TAGS@{ub}
        @{"MDTA_Cluster" link "include:datatypes/midiclass.h/main" 42} -- (@{"UBYTE" link "include:exec/types.h/main" 47} *) name of the CAMD cluster to play midi
            data to. Default: "out.0". Applicability is (ISG).

        Tags defined in @{"datatypes/soundclass.h" link "include:datatypes/soundclass.h/main"}:
        @{"SDTA_Cycles" link "include:datatypes/soundclass.h/main" 46}
        @{"SDTA_Volume" link "include:datatypes/soundclass.h/main" 43} -- volume does not get used yet
        @{"SDTA_SignalTask" link "include:datatypes/soundclass.h/main" 49}
        @{"SDTA_SignalBit" link "include:datatypes/soundclass.h/main" 53}

        Tags defined in @{"datatypes/datatypesclass.h" link "include:datatypes/datatypesclass.h/main"}
        @{"DTA_Methods" link "include:datatypes/datatypesclass.h/main" 87}
        @{"DTA_TriggerMethods" link "include:datatypes/datatypesclass.h/main" 76}
        @{"DTA_NominalVert" link "include:datatypes/datatypesclass.h/main" 175}
        @{"DTA_NominalHoriz" link "include:datatypes/datatypesclass.h/main" 176}
        @{"DTA_Title" link "include:datatypes/datatypesclass.h/main" 73}
        @{"DTA_ObjName" link "include:datatypes/datatypesclass.h/main" 156}
        @{"DTA_Name" link "include:datatypes/datatypesclass.h/main" 143}
        @{"DTA_Immediate" link "include:datatypes/datatypesclass.h/main" 133}
        @{"DTA_Repeat" link "include:datatypes/datatypesclass.h/main" 137}

        Tags that will change in future, do not use !
        @{"MDTA_Buffer" link "include:datatypes/midiclass.h/main" 43} -- (@{"UBYTE" link "include:exec/types.h/main" 47} *) pointer to buffer with SMF file contents
        @{"MDTA_BufferLen" link "include:datatypes/midiclass.h/main" 44} -- (@{"ULONG" link "include:exec/types.h/main" 37}) size of this buffer

    @{b}LIMITATIONS@{ub}
        It is not very useful for loading/saving yet.
        No reset gets send before starting playing.
        No use is made of volume setting.

    @{b}BUGS@{ub}
        None known.

    @{b}SEE ALSO@{ub}
        datatypesclass (have a look at datatypes.library V45),
        sound_dtc


@endnode
