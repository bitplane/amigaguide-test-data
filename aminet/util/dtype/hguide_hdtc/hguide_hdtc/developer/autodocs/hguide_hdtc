@node "--datasheet--" "hyperguide.datatype/--datasheet--"

    @{b}NAME@{ub}
        hyperguide.datatype - hypertext datatype for HyperGuide or AmigaGuide

    @{b}SUPERCLASS@{ub}
        hypertext.datatype

    @{b}DESCRIPTION@{ub}
        This datatype replaces the @{"amigaguide.datatype" link "amigaguide_dtc/amigaguide.datatype"} with even more
        features using the hypertext.datatype.

    @{b}METHODS@{ub}
        @{"OM_NEW" link "OM_NEW"} -- create a hyperguide @{"Object" link "AG:SysInc/intuition/classusr.h/main" 19}.

        @{"OM_DISPOSE" link "OM_DISPOSE"} -- dispose the @{"Object" link "AG:SysInc/intuition/classusr.h/main" 19}.

        @{"OM_GET" link "OM_GET"} -- is used to overwrite some attributes of the superclass.

        @{"OM_SET" link "OM_SET"} -- passes the method to the superclass and performs a refresh
            if needed.

        @{"OM_UPDATE" link "OM_UPDATE"} -- passes the method to the superclass and performs a refresh
            if needed.

        @{"GM_LAYOUT" link "GM_LAYOUT"} -- passes the method to the superclass and performs a layout
            if needed.

        @{"DTM_GOTO" link "DTM_GOTO"} -- Cause the object to load a internal node. Other objects
            are handled by the superclass.

        @{"DTM_ASYNCLAYOUT" link "DTM_ASYNCLAYOUT"} -- do asyncron layout method.

        @{"DTM_PROCLAYOUT" link "DTM_PROCLAYOUT"} -- layout method in a process context.

        @{"HTDTM_CONVATTRIB" link "HTDTM_CONVATTRIB"} -- convert HyperGuide attributes into the internal
            representation.

    @{b}ATTRIBUTES@{ub}
        The following tags are used in the @{"OM_GET" link "OM_GET"} method and thus overwrites
        the values of the superclass.

        @{"DTA_ObjVersion" link "AG:SysInc/datatypes/datatypesclass.h/main" 160} -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) version of the document.
            (@$VER: command)

            Applicability is (G).

        @{"DTA_ObjCopyright" link "AG:SysInc/datatypes/datatypesclass.h/main" 159} -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) copyright information of the document.
            (\@(C) or @copyright command)

            Applicability is (G).

        @{"DTA_ObjAnnotation" link "AG:SysInc/datatypes/datatypesclass.h/main" 158} -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) annotation of the document.
            (@annotation command)

            Applicability is (G).

        @{"DTA_ObjAuthor" link "AG:SysInc/datatypes/datatypesclass.h/main" 157} -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) author of the ducument.
            (@author command)

            Applicability is (G).

        HTDTA_LoadBuffer -- (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) indicates, if the hypertext.datatype should
            load the entire document file or not. This attribute is set by the
            hyperguide.datatype to @{"FALSE" link "AG:SysInc/exec/types.h/main" 76}! DO @{"NOT" link "AG:SysInc/intuition/intuition.h/main" 1501} CHANGE!

            Applicability is (G).

        HTDTA_NodeIndexing -- (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) indicates, if the hypertext.datatype
            should use nodeindexing. Therefore it tries to load and save the
            node list from and into a database.

            Applicability is (G).

        HTDTA_NodeList -- (struct @{"List" link "AG:SysInc/exec/lists.h/main" 20} *) list of all nodes within the
            document. The list have to contain only (struct HTNode)'s!

            Applicability is (G).

        HTDTA_PathList -- (struct @{"List" link "AG:SysInc/exec/lists.h/main" 20} *) list of object dependend paths.

            Applicability is (G).

        HTDTA_FileHandle -- (@{"BPTR" link "AG:SysInc/dos/dos.h/main" 130}) filehandle to the database file.

            Applicability is (G).

        HTDTA_ObjName -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) full filename including path and nodename.

            Applicability is (G).

    @{b}NOTE@{ub}
        See hyperguide_hdtc.hguide for supported HyperGuide/AmigaGuide
        commands and attributes.

    @{b}SEE ALSO@{ub}
        hypertext.datatype, @{"amigaguide.datatype" link "amigaguide_dtc/amigaguide.datatype"}, HTDS.hguide,
        hyperguide_hdtc.hguide


@endnode
@node "DTM_ASYNCLAYOUT" "hyperguide.datatype/DTM_ASYNCLAYOUT"

    @{b}NAME@{ub}
        DTM_ASYNCLAYOUT -- asynchronously layout the object

    @{b}FUNCTION@{ub}
        This method performs now really the layout of the object.

    @{b}INPUTS@{ub}
        None.

    @{b}RESULT@{ub}
        Total number of vertical units.

    @{b}SEE ALSO@{ub}
        @{"DTM_PROCLAYOUT" link "DTM_PROCLAYOUT"}, @{"GM_LAYOUT" link "GM_LAYOUT"}, @{"hypertext.datatype/GM_LAYOUT" link "GM_LAYOUT"}
        hypertext.datatype/HTDTM_LAYOUT


@endnode
@node "DTM_GOTO" "hyperguide.datatype/DTM_GOTO"

    @{b}NAME@{ub}
        DTM_GOTO -- load and display an other object

    @{b}FUNCTION@{ub}
        This method tries first to load an object from the internal list of
        nodes. If this fails it passes the method to its superclass.

    @{b}INPUTS@{ub}
        struct @{b}dtGoto@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *dtg_GInfo;
            @{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} dtg_NodeName;
            struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *dtg_AttrList;
        };

        dtg_NodeName -- name of the node to go to. This also can be a complete
            filename.
        dtg_AttrList -- list of attributes, which specifies the object to go to.

    @{b}RESULTS@{ub}
        None defined.

    @{b}SEE ALSO@{ub}
        hypertext.datatype/DTM_GOTO


@endnode
@node "DTM_PROCLAYOUT" "hyperguide.datatype/DTM_PROCLAYOUT"

    @{b}NAME@{ub}
        DTM_PROCLAYOUT -- performs a layout on a process context

    @{b}FUNCTION@{ub}
        This method performs a layout on a process context. Thus this method
        must only be invoked from a process! It first calls the superclass
        DTM_PROCLAYOUT method and then falls through the @{"DTM_ASYNCLAYOUT" link "DTM_ASYNCLAYOUT"}
        method.

    @{b}INPUTS@{ub}
        None.

    @{b}RESULT@{ub}
        None.

    @{b}EXAMPLE@{ub}
        ...
        case DTM_PROCLAYOUT:
           /* Tell everyone that we are busy doing things */
           NotifyAttrs(obj, ((struct @{"gpLayout" link "AG:SysInc/intuition/gadgetclass.h/main" 320} *) msg)->gpl_GInfo, @{"NULL" link "AG:SysInc/exec/types.h/main" 79},
                       @{"GA_ID" link "AG:SysInc/intuition/gadgetclass.h/main" 47},       ((struct @{"Gadget" link "AG:SysInc/intuition/intuition.h/main" 215} *) obj)->GadgetID,
                       @{"DTA_Busy" link "AG:SysInc/datatypes/datatypesclass.h/main" 101},    @{"TRUE" link "AG:SysInc/exec/types.h/main" 73},
                       @{"TAG_DONE" link "AG:SysInc/utility/tagitem.h/main" 39});

           /* Let the super-class partake and then fall through to our layout
              method */
           @{"DoSuperMethodA" link "amiga_lib/DoSuperMethodA()"} (cl, obj, msg);
        case @{"DTM_ASYNCLAYOUT" link "DTM_ASYNCLAYOUT"}:
           /* perform the layout now! */
           break;
        ...

    @{b}SEE ALSO@{ub}
        @{"datatypes.library/DoAsyncLayout()" link "datatypes/DoAsyncLayout()"}, @{"DTM_ASYNCLAYOUT" link "DTM_ASYNCLAYOUT"},
        @{"hypertext.datatype/GM_LAYOUT" link "GM_LAYOUT"}


@endnode
@node "GM_LAYOUT" "hyperguide.datatype/GM_LAYOUT"

    @{b}NAME@{ub}
        GM_LAYOUT -- starts layout of the hyperguide object

    @{b}FUNCTION@{ub}
        This method is directly passed to its superclass. If the superclass
        returns zero the object needs to be layouted, which is done
        asynchronously by calling the @{"DoAsyncLayout()" link "datatypes/DoAsyncLayout()"} function. If it returns
        non zero nothing has to be done.

    @{b}INPUTS@{ub}
        struct @{b}gpLayout@{ub}
        {
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
           struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *gpl_GInfo;
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} gpl_Initial;
        };

        gpl_Initial - First call of GM_LAYOUT for this object

    @{b}RESULTS@{ub}
        0   - start the asynchronous layout
        !=0 - do nothing

    @{b}SEE ALSO@{ub}
        @{"DTM_PROCLAYOUT" link "DTM_PROCLAYOUT"}, @{"DTM_ASYNCLAYOUT" link "DTM_ASYNCLAYOUT"}, hypertext.datatype/HTDTM_LAYOUT,
        hypertext.datatype/GM_LAYOUT, @{"datatypes.library/DoAsyncLayout()" link "datatypes/DoAsyncLayout()"}


@endnode
@node "HTDTM_CONVATTRIB" "hyperguide.datatype/HTDTM_CONVATTRIB"

    @{b}NAME@{ub}
        HTDTM_CONVATTRIB -- converts additional HyperGuide style attributes.

    @{b}FUNCTION@{ub}
        This method is used for the implementation of HyperGuide attributes,
        which aren't handled by the ConvertAttributes() function.

    @{b}INPUTS@{ub}
        struct @{b}htConvAttrib@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *dt_GInfo;
            @{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} htca_Keyword;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} htca_KeywordLen;
            @{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} htca_Arguments;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} htca_ArgumentsLen;
            struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *htca_TagList;
            struct HTSegInfo *htca_SegInfo;
            struct HTConvInfo *htca_ConvInfo;
            @{"APTR" link "AG:SysInc/exec/types.h/main" 34} htca_UserData;
        };

        htca_Keyword -- attribute name
        htca_KeywordLen -- length of the attribute name
        htca_Arguments -- additional arguments for the attribute
        htca_ArgumentsLen -- length of arguments
        htca_TagList -- TagList passed to AllocConvInfoA()
        htca_SegInfo -- segment info returned by AllocSgeInfoA()
        htca_ConvInfo -- convert info returned by AllocConvInfoA()
        htca_UserData -- userdata passed to AllocConvInfoA() via
            HTDTCIA_UserData.

    @{b}RESULTS@{ub}
        none

    @{b}SEE ALSO@{ub}
        hypertext.datatype/ConvertAttributes(), hypertext.datatype/HTDTM_CONVATTRIB


@endnode
@node "OM_DISPOSE" "hyperguide.datatype/OM_DISPOSE"

    @{b}NAME@{ub}
        OM_DISPOSE -- frees all allocated resources of a hyperguide object

    @{b}FUNCTION@{ub}
        This method frees all allocated resources of a hyperguide object.
        After this it calls the superclass OM_DISPOSE method.

    @{b}INPUTS@{ub}
        None.

    @{b}RESULT@{ub}
        None.

    @{b}SEE ALSO@{ub}
        hypertext.datatype/OM_DISPOSE, @{"datatypes.library/DisposeDTObject()" link "datatypes/DisposeDTObject()"},
        @{"OM_NEW" link "OM_NEW"}


@endnode
@node "OM_GET" "hyperguide.datatype/OM_GET"

    @{b}NAME@{ub}
        OM_GET -- get attributes of a hyperguide object.

    @{b}FUNCTION@{ub}
        The OM_GET method is used to get attributes of a hyperguide.datatype
        object. This method is processed first and then passed to the
        superclass if the attribute isn't recognized.

    @{b}INPUTS@{ub}
        struct @{b}opGet@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               MethodID;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               opg_AttrID;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               *opg_Storage;
        };

        opg_AttrID -- attributes long word id
        opg_Storage -- pointer to a data area to hold the value of the
            attribute

    @{b}RESULT@{ub}
        zero for unsupported attributes, non-zero for supported attributes.

    @{b}ATTRIBUTES@{ub}
        @{"DTA_ObjVersion" link "AG:SysInc/datatypes/datatypesclass.h/main" 160} -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) version of the document.
            (@$VER: command)

        @{"DTA_ObjCopyright" link "AG:SysInc/datatypes/datatypesclass.h/main" 159} -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) copyright information of the document.
            (\@(C) or @copyright command)

        @{"DTA_ObjAnnotation" link "AG:SysInc/datatypes/datatypesclass.h/main" 158} -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) annotation of the document.
            (@annotation command)

        @{"DTA_ObjAuthor" link "AG:SysInc/datatypes/datatypesclass.h/main" 157} -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) author of the ducument.
            (@author command)

        HTDTA_LoadBuffer -- (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) indicates, if the hypertext.datatype should
            load the entire document file or not. This attribute is set by the
            hyperguide.datatype to @{"FALSE" link "AG:SysInc/exec/types.h/main" 76}! DO @{"NOT" link "AG:SysInc/intuition/intuition.h/main" 1501} CHANGE!

        HTDTA_NodeIndexing -- (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) indicates, if the hypertext.datatype
            should use nodeindexing. Therefore it tries to load and save the
            node list from and into a database.

        HTDTA_NodeList -- (struct @{"List" link "AG:SysInc/exec/lists.h/main" 20} *) list of all nodes within the
            document. The list have to contain only (struct HTNode)'s!

        HTDTA_PathList -- (struct @{"List" link "AG:SysInc/exec/lists.h/main" 20} *) list of object dependend paths.

        HTDTA_FileHandle -- (@{"BPTR" link "AG:SysInc/dos/dos.h/main" 130}) filehandle to the database file.

        HTDTA_ObjName -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) full filename including path and nodename.

    @{b}SEE ALSO@{ub}
        hypertext.datatype/OM_GET, @{"OM_SET" link "OM_SET"}


@endnode
@node "OM_NEW" "hyperguide.datatype/OM_NEW"

    @{b}NAME@{ub}
        OM_NEW -- create a hyperguide object.

    @{b}FUNCTION@{ub}
        This method first calls the superclass OM_NEW method and if this
        returns a valid @{"Object" link "AG:SysInc/intuition/classusr.h/main" 19} pointer it allocates and intializes all needed
        resources. After this it reads the HyperGuide preference file and
        scans then the complete file to collect all nodes within this
        database.

    @{b}INPUTS@{ub}
        struct @{b}opSet@{ub} {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               MethodID;
            struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32}      *ops_AttrList;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25}   *ops_GInfo;
        };

        ops_AttrList -- initial attribute values
        ops_GInfo -- always @{"NULL" link "AG:SysInc/exec/types.h/main" 79} for OM_NEW

    @{b}RESULT@{ub}
        pointer to the newly created HyperGuide object or @{"NULL" link "AG:SysInc/exec/types.h/main" 79} for a failure.
        If this method fails, a possible reason for failure is provided via
        the @{"IoErr()" link "dos/IoErr()"} function.

    @{b}SEE ALSO@{ub}
        hypertext.datatype/OM_NEW, @{"OM_DISPOSE" link "OM_DISPOSE"}, @{"OM_SET" link "OM_SET"}


@endnode
@node "OM_SET" "hyperguide.datatype/OM_SET"

    @{b}NAME@{ub}
        OM_SET -- sets attributes of a hyperguide object

    @{b}FUNCTION@{ub}
        The OM_SET method is used to set attributes of a hyperguide.datatype
        object. This method is processed first and then passed to its
        superclass. If the result is non zero it calls the HTDTM_RENDER
        method, which invokes the @{"GM_RENDER" link "AG:SysInc/intuition/gadgetclass.h/main" 191} method on the separate hypertext
        process.

    @{b}INPUTS@{ub}
        struct @{b}opSet@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               MethodID;
            struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32}      *ops_AttrList;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25}   *ops_GInfo;
        };

        ops_AttrList - list of new attributes
        ops_GInfo - @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} structure

    @{b}RESULT@{ub}
        non zero if the hyperguide object needs rendering, zero if not.

    @{b}ATTRIBUTES@{ub}
        None.

    @{b}SEE ALSO@{ub}
        hypertext.datatype/OM_SET, @{"OM_GET" link "OM_GET"}, @{"OM_UPDATE" link "OM_UPDATE"}, @{"OM_NEW" link "OM_NEW"},
        @{"datatypes.library/SetDTAttrsA()" link "datatypes/SetDTAttrsA()"}


@endnode
@node "OM_UPDATE" "hyperguide.datatype/OM_UPDATE"

    @{b}NAME@{ub}
        OM_UPDATE -- updates attributes of a hyperguide object.

    @{b}FUNCTION@{ub}
        The OM_UPDATE method is used to update attributes of a
        hypertext.datatype object. This method is processed first and then
        passed to the superclass. This method calls directly the @{"OM_SET" link "OM_SET"}
        method, thus all attributes of this method are also supported. The
        following ATTRIBUTES section lists all attributes, which are only
        supported by the the OM_UPDATE method. If the result is non zero it
        calls the HTDTM_RENDER method, which invokes the @{"GM_RENDER" link "AG:SysInc/intuition/gadgetclass.h/main" 191} method on
        the separate hypertext process.

    @{b}INPUTS@{ub}
        struct @{b}opUpdate@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               MethodID;
            struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32}      *opu_AttrList;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25}   *opu_GInfo;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               opu_Flags;
        };

        opu_AttrList -- list of new attributes
        opu_GInfo -- @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} structure
        opu_Flags -- flags indicating the status of this update method

    @{b}ATTRIBUTES@{ub}
        None.

    @{b}RESULT@{ub}
        Non zero if the object needs to be rendered. Zero if there has nothing
        changed, so that rendering isn't needed.

    @{b}SEE ALSO@{ub}
        hypertext.datatype/OM_UPDATE, @{"OM_SET" link "OM_SET"}, @{"rootclass/OM_NOTIFY" link "AG:SysInc/intuition/classusr.h/main" 69}


@endnode
