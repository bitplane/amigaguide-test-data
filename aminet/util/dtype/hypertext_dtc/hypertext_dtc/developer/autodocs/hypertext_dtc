@node "AllocConvInfoA()" "hypertext.datatype/AllocConvInfoA()"

    @{b}NAME@{ub}
        AllocConvInfoA -- allocate @{"ConvertAttributes()" link "ConvertAttributes()"} info structure
        AllocConvInfo -- varargs stub for AllocConvInfoA()

    @{b}SYNOPSIS@{ub}
        convinfo = AllocConvInfoA(segInfo,segTagList,tagList);
           D0                       A0        A1       A2

        struct HTConvInfo *AllocConvInfoA(struct HTSegInfo *,
                                          struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *,struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *);

        convinfo = AllocConvInfo(segInfo,segTagList,tag1,...);

        struct HTConvInfo *AllocConvInfo(struct HTSegInfo *,
                                         struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *,@{"Tag" link "AG:SysInc/utility/tagitem.h/main" 30} ,...);

    @{b}FUNCTION@{ub}
        This function allocates a structure for use with @{"ConvertAttributes()" link "ConvertAttributes()"}.
        It scans the given @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} array segTagList and setup the appropriate
        pointers to convert the specified hypertext format to the given
        segment @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} array.

    @{b}TAGS@{ub}
        HTDTCIA_Format -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) format to use for conversion. This may be
            any hypertext format such as "hyperguide", "html" or "texinfo".
            Currently only "hyperguide" is supported.
            Defaults to "hyperguide".

        HTDTCIA_UserData -- (@{"APTR" link "AG:SysInc/exec/types.h/main" 34}) this data field is passed to the
            @{"HTDTM_CONVATTRIB" link "HTDTM_CONVATTRIB"} method in the UserData field of this message.

    @{b}INPUTS@{ub}
        segInfo -- (struct HTSegInfo *) info structure from @{"AllocSegInfoA()" link "AllocSegInfoA()"}
        segTagList -- (struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *) tag list to use for AllocSegment()
        tagList -- (struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *) tag list for this function.

    @{b}RESULTS@{ub}
        convinfo -- (struct HTConvInfo *) pointer to a ConvertInfo structure
            or @{"NULL" link "AG:SysInc/exec/types.h/main" 79} for failure.

    @{b}SEE ALSO@{ub}
        @{"FreeConvInfo()" link "FreeConvInfo()"}, @{"AllocSegInfoA()" link "AllocSegInfoA()"}, @{"ConvertAttributes()" link "ConvertAttributes()"}


