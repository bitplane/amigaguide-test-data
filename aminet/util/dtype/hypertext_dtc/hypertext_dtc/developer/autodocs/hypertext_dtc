            @{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} hts_String;
            @{"LONG" link "AG:SysInc/exec/types.h/main" 36} hts_StringLen;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} hts_Flags;
        };

        hts_String -- string or pattern to search for
        hts_StringLen -- length of the given string or pattern
        hts_Flags -- flags, which controls the search. Following flags are
            currently supported :

            HTDTSF_NOCASE -- ignore case
            HTDTSF_PATTERN -- string is a pattern

    @{b}RESULTS@{ub}
       none

    @{b}SEE ALSO@{ub}
       @{"HTDTM_SEARCH" link "HTDTM_SEARCH"}


@endnode
@node "HTDTM_HTPROC" "hypertext.datatype/HTDTM_HTPROC"

    @{b}NAME@{ub}
        HTDTM_HTPROC -- tests if its on a process context

    @{b}FUNCTION@{ub}
        Check if the current method is invoked on the separate hypertext
        object process. Note: If you overwrite some methods like @{"DTM_GOTO" link "DTM_GOTO"}, you
        have to check first if you are in that special process context, and if
        not you have to pass this method directly to superclass, so that this
        can signal the hypertext object process to do this method on its
        context. This strategy is needed to avoid problems with input task
        based method invocations.

    @{b}INPUTS@{ub}
        none

    @{b}SEE ALSO@{ub}
        @{"DTM_GOTO" link "DTM_GOTO"}


@endnode
@node "HTDTM_LAYOUT" "hypertext.datatype/HTDTM_LAYOUT"

    @{b}NAME@{ub}
        HTDTM_LAYOUT -- layout all hypertext object segments

    @{b}FUNCTION@{ub}
        This method have to be invoked from the @{"GM_LAYOUT" link "GM_LAYOUT"} method of subclasses
        of the hypertext.datatype. It layouts all allocated hypertext segments
        and calculate the correct positions of pictures and texts within a
        document. Thus it must be invoked after all segments are allocated
        during the @{"GM_LAYOUT" link "GM_LAYOUT"} method. Then you invoke this method to layout the
        complete hypertext object. This method must also be invoked on any
        subsequent call of @{"GM_LAYOUT" link "GM_LAYOUT"}, so it can calculate correct positions
        of centered or justified segments.

    @{b}INPUTS@{ub}
        struct @{b}htLayout@{ub}
        {
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
           struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *dt_GInfo;
           struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *htl_AttrList;
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} htl_Initial;
        };

        htl_AttrList - Additional attributes. Currently non defined.
        htl_Initial  - First call of HTDTM_LAYOUT for this object

    @{b}RESULT@{ub}
        returns total number of lines.

    @{b}SEE ALSO@{ub}
        @{"GM_LAYOUT" link "GM_LAYOUT"}


@endnode
@node "HTDTM_LOADNODES" "hypertext.datatype/HTDTM_LOADNODES"

    @{b}NAME@{ub}
        HTDTM_LOADNODES -- loads nodes for the current document

    @{b}FUNCTION@{ub}
        This method tries to load all needed node information of the current
        document. Currently node informations are only stored in the documents
        icon. But in the future there may be a real database to hold the node
        informations.

    @{b}INPUTS@{ub}
        struct @{b}htLoadNodes@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *dt_GInfo;
            struct @{"List" link "AG:SysInc/exec/lists.h/main" 20} *htln_List;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} htln_NodeSize;
        };

        htln_List -- list to append the loaded nodes
        htln_NodeSize -- size of your private node including the size of the
            struct HTNode.

    @{b}RESULTS@{ub}
        @{"FALSE" link "AG:SysInc/exec/types.h/main" 76}, if nothing could be loaded or @{"TRUE" link "AG:SysInc/exec/types.h/main" 73} if the node information are
        still actual and loaded.

    @{b}SEE ALSO@{ub}
        @{"HTDTM_SAVENODES" link "HTDTM_SAVENODES"}


@endnode
@node "HTDTM_OBTAIN" "hypertext.datatype/HTDTM_OBTAIN"

    @{b}NAME@{ub}
        HTDTM_OBTAIN -- obtain exclusive access to the hypertext object.

    @{b}FUNCTION@{ub}
        This method is used to get exclusive access to the hypertext object.
        Currently its the same as obtaining the @{"DTSpecialInfo" link "AG:SysInc/datatypes/datatypesclass.h/main" 207} semapore. But in
        future this might change so you have to use this method!

    @{b}INPUTS@{ub}
        none

    @{b}SEE ALSO@{ub}
        @{"exec.library/ObtainSemaphore()" link "exec/ObtainSemaphore()"}, @{"HTDTM_RELEASE" link "HTDTM_RELEASE"}, @{"HTDTM_ATTEMPT" link "HTDTM_ATTEMPT"}


@endnode
@node "HTDTM_OBTAINPEN" "hypertext.datatype/HTDTM_OBTAINPEN"

    @{b}NAME@{ub}
        HTDTM_OBTAINPEN -- obtain a specific color pen

    @{b}FUNCTION@{ub}
        This method is used to obtain a specific color pen. It is possible to
        pass a string, which will be converted by this method into the
        appropriate color. This string can be one of the following color
        names :

        Black, Green, Silver, Lime, Gray, Olive, White, Yellow, Maroon, Navy
        Red, Blue, Purple, Teal, Fuchsia, Aqua.

        Or a string which represents the RGB values with "#RRGGBB" format.
        Each letter represents a hexadecimal digit.

        If there is no string given (@{"NULL" link "AG:SysInc/exec/types.h/main" 79}), the method tries to obtain the
        color specified by the RGB values.

    @{b}INPUTS@{ub}
        struct @{b}htObtainPen@{ub}
        {
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
           struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *dt_GInfo;
           @{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} htop_String;
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} htop_StringLen;
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} htop_Red;
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} htop_Green;
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} htop_Blue;
        };

        htop_String -- pointer to the color string or @{"NULL" link "AG:SysInc/exec/types.h/main" 79}.
        htop_StringLen -- length of the htop_String.
        htop_Red -- red level 32 bit.
        htop_Green -- green level 32 bit.
        htop_Blue -- blue lebel 32 bit.

    @{b}RESULTS@{ub}
        returns the pen number or -1 for a failure.

    @{b}NOTES@{ub}
        This method works only if the hypertext object was added to a window
        with the @{"AddDTObject()" link "datatypes/AddDTObject()"} function.

    @{b}SEE ALSO@{ub}
        @{"graphics.library/ObtainBestPenA()" link "graphics/ObtainBestPenA()"}


@endnode
@node "HTDTM_RELEASE" "hypertext.datatype/HTDTM_RELEASE"

    @{b}NAME@{ub}
        HTDTM_RELEASE -- release exclusive access of a hypertext object.

    @{b}FUNCTION@{ub}
        This method is used to release a exclusive access to a hypertext
        object done by the @{"HTDTM_OBTAIN" link "HTDTM_OBTAIN"} method. Currently its the same as
        releasing the @{"DTSpecialInfo" link "AG:SysInc/datatypes/datatypesclass.h/main" 207} semapore. But in future this might change
        so you have to use this method!

    @{b}INPUTS@{ub}
        none

    @{b}SEE ALSO@{ub}
        @{"exec.library/ReleaseSemaphore()" link "exec/ReleaseSemaphore()"}, @{"HTDTM_OBTAIN" link "HTDTM_OBTAIN"}, @{"HTDTM_ATTEMPT" link "HTDTM_ATTEMPT"}


@endnode
@node "HTDTM_RENDER" "hypertext.datatype/HTDTM_RENDER"

    @{b}NAME@{ub}
        HTDTM_RENDER -- render the hypertext object on its own process.

    @{b}FUNCTION@{ub}
        This function is used to render the hypertext object on its own
        process.

    @{b}INPUTS@{ub}
        none

    @{b}SEE ALSO@{ub}
        @{"GM_RENDER" link "GM_RENDER"}


@endnode
@node "HTDTM_SAVENODES" "hypertext.datatype/HTDTM_SAVENODES"

    @{b}NAME@{ub}
        HTDTM_SAVENODES -- save node informations of the current document

    @{b}FUNCTION@{ub}
        This method tries to save the node informations given by the specified
        list. The list have to contain HTNode structures.

    @{b}INPUTS@{ub}
       struct @{b}htSaveNodes@{ub}
       {
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
           struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *dt_GInfo;
           struct @{"List" link "AG:SysInc/exec/lists.h/main" 20} *htsn_List;
       };

       htsn_List -- list of node informations to save

    @{b}RESULTS@{ub}
       @{"TRUE" link "AG:SysInc/exec/types.h/main" 73} if the node information could be saved, otherwise @{"FALSE" link "AG:SysInc/exec/types.h/main" 76}.

    @{b}SEE ALSO@{ub}
       @{"HTDTM_LOADNODES" link "HTDTM_LOADNODES"}


@endnode
@node "HTDTM_SEARCH" "hypertext.datatype/HTDTM_SEARCH"

    @{b}NAME@{ub}
        HTDTM_SEARCH -- search for a given string or pattern.

    @{b}FUNCTION@{ub}
        This method searches for the occurance of the given string or pattern.
        If the HTDTSF_PROMPT flag is set it opens the search requester to let
        the user input the string or pattern to search for. If the
        HTDTSF_PATTERN flag is set the given string is interpreted as a
        pattern. HTDTSF_NOCASE ignores case in comparsion.

    @{b}INPUTS@{ub}
        struct @{b}htSearch@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *dt_GInfo;
            @{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} hts_String;
            @{"LONG" link "AG:SysInc/exec/types.h/main" 36} hts_StringLen;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} hts_Flags;
        };

        hts_String -- string or pattern to search for
        hts_StringLen -- length of the given string or pattern
        hts_Flags -- flags, which controls the search. Following flags are
            currently supported :

            HTDTSF_NOCASE -- ignore case
            HTDTSF_PATTERN -- string is a pattern
            HTDTSF_PROMPT -- opens the search requester

    @{b}RESULTS@{ub}
        @{"TRUE" link "AG:SysInc/exec/types.h/main" 73} if something was found, otherwise @{"FALSE" link "AG:SysInc/exec/types.h/main" 76}.

    @{b}SEE ALSO@{ub}
        @{"HTDTM_GUISEARCH" link "HTDTM_GUISEARCH"}


@endnode
@node "OM_DISPOSE" "hypertext.datatype/OM_DISPOSE"

    @{b}NAME@{ub}
        OM_DISPOSE -- frees all allocated resources of a hypertext object

    @{b}FUNCTION@{ub}
        This method tries to free all allocated resources of a hypertext
        object :

        1. It tries to quit all spawned applications.
        2. Dispose any cached objects
        3. Closes all fonts
        4. Dispose any embedded objects
        5. Dispose possibly background image
        6. Releases all allocated color pens

        After this it calls the superclass OM_DISPOSE method.

    @{b}INPUTS@{ub}
        none

    @{b}RESULT@{ub}
        none

    @{b}SEE ALSO@{ub}
        datatypesclass/OM_DISPOSE, @{"OM_NEW" link "OM_NEW"}, @{"datatypes.library/DisposeDTObject()" link "datatypes/DisposeDTObject()"}


@endnode
@node "OM_GET" "hypertext.datatype/OM_GET"

    @{b}NAME@{ub}
        OM_GET -- get attributes of a hypertext object.

    @{b}FUNCTION@{ub}
        The OM_GET method is used to get attributes of a hypertext.datatype
        object. This method is processed first and then passed to the
        superclass if the attribute isn't recognized.

    @{b}INPUTS@{ub}
        struct @{b}opGet@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               MethodID;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               opg_AttrID;
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               *opg_Storage;
        };

        opg_AttrID -- attributes long word id
        opg_Storage -- pointer to a data area to hold the value of the
            attribute

    @{b}RESULT@{ub}
        zero for unsupported attributes, non-zero for supported attributes.

    @{b}ATTRIBUTES@{ub}
        @{"DTA_Domain" link "AG:SysInc/datatypes/datatypesclass.h/main" 147} (struct @{"IBox" link "AG:SysInc/intuition/intuition.h/main" 897} *) -- objects domain box. This is overwritten,
            if a control panel is used.

        @{"DTA_TextFont" link "AG:SysInc/datatypes/datatypesclass.h/main" 83} (struct @{"TextFont" link "AG:SysInc/graphics/text.h/main" 89} *) -- Text font to use for normal texts,
            not explicitly specified using the HTDTSA_TextFont text segment
            @{"Tag" link "AG:SysInc/utility/tagitem.h/main" 30}.

        @{"DTA_TextAttr" link "AG:SysInc/datatypes/datatypesclass.h/main" 42} (struct @{"TextAttr" link "AG:SysInc/graphics/text.h/main" 65} *) -- Text attribute structure to use
            for normal texts. This corresponds to the @{"DTA_TextFont" link "AG:SysInc/datatypes/datatypesclass.h/main" 83} attribute.

        @{"DTA_Title" link "AG:SysInc/datatypes/datatypesclass.h/main" 73} (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Title of the hypertext object, which is normally
            displayed in the windows title bar. The string is copied, so that
            after the set method returns you can free its resources.

        @{"DTA_NodeName" link "AG:SysInc/datatypes/datatypesclass.h/main" 70} (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Name of node of this hypertext object.
            The set method copies the string.

        @{"DTA_Methods" link "AG:SysInc/datatypes/datatypesclass.h/main" 87} (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37} *) -- ~0 terminated MethodID list of supported
            methods.

        @{"DTA_ControlPanel" link "AG:SysInc/datatypes/datatypesclass.h/main" 128} (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- Indicates, if the hypertext datatype should
            (@{"TRUE" link "AG:SysInc/exec/types.h/main" 73}) create a control panel for the created object or not
            (@{"FALSE" link "AG:SysInc/exec/types.h/main" 76}).

        AGA_Secure (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- Indicates, if its permitted (@{"FALSE" link "AG:SysInc/exec/types.h/main" 76}) to start
            external programms or not (@{"TRUE" link "AG:SysInc/exec/types.h/main" 73}). Only supported for compatibility
            with @{"amigaguide.datatype" link "amigaguide_dtc/amigaguide.datatype"}. Please use HTDTA_Secure instead.

        HTDTA_Secure (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- Indicates, if its permitted (@{"FALSE" link "AG:SysInc/exec/types.h/main" 76}) to start
            external programms or not (@{"TRUE" link "AG:SysInc/exec/types.h/main" 73}).

        HTDTA_HyperText (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- Indicates, if the object is a hypertext
            object.

        HTDTA_SegmentList (struct @{"List" link "AG:SysInc/exec/lists.h/main" 20} *) -- @{"List" link "AG:SysInc/exec/lists.h/main" 20} of linked segments of the
            current object.

        HTDTA_WordDelim (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- String, which describes the delimiter
            characters to use for separating words. The string is not
            copied.

        HTDTA_Buffer (@{"UBYTE" link "AG:SysInc/exec/types.h/main" 47} *) -- Pointer to the raw hypertext data buffer, if
            any is available. Subclasses which uses IFF files don't provide
            this buffer. See catalog.datatype for example.

        HTDTA_BufferLen (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) -- Length of raw hypertext data buffer.

        HTDTA_LoadBuffer (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- Indicates, if the hypertext base class
            should load (@{"TRUE" link "AG:SysInc/exec/types.h/main" 73}) the entire ascii or binary file into a
            buffer and provide it for the subclass via HTDTA_Buffer and
            HTDTA_BufferLen.

        HTDTA_Pool (@{"APTR" link "AG:SysInc/exec/types.h/main" 34}) -- Memory pool of the current hypertext object.

        HTDTA_EmbeddedList (struct @{"List" link "AG:SysInc/exec/lists.h/main" 20} *) -- @{"List" link "AG:SysInc/exec/lists.h/main" 20} of all embedded objects.
            This list can only be walked trough with intuition's @{"NextObject()" link "intuition/NextObject()"}
            function.

        HTDTA_UnderlineLink (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- Indicates, if links should be shown as
            buttons (@{"FALSE" link "AG:SysInc/exec/types.h/main" 76}) like AmigaGuide links or should be underlined
            (@{"TRUE" link "AG:SysInc/exec/types.h/main" 73}) like most Web browsers do.

        HTDTA_Spacing (@{"UWORD" link "AG:SysInc/exec/types.h/main" 40}) -- Number of pixel between two lines. This value
            is used in @{"HTDTM_LAYOUT" link "HTDTM_LAYOUT"} method. Thus if you change the value you
            have to invoke @{"DTM_PROCLAYOUT" link "AG:SysInc/datatypes/datatypesclass.h/main" 260} to reflect the change in the output.

        HTDTA_Contents (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Defines the name of the contents object of
            the current hypertext object. The string is copied.

        HTDTA_Index (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Defines the name of the index object of the
            current hypertext object. The string is copied.

        HTDTA_Help (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Defines the name of the help object of the
            current hypertext object. The string is copied.

        HTDTA_Previous (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Defines the name of the previous object of
            the current hypertext object. The string is copied.

        HTDTA_Next (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Defines the name of the next object of the
            current hypertext object. The string is copied.

        HTDTA_TabWidth (@{"LONG" link "AG:SysInc/exec/types.h/main" 36}) -- number of space characters to use for a
            tabulator character.

        HTDTA_Background (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- file name of a picture to use for
            the background.

        HTDTA_BackgroundPen (@{"LONG" link "AG:SysInc/exec/types.h/main" 36}) -- pen number to use for background
            color.

        HTDTA_ForegroundPen (@{"LONG" link "AG:SysInc/exec/types.h/main" 36}) -- pen number to use for foreground
            color. This is normaly all standard texts.

        HTDTA_AltForegroundPen (@{"LONG" link "AG:SysInc/exec/types.h/main" 36}) -- pen number to use for foreground
            color, if background and foreground color are the same.

        HTDTA_ObjectDir (@{"BPTR" link "AG:SysInc/dos/dos.h/main" 130}) -- used to get a shared lock on the directory
            of the object. It handles all different datatypes source types
            like IFF, misc or files. The returned lock must be free'd after
            you have finished your job with @{"UnLock()" link "dos/UnLock()"}.

        HTDTA_Depth (@{"LONG" link "AG:SysInc/exec/types.h/main" 36}) -- recommended color depth for the hypertext
            object. This is used by applications to open an appropriate
            custom screen with at least this depth.

        HTDTA_FileHandle (@{"BPTR" link "AG:SysInc/dos/dos.h/main" 130}) -- file handle from @{"Open()" link "dos/Open()"} of the hypertext
            object. This is used for obtaining file informations from
            @{"DTST_RAM" link "AG:SysInc/datatypes/datatypesclass.h/main" 197} objects, which are part of an normal file. For example
            the hyperguide.datatype creates for each internal node a @{"DTST_RAM" link "AG:SysInc/datatypes/datatypesclass.h/main" 197}
            object with HTDTA_Buffer and HTDTA_BufferLen set. ATTENTION this
            filehandle *must* not be closed !
            NOTE: This attribute should be overwritten from SubClass
                  implementors.

        HTDTA_NodeList (struct @{"List" link "AG:SysInc/exec/lists.h/main" 20} *) -- used by the hypertext.datatype to
            obtain the list of internal nodes from the subclass.
            NOTE: This attribute should be overwritten from SubClass
                  implementors.

        HTDTA_ShowLink (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- indicates, if a link should be shown in as
            @{"DTA_Title" link "AG:SysInc/datatypes/datatypesclass.h/main" 73} when its activated via key or mouse actions.

        HTDTA_SeparatorIsFF (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- indicates, if a separator should be
            treated as a form feed within printing and AscII export.

        HTDTA_NodeIndexing (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- indicates, if internal nodes should be
            saved in a database.
            NOTE: This attribute should be overwritten from SubClass
                  implementors.

        HTDTA_PathList (struct @{"List" link "AG:SysInc/exec/lists.h/main" 20} *) -- list of pathes to search of objects
            to go to. This list is object dependend and therefore relative
            pathes are relative to the objects directory.
            NOTE: This attribute should be overwritten from SubClass
                  implementors.

    @{b}SEE ALSO@{ub}
        datatypesclass/OM_GET, @{"OM_SET" link "OM_SET"}, @{"OM_UPDATE" link "OM_UPDATE"}, @{"intuition.library/GetAttr()" link "intuition/GetAttr()"}


@endnode
@node "OM_NEW" "hypertext.datatype/OM_NEW"

    @{b}NAME@{ub}
        OM_NEW -- create a hypertext object

    @{b}FUNCTION@{ub}
        This method first calls the superclass OM_NEW method and if this
        returns a non-NULL @{"Object" link "AG:SysInc/intuition/classusr.h/main" 19} pointer, allocates all needed resources for
        a hypertext object. This method is really complex. Here is a short
        description whats going on :

        1. calls superclass to create the object
        2. initializes all fields with their defaults
        3. initializes some fields according to their hypertext.prefs values
        4. creates navigator buttons
        5. allocates the objects memory pool
        6. loads the file into a buffer and offers it via HTDTA_Buffer
           attribute (only for ASCII files)
        7. spawn a new process
        8. creates the ARexx port

    @{b}INPUTS@{ub}
        struct @{b}opSet@{ub} {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}               MethodID;
            struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32}      *ops_AttrList;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25}   *ops_GInfo;
        };

        ops_AttrList -- initial attribute values
        ops_GInfo -- always @{"NULL" link "AG:SysInc/exec/types.h/main" 79} for OM_NEW

    @{b}ATTRIBUTES@{ub}
        @{"DTA_TextAttr" link "AG:SysInc/datatypes/datatypesclass.h/main" 42} (struct @{"TextAttr" link "AG:SysInc/graphics/text.h/main" 65} *) -- Text attribute structure to use
            for normal texts. This corresponds to the @{"DTA_TextFont" link "AG:SysInc/datatypes/datatypesclass.h/main" 83} attribute.

            Defaults to a system standard font @{"TextAttr" link "AG:SysInc/graphics/text.h/main" 65}.

        @{"DTA_Title" link "AG:SysInc/datatypes/datatypesclass.h/main" 73} (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Title of the hypertext object, which is normally
            displayed in the windows title bar. The string is copied, so that
            after the set method returns you can free its resources.

            Defaults to @{"NULL" link "AG:SysInc/exec/types.h/main" 79}.

        @{"DTA_NodeName" link "AG:SysInc/datatypes/datatypesclass.h/main" 70} (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Name of node of this hypertext object.
            The set method copies the string.

            Defaults to "main".

        @{"DTA_ControlPanel" link "AG:SysInc/datatypes/datatypesclass.h/main" 128} (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- Indicates, if the hypertext datatype should
            (@{"TRUE" link "AG:SysInc/exec/types.h/main" 73}) create a control panel for the created object or not
            (@{"FALSE" link "AG:SysInc/exec/types.h/main" 76}).

            Defaults to @{"TRUE" link "AG:SysInc/exec/types.h/main" 73}.

        AGA_Secure (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- Indicates, if its permitted (@{"FALSE" link "AG:SysInc/exec/types.h/main" 76}) to start
            external programms or not (@{"TRUE" link "AG:SysInc/exec/types.h/main" 73}). Only supported for compatibility
            with @{"amigaguide.datatype" link "amigaguide_dtc/amigaguide.datatype"}. Please use HTDTA_Secure instead.

            Defaults to @{"FALSE" link "AG:SysInc/exec/types.h/main" 76}.

        HTDTA_Secure (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- Indicates, if its permitted (@{"FALSE" link "AG:SysInc/exec/types.h/main" 76}) to start
            external programms or not (@{"TRUE" link "AG:SysInc/exec/types.h/main" 73}).

            Defaults to @{"FALSE" link "AG:SysInc/exec/types.h/main" 76}.

        HTDTA_WordDelim (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- String, which describes the delimiter
            characters to use for separating words. The string is not
            copied.

            Defaults to " \t\n".

        HTDTA_Buffer (@{"UBYTE" link "AG:SysInc/exec/types.h/main" 47} *) -- Pointer to the raw hypertext data buffer, if
            any is available. Subclasses which uses IFF files don't provide
            this buffer. See catalog.datatype for example.

            For ascii and binary files the entire file is loaded into this
            buffer.

        HTDTA_BufferLen (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) -- Length of raw hypertext data buffer.

            Defaults to length of the HTDS_Buffer.

        HTDTA_UnderlineLink (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- Indicates, if links should be shown as
            buttons (@{"FALSE" link "AG:SysInc/exec/types.h/main" 76}) like AmigaGuide links or should be underlined
            (@{"TRUE" link "AG:SysInc/exec/types.h/main" 73}) like most Web browsers do.

            Defaults to @{"FALSE" link "AG:SysInc/exec/types.h/main" 76}.

        HTDTA_Spacing (@{"UWORD" link "AG:SysInc/exec/types.h/main" 40}) -- Number of pixel between two lines. This value
            is used in @{"HTDTM_LAYOUT" link "HTDTM_LAYOUT"} method. Thus if you change the value you
            have to invoke @{"DTM_PROCLAYOUT" link "AG:SysInc/datatypes/datatypesclass.h/main" 260} to reflect the change in the output.

            Defaults to 1.

        HTDTA_Contents (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Defines the name of the contents object of
            the current hypertext object. The string is copied.

            Defaults to global contents as specified in the prefs file or @{"NULL" link "AG:SysInc/exec/types.h/main" 79}
            is no global contents is specified.

        HTDTA_Index (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Defines the name of the index object of the
            current hypertext object. The string is copied.

            Defaults to @{"NULL" link "AG:SysInc/exec/types.h/main" 79}.

        HTDTA_Help (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Defines the name of the help object of the
            current hypertext object. The string is copied.

            Defaults to "HELP:<language>/HTDS_Help.hguide"

        HTDTA_Previous (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Defines the name of the previous object of
            the current hypertext object. The string is copied.

            Defaults to @{"NULL" link "AG:SysInc/exec/types.h/main" 79}.

        HTDTA_Next (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- Defines the name of the next object of the
            current hypertext object. The string is copied.

            Defaults to @{"NULL" link "AG:SysInc/exec/types.h/main" 79}.

        HTDTA_TabWidth (@{"LONG" link "AG:SysInc/exec/types.h/main" 36}) -- number of space characters to use for a
            tabulator character.

            Defaults to 8.

        HTDTA_Background (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) -- file name of a picture to use for
            the background.

            Defaults to value specified in the prefs (DEFBGPIC) file or
            @{"NULL" link "AG:SysInc/exec/types.h/main" 79} if nothing was specified.

        HTDTA_BackgroundPen (@{"LONG" link "AG:SysInc/exec/types.h/main" 36}) -- pen number to use for background
            color.

            Defaults to value specified in the prefs (DEFBGPEN) file or
            0 if nothing was specified.

        HTDTA_ForegroundPen (@{"LONG" link "AG:SysInc/exec/types.h/main" 36}) -- pen number to use for foreground
            color. This is normaly all standard texts.

            Defaults to value specified in the prefs (DEFFGPEN) file or
            1 if nothing was specified.

        HTDTA_AltForegroundPen (@{"LONG" link "AG:SysInc/exec/types.h/main" 36}) -- pen number to use for foreground
            color, if background and foreground color are the same.

            Defaults to value specified in the prefs (DEFALTFGPEN) file or
            3 if nothing was specified.

        HTDTA_Depth (@{"LONG" link "AG:SysInc/exec/types.h/main" 36}) -- recommended color depth for the hypertext
            object. This is used by applications to open a appropriate
            custom screen with at least this depth.

        HTDTA_ShowLink (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) -- indicates, if a link should be shown in as
            @{"DTA_Title" link "AG:SysInc/datatypes/datatypesclass.h/main" 73} when its activated via key or mouse actions.

            Defaults to value specified in the prefs (SHOWLINK) file or
            @{"FALSE" link "AG:SysInc/exec/types.h/main" 76} if nothing was specified.

    @{b}RESULT@{ub}
        pointer to the newly created hypertext object or @{"NULL" link "AG:SysInc/exec/types.h/main" 79} for a failure.
        If this method fails, a possible reason for failure is provided via
        the @{"IoErr()" link "dos/IoErr()"} function.

    @{b}SEE ALSO@{ub}
        datatypesclass/OM_NEW, @{"OM_DISPOSE" link "OM_DISPOSE"}, @{"OM_SET" link "OM_SET"},
        @{"datatypes.library/NewDTObjectA()" link "datatypes/NewDTObjectA()"}


@endnode
