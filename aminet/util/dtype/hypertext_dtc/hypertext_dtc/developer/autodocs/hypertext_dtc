@node "GM_LAYOUT" "hypertext.datatype/GM_LAYOUT"

    @{b}NAME@{ub}
        GM_LAYOUT -- layout the hypertext object

    @{b}FUNCTION@{ub}
        This method layouts the navigator gadget and calculates the new inner
        dimension of the hypertext object. Thus any subclass implementor have
        to call the superclass first and only invoke its own layout method, if
        the result of the call is zero! Typically a subclass allocates all
        hypertext segments within the first call of this method
        (gpl_Initial == @{"TRUE" link "AG:SysInc/exec/types.h/main" 73}). After this and for all !gpl_Initial invocations
        it have to invoke the @{"HTDTM_LAYOUT" link "HTDTM_LAYOUT"} method.

    @{b}INPUTS@{ub}
        struct @{b}gpLayout@{ub}
        {
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
           struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *gpl_GInfo;
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} gpl_Initial;
        };

        gpl_Initial - First call of GM_LAYOUT for this object

    @{b}RESULT@{ub}
        0 - perform layout of the subclass
        1 - don't perform layout of the subclass

    @{b}EXAMPLE@{ub}
        /* example GM_LAYOUT method for a subclass */
        ...
        case GM_LAYOUT:
            NotifyAttrs(obj, ((struct @{"gpLayout" link "AG:SysInc/intuition/gadgetclass.h/main" 320} *) msg)->gpl_GInfo, @{"NULL" link "AG:SysInc/exec/types.h/main" 79},
                        @{"GA_ID" link "AG:SysInc/intuition/gadgetclass.h/main" 47},       ((struct @{"Gadget" link "AG:SysInc/intuition/intuition.h/main" 215} *) obj)->GadgetID,
                        @{"DTA_Busy" link "AG:SysInc/datatypes/datatypesclass.h/main" 101},    @{"TRUE" link "AG:SysInc/exec/types.h/main" 73},
                        @{"TAG_DONE" link "AG:SysInc/utility/tagitem.h/main" 39});

            if((rc = @{"DoSuperMethodA" link "amiga_lib/DoSuperMethodA()"}(cl,obj,msg)) == 0)
            {
                /* we need to do this one asynchronously /*
                rc = @{"DoAsyncLayout" link "datatypes/DoAsyncLayout()"} (obj, (struct @{"gpLayout" link "AG:SysInc/intuition/gadgetclass.h/main" 320} *) msg);
            }
            break;
        ...

    @{b}SEE ALSO@{ub}
        @{"HTDTM_LAYOUT" link "HTDTM_LAYOUT"}, gadgetclass/GM_LAYOUT


@endnode
@node "GM_RENDER" "hypertext.datatype/GM_RENDER"

    @{b}NAME@{ub}
        GM_RENDER -- render the object

    @{b}FUNCTION@{ub}
        This method is used to render the object itself. This method is maybe
        invoked from input.device task, thus there are all limitations for
        exec tasks (e.g. no dos calls). Therefore this method is designed
        asyncronly. When this method is invoked it sends a message to the
        object privates process, which then renders the object on its context.
        This also provides a faster response to the user (e.g. if the user
        scrolls fast in an object).

    @{b}INPUTS@{ub}
        struct @{b}gpRender@{ub}
        {
            @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
            struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *gpr_GInfo;
            struct @{"RastPort" link "AG:SysInc/graphics/rastport.h/main" 54} *gpr_RPort;
            @{"LONG" link "AG:SysInc/exec/types.h/main" 36} gpr_Redraw;
        };

        gpr_RPort -- rastport to draw into.
        gpr_Redraw -- redraw mode. Currently only @{"GREDRAW_REDRAW" link "AG:SysInc/intuition/gadgetclass.h/main" 252} available.

    @{b}NOTE@{ub}
        This method uses internal structures, which are created during the
        initial layout. Thus this method have @{"NOT" link "AG:SysInc/intuition/intuition.h/main" 1501} to be overwritten!

    @{b}SEE ALSO@{ub}
        gadgetclass/GM_RENDER, @{"HTDTM_RENDER" link "HTDTM_RENDER"}


@endnode
@node "HTDTM_ALLOCVEC" "hypertext.datatype/HTDTM_ALLOCVEC"

    @{b}NAME@{ub}
        HTDTM_ALLOCVEC -- allocate memory from the hypertext objects pool.

    @{b}FUNCTION@{ub}
        This method is used to allocate memory from the hypertext objects
        memory pool. This memory have to be freed using the @{"HTDTM_FREEVEC" link "HTDTM_FREEVEC"}
        method or its freed if the object is disposed through the @{"OM_DISPOSE" link "OM_DISPOSE"}
        method. The sematics are equal to the @{"AllocVec()" link "exec/AllocVec()"} of the exec.library,
        so you don't need to recognize the size of the allocated memory block.
        Also this method does the needed arbitration for the used memory pool.
        So if you don't know, if you are the only task which allocates memory
        from the objects memory pool just use this method.

    @{b}INPUTS@{ub}
        struct @{b}htAllocVec@{ub}
        {
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} MethodID;
           struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *dt_GInfo;
           @{"ULONG" link "AG:SysInc/exec/types.h/main" 37} htav_Size;
        };

        htav_Size -- size of the memory block to allocate

    @{b}RESULTS@{ub}
        @{"NULL" link "AG:SysInc/exec/types.h/main" 79} for failure, otherwise a pointer to the new allocated memory.

    @{b}SEE ALSO@{ub}
        @{"exec.library/AllocVec()" link "exec/AllocVec()"}, @{"exec.library/AllocPooled()" link "exec/AllocPooled()"}, @{"HTDTM_FREEVEC" link "HTDTM_FREEVEC"}


