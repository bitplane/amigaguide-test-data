@node "AllocSegInfoA()" "hypertext.datatype/AllocSegInfoA()"

    @{b}NAME@{ub}
        AllocSegInfoA -- allocates a segment info structure
        AllocSegInfo -- varargs stub for AllocSegInfoA()

    @{b}SYNOPSIS@{ub}
        seginfo = AllocSegInfoA(tagList);
          D0                      A0

        @{"APTR" link "AG:SysInc/exec/types.h/main" 34} AllocSegInfoA(struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *);

        seginfo = AllocSegInfo(tag1,...);

        @{"APTR" link "AG:SysInc/exec/types.h/main" 34} AllocSegInfo(@{"Tag" link "AG:SysInc/utility/tagitem.h/main" 30} , ...);

    @{b}FUNCTION@{ub}
        This function allocates a info structure to use for the
        @{"AllocSegmentA()" link "AllocSegmentA()"} function. It stores informaions that this function
        need to know. And also it uses private fields for tempory storage
        between to calls to @{"AllocSegmentA()" link "AllocSegmentA()"}.

    @{b}TAGS@{ub}
        HTDTSIA_Pool -- (@{"APTR" link "AG:SysInc/exec/types.h/main" 34}) pool header for use with @{"AllocPooled()" link "exec/AllocPooled()"}.
            This @{"Tag" link "AG:SysInc/utility/tagitem.h/main" 30} is Required !

        HTDTSIA_Object -- (@{"Object" link "AG:SysInc/intuition/classusr.h/main" 19} *) pointer to the hypertext object to
            allocate segments for.
            This @{"Tag" link "AG:SysInc/utility/tagitem.h/main" 30} is Required !

        HTDTSIA_GadgetInfo -- (struct @{"GadgetInfo" link "AG:SysInc/intuition/cghooks.h/main" 25} *) BOOPSI information
            structure.
            This @{"Tag" link "AG:SysInc/utility/tagitem.h/main" 30} is Required !

        HTDTSIA_List -- (struct @{"List" link "AG:SysInc/exec/lists.h/main" 20} *) list to append segments to.
            Defaults to the hypertext object HTDTA_SegmentList.

    @{b}INPUTS@{ub}
        tagList -- (struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *) list of attributes

    @{b}RESULTS@{ub}
        a pointer to a private segment info structure or @{"NULL" link "AG:SysInc/exec/types.h/main" 79} for failure.
        If something fails, a error code is returned in @{"IoErr()" link "dos/IoErr()"}. The
        following error codes are defined :
            @{"ERROR_REQUIRED_ARG_MISSING" link "AG:SysInc/dos/dos.h/main" 185} -- required tag is missing.
            @{"ERROR_OBJECT_WRONG_TYPE" link "AG:SysInc/dos/dos.h/main" 202} -- the passed @{"Object" link "AG:SysInc/intuition/classusr.h/main" 19} isn't a hypertext
                object.

    @{b}NOTES@{ub}
        The function uses the given pool header to allocate it's memory. So
        if you pass a pool, which is used in more than one task, you have to
        arbitriate by yourself.

    @{b}SEE ALSO@{ub}
        @{"FreeSegInfo()" link "FreeSegInfo()"}, @{"AllocSegmentA()" link "AllocSegmentA()"}, @{"FreeSegment()" link "FreeSegment()"}


@endnode
@node "AllocSegmentA()" "hypertext.datatype/AllocSegmentA()"

    @{b}NAME@{ub}
        AllocSegementA -- Allocate a hypertext segment
        AllocSegement -- varargs stub for AllocSegmentA()

    @{b}SYNOPSIS@{ub}
        segment = AllocSegmentA(segInfo,type,tagList);
          D0                       A0    D0    A1

        struct HTSegment *AllocSegmentA(@{"APTR" link "AG:SysInc/exec/types.h/main" 34}, @{"ULONG" link "AG:SysInc/exec/types.h/main" 37}, struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *);

        segment = AllocSegment(segInfo,type,tag1,...);

        struct HTSegment *AllocSegment(@{"APTR" link "AG:SysInc/exec/types.h/main" 34}, @{"ULONG" link "AG:SysInc/exec/types.h/main" 37},
                                       @{"Tag" link "AG:SysInc/utility/tagitem.h/main" 30}, ...);

    @{b}FUNCTION@{ub}
        This function allocates a new hypertext segment and adds it to the
        list of the hypertext object given in the SegmentInfo structure.
        Currently there are the following types of segments, which the
        hypertext.datatype supports :
            HTST_NORMAL -- normal text
            HTST_DTOBJECT -- datatypes object, which supports @{"DTM_DRAW" link "AG:SysInc/datatypes/datatypesclass.h/main" 282} method
            HTST_SEPARATOR -- horizontal separator line
            HTST_STARTPARAGRAPH -- start paragraph definition
            HTST_ENDPARAGRAPH -- end paragraph definition
            HTST_TAB -- a tabstop
            HTST_SETTABS -- tabulator array definition
            HTST_SETPARAGRAPH -- use current pixel width for paragraph
                indention

    @{b}TAGS@{ub}
        Tags for HTST_NORMAL :

            HTDTSA_Text -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) text to render

            HTDTSA_TextLen -- (@{"UWORD" link "AG:SysInc/exec/types.h/main" 40}) length of text from HTDTSA_Text

            HTDTSA_XOffset -- (@{"UWORD" link "AG:SysInc/exec/types.h/main" 40}) x offset for this segment.
                Defaults to the end of the last segment.
                NOTE: Obsolete

            HTDTSA_YOffset -- (@{"UWORD" link "AG:SysInc/exec/types.h/main" 40}) y offset for this segment. This is only
                usefull, if you don't call the @{"HTDTM_LAYOUT" link "HTDTM_LAYOUT"} method. But this
                isn't recommended.
                NOTE: Obsolete

            HTDTSA_Width -- (@{"UWORD" link "AG:SysInc/exec/types.h/main" 40}) width of this segment. For all currently
                supported segment types (HTST_#?) this attribute is calculated.

            HTDTSA_Height -- (@{"UWORD" link "AG:SysInc/exec/types.h/main" 40}) height of this segment. For all currently
                supported segment types (HTST_#?) this attribute is calculated.

            HTDTSA_Flags -- (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) flags used for this segment. The following
                Flags are currently supported :
                    HTSF_LF -- line feed, end of line marker
                    HTSF_BR -- line break even in smartwrap mode
                    HTSF_LINK -- it's a link, a bevelborder would be drawn
                    HTSF_ITEM -- segment is a first level item (like HTML <DT>
                        tag)
                    HTSF_ITEM2 -- segment is a second level item (like HTML
                        <DD> tag)

            HTDTSA_LayoutFlags -- (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) layout flags to use :
                    HTSLF_JCENTER -- center this segment
                    HTSLF_JRIGHT -- layout this segment most right
                    HTSLF_WRAP -- this segment can be wrapped

            HTDTSA_FgPen -- (@{"UBYTE" link "AG:SysInc/exec/types.h/main" 47}) foreground pen for the text in this
                segment.

            HTDTSA_BgPen -- (@{"UBYTE" link "AG:SysInc/exec/types.h/main" 47}) background pen for the text in this
                segment.

            HTDTSA_Style -- (@{"UBYTE" link "AG:SysInc/exec/types.h/main" 47}) FSF_#? flags for the text style.

            HTDTSA_TextFont -- (struct @{"TextFont" link "AG:SysInc/graphics/text.h/main" 89} *) font to use for the text.

            HTDTSA_LinkType -- (@{"UWORD" link "AG:SysInc/exec/types.h/main" 40}) type of the link, which describes the
                HTDTSA_LinkData attribute. Following types exists:
                    HTLKT_NODE -- amigaguide style nodename
                    HTLKT_OBJECT -- complete filename to a file, opened with
                        @{"NewDTObjectA()" link "datatypes/NewDTObjectA()"}.
                    HTLKT_RX -- complete filename to a arexx macro
                    HTLKT_RXS -- arexx commmand string
                    HTLKT_SYSTEM -- a complete filename to a program
                    HTLKT_QUIT -- just quit current application of this object
                        by sending a @{"SIGBREAKF_CTRL_C" link "AG:SysInc/dos/dos.h/main" 245} signal.
                    HTLKT_USER -- user defined linktype (subclasses).

            HTDTSA_LinkData -- (@{"APTR" link "AG:SysInc/exec/types.h/main" 34}) link data. See HTDTSA_LinkType above.

            HTDTSA_AllocText -- (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) if set to @{"TRUE" link "AG:SysInc/exec/types.h/main" 73}, the text given by the
                HTDTSA_Text tag should be copied in a own memory region. This
                is done by allocating new memory from the SegInfo pool.

            HTDTSA_AllocLink -- (@{"BOOL" link "AG:SysInc/exec/types.h/main" 69}) if set to @{"TRUE" link "AG:SysInc/exec/types.h/main" 73}, the text given by the
                HTDTSA_LinkData tag should be copied in a own memory region.
                This is done by allocating new memory from the SegInfo pool.
                Note the LinkData must be e zero terminated string to use
                this @{"Tag" link "AG:SysInc/utility/tagitem.h/main" 30}!

        Tags for HTST_DTOBJECT :

            HTDTSA_Name -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) name of the object to open via
                @{"NewDTObjectA()" link "datatypes/NewDTObjectA()"}

        Tags for HTST_SEPARATOR :

            HTDTSA_Height -- (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) height of the separator.
                Not implemented yet.

            HTDTSA_Style -- (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) style of the separator bar. SEPS_#?
                values.

        Tags for HTST_STARTPARAGRAPH :

            HTDTSA_ParaIndent -- (@{"LONG" link "AG:SysInc/exec/types.h/main" 36}) number of chars to indent the first
                line of the paragraph. This can be negative.

            HTDTSA_BodyIndent -- (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) number of chars to indent the body of
                the paragraph.

        Tags for HTST_ENDPARAGRAPH :

            none

        Tags for HTST_TAB :

            HTDTSA_NumTabs -- (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) number of tabstops

        Tags for HTST_SETTABS :

            HTDTSA_TabStops -- (@{"UWORD" link "AG:SysInc/exec/types.h/main" 40} *) ~0 terminated array of character
                positions to use for tabs. This array is copied.

        Tags for HTST_SETPARAGRAPH :

            none.

        Tags for HTST_STARTLIST :

            HTDTSA_ListType -- (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) type of the list HTSLIT_#? values.
                HTSLIT_ITEMIZE -- HTML <UL> style list
                HTSLIT_ENUMERATION -- HTML <OL> style list
                HTSLIT_DEFINITION -- HTML <DL> style list
                Defaults to HTSLIT_ITEMIZE.

            HTDTSA_ListItemFormat -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) format string for each item
                introducer. Not implemented yet.

        Tags for HTST_ENDLIST :

            HTDTSA_ListType -- type of the list HTSLIT_#? values.

        Tags for HTST_LABEL :

            HTDTSA_Label -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) label name

            HTDTSA_LabelLen -- (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) length of label name

        Tags for HTST_GADGET :

            Not implemented yet.

    @{b}INPUTS@{ub}
        segInfo -- (@{"APTR" link "AG:SysInc/exec/types.h/main" 34}) info structure from @{"AllocSegInfoA()" link "AllocSegInfoA()"}
        type -- (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) type of the segment see HTST_#? values
        tagList -- (struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} *) list of attributes for the segment

    @{b}RESULTS@{ub}
        pointer to a HTSegment or @{"NULL" link "AG:SysInc/exec/types.h/main" 79} for failure.

    @{b}NOTES@{ub}
        The function uses the pool header specified in @{"AllocSegInfoA()" link "AllocSegInfoA()"}
        function to allocate it's memory. So if you pass a pool, which is
        used in more than one task, you have to arbitriate by yourself.

    @{b}SEE ALSO@{ub}
        @{"FreeSegment()" link "FreeSegment()"}, @{"exec.library/AllocPooled()" link "exec/AllocPooled()"},
        @{"datatypes.library/NewDTObjectA()" link "datatypes/NewDTObjectA()"}, datatypes/hypertextclass.h


@endnode
@node "ConvertAttributes()" "hypertext.datatype/ConvertAttributes()"

    @{b}NAME@{ub}
        ConvertAttributes -- convert AmigaGuide style attributes to internal
                             representation

    @{b}SYNOPSIS@{ub}
        string = ConvertAttributes(convInfo,string,len)
          D0                         A0       A1    D0

        @{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} ConvertAttributes(struct HTConvInfo * ,@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} ,@{"ULONG" link "AG:SysInc/exec/types.h/main" 37});

    @{b}FUNCTION@{ub}
        This function converts all attributes in the passed string
        to internal representation. The format of the attribute must match
        the one you specified in the @{"AllocConvInfoA()" link "AllocConvInfoA()"} function.
        After you performed this function all converted attributes are set
        in the @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} list, which you passed to @{"AllocConvInfoA()" link "AllocConvInfoA()"}.
        Currently supported Tags are :

            HTDTSA_LayoutFlags -- for justifation attributes
            HTDTSA_FgPen -- text color
            HTDTSA_BgPen -- background color
            HTDTSA_Style -- font style
            HTDTSA_TextFont -- textfont

        The converting is stopped, if len characters are converted or if
        the next to convert character is not a attribute introducer of the
        specified format.
        If a attribute isn't known by this function, the @{"HTDTM_CONVATTRIB" link "HTDTM_CONVATTRIB"}
        method is invoked on the object.

    @{b}INPUTS@{ub}
        convInfo -- (struct HTConvInfo *) info struct from @{"AllocConvInfoA()" link "AllocConvInfoA()"}
        string -- (@{"STRPTR" link "AG:SysInc/exec/types.h/main" 52}) string to convert
        len -- (@{"ULONG" link "AG:SysInc/exec/types.h/main" 37}) maximal length of the string

    @{b}RESULTS@{ub}
        string -- pointer to the next to last converted character.

    @{b}ATTRIBUTES@{ub}
        \@{apen <pennum>} -- Used to change the foreground color to a specific
            pen number.

        \@{b} -- Turn bold on.

        \@{bg <colortext>} -- Used to change the background text color. Color
            can be :

                Text
                Shine
                Shadow
                Fill
                FillText
                Background
                Highlight

        \@{bpen <pennum>} -- Used to change the background color to a specific
            pen number.

        \@{stdfont} -- Reset to standard font.

        \@{fg <colortext>} -- Used to change the foreground text color. The same
            colors can be used as in the bg command.

        \@{font <fontname>[,<size>]} -- Used to set a @{"TextFont" link "AG:SysInc/graphics/text.h/main" 89}, with name
            <fontname> and size <size>. If size isn't specified 8 is used.

        \@{i} -- Turn italic on.

        \@{jcenter} -- Turn centering on.

        \@{jleft} -- Turn on left justification.

        \@{jright} -- Turn on right justification.

        \@{plain} -- reset font style to normal.

        \@{u} -- Turn underline on.

        \@{ub} -- Turn bold off.

        \@{ui} -- Turn italic off.

        \@{uu} -- Turn underline off.

    @{b}EXAMPLE@{ub}
        struct HTSegInfo *seginfo;

        if((seginfo = @{"AllocSegInfo" link "AllocSegInfoA()"}(HTDTSIA_Pool,pool,
                                   HTDTSIA_Object,obj,
                                   HTDTSIA_GadgetInfo,msg->gpl_GInfo,
                                   @{"TAG_DONE" link "AG:SysInc/utility/tagitem.h/main" 39})) != @{"NULL" link "AG:SysInc/exec/types.h/main" 79})
        {
           struct HTConvInfo *convinfo;
           struct @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} tags[5];

           /* @{"AllocConvInfoA()" link "AllocConvInfoA()"} setup defaults, so we only need to provide
            * the @{"Tag" link "AG:SysInc/utility/tagitem.h/main" 30} id's
            */
           tags[0].ti_Tag  = HTDTSA_Flags;
           tags[1].ti_Tag  = HTDTSA_FgPen;
           tags[2].ti_Tag  = HTDTSA_BgPen;
           tags[3].ti_Tag  = HTDTSA_Style;
           tags[4].ti_Tag  = @{"TAG_DONE" link "AG:SysInc/utility/tagitem.h/main" 39};

           /* allocate the convert info structure for the @{"TagItem" link "AG:SysInc/utility/tagitem.h/main" 32} array
            * tags[]
            */
           if((convinfo = @{"AllocConvInfoA" link "AllocConvInfoA()"}(seginfo,tags,@{"NULL" link "AG:SysInc/exec/types.h/main" 79})) != @{"NULL" link "AG:SysInc/exec/types.h/main" 79})
           {
              @{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} buffer = "\@{fg highlight}highlighted Text@{fg text}";
              @{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} ptr = buffer;
              @{"STRPTR" link "AG:SysInc/exec/types.h/main" 52} seg,endseg;

              seg = ptr;
              while(*ptr != '\0')
              {
                 endseg = ptr;
                 if(*ptr == '@')
                 {
                    /* is there a outstanding segment with old attributes ?
                     * if there is, allocate a segment.
                     */
                    if(seg < endseg)
                       AllocSegment(seginfo,HTST_NORMAL,
                                    HTDTSA_Text,seg,
                                    HTDTSA_TextLen,endseg-seg,
                                    @{"TAG_MORE" link "AG:SysInc/utility/tagitem.h/main" 42},tags);

                    /* now convert the new attributes to the internal
                     *  data representation in the TagArray tags[]
                     */
                    ptr = ConvertAttributes(convinfo,ptr,strlen(ptr));

                    /* set now the beginning of the next segment */
                    seg = ptr + 1;
                 }

                 ptr++;
              }
              /* is there a outstanding segment ? */
              if(seg < endseg)
                 AllocSegment(seginfo,HTST_NORMAL,
                              HTDTSA_Text,seg,
                              HTDTSA_TextLen,endseg-seg,
                              @{"TAG_MORE" link "AG:SysInc/utility/tagitem.h/main" 42},tags);

              @{"FreeConvInfo" link "FreeConvInfo()"}(convinfo);
           }
           @{"FreeSegInfo" link "FreeSegInfo()"}(seginfo);
        }

    @{b}SEE ALSO@{ub}
        @{"AllocConvInfoA()" link "AllocConvInfoA()"}, @{"HTDTM_CONVATTRIB" link "HTDTM_CONVATTRIB"}, hyperguide.datatype,
        hypertext.datatype


@endnode
