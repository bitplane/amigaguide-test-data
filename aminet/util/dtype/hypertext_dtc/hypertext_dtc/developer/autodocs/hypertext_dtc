            @{"STM_RETRACE" link "AG:SysInc/datatypes/datatypesclass.h/main" 367} -- retrace to previously viewed node

            @{"STM_COMMAND" link "AG:SysInc/datatypes/datatypesclass.h/main" 375} -- dtt_Data contains a ARexx command string, which
                will be executed

            @{"STM_CONTENTS" link "AG:SysInc/datatypes/datatypesclass.h/main" 365} -- activate contents node of the actual viewed node

            @{"STM_INDEX" link "AG:SysInc/datatypes/datatypesclass.h/main" 366} -- activate index node of actual viewed node

