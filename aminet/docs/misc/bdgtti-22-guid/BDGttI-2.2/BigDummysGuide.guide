     exit X Q  ^C ^? :quitbye  CtrlAltDel   ~~q  :~q  logout  save/quit :!QUIT
     ^[zz ^[ZZZZZZ ^H  man vi ^  ^L  ^[c  ^# ^E ^X ^I ^T ? help  helpquit ^D  ^d
