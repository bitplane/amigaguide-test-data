@node ABYSS "Abyssal Gatekeeper"

@{b}Abyssal Gatekeeper@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Summon Gatekeeper (1/1)
Cost    = 1B
Artist  = Mark Tedin

Text(WL): If Abyssal Gatekeeper is put into any graveyard from play,
          each player chooses and buries a creature he or she controls.

Flavor Text: @{i}"There are two ways for me to pass this gate. One involves
               you remaining conscious." ---Gerrard of the Weatherlight

 @{" Rulings " link MTG_CARD_A.guide/ABYSG}

@endnode
@node AGONI "Agonizing Memories"

@{b}Agonizing Memories@{ub}

Color   = Black
Rarity  = WL(U)
Type    = Sorcery
Cost    = 2BB
Artist  = Mike Dringenberg

Text(WL): Look at target player's hand. Choose two of those cards and
          put them on top of his or her library in any order.

Flavor Text: @{i}"An innocent man died because of my anger. That knowledge
               will haunt me for all eternity." ---Karn, silver golem

 @{b}NO RULINGS@{ub}

@endnode
@node BARRO "Barrow Ghoul"

@{b}Barrow Ghoul@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Summon Zombie (4/4)
Cost    = 1B
Artist  = Bryan Talbot

Text(WL): During your upkeep, remove the top creature card in your
          graveyard from the game or bury Barrow Ghoul.

Flavor Text: @{i}"The killed my family to deny me a future. They fed on my
               ancestors to deny me a past." ---Crovax

 @{b}NO RULINGS@{ub}

@endnode
@node BONED "Bone Dancer"

@{b}Bone Dancer@{ub}

Color   = Black
Rarity  = WL(R)
Type    = Summon Zombie (2/2)
Cost    = 1BB
Artist  = Scott Kirschner

Text(WL): <0>: Put the top creature card of defending player's graveyard
          into play under your control. Bone Dancer deals no combat damage
          this turn. Use this ability only if Bone Dancer is attacking and
          unblocked and only once each turn.

 @{b}NO RULINGS@{ub}

@endnode
@node BURIE "Buried Alive"

@{b}Buried Alive@{ub}

Color   = Black
Rarity  = WL(U)
Type    = Sorcery
Cost    = 2B
Artist  = Brian Horton

Text(WL): Search your library for up to three creature cards and put them
          into your graveyard. Shuffle your library afterwards.

Flavor Text: @{i}"Is it worse to walk while dead, or to be buried alive? I
               have wirnessed both." ---Crovax

 @{" Rulings " link MTG_CARD_B.guide/BURIE}

@endnode
@node CIRCL "Circling Vultures"

@{b}Circling Vultures@{ub}

Color   = Black
Rarity  = WL(U)
Type    = Summon Birds (3/2)
Cost    = B
Artist  = Una Fricker

Text(WL): Flying
          During your upkeep, remove the top creature card in your
          graveyard from the game or bury Circling Vultures.
          If Circling Vultures is in your hand, you may discard it.
          Play this ability as an instant.

 @{b}NO RULINGS@{ub}

@endnode
@node COILS "Coils of the Medusa"

@{b}Coils of the Medusa@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Enchant Creature
Cost    = 1B
Artist  = Darbury Stenderu

Text(WL): Enchanted creature gets +1/-1.
          Sacrifice Coils of the Medusa: Destroy all non-Wall creatures
          blocking enchanted creature.

Flavor Text: @{i}Serpentine locks shape ornate rocks.

 @{b}NO RULINGS@{ub}

@endnode
@node DOOMS "Doomsday"

@{b}Doomsday@{ub}

Color   = Black
Rarity  = WL(R)
Type    = Sorcery
Cost    = BBB
Artist  = Adrian Smith

Text(WL): Pay half your life, rounded up: Put your graveyard on top of
          your library, then remove all but five cards of your library
          from the game. Put the rest on top of your library in any order.

 @{" Rulings " link MTG_CARD_D.guide/DOOMS}

@endnode
@node FATAL "Fatal Blow"

@{b}Fatal Blow@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Instant
Cost    = B
Artist  = George Pratt

Text(WL): Bury target creature that was damaged this turn.

Flavor Text: @{i}"What is crueler? To let a wound of the heard fester, or to
               simply cut it out." ---Crovax

 @{" Rulings " link MTG_CARD_F.guide/FATBL}

@endnode
@node FESTE "Festering Evil"

@{b}Festering Evil@{ub}

Color   = Black
Rarity  = WL(U)
Type    = Enchantment
Cost    = 3BB
Artist  = John Matson

Text(WL): During your upkeep, Festering Evil deals 1 damage to each
          creature and player.
          <BB>, Sacrifice Festering Evil: Festering Evil deals 3 damage
          to each creature and player.

 @{b}NO RULINGS@{ub}

@endnode
@node FLEDG "Fledgling Djinn"

@{b}Fledgling Djinn@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Summon Djinn (2/2)
Cost    = 1B
Artist  = Thomas Gianni

Text(WL): Flying
          During your upkeep, Fledgling Djinn deals 1 damage to you.

Flavor Text: @{i}"The young can be quite dangerous. Trust me, I should know."
               ---Ertai, wizard adept

 @{b}NO RULINGS@{ub}

@endnode
@node GALLO "Gallowbraid"

@{b}Gallowbraid@{ub}

Color   = Black
Rarity  = WL(R)
Type    = Summon Legend (5/5)
Cost    = 3BB
Artist  = Carl Critchlow

Text(WL): Trample
          Cumulative upkeep: 1 life

Flavor Text: @{i}If its skin looks like stone, it is only to match its heart."
               ---Crovax

 @{b}NO RULINGS@{ub}

@endnode
@node HAUNT "Haunting Misery"

@{b}Haunting Misery@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Sorcery
Cost    = 1BB
Artist  = Gary Leach

Text(WL): Remove X creature cards in your graveyard from the game:
          Haunting Misery deals X damage to target player.

Flavor Text: @{i}"I am condemned without end." ---Crovax

 @{b}NO RULINGS@{ub}

@endnode
@node HIDDE "Hidden Horror"

@{b}Hidden Horror@{ub}

Color   = Black
Rarity  = WL(U)
Type    = Summon Undead (4/4)
Cost    = 1BB
Artist  = Clint Langley

Text(WL): When Hidden Horror comes into play, choose and discard
          a creature card or bury Hidden Horror.

Flavor Text: @{i}Lifespans are measured by its dreadful length.

 @{b}NO RULINGS@{ub}

@endnode
@node INFER "Infernal Tribute"

@{b}Infernal Tribute@{ub}

Color   = Black
Rarity  = WL(R)
Type    = Enchantment
Cost    = BBB
Artist  = Terese Nielsen

Text(WL): <2>, Sacrifice a card in play: Draw a card.

Flavor Text: @{i}"I would not barter my soul for any of the filth that they
               called power. So they took it from me and damned me to
               solitude." ---Crovax

 @{b}NO RULINGS@{ub}

@endnode
@node MISCH "Mischievous Poltergeist"

@{b}Mischievous Poltergeist@{ub}

Color   = Black
Rarity  = WL(U)
Type    = Summon Ghost (1/1)
Cost    = 2B
Artist  = DiTerlizzi

Text(WL): Flying
          Pay 1 life: Regenerate

Flavor Text: @{i}"The past is a ghost that haunts you from the moment it
               exists until the moment you don't."
               ---Gerrard of the Weatherlight

 @{b}NO RULINGS@{ub}

@endnode
@node MORIN "Morinfen"

@{b}Morinfen@{ub}

Color   = Black
Rarity  = WL(R)
Type    = Summon Legend (5/4)
Cost    = 3BB
Artist  = Carl Critchlow

Text(WL): Flying
          Cumulative upkeep: 1 life

Flavor Text: @{i}I looked into its eyes, and its oul was so empty I saw no
               reflection, no light there." ---Crovax

 @{b}NO RULINGS@{ub}

@endnode
@node NECRA "Necratog"

@{b}Necratog@{ub}

Color   = Black
Rarity  = WL(U)
Type    = Summon Atog (1/2)
Cost    = 1BB
Artist  = Bryan Talbot

Text(WL): Remove the top creature card in your graveyard from
          the game: +2/+2 until end of turn

Flavor Text: @{i}The necratog can always dig up a meal.

 @{b}NO RULINGS@{ub}

@endnode
@node ODYLI "Odylic Wraith"

@{b}Odylic Wraith@{ub}

Color   = Black
Rarity  = WL(U)
Type    = Summon Undead (2/2)
Cost    = 3B
Artist  = Ian Miller

Text(WL): Swampwalk
          If Odylic Wraith damages any player, that player chooses
          and discards a card.

Flavor Text: @{i}By the time you've seen it, you won't remember that you did.

 @{b}NO RULINGS@{ub}

@endnode
@node RAZOR "Razortooth Rats"

@{b}Razortooth Rats@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Summon Rats (2/1)
Cost    = 2B
Artist  = Brian Horton

Text(WL): Razortooth Rats cannot be blocked except by artifact
          creatures and black creatures.

Flavor Text: @{i}"Men and rats both hunger: we for
               our playthings; they for use."
               ---Crovax

 @{b}NO RULINGS@{ub}

@endnode
@node SHADO "Shadow Rider"

@{b}Shadow Rider@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Summon Knight (3/3)
Cost    = 2BB
Artist  = Pete Venters

Text(WL): Flanking

Flavor Text: @{i}In its world of complete darkness, it has no shadows to fear.

 @{b}NO RULINGS@{ub}

@endnode
@node SHATT "Shattered Crypt"

@{b}Shattered Crypt@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Sorcery
Cost    = XBB
Artist  = Gary Leach

Text(WL): Return X target creature cards from your graveyard to your
          hand and lose X life.

Flavor Text: @{i}"You must be mad to want one such as I aboard the Weatherlight.
               But I would be mad to remain here with my rotting family.
               I accept." ---Crovax

 @{b}NO RULINGS@{ub}

@endnode
@node SPINN "Spinning Darkness"

@{b}Spinning Darkness@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Instant
Cost    = 4BB
Artist  = John Coulthart

Text(WL): You may remove the top three black cards in your graveyard
          from the game instead of paying Spinning Darkness's casting
          cost. Spinning Darkness deals 3 damage to target nonblack
          creature. Gain 3 life.

Flavor Text: @{i}"I have seen the night torn into thin darkling strips and
               woven into shapes too bleak for dreams." ---Crovax

 @{b}NO RULINGS@{ub}

@endnode
@node STRAN "Strands of Night"

@{b}Strands of Night@{ub}

Color   = Black
Rarity  = WL(U)
Type    = Enchantment
Cost    = 2BB
Artist  = Patrick Kochakji

Text(WL): <BB>, Pay 2 life, Sacrifice a swamp: Put target creature
          card from your graveyard into play.

 @{b}NO RULINGS@{ub}

@endnode
@node TENDR "Tendrils of Despair"

@{b}Tendrils of Despair@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Sorcery
Cost    = B
Artist  = John Coulthart

Text(WL): Sacrifice a creature: Target opponent chooses and discards
          two cards.

Flavor Text: @{i}"Because I am incapable of tears does not mean I have no
               need to shed them." ---Karn, silver golem

 @{" Rulings " link MTG_CARD_T.guide/TENDR}

@endnode
@node URBJU "Urborg Justice"

@{b}Urborg Justice@{ub}

Color   = Black
Rarity  = WL(R)
Type    = Instant
Cost    = BB
Artist  = Gary Leach

Text(WL): Target opponent chooses and buries a number of creatures he
          or she controls equal to the number of creatures put into
          your graveyard from play so far this turn.

Flavor Text: @{i}"It is a narrow line between justice and venegance."
               ---Crovax

 @{" Rulings " link MTG_CARD_U.guide/URBJU}

@endnode
@node URBST "Urborg Stalker"

@{b}Urborg Stalker@{ub}

Color   = Black
Rarity  = WL(R)
Type    = Summon Undead (2/4)
Cost    = 3B
Artist  = Cliff Nielsen

Text(WL): During each player's upkeep, if that player controls any
          nonblack permanents other than lands, Urborg Stalker
          deals 1 damage to that player.

Flavor Text: @{i}"May you be a stalker's dream." ---Urborg curse

 @{b}NO RULINGS@{ub}

@endnode
@node WAVEO "Wave of Terror"

@{b}Wave of Terror@{ub}

Color   = Black
Rarity  = WL(R)
Type    = Enchantment
Cost    = 2B
Artist  = Adrian Smith

Text(WL): Cumulative upkeep: <1>
          At the end of your upkeep, bury each creature with casting
          cost equal to Wave of Terror's last paid cumulative upkeep.

Flavor Text: @{i}The sea of fear has endless depths.

 @{" Rulings " link MTG_CARD_W.guide/WAVEO}

@endnode
@node ZOMBI "Zombie Scavengers"

@{b}Zombie Scavengers@{ub}

Color   = Black
Rarity  = WL(C)
Type    = Summon Zombies (3/1)
Cost    = 2B
Artist  = Patrick Kochakji

Text(WL): Remove the top creature card in your graveyard from
          the game: Regenerate

Flavor Text: @{i}"Pick a shell upon my shore and put it into your ear.
               That sound isn't the sea, but the whispers of the fallen."
               ---Crovax

 @{b}NO RULINGS@{ub}

@endnode
