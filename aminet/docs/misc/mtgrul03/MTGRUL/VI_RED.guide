@node BOGAR "Bogardan Phoenix"

@{b}Bogardan Phoenix@{ub}

Color   = Red
Rarity  = VI(R)
Type    = Summon Phoenix (3/3)
Cost    = 2RRR
Artist  = David O'Connor

Text(VI): Flying
          If Bogardan Phoenix is put into any graveyard prom play and has
          no death counter on it, return Bogardan Phoenix to play and put
          a death counter on it. If Bogardan Phoenix is put into any
          graveyard from play and has a death counter on it, remove
          it from the game.

Flavor Text: @{i}No Flavor Text@{ui}

 @{" Rulings " link MTG_CARD_B.guide/BOGAR}

@endnode
@node DWARV "Dwarven Vigilantes"

@{b}Dwarven Vigilantes@{ub}

Color   = Red
Rarity  = VI(C)
Type    = Summon Dwarves (2/2)
Cost    = 2R
Artist  = Pete Venters

Text(VI): If Dwarven Vigilantes attacks and is not blocked, you may choose
          to have it deal no combat damage this turn. If you do, Dwarven
          Vigilantes deals an amount of damage equal to its power to target
          creature.

Flavor Text: @{i}Some dwarves can only be pushed so far.@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node ELKIN "Elkin Lair"

@{b}Elkin Lair@{ub}

Color   = Red
Rarity  = VI(R)
Type    = Enchant World
Cost    = 3R
Artist  = Jerry Tiritilli

Text(VI): During each player's upkeep, that player chooses a card at random
          from his or her hand and sets it aside face up. The player may
          play that card as though it were in his or her hand. If the
          player does not play the card by end of turn, bury that card.

Flavor Text: @{i}No Flavor Text@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node FIREB "Fireblast"

@{b}Fireblast@{ub}

Color   = Red
Rarity  = VI(C)
Type    = Instant
Cost    = 4RR
Artist  = Michael Danza

Text(VI): You may sacrifice two mountains instead of paying Fireblast's
          casting cost. Deal 4 damage to any one target.

Flavor Text: @{i}Embermages aren't well known for their diplomatic skills.@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node GOBRE "Goblin Recruiter"

@{b}Goblin Recruiter@{ub}

Color   = Red
Rarity  = VI(U)
Type    = Summon Goblin (1/1)
Cost    = 1R
Artist  = Scott Kirschner

Text(VI): When Goblin Recruiter comes into play, search your library for
          any number of Goblin cards. Reveal those cards to all players.
          Shuffle your library, then put the cards on top of your library
          in any order.

Flavor Text: @{i}"Next!"@{ui}

 @{" Rulings " link MTG_CARD_G.guide/GOREC}

@endnode
@node GOBSW "Goblin Swine-Rider"

@{b}Goblin Swine-Rider@{ub}

Color   = Red
Rarity  = VI(C)
Type    = Summon Goblin (1/1)
Cost    = R
Artist  = G. Darrow & I. Rabarot

Text(VI): If Goblin Swine-Rider is blocked, it deals 2 damage to each
          attacking creature and 2 damage to each blocking creature.

Flavor Text: @{i}"May you get the mount you deserve."
             -Suq'Ata curse@{ui}

 @{" Rulings " link MTG_CARD_G.guide/GOSWR}

@endnode
@node HEART "Hearth Charm"

@{b}Hearth Charm@{ub}

Color   = Red
Rarity  = VI(C)
Type    = Instant
Cost    = R
Artist  = Greg Spalenka

Text(VI): Choose one - Destroy target artifact creature; or all attacking
          creatures get +1/+0 until end of turn; or target creature with
          power 2 or less is unblockable this turn.

Flavor Text: @{i}No Flavor Text@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node HEATW "Heat Wave"

@{b}Heat Wave@{ub}

Color   = Red
Rarity  = VI(U)
Type    = Enchantment
Cost    = 2R
Artist  = Alan Rabinowitz

Text(VI): Cumulative upkeep: <R>
          Blue creatures cannot block creatures you control. Nonblue
          creatures cannot block creatures you control unless their
          controller plays an additional 1 life for each blocking
          creature.

Flavor Text: @{i}No Flavor Text@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node HULKI "Hulking Cyclops"

@{b}Hulking Cyclops@{ub}

Color   = Red
Rarity  = VI(U) / PT(U)
Type    = Summon Cyclops (5/5) / Summon Creature (5/5)
Cost    = 3RR
Artist  = DiTerlizzi (VI) / Paolo Parente (PT)

Text(PT): Hulking Cyclops can't intercept.

Text(VI): Hulking Cyclops cannot block.

Flavor Text: @{i}"Some say a great cyclops turns the world in its hands,
             looking down upon it with its one bright eye."
             -Afari, Tales@{ui}

 @{" Rulings " link MTG_CARD_H.guide/HULKI}

@endnode
@node KEEPE "Keeper of Kookus"

@{b}Keeper of Kookus@{ub}

Color   = Red
Rarity  = VI(C)
Type    = Summon Goblin (1/1)
Cost    = R
Artist  = Scott Hampton

Text(VI): <R>: Protection from red until end of turn.

Flavor Text: @{i}Wanted: Thick-skinned goblin for guarding mean
             ol' Kookus. Must like fires. Must heal quickly.@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node KOOKU "Kookus"

@{b}Kookus@{ub}

Color   = Red
Rarity  = VI(R)
Type    = Summon Djinn (3/5)
Cost    = 3RR
Artist  = Scott Hampton

Text(VI): Trample
          During your upkeep, if you do not controll at least one Keeper of
          Kookus, Kookus deals 3 damage to you and attacks this turn if able.
          <R>: +1/+0 until end of turn.

Flavor Text: @{i}No Flavor Text@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node LIGHT "Lightning Cloud"

@{b}Lightning Cloud@{ub}

Color   = Red
Rarity  = VI(R)
Type    = Enchantment
Cost    = 3R
Artist  = Steve Luke

Text(VI): <R>: Lightning Cloud does 1 damage to target creature or player.
          Use this ability only when a red spell is successfully cast and
          only once for each such spell.

Flavor Text: @{i}The mightiest clouds sit upon spires of fire.
             -Femeref adage@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node MOBME "Mob Mentality"

@{b}Mob Mentality@{ub}

Color   = Red
Rarity  = VI(U)
Type    = Enchant Creature
Cost    = R
Artist  = Douglas Shuler

Text(VI): Enchanted creature gains trample. If all non-Wall creatures you
          control attack, enchanted creature gets +*/+0 until end of turn,
          where * is equal to the number of attacking creatures.
Flavor Text: @{i}"Why is loud stupidity so infectious?"
             -Rana, Suq'Ata market fool@{ui}

 @{b}NO RULINGS@{ub}

@endnode
@node OGREE "Ogre Enforcer"

@{b}Ogre Enforcer@{ub}

Color   = Red
Rarity  = VI(R)
Type    = Summon Ogre (4/4)
Cost    = 3RR
Artist  = Pete Venters

Text(VI): Ogre Enforcer cannot be destroyed by lethal damage unless a
          single source deals enough damage to destroy it.

Flavor Text: @{i}"Ate up all of his siblings in the first week. A
             good beginning for one destined to command."
             -Suka, ogre matron@{ui}

 @{" Rulings " link MTG_CARD_O.guide/OGREE}

@endnode
