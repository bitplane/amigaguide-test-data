@node "uropa2" "UROPA²"
@toc "main"

@{b}Name.............@{ub} UROPA²
@{b}Editore..........@{ub} VULCAN SOFTWARE/AUSTEX SOFTWARE
@{b}Prezzo...........@{ub} @{"Listino" link "Listino.guide/giochi"}
@{b}Supporto.........@{ub} CD-ROM.
