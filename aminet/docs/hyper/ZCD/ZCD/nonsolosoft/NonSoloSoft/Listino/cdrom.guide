@node "anim2cd" "Animations"
@toc "main"

@{b}Name.............@{ub} Animations Double CD
@{b}Editore..........@{ub} Weird Science
@{b}Prezzo...........@{ub} @{"Listino" link "Listino.guide/cdrom"}
@{b}Supporto.........@{ub} 2 Cd
@{b}Compatibilita'...@{ub} Amiga (NoBoot)

@{b}Produzione.......@{ub} 1995

@{b}Contenuto........@{ub} Animazioni in formato .ANIM .FLI .FLC &
