@node "psuite64" "Personal Suite 6.4"
@toc "main"


@{b}Name.............@{ub} Personal Suite 6.4
@{b}Editore..........@{ub} Cloanto
@{b}Prezzo...........@{ub} @{"Listino" link "Listino.guide/cdrom"}
@{b}Supporto.........@{ub} CD-ROM
@{b}Compatibilita'...@{ub} Amiga

