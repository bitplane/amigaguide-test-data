 @{"Übersicht GameCD`s   " link G1996}

 @{"Zurück zum Hauptmenü " link CDROM.Guide/Main}

@ENDNODE
@NODE J1996 "Erscheinungsjahr 1996"
 
 @{" CD+G        " link CD+G}        @{" Information " link INFOS}
 @{" Cover CDROM " link COVER}        @{" Kids        " link KIDS}
