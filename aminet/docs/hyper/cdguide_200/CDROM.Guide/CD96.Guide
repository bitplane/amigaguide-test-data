@NODE CD6014 "AmiNet 10"

 @{b}AMINET 10@{ub}

 @{b}CDROM`s@{ub}     : 1
 @{b}Herausgeber@{ub} : Schatztruhe
 @{b}Sprache@{ub}     : Deutsch/Englisch
 @{b}Größe@{ub}       : 636 MByte
 @{b}Preis@{ub}       : 25,- DM

 @{b}Inhalt@{ub}      : Kopie eines Teils des AmiNet-Archives (Stand : 19.01.1996)
               Der besondere Schwerpunkt dieser CD liegt beim DTP.
               Auf dieser AmiNet-CD ist die Vollversion von PageStream V2.2
               und eine Spezialversion von TypeSmith V2.5 enthalten.
               BIZ  - Anwendungssoftware & Demos kommerzieller Programme
               COMM - Kommunikationssoftware
               DEMO - Demos, Intros
               DEV  - Entwicklersoftware
               DISK - Disktools
               DOCS - Textdokumente
               GAME - PD-Spiele & Demos kommerzieller Spiele
               GFX  - Grafiksoftware
               HARD - Hardwareinformationen
               MISC - Verschiedenes
               MODS - Musik-Module
               MUS  - Musiksoftware
               PIX  - Bilder
               TEXT - Texte
               UTIL - Nützliche Utilities
               Insgesamt enthalten sind 2241 Files aus dem AmiNet.

 @{b}Bootfähig@{ub}   : NEIN
 @{b}Hardware@{ub}    : Amiga + CDROM-Laufwerk
 @{b}Zubehör@{ub}     : Diskettenlaufwerk, Tastatur/Maus, Speicher

 @{b}Wertung@{ub}     : ***** 

 @{b}Test@{ub}        : AMIGA Magazin 03/96 S.34 

@ENDNODE
