@NODE CD2009 "Women In Motion"

 @{b}WOMEN IN MOTION@{ub}
 
 @{b}CDROM`s@{ub}     : 1
 @{b}Herausgeber@{ub} : On Line
 @{b}Sprache@{ub}     : Englisch
 @{b}Größe@{ub}       : ? MByte
 @{b}Preis@{ub}       : ? DM
 
 @{b}Inhalt@{ub}      : Die historischen Fotografien von Edward Muybridge sind unüber-
               troffene Berühmtheiten der Fotografie im 19. Jahrhundert. Die 
               Amiga-Technologie erweckt diese Bilder zum Leben. Dieser
               Titel gibt einzigartige Einblicke in Bewegungsabläufe. Sie
               können jedes Einzelbild studieren, ausdrucken oder in ein
               Grafikprogramm zur Weiterbearbeitung laden.
 
 @{b}Bootfähig@{ub}   : JA
 @{b}Hardware@{ub}    : CDTV/A570
               CD32/A1241 

 @{b}Wertung@{ub}     : -

 @{b}Test@{ub}        : -

@ENDNODE
