@EndNode


@Node "NODE_TTYPES_USEROXXLER" "CyberGraphX4.guide/NODE_TTYPES_USEROXXLER"
@Prev "NODE_TTYPES_SCROLLMASK"
@Next "NODE_TOOLS"
@Toc "NODE_TTYPES"
@{CODE}

	@{u}Tooltype USEROXXLER (nur CV64)@{uu}

