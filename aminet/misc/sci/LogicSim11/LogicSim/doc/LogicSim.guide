   |  |  |  |  |  |  |  |  |  |  |  |  |
   |__|  |__|  |__|  |__|  |__|  |__|  |
   +--------------------------------------->
                                          t
   ^
  J|
   |     ____
   |    |    |
   |    |    |
   |____|    |__________________________
   +--------------------------------------->
                                          t
   ^
  K|
   |              ______________________
   |             |
   |             |
   |_____________|
   +--------------------------------------->
                                          t
   ^
  Q|
   |            _____
   |           |     |
   |           |     |
   |___________|     |__________________
   +--------------------------------------->
                                          t
   ^
 /Q|
   |___________       __________________
   |           |     |
   |           |     |
   |           |_____|
   +--------------------------------------->
                                          t



@endnode

