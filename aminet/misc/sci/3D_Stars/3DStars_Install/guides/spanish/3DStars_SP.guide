@INDEX INDEX
@NODE MAIN "Teclas de 3D Stars"

          al = Ańo luz; s = segundo; f = fotograma
         Dec. = Declinación; AD = Ascensión Derecha


       Manteniendo la tecla pulsada aumenta su efecto.

 Combinación 1            Función                 Combinación 2
 ==============================================================
 (teclado normal)                               (tec. numérico)
@{B}
        ,           @{UB}Rotar hacia abajo@{B}                    2
        i           @{UB}Rotar hacia arriba@{B}                   8
        j           @{UB}Rotar hacia la izquierda@{B}             4
        l           @{UB}Rotar hacia la derecha@{B}               6
        o           @{UB}Rotar sentido horario@{B}                9
        u           @{UB}Rotar sentido antihorario@{B}            7
  cursor Arriba     @{UB}Mover hacia adelante@{B}
  cursor Abajo      @{UB}Mover hacia atrás@{B}
        k           @{UB}Parar@{B}                                5
        x           @{UB}Punto de vista hacia adelante@{B}        0
        c           @{UB}Punto de vista hacia atrás@{B}           .
        q           @{UB}Ir al Sol@{B}                            *
        ˇ (ż)       @{UB}Aumentar brillo@{B}                      +
        ' (?)       @{UB}Disminuir brillo@{B}                     -
        w           @{UB}Ampliar zoom@{B}                         1
        e           @{UB}Reducir zoom@{B}                         3
        h           @{UB}Parar de forma gradual@{B}
        s           @{UB}Des/Activar efecto estéreo (3D)@{B}    Intro
        r           @{UB}Incrementar posición del plano de pantalla (3D)@{B}
        t           @{UB}Decrementar posición del plano de pantalla (3D)@{B}
        f           @{UB}Incrementar efecto estéreo (3D)@{B}
        g           @{UB}Decrementar efecto estéreo (3D)@{B}

        p           @{UB}Pausa/Continuar@{B}

       ESC          @{UB}Salir


 TECLAS ABREVIADAS MENÚ
 ======================

 Amiga dch.+ Q     Salir
 Amiga dch.+ *     Reiniciar estrellas
 Amiga dch.+ S     Mostrar/Ocultar estadísticas
 Amiga dch.+ T     Mostrar/Ocultar barra de título de la pantalla


