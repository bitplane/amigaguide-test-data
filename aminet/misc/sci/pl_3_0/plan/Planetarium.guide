@node "ENGLISH" " english "

               English documentation for "PLANETARIUM 3.0"


    @{" FEATURES " link "I." 0}
    @{" Some remarks " link "II." 0}
    @{" Contents " link "III." 0}
    @{" Overview " link "IV." 0}
    @{" Functions " link "Screen" 0}
    @{" SHORTCUTS " link "V.I." 0}
