Select Item: @{"CO2" LINK "aqua_env_CO2_txt" } - @{"O2" LINK "aqua_env_O2_txt" } - @{"NH3" LINK "aqua_env_NH3_txt" } - @{"NH4+" LINK "aqua_env_NH4_txt" } - @{"NO2" LINK "aqua_env_NO2_txt" } - @{"NO3-" LINK "aqua_env_NO3_txt" } - @{"PH" LINK "aqua_env_PH_txt" } - @{"DH" LINK "aqua_env_DH_txt" } - @{"Temperature" LINK "aqua_env_temp_ga" }
