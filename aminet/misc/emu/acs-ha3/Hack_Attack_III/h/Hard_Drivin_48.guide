@DATABASE "Hard Drivin' 48K"
@NODE "MAIN" "SPECCY POKES - H - Hard Drivin' 48K"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - H
                   ====================================

                             Hard Drivin' 48K
                             ================


DESCRIPTION              POKE
===========              ====

@{"Infinite Time" RXS "ADDRESS COMMAND ZXAMPoke(41927,0)"}           41927,0
@{"'Hard Pilot' " RXS "ADDRESS COMMAND ZXAMPoke(42458,255)"}           42458,255
@{"Replays = x  " RXS "ADDRESS COMMAND ZXAMPoke(62937,1)"}           62937,x (x= 1-255)
@{"Mins = x     " rxs "address command zxampoke(57857,128)"}           57857,x (x= 1-128)


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).


                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode
