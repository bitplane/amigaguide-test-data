@DATABASE "Tempest"
@NODE "MAIN" "SPECCY POKES - T - Tempest"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - T
                   ====================================

                                  Tempest
                                  =======



DESCRIPTION              POKE
===========              ====

@{"Infinite Lives Pl. 1" RXS "ADDRESS COMMAND ZXAMPoke(33537,183)"}    33537,183
@{"Infinite Lives Pl. 2" RXS "ADDRESS COMMAND ZXAMPoke(33610,183)"}    33610,183
@{"Infinite Super Zap  " RXS "ADDRESS COMMAND ZXAMPoke(34909,0)"}    34909,0
@{"Lives = x           " RXS "ADDRESS COMMAND ZXAMPoke(33462,255)"}    33462,x (x= 1-255)

                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).
@endnode
