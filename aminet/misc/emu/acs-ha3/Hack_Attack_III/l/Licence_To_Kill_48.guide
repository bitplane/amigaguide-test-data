@DATABASE "Licence To Kill 48K"
@NODE "MAIN" "SPECCY POKES - L - Licence To Kill 48K"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - L
                   ====================================

                            Licence To Kill 48K
                            ===================



DESCRIPTION              POKE
===========              ====

@{"Lives = x           " RXS "ADDRESS COMMAND ZXAMPoke(47713,20)"}    47713,x (x= 1-20)
@{"Infinite Lives Lvl 1" rxs "address command zxampoke(55802,0)"}    55802,0
@{"Infinite Lives Lvl 2" rxs "address command zxampoke(48181,183)"}    48181,183
@{"Infinite Lives Lvl 3" rxs "address command zxampoke(48428,183)"}    48428,183
@{"Infinite Lives Lvl 4" rxs "address command zxampoke(48633,183)"}    48633,183
@{"Infinite Lives Lvl 5" rxs "address command zxampoke(59174,183)"}    59174,183
@{"Infinite Lives Lvl 6" rxs "address command zxampoke(59285,183)"}    59285,183
@{"Infinite Lives      " rxs "address command zxampoke(48633,183) zxampoke(55802,0)"}    48633,183:55802,0
@{"Infinite Energy     " RXS "ADDRESS COMMAND ZXAMPOKE(59400,0) zxampoke(54604,0) zxampoke(57078,0) zxampoke(58646,0)"}    59400,0:54604,0:57078,0:58646,0
@{"Infinite Bonus      " RXS "ADDRESS COMMAND ZXAMPOKE(47372,239)"}    47372,239
@{"Infinite Ammo       " RXS "ADDRESS COMMAND ZXAMPOKE(54919,0)"}    54919,0
@{"Infinite Time       " RXS "ADDRESS COMMAND ZXAMPOKE(57927,0)"}    57927,0
@{"Immune To Boats     " RXS "ADDRESS COMMAND ZXAMPOKE(56241,0)"}    56241,0
@{"Ammo (Lvl 2) = x    " rxs "address comman zxampoke(48030,255)"}    48030,x (x= 1-255)  * TEST!!!! *


                         In case you're wondering, if you want infinite
                         lives all through the game, just select the
                         POKE marked "Infinite Lives". Otherwise, you
                         can choose the level you want.

                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).


                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode

