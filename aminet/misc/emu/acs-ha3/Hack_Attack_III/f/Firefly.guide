@DATABASE "Firefly"
@NODE "MAIN" "SPECCY POKES - F - Firefly"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - F
                   ====================================

                                  Firefly
                                  =======


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives  " RXS "ADDRESS COMMAND ZXAMPoke(45453,167)"}        45453,167
@{"No Aliens       " RXS "ADDRESS COMMAND ZXAMPoke(38720,201)"}        38720,201
@{"Always Correct  " RXS "ADDRESS COMMAND ZXAMPoke(45913,62)"}        45913,62
@{"Infinite Time   " RXS "ADDRESS COMMAND ZXAMPoke(45889,24)"}        45889,24
@{"Yokas Not Needed" RXS "ADDRESS COMMAND ZXAMPoke(42877,24)"}        42877,24
@{"Lives = x       " RXS "ADDRESS COMMAND ZXAMPoke(44998,255)"}        44998,x (x= 1-255)

                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

                         Rastan.
@endnode
