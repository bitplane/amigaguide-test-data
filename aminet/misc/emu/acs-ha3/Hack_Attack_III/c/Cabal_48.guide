@DATABASE "CABAL 48K"
@NODE "MAIN" "SPECCY POKES - C - CABAL 48K"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - C
                   ====================================

                                 CABAL 48K
                                 =========


DESCRIPTION              POKE
===========              ====

@{"Pl. 1 Lives = x" RXS "ADDRESS COMMAND ZXAMPoke(31651,255)"}         31651,x (x= 1-255)
@{"Pl. 2 Lives = x" RXS "ADDRESS COMMAND ZXAMPoke(31668,255)"}         31668,x (x= 1-255)
@{"Immunity       " RXS "ADDRESS COMMAND ZXAMPoke(34822,24)"}         34822,24
@{"Smart Bomb     " RXS "ADDRESS COMMAND ZXAMPoke(39202,201)"}         39202,201
@{"No Enemies     " RXS "ADDRESS COMMAND ZXAMPoke(39217,201) zxampoke(39245,201)"}         39217,201:39245,201


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).


                         The "Lives = x" POKEs are mine and tested. The
                         others aren't and haven't been.


                         Rastan.
@endnode
