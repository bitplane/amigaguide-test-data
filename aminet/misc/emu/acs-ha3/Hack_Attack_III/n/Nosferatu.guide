@DATABASE "Nosferatu"
@NODE "MAIN" "SPECCY POKES - N - Nosferatu"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - N
                   ====================================

                                 Nosferatu
                                 =========



DESCRIPTION              POKE
===========              ====

@{"Infinite Time" RXS "ADDRESS COMMAND ZXAMPoke(32499,0)"}           32499,0
@{"Immunity     " RXS "ADDRESS COMMAND ZXAMPoke(39391,201)"}           39391,201
@{"No Enemies   " RXS "ADDRESS COMMAND ZXAMPoke(39791,201)"}           39791,201

                         The "No Enemies" POKE only freezes them. You
                         can still be injured by them though.

                         Rastan.
@endnode
