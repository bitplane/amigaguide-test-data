@DATABASE "Red Heat"
@NODE "MAIN" "SPECCY POKES - R - Red Heat"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - R
                   ====================================

                                 Red Heat
                                 ========



DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(33644,62)"}          33644,62
@{"No Fall Down  " RXS "ADDRESS COMMAND ZXAMPoke(31367,255) zxampoke(37977,255)"}          31367,255:37977,255
@{"Lives = x     " rxs "address command zxampoke(33372,255)"}          33372,x (x= 1-255)
@{"Level = x-1   " rxs "address command zxampoke(33377,0)"}          33377,x-1 (Level 1=0, 2=1 etc)
@{"Ammo = x      " rxs "address command zxampoke(33390,255)"}          33390,x (x= 1-255)



                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode
