@DATABASE "Rick Dangerous 2"
@NODE "MAIN" "SPECCY POKES - R - Rick Dangerous 2"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - R
                   ====================================

                             Rick Dangerous 2
                             ================



DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(35376,0)"}          35376,0
@{"Infinite Ammo " RXS "ADDRESS COMMAND ZXAMPoke(34541,0) zxampoke(38303)"}          34541,0:38303,0
@{"Infinite Bombs" RXS "ADDRESS COMMAND ZXAMPoke(34574,0) zxampoke(39745,0)"}          34574,0:39745,0
@{"Weapons = x   " RXS "ADDRESS COMMAND ZXAMPoke(31987,255)"}          31987, x (x= 1-255)
@{"Lives = x     " rxs "address command zxampoke(31937,255)"}          31937,x (x= 1-255)


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).


                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode
