@DATABASE "Rygar"
@NODE "MAIN" "SPECCY POKES - R - Rygar"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - R
                   ====================================

                                   Rygar
                                   =====



DESCRIPTION              POKE
===========              ====

@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(56743,255)"}          56743,x (x= 1-255)
@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(61577,0)"}          61577,0
@{"Time = x      " RXS "ADDRESS COMMAND ZXAMPoke(56798,255)"}          56798,x (x= 1-255)
@{"Infinite Time " RXS "ADDRESS COMMAND ZXAMPoke(51216,0)"}          51216,0

                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

                         Rastan.
@endnode
