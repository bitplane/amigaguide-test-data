@DATABASE "Incredible Shrinking Fireman"
@NODE "MAIN" "SPECCY POKES - I - Incredible Shrinking Fireman"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - I
                   ====================================

                       Incredible Shrinking Fireman
                       ============================


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(60217,183)"}              60217,183
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(60456,255) zxampoke(59505,255)"}              59505,x:60456,x (x= 1-255)
@{"Immunity      " RXS "ADDRESS COMMAND ZXAMPoke(60205,201)"}              60205,201
@{"No Enemies    " RXS "ADDRESS COMMAND ZXAMPoke(59876,0)"}              59876,0
@endnode
