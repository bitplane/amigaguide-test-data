@DATABASE "Indiana Jones And The Last Crusade"
@NODE "MAIN" "SPECCY POKES - I - Indiana Jones And The Last Crusade"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - I
                   ====================================

                    Indiana Jones And The Last Crusade
                    ==================================


DESCRIPTION              POKE
===========              ====

@{"Invisible     " RXS "ADDRESS COMMAND ZXAMPoke(37370,0)"}          37370,0
@{"No 1st Enemy  " RXS "ADDRESS COMMAND ZXAMPoke(38014,0)"}          38014,0
@{"Mega Jumps    " RXS "ADDRESS COMMAND ZXAMPoke(38680,0)"}          38680,0
@{"ESP           " RXS "ADDRESS COMMAND ZXAMPoke(35179,0)"}          35179,0
@{"Slow Enemy    " RXS "ADDRESS COMMAND ZXAMPoke(35756,0)"}          35756,0
@{"Fast Punches  " RXS "ADDRESS COMMAND ZXAMPoke(38129,0)"}          38129,0
@{"Infinite Whips" RXS "ADDRESS COMMAND ZXAMPoke(38137,0) zxampoke(38141,0)"}          38137,0:38141,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(42596,255)"}          42596,x (x= 1-255)
@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(43076,0)"}          43076,0
      OR
@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(42389,0)"}          42389,0


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

                         I haven't tested this one as I don't have the
                         game :(

                         Rastan
@endnode
