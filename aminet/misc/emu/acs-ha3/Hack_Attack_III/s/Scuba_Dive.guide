@DATABASE "Scuba Dive"
@NODE "MAIN" "SPECCY POKES - S - Scuba Dive"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - S
                   ====================================

                                Scuba Dive
                                ==========



DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(55845,0)"}          55845,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(55711,255)"}          55711,x (x= 1-255)
@endnode
