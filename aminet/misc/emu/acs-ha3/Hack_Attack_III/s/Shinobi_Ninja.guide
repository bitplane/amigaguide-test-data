@DATABASE "Shinobi Ninja"
@NODE "MAIN" "SPECCY POKES - S - Shinobi Ninja"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - S
                   ====================================

                               Shinobi Ninja
                               =============


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives   " RXS "ADDRESS COMMAND ZXAMPoke(34715,0)"}       34715,0
@{"Minutes = x      " RXS "ADDRESS COMMAND ZXAMPoke(34576,20)"}       34576,x (x= 1-255)
@{"Lives & Creds = x" RXS "ADDRESS COMMAND ZXAMPoke(35424,255)"}       34524,x (x= 1-255)
@{"Enemy Power = x  " rxs "address command zxampoke(46689,1)"}       46689,x (x= 1-255)


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).


                         This is one of my POKEs. Enjoy!

                         Rastan.
@endnode
