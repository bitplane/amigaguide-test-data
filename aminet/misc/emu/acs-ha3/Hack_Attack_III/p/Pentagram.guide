@DATABASE "Pentagram"
@NODE "MAIN" "SPECCY POKES - P - Pentagram"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - P
                   ====================================

                                 Pentagram
                                 =========



DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(49917,201)"}          49917,201
@{"Infinite Time " RXS "ADDRESS COMMAND ZXAMPoke(49916,0)"}          49916,0
@{"Mega Jump     " RXS "ADDRESS COMMAND ZXAMPoke(50751,0)"}          50751,0

                         The "Mega Jump" cheat can sometimes cause the
                         game to lock up on certain screens..
@endnode
