@DATABASE "Dynatron Mission"
@NODE "MAIN" "SPECCY POKES - D - Dynatron Mission"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - D
                   ====================================

                             Dynatron Mission
                             ================


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(41629,0)"}          41629,0
@{"Immunity      " RXS "ADDRESS COMMAND ZXAMPoke(41686,201)"}          41606,201
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(44969,255)"}          44969,x (x= 1-255)

                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

                         Rastan.
@endnode
