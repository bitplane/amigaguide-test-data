@DATABASE "Monty On The Run"
@NODE "MAIN" "SPECCY POKES - M - Monty On The Run"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - M
                   ====================================

                             Monty On The Run
                             ================



DESCRIPTION              POKE
===========              ====

@{"Infinite Lives  " RXS "ADDRESS COMMAND ZXAMPoke(34716,24)"}        34716,24
@{"Lives = x       " RXS "ADDRESS COMMAND ZXAMPoke(39039,255)"}        39039,x (x= 1-255)
@{"Infinite Shields" RXS "ADDRESS COMMAND ZXAMPoke(36477,0)"}        36477,0
@{"Immunity        " RXS "ADDRESS COMMAND ZXAMPoke(36765,201)"}        36765,201
@{"Harmless Water  " RXS "ADDRESS COMMAND ZXAMPoke(39504,0)"}        39504,0
@{"No Crushers     " RXS "ADDRESS COMMAND ZXAMPoke(34445,201)"}        34445,201


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).
@endnode
