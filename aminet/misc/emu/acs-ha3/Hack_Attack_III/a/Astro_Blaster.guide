@DATABASE "Astro Blaster"
@NODE "MAIN" "SPECCY POKES - A - Astro Blaster"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - A
                   ====================================

                               Astro Blaster
                               =============


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(47422,0)"}          47422,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(26369,255)"}          26369,x (x= 1-255)


                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).

@endnode
