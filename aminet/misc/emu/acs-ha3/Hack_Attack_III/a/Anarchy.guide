@DATABASE "Anarchy"
@NODE "MAIN" "SPECCY POKES - A - Anarchy"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - A
                   ====================================

                                  Anarchy
                                  =======


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(42886,201)"}          42886,201
@{"Infinite Time " RXS "ADDRESS COMMAND ZXAMPoke(34566,33)"}          34566,33
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(42405,255)"}          42405,x (x = 1-255)

                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI.
@endnode
