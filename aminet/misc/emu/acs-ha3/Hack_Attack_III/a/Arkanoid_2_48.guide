@DATABASE "Arkanoid 2 48K"
@NODE "MAIN" "SPECCY POKES - A - Arkanoid 2 48K"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - A
                   ====================================

                              Arkanoid 2 48K
                              ==============


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives  " RXS "ADDRESS COMMAND ZXAMPoke(33055,255,0) ZXAMPoke(33909,0)"}        33055,255:33909,0
@{"No Moving Bricks" RXS "ADDRESS COMMAND ZXAMPoke(33423,0) ZXAMPoke(33429,0)"}        33423,0:33429,0
@{"Two Bats        " RXS "ADDRESS COMMAND ZXAMPoke(40413,1)"}        40413,1
@{"Catch Bat       " RXS "ADDRESS COMMAND ZXAMPoke(40413,4)"}        40413,4
@{"Laser Bat       " RXS "ADDRESS COMMAND ZXAMPoke(40413,32)"}        40413,32
@{"Next Screen     " RXS "ADDRESS COMMAND ZXAMPoke(40414,1)"}        40414,1
@{"Power Ball      " RXS "ADDRESS COMMAND ZXAMPoke(40415,64)"}        40415,64
@{"Bricks = x      " RXS "ADDRESS COMMAND ZXAMPoke(40443,30)"}        40443,x (x= 1-255)
@{"Ball Speed = x  " RXS "ADDRESS COMMAND ZXAMPoke(40420,1)"}        40420,x (x= 1-255)


                         As far as I can make out, you have to ESCape from 
                         the game, select which type of bat you want, then
                         go back into the game. Obviously, you can't have
                         more than one type of bat.

                         I haven't tested this one as I don't have the
                         game :(

                         Rastan
@endnode
