@DATABASE "ATF"
@NODE "MAIN" "SPECCY POKES - A - ATF"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - A
                   ====================================

                                    ATF
                                    ===


DESCRIPTION              POKE
===========              ====

@{"Infinite Lives " RXS "ADDRESS COMMAND ZXAMPoke(32990,0)"}         32990,0
@{"No Weight Limit" RXS "ADDRESS COMMAND ZXAMPoke(35717,0) ZXAMPoke(35718,0)"}         35717,0:35718,0
@{"Always Fast    " RXS "ADDRESS COMMAND ZXAMPoke(36451,62) ZXAMPoke(36452,100) ZXAMPoke(36453,0)"}         36451,62:36452,100:36453,0
@{"Lives = x      " RXS "ADDRESS COMMAND ZXAMPoke(32815,255)"}         32815,x (x= 1-255)

                         Change x to whatever value you wish, using
                         the POKE option on the ZXAM GUI. Simply
                         click the button to get the maximum value
                         x can be (usually 255).
@endnode
