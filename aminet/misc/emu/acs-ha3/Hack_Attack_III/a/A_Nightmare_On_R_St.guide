@DATABASE "A Nightmare On Robinson Street"
@NODE "MAIN" "SPECCY POKES - A - A Nightmare On Robinson Street"
@TOC "MAIN"

                   ZX SPECTRUM (SPECCY heheh) POKES - A
                   ====================================

                      A Nightmare On Robinson Street
                      ==============================


DESCRIPTION              POKE
===========              ====
            
@{"Enemies = x   " RXS "ADDRESS COMMAND ZXAMPoke(49937,5)"}          49937,x (x= 1-255)
@{"Energy = x    " RXS "ADDRESS COMMAND ZXAMPoke(49990,255)"}          49990,x (x= 1-255)
@{"Immune To Ammo" RXS "ADDRESS COMMAND ZXAMPoke(53267,0)"}          53267,0
@{"Immune To Dogs" RXS "ADDRESS COMMAND ZXAMPoke(56139,0)"}          56139,0


                         The first two POKEs are mine, and have been
                         tested. The other two aren't, and haven't.

                         Rastan.
@endnode
