@node sect0 "Name"
rzxcheck - Check the signature in a ZX Spectrum RZX file    
@endnode

@node sect1 "Synopsis"
 @{b}rzxcheck@{ub} @{i}rzxfile@{ui}...     


@endnode

@node sect2 "Description"
rzxcheck verifies the digital signature found in a Sinclair ZX Spectrum RZX input recording file.    
@endnode

@node sect3 "Options"


· @{i}rzxfile@{ui} @{lindent 3}
specifies an input recording file whose signature is to be verified.    @{lindent 0}


@endnode

@node sect4 "Bugs"
None known.    
@endnode

@node sect5 "See Also"
@{i}fuse@{ui}(1), @{i}fuse-utils@{ui}(1), @{i}rzxdump@{ui}(1), @{i}rzxtool@{ui}(1) The comp.sys.sinclair Spectrum FAQ, at 
@{i}http://www.worldofspectrum.org/faq/index.html@{ui}.    


@endnode

@node sect6 "Author"
Philip Kendall (philip-fuse@shadowmagic.org.uk). 
@endnode
