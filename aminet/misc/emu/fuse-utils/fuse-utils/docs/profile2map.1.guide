@node sect0 "Name"
profile2map - Fuse profiler output converter    
@endnode

@node sect1 "Synopsis"
 @{b}profile2map@{ub} @{i}infile@{ui} outfile     
@endnode

@node sect2 "Description"
profile2map converts Fuse profiler output into Z80-style map format.    
@endnode

@node sect3 "Options"


· @{i}infile@{ui} @{lindent 3}
specifies the Fuse profiler output to be converted. @{lindent 0}

· @{i}outfile@{ui} @{lindent 3}
specifies the Z80 map file for output.    @{lindent 0}


@endnode

@node sect4 "Bugs"
None known.    
@endnode

@node sect5 "See Also"
@{i}fuse@{ui}(1), @{i}fuse-utils@{ui}(1) The comp.sys.sinclair Spectrum FAQ, at 
@{i}http://www.worldofspectrum.org/faq/index.html@{ui}.    


@endnode

@node sect6 "Author"
Stuart Brady (sdbrady@ntlworld.com). 
@endnode
