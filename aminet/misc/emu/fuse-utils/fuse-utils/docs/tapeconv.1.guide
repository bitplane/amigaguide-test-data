@database tapeconv
@master "tapeconv.1"
@remark "manual page source format generated by PolyglotMan v3.2 available at http://polyglotman.sourceforge.net/"
@wordwrap
@tab 8
   
@node sect0 "Name"
tapeconv - Sinclair ZX Spectrum tape file converter    
@endnode

@node sect1 "Synopsis"
 @{b}tapeconv@{ub} [ -a @{i}archive info TZX@{ui} ]@{i}@{ui} [ -b ]@{i}@{ui} [ -s @{i}SCR loading screen@{ui} ]@{i}@{ui} [ -i @{i}JPG or GIF inlay image@{ui} ]@{i}@{ui} @{i}infile@{ui} outfile     
@endnode

@node sect2 "Description"
tapeconv converts between ZX Spectrum tape images.    
@endnode

@node sect3 "Options"


· -a @{i}archive info TZX@{ui} @{lindent 3}
causes the TZX supplied to be scanned for a Archive Info block containing author, year of relase etc. information about the file and then added to the output TZX. @{lindent 0}

· [ -b ]@{i}@{ui} @{lindent 3}
causes the output TZX to be stripped of any concatenation blocks that get created when appending TZX files. @{lindent 0}

· [ -s @{i}SCR loading screen@{ui} ]@{i}@{ui} @{lindent 3}
causes the supplied .scr format file to be attached to the TZX as a Custom Info block marked as a loading screen. @{lindent 0}

· [ -i @{i}JPG or GIF inlay image@{ui} ]@{i}@{ui} @{lindent 3}
causes the supplied .gif or .jpg format file to be attached to the TZX as a Custom Info block marked as a cassette inlay. @{lindent 0}

· @{i}infile@{ui} @{lindent 3}
specifies the tape file to be converted. This file can be in any of the tape formats supported by @{i}libspectrum@{ui}(3). @{lindent 0}

· @{i}outfile@{ui} @{lindent 3}
specifies the output tape file. The format will be determined by the file extension and can be in any of the formats @{i}libspectrum@{ui}(3) supports for output.    @{lindent 0}


@endnode

@node sect4 "Bugs"
None known.    
@endnode

@node sect5 "See Also"
@{i}fuse@{ui}(1), @{i}fuse-utils@{ui}(1), @{i}libspectrum@{ui}(3), @{i}listbasic@{ui}(1), @{i}tzxlist@{ui}(1) The comp.sys.sinclair Spectrum FAQ, at 
@{i}http://www.worldofspectrum.org/faq/index.html@{ui}.    


@endnode

@node sect6 "Author"
Philip Kendall (philip-fuse@shadowmagic.org.uk). 
@endnode
