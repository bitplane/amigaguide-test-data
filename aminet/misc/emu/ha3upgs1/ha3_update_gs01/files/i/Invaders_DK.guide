@DATABASE "Invaders"
@NODE "MAIN" "SPECCY POKES - I - Invaders_DK_Tronics"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/d/DK_INVAD.SNA|N > T:NIL"} ... retro:games/spectrum/d/DK_INVAD.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - I@{uu}


                       @{U}@{B}Invaders - DK Tronics version@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(28694,0)"}          28694,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(26495,255)"}          26495,x (x= 1-255). Click to set to 255
@endnode
