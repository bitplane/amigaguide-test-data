@DATABASE "Mig_Buster"
@NODE "MAIN" "SPECCY POKES - M - Mig Buster"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/m/MIGBUSTR.Z80|N > T:NIL"} ... retro:games/spectrum/m/MIGBUSTR.Z80
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - M@{uu}


                                @{U}@{B}Mig Buster@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives " RXS "ADDRESS COMMAND ZXAMPoke(39223,0)"}         39223,0
@{"Infinite Ammo  " RXS "ADDRESS COMMAND ZXAMPoke(39819,0)"}         39819,0
@{"Infinite Energy" RXS "ADDRESS COMMAND ZXAMPoke(49737,0)"}         49737,0
@{"Lives = x      " RXS "ADDRESS COMMAND ZXAMPoke(39319,255)"}         39319,x (x= 1-255). Click to set to 255
@endnode
