@DATABASE "Maze_Chase"
@NODE "MAIN" "SPECCY POKES - M - Maze Chase"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/m/MAZCHASE.SNA|N > T:NIL"} ... retro:games/spectrum/m/MAZCHASE.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - M@{uu}


                                @{U}@{B}Maze Chase@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(34248,0)"}          34248,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(34301,255)"}          34301,x (x= 1-255). Click to set to 255
@endnode
