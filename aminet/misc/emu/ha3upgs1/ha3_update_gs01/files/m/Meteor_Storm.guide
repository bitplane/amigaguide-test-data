@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/m/METEO.SNA|N > T:NIL"} ... retro:games/spectrum/m/METEO.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - M@{uu}


                               @{U}@{B}Meteor Storm@{UB}@{UU}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(31086,182)"}          31086,182
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(29976,255)"}          29976,x (x= 1-255). Click to set to 255
@endnode
