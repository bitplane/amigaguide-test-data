@DATABASE "Reveal"
@NODE "MAIN" "SPECCY POKES - R - Reveal"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/r/REVEAL.Z80|N > T:NIL"} ... retro:games/spectrum/R/REVEAL.Z80
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - R@{uu}


                                  @{U}@{B}Reveal@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(33086,0)"}          33086,0
@{"Infinite Time " RXS "ADDRESS COMMAND ZXAMPoke(42038,0)"}          42038,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(32612,255)"}          32612,x (x= 1-255). Click to set to 255
@endnode
