@DATABASE "Galactic_Gunners"
@NODE "MAIN" "SPECCY POKES - G - Galactic Gunners"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/g/GALACGUN.SNA|N > T:NIL"} ... retro:games/spectrum/g/GALACGUN.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - G@{uu}


                             @{U}@{B}Galactic Gunners@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(65008,0)"}          65008,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(40004,255)"}          40004,x (x= 1-255). Click to set to 255
@endnode
