@DATABASE "Paris_To_Dakar"
@NODE "MAIN" "SPECCY POKES - P - Paris To Dakar"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/p/P2DAKAR.Z80|N > T:NIL"} ... retro:games/spectrum/P/P2DAKAR.Z80
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - P@{uu}


                              @{B}@{U}Paris To Dakar@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Time  " RXS "ADDRESS COMMAND ZXAMPoke(47947,0)"}         47947,0
@{"Infinite Damage" RXS "ADDRESS COMMAND ZXAMPoke(49786,0)"}         49786,0
@{"Infinite Fuel  " RXS "ADDRESS COMMAND ZXAMPoke(47746,182)"}         47746,182
@{"Time = x       " RXS "ADDRESS COMMAND ZXAMPoke(49327,254)"}         49327,x (x= 1-254). Click to set to 255
@{"Start 1st Posn " RXS "ADDRESS COMMAND ZXAMPoke(49337,1) zxampoke(49338,0)"}         49337,1:49338,0
@endnode
