@DATABASE "Hypsys_Part_2"
@NODE "MAIN" "SPECCY POKES - H - Hypsys Part 2"
@{"LOAD FROM SPECCY SENSATIONS 2" system "rx rexx:zxam_run.rexx speccy2:games/h/hypsys/hypsys2.SNA|N > T:NIL"} ... speccy2:games/h/hypsys/HYPSYS2.sna
@{"RUN GAME                     " rxs "zxamrun()"}
@TOC "MAIN"


                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - G@{uu}


                               @{U}@{B}Hypsys Part 2@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}

            
@{"Infinite Energy    " RXS "ADDRESS COMMAND ZXAMPoke(54500,0) zxampoke(54513,0)"}     54500,0:54513,0
@{"Infinite Ammo      " RXS "ADDRESS COMMAND ZXAMPoke(54561,182) zxampoke(54568,0)"}     54561,182:54568,0
@{"Infinite Rockets   " RXS "ADDRESS COMMAND ZXAMPoke(54607,182)"}     54607,182
@{"Immune To Big Ships" RXS "ADDRESS COMMAND ZXAMPoke(54409,201)"}     54409,201
@endnode
