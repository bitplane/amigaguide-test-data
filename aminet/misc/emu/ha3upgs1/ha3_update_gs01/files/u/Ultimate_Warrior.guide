@DATABASE "Ultimate_Warrior"
@NODE "MAIN" "SPECCY POKES - U - Ultimate Warrior"
@TOC "MAIN"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/u/ULTIMATE.SNA|N > T:NIL"} ... retro:games/spectrum/u/ULTIMATE.SNA
@{"RUN GAME            " rxs "zxamrun()"}

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - U@{uu}


                             @{U}@{B}Ultimate Warrior@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(50643,0)"}          50643,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(50619,255) zxampoke(50655,255)"}          50619,x:50655,x (x= 1-255). Click to set to 255
@endnode
