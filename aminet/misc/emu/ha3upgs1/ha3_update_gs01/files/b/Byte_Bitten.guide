@DATABASE "Byte_Bitten"
@NODE "MAIN" "SPECCY POKES - B - Bite Bitten"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/b/byte.SNA|N > T:NIL"} ... retro:games/spectrum/b/BYTE.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"


                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - B@{uu}


                               @{b}@{u}Bite The Dust@{uu}@{ub}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}

            
@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(53429,0)"}          53429,0
@{"Infinite Time " RXS "ADDRESS COMMAND ZXAMPoke(52790,0)"}          52790,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(43358,255)"}          43358,x (x= 1-255). Click to set to 255
@endnode
