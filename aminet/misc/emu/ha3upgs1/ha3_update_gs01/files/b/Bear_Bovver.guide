@DATABASE "Bear_Bovver"
@NODE "MAIN" "SPECCY POKES - B - Bear Bovver"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/b/bear.SNA|N > T:NIL"} ... retro:games/spectrum/b/BEAR.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"


                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - B@{uu}


                                @{u}@{b}Ball Crazy@{uu}@{ub}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}

            
@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(39192,0)"}          39192,0
@{"Infinite Bombs" RXS "ADDRESS COMMAND ZXAMPoke(39134,0)"}          39134,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(49236,255)"}          49236,x (x= 1-255). Click to set to 255
@{"Bombs = x     " RXS "ADDRESS COMMAND ZXAMPoke(49231,255)"}          49231,x (x= 1-255). Click to set to 255
@endnode
