@DATABASE "Frenzy"
@NODE "MAIN" "SPECCY POKES - F - Frenzy"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/f/FRENZY.SNA|N > T:NIL"} ... retro:games/spectrum/f/FRENZY.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - F@{uu}


                                  @{U}@{B}Frenzy@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(29956,0)"}          29956,0
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(29812,255)"}          29812,x (x= 1-255). Click to set to 255
@endnode
