@DATABASE "Delta_Charge"
@NODE "MAIN" "SPECCY POKES - D - Delta Charge"
@{"LOAD FROM RETRO GOLD" system "rx rexx:zxam_run.rexx retro:games/spectrum/d/DELTA.SNA|N > T:NIL"} ... retro:games/spectrum/d/DELTA.SNA
@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - D@{uu}


                               @{u}@{b}Delta Charge@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Lives" RXS "ADDRESS COMMAND ZXAMPoke(40868,58)"}          40868,58
@{"Lives = x     " RXS "ADDRESS COMMAND ZXAMPoke(32938,255)"}          32938,x (x= 1-255). Click to set to 255
@endnode
