@{"RUN GAME            " rxs "zxamrun()"}
@TOC "MAIN"

                   @{u}ZX SPECTRUM (SPECCY heheh) POKES - D@{uu}


                           @{U}@{B}Dimension Destructors@{UU}@{UB}


@{u}DESCRIPTION@{uu}              @{u}POKE@{uu}


@{"Infinite Shields" RXS "ADDRESS COMMAND ZXAMPoke(51124,182)"}        51124,182
@{"Shields = x     " RXS "ADDRESS COMMAND ZXAMPoke(48199,254)"}        48819,x (x= 1-254). Click to set to 254
@endnode
