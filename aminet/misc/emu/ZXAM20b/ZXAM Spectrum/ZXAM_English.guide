     @{"ZXAMDisableAbort" link   "ZXAMDisableAbort" 0}

Available since version 1.6 (39.20):

     @{"ZXAMDisassemble" link   "ZXAMDisassemble" 0}

Available since version 1.6b (39.21):

     @{"ZXAMLoadMode" link   "ZXAMLoadMode" 0}
