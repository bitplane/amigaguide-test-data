@{"         Privater Quoteheader         " link menu_brett_5_0_3}
@{"         Cookies                      " link menu_brett_5_0_4} - Sprüchedatei

@{" Point » Allgemeines                  " link menu_brett_5_2_0} - Netz, Packer, Anruf
@{"         Modem                        " link menu_brett_5_2_1} - Serielle Parameter, Modemkommandos
@{"         Sysop-Modus                  " link pointwin_gads} - Allgemein, Export, Import
