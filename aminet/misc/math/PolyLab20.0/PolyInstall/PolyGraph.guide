 exit
 
 BREAK_C:
 say 'Program aborted!'
@endnode

@node "test-33.rexx" "ARexx script test-33.rexx"
@prev "test-32.rexx"
 /* test-33.rexx */
 
 say "Dieses ARexx-Programm zeigt als"
 say "Beispiel die Anwendung folgender"
 say "Befehle von PolyMeas.V20.0:"
 say ""
 say "'ChooseMenu Use All Indices'"
 say "'ChooseMenu Show Buttons'"
 say "'ChooseMenu X-Value fixed'"
 say "'ChooseMenu Y-Value fixed'"
 say "'ChooseMenu Debug'"
 say "'ChooseMenu Sort by X-Value'"
 say "'GraphToFront', 'MeasToFront', 'GraphToBack', 'MeasToBack'"
 say "'WBenchToFront', 'PGScreenToBack'"
 say "'ChooseKey DEL'"
 
 signal ON BREAK_C
 HOST = address()
 address VALUE HOST
 say 'Sending Commands to 'HOST
 if  index(HOST, 'PolyMeas.Host') ~= 1 then address 'PolyMeas.Host'
 
 'GraphToBack'
 do i=1 to 2
    say "'ChooseMenu Use All Indices OFF'"
    'ChooseMenu Use All Indices OFF'
    pull yes
    say "'ChooseMenu Use All Indices ON'"
    'ChooseMenu Use All Indices ON'
    pull yes
 
    say "'ChooseMenu Show Buttons OFF'"
    'ChooseMenu Show Buttons OFF'
    pull yes
    say "'ChooseMenu Show Buttons ON'"
    'ChooseMenu Show Buttons ON'
    pull yes
 
    say "'ChooseMenu X-Value fixed OFF'"
    'ChooseMenu X-Value fixed OFF'
    pull yes
    say "'ChooseMenu X-Value fixed ON'"
    'ChooseMenu X-Value fixed ON'
    pull yes
 
    say "'ChooseMenu Y-Value fixed OFF'"
    'ChooseMenu Y-Value fixed OFF'
    pull yes
    say "'ChooseMenu Y-Value fixed ON'"
    'ChooseMenu Y-Value fixed ON'
    pull yes
 
    say "'ChooseMenu Debug OFF'"
    'ChooseMenu Debug OFF'
    pull yes
    say "'ChooseMenu Debug ON'"
    'ChooseMenu Debug ON'
    pull yes
 
    say "'ChooseMenu Sort by X-Value'"
    'ChooseMenu Sort by X-Value'
    pull yes
 
    say "'GraphToFront'"
    'GraphToFront'
    pull yes
 
    say "'GraphToBack'"
    'GraphToBack'
    pull yes
 
    say "'MeasToFront'"
    'MeasToFront'
    pull yes
 
    say "'MeasToBack'"
    'MeasToBack'
    pull yes
 
    say "'WBenchToFront'"
    'WBenchToFront'
    pull yes
 
    say "'PGScreenToBack'"
    'PGScreenToBack'
    pull yes
 end i
 'GraphToBack'
 say "Deleting Datablocks...enter First Index"
 pull FInd
 say "Enter Last Index"
 pull SInd
 'SetIndex' FInd
 do i=FInd to SInd
    'ChooseKey DEL'
 end i
 
 say 'program finished!'
 exit
 
 BREAK_C:
 say 'Program aborted!'
@endnode

