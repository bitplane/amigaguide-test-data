@node "test-00.rexx" "ARexx script test-00.rexx"
@prev "arexx"
 /* test-00.rexx */

 say "Dieses ARexx-Programm zeigt als"
 say "Beispiel die Anwendung folgender"
 say "Befehle von PolyMeas.V20.0:"
 say ""
 say "'GiveInfo'."
 say ""

 signal ON BREAK_C
 address 'PolyMeas.Host'
 options results

 'ChooseMenu Narrator ON'
 'GraphToFront'
 'GiveInfo' 'Hello, this is your PolyGraph speaking!'
 'Delay 50'
 'GiveInfo' 'You will like this program for sure!'
 'Delay 50'
 'GiveInfo' 'And you will be happy, what you can do now!'
 'Delay 50'
 'GiveInfo' 'But you should read the manual carefully!'
 'Delay 50'
 'GiveInfo' 'Only winners work with PolyGraph.'
 'ChooseMenu Narrator OFF'
 'Delay 150'
 exit
@endnode

@node "test-02.rexx" "ARexx script test-02.rexx"
@prev "test-00.rexx"
 /* test-02.rexx */

 say "Dieses ARexx-Programm zeigt als"
 say "Beispiel die Anwendung folgender"
 say "Befehle von PolyMeas.V20.0:"
 say ""
 say "'Plot', 'ShowData'."

 signal ON BREAK_C
 address 'PolyMeas.Host'

 'ChooseMenu New'
 'SetGraphLimits -50 550 0 500000'
 'GraphToFront'

 do i=1 to 50
   x = i*10
   y = 2*x*x-4*x+3
   'Plot' x y
 end
 'ShowData'

 say 'program finished!'
 exit
 BREAK_C:
 say 'Program aborted!'
@endnode

@node "test-03.rexx" "ARexx script test-03.rexx"
@prev "test-02.rexx"
 /* test-03.rexx */

 say "Dieses ARexx-Programm zeigt als"
 say "Beispiel die Anwendung folgender"
 say "Befehle von PolyMeas.V20.0:"
 say ""
 say "'DataFile', 'StoreValue', 'SendData',"
 say "'ShowData', 'GiveInfo', 'SetIndex',"
 say "und 'GetData'."

 signal ON BREAK_C
 address 'PolyMeas.Host'
 options results

 'DataFile' 'my1.cfg'
 address COMMAND 'wait 1 sec'
 'DataFile my12.cfg'
 address COMMAND 'wait 1 sec'
 'DataFile my123.cfg'
 address COMMAND 'wait 1 sec'
 'DataFile' 'ram:test.dat'

 'ChooseMenu New'
 'SetGraphLimits -50 550 0 500000'
 'GraphToFront'

 do i=1 to 50
   x = i*10
   y = 2*x*x-4*x+3
   'StoreValue' x 1
   'StoreValue' y 2
   'StoreValue' 10*y 5
   if i > 40 then 'SaveData'
   'SendData' i
 end
 'ShowData'
 'MeasToBack'
 'GraphToBack'
 'GiveInfo Setting_the_indices_now!'
 say 'Setting Index to 10'
 'SetIndex 10'
 address COMMAND 'wait 1 sec'
 say 'Setting Index to 0'
 'SetIndex 0'
 address COMMAND 'wait 1 sec'
 say 'Setting Index to 1'
 'SetIndex 1'
 address COMMAND 'wait 1 sec'
 say 'Setting Index to 55'
 'SetIndex 55'
 address COMMAND 'wait 1 sec'

 do  i=1 to 5
   say 'index ?'
   pull index
   say 'field ?'
   pull field
   'GetData' index field
   say 'Value from PolyGraph.V20.0 is ' result
 end

 say 'program finished!'
 exit
 BREAK_C:
 say 'Program aborted!'
@endnode

@node "test-05.rexx" "ARexx script test-05.rexx"
@prev "test-03.rexx"
 /* test-05.rexx */

 say "Dieses ARexx-Programm zeigt als"
 say "Beispiel die Anwendung folgender"
 say "Befehle von PolyMeas.V20.0:"
 say ""
 say "'TermChars', 'OpenIEEE', 'Remote'"
 say "'MeasureIEEE', 'ReadIEEE', 'ReadLnIEEE'"
 say "'SendIEEE', 'Plot', 'Local' und 'CloseIEEE'."
 say ""

 signal ON BREAK_C
 address 'PolyMeas.Host'
 options results

 'TermChars 13 10'
 'TermChars'
 say result

 'OpenIEEE'
 'Remote'

 do  i=1 to 5
   say 'Commandstring for 'MeasureIEEE' ?'
   pull cmd
   say 'IEEE Device nr ?'
   pull chnr
   'MeasureIEEE' chnr cmd
   say 'rc = ' rc
   say 'Resultstring is ' result
 end
 do  i=1 to 2
   say 'IEEE Device nr for 'ReadIEEE' ?'
   pull chnr
   'ReadIEEE' chnr
   say 'rc = ' rc
   say 'Resultstring is ' result
 end
 do  i=1 to 2
   say 'IEEE Device nr for 'ReadLnIEEE' ?'
   pull chnr
   'ReadLnIEEE' chnr
   say 'rc = ' rc
   say 'Resultstring is ' result
 end

 do  i=1 to 2
   say i". IEEE Device nr ?"
   pull chnr.i
   say "Commandstring for 'SendIEEE' ?"
   pull cmd.i
 end i

 do  i=1 to 10
   'MeasureIEEE' chnr.1 cmd.1
   x = result
   'MeasureIEEE' chnr.2 cmd.2
   y = result
   'Plot' x y
 end
 'Local' chnr.1","chnr.2
 'CloseIEEE'

 say 'program finished!'
 exit
 BREAK_C:
 say 'Program aborted!'
@endnode

