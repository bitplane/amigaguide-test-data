@node "test6.rexx" "ARexx script GPIB/test6.rexx"
@prev "test20.rexx"
 /* test6.rexx */
 signal ON BREAK_C
 
 scanner = 17
 fluke = 1
 
 address 'PolyMeas.Host'
 options results
 
 'OpenIEEE'
 do  i=1 to 10
    'SendIEEE' scanner 'CH01'
    'ReadIEEE' fluke
    x = result
    'SendIEEE' scanner 'CH02'
    'ReadIEEE' fluke
    y = result
    'Plot' x y
 end
 'CloseIEEE'
 
 say 'program finished!'
 exit
 BREAK_C:
 say 'Program aborted!'
@endnode

@node "test9.rexx" "ARexx script GPIB/test9.rexx"
@prev "test6.rexx"
 /* test9.rexx */
 signal ON BREAK_C
 
 Fluke = 1
 address 'PolyMeas.Host'
 options results
 
 say 'Testing Serial Polling on the Fluke 8840A'
 'TermChars 13 10'
 'TermChars'
 say result
 
 'OpenIEEE'
 'Abort'
 'Delay 100'
 'Clear'
 'Delay 100'
 'Remote'
 
 say 'Go on with measurement ?'
 pull yes
 
 'SendIEEE' Fluke 'T4'
 'SPoll' Fluke
 
 do  i=1 to 10
    'Trigger' Fluke
    do j=1 to 20
       'SPoll' Fluke
       if  bittst(d2c(result),4) then
          do
             'ReadIEEE' Fluke
             'StoreValue' result 1
             'SendData' i
             leave j
          end
    end
 end
 
 'SPoll' Fluke
 say bittst(d2c(result),4)
 
 'Local' Fluke
 'CloseIEEE'
 
 say 'program finished!'
 exit
 BREAK_C:
 say 'Program aborted!'
@endnode

@node "test10.rexx" "ARexx script GPIB/test10.rexx"
@prev "test9.rexx"
 /* test10.rexx */
 signal ON BREAK_C
 
 Fluke = 1
 address 'PolyMeas.Host'
 options results
 
 say 'Testing Serial Polling on the Fluke 8840A'
 'TermChars 13 10'
 'TermChars'
 say result
 
 'OpenIEEE'
 'Abort'
 'Clear'
 'Remote'
 
 say 'Go on with measurement ?'
 pull yes
 
 'SendIEEE' Fluke 'T4'
 'SPoll' Fluke
 
 do  i=1 to 10
    'Trigger' Fluke
    'PollReadIEEE' Fluke 4
    'StoreValue' result 1
    'SendData' i
 end
 
 'SendIEEE' Fluke 'T0S1'
 do  i=1 to 5
    'MultReadIEEE' Fluke 10
    say result
 end
 'PollReadIEEE' Fluke 4
 say result
 
 'Local' Fluke
 'CloseIEEE'
 
 say 'program finished!'
 exit
 BREAK_C:
 say 'Program aborted!'
@endnode

