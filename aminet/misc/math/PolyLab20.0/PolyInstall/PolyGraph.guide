 say "'ChooseMenu Load'"
 say "'ChooseMenu Save as'"
 
 signal ON BREAK_C
 address 'PolyMeas.Host'
 'GraphToBack'
 
 do i=1 to 2
    say "Please enter Filename to load"
    parse pull File
    'ChooseMenu Load' File
    'Delay 100'
    'GraphToBack'
    say "Please enter File to append"
    parse pull File
    'ChooseMenu Load' File 'Append'
    'Delay 100'
    'GraphToBack'
 
    say "Please enter File to save to"
    parse pull File
    'ChooseMenu Save as' File
    'Delay 100'
    'GraphToBack'
    say "Please enter File to save and overwrite previous"
    parse pull File
    'ChooseMenu Save as' File 'OverWrite'
    'Delay 100'
    'GraphToBack'
 end i
 
