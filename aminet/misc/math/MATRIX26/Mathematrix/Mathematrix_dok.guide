@{" Det " Link Det}
@{" Ax=B " Link Ax=B}
@{" +,- " Link +,-}
@{" * " Link *}
@{" ^ " Link ^}
@{" DEL " Link DEL}
@{" Zeigen " Link Zeigen}
@{" Stat " Link Stat}
@{" 1-6 " Link 1-6}
