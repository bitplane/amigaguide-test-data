@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual ---------------------------------------- Built-in functions -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "Main" "Built-in functions"
@{U}9) Built-in functions@{UU}

   These are the built-in functions of Laplace. Not included are keywords like
@{"while" LINK "Syntax.guide/Loops"}, @{"for" LINK "Syntax.guide/Loops"} etc. and functions from @{"libraries" LINK "Libraries.guide/Libraries"}.

   All functions can be overwritten by your own functions or procedures.

   @{" * " LINK "FKT-ABS"} abs()                @{" * " LINK "FKT-ACOS"} acos()               @{" * " LINK "FKT-ACOSH"} acosh()
   @{" * " LINK "FKT-ACOT"} acot()               @{" * " LINK "FKT-ARC"} arc()                @{" * " LINK "FKT-ARCCOS"} arccos()
   @{" * " LINK "FKT-ARCCOT"} arccot()             @{" * " LINK "FKT-ARCOSH"} arcosh()             @{" * " LINK "FKT-ARCSIN"} arcsin()
   @{" * " LINK "FKT-ARCTAN"} arctan()             @{" * " LINK "FKT-ARSINH"} arsinh()             @{" * " LINK "FKT-ARTANH"} artanh()
   @{" * " LINK "FKT-ASIN"} asin()               @{" * " LINK "FKT-ASINH"} asinh()              @{" * " LINK "FKT-ATAN"} atan()
   @{" * " LINK "FKT-ATANH"} atanh()              @{" * " LINK "FKT-BREAK"} break()              @{" * " LINK "FKT-CEIL"} ceil()
   @{" * " LINK "FKT-CLOCK"} clock()              @{" * " LINK "FKT-COLS"} cols()               @{" * " LINK "FKT-CONJ"} conj()
   @{" * " LINK "FKT-COS"} cos()                @{" * " LINK "FKT-COSH"} cosh()               @{" * " LINK "FKT-COT"} cot()
   @{" * " LINK "FKT-COUNT"} count()              @{" * " LINK "FKT-DERIVE"} derive()             @{" * " LINK "FKT-DET"} det()
   @{" * " LINK "FKT-DIM"} dim()                @{" * " LINK "FKT-EXP"} exp()                @{" * " LINK "FKT-FAK"} fak()
   @{" * " LINK "FKT-FLOOR"} floor()              @{" * " LINK "FKT-GENARRAY"} genarray()           @{" * " LINK "FKT-GENMATRIX"} genmatrix()
   @{" * " LINK "FKT-GENVECTOR"} genvector()          @{" * " LINK "FKT-GSOLVE"} gsolve()             @{" * " LINK "FKT-IM"} im()
   @{" * " LINK "FKT-INCLUDE"} include()            @{" * " LINK "FKT-INTEGRAL"} integral()           @{" * " LINK "FKT-INV"} inv()
   @{" * " LINK "FKT-INVERT"} invert()             @{" * " LINK "FKT-IRANDOM"} irandom()            @{" * " LINK "FKT-ISSUBTYPE"} issubtype()
   @{" * " LINK "FKT-LG"} lg()                 @{" * " LINK "FKT-LHS"} lhs()                @{" * " LINK "FKT-LN"} ln()
   @{" * " LINK "FKT-NEG"} neg()                @{" * " LINK "FKT-NINT"} nint()               @{" * " LINK "FKT-NORM"} norm()
   @{" * " LINK "FKT-PLOT-ADDFUNC"} plot_addfunc()       @{" * " LINK "FKT-PLOT-CLOSE"} plot_close()         @{" * " LINK "FKT-PLOT-DELFUNC"} plot_delfunc()
   @{" * " LINK "FKT-PLOT-NEW"} plot_new()           @{" * " LINK "FKT-PLOT-NEWANIM"} plot_newanim()       @{" * " LINK "FKT-PLOT-OPEN"} plot_open()
   @{" * " LINK "FKT-PLOT-REPFUNC"} plot_repfunc()       @{" * " LINK "FKT-PLOT-SETRANGE"} plot_setrange()      @{" * " LINK "FKT-RANDOM"} random()
   @{" * " LINK "FKT-RANDOMSEED"} randomseed()         @{" * " LINK "FKT-RANK"} rank()               @{" * " LINK "FKT-RE"} re()
   @{" * " LINK "FKT-RETURN"} return()             @{" * " LINK "FKT-RHS"} rhs()                @{" * " LINK "FKT-ROWS"} rows()
   @{" * " LINK "FKT-SIGN"} sign()               @{" * " LINK "FKT-SIN"} sin()                @{" * " LINK "FKT-SINH"} sinh()
   @{" * " LINK "FKT-SPUR"} spur()               @{" * " LINK "FKT-SQRT"} sqrt()               @{" * " LINK "FKT-TAN"} tan()
   @{" * " LINK "FKT-TANH"} tanh()               @{" * " LINK "FKT-TRANS"} trans()              @{" * " LINK "FKT-TYPEOF"} typeof()
