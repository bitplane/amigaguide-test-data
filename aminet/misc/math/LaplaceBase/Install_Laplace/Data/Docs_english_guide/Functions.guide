@REM KEY 0 0 "Functions" "floor()"
@{U}floor()@{UU}

@{B}sypnosis:@{UB}
   @{B}floor(@{I}x @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}x @{UI}: number, tensor

@{B}result:@{UB}
   number, tensor

   Return the integer that is  less than or equal to  @{I}x @{UI}. For complex numbers
@{I}floor () @{UI} is applied separately to the real and imaginary part of @{I}x @{UI}.

   @{I}floor () @{UI} on a tensor is applied on each member of the tensor.


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ ę by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-GENARRAY"
@TITLE "genarray()"
@NEXT "FKT-GENMATRIX"
@PREV "FKT-FLOOR"
@TOC "Functions"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual ------------------------------------------------ genarray() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "Functions" "genarray()"
@{U}genarray()@{UU}

@{B}sypnosis:@{UB}
   @{B}genarray(@{I}v @{UI}=@{I}a @{UI}..@{I}b @{UI}, @{I}exp @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}v @{UI}: identifier
   @{I}a, b @{UI}: positive integer
   @{I}exp @{UI}: any expression

@{B}result:@{UB}
   array

   Create a new array. @{I}v @{UI} runs from @{I}a @{UI}  to @{I}b @{UI}, and @{I}exp @{UI} will be evaluated for
each component. The resulting array has @{I}b - a + 1 @{UI} members.

   E.g.:
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT} genarray(a=1 .. 3, 1/a)
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT}   => @{I}{1, 1/2, 1/3}@{UI}

   Note: don't use identifiers like @{I}i @{UI} or @{I}e @{UI}. They have different meanings in
Laplace.


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ ę by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
@ENDNODE
@NODE "FKT-GENMATRIX"
@TITLE "genmatrix()"
@NEXT "FKT-GENVECTOR"
@PREV "FKT-GENARRAY"
@TOC "Functions"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual ----------------------------------------------- genmatrix() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "Functions" "genmatrix()"
@{U}genmatrix()@{UU}

@{B}sypnosis:@{UB}
   @{B}genmatrix(@{I}c @{UI}=@{I}c1 @{UI}..@{I}c2 @{UI}, @{I}r @{UI}=@{I}r1 @{UI}..@{I}r2 @{UI}, @{I}exp @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}c, r @{UI}: identifier
   @{I}c1, c2, r1, r2 @{UI}: positive integer
   @{I}exp @{UI}: any expression

@{B}result:@{UB}
   matrix

   Create a new matrix. @{I}c @{UI} runs from @{I}c1 @{UI} to @{I}c2 @{UI}, @{I}r @{UI} from @{I}r1 @{UI} to @{I}r2 @{UI}, and @{I}exp @{UI}
will be evaluated for each  component. The resulting matrix has  @{I}c2 - c1 + 1  @{UI}
columns and @{I}r2 - r1 + 1 @{UI} rows.

   E.g.:
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT} genmatrix(a=1 .. 3, b=1 .. 3, a/b)
@{B}@{BG FILL}@{FG FILLTEXT}>@{UB}@{BG BACKGROUND}@{FG TEXT}   => @{I}[1, 1/2, 1/3; 2, 1, 2/3; 3, 3/2; 1]@{UI}

   Note: don't use variable names like @{I}i @{UI} or @{I}e @{UI}. They have different meanings
in Laplace.


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ ę by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
