@TOC "Functions"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual ---------------------------------------------------- acos() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "Functions" "acos()"
@{U}acos()@{UU}

@{B}sypnosis:@{UB}
   @{B}acos(@{I}x @{UI})@{UB}

@{B}arguments:@{UB}
   @{I}x @{UI}: number

@{B}result:@{UB}
   number

   Return the arcus cosinus of @{I}x @{UI}. This is a synonym for @{I}arccos  x @{UI}.


@{FG SHINE}@{BG SHADOW}@{B}------------------------------------------------------------------ ę by P!\K -@{FG TEXT}@{BG BACKGROUND}@{UB}
