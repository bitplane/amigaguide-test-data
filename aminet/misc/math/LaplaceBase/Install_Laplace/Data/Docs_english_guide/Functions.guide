@PREV "FKT-EXP"
@TOC "Functions"
@{FG SHINE}@{BG SHADOW}@{B}- Laplace Manual ----------------------------------------------------- fak() -@{FG TEXT}@{BG BACKGROUND}@{UB}

@REM KEY 0 0 "Functions" "fak()"
@{U}fak()@{UU}

@{B}sypnosis:@{UB}
   @{B}fak(@{I}x @{UI})@{UB}

@{B}arguments:@{UB}
