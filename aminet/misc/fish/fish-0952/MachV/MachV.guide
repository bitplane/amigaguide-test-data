 @{" WIN_BACK_TO_FRONT " Link "WIN_BACK_TO_FRONT"} 
 @{" WIN_FRONT_TO_BACK " Link "WIN_FRONT_TO_BACK"} 
 @{" WIN_MOVE_WINDOW " Link "WIN_MOVE_WINDOW"} 
 @{" WIN_LAYER " Link "WIN_LAYER"} 
 @{" WIN_SIZE_WINDOW " Link "WIN_SIZE_WINDOW"} 
 @{" WIN_CHANGE_WINDOW " Link "WIN_CHANGE_WINDOW"} 
 @{" WIN_ZOOM_WINDOW " Link "WIN_ZOOM_WINDOW"} 
 @{" WIN_SEND_CLOSE " Link "WIN_SEND_CLOSE"} 
 @{" WIN_SEND_GADGET_DOWN " Link "WIN_SEND_GADGET_DOWN"} 
