@{"Farben" link Farben}
@{"Zeichensatz" link Zeichensatz}
@{"F-Tasten" link FTasten}
@{"Extern-Menü" link ExternMenue}
@{"TeX-Pfade" link TeXPfade}
@{"Rechter Rand" link RechterRand}
@{"Linker Rand" link LinkerRand}
