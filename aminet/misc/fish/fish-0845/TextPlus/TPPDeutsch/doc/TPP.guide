@Node Activate "TPP/ARexx-Port/ARexx-Befehle/Activate"
NAME         Activate Filename

FUNKTION     Aktiviert das Fenster mit dem Namen Filename.

BEISPIEL     Activate MAN:TP-ARexx.doc

RETURN       Bei einem Fehler: ErrorCode 5 Severity 4

SIEHE AUCH
@EndNode

@Node Append "TPP/ARexx-Port/ARexx-Befehle/Append"
NAME         Append Filename

FUNKTION     Hängt das File mit dem Namen Filename an das Ende
             des aktuellen Textes.
BEISPIEL     Append RAM:TP.tmp

RETURN       Bei einem Fehler: ErrorCode 4 Severity 1

SIEHE AUCH   @{"BLoad" link BLoad}
@EndNode

@Node AutoDivMode "TPP/ARexx-Port/ARexx-Befehle/AutoDivMode"
NAME         AutoDivMode switch

FUNKTION     Schaltet den Auto-Trenn-Modus an oder aus.

BEISPIEL     AutoDivMode on
             AutoDivMode off

RETURN

SIEHE AUCH   @{"BackUpMode" link BackupMode}, @{"BMode" link BMode},
             @{"InsertMode" link InsertMode}, @{"LetterMode" link LetterMode}
@EndNode

@Node AutoSave "TPP/ARexx-Port/ARexx-Befehle/AutoSave"
NAME         AutoSave n

FUNKTION     Speichert das aktuelle File alle n Minuten.

BEISPIEL     AutoSave 10
             AutoSave 0   (schaltet AutoSave aus)
RETURN

SIEHE AUCH
@EndNode

@Node BackTab "TPP/ARexx-Port/ARexx-Befehle/BackTab"
NAME         BackTab

FUNKTION     Springt zum vorhergehenden Tabulator.

BEISPIEL     BackTab

RETURN

SIEHE AUCH   @{"Tab" link Tab}, @{"BInsTab" link BInsTab},
             @{"BDelBackTab" link BDelBackTab}, @{"InsTab" link InsTab},
             @{"DelBackTab" link DelBackTab}, @{"BLeft" link BLeft},
             @{"BRight" link BRight}
@EndNode

@Node BackUpMode "TPP/ARexx-Port/ARexx-Befehle/BackUpMode"
NAME         BackUpMode switch

FUNKTION     Schaltet den BackUp-Modus an oder aus.

BEISPIEL     BackUpMode on
             BackUpMode off

RETURN

SIEHE AUCH   @{"AutoDivMode" link AutoDivMode}, @{"BMode" link BMode},
             @{"InsertMode" link InsertMode}, @{"LetterMode" link LetterMode}
@EndNode

