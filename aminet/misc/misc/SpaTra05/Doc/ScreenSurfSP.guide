@NODE 4.1 "Tipos de herramienta soportados"

 CX_POPKEY=<tecla(s) para invocar al gestor de pantallas>

 CX_CLOSEKEY=<tecla(s) para salir del programa>

 CX_CONFIGKEY=<tecla(s) para invocar la ventana de preferencias>

 CX_WINDOWKEY=<tecla(s) para invocar al gestor de ventanas>

 CX_TABKEY=<tecla(s) para saltar de una ventana a la siguiente>

 WBSCREEN=1  mostrar lista siempre sobre el Workbench
         =0  mostrar lista sobre la pantalla en primer plano

 PUBLIC=1    sólo mostrar pantallas públicas

 APPER=0     evitará que se muestre la ventana informativa inicial
             al poner en marcha ScreenSurf.

 OPTIONxx=Nombre del programa con su camino completo

             donde xx comienza obligatoriamente por el valor cero
             y han de ser valores consecutivos.  El nş máximo
             de opciones es 63 (limitación del sistema operativo).
@ENDNODE

