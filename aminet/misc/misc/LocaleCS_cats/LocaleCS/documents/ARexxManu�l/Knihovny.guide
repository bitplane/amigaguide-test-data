@Node RARP " Popis knihovny                                 Tomáî Procházka (©1999)"
@{Lindent 1}
 @{FG Fill}RexxArplib.library@{FG Text}  (3.0)
ŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻ
@{B}GetFile()@{UB}          - requester pro výbër soboru  (rexxreqtools.library)
@{B}GetFont()@{UB}          - requester pro výbër fontu
@{B}Request()@{UB}          - requester s textem a dvëma tlaçíty
@{B}PostMsg()@{UB}          - otevęe okno s textem (zprávou)
@{B}Getenv()@{UB}           - preçte globální (ENV) promënnou (lze pęeçíst jakýkoliv soubor, naçte i více ęádkű)
@{B}Setenv()@{UB}           - uloůí globální (ENV) promënnou (promënnou lze uloůit kamkoli, uloůí i více ęádkű)
@{B}FileList()@{UB}         - vyhledává soub. nebo adr. podle daného ARP vzoru

@{B}ScreenToBack()@{UB}     - pęesune obrazovku na pozadí
@{B}ScreenToFront()@{UB}    - pęesune obrazovku na popęedí
@{B}ScreenRows()@{UB}       - vrátí poçet ęádkű dané obrazovky
@{B}ScreenCols()@{UB}       - vrátí poçet slupcű dané obrazovky
@{B}ScreenLace()@{UB}       - informamuje o tom, zda je daná obrazovka v reůimu interlace
@{B}ScreenColor()@{UB}      - slouůí ke zjiîtëní nebo zmënëní barev obrazovky
@{B}MoveScreen()@{UB}       - posouvá s danou veęejnou obrazovkou
@{B}OpenScreen()@{UB}       - otevírá novou veęejnou obrazovku dle vaîeho pęání
@{B}CloseScreen()@{UB}      - zavírá danou veęejnou obrazovku
@{B}ShowTitle()@{UB}        - zobrazuje nebo skrývá horní liîtu obrazovky

@{B}CreateHost()@{UB}       - vytvoęí nový Host port pro komunikaci mezi ARexxem a
                     grafickým prostęedím...

  Dále  následuje  spousta  pęíkazű  (cca  47)  které  slouůí  k  vytváęení
jednoduchého grafického prostęedí.  Lze otevęít okno nebo celou obrazovku a
umisďovat  na ni gadgety, IFF obrázky, kreslit na ni.  Dokáůe napęíkad çíst
z klávesnice.
  Nevýhodou  je,  ůe  GUI  se  neumí pęizpűsobit velikosti písma a po zmënë
velikosti   okna   nedojde  k  automatickému  pęekreslení,  toho  vîak  lze
dosáhnout, za cenu trochu vëtîího usílí, programovë.
@EndNode

@Node RTRS " Popis knihovny                                 Tomáî Procházka (©1999)"
@{Lindent 1}
@{FG Fill} RexxTricks.library@{FG Text} (38.6)
ŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻ
 @{U}Funkce AmigaDOSu@{UU}

@{B}GETENV()@{UB}            - pęeçte globální (ENV) promënnou (naçte jakýkoliv soubor, ale jen jeden ęádek)
@{B}SETENV()@{UB}            - uloůí globální (ENV) promënnou (do jakéhokoliv souboru, i více ęádkű)
@{B}UNSETENV()@{UB}          - Smaůe globální (ENV) promënnou (nebo jakýkoliv jiný soubor)

@{B}PATHPART()@{UB}          - vrátí ze zadané celé cesty jen adresáę (bez souboru)
@{B}FILEPART()@{UB}          - vrátí ze zadané celé cesty jen název souboru
@{B}MAKEPATH()@{UB}          - vytvoęí celou cestu spojením souborové a adresáęové çásti

@{B}SUFFIXPART()@{UB}        - vrátí pęíponu zadaného souboru
@{B}MAKESUFFIX()@{UB}        - pęidá k názvu souboru koncovku

@{B}GETCOMMENT()@{UB}        - pęeçte komentáę souboru
@{B}SETCOMMENT()@{UB}        - uloůí komentáę souboru

@{B}GETPROTECTION()@{UB}     - pęeçte aktuální stavové bity Get protection flags of a file
@{B}SETPROTECTION()@{UB}     - nastavuje stavové bity souboru

@{B}MATCHPATTERN()@{UB}      - hledá zadaný vzor v ęetëzci (s pouůitím wildcards)
@{B}SEARCHPATTERN()@{UB}     - hledá zadaný vzor v souboru (s pouůitím wildcards)

@{B}GETKEY()@{UB}            - çekáná na stisk klávesy v oknë a vrátí, co bylo stisknuto

@{B}GETDIR()@{UB}            - naçte obsah adresáęe do kmenového symbolu (do pole)

@{B}READFILE()@{UB}          - naçte textový soubor do kmenového symbolu (do pole)
@{B}WRITEFILE()@{UB}         - uloůí obsah kmenového symbolu (promënné) do souboru
@{B}READLINES()@{UB}         - naçte çást souboru do kmenového symbolu (do pole)
@{B}WRITELINES()@{UB}        - Nahradí nebo vloůí ęádky do textového souboru


@{U} SCSI funkce@{UU}:

@{B}SCSI_DEVICETYPE()@{UB}   - vrátí informace o typu SCSI zaůízení (disk,CDROM,SCANNER,...)
@{B}SCSI_MANUFACTURER()@{UB} - pęeçte z SCSI zaęízení informace o výrobci
@{B}SCSI_PRODUCT()@{UB}      - pęeçte z SCSI zaůízení informace o typu výrobku
@{B}SCSI_REVISION()@{UB}     - pęeçte z SCSI zaęízení informace o verzi (revizi) výrobku
@{B}SCSI_TESTREADY()@{UB}    - testuje zda je SCSI zaęízení pęipraveno nebo ne


@{U} Funkce pro práci s Clipboardem@{UU}:

@{B}READCLIPBOARD()@{UB}    - pęeçte text z clipboardu (workbenchovského)
@{B}WRITECLIPBOARD()@{UB}   - uloůí text do clipboardu (workbenchovského)


@{U} Funkce pro práci s kmenovými symboly (s poli promënných)@{UU}:

@{B}QSORT()@{UB}            - setęídí pole pomoci QuickSort
@{B}BSEARCH()@{UB}          - hledá daný vzor v zadaném poli (binárnë)
@{B}LSEARCH()@{UB}          - hledá dany vzor v zadaném poli (lineárnë)

@{B}STEMCOPY()@{UB}         - zkopíruje obsah pole nebo jeho çást do jiného pole
@{B}STEMINSERT()@{UB}       - vloůí obsah pole nebo jeho çást do jiného pole
@{B}STEMREMOVE()@{UB}       - smaůe çást pol

@{B}VIEWLIST()@{UB}         - Zobrazí pole promënných v pëkném oknë (lze lokalizovat)


@{U} Funkce pro práci s veęejnými obrazovkami (Publicscreen)@{UU}:

@{B}GETDEFAULTPUBSCREEN()@{UB} - vrátí název standartní veęejné obrazovky
@{B}SETDEFAULTPUBSCREEN()@{UB} - nastaví novou standartní veęejnou obrazovku

@{B}GETPUBSCREENMODES()@{UB}   - vrátí aktuální rozliîení std. veęejné obrazovky
@{B}SETPUBSCREENMODES()@{UB}   - nastaví nové rozliîení std. veęejné obrazovky

@{B}PUBSCREENTOFRONT()@{UB}    - pęesune standarní veęejnou obrazovku do popęedí
@{B}PUBSCREENTOBACK()@{UB}     - odsune standarní veęejnou obrazovku do popęedí

@{B}PUBSCREENLIST()@{UB}       - vrátí seznam vîech otevęených veęejných obrazovek

@{B}BEEP()@{UB}                - Blikne vîemi obrazovkami


@{U} Funkce pro práci s ikonami@{UU}:

@{B}GETTOOLTYPEVALUE()@{UB}  - vrátí hodnotu tooltypu
@{B}SETTOOLTYPEVALUE()@{UB}  - nastaví hodnotu tooltypu

@{B}GETTOOLTYPES()@{UB}      - vrátí vîechny tooltypy ikony
@{B}SETTOOLTYPES()@{UB}      - nastaví vîechny tooltypy ikony

@{B}GETDEFAULTTOOL()@{UB}    - vrátí pęięazený program nastavený v ikonë
@{B}SETDEFAULTTOOL()@{UB}    - nastaví nový pęięazený program pro danou ikonu

@{B}GETSTACK()@{UB}          - vrátí velikost zásobníku nastavenou v ikonë
@{B}SETSTACK()@{UB}          - nastaví novou velikost zásobníku pro danou ikonu

@{B}CREATEICON()@{UB}        - vytvoęí pro soubor novou ikonu (vçetnë nastavení)
@{B}WBINFO()@{UB}            - zobrazí workbenchovské ŞIkon Infoş (OS3.0+)


@{U} Ostatní funkce@{UU}:

@{B}WHATIS()@{UB}             - zjistí typ souboru s pouůitím 'whatis.library'
@{B}WHATISTYPES()@{UB}        - vrátí seznma vîech známých datatypű 'whatis.library'

@{B}FILEID_IDENTIFY()@{UB}    - zjistí typ souboru s pouůitím 'FileID.library'
@{B}FILEID_GETHIGHID()@{UB}   - vrátí maximální poçet datatypű  knihovny 'FileID.library'
@{B}FILEID_GETIDSTRING()@{UB} - vrátí popis (název) datatypu o zadaném çísle
@{B}FILEID_GETTYPES()@{UB}    - vrátí seznam vîech známých datatypű 'FileID.library'

@{B}UUDECODE()@{UB}           - dekóduje ASCII soubor zpët do binární podoby pomoci Şuudecodeş
@{B}UUENCODE()@{UB}           - pęevede binární soubor do ASCII podoby pomoci Şuuencodeş

@{B}CRC32()@{UB}              - Spoçítáe 32-bitový CRC kontrolní souçet souboru

@{B}COUNTCHARS()@{UB}         - spoçítá poçet výskytű znaku(/ű) v ęetëzci

@{B}RAND()@{UB}               - vrátí náhodné çíslo v daném rozsahu

@{B}REXXTRICKSVERSION()@{UB}  - vrátí verzi vámi pouůívané Şrexxtricks.libraryş

@EndNode

