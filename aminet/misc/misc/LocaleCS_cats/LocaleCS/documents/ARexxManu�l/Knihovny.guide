@{B}STEMINSERT()@{UB}          @{FG HighLight}*@{FG Text} vloůí obsah pole nebo jeho çást do jiného pole
@{B}STEMREMOVE()@{UB}          @{FG HighLight}*@{FG Text} smaůe çást pol
@{B}SUFFIXPART()@{UB}          @{FG HighLight}*@{FG Text} vrátí pęíponu zadaného souboru
@{B}UNSETENV()@{UB}            @{FG HighLight}*@{FG Text} Smaůe globální (ENV) promënnou (nebo jakýkoliv jiný soubor)
@{B}UUDECODE()@{UB}            @{FG HighLight}*@{FG Text} dekóduje ASCII soubor zpët do binární podoby pomoci Şuudecodeş
@{B}UUENCODE()@{UB}            @{FG HighLight}*@{FG Text} pęevede binární soubor do ASCII podoby pomoci Şuuencodeş
@{B}VIEWLIST()@{UB}            @{FG HighLight}*@{FG Text} Zobrazí pole promënných v pëkném oknë (lze lokalizovat)
@{B}WBINFO()@{UB}              @{FG HighLight}*@{FG Text} zobrazí workbenchovské ŞIkon Infoş (OS3.0)
@{B}WHATIS()@{UB}              @{FG HighLight}*@{FG Text} zjistí typ souboru s pouůitím 'whatis.library'
@{B}WHATISTYPES()@{UB}         @{FG HighLight}*@{FG Text} vrátí seznma vîech známých datatypű 'whatis.library'
@{B}WRITECLIPBOARD()@{UB}      @{FG HighLight}*@{FG Text} uloůí text do clipboardu (workbenchovského)
@{B}WRITEFILE()@{UB}           @{FG HighLight}*@{FG Text} uloůí obsah kmenového symbolu (promënné) do souboru
@{B}WRITELINES()@{UB}          @{FG HighLight}*@{FG Text} Nahradí nebo vloůí ęádky do textového souboru

@EndNode
