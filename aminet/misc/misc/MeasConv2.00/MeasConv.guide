@NODE args "Arguments ToolTypes and Default Settings"
@{bold "Arguments,ToolTypes and Default Settings"}

ToolTypes:             Meaning
- NOPOPUP              don`t open main window at startup
Arguments:
- NOPOPUP              same as tooltype
@ENDNODE

@NODE mw "Main Window"
@{bold "Main Window"}

When You start MeasConv You it should be Opened one Window (IF ARG OR TOOLYTYPE NONPOPUP WAS NOT SET)
In Window You Then there should be 5 Button gadget.
(That Should Look SOmthing Like this)

             |-------------------------|
             |      MeasConv 02.00     |
             |    © Aris Basic 1995    |
             |        GMYware          |
             |-------------------------|
             |     Length Converter    | <- Pop`s up @{"Length Converter Wondow" LINK lc}
             |-------------------------|
             |    Other Converters     | <- Pop`s up @{"Other Converters Window" LINK oc}
             |-------------------------|
             |         About           | <- Pop`s up ABout Requester
             |-------------------------|
             |  Hide      |   Quit     |
             ---------------------------
                 ^             ^
             Iconify       Quits MeasConv



@{bold "MENU"}

About                        <- Pop`s up ABout Requester

Converters-
          Length Converter   <- Pop`s up @{"Length Convertor Window" LINK lc}
          Other Convertors   <- Pop`s up @{"Other COnvertors Window" LINK oc}

Hide                         <- Iconify
Quit                         <- Quit MeasConv

@ENDNODE
@NODE lc "Length Converter"
@{bold "Length Converter"}

    |-------------------------|
    |Length Converter         |
    |-------------------------|
    |Centimeters |           ||   <- Put Value in String gadget and press Return to
    |-------------------------|      Convert Centimeters in other Measurment Systems
    |Kilometers  |           ||   <- Put Value in String gadget and Press Return to 
    |-------------------------|      Convert Kilometers in other Mesurmenst Systems
    |Inches      |           ||   <- Put Value in String gadget and Press Return to
    |-------------------------|      Convert Inches in other Measurment Systems
    |Feets       |           ||   <- Put Value in String gadget and Press Return to
    |-------------------------|      Convert Feets in other Measurment Systems
    |Miles       |           ||   <- Put Value in String gadget and Press Return to
    |-------------------------|      Convert Miles in other Measurment Systems
    |          Exit           |
    ---------------------------
                 ^
              Closes
          Length Converter
             Window

@{bold "MENU"}

Exit         <- Closes Length Converter Window

Quit         <- Quits MeasConv

@ENDNODE
@NODE oc "Other Converters"
@{bold "Other Converters"}

    |-------------------------|
    |Weight Converter         |
    |-------------------------|
    |Kilograms   |           ||   <- Put Value in String gadget and press Return to
    |-------------------------|      Convert Kilograms in Pounds
    |Pounds      |           ||   <- Put Value in String gadget and Press Return to
    |-------------------------|      Convert Pounds in Kilograms
    |Temperature Converter    |
    |-------------------------|
    |Celsius     |           ||   <- Put Value in String gadget and Press Return to
    |-------------------------|      Convert Celsius in Fahreheits and Kelvins
    |Fahreheit   |           ||   <- Put Value in String gadget and Press Return to
    |-------------------------|      Convert Fahreheit in Celsius and Kelvins
    |Kelvin      |           ||   <- Put Value in String gadget and Press Return to
    |-------------------------|      Convert Kelvins in Celsius and Fahreheit
    |           Exit          |
    ---------------------------
                 ^
              Closes
          Other Converters
             Window

@{bold "MENU"}

Exit         <- Closes Other Converters Window

Quit         <- Quits MeasConv

@ENDNODE
@NODE mcrx "MeasConvRx"
@{bold "ARexx Port"}


ARexx Port Name :  @{bold "MEASCONV"}

Port Command    :  @{bold "CM2INCH"}   <- Converts Argument in Centimeters to Inches
                   @{bold "INCH2CM"}   <- Converts Argument in Inches to Centimeters
                   @{bold "INCH2FT"}   <- Converts Argument in Inches to Feets
                   @{bold "FT2INCH"}   <- Converts Argument in Feets to Inches
                   @{bold "FT2MILE"}   <- Converts Argument in Feets to Miles
                   @{bold "MILE2FT"}   <- Converts Argument in Miles to Feets
                   @{bold "MILE2KM"}   <- Converts Argument in Miles to Kilometers
                   @{bold "KM2MILE"}   <- Converts Argument in Kilometers to Miles

                   @{bold "KG2POUND"}   <- Converts Argument in Kilograms to Pounds
                   @{bold "POUND2KG"}   <- Converts Argument in Pounds to Kilograms

                   @{bold "CELSIUS2FAHREHEIT"}   <- Converts Argument in Celsius to Fahreheit
                   @{bold "FAHREHEIT2CELSIUS"}   <- Converts Argument in Fahreheit to Celsius
                   @{bold "CELSIUS2KELVIN"}   <- Converts Argument in Celsius to Kelvin
                   @{bold "KELVIN2CELSIUS"}   <- Converts Argument in Kelvin to Celsius
                   @{bold "KELVIN2FAHREHEIT"}   <- Converts Argument in Kelvin to Fahreheit
                   @{bold "FAHREHEIT2KELVIN"}   <- Converts Argument in Fahreheit to Kelvin

                   @{bold "ABOUT"}  <- Pop`s up small ABout Requester

                   @{bold "QUIT"}  <- Quits MeasConvRx (*ONLY WAY TO DO THAT*)

(ALL RESULTS ARE IN @{bold "RESULT"})

And Other Standard @{"MUI" LINK mui} ARexx Commands.

@ENDNODE
