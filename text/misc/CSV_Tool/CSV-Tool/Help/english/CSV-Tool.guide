@node MENUS "CSV-Tool Help:  MENUS"

@{white "@{b}Panel@{ub}"}: @{Menu_Title " Import "} @{Menu_Title " Format "} @{Menu_Title " Export "}

 @{Menu_Title " Project "}
 @{Menu_ItemKS " New             " "N"} - Create new and empty project.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Open...         " "O"} - Open an existing project file.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Save            " "S"} - Save the current project file.
 @{Menu_ItemKS " Save as...      " "A"} - Save the current project filer under new path/name.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Help            " "H"} - Shows this document.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " about CanDo...  " "?"} - Information about the underlieing programming language.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Quit            " "Q"} - Shutdown program.


@{white "@{b}Panel@{ub}"}: @{Menu_Title " Export "}

 @{Menu_Title " Edit "}
 @{Menu_ItemKS " Cut             " "X"} - Cut the whole text to clipboard.
 @{Menu_BR-Bar " Copy...         "}
     @{Menu_ItemKS " All         " "C"} - Copy the whole text to clipboard.
     @{Menu_ItemKS " Line        " "L"} - Copy the current line to clipboard.
     @{Menu_ItemKS " Word        " "W"} - Copy the current word to clipboard.
 @{Menu_ItemKS " Copy            " "C"} - .
 @{Menu_ItemKS " Paste           " "V"} - Paste clipboard contents at cursor position.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Replace         " "R"} - Replace the whole text with clipboard contents.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_BR-Bar " Delete...       "}
     @{Menu_ItemKS " All         " "E"} - Clear the whole text.
     @{Menu_ItemKS " to SOL      " "<"} - Delete to start of current line.
     @{Menu_ItemKS " to EOL      " ">"} - Delete to end of current line.
     @{Menu_ItemKS " Line        " "-"} - Delete the current line.
     @{Menu_ItemKS " Word        " "."} - Delete the current word.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_ItemKS " Clone Line      " "+"} - Clone the current line.
 @{Menu_ItemKS " Trim Line       " "#"} - Trim the current line.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_BR-Bar " Word Case to... "}
     @{Menu_ItemKS " UPPER       " "U"} - Upper case the current word.
     @{Menu_ItemKS " lower       " "\\"} - Lower Case the current word.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_BR-Bar " Search...       "}
     @{Menu_ItemKS " String      " "F"} - Open search requester.
     @{Menu_ItemKS " Next        " "G"} - Move to next found string.
     @{Menu_ItemKS " Word        " ","} - Move to next found of current word.
 @{Menu_BR-Bar "~~~~~~~~~~~~~~~~~~~~~~~~~"}
 @{Menu_BR-Bar " Replace...      "}
     @{Menu_ItemKS " String      " "P"} - Open search and replace requester.
     @{Menu_ItemKS " Next        " "B"} - Replace next found string.
     @{Menu_ItemKS " All         " "T"} - Replace all found strings.

@endnode

@node KEYS "CSV-Tool Help:  KEYBOARD"
@smartwrap
@font helvetica.font 13
@{jleft}@{lindent 8}

@{Title_Header "K E Y B O A R D"}
@{Title_String "The most important @{b}Shortcuts@{ub}"}
@{Title_Footer "for rapid functionen access."}
@{lindent 8}


@{white "@{b}Panel@{ub}"}: @{Menu_Title " Import "} @{Menu_Title " Format "} @{Menu_Title " Export "}@{par}

@{Key_Button "N"} - @{white "New"}@{par}

@{Key_Button "O"} - @{white "Open..."}@{par}

@{Key_Button "S"} - @{white "Save"}@{par}

@{Key_Button "A"} - @{white "Save as"}@{par}

@{Key_Button "H"} | @{Key_Pressed "Help"} - @{white "Help"}@{par}

@{Key_Button "Q"} - @{white "Quit"}@{par}


@{white "@{b}Panel@{ub}"}: @{Menu_Title " Export "}@{par}

@{Key_Button "X"} - @{white "Cut"}@{par}

@{Key_Button "C"} - @{white "Copy"}@{par}

@{Key_Button "V"} - @{white "Paste"}@{par}

@{Key_Button "R"} - @{white "Replace"}@{par}

@{Key_Button "L"} - @{white "Copy Line"}@{par}

@{Key_Button "W"} - @{white "Copy Word"}@{par}

@{Key_Button "E"} - @{white "Empty Text"}@{par}

@{Key_Button "<"} | @{Key_Pressed "Shift"} @{Key_Pressed "Back"} - @{white "Delete to SOL"}@{par}

@{Key_Button ">"} | @{Key_Pressed "Shift"} @{Key_Pressed "Del"} - @{white "Delete to EOL"}@{par}

@{Key_Button "-"} - @{white "Delete Line"}@{par}

@{Key_Button "."} - @{white "Delete Word"}@{par}

@{Key_Button "+"} - @{white "Clone Line"}@{par}

@{Key_Button "#"} - @{white "Trim Line"}@{par}

@{Key_Button "U"} - @{white "Upper Case"}@{par}

@{Key_Button "\\"} - @{white "Lower Case"}@{par}

@{Key_Button "F"} - @{white "Search..."}@{par}

@{Key_Button "G"} - @{white "Search Next"}@{par}

@{Key_Button ",."} - @{white "Search Word"}@{par}

@{Key_Button "P"} - @{white "Replace..."}@{par}

@{Key_Button "B"} - @{white "Replace Next"}@{par}

@{Key_Button "T"} - @{white "Replace All"}@{par}


@{Key_Pressed "F1"} --> @{Key_Pressed "F10"} - @{white "insert"} @{bold "[CELL_A]"} --> @{bold "[CELL_J]"}@{par}


@{Key_Pressed "Shift"} @{Key_Pressed "F1"} --> @{Key_Pressed "Shift"} @{Key_Pressed "F10"} - @{white "insert"} @{bold "[COLUMN_A]"} @{bold "[COLUMN_J]"}@{par}


@{Key_Pressed "Alt"} @{Key_Pressed "F1"} - @{white "insert"} @{bold "[FILENAME]"}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F2"} - @{white "insert"} @{bold "[FILECOMMENT]"}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F3"} - @{white "insert"} @{bold "[FILEDATE]"}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F4"} - @{white "insert"} @{bold "[FILETIME]"}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F5"} - @{white "insert"} @{bold "[FILESIZE]"}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F6"} - @{white "insert"} @{bold "[THEDATE]"}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F7"} - @{white "insert"} @{bold "[THETIME]"}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F8"} - @{white "insert"} @{bold "[INDEXFILE]"}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F9"} - @{white "insert"} @{bold "[RECORDFILE]"}@{par}

@{Key_Pressed "Alt"} @{Key_Pressed "F10"} - @{white "insert"} @{bold "[COUNT]"}@{par}
@{PARD}

@endnode

@node MOUSE "CSV-Tool Help:  MOUSE"
@smartwrap
@font helvetica.font 13
@{jleft}@{lindent 8}

@{Title_Header "M O U S E"}
@{Title_String "Something about what happens when dragging"}
@{Title_Footer "and dropping files over the program window."}
@{lindent 8}


@{bold "NOTE:"}@{lindent 24}
      If you drag a @{white "File"} and drop it over the window
from @{bold "CSV-Tool"}, the program will open the file as
project, after checking if it's of the right format.@{par}
If you drag a @{white "Folder"} and drop it over the window,
and @{white "current @{b}Panel@{ub}"} is @{Menu_Title " Export "},
the program will search in this path for the following files:@{par}

@{blue "Columnes.tpl EvenLines.tpl Footer.tpl Header.tpl OddLines.tpl Records.tpl"}@{par}

Each file that match will be loaded as template.
@{PARD}

@endnode

@node IMPORT "CSV-Tool Help:  Import"
@smartwrap
@font helvetica.font 13
@{jleft}@{lindent 8}

@{Title_Header "I M P O R T"}
@{Title_String "@{B}A@{UB} - Import of the data"}
@{Title_Footer "as CSV/TSV file in two steps."}


@{bold "Section I"}@{lindent 24}

Import File@{par}
@{" path:to/the/file                                      " link ""}@{"   " link ""}@{par}

First of all an import file must be selected (@{white "CSV"}/ @{white "TSV"} file).@{par}

Preview of the first three Lines@{par}
@{Menu_BR-Bar " ID;LastName;FirstName;ZIP;Adress;Country      "}@{par}
@{Menu_BR-Bar " 01;Doe;John;4011 NY;First Avenue 183;U.S.A. "}@{par}
@{Menu_BR-Bar " 02;Doe;Jane;4011 NY;First Avenue 183;U.S.A. "}@{par}
@{lindent 8}


@{bold "Section II"}@{lindent 24}

Cell Separator Character@{par}
@{"   " link ""} Comma @{tab}@{"   " link ""} Semicolon@{tab}@{"   " link ""} Tabulator@{tab}@{"   " link ""}@{" ; " link ""} Char@{tab}@{par}

Value Prefix / Suffix Character@{par}
@{"   " link ""} Dbl. Quote@{tab}@{"   " link ""} Sgl. Quote@{tab}@{"   " link ""} None@{tab}@{tab}@{"   " link ""}@{"   " link ""} Char@{tab}@{par}

Secondly the separator character and the value prefix and suffix character must be defined.
The program inquires the most usual character combinationes @{bold "automatically"}.@{par}

Preview of the Value Interpretation@{par}
@{Menu_Title " [COLUMN_A] "} @{Menu_Title " [COLUMN_B] "} @{Menu_Title " [COLUMN_C] "} @{Menu_Title " [COLUMN_D] "} @{Menu_Title " [COLUMN_E] "}@{par}
@{" 01                " link ""}@{" Doe              " link ""}@{" John             " link ""}@{" 4011 NY        " link ""}@{" First Avenue " link ""}@{par}

@{"   " link ""} @{white "use #1 Line as Columnes"}    @{"   " link ""} start at #2 Line@{par}
@{PARD}

@endnode

@node FORMAT "CSV-Tool Help:  Format"
@smartwrap
@font helvetica.font 13
@{jleft}@{lindent 8}

@{Title_Header "F O R M A T"}
@{Title_String "@{B}B@{UB} - @{U}Optional@{UU} formating"}
@{Title_Footer "of the values by columne."}


@{bold "Section I"}@{lindent 24}

@{uline "Optionally"} values can be formated by columne.@{par}

@{"    Columne    " link ""}@{" Original Value           " link ""}@{" Formated Value           " link ""}@{par}
@{Menu_Title  " [COLUMN_A]   01                              01                              "}@{par}
@{Menu_BR-Bar " [COLUMN_B]   Doe                            Doe                            "}@{par}
@{Menu_BR-Bar " [COLUMN_C]   John                           John                          "}@{par}
@{Menu_BR-Bar " [COLUMN_D]   4011 NY                      4011 NY                    "}@{par}
@{Menu_BR-Bar " [COLUMN_E]   First Avenue 183           First Avenue 183        "}@{par}
@{Menu_BR-Bar " [COLUMN_F]   U.S.A.                          U.S.A.                        "}@{par}
@{Menu_BR-Bar " [COUNT]         2                                 2                               "}@{par}

@{"   " link ""} @{white "trim String"} @{tab}@{"   " link ""} UPPER Case @{tab}@{"   " link ""} lower Case @{par}

@{bold "trim String"} - Removes leading and following spaces from the string,
furthermore all spaces between words except one. @{bold "UPPER Case"} -
Makes the string upper case or @{bold "lower Case"} lower case.@{par}

@{"   " link ""} @{white "if empty..."}@{tab}@{"                                       " link ""} insert this Value@{par}
  |_If empty use the following string.@{par}

@{"   " link ""} @{white "format numeric Value"}  @{"                           " link ""} with this Pattern@{par}
  |_Format numeric values by the following @{" Pattern " link "PATTERN"}.@{par}

@{"   " link ""} @{white "max. Chars"} @{tab}@{Menu_BR-Bar "   1   "} @{"                                                        " link ""}@{par}
  |_Reduces the output to a maximum number of characters.@{par}


@{"   " link ""} the [COUNT]er starts at @{tab}@{Menu_BR-Bar "    1    "} @{"                                       " link ""}@{par}
@{PARD}

@endnode

@node EXPORT "CSV-Tool Help:  Export"
@smartwrap
@font helvetica.font 13
@{jleft}@{lindent 8}

@{Title_Header "E X P O R T"}
@{Title_String "@{B}C@{UB} - Export of the data list "}
@{Title_Footer "as (HTML?) file in two steps."}


@{bold "Section I"}@{lindent 24}

First of all load or create the template files. Use the clipboard, the @{white "integrated Editor"} or external files.
The program supports fixed @{" variable names " link "PROLOG"} inside the template files.@{par}

Template Documents@{tab}@{tab}@{tab}@{tab}@{tab}@{tab}    @{"  Records  " link ""}@{par}
@{"   Header   " link ""}@{"  Columnes  " link ""}@{"  Even Lines  " link ""}@{"  Odd Lines  " link ""}@{"   Footer   " link ""}@{par}
@{" Line: <n> of <n> · Column: <n> of <n> · Size: <n> · ASCII: <n>  " link ""}@{par}

@{"   Load...    " link ""}@{"   Load Set   " link ""}@{tab}@{tab}@{tab}@{"   Save Set   " link ""}@{"  Save as   " link ""}@{par}

@{bold "Load Set"} - Select a Folder with template files.
The program will search in this path for the files: @{blue "Columnes.tpl EvenLines.tpl Footer.tpl Header.tpl OddLines.tpl Records.tpl"}
 and each file that match will be loaded as template.@{par}

@{bold "Save Set"} - Select a Folder to save the template files @{blue "Columnes.tpl EvenLines.tpl Footer.tpl Header.tpl OddLines.tpl Records.tpl"}
 to.
@{lindent 8}


@{bold "Section II"}@{lindent 24}

Export File@{par}
@{" path:to/the/file                                      " link ""}@{"   " link ""}@{par}

Secondly an export file path and name must be defined.@{par}

@{"   " link ""} @{white "...use HTML Char Encoding"}@{par}

@{"   " link ""} @{white "Record List"}@{par}
 |_ All Records will be written as List into the @{bold "Export File"}.@{par}

@{"   " link ""} single File@{par}
 |_ All Record Files will be appended to the @{bold "Export File"}.@{par}

@{"   " link ""} multiple Records@{par}
 |_ The Records will be exported as multiple Files.@{par}

Name @{"              " link ""} [COUNT] @{"              " link ""} .Suffix@{par}

Record Files Name and Suffix Definition.@{par}
@{pard}

@endnode

