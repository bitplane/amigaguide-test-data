@node PROLOG "CSV-Tool Help:  PROLOG"
@smartwrap
@font helvetica.font 13
@toc MAIN
@{jleft}@{lindent 8}

@{Title_Header "P R O L O G"}
@{Title_String "A few basics about the supported"}
@{Title_Footer "variable names in template files."}
@{lindent 8}


@{bold "T"}he program is a conversion tool for a variety of different CSV and TSV formats,
it supports the following variable names @{italic "(strings to be parsed and replaced) "}inside
the template files:@{par}


@{white "@{b}Template@{ub}"}: @{Menu_Title " Header "} @{Menu_Title " Footer "}@{par}

@{" [FILENAME] " link "EXPORT"} (without Suffix)@{par}

@{" [FILECOMMENT] " link "EXPORT"}@{par}

@{" [FILEDATE] " link "EXPORT"} (DD-Mon-YYYY)@{par}

@{" [FILETIME] " link "EXPORT"} (HH:MM:SS)@{par}

@{" [FILESIZE] " link "EXPORT"}@{par}

@{" [THEDATE] " link "EXPORT"}@{par}
    |_@{white "variable name for the"} @{bold "current Date"} (DD-Mon-YYYY)@{par}

@{" [THETIME] " link "EXPORT"}@{par}
    |_@{white "variable name for the"} @{bold "current Time"} (HH:MM:SS)@{par}


@{white "@{b}Template@{ub}"}: @{Menu_Title " Even Lines "} @{Menu_Title " Odd Lines "}@{par}

@{" [COUNT] " link "EXPORT"}@{par}
    |_@{white "variable name for the"} @{bold "Counter"}@{par}

@{" [CELL_A] " link "EXPORT"} to @{" [CELL_Z] " link "EXPORT"}@{par}
    |_@{white "variable names for the"} @{bold "Cell Values"}@{par}

@{" [INDEXFILE] " link "EXPORT"}@{par}
    |_@{white "variable name for the"} @{bold "Export File"}@{par}

@{" [RECORDFILE] " link "EXPORT"}@{par}
    |_@{white "variable name for the actual"} @{bold "Record File"}@{par}


@{white "@{b}Template@{ub}"}: @{Menu_Title " Columnes "}@{par}

@{" [COLUMN_A] " link "EXPORT"} to @{" [COLUMN_Z] " link "EXPORT"}@{par}
    |_@{white "variable names for the"} @{bold "Columne Titles"}@{par}


@{white "@{b}Template@{ub}"}: @{Menu_Title " Records "}@{par}

@{" [COUNT] " link "EXPORT"}@{par}
    |_@{white "variable name for the"} @{bold "Counter"}@{par}

@{" [CELL_A] " link "EXPORT"} to @{" [CELL_Z] " link "EXPORT"}@{par}
    |_@{white "variable names for the"} @{bold "Cell Values"}@{par}

@{" [COLUMN_A] " link "EXPORT"} to @{" [COLUMN_Z] " link "EXPORT"}@{par}
    |_@{white "variable names for the"} @{bold "Columne Titles"}@{par}

@{" [INDEXFILE] " link "EXPORT"}@{par}
    |_@{white "variable name for the"} @{bold "Export File"}@{par}

@{" [RECORDFILE] " link "EXPORT"}@{par}
    |_@{white "variable name for the actual"} @{bold "Record File"}@{par}

@{" [PREVRECORD] " link "EXPORT"}@{par}
    |_@{white "variable name for the previous"} @{bold "Record File"}@{par}

@{" [NEXTRECORD] " link "EXPORT"}@{par}
    |_@{white "variable name for the next"} @{bold "Record File"}@{par}
@{pard}

@endnode


@node LIBS "CSV-Tool Help:  LIBRARIES"
@smartwrap
@font helvetica.font 13
@{jleft}@{lindent 8}

@{Title_Header "L I B R A R I E S"}
