  17 @{" Center              " link "center"    } <CENTER>Centered part</CENTER>
  18 @{" Table structure     " link "table"     } <TABLE><TR><TH><TD>...</TD></TR>...
  19 @{" Table cell          " link "tc"        } <TH WIDTH="..." ALIGN="..." BGCOLOR="...">
  20 @{" Table caption       " link "caption"   } <CAPTION VALIGN="..." ALIGN="...">
  21 @{" Anchor              " link "anchor"    } <A NAME="this_is_an_anchor">
  22 @{" Map structure       " link "map"       } <MAP NAME="...">
  23 @{" Map sensible area   " link "area"      } <AREA SHAPE="..." COORDS="...">
  24 @{" Link                " link "link"      } <A HREF="file.html#anchor">
  25 @{" Image               " link "image"     } <IMG SRC="..." WIDTH="..." ALIGN="...">
  26 @{" Formular            " link "formular"  } <FORM METHOD="...">...</FORM>
