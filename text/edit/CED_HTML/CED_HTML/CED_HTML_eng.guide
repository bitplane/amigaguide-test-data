       5.11 @{" New line            " link "newline"   } <BR> or <WBR>
       5.12 @{" No new line         " link "nonewline" } <NOBR>unwrapped text</NOBR>
       5.13 @{" Horizontal bar      " link "bar"       } <HR WIDTH="..." ALIGN="..." NOSHADE>
