       5.15 @{" Remove all comments " link "remcomm"   } Delete <!-- Comments -->
       5.16 @{" Iso latin 1         " link "iso"       } Change special chars to ASCII code
       5.17 @{" Center              " link "center"    } <CENTER>Centered part</CENTER>
       5.18 @{" Table structure     " link "table"     } <TABLE><TR><TH><TD>...</TD></TR>...
       5.19 @{" Table cell          " link "tc"        } <TH WIDTH="..." ALIGN="..." BGCOLOR="...">
       5.20 @{" Table caption       " link "caption"   } <CAPTION VALIGN="..." ALIGN="...">
       5.21 @{" Anchor              " link "anchor"    } <A NAME="this_is_an_anchor">
       5.22 @{" Map structure       " link "map"       } <MAP NAME="...">
       5.23 @{" Map sensible area   " link "area"      } <AREA SHAPE="..." COORDS="...">
       5.24 @{" Link                " link "link"      } <A HREF="file.html#anchor">
       5.25 @{" Image               " link "image"     } <IMG SRC="..." WIDTH="..." ALIGN="...">
       5.26 @{" Formular            " link "formular"  } <FORM METHOD="...">...</FORM>
       5.27 @{" Formular line       " link "single"    } <INPUT NAME="..." TYPE="..." SIZE="...">
       5.28 @{" Formular block      " link "several"   } <TEXTAREA NAME="..." COLS="..." ROWS="...">
       5.29 @{" Formular list       " link "formlist"  } <SELECT NAME="..." SIZE="..."><OPTION>...
