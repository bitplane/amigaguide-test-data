@NODE "String" "String"

COMMAND     : String

 PARAMETERS : STRING/A

 DESCRIPTION: This command inserts the given string into the current insert
              position.  Please note that any string may be inserted
              including control characters but not the NULL character.

@ENDNODE

@NODE "SCRFRONT" "SCRFRONT"

COMMAND     : SCRFRONT

 PARAMETERS : NONE

 DESCRIPTION: Brings the SkoEd Screen to the front.

@ENDNODE

@NODE "UpUp" "UpUp"
@TOC "MAIN"

COMMAND     : UpUp

 PARAMETERS : NONE

 DESCRIPTION: This command moves the Cursor up 1 line, scrolling if needed.
              This routine attempts to keep the Cursor 1 line below the
              topline so that the line above the Cursor is always visible.
@ENDNODE

@NODE "DownDown" "DownDown"
@TOC "MAIN"

COMMAND     : DownDown

 PARAMETERS : NONE

 DESCRIPTION: This command moves the Cursor Down 1 line, scrolling if needed.
              This routine attempts to keep the Cursor 1 line above the
              bottomline so that the line below the Cursor is always
              visible.
@ENDNODE

@NODE "StartOfBlock" "StartOfBlock"
@TOC "MAIN"

COMMAND     : StartOfBlock

 PARAMETERS : NONE

 DESCRIPTION: This command moves the Cursor to the start of the current 
              Block.
@ENDNODE

@NODE "EndOfBlock" "EndOfBlock"
@TOC "MAIN"

COMMAND     : EndOfBlock

 PARAMETERS : NONE

 DESCRIPTION: This command moves the Cursor to the end of the current Block.

@ENDNODE

@NODE "Up" "Up"
@TOC "MAIN"

COMMAND     : Up

 PARAMETERS : NONE

 DESCRIPTION: This moves the Cursor up 1 line, scrolling if needed.

 See Also   : @{"Down" Link "Down"} @{"Left" Link "Left"} @{"Right" Link "Right"} @{"Page_Up" Link "Page_Up"} @{"Page_Down" Link "Page_Down"}
@ENDNODE

@NODE "Down" "Down"
@TOC "MAIN"

COMMAND     : Down

 PARAMETERS : NONE

 DESCRIPTION: This moves the Cursor Down 1 line, scrolling if needed.

 See Also   : @{"Up" Link "Up"} @{"Left" Link "Left"} @{"Right" Link "Right"} @{"Page_Up" Link "Page_Up"} @{"Page_Down" Link "Page_Down"}
@ENDNODE

@NODE "Left" "Left"
@TOC "MAIN"

COMMAND     : Left

 PARAMETERS : NONE

 DESCRIPTION: This moves the Cursor Left 1 character.  If the Start of a
              line is reached the the Cursor is move to the end of the line
              above.

 See Also   : @{"Up" Link "Up"} @{"Down" Link "Down"} @{"Right" Link "Right"} @{"Page_Up" Link "Page_Up"} @{"Page_Down" Link "Page_Down"}
@ENDNODE

@NODE "Right" "Right"
@TOC "MAIN"

COMMAND     : Right

 PARAMETERS : NONE

 DESCRIPTION: This moves the Cursor Right 1 character until you reach the
              maximum length of the line (Currently 4096 chars).

 See Also   : @{"Up" Link "Up"} @{"Down" Link "Down"} @{"Left" Link "Left"} @{"Page_Up" Link "Page_Up"} @{"Page_Down" Link "Page_Down"}
@ENDNODE

@NODE "Page_Up" "Page_Up"
@TOC "MAIN"

COMMAND     : Page_Up

 PARAMETERS : NONE

 DESCRIPTION: Move Cursor up 1 page.

 See Also   : @{"Up" Link "Up"} @{"Down" Link "Down"} @{"Left" Link "Left"} @{"Right" Link "Right"} @{"Page_Down" Link "Page_Down"}
@ENDNODE

@NODE "Page_Down" "Page_Down"
@TOC "MAIN"

COMMAND     : Page_Down

 PARAMETERS : NONE

 DESCRIPTION: Move Cursor down 1 page.

 See Also   : @{"Up" Link "Up"} @{"Down" Link "Down"} @{"Left" Link "Left"} @{"Right" Link "Right"} @{"Page_Up" Link "Page_Up"}
@ENDNODE

