@database TTX_Help_BRIEF.guide
@$VER: TTX_Help_BRIEF.guide 2.0 (28.2.94)
@author Jamie Clark

@node Main "Help on BRIEF emulation"

@{u}Basic Text Commands@{uu}

Backspace               @{b}[Backspace]@{ub}
Delete Line             @{b}[Alt]-D@{ub}
Insert new line         @{b}[Enter]@{ub}
Delete Character        @{b}[Del]@{ub}
Open Line               @{b}[Ctrl]-[Enter]@{ub}
Delete to End of Line   @{b}[Alt]-K@{ub}
Back Tab                @{b}[Shift]-[Tab]@{ub}
Tab Stop                @{b}[Tab]@{ub}
Delete Next Word        @{b}[Alt]-[Backspace]@{ub}
Delete Previous Word    @{b}[Ctrl]-[Backspace]@{ub}
Insert new indent line  @{b}[Return]@{ub}


@{u}Macros And Keystroke Recording@{uu}

Remember ON/OFF Toggle  @{b}[F7]@{ub}
Execute Command         @{b}[F10]@{ub}
Playback                @{b}[F8]@{ub}
Save Keystroke Macro    @{b}[Alt]-[F8]@{ub}
Load Keystroke Macro    @{b}[Alt]-[F7]@{ub}


@{u}Manipulating Buffers@{uu}

Buffer List             @{b}[Alt]-B@{ub}
Read File info Buffer   @{b}[Alt]-R@{ub}
Edit File               @{b}[Alt]-E@{ub}
Change Output File      @{b}[Alt]-O@{ub}
Previous Buffer         @{b}[Alt]-[Minus]@{ub}
Next Buffer             @{b}[Alt]-N@{ub}
Delete Current Buffer   @{b}[Ctrl]-[Minus]@{ub}
Write All and Exit      @{b}[Ctrl]-X@{ub}
Write Buffer            @{b}[Alt]-W@{ub}


@{u}Windows@{uu}

Change Window           @{b}[F1]@{ub}
Resize Window           @{b}[F2]@{ub}
Create Window           @{b}[F3]@{ub}
Delete Window           @{b}[F4]@{ub}
Quick Window Change     @{b}[Alt]-[Arrow]@{ub}
Zoom Winodw Toggle      @{b}[Alt]-[F2]@{ub}


@{u}Cursor Movement@{uu}

Down                    @{b}[CursorDown]@{ub}
Page Down               @{b}[PageDn]@{ub}
Left                    @{b}[CursorLeft]@{ub}
Page Up                 @{b}[PageUp]@{ub}
Right                   @{b}[CursorRight]@{ub}
Go to Line              @{b}[Alt]-G@{ub}
Up                      @{b}[CursorUp]@{ub}
Line to Center          @{b}[Ctrl]-C                or [NumericPad]-5@{ub}
Scroll Up               @{b}[Ctrl]-U@{ub}
Scroll Down             @{b}[Ctrl]-D@{ub}
End of Line             @{b}[End]@{ub}
Previous Word           @{b}[Ctrl]-[CursorLeft]@{ub}
Next Word               @{b}[Ctrl]-[CursorRight]@{ub}
Drop Bookmark           @{b}[Alt]-0@{ub} through @{b}[Alt]-9@{ub}
Go to Bookmark          @{b}[Alt]-J@{ub}
Line to Top             @{b}[Ctrl]-T@{ub}
Line to Bottom          @{b}[Ctrl]-B@{ub}
Beginning of Line       @{b}[Home]@{ub}
End of Window           @{b}[End] [End]             or [Ctrl]-[End]@{ub}
Top of Window           @{b}[Home] [Home]           or [Ctrl]-[Home]@{ub}
End of Buffer           @{b}[End] [End] [End]       or [Ctrl]-[PageDn]@{ub}
Top of Buffer           @{b}[Home] [Home] [Home]    or [Ctrl]-[PageUp]@{ub}


@{u}Marked Blocks@{uu}

Mark                    @{b}[Alt]-M@{ub}
Delete Block            @{b}[Del]@{ub}
Line Mark               @{b}[Alt]-L@{ub}
Print Block             @{b}[Alt]-P@{ub}
Column Mark             @{b}[Alt]-C@{ub}
Write Block             @{b}[Alt]-W@{ub}
Noninclusive Mark       @{b}[Alt]-A@{ub}
Paste from Scrap        @{b}[Ins]@{ub}
Copy Block to Scrap     @{b}[NumericPad]-+@{ub}
Cut Block to Scrap      @{b}[NumericPad]-[Minus]@{ub}
Outdent Block           @{b}[Shift]-[Tab]@{ub}
Indent Block            @{b}[Tab]@{ub}


@{u}Unmarked Blocks@{uu}

Cut Line to Scrap  @{b}[NumericPad]-[Minus]@{ub}
Copy Line to Scrap @{b}[NumericPad]-+@{ub}


@{u}Miscellaneous@{uu}

Exit                    @{b}[Alt]-X@{ub}
Help                    @{b}[Alt]-H@{ub} or @{b}[Help]@{ub}
Insert Mode Toggle      @{b}[Alt]-I@{ub}
Backup File Toggle      @{b}[Ctrl]-W@{ub}
Suspend BRIEF           @{b}[Alt]-Z                 or [Ctrl]-Z@{ub}
UnDo                    @{b}[NumericPad]-*          or [Alt]-U@{ub}
Display Version ID      @{b}[Alt]-V@{ub}
NumLock Toggle          @{b}[Shift]-[NumLock]@{ub}
Quote                   @{b}[Alt]-Q@{ub}


@{u}Searching And Translating@{uu}

Search Forward          @{b}[F5]@{ub} or @{b}[Alt]-S@{ub}
Translate Forward       @{b}[F6]@{ub} or @{b}[Alt]-T@{ub}
Search Backward         @{b}[Alt]-[F5]@{ub}
Translate Backward      @{b}[Alt]-[F6]@{ub}
Search Again            @{b}[Shift]-[F5]@{ub}
Translate Again         @{b}[Shift]-[F6]@{ub}
Case Sens. Toggle       @{b}[Ctrl]-[F5]@{ub}

@endnode
