@NODE MAIN "Wie baut man mit Scriba ein Amiga Guide"
@{JCENTER}@{U}W@{UU}@{U}i@{UU}@{U}e@{UU}@{U} @{UU}@{U}b@{UU}@{U}a@{UU}@{U}u@{UU}@{U}t@{UU}@{U} @{UU}@{U}m@{UU}@{U}a@{UU}@{U}n@{UU}@{U} @{UU}@{U}m@{UU}@{U}i@{UU}@{U}t@{UU}@{U} @{UU}@{U}S@{UU}@{U}c@{UU}@{U}r@{UU}@{U}i@{UU}@{U}b@{UU}@{U}a@{UU}@{U} @{UU}@{U}e@{UU}@{U}i@{UU}@{U}n@{UU}@{U} @{UU}@{U}A@{UU}@{U}m@{UU}@{U}i@{UU}@{U}g@{UU}@{U}a@{UU}@{U}G@{UU}@{U}u@{UU}@{U}i@{UU}@{U}d@{UU}@{U}e@{UU}

@{JCENTER}

@{JLEFT}1.) Scriba starten und auf Seite 1 die "Main" - Links schreiben.

@{JLEFT}     Die Seite 1 wird im Guide immer zu Erst nach dem Start angezeigt.

@{JLEFT}

@{JLEFT}2.) Alle weiteren Seiten werden zu einfachen "Nodes". Das heißt,

@{JLEFT}das sie zu Unterseiten im Guide werden.

@{JLEFT}

@{JCENTER}@{"Links " LINK "2"} schreiben

@{JCENTER}

@{JCENTER}

@{JCENTER} @{"Was" LINK "3"} geht sonst noch alles?

@{JCENTER}

@{JCENTER} @{"Was" LINK "4"} man nicht sieht!


@ENDNODE

@NODE 2 2
@{JCENTER}@{U}L@{UU}@{U}i@{UU}@{U}n@{UU}@{U}k@{UU}@{U}s@{UU}@{U} @{UU}@{U}s@{UU}@{U}c@{UU}@{U}h@{UU}@{U}r@{UU}@{U}e@{UU}@{U}i@{UU}@{U}b@{UU}@{U}e@{UU}@{U}n@{UU}

@{JCENTER}

@{JLEFT}Man tippt irgend ein Text. Nun markiert man mit einem Doppelklick ein Wort.

@{JLEFT}Anschließend geht man is das Menu/Format/Hyperlink.

@{JLEFT}Dort schreibt man im Textrequester die Seitennummer hinein, zu der man

@{JLEFT}springen will, wenn man den Knopf drückt.

@{JLEFT}

@{JLEFT}Has das geklappt, wird nun dieses Wort dauerhaft grau hinterlegt.

@{JLEFT}Wenn man nun auf dies grau hinterlegte Wort doppelklickt, springt

@{JLEFT}Scriba zu der angegebenen Seite.

@{JLEFT}

@{JLEFT}Schreibt man im Textrequester 1 rein, dann springt später das Guide zurück

@{JLEFT}zur Startseite.

@{JLEFT}

@{JLEFT}

@{JLEFT}Wichtig: Als Hyperlink wird nur EIN Wort akzeptiert !

@{JLEFT}


@ENDNODE

@NODE 3 3
@{JCENTER}@{U}W@{UU}@{U}a@{UU}@{U}s@{UU}@{U} @{UU}@{U}g@{UU}@{U}e@{UU}@{U}h@{UU}@{U}t@{UU}@{U} @{UU}@{U}s@{UU}@{U}o@{UU}@{U}n@{UU}@{U}s@{UU}@{U}t@{UU}@{U} @{UU}@{U}n@{UU}@{U}o@{UU}@{U}c@{UU}@{U}h@{UU}@{U} @{UU}@{U}a@{UU}@{U}l@{UU}@{U}l@{UU}@{U}e@{UU}@{U}s@{UU}@{U}?@{UU}

@{JCENTER}

@{JLEFT}Folgende Zeichenformatierungen werden von Scriba übernommen:

@{JLEFT}

@{JLEFT}Bold, Italic, Underline

@{JLEFT}

@{JLEFT}

@{JLEFT}

@{JLEFT}

@{JLEFT}Folgende Zeilenformatierung wird übernommen:

@{JLEFT}

@{JLEFT}Left, Center, Right


@ENDNODE

@NODE 4 4
@{JCENTER}@{U}W@{UU}@{U}a@{UU}@{U}s@{UU}@{U} @{UU}@{U}m@{UU}@{U}a@{UU}@{U}n@{UU}@{U} @{UU}@{U}n@{UU}@{U}i@{UU}@{U}c@{UU}@{U}h@{UU}@{U}t@{UU}@{U} @{UU}@{U}s@{UU}@{U}i@{UU}@{U}e@{UU}@{U}h@{UU}@{U}t@{UU}@{U}!@{UU}

@{JCENTER}

@{JLEFT}Selbst einige Dokument spezifische Daten wie der Titel, Ersteller, 

@{JLEFT}Kommentar und Subjekt werden in ein Guide mit reingepackt.

@{JLEFT}

@{JLEFT}Der Titel erscheind auf der Startseite oben im Fenster.

@{JLEFT}Der Ersteller wird im Guide als Creator eingetragen.

@{JLEFT}Der Kommentar füllt die Copyright - Zeile im Guide.

@{JLEFT}Das Subjekt stellt die Version-Zeile des Guides.

@{JLEFT}

@{JLEFT}Scriba packt außerdem als Remark sein Name mit rein.
@ENDNODE
