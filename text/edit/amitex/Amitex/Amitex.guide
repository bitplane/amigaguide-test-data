	@{"TIME    " LINK "TIME"} renvoie l'heure courante
	@{"TITLE   " LINK "TITLE"} choix du titre affiché dans la fenêtre
	@{"TOBACK  " LINK "TOBACK"} renvoie la fenêtre active en arrière-plan
	@{"TOFRONT " LINK "TOFRONT"} renvoie la fenêtre active en avant-plan
	@{"TRACE   " LINK "TRACE"} marquage d'un emplacement
	@{"TYPE    " LINK "TYPE"} renvoie le type d'un caractère
	@{"UNLOCK  " LINK "UNLOCK"} annule le verrouillage des actions utilisateur
