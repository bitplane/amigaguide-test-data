	@{"UNMARK  " LINK "UNMARK"} annulation du marquage d'un texte
	@{"UPPER   " LINK "UPPER"} conversion d'un texte en majuscules
	@{"VAL     " LINK "VAL"} conversion d'une chaîne de caractères en nombre
