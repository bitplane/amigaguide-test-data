	@{"SUPBLOCK" LINK "SUPBLOCK"} effacement du bloc de texte
	@{"SUPLINES" LINK "SUPLINES"} suppression de lignes de texte
	@{"TESTCASE" LINK "TESTCASE"} mode de recherche (sensibilitť aux majuscules/minuscules)
	@{"TESTTEXT" LINK TESTTEXT} vťrification de l'orthographe d'une chaÓne
	@{"TEXTMARK" LINK "TEXTMARK"} renvoie le texte marquť (ObsolŤte)
	@{"TEXTPATH" LINK TEXTPATH} chemin du programme
	@{"TEXTS   " LINK TEXTS} nombre et noms des textes
	@{"TEXTSEL " LINK TEXTSEL} renvoie le texte marquť
