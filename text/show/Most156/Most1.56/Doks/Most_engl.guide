@Node "Scrolling" "Most_engl.guide/Scrolling"
@Next "Searching"
@Toc "Keyboard commands"

Scrolling
=========

one line forwards
     @{b}CURSOR DOWN@{ub} @{b}NUMERICPAD 2@{ub} @{b}RETURN@{ub} @{b}ENTER@{ub}

one line backwards
     @{b}CURSOR UP@{ub} @{b}NUMERICPAD 8@{ub} @{b}DELETE@{ub}

one page forwards
     @{b}SHIFT CURSOR DOWN@{ub} @{b}SPACE@{ub} @{b}PAGE DOWN@{ub}

one page backwards
     @{b}SHIFT CURSOR UP@{ub} @{b}BACKSPACE@{ub} @{b}PAGE UP@{ub} @{b}b@{ub}

Jump to beginning of text
     @{b}HOME@{ub} @{b}<@{ub}

Jump to end of text
     @{b}END@{ub} @{b}>@{ub}

oen column to the right
     @{b}CURSOR RIGHT@{ub} @{b}NUMERICPAD 6@{ub}

one column to the left
     @{b}CURSOR LEFT@{ub} @{b}NUMERICPAD 4@{ub}

8 columns to the right
     @{b}SHIFT CURSOR RIGHT@{ub}

8 columns to the left
     @{b}SHIFT CURSOR LEFT@{ub}

jump to first column
     @{b}NUMERICPAD 5@{ub}


@EndNode

