@node "elem_intro" "Einleitung" 
@toc xml
@{jleft}Die XML-Datei muss mit folgenden Zeilen beginnen:@{line}
<?xml version="1.0" encoding="iso-8859-1"?>@{line}
<!DOCTYPE guide SYSTEM "xmlguide.dtd">@{line}
<?xml-stylesheet type="text/xml" href="htmlguide.xsl"?>@{line}@{line}@{par}
@{jleft}Falls Du Dich über das 'htmlguide.xsl' wunderst: Manche Webbrowser können XML-Dateien parsen. Eine geeignete
XSL-Datei für das HTML-Format muss allerdings erst noch erstellt werden.@{line}@{par}
@endnode

@node "elem_guide" "guide" 
@toc xml
@{jleft}@{u}@{b}guide@{ub}@{uu}@{line}@{par}
@{jleft}Dies ist das Basis-Element in der XML-Datei.@{line}@{par}
@{jleft}@{u}Elternelemente@{uu}@{line}@{par}
@{jleft}keine@{line}@{par}
@{jleft}@{u}Kindelemente@{uu}@{line}@{par}
@{jleft}@{"author" link "elem_author"}, @{"version" link "elem_version"}, @{"master" link "elem_master"}, @{"copyright" link "elem_copyright"}, @{"node" link "elem_node"}@{line}@{par}
@{jleft}@{u}Attribute@{uu}@{line}@{par}
@{jleft}@{u}@{i}database@{ui}@{uu}@{line}@{par}
@{jleft}erforderlich; der String wird im Amigaguide hinter 'database' eingetragen.@{line}@{par}
@{jleft}@{u}@{i}index@{ui}@{uu}@{line}@{par}
@{jleft}optional; schaltet die Index-Funktion ein. Es wird ein Knoten mit dem angegebnen Namen erzeugt. In diesem Knoten werden
alle Begriffe, die zwischen <index>...</index> stehen als Verknüpfungen eingetragen.@{line}@{par}
@endnode

@node "elem_author" "author" 
@toc xml
@{jleft}@{u}@{b}author@{ub}@{uu}@{line}@{par}
@{jleft}Hier kann der Name des Autors angegeben werden.@{line}@{par}
@{jleft}@{u}Elternelemente@{uu}@{line}@{par}
@{jleft}@{"guide" link "elem_guide"}@{line}@{par}
@{jleft}@{u}Kindelemente@{uu}@{line}@{par}
@{jleft}keine@{line}@{par}
@{jleft}@{u}Attribute@{uu}@{line}@{par}
@{jleft}keine@{line}@{par}
@endnode

@node "elem_version" "version" 
@toc xml
@{jleft}@{u}@{b}version@{ub}@{uu}@{line}@{par}
@{jleft}Dient zur Angabe Versionsstrings in der Form 'name version.revision (tag.monat.jahr)'@{line}@{par}
@{jleft}@{u}Elternelemente@{uu}@{line}@{par}
@{jleft}@{"guide" link "elem_guide"}@{line}@{par}
@{jleft}@{u}Kindelemente@{uu}@{line}@{par}
@{jleft}keine@{line}@{par}
@{jleft}@{u}Attribute@{uu}@{line}@{par}
@{jleft}keine@{line}@{par}
@endnode

