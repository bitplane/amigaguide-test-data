@database "doc-en"
@smartwrap

@index index
@author Matthias Rustler
@$VER: doc-en.guide 0.1 (7.12.2005)
@master doc-de.xml
@node "MAIN" "English guide for XMLGuide" 
@{jcenter}@{u}@{b}Project: xmlguide@{ub}@{uu}@{line}@{par}
@{jleft}@{"German version" link "doc-de.guide/MAIN"}@{line}@{par}
@{jleft}This project makes it possible to write guides in XML format. I have created a DTD and a XSL file.
With the help of a XSL processor you can create an Amigaguide file from the XML file. With the right XSL files you could
output other file types like HTML.@{line}@{par}
@{jleft}Because XSL is a programming language there are some features which aren't part of Amigaguide. With the parent attribute
nodes can be inserted into a tree structure. This makes it possible to automatically create tables of contents. A click at the
'Contents' button of Multiview jumps to the parent node. Also it is possible to mark words which go to the index node.@{line}@{par}
@{jleft}@{line}@{par}
@{jleft}@{u}@{b}Some definitions@{ub}@{uu}@{line}@{par}
@{jleft}@{u}XML (Extensible Markup Language)@{uu}@{line}@{par}
@{jleft}It's a language to store data in a tree like structure.@{line}@{par}
@{jleft}@{u}DTD (Document Type Definition)@{uu}@{line}@{par}
@{jleft}Defines the structure of a XML document.@{line}@{par}
@{jleft}@{u}XSLT (Extensible Stylesheet Language Transformations)@{uu}@{line}@{par}
@{jleft}It's a programming language to transform XML documents.@{line}@{par}
@{jleft}@{line}@{par}
@{jcenter}@{u}@{b}Table of Contents@{ub}@{uu}@{line}@{par}
@{jcenter}@{"Structure of the XML file" link "xml"}@{line}
@{"Process" link "ablauf"}@{line}
@{"Contact" link "Kontakt"}@{line}
@{par}
@endnode

@node "xml" "Structure of the XML file" 
@toc MAIN
@{jcenter}@{u}@{b}Table of Contents@{ub}@{uu}@{line}@{par}
@{jcenter}@{"Introduction" link "elem_intro"}@{line}
@{"guide" link "elem_guide"}@{line}
@{"author" link "elem_author"}@{line}
@{"version" link "elem_version"}@{line}
@{"master" link "elem_master"}@{line}
@{"copyright" link "elem_copyright"}@{line}
@{"node" link "elem_node"}@{line}
@{"p" link "elem_p"}@{line}
@{"link" link "elem_link"}@{line}
@{"elink" link "elem_elink"}@{line}
@{"h" link "elem_h"}@{line}
@{"contents" link "elem_contents"}@{line}
@{"index" link "elem_index"}@{line}
@{"br" link "elem_br"}@{line}
@{par}
@endnode

@node "elem_intro" "Introduction" 
@toc xml
@{jleft}The XML file must start with the following lines:@{line}
<?xml version="1.0" encoding="iso-8859-1"?>@{line}
<!DOCTYPE guide SYSTEM "xmlguide.dtd">@{line}
<?xml-stylesheet type="text/xml" href="htmlguide.xsl"?>@{line}@{line}@{par}
@{jleft}If you wonder about the 'htmlguide.xsl': Some web browsers are able to parse XML files. A XSL file to create HTML files has
yet to be written.@{line}@{par}
@endnode

@node "elem_guide" "guide" 
@toc xml
@{jleft}@{u}@{b}guide@{ub}@{uu}@{line}@{par}
@{jleft}This is the base element of the XML file.@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}@{"author" link "elem_author"}, @{"version" link "elem_version"}, @{"master" link "elem_master"}, @{"copyright" link "elem_copyright"}, @{"node" link "elem_node"}@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}@{u}@{i}database@{ui}@{uu}@{line}@{par}
@{jleft}required; the string will be inserted in the Amigaguide behind 'database'.@{line}@{par}
@{jleft}@{u}@{i}index@{ui}@{uu}@{line}@{par}
@{jleft}optional; switches on the index function. A node with the given name will be created. All words between
<index>...</index> will be inserted as links to this node.@{line}@{par}
@endnode

@node "elem_author" "author" 
@toc xml
@{jleft}@{u}@{b}author@{ub}@{uu}@{line}@{par}
@{jleft}This is for the name of the author.@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"guide" link "elem_guide"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@endnode

@node "elem_version" "version" 
@toc xml
@{jleft}@{u}@{b}version@{ub}@{uu}@{line}@{par}
@{jleft}This is for a version string in the format 'name version.revision (day.month.year)'@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"guide" link "elem_guide"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@endnode

@node "elem_master" "master" 
@toc xml
@{jleft}@{u}@{b}master@{ub}@{uu}@{line}@{par}
@{jleft}This is for a reference to the original document.@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"guide" link "elem_guide"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@{jleft}@{u}Attributes@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@endnode

@node "elem_copyright" "copyright" 
@toc xml
@{jleft}@{u}@{b}copyright@{ub}@{uu}@{line}@{par}
@{jleft}This is for a copyright hint.@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"guide" link "elem_guide"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@endnode

@node "elem_node" "node" 
@toc xml
@{jleft}@{u}@{b}node@{ub}@{uu}@{line}@{par}
@{jleft}Creates a new node. Take care that a node with name 'MAIN' exists. Otherwise nothing is visible when opening the Amigaguide file.@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"guide" link "elem_guide"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}@{"p" link "elem_p"}, @{"h1" link "elem_h"}, @{"h2" link "elem_h"}, @{"h3" link "elem_h"}, @{"contents" link "elem_contents"}@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}@{u}@{i}name@{ui}@{uu}@{line}@{par}
@{jleft}required name of node@{line}@{par}
@{jleft}@{u}@{i}title@{ui}@{uu}@{line}@{par}
@{jleft}optional title string of node@{line}@{par}
@{jleft}@{u}@{i}parent@{ui}@{uu}@{line}@{par}
@{jleft}optional parent node; this will be used for tables of contents. A click at 'Contents' in Multiview jumps to the given parent node.@{line}@{par}
@endnode

@node "elem_p" "p" 
@toc xml
@{jleft}@{u}@{b}p@{ub}@{uu}@{line}@{par}
@{jleft}Creates a paragraph.@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"node" link "elem_node"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}@{"index" link "elem_index"}, @{"br" link "elem_br"}, @{"link" link "elem_link"}@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}@{u}@{i}align@{ui}@{uu}@{line}@{par}
@{jleft}optional; possible values: left, right or center@{line}@{par}
@endnode

@node "elem_link" "link" 
@toc xml
@{jleft}@{u}@{b}link@{ub}@{uu}@{line}@{par}
@{jleft}Creates a button which jumps when clicked to the given node. The string between start and end tag becomes the button description.@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"p" link "elem_p"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}@{u}@{i}node@{ui}@{uu}@{line}@{par}
@{jleft}Name of the target node.@{line}@{par}
@endnode

@node "elem_elink" "elink" 
@toc xml
@{jleft}@{u}@{b}elink@{ub}@{uu}@{line}@{par}
@{jleft}Creates a button which opens an extern file. The string between start and end node will be used as description.@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"p" link "elem_p"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}@{u}@{i}path@{ui}@{uu}@{line}@{par}
@{jleft}requird; contains path to other file.@{line}@{par}
@{jleft}@{u}@{i}node@{ui}@{uu}@{line}@{par}
@{jleft}optional; name of the node. When not given 'MAIN' will be used.@{line}@{par}
@{jleft}@{u}@{i}suffix@{ui}@{uu}@{line}@{par}
@{jleft}possible values: "keep" und "add". "keep" is the default. "keep" means the path is used unchanged.
With add "add" the XSLT processor has to append a suffix, e. g. ".guide" for Amigaguide files or ".html" for Html files.@{line}@{par}
@endnode

@node "elem_h" "h" 
@toc xml
@{jleft}@{u}@{b}h1@{ub}@{uu}@{line}@{par}
@{jleft}@{u}@{b}h2@{ub}@{uu}@{line}@{par}
@{jleft}@{u}@{b}h3@{ub}@{uu}@{line}@{par}
@{jleft}Headline with grade 1, 2 or 3.@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"node" link "elem_node"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}@{u}@{i}align@{ui}@{uu}@{line}@{par}
@{jleft}optional; possible values: left, right or center@{line}@{par}
@endnode

@node "elem_contents" "contents" 
@toc xml
@{jleft}@{u}@{b}contents@{ub}@{uu}@{line}@{par}
@{jleft}Creates a table of contents at the given place. Links will be created for all nodes which parent attribute leads to the current node.@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"p" link "elem_p"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}@{u}@{i}align@{ui}@{uu}@{line}@{par}
@{jleft}optional; possible values: left, right or center@{line}@{par}
@endnode

@node "elem_index" "index" 
@toc xml
@{jleft}@{u}@{b}index@{ub}@{uu}@{line}@{par}
@{jleft}Der string between <index>...<index> will be inserted as link into the node "index".@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"p" link "elem_p"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@endnode

@node "elem_br" "br" 
@toc xml
@{jleft}@{u}@{b}br@{ub}@{uu}@{line}@{par}
@{jleft}Creates a line break. It's an empty element and must be written like: <br />.@{line}@{par}
@{jleft}@{u}parent elements@{uu}@{line}@{par}
@{jleft}@{"p" link "elem_p"}@{line}@{par}
@{jleft}@{u}child elements@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@{jleft}@{u}attributes@{uu}@{line}@{par}
@{jleft}none@{line}@{par}
@endnode

@node "ablauf" "Process" 
@toc MAIN
@{jleft}@{u}@{b}Process@{ub}@{uu}@{line}@{par}
@{jleft}Write original document in XML format. Take care about the rules of XML.@{line}
All tags must be closed (<p>...</p>);
Empty Tags must be written like: <br />.@{line}
< > and " must be written as &lt;, &gt; and &quot.@{line}@{par}
@{jleft}Translate the document with a XSLT processor to an Amigaguide document.@{line}@{par}
@{jleft}@{u}xsltproc@{uu}@{line}@{par}
@{jleft}xsltproc can be downloaded from Aminet.@{line}Example call: xsltproc -o doc-de.guide xmlguide.xsl doc-de.xml@{line}@{par}
@{jleft}@{u}xalan-c@{uu}@{line}@{par}
@{jleft}xalan isn't available for Amiga to my knowledge. Advantage is the more penible handling of IDREF attributes.@{line}@{par}
@endnode

