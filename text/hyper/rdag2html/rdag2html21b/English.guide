@DATABASE "RDAG2HTML.guide"
@NODE "Main" "Rexx Does AmigaGuideź 2 HTML"
@TOC "MAIN"

	RDAG2HTML 2.1b - Rexx Does AmigaGuideź To HTML

	RDAG2HTML is a ARexx program, which is able to convert
	your AmigaGuideź documents to HTML.

	© 1995 - 1997  Michael Ranner

	@{"Legal, Disclaimer" LINK "Legal" 0}
	@{"Features" LINK "Features" 0}
	@{"Installation" LINK "Install" 0}
	@{"Usage" LINK "Usage" 0}
	@{"Changes, History" LINK "History" 0}
	@{"Author, Support" LINK "Author" 0}
	@{"Bugreports and Suggestions" LINK "Bugs" 0}

@ENDNODE

