@node "Overview" "Overview"
@title "GuideMaker Overview"
@tab 23
@remark @{" Screen " SYSTEM "RUN setenv gmts `GetTopScreen` +
@remark MULTIVIEW WINDOWWIDTH 800 WINDOWHEIGHT 700 GMScreen.jpg PUBSCREEN $gmts +
@remark unsetenv gmts"}:@{lindent 8}@{par}
